@using Simetric.Services.ESign
@inject AuthenticationStateProvider AuthStateProvider
@inject IMenuService MenuService
@inject IEDeclaraMenuService EDeclaraMenuService
@inject EmisorOnboardingService EmisorOnboardingService
@inject EmisionControlService EmisionControlService
@inject MenuStateService MenuStateService 
@inject NavigationManager NavManager

<div class="nav-shell @(sidebarOpen ? "is-open" : string.Empty)">
    <div class="nav-toggle-wrap">
        <button type="button" class="nav-toggle" @onclick="ToggleSidebar" aria-label="Abrir menu">
