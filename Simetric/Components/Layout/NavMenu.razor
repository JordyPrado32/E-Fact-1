    private async Task<bool> RequiereConfiguracionInicialAsync(ClaimsPrincipal user)
    {
        if (isSuperAdmin ||
            IsEContaxContext ||
            IsEDeclaraContext ||
            IsESignContext ||
            !int.TryParse(user.FindFirst("IdUsuario")?.Value, out var idUsuario) ||
            idUsuario <= 0)
        {
            return false;
        }

        await EmisorOnboardingService.RefreshRequirementAsync(idUsuario);
        var estadoEmision = await EmisionControlService.ObtenerEstadoAsync(idUsuario);

        return EmisorOnboardingService.RequiresInitialSetup ||
               !estadoEmision.PuedeEmitir;
    }

