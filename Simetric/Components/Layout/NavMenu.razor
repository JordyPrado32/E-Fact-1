            }

            StateHasChanged();
        });
    }
    private void AsegurarVistasModulosPadre()
    {
        AsegurarVistaModuloPadre("Tutoriales", "/tutoriales", "ri-question-line");
        AsegurarVistaModuloPadre("Soporte", "/soporte", "ri-customer-service-2-line");
        AsegurarVistaModuloPadre("Cuentas por cobrar", "/cuentas-por-cobrar", "ri-wallet-3-line");
        AsegurarMenuHijo("Cuentas por cobrar", "Registro de abonos", "/cuentas-por-cobrar", "ri-hand-coin-line");
        AsegurarMenuHijo("Cuentas por cobrar", "Estado de cuenta", "/cuentas-por-cobrar/estado-cuenta", "ri-file-list-3-line");


        // Configuración con hijo Perfil
        AsegurarVistaModuloPadre("Configuracion", "/configuracion", "ri-settings-3-line");
        AsegurarMenuHijo("Configuracion", "Perfil", "/perfil", "ri-user-settings-line");
        if (!IsEDeclaraContext && !IsESignContext)
        {
            AsegurarMenuHijo("Configuracion", "Firma", "/firma", "ri-shield-keyhole-line");
        }
        
        if (IsEDeclaraContext)
        {
            AsegurarMenuHijo("Configuracion", "Suscripción", "/e-declara/configuracion/suscripcion", "ri-bank-card-line");
        }
    }

    private void AsegurarVistaModuloPadre(string nombreMenu, string rutaMenu, string iconoMenu)
    {
        var menuExistente = listadoMenus.FirstOrDefault(m => CoincideNombreMenu(m, nombreMenu));

        if (menuExistente is not null)
        {
            menuExistente.IdMenuPadre = 0;
            menuExistente.RutaMenu = string.IsNullOrWhiteSpace(menuExistente.RutaMenu)
                ? rutaMenu
                : menuExistente.RutaMenu;
            menuExistente.IconoMenu = string.IsNullOrWhiteSpace(menuExistente.IconoMenu)
                ? iconoMenu
                : menuExistente.IconoMenu;
            return;
        }

        var hijoDelModulo = listadoMenus.FirstOrDefault(m =>
            m.IdMenuPadre != 0 &&
            !string.IsNullOrWhiteSpace(m.RutaMenu) &&
            m.RutaMenu.Trim().StartsWith($"{rutaMenu}/", StringComparison.OrdinalIgnoreCase));

        listadoMenus.Add(new Simetric.Models.Menu
        {
            IdMenu = hijoDelModulo?.IdMenuPadre ?? ObtenerIdMenuSintetico(nombreMenu),
            IdMenuPadre = 0,
            NombreMenu = nombreMenu,
            RutaMenu = rutaMenu,
            IconoMenu = iconoMenu,
            EstadoMenu = true
        });
    }
    private void AsegurarMenuHijo(string nombrePadre, string nombreHijo, string rutaHijo, string iconoHijo)
    {
        var padre = listadoMenus.FirstOrDefault(m => CoincideNombreMenu(m, nombrePadre));
        if (padre is null) return;

        if (CoincideRutaMenu(padre.RutaMenu, rutaHijo) ||
            listadoMenus.Any(m => CoincideRutaMenu(m.RutaMenu, rutaHijo)))
        {
            return;
        }

        var yaExiste = listadoMenus.Any(m =>
            m.IdMenuPadre == padre.IdMenu && CoincideNombreMenu(m, nombreHijo));
        if (yaExiste) return;

        listadoMenus.Add(new Simetric.Models.Menu
        {
            IdMenu = ObtenerIdMenuSintetico($"{nombrePadre}:{nombreHijo}"),
            IdMenuPadre = padre.IdMenu,
            NombreMenu = nombreHijo,
            RutaMenu = rutaHijo,
            IconoMenu = iconoHijo,
            EstadoMenu = true
        });
    }

    private static bool CoincideRutaMenu(string? rutaActual, string? rutaObjetivo) =>
        !string.IsNullOrWhiteSpace(rutaActual) &&
        !string.IsNullOrWhiteSpace(rutaObjetivo) &&
        string.Equals(
            rutaActual.Trim().TrimEnd('/'),
            rutaObjetivo.Trim().TrimEnd('/'),
            StringComparison.OrdinalIgnoreCase);

    private static string? NormalizarRutaMenu(string? ruta) =>
        string.IsNullOrWhiteSpace(ruta) ? null : ruta.Trim().TrimEnd('/').ToLowerInvariant();

    private static string? NormalizarNombreMenu(string? nombreMenu) =>
        string.IsNullOrWhiteSpace(nombreMenu) ? null : nombreMenu.Trim().ToLowerInvariant();

    private static List<Simetric.Models.Menu> DeduplicarMenus(IEnumerable<Simetric.Models.Menu> menus) =>
        menus
            .GroupBy(menu => menu.IdMenu != 0
                ? $"id:{menu.IdMenu}"
                : $"padre:{menu.IdMenuPadre}|nombre:{NormalizarNombreMenu(menu.NombreMenu)}|ruta:{NormalizarRutaMenu(menu.RutaMenu)}")
            .Select(grupo => grupo
                .OrderByDescending(menu => !string.IsNullOrWhiteSpace(menu.RutaMenu))
                .ThenByDescending(menu => !string.IsNullOrWhiteSpace(menu.IconoMenu))
                .First())
            .OrderBy(menu => menu.IdMenuPadre)
            .ThenBy(menu => menu.NombreMenu)
            .ToList();

    private static int ObtenerIdMenuSintetico(string nombreMenu) =>
        -Math.Abs(StringComparer.OrdinalIgnoreCase.GetHashCode(nombreMenu));

    private bool IsEContaxPath(string location) => EContaxRoutes.IsEContaxPath(NavManager, location);
    private bool IsDemoPath(string location) =>
        NavManager.ToBaseRelativePath(location).StartsWith("demo", StringComparison.OrdinalIgnoreCase);
