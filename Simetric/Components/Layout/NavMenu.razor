@code {
    private readonly List<Simetric.Models.Menu> listadoMenus = new();
    private bool isLoading = true;
    private bool sidebarOpen;
    private int menuAbiertoId;
    private bool isAssociatedUser;
    private bool isSuperAdmin;
    private bool requiresAccountSetup;
    private bool? _lastIsEDeclaraContext;
    private bool? _lastIsEContaxContext;
    private bool? _lastIsESignContext;
    private bool IsEContaxContext => IsEContaxPath(NavManager.Uri);
    private bool IsEDeclaraContext => IsEDeclaraPath(NavManager.Uri);
    private bool IsESignContext => IsESignPath(NavManager.Uri);
    private bool IsDemoContext => IsDemoPath(NavManager.Uri);

    private bool IsEDeclaraPath(string location) => EDeclaraRoutes.IsEDeclaraPath(NavManager, location);
    private bool IsESignPath(string location) => ESignRoutes.IsESignPath(NavManager, location);

    protected override async Task OnInitializedAsync()
    {
        EmisorOnboardingService.Changed += OnOnboardingChanged;
        EmisionControlService.Changed += OnEmisionChanged;
        MenuStateService.OnMenuChanged += HandleMenuChanged; // Escucha los cambios aquí.
        NavManager.LocationChanged += OnLocationChanged;
        _lastIsEDeclaraContext = IsEDeclaraContext;
        _lastIsEContaxContext = IsEContaxContext;
        _lastIsESignContext = IsESignContext;
        await CargarMenus();
    }

    public void Dispose()
    {
        EmisorOnboardingService.Changed -= OnOnboardingChanged;
        EmisionControlService.Changed -= OnEmisionChanged;
        NavManager.LocationChanged -= OnLocationChanged;
        MenuStateService.OnMenuChanged -= HandleMenuChanged; // Se desconecta aquí.
    }

    // Este método refresca el menú sin requerir F5.
    private async void HandleMenuChanged()
    {
        await CargarMenus();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CloseSidebar()
    {
        sidebarOpen = false;
    }

    private void ToggleSubmenu(int id)
    {
        menuAbiertoId = menuAbiertoId == id ? 0 : id;
    }

    private IEnumerable<Simetric.Models.Menu> GetMenusPadreOrdenados() =>
        listadoMenus
            .Where(m => m.IdMenuPadre == 0 && !CoincideNombreMenu(m, "Inicio"))
            .OrderBy(m => ObtenerPrioridadMenuPadre(m))
            .ThenBy(m => m.OrdenMenu ?? 9999)
            .ThenBy(m => m.IdMenu);

    private IEnumerable<Simetric.Models.Menu> GetMenusHijosOrdenados(int idPadre)
    {
        var padre = listadoMenus.FirstOrDefault(m => m.IdMenu == idPadre);

        return listadoMenus
            .Where(m => m.IdMenuPadre == idPadre && !CoincideRutaMenu(m.RutaMenu, padre?.RutaMenu))
            .GroupBy(m => NormalizarRutaMenu(m.RutaMenu) ?? $"menu:{m.IdMenu}")
            .Select(g => g.First())
            .OrderBy(m => m.OrdenMenu ?? 9999)
            .ThenBy(m => m.IdMenu);
    }


    private static int ObtenerPrioridadMenuPadre(Simetric.Models.Menu menu)
    {
        if (EsMenuConfiguracion(menu))
            return 90;

        if (EsMenuTutoriales(menu) || EsMenuAyuda(menu))
            return 91;

        if (EsMenuSoporte(menu))
            return 92;

        return 0;
    }


    private static bool EsMenuConfiguracion(Simetric.Models.Menu menu) =>
        CoincideNombreMenu(menu, "Configuracion");

    private static bool EsMenuAyuda(Simetric.Models.Menu menu) =>
        CoincideNombreMenu(menu, "Ayuda");

    private static bool EsMenuTutoriales(Simetric.Models.Menu menu) =>
        CoincideNombreMenu(menu, "Tutoriales")
        || CoincideRutaMenu(menu.RutaMenu, "/tutoriales")
        || CoincideRutaMenu(menu.RutaMenu, "/ayuda/tutoriales");

    private static bool EsMenuSoporte(Simetric.Models.Menu menu) =>
        CoincideNombreMenu(menu, "Soporte")
        || CoincideRutaMenu(menu.RutaMenu, "/soporte");

    private static bool CoincideNombreMenu(Simetric.Models.Menu menu, string nombreObjetivo) =>
        !string.IsNullOrWhiteSpace(menu.NombreMenu) &&
        CultureInfo.InvariantCulture.CompareInfo.Compare(
            menu.NombreMenu.Trim(),
            nombreObjetivo,
            CompareOptions.IgnoreCase | CompareOptions.IgnoreNonSpace) == 0;

    private static string GetMenuTexto(Simetric.Models.Menu menu) =>
        EsMenuClientesProveedores(menu)
            ? "Clientes / Proveedores"
            : menu.NombreMenu;

    private static string? GetRutaMenuVisible(Simetric.Models.Menu menu)
    {
        if (EsMenuClientesProveedores(menu))
        {
            return "/clientes";
        }

        return string.IsNullOrWhiteSpace(menu.RutaMenu) ? null : menu.RutaMenu.Trim();
    }

    private static bool EsMenuClientesProveedores(Simetric.Models.Menu menu) =>
        CoincideRutaMenu(menu.RutaMenu, "/clientes") ||
        CoincideNombreMenu(menu, "Clientes") ||
        CoincideNombreMenu(menu, "Clientes / Proveedores") ||
        CoincideNombreMenu(menu, "Clientes/Proveedores");

    private async Task CargarMenus()
    {
        try
        {
            isLoading = true;
            listadoMenus.Clear();

            if (IsEContaxContext)
            {
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                isSuperAdmin = string.Equals(
                    user.FindFirst("IdTipoUsuario")?.Value,
                    AppAccessService.AdminRoleId,
                    StringComparison.OrdinalIgnoreCase);

                isAssociatedUser =
                    (bool.TryParse(user.FindFirst("EstadoAsociado")?.Value, out var estadoAsociado) && estadoAsociado) ||
                    !string.IsNullOrWhiteSpace(user.FindFirst("IdJefe")?.Value);

                requiresAccountSetup = await RequiereConfiguracionInicialAsync(user);

                var claimValue = user.FindFirst("IdTipoUsuario")?.Value
                    ?? user.FindFirst(ClaimTypes.Role)?.Value;

                if (int.TryParse(claimValue, out int idTipoUsuario))
                {
                    if (IsEDeclaraContext)
                    {
                        listadoMenus.AddRange(await EDeclaraMenuService.GetMenusByRol(idTipoUsuario));
                    }
                    else
                    {
                        var efactMenus = await MenuService.GetMenusByRol(idTipoUsuario);
                        listadoMenus.AddRange(efactMenus.Where(m => 
                            !string.Equals(m.NombreMenu, "Firma Electronica", StringComparison.OrdinalIgnoreCase) &&
                            !string.Equals(m.NombreMenu, "Firma Electrónica", StringComparison.OrdinalIgnoreCase) &&
                            (m.RutaMenu == null || 
                             (!m.RutaMenu.Contains("/solicitud", StringComparison.OrdinalIgnoreCase) && 
                              !m.RutaMenu.Contains("/e-sign", StringComparison.OrdinalIgnoreCase)))
                        ));
                    }
                }

                // â† SIEMPRE, independiente de si hay menÃºs en BD o no
                AsegurarVistasModulosPadre();
                var menusNormalizados = DeduplicarMenus(listadoMenus);
                listadoMenus.Clear();
                listadoMenus.AddRange(menusNormalizados);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en NavMenu: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
