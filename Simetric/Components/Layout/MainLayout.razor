@code {
    [CascadingParameter] private Task<AuthenticationState>? LayoutAuthenticationStateTask { get; set; }

    private const string WelcomeStoragePrefix = "numerica:welcome-seen:";
    private const string EContaxWelcomeStoragePrefix = "numerica:econtax-welcome-seen:";
    private const string EDeclaraWelcomeStoragePrefix = "numerica:edeclara-welcome-seen:";
    private const string ESignWelcomeStoragePrefix = "numerica:esign-welcome-seen:";
    private const string ReadyConfirmationStoragePrefix = "numerica:ready-confirmation-dismissed:";
    private const string OnboardingBotSessionStoragePrefix = "numerica:onboarding-bot-dismissed:";
    private const string DefaultAvatarUrl = "/images/avatars/Avatar-Boy.jpg";

    private bool _cerrandoSesion;
    private bool _mostrarBienvenida;
    private string? _welcomeStorageKey;
    private EmisionEstado? _emisionEstado;
    private int _saldoDocumentosHeader;
    private bool _resaltarSaldoDocumentos;
    private int _saldoHighlightVersion;
    private bool _mostrarMenuSesion;
    private bool _cuentaListaParaFacturar;
    private bool _ocultarConfirmacionCuentaLista;
    private bool _tieneClientesActivos;
    private bool _tieneProductosActivos;
    private bool _layoutAuthResolved;
    private bool _layoutUserAuthenticated;
    private string? _readyConfirmationStorageKey;
    private string? _onboardingBotSessionStorageKey;
    private string? _onboardingBotDismissedStepKey;

    private bool IsEContaxContext => IsEContaxPath(NavManager.Uri);
    private bool IsEDeclaraContext => IsEDeclaraPath(NavManager.Uri);
    private bool IsESignContext => IsESignPath(NavManager.Uri);
    private bool IsDemoContext => IsDemoPath(NavManager.Uri);
    private string CurrentRoutePath =>
        NavManager.ToBaseRelativePath(NavManager.Uri).Split('?', '#')[0].Trim('/');
    private bool IsAuthEntryContext =>
        string.IsNullOrWhiteSpace(CurrentRoutePath) ||
        string.Equals(CurrentRoutePath, "login", StringComparison.OrdinalIgnoreCase);
    private bool ShouldRenderShell => IsDemoContext || (!IsAuthEntryContext && _layoutAuthResolved && _layoutUserAuthenticated);
    private bool IsDashboardContext =>
        string.Equals(CurrentRoutePath, "dashboard", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(CurrentRoutePath, "demo/dashboard", StringComparison.OrdinalIgnoreCase);
    private bool ShouldShowTutorialLauncher => !IsEContaxContext && !IsEDeclaraContext && !IsESignContext && !IsDemoContext;
    private bool ShouldShowAsistenteFacturacion => !IsEContaxContext && !IsEDeclaraContext && !IsESignContext;
    private OnboardingBotTip? OnboardingBotMessage => BuildOnboardingBotMessage();
    private bool ShouldShowOnboardingBot =>
        OnboardingBotMessage is not null &&
        !string.Equals(_onboardingBotDismissedStepKey, OnboardingBotMessage.StepKey, StringComparison.Ordinal);
    private bool ShouldShowGlobalReadyConfirmation =>
        !IsEContaxContext && !IsEDeclaraContext && !IsDemoContext &&
        _cuentaListaParaFacturar && _emisionEstado?.MostrarAviso != true && !_ocultarConfirmacionCuentaLista;
    private bool HasFloatingWidgets => ShouldShowTutorialLauncher || ShouldShowAsistenteFacturacion;
    private string SaldoDocumentosHeaderCaption =>
        _emisionEstado?.PlanIlimitadoActivo == true
            ? _emisionEstado.PlanIlimitadoVigenteHasta is DateTime vigenteHasta
                ? $"Vence {vigenteHasta:dd/MM/yyyy}"
                : "Plan sin vencimiento"
            : "Documentos disponibles";
    private string SaldoDocumentosHeaderLabel =>
        _emisionEstado?.PlanIlimitadoActivo == true
            ? _emisionEstado.PlanIlimitadoVigenteHasta is DateTime vigenteHasta
                ? $"Ilimitado - {ObtenerDuracionRestantePlan(vigenteHasta)}"
                : "Ilimitado"
            : _saldoDocumentosHeader.ToString();
    private string SaldoDocumentosHeaderTitle =>
        _emisionEstado?.PlanIlimitadoActivo == true
            ? _emisionEstado.PlanIlimitadoVigenteHasta is DateTime vigenteHasta
                ? $"Plan ilimitado vigente hasta el {vigenteHasta:dd/MM/yyyy}. Quedan {ObtenerDuracionRestantePlan(vigenteHasta)}."
                : "Plan ilimitado activo sin fecha de vencimiento."
            : "Comprar documentos";
    private string ReadyConfirmationMessage =>
        !_tieneClientesActivos && !_tieneProductosActivos
            ? "Completaste emisor, firma y documentos. Ya puedes emitir; aun no tienes clientes ni productos, te recomendamos registrarlos para facturar mas rapido."
            : !_tieneClientesActivos
                ? "Completaste emisor, firma y documentos. Ya puedes emitir; aun no tienes clientes registrados, te recomendamos crear al menos uno."
                : !_tieneProductosActivos
                    ? "Completaste emisor, firma y documentos. Ya puedes emitir; aun no tienes productos registrados, te recomendamos crear al menos uno."
                    : "Completaste emisor, firma y documentos. Ya puedes emitir; clientes y productos quedan listos como apoyo operativo.";
    private string PrivacyPolicyRoute =>
        $"/politica-privacidad?returnUrl={Uri.EscapeDataString(CurrentLocalRoute)}";
    private string CurrentLocalRoute
    {
        get
        {
            var relative = NavManager.ToBaseRelativePath(NavManager.Uri);
            return string.IsNullOrWhiteSpace(relative) ? "/dashboard" : $"/{relative}";
        }
    }

    private string WelcomeTitle =>
        IsEContaxContext ? "Bienvenido a E-Contax" :
        IsEDeclaraContext ? "Bienvenido a E-Declara" :
        IsESignContext ? "Bienvenido a eRúbrica" :
                           "Bienvenido a e-fact";

    private string WelcomeLogoSource =>
        IsEContaxContext ? "/images/econtax/LogoEContax.png" :
        IsEDeclaraContext ? "/images/LogoNumericaMark.png" :
        IsESignContext ? "/images/esign/erubrica.png" :
                             "/images/LogoPrincipal.svg";

    private string WelcomeLogoAlt =>
        IsEContaxContext ? "Numerica E-Contax" :
        IsEDeclaraContext ? "Numerica E-Declara" :
        IsESignContext ? "Numerica eRúbrica" :
                            "Numerica e-fact IA";

    protected override async Task OnParametersSetAsync()
    {
        if (LayoutAuthenticationStateTask is null)
        {
            _layoutAuthResolved = true;
            _layoutUserAuthenticated = false;
            return;
        }

        var authState = await LayoutAuthenticationStateTask;
        _layoutAuthResolved = true;
        _layoutUserAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    protected override void OnInitialized()
    {
        EmisorOnboardingService.Changed += OnOnboardingChanged;
        EmisionControlService.Changed += OnEmisionChanged;
        NavManager.LocationChanged += OnLocationChanged;
        
        _ = CheckBackofficeRedirectAsync();
    }

    private async Task CheckBackofficeRedirectAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idTipoUsuario = user.FindFirst("IdTipoUsuario")?.Value;
            if (string.Equals(idTipoUsuario, "7", StringComparison.OrdinalIgnoreCase))
            {
                NavManager.NavigateToIfNeeded("/backoffice", forceLoad: true);
            }
        }
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true) return;

        if (!IsEContaxContext && !IsEDeclaraContext && !IsESignContext)
        {
            await ActualizarEstadoEmisionAsync(user);
            await EvaluarConfirmacionCuentaListaAsync(user);
            await EvaluarEstadoBotOnboardingAsync(user);
            await InvokeAsync(StateHasChanged);
        }

        await EvaluarBienvenidaAsync(user, IsEContaxContext, IsEDeclaraContext, IsESignContext);
    }

    public void Dispose()
    {
        EmisorOnboardingService.Changed -= OnOnboardingChanged;
        EmisionControlService.Changed -= OnEmisionChanged;
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private async Task CerrarBienvenida()
    {
        _mostrarBienvenida = false;
        try
        {
            if (!string.IsNullOrWhiteSpace(_welcomeStorageKey))
                await JS.InvokeVoidAsync("localStorage.setItem", _welcomeStorageKey, "true");

            await JS.InvokeVoidAsync("numericaUi.toggleBodyScrollLock", false);
        }
        catch (JSDisconnectedException) { }
    }

    private void IrAEmisor() => NavManager.NavigateTo(_emisionEstado?.RutaAccion ?? "/emisor");

    private void OnOnboardingChanged()
    {
        _ = InvokeAsync(async () =>
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            await ActualizarEstadoEmisionAsync(authState.User);
            await EvaluarEstadoBotOnboardingAsync(authState.User);
            StateHasChanged();
        });
    }

    private void OnEmisionChanged()
    {
        _ = InvokeAsync(async () =>
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated != true)
            {
                _emisionEstado = null;
                _saldoDocumentosHeader = 0;
                _resaltarSaldoDocumentos = false;
                StateHasChanged();
                return;
            }

            var saldoAnterior = _saldoDocumentosHeader;
            await ActualizarEstadoEmisionAsync(user);
            await EvaluarEstadoBotOnboardingAsync(user);

            if (_saldoDocumentosHeader != saldoAnterior)
                ActivarResalteSaldo();

            StateHasChanged();
        });
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _mostrarMenuSesion = false;
        _ = InvokeAsync(async () =>
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var idTipoUsuario = user.FindFirst("IdTipoUsuario")?.Value;
                if (string.Equals(idTipoUsuario, "7", StringComparison.OrdinalIgnoreCase))
                {
                    NavManager.NavigateToIfNeeded("/backoffice", forceLoad: true);
                    return;
                }
            }
            var isEContaxLocation = IsEContaxPath(e.Location);
            var isEDeclaraLocation = IsEDeclaraPath(e.Location);
            var isESignLocation = IsESignPath(e.Location);

            if (isEContaxLocation || isEDeclaraLocation || isESignLocation)
            {
                _emisionEstado = null;
                _saldoDocumentosHeader = 0;
                _resaltarSaldoDocumentos = false;

                if (user.Identity?.IsAuthenticated == true)
                    await EvaluarBienvenidaAsync(user, isEContaxLocation, isEDeclaraLocation, isESignLocation);

                StateHasChanged();
                return;
            }

            if (user.Identity?.IsAuthenticated == true)
            {
                await ActualizarEstadoEmisionAsync(user);
                await EvaluarEstadoBotOnboardingAsync(user);
                await EvaluarBienvenidaAsync(user, isEContaxLocation, isEDeclaraLocation, false);
            }
            else
            {
                _emisionEstado = null;
                _saldoDocumentosHeader = 0;
            }

            StateHasChanged();
        });
    }

    private async Task EvaluarBienvenidaAsync(ClaimsPrincipal user, bool isEContaxContext, bool isEDeclaraContext, bool isESignContext)
    {
        var userKey = GetUserWelcomeKey(user);
        if (string.IsNullOrWhiteSpace(userKey)) return;

        var storagePrefix = isEContaxContext ? EContaxWelcomeStoragePrefix :
                            isEDeclaraContext ? EDeclaraWelcomeStoragePrefix :
                            isESignContext ? ESignWelcomeStoragePrefix :
                                               WelcomeStoragePrefix;

        var welcomeStorageKey = $"{storagePrefix}{userKey}";

        if (_mostrarBienvenida && string.Equals(_welcomeStorageKey, welcomeStorageKey, StringComparison.Ordinal))
            return;

        _welcomeStorageKey = welcomeStorageKey;

        try
        {
            var storedValue = await JS.InvokeAsync<string?>("localStorage.getItem", _welcomeStorageKey);

            if (!string.Equals(storedValue, "true", StringComparison.OrdinalIgnoreCase))
            {
                _mostrarBienvenida = true;
                await JS.InvokeVoidAsync("numericaUi.toggleBodyScrollLock", true);
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_mostrarBienvenida)
                    await JS.InvokeVoidAsync("numericaUi.toggleBodyScrollLock", false);

                _mostrarBienvenida = false;
            }
        }
        catch (JSDisconnectedException) { }
    }

    private async Task OcultarBotOnboardingEnSesionAsync()
    {
        if (OnboardingBotMessage is null)
            return;

        _onboardingBotDismissedStepKey = OnboardingBotMessage.StepKey;

        try
        {
            if (!string.IsNullOrWhiteSpace(_onboardingBotSessionStorageKey))
                await JS.InvokeVoidAsync("sessionStorage.setItem", _onboardingBotSessionStorageKey, _onboardingBotDismissedStepKey);
        }
        catch (JSDisconnectedException) { }

        await InvokeAsync(StateHasChanged);
    }

    private async Task EvaluarEstadoBotOnboardingAsync(ClaimsPrincipal user)
    {
        var userKey = GetUserWelcomeKey(user);
        if (string.IsNullOrWhiteSpace(userKey))
            return;

        _onboardingBotSessionStorageKey = $"{OnboardingBotSessionStoragePrefix}{userKey}";

        try
        {
            _onboardingBotDismissedStepKey = await JS.InvokeAsync<string?>("sessionStorage.getItem", _onboardingBotSessionStorageKey);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task ActualizarEstadoEmisionAsync(ClaimsPrincipal user)
    {
        var idUsuario = ObtenerIdUsuario(user);
        try
        {
            _emisionEstado = await EmisionControlService.ObtenerEstadoAsync(idUsuario);
            _saldoDocumentosHeader = _emisionEstado?.SaldoDocumentosDisponibles ?? 0;
            _cuentaListaParaFacturar =
                _emisionEstado?.PuedeEmitir == true &&
                !EmisorOnboardingService.RequiresInitialSetup;

            if (idUsuario is > 0)
            {
                var usuarioId = idUsuario.Value;
                var clientesTask = DashboardService.TieneClientesActivosAsync(usuarioId);
                var productosTask = DashboardService.TieneProductosActivosAsync(usuarioId);
                await Task.WhenAll(clientesTask, productosTask);
                _tieneClientesActivos = clientesTask.Result;
                _tieneProductosActivos = productosTask.Result;
            }
            else
            {
                _tieneClientesActivos = false;
                _tieneProductosActivos = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo actualizar el estado de emision desde el layout.");
            _emisionEstado = null;
            _saldoDocumentosHeader = 0;
            _cuentaListaParaFacturar = false;
            _tieneClientesActivos = false;
            _tieneProductosActivos = false;
        }
    }

    private void ActivarResalteSaldo()
    {
        _resaltarSaldoDocumentos = true;
        var version = ++_saldoHighlightVersion;
        _ = RestablecerResalteSaldoAsync(version);
    }

    private async Task RestablecerResalteSaldoAsync(int version)
    {
        try
        {
            await Task.Delay(1400);
            await InvokeAsync(() =>
            {
                if (version != _saldoHighlightVersion) return;
                _resaltarSaldoDocumentos = false;
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }

    private async Task CerrarSesion()
    {
        if (_cerrandoSesion) return;
        _cerrandoSesion = true;
        EmisorOnboardingService.SetRequiredStep(InitialSetupStep.None);

        try
        {
            await JS.InvokeVoidAsync("numericaLogoutAndRedirect", "/login");
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }

    private void ToggleSessionMenu() => _mostrarMenuSesion = !_mostrarMenuSesion;

