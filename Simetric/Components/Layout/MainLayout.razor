    private async Task OcultarConfirmacionCuentaLista()
    {
        _ocultarConfirmacionCuentaLista = true;

        try
        {
            if (!string.IsNullOrWhiteSpace(_readyConfirmationStorageKey))
            {
                await JS.InvokeVoidAsync("localStorage.setItem", _readyConfirmationStorageKey, "true");
            }
        }
        catch (JSDisconnectedException) { }
    }

    private async Task EvaluarConfirmacionCuentaListaAsync(ClaimsPrincipal user)
    {
        var userKey = GetUserWelcomeKey(user);
        if (string.IsNullOrWhiteSpace(userKey))
        {
            return;
        }

        _readyConfirmationStorageKey = $"{ReadyConfirmationStoragePrefix}{userKey}";

        try
        {
            var dismissed = await JS.InvokeAsync<string?>("localStorage.getItem", _readyConfirmationStorageKey);
            _ocultarConfirmacionCuentaLista = string.Equals(dismissed, "true", StringComparison.OrdinalIgnoreCase);
        }
        catch (JSDisconnectedException) { }
    }

