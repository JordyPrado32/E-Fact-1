    private bool MostrarRobotAvisoEmision =>
        _emisionEstado?.RequiereCompraDocumentos == true ||
        _emisionEstado?.AdvertenciaSaldoBajo == true;

    private string ClaseEmocionRobotSaldo
    {
        get
        {
            if (_emisionEstado?.PlanIlimitadoActivo == true) return "is-happy";
            if (_saldoDocumentosHeader <= 0) return "is-sad";
            return _saldoDocumentosHeader < EmisionControlService.UmbralSaldoBajoDocumentos
                ? "is-scared" : "is-happy";
        }
    }

    private string ClaseEmocionRobotAviso =>
        _emisionEstado?.RequiereCompraDocumentos == true ? "is-sad" :
        _emisionEstado?.AdvertenciaSaldoBajo == true ? "is-scared" : "is-happy";

    private string ObtenerClaseSaldoDocumentos()
    {
        if (_emisionEstado?.PlanIlimitadoActivo == true) return "is-positive";
        if (_saldoDocumentosHeader <= 0) return "is-empty";
        return _saldoDocumentosHeader < EmisionControlService.UmbralSaldoBajoDocumentos
            ? "is-low" : "is-positive";
    }

    private static string ObtenerDuracionRestantePlan(DateTime vigenteHasta)
    {
        var diasRestantes = Math.Max(0, (vigenteHasta.Date - DateTime.Today).Days);
        if (diasRestantes == 0) return "menos de 1 dia";
        return diasRestantes == 1 ? "1 dia" : $"{diasRestantes} dias";
    }

    private string ObtenerClaseAvisoEmision()
    {
        if (_emisionEstado?.RequiereCompraDocumentos == true)
            return "activation-banner-documents activation-banner-with-robot";
        return _emisionEstado?.AdvertenciaSaldoBajo == true
            ? "activation-banner-low-balance activation-banner-with-robot"
            : string.Empty;
    }

    private OnboardingBotTip? BuildOnboardingBotMessage()
    {
        if (IsEContaxContext || IsEDeclaraContext || IsESignContext || IsDemoContext || _cuentaListaParaFacturar)
            return null;

        if (EmisorOnboardingService.RequiredStep == InitialSetupStep.Emisor)
        {
            return new OnboardingBotTip(
                "Bot de configuración",
                "Vamos por el primer paso: completa tu emisor para dejar lista la identidad tributaria con la que emitirás.",
                "/emisor",
                "Ir a emisor");
        }

        if (_emisionEstado?.TieneEmisorActivo == true && _emisionEstado.TieneFirmaElectronica == false)
        {
            return new OnboardingBotTip(
                "Siguiente paso",
                "Tu emisor ya está listo. Ahora carga la firma electrónica .p12 y su clave para poder firmar comprobantes.",
                "/firma",
                "Configurar firma");
        }

        if (_emisionEstado?.RequiereCompraDocumentos == true)
        {
            return new OnboardingBotTip(
                "Último paso operativo",
                "Ya configuraste emisor y firma. Solo falta activar documentos para que la cuenta quede lista para emitir.",
                EmisionControlService.RutaCompraDocumentos,
                "Comprar documentos");
        }

        return null;
    }

    private string ObtenerIconoAvisoEmision()
    {
        if (_emisionEstado?.RequiereCompraDocumentos == true) return "bi-shield-lock-fill";
        return _emisionEstado?.AdvertenciaSaldoBajo == true
            ? "bi-bag-plus-fill" : "bi-patch-exclamation-fill";
    }

    private static string? GetUserWelcomeKey(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
              ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrWhiteSpace(id)) return id.Trim();
        return user.FindFirst(ClaimTypes.Email)?.Value?.Trim().ToLowerInvariant();
    }

    private static int? ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
              ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(id, out var idUsuario) ? idUsuario : null;
    }

    private static string GetDisplayName(ClaimsPrincipal user)
    {
        var nombres = user.Identity?.Name?.Trim();
        var apellidos = user.FindFirst(ClaimTypes.Surname)?.Value?.Trim();
        return BuildShortPersonName(nombres, apellidos);
    }

    private static string BuildShortPersonName(string? nombres, string? apellidos)
    {
        var nombresPartes = SplitNameWords(nombres);
        var apellidosPartes = SplitNameWords(apellidos);

        var primerNombre = nombresPartes.FirstOrDefault();
        var primerApellido = apellidosPartes.FirstOrDefault();

        if (string.IsNullOrWhiteSpace(primerApellido))
        {
            primerApellido = nombresPartes.Length >= 3
                ? nombresPartes[2]
                : nombresPartes.Skip(1).FirstOrDefault();
        }

        var nombreCorto = string.Join(" ", new[] { primerNombre, primerApellido }
            .Where(x => !string.IsNullOrWhiteSpace(x)));

        return string.IsNullOrWhiteSpace(nombreCorto) ? "Usuario" : nombreCorto;
    }

    private static string[] SplitNameWords(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? Array.Empty<string>()
            : value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    private static string GetUserAvatar(ClaimsPrincipal user)
        => ResolveAvatarUrl(user.FindFirst("AvatarUrl")?.Value);

    private static string ResolveAvatarUrl(string? avatarUrl)
    {
        if (string.IsNullOrWhiteSpace(avatarUrl) ||
            avatarUrl.EndsWith("default.png", StringComparison.OrdinalIgnoreCase))
            return DefaultAvatarUrl;

        if (avatarUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase) ||
            avatarUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            avatarUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            avatarUrl.StartsWith("/", StringComparison.Ordinal))
            return avatarUrl;

        return avatarUrl.StartsWith("images/", StringComparison.OrdinalIgnoreCase)
            ? $"/{avatarUrl}" : avatarUrl;
    }

