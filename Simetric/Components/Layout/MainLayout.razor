@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.JSInterop
@using Simetric.Extensions
@using Simetric.Services
@using Simetric.Services.EContax
@using Simetric.Services.EDeclara
@using Simetric.Services.ESign
@implements IDisposable
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject DashboardService DashboardService
@inject EmisorOnboardingService EmisorOnboardingService
@inject EmisionControlService EmisionControlService
@inject AuthenticationStateProvider AuthStateProvider
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject ILogger<MainLayout> Logger

@if (!ShouldRenderShell)
{
    @Body
}
else
{
<div class="page @(IsEContaxContext ? "econtax-theme" : (IsEDeclaraContext ? "edeclara-theme" : (IsESignContext ? "esign-theme" : string.Empty)))">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="workspace">
        <header class="workspace-header">
            <div class="workspace-intro workspace-brand @(IsEContaxContext ? "workspace-brand-econtax" : (IsESignContext ? "workspace-brand-esign" : string.Empty))">
                @if (IsEContaxContext)
                {
                    <img src="/images/LogoNumerica.svg" alt="Logo Numerica" class="workspace-brand-image workspace-brand-image-numerica" />
                    <img src="/images/econtax/LogoEContax.png" alt="Logo E-Contax" class="workspace-brand-image workspace-brand-logo-econtax" />
                }
                else if (IsEDeclaraContext)
                {
                    <img src="/images/LogoNumerica.svg" alt="Logo Numerica" class="workspace-brand-image workspace-brand-image-numerica" />
                    <div class="workspace-brand-copy">
                        <span>Numerica software</span>
                        <strong>E-Declara</strong>
                    </div>
                }
                else if (IsESignContext)
                {
                    <img src="/images/LogoNumerica.svg" alt="Logo Numerica" class="workspace-brand-image workspace-brand-image-numerica" />
                    <img src="/images/esign/erubrica.png" alt="Logo eRubrica" class="workspace-brand-image" style="width: auto; max-width: 140px; height: 50px; object-fit: contain; object-position: left center;" />
                }
                else
                {
                    <img src="/images/LogoNumerica.svg" alt="Logo Numerica" class="workspace-brand-image workspace-brand-image-numerica" />
                    <img src="/images/logo.png" alt="Logo E-FACT" class="workspace-brand-image workspace-brand-image-efact" />
                }
            </div>

            <AuthorizeView>
                <Authorized>
                    <div class="session-card">
                        @if (IsEContaxContext)
                        {
                            <div class="session-service-pill">
                                <div class="session-service-icon">
                                    <div class="robot-mini is-happy" aria-hidden="true">
                                        <span class="robot-mini-antenna"></span>
                                        <span class="robot-mini-head">
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-mouth"></span>
                                        </span>
                                        <span class="robot-mini-body"></span>
                                    </div>
                                </div>
                                <div class="session-service-copy">
                                    <span>Servicio activo</span>
                                    <strong>E-Contax</strong>
                                </div>
                            </div>
                        }
                        else if (IsEDeclaraContext)
                        {
                            <div class="session-service-pill">
                                <div class="session-service-icon">
                                    <div class="robot-mini is-happy" aria-hidden="true">
                                        <span class="robot-mini-antenna"></span>
                                        <span class="robot-mini-head">
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-mouth"></span>
                                        </span>
                                        <span class="robot-mini-body"></span>
                                    </div>
                                </div>
                                <div class="session-service-copy">
                                    <span>Servicio activo</span>
                                    <strong>E-Declara</strong>
                                </div>
                            </div>
                        }
                        else if (IsESignContext)
                        {
                            <div class="session-service-pill session-service-pill-esign">
                                <div class="session-service-icon">
                                    <div class="robot-mini is-happy" aria-hidden="true">
                                        <span class="robot-mini-antenna"></span>
                                        <span class="robot-mini-head">
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-mouth"></span>
                                        </span>
                                        <span class="robot-mini-body"></span>
                                    </div>
                                </div>
                                <div class="session-service-copy">
                                    <span>Servicio activo</span>
                                    <strong>eRúbrica</strong>
                                </div>
                            </div>
                        }
                        else
                        {
                            <SolicitudNotifications />

                            <a class="session-documents-pill @ObtenerClaseSaldoDocumentos() @(_resaltarSaldoDocumentos ? "session-documents-pill-live" : string.Empty)"
                               href="/compra-documentos"
                               title="@SaldoDocumentosHeaderTitle"
                               aria-label="Ir a compra de documentos">
                                <div class="session-documents-icon">
                                    <i class="bi bi-files" aria-hidden="true"></i>
                                </div>
                                <div class="session-documents-copy">
                                    <span>@SaldoDocumentosHeaderCaption</span>
                                    <strong aria-live="polite">@SaldoDocumentosHeaderLabel</strong>
                                </div>
                            </a>
                        }

                        <div class="session-profile-menu">
                            <button type="button"
                                    class="session-profile-trigger"
                                    aria-haspopup="menu"
                                    aria-expanded="@_mostrarMenuSesion"
                                    @onclick="ToggleSessionMenu">
                                <div class="session-meta">
                                    <span class="session-label">Sesion activa</span>
                                    <span class="user-name">@GetDisplayName(context.User)</span>
                                </div>
                                <img src="@GetUserAvatar(context.User)" class="user-avatar" alt="Avatar del usuario" />
                                <i class="bi bi-gear session-profile-chevron"></i>
                            </button>

                            @if (_mostrarMenuSesion)
                            {
                                <div class="session-profile-dropdown" role="menu">
                                    <button type="button" role="menuitem" @onclick="AbrirPerfil">
                                        <i class="bi bi-person-circle"></i>
                                        <span>Mi perfil</span>
                                    </button>
                                    @if (ShouldShowTutorialLauncher)
                                    {
                                        <button type="button" role="menuitem" @onclick="AbrirEmisorSesion">
                                            <i class="ri-building-2-line"></i>
                                            <span>Emisor</span>
                                        </button>
                                        <button type="button" role="menuitem" @onclick="AbrirPuntoEmisionSesion">
                                            <i class="ri-safe-2-line"></i>
                                            <span>Punto de emision</span>
                                        </button>
                                        <RouteTutorialLauncher MenuMode="true" />
                                    }
                                    <button type="button" role="menuitem" class="is-danger" @onclick="CerrarSesion">
                                        <i class="bi bi-box-arrow-right"></i>
                                        <span>Salir</span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    @if (IsDemoContext)
                    {
                        <div class="session-card">
                            <div class="session-service-pill">
                                <div class="session-service-icon">
                                    <div class="robot-mini is-happy" aria-hidden="true">
                                        <span class="robot-mini-antenna"></span>
                                        <span class="robot-mini-head">
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-eye"></span>
                                            <span class="robot-mini-mouth"></span>
                                        </span>
                                        <span class="robot-mini-body"></span>
                                    </div>
                                </div>
                                <div class="session-service-copy">
                                    <span>Acceso actual</span>
                                    <strong>Invitado demo</strong>
                                </div>
                            </div>

                            <button type="button" class="session-profile-trigger" @onclick="IrAPortalDemo">
                                <div class="session-meta">
                                    <span class="session-label">Sesion de recorrido</span>
                                    <span class="user-name">Solo lectura</span>
                                </div>
                                <div class="user-avatar d-inline-flex align-items-center justify-content-center text-white fw-bold"
                                     style="background:linear-gradient(135deg,#006bb5,#004a7c);">
                                    <i class="ri-eye-line"></i>
                                </div>
                            </button>

                            <button class="btn-logout" @onclick="VolverAlLogin">
                                <i class="bi bi-arrow-left-circle"></i>
                                <span>Salir demo</span>
                            </button>
                        </div>
                    }
                </NotAuthorized>
            </AuthorizeView>
        </header>

        @if (ShouldShowGlobalReadyConfirmation)
        {
            <section class="setup-ready-banner" role="status" aria-live="polite">
                <div class="setup-ready-icon"><i class="bi bi-check2-circle"></i></div>
                <div class="setup-ready-copy">
                    <strong>Tu cuenta ya está lista para facturar</strong>
                    <span>@ReadyConfirmationMessage</span>
                </div>
                <button type="button" class="setup-ready-action" @onclick="IrAFacturacion">
                    Emitir factura
                </button>
                <button type="button" class="setup-ready-close" @onclick="OcultarConfirmacionCuentaLista" aria-label="Cerrar confirmación">
                    <i class="bi bi-x-lg"></i>
                </button>
            </section>
        }

        <article class="workspace-content @(HasFloatingWidgets ? "has-floating-widgets" : string.Empty)">
            @Body
            @if (ShouldShowTutorialLauncher)
            {
                <ServicioAccesoGuard />
                <EmisorSetupGuard />
                <RouteTutorialHost />
            }
        </article>

        @if (!IsEContaxContext && !IsEDeclaraContext && !IsESignContext && !IsDemoContext)
        {
            <footer class="workspace-footer">
                <div class="workspace-footer-brand">
                    <span>© @DateTime.Now.Year e-fact</span>
                    <small>Desarrollado por Numérica Software</small>
                </div>
                <div class="workspace-footer-links">
                    <a href="/soporte"><i class="bi bi-headset"></i> Soporte</a>
                    <a href="mailto:soporte@numericasoftware.com"><i class="bi bi-envelope"></i> soporte@numericasoftware.com</a>
                    <a href="@PrivacyPolicyRoute">Política de privacidad</a>
                </div>
            </footer>
        }
    </main>
</div>

@if (ShouldShowAsistenteFacturacion)
{
    <AsistenteFacturacionLauncher ShowOnboardingBubble="@(ShouldShowOnboardingBot && OnboardingBotMessage is not null)"
                                  OnboardingBubbleTitle="@OnboardingBotMessage?.Title"
                                  OnboardingBubbleMessage="@OnboardingBotMessage?.Message"
                                  OnboardingBubbleActionLabel="@OnboardingBotMessage?.ActionLabel"
                                  OnboardingBubbleActionRoute="@OnboardingBotMessage?.ActionRoute"
                                  OnboardingBubbleDismiss="OcultarBotOnboardingEnSesionAsync" />
}

@if (_mostrarBienvenida)
{
    @if (!IsEContaxContext && !IsEDeclaraContext && !IsESignContext)
    {
        <div class="efact-welcome-backdrop" role="dialog" aria-modal="true" aria-labelledby="welcomeTitle">
            <div class="efact-welcome-card">
                <button type="button" class="efact-welcome-close" @onclick="CerrarBienvenida" aria-label="Cerrar bienvenida">
                    <i class="bi bi-x-lg"></i>
                </button>

                <div class="efact-welcome-grid">
                    <!-- Column 1: Copy and setup steps -->
                    <div class="efact-welcome-left">
                        <div class="efact-welcome-logo">
                            <img src="/images/logo.png" alt="e-fact" />
                        </div>
                        <h2 class="efact-welcome-title">¡Bienvenido a e-fact!</h2>
                        <p class="efact-welcome-subtitle">Estás a pocos pasos de emitir tu primer comprobante electrónico.</p>
                        
                        <div class="efact-welcome-steps-section">
                            <h3 class="efact-welcome-steps-header">Te ayudaremos a completar:</h3>
                            <div class="efact-welcome-steps-list">
                                <div class="efact-welcome-step-item">
                                    <div class="efact-welcome-step-icon">
                                        <i class="bi bi-building"></i>
                                    </div>
                                    <div class="efact-welcome-step-content">
                                        <strong>Registrar tu empresa</strong>
                                        <span>Configura los datos de tu empresa emisora.</span>
                                    </div>
                                </div>
                                <div class="efact-welcome-step-item">
                                    <div class="efact-welcome-step-icon">
                                        <i class="bi bi-pen"></i>
                                    </div>
                                    <div class="efact-welcome-step-content">
                                        <strong>Cargar tu firma electrónica</strong>
                                        <span>Asocia tu firma para emitir documentos.</span>
                                    </div>
                                </div>
                                <div class="efact-welcome-step-item">
                                    <div class="efact-welcome-step-icon">
                                        <i class="bi bi-file-earmark-text"></i>
                                    </div>
                                    <div class="efact-welcome-step-content">
                                        <strong>Activar tus documentos de cortesía</strong>
                                        <span>Recibe tu bono de bienvenida de 9 documentos.</span>
                                    </div>
                                </div>
                                <div class="efact-welcome-step-item">
                                    <div class="efact-welcome-step-icon">
                                        <i class="bi bi-file-earmark-check"></i>
                                    </div>
                                    <div class="efact-welcome-step-content">
                                        <strong>Emitir tu primera factura</strong>
                                        <span>Listo para empezar a facturar.</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="efact-welcome-bonus-box">
                            <div class="efact-welcome-bonus-icon">
                                <i class="bi bi-gift-fill"></i>
                            </div>
                            <div class="efact-welcome-bonus-content">
                                <strong>Bono de bienvenida</strong>
                                <span>Incluye <strong>9 comprobantes electrónicos</strong> de cortesía para empezar a facturar hoy mismo.</span>
                            </div>
                        </div>

                        <button type="button" class="efact-welcome-btn-primary" @onclick="CerrarBienvenida">
                            Comenzar configuración <i class="bi bi-arrow-right-short"></i>
                        </button>
                    </div>

                    <!-- Column 2: Dashboard Mockup & bottom features -->
                    <div class="efact-welcome-right">
                        <!-- Floating diagrams -->
                        <div class="efact-welcome-floating-container">
                            <div class="efact-welcome-floating-cloud">
                                <div class="css-cloud">
                                    <div class="cloud-check-circle">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Document cards -->
                            <div class="efact-welcome-doc-card card-factura">
                                <span class="doc-title">FACTURA</span>
                                <div class="doc-lines">
                                    <span class="doc-line"></span>
                                    <span class="doc-line"></span>
                                    <span class="doc-line"></span>
                                    <span class="doc-line short"></span>
                                </div>
                                <div class="doc-card-footer">
                                    <span class="doc-badge-green">AUTORIZADO</span>
                                    <div class="doc-check-circle">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="efact-welcome-doc-card card-retencion">
                                <span class="doc-title">RETENCIÓN</span>
                                <div class="doc-lines">
                                    <span class="doc-line"></span>
                                    <span class="doc-line"></span>
                                    <span class="doc-line"></span>
                                    <span class="doc-line short"></span>
                                </div>
                                <div class="doc-card-footer">
                                    <span class="doc-badge-green">AUTORIZADO</span>
                                    <div class="doc-check-circle">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="efact-welcome-doc-card card-nota">
                                <span class="doc-title">NOTA DE CRÉDITO</span>
                                <div class="doc-lines">
                                    <span class="doc-line"></span>
                                    <span class="doc-line"></span>
                                    <span class="doc-line"></span>
                                    <span class="doc-line short"></span>
                                </div>
                                <div class="doc-card-footer">
                                    <span class="doc-badge-green">AUTORIZADO</span>
                                    <div class="doc-check-circle">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Laptop Mockup -->
                        <div class="efact-welcome-laptop-mockup">
                            <div class="laptop-screen">
                                <div class="mock-dashboard">
                                    <div class="mock-sidebar">
                                        <div class="mock-logo-container">
                                            <span class="mock-logo-text">e-fact</span>
                                        </div>
                                        <div class="mock-nav">
                                            <span class="active"><i class="bi bi-house-door"></i> Inicio</span>
                                            <span><i class="bi bi-file-earmark"></i> Documentos</span>
                                            <span><i class="bi bi-receipt"></i> Facturas</span>
                                            <span><i class="bi bi-people"></i> Clientes / Proveedores</span>
                                            <span><i class="bi bi-box"></i> Productos</span>
                                            <span><i class="bi bi-bar-chart"></i> Reportes</span>
                                            <span><i class="bi bi-gear"></i> Configuración</span>
                                        </div>
                                    </div>
                                    <div class="mock-content">
                                        <div class="mock-content-header">
                                            <span class="title">Resumen general</span>
                                            <div class="icons">
                                                <i class="bi bi-bell"></i>
                                                <i class="bi bi-person-circle"></i>
                                            </div>
                                        </div>
                                        <div class="mock-stats-row">
                                            <div class="mock-stat-card">
                                                <span class="label">Facturas emitidas</span>
                                                <span class="value">43</span>
                                                <span class="sub">Este mes</span>
                                            </div>
                                            <div class="mock-stat-card bg-light-green">
                                                <span class="label">Documentos de cortesía</span>
                                                <span class="value color-green">9</span>
                                                <span class="sub">Disponibles</span>
                                            </div>
                                            <div class="mock-stat-card">
                                                <span class="label">Ventas del mes</span>
                                                <span class="value">$ 12.540,00</span>
                                                <span class="sub">USD</span>
                                            </div>
                                        </div>
                                        <div class="mock-bottom-grid">
                                            <div class="mock-chart-card">
                                                <span class="chart-title">Ventas últimos 6 meses</span>
                                                <div class="mock-chart">
                                                    <svg viewBox="0 0 200 60" class="chart-line-svg">
                                                        <path d="M 0 50 Q 30 45 60 48 T 120 35 T 180 20" fill="none" stroke="#2563eb" stroke-width="2.5" />
                                                        <path d="M 0 50 Q 30 45 60 48 T 120 35 T 180 20 L 200 60 L 0 60 Z" fill="rgba(37, 99, 235, 0.08)" />
                                                        <circle cx="60" cy="48" r="2.5" fill="#2563eb" />
                                                        <circle cx="120" cy="35" r="2.5" fill="#2563eb" />
                                                        <circle cx="180" cy="20" r="2.5" fill="#2563eb" />
                                                    </svg>
                                                    <div class="chart-months">
                                                        <span>Ene</span><span>Feb</span><span>Mar</span><span>Abr</span><span>May</span><span>Jun</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="mock-quick-actions">
                                                <span class="actions-title">Accesos rápidos</span>
                                                <div class="action-list">
                                                    <span><i class="bi bi-file-earmark-plus"></i> Nueva factura</span>
                                                    <span><i class="bi bi-people"></i> Clientes / Proveedores</span>
                                                    <span><i class="bi bi-box"></i> Productos</span>
                                                    <span><i class="bi bi-bar-chart"></i> Reportes</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="laptop-keyboard-part"></div>
                        </div>

                        <!-- Footer features grid -->
                        <div class="efact-welcome-features">
                            <div class="feature-item">
                                <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                                <div class="feature-text">
                                    <strong>Cumple con el SRI</strong>
                                    <span>100% autorizado</span>
                                </div>
                            </div>
                            <div class="feature-item">
                                <div class="feature-icon"><i class="bi bi-lock"></i></div>
                                <div class="feature-text">
                                    <strong>Datos seguros</strong>
                                    <span>y encriptados</span>
                                </div>
                            </div>
                            <div class="feature-item">
                                <div class="feature-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                                <div class="feature-text">
                                    <strong>Disponible 24/7</strong>
                                    <span>en la nube</span>
                                </div>
                            </div>
                            <div class="feature-item">
                                <div class="feature-icon"><i class="bi bi-headset"></i></div>
                                <div class="feature-text">
                                    <strong>Soporte experto</strong>
                                    <span>cuando lo necesites</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (IsESignContext)
    {
        <div class="esign-welcome-backdrop" role="dialog" aria-modal="true" aria-labelledby="welcomeTitle">
            <div class="esign-welcome-card">
                <button type="button" class="esign-welcome-close" @onclick="CerrarBienvenida" aria-label="Cerrar bienvenida">
                    <i class="bi bi-x-lg"></i>
                </button>

                <div class="esign-welcome-grid">
                    <!-- Column 1: Copy and setup steps -->
                    <div class="esign-welcome-left">
                        <div class="esign-welcome-logo">
        <img src="/images/esign/erubrica.png" alt="eRubrica" style="width: auto; max-width: 140px; height: 50px; object-fit: contain;" />
                        </div>
                        <h2 class="esign-welcome-title">Bienvenido a eRubrica</h2>
                        <p class="esign-welcome-subtitle">Estás a pocos pasos de obtener tu firma electrónica de manera rápida y segura.</p>
                        
                        <div class="esign-welcome-steps-section">
                            <h3 class="esign-welcome-steps-header">Te ayudaremos a completar:</h3>
                            <div class="esign-welcome-steps-list">
                                <div class="esign-welcome-step-item">
                                    <div class="esign-welcome-step-icon">
                                        <i class="bi bi-file-earmark-text"></i>
                                    </div>
                                    <div class="esign-welcome-step-content">
                                        <strong>Registrar tu solicitud</strong>
                                        <span>Configura tus datos personales y sube los requisitos mínimos.</span>
                                    </div>
                                </div>
                                <div class="esign-welcome-step-item">
                                    <div class="esign-welcome-step-icon">
                                        <i class="bi bi-credit-card"></i>
                                    </div>
                                    <div class="esign-welcome-step-content">
                                        <strong>Realizar el pago</strong>
                                        <span>Elige tu método preferido: transferencia, depósito o tarjeta.</span>
                                    </div>
                                </div>
                                <div class="esign-welcome-step-item">
                                    <div class="esign-welcome-step-icon">
                                        <i class="bi bi-person-check"></i>
                                    </div>
                                    <div class="esign-welcome-step-content">
                                        <strong>Validación técnica</strong>
                                        <span>Validamos tu identidad y documentos de forma ágil y segura.</span>
                                    </div>
                                </div>
                                <div class="esign-welcome-step-item">
                                    <div class="esign-welcome-step-icon">
                                        <i class="bi bi-download"></i>
                                    </div>
                                    <div class="esign-welcome-step-content">
                                        <strong>Descargar certificado</strong>
                                        <span>Recibe tu firma electrónica lista para usarse donde la necesites.</span>
                                    </div>
                                </div>
                            </div>
