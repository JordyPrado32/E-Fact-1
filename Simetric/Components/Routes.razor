@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Simetric.Components.Layout.MainLayout)">
                    <Authorizing>
                        @* Sin contenido: evita el "Authorizing..." por defecto de Blazor *@
                    </Authorizing>
                    <NotAuthorized>
                        @if (context.User.Identity?.IsAuthenticated != true)
                        {
                            <LayoutView Layout="@typeof(Simetric.Components.Layout.EmptyLayout)">
                                <RedirectToLogin />
                            </LayoutView>
                        }
                        else
                        {
                            <div class="alert alert-warning m-5">
                                No tienes permisos para acceder a este recurso.
                            </div>
                        }
                    </NotAuthorized>
                </AuthorizeRouteView>
            }
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>No encontrado | Numerica e-fact</PageTitle>
            <LayoutView Layout="@typeof(Simetric.Components.Layout.MainLayout)">
                <p role="alert">Lo sentimos, no hay nada en esta dirección.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private static bool IsAllowAnonymousPage(RouteData routeData) =>
        Attribute.IsDefined(routeData.PageType, typeof(AllowAnonymousAttribute), inherit: true);
}
