@if (Visible)
{
    <div class="docs-history-backdrop" @onclick="HandleCloseAsync"></div>

    <div class="docs-history-shell @ModalClass" role="dialog" aria-modal="true" aria-label="@Title">
        <section class="docs-history-dialog" @onclick:stopPropagation="true">
            <header class="docs-history-header">
                <div class="docs-history-copy">
                    @if (!string.IsNullOrWhiteSpace(Eyebrow))
                    {
                        <span class="docs-history-kicker">@Eyebrow</span>
                    }

                    <h3>@Title</h3>

                    @if (!string.IsNullOrWhiteSpace(Description))
                    {
                        <p>@Description</p>
                    }
                </div>

                <button type="button"
                        class="docs-history-close"
                        @onclick="HandleCloseAsync"
                        aria-label="Cerrar panel">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="docs-history-body">
                @ChildContent
            </div>

            <footer class="docs-history-footer">
                <button type="button"
                        class="secondary-btn secondary-btn-quiet"
                        @onclick="HandleCloseAsync">
                    Cerrar
                </button>
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Eyebrow { get; set; } = "Historial";
    [Parameter] public string Title { get; set; } = "Panel";
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? ModalClass { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Task HandleCloseAsync() => OnClose.InvokeAsync();
}
