@if (Visible)
{
    <div class="initial-sequence-overlay" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="initial-sequence-title">
        <button type="button"
                class="initial-sequence-backdrop"
                aria-label="Cerrar y responder después"
                @onclick="Dismiss"></button>
        <div class="initial-sequence-dialog">
            <section class="initial-sequence-card">
                <button type="button"
                        class="initial-sequence-close"
                        title="Responder después"
                        aria-label="Cerrar"
                        @onclick="Dismiss">
                    <i class="bi bi-x-lg"></i>
                </button>
                <div class="initial-sequence-header">
                    <div class="initial-sequence-copy">
                        <span class="initial-sequence-kicker">Configuracion del documento</span>
                        <h5 class="initial-sequence-title" id="initial-sequence-title">@Title</h5>
                        @if (!string.IsNullOrWhiteSpace(Description))
                        {
                            <p class="initial-sequence-description">@Description</p>
                        }
                    </div>
                    <div class="initial-sequence-badge" aria-hidden="true">
                        <span>001</span>
                        <small>Inicio</small>
                    </div>
                </div>

                <div class="initial-sequence-body">
                    <div class="initial-sequence-panel">
                        <div class="initial-sequence-panel-top">
                            <span class="initial-sequence-step">Paso 1</span>
                            @if (HadPreviousDocuments is not null)
                            {
                                <span class="@GetSelectionStateClass()">@GetSelectionStateLabel()</span>
                            }
                        </div>

                        <label class="initial-sequence-label">@QuestionLabel</label>
                        <select class="initial-sequence-select" value="@GetResponseValue()" @onchange="OnResponseChanged">
                            <option value="">Seleccione...</option>
                            <option value="true">Si</option>
                            <option value="false">No</option>
                        </select>

                        <p class="initial-sequence-helper">
                            Si ya emitias este documento antes, puedes continuar la numeracion desde la secuencia donde te quedaste.
                        </p>
                    </div>

                    @if (HadPreviousDocuments == true)
                    {
                        <div class="initial-sequence-panel initial-sequence-panel-highlighted">
                            <div class="initial-sequence-panel-top">
                                <div>
                                    <span class="initial-sequence-step">Secuencia anterior</span>
                                    <label class="initial-sequence-label mb-0">@SequenceLabel</label>
                                </div>
                                <span class="initial-sequence-length-pill">9 digitos</span>
                            </div>

                            <input class="initial-sequence-input"
                                   value="@PreviousSequence"
                                   @oninput="OnSequenceChanged"
                                   maxlength="9"
                                   inputmode="numeric"
                                   placeholder="@SequencePlaceholder" />

                            @if (!string.IsNullOrWhiteSpace(SequenceHint))
                            {
                                <div class="initial-sequence-hint">
                                    <span class="initial-sequence-hint-marker"></span>
                                    <span>@SequenceHint</span>
                                </div>
                            }
                        </div>
                    }
                    else if (HadPreviousDocuments == false)
                    {
                        <div class="initial-sequence-info">
                            <strong>Se iniciara la numeracion normal.</strong>
                            <span>La siguiente emision comenzara desde la secuencia inicial configurada para este documento.</span>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <div class="initial-sequence-error" role="alert">
                            @ErrorMessage
                        </div>
                    }
                </div>

                <div class="initial-sequence-footer">
                    <div class="initial-sequence-footer-copy">
                        <strong>Configuracion unica</strong>
                        <span>Este ajuste solo se solicita la primera vez para cada tipo de documento.</span>
                    </div>
                    <button type="button" class="primary-btn initial-sequence-cta" @onclick="OnConfirm">
                        Guardar y continuar
                    </button>
                </div>
            </section>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Configuracion inicial de secuencia";
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string QuestionLabel { get; set; } = "Ya habias generado documentos antes?";
    [Parameter] public string SequenceLabel { get; set; } = "Ingresa la secuencia donde te quedaste";
    [Parameter] public string SequencePlaceholder { get; set; } = "Ej: 000000125";
    [Parameter] public string SequenceHint { get; set; } = "Si te quedaste en la 125, la siguiente sera la 126.";
    [Parameter] public bool? HadPreviousDocuments { get; set; }
    [Parameter] public EventCallback<bool?> HadPreviousDocumentsChanged { get; set; }
    [Parameter] public string PreviousSequence { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> PreviousSequenceChanged { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }

    private Task Dismiss() => OnDismiss.InvokeAsync();

    private string GetResponseValue() => HadPreviousDocuments switch
    {
        true => "true",
        false => "false",
        _ => string.Empty
    };

    private async Task OnResponseChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        bool? parsed = raw switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };

        await HadPreviousDocumentsChanged.InvokeAsync(parsed);
    }

    private Task OnSequenceChanged(ChangeEventArgs e)
        => PreviousSequenceChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);

    private string GetSelectionStateClass() => HadPreviousDocuments switch
    {
        true => "initial-sequence-state initial-sequence-state-positive",
        false => "initial-sequence-state initial-sequence-state-neutral",
        _ => "initial-sequence-state"
    };

    private string GetSelectionStateLabel() => HadPreviousDocuments switch
    {
        true => "Continuar secuencia",
        false => "Empezar desde cero",
        _ => string.Empty
    };
}
