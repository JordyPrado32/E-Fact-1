    private async Task<int?> ObtenerIdUsuarioLogueado()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var idClaim = user.FindFirst("IdUsuario")?.Value;
        return int.TryParse(idClaim, out var id) ? id : null;
    }

    private Task OnRucKeyDownAsync(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            omitirSiguienteGuardadoPorConsultaSri = true;
        }

        return Task.CompletedTask;
    }

    private async Task OnRucKeyUpAsync(KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await ConsultarSriPorRucAsync();
    }

    private async Task ConsultarSriPorRucAsync()
    {
        if (isDemoMode)
        {
            mensaje = "Modo demo: la consulta automática al SRI está bloqueada.";
            debugError = null;
            return;
        }

        var ruc = SoloDigitos(model.Ruc);
        model.Ruc = ruc;

        if (string.IsNullOrWhiteSpace(ruc))
        {
            mensaje = "Ingresa un RUC antes de consultar al SRI.";
            debugError = null;
            return;
        }

        if (ruc.Length != 13)
        {
            mensaje = "El RUC debe tener 13 dígitos para consultar al SRI.";
            debugError = null;
            return;
        }

        consultandoSri = true;
        mensaje = "Consultando datos del SRI...";
        debugError = null;
        StateHasChanged();

        try
        {
            var consulta = new CConsultaSri();
            var datos = await Task.Run(() => consulta.GetRucSri(ruc));

            if (datos is null)
            {
                mensaje = "El SRI no devolvió información para este RUC.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(datos.Error))
            {
                mensaje = "No se pudieron recuperar los datos del SRI.";
                debugError = FormatearMensajeError(datos.Error);
                return;
            }

            AplicarDatosSri(datos, ruc);
            var establecimientoDetectado = string.IsNullOrWhiteSpace(model.CodEstablecimiento)
                ? null
                : model.CodEstablecimiento;

            mensaje = establecimientoDetectado is null
                ? "Datos del SRI cargados. Revisa y completa los campos faltantes antes de guardar."
                : $"Datos del SRI cargados. El establecimiento {establecimientoDetectado} quedará asignado automáticamente en puntos de emisión cuando guardes el emisor.";
            debugError = null;
        }
        catch (Exception ex)
        {
            mensaje = "Ocurrió un error al consultar el SRI.";
            debugError = FormatearMensajeError(ex.Message);
        }
        finally
        {
            consultandoSri = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void AplicarDatosSri(DatosPersonaSri datos, string ruc)
    {
        var establecimiento = SeleccionarEstablecimientoSri(datos.personaEstablecimientos);
        var nombreComercial = Convert.ToString(datos.nombreComercial)?.Trim();

        model.Ruc = ruc;
        model.RazonSocial = TextoSeguro(datos.razonSocial);
        model.NomComercial = TextoSeguro(nombreComercial);
        model.LlevaContabilidad = "NO";
        model.Retenciones = "NO";
        model.DireccionMatriz = TextoSeguro(establecimiento?.direccionCompleta);
        model.DirEstablecimiento = TextoSeguro(establecimiento?.direccionCompleta);
        model.CodEstablecimiento = NormalizarCodigoEstablecimiento(establecimiento?.numeroEstablecimiento);
    }

    private static PersonaEstablecimientosRuc? SeleccionarEstablecimientoSri(List<PersonaEstablecimientosRuc>? establecimientos)
    {
        if (establecimientos is null || establecimientos.Count == 0)
        {
            return null;
        }

        return establecimientos.FirstOrDefault(item =>
                   (item.estado ?? string.Empty).Contains("ABIER", StringComparison.OrdinalIgnoreCase) ||
                   (item.estado ?? string.Empty).Contains("ACT", StringComparison.OrdinalIgnoreCase))
               ?? establecimientos.FirstOrDefault();
    }

    private static string TextoSeguro(string? valor) =>
        string.IsNullOrWhiteSpace(valor) ? string.Empty : valor.Trim();

    private static string MapearLlevaContabilidadSri(DatosPersonaSri datos)
    {
        var obligado = datos.obligado?.Trim();
        if (string.IsNullOrWhiteSpace(obligado))
        {
            return "NO";
        }

        if (obligado.Equals("SI", StringComparison.OrdinalIgnoreCase) ||
            obligado.Equals("S", StringComparison.OrdinalIgnoreCase) ||
            obligado.Equals("Si", StringComparison.OrdinalIgnoreCase) ||
            obligado.Contains("OBLIG", StringComparison.OrdinalIgnoreCase))
        {
            return "SI";
        }

        if (obligado.Equals("NO", StringComparison.OrdinalIgnoreCase) ||
            obligado.Equals("N", StringComparison.OrdinalIgnoreCase) ||
            obligado.Equals("No", StringComparison.OrdinalIgnoreCase) ||
            obligado.Contains("NO OBLIG", StringComparison.OrdinalIgnoreCase))
        {
            return "NO";
        }

        return string.Empty;
    }

    private static string MapearRetencionesSri(DatosPersonaSri datos)
    {
        var texto = string.Join(" ",
            new[]
            {
                datos.claseContribuyente,
                datos.subtipoContribuyente,
                datos.actividadContribuyente,
                Convert.ToString(datos.agenteRepresentante),
                Convert.ToString(datos.representanteLegal)
            }.Where(item => !string.IsNullOrWhiteSpace(item)));

        if (string.IsNullOrWhiteSpace(texto))
        {
            return "NO";
        }

        if (texto.Contains("AGENTE DE RETENCION", StringComparison.OrdinalIgnoreCase) ||
            texto.Contains("AGENTE RETENCION", StringComparison.OrdinalIgnoreCase) ||
            texto.Contains("RETENCION", StringComparison.OrdinalIgnoreCase))
        {
            return "SI";
        }

        return "NO";
    }

    private static string? NormalizarCodigoEstablecimiento(string? numeroEstablecimiento)
    {
        var digitos = SoloDigitos(numeroEstablecimiento);
        return string.IsNullOrWhiteSpace(digitos)
            ? null
            : digitos.Length >= 3
                ? digitos[^3..]
                : digitos.PadLeft(3, '0');
    }

    private static string SoloDigitos(string? valor) =>
        new string((valor ?? string.Empty).Where(char.IsDigit).ToArray());

    private bool YaExisteEmisorActivo()
    {
        return emisores.Any(e => e.Estado == true);
    }

    private bool BloquearFormularioCreacion => !editando && YaExisteEmisorActivo();
    private string MensajeBloqueoFormulario => "Esta cuenta ya tiene un emisor activo. Puedes editarlo desde el listado.";

    private async Task Guardar()
    {
        if (omitirSiguienteGuardadoPorConsultaSri || consultandoSri)
        {
            omitirSiguienteGuardadoPorConsultaSri = false;
            return;
        }

        if (isDemoMode)
        {
            mensaje = "Modo demo: guardar emisor está bloqueado.";
            debugError = null;
            return;
        }

        mensaje = "Guardando...";
        debugError = null;

        var idActual = await ObtenerIdUsuarioLogueado();
        if (idActual == null)
        {
            mensaje = "Error: No se pudo identificar al usuario en sesión.";
            return;
        }

        // VALIDACIÓN: solo permitir un emisor al crear
        if (!editando && YaExisteEmisorActivo())
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "Emisor ya registrado",
                text = "Solo puedes registrar un emisor activo en el sistema.",
                confirmButtonText = "Entendido"
            });

            mensaje = "Ya existe un emisor activo registrado.";
            return;
        }

        model.IdUsuario = idActual;
        model.Estado ??= true;
        model.Retenciones = "NO";
        model.LlevaContabilidad = "NO";

        model.RazonSocial = model.RazonSocial?.Trim();
        model.Ruc = model.Ruc?.Trim();
        model.NomComercial = model.NomComercial?.Trim();
        model.DirEstablecimiento = model.DirEstablecimiento?.Trim();
        model.DireccionMatriz = model.DireccionMatriz?.Trim();
        model.ClaveInterna = model.ClaveInterna?.Trim();
        model.Telefono = model.Telefono?.Trim();
        model.Email = model.Email?.Trim();
        model.LlevaContabilidad = model.LlevaContabilidad?.Trim().ToUpperInvariant();
        model.PathCertificado = model.PathCertificado?.Trim();
        model.ClaveCertificado = model.ClaveCertificado?.Trim();
        if (!string.IsNullOrWhiteSpace(model.ClaveCertificado))
        {
            model.EliminarClaveCertificado = false;
        }

        model.CodEstablecimiento = NormalizarCodigoEstablecimiento(model.CodEstablecimiento);
        model.CodPuntoEmision = NormalizarCodigoEstablecimiento(model.CodPuntoEmision) ?? "001";

        try
        {
            var creandoPrimerEmisor = !editando;
            HttpResponseMessage resp = editando
     ? await Http.PutAsJsonAsync($"api/emisores/{model.Codigo}", model)
     : await Http.PostAsJsonAsync("api/emisores", model);

            if (!resp.IsSuccessStatusCode)
            {
                var detalle = await LeerMensajeErrorHttpAsync(resp, "No se pudo guardar el emisor.");

                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "No se pudo guardar el emisor",
                    text = detalle
                });

                debugError = detalle.Equals("No se pudo guardar el emisor.", StringComparison.Ordinal)
                    ? null
                    : detalle;
                mensaje = "No se pudo guardar el emisor.";
                return;
            }

            await CargarTodo();
            Nuevo();
            mostrarModalFormularioEmisor = false;
            await EmisorOnboardingService.RefreshRequirementAsync(idActual);
            EmisorOnboardingService.NotifyChanged();

            mensaje = creandoPrimerEmisor
                ? "Emisor creado correctamente. Puedes configurar la firma electrónica ahora o hacerlo más adelante."
                : "Emisor actualizado correctamente.";
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = "Error al guardar (API).";
        }
    }

    private void ConfirmarEliminar(EmisorDto e)
    {
        emisorAEliminar = e;
        mostrarConfirmacion = true;
    }

    private void CancelarEliminar()
    {
        mostrarConfirmacion = false;
        emisorAEliminar = null;
    }

    private async Task EliminarConfirmado()
    {
        if (emisorAEliminar is null) return;

        if (isDemoMode)
        {
            mensaje = "Modo demo: eliminar emisores está bloqueado.";
            debugError = null;
            CancelarEliminar();
            return;
        }

        try
        {
            var idUsuario = await ObtenerIdUsuarioLogueado();
            if (idUsuario == null || idUsuario <= 0)
            {
                mensaje = "No se pudo obtener la sesión del usuario.";
                return;
            }

            var resp = await Http.PutAsync(
                $"api/emisores/{emisorAEliminar.Codigo}/desactivar?idUsuario={idUsuario}",
                null);

            if (resp.IsSuccessStatusCode)
            {
                mensaje = "Emisor desactivado.";
                await CargarTodo();
                await EmisorOnboardingService.RefreshRequirementAsync(idUsuario);
                CancelarEliminar();
            }
            else
            {
                debugError = await LeerMensajeErrorHttpAsync(resp, "No se pudo desactivar el emisor.");
                mensaje = "No se pudo desactivar el emisor.";
            }
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = "Error al desactivar emisor.";
        }
    }

    private void QuitarLogo()
