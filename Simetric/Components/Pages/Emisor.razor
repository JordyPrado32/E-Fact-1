    private static string FormatearMensajeError(string? rawMessage)
    {
        if (string.IsNullOrWhiteSpace(rawMessage))
        {
            return "Se produjo un error inesperado.";
        }

        var limpio = rawMessage
            .Replace("\r", " ", StringComparison.Ordinal)
            .Replace("\n", " ", StringComparison.Ordinal)
            .Trim();

        if (PareceHtml(limpio))
        {
            return "El servidor devolvió un error interno no controlado.";
        }

        return limpio.Length > 320
            ? $"{limpio[..317].TrimEnd()}..."
            : limpio;
    }

    private async Task<string> LeerMensajeErrorHttpAsync(HttpResponseMessage response, string fallbackMessage)
    {
        var rawBody = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(rawBody))
        {
            return fallbackMessage;
        }

        var mediaType = response.Content.Headers.ContentType?.MediaType;
        var normalizedBody = rawBody.Trim();

        if (string.Equals(mediaType, "text/html", StringComparison.OrdinalIgnoreCase) || PareceHtml(normalizedBody))
        {
            return $"{fallbackMessage} El servidor devolvió un error interno.";
        }

        var messageFromJson = IntentarExtraerMensajeJson(normalizedBody);
        if (!string.IsNullOrWhiteSpace(messageFromJson))
        {
            return FormatearMensajeError(messageFromJson);
        }

        return FormatearMensajeError(normalizedBody);
    }

    private static string? IntentarExtraerMensajeJson(string rawBody)
    {
        try
        {
            using var doc = JsonDocument.Parse(rawBody);
            var root = doc.RootElement;

            if (root.ValueKind == JsonValueKind.String)
            {
                return root.GetString();
            }

            if (root.ValueKind != JsonValueKind.Object)
            {
                return null;
            }

            if (root.TryGetProperty("message", out var messageElement) && messageElement.ValueKind == JsonValueKind.String)
            {
                return messageElement.GetString();
            }

            if (root.TryGetProperty("title", out var titleElement) && titleElement.ValueKind == JsonValueKind.String)
            {
                return titleElement.GetString();
            }

            if (root.TryGetProperty("errors", out var errorsElement) && errorsElement.ValueKind == JsonValueKind.Object)
            {
                foreach (var property in errorsElement.EnumerateObject())
                {
                    if (property.Value.ValueKind != JsonValueKind.Array)
                    {
                        continue;
                    }

                    foreach (var item in property.Value.EnumerateArray())
                    {
                        if (item.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(item.GetString()))
                        {
                            return item.GetString();
                        }
                    }
                }
            }
        }
        catch
        {
            return null;
        }

        return null;
    }

    private static bool PareceHtml(string value) =>
        value.StartsWith("<!DOCTYPE", StringComparison.OrdinalIgnoreCase) ||
        value.StartsWith("<html", StringComparison.OrdinalIgnoreCase);
