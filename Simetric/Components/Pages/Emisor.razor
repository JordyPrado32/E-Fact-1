@page "/emisor"

@page "/demo/emisor"
@using ConsultaDeRucApi.Services
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Simetric.Extensions
@using Simetric.Services
@using System.IO
@using System.Text.Json

@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject EmisorOnboardingService EmisorOnboardingService
@inject EmisionControlService EmisionControlService
@attribute [AllowAnonymous]

@rendermode InteractiveServer

@{
    var filteredEmisores = EmisoresFiltrados.ToList();
}

<PageTitle>Emisor | @PageBrandTitle</PageTitle>

<div class="entity-shell" data-tour="emisor.page">
    @if (MostrarVolverInicioOnboarding)
    {
        <div class="breadcrumb-container">
            <button type="button" class="breadcrumb-home-btn" @onclick='() => NavManager.NavigateTo("/dashboard")'>
                <i class="bi bi-house-door"></i>
                <span>Volver al inicio</span>
            </button>
        </div>
    }

    <section class="entity-hero" data-tour="emisor.hero" style="display:none;">
        <div class="hero-copy">
            <span class="hero-eyebrow">Configuración fiscal</span>
            <h2>Datos del emisor</h2>
            <p>
                Configura la información legal, dirección, obligatoriedad de llevar contabilidad
                y los datos de contacto de tu empresa para la emisión de comprobantes.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Emisores registrados</span>
                <strong>@emisores.Count</strong>
                <small>Empresas configuradas en la plataforma.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Emisores activos</span>
                <strong>@emisores.Count(e => e.Estado == true)</strong>
                <small>Empresas habilitadas para operaciones.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Con RUC registrado</span>
                <strong>@emisores.Count(e => !string.IsNullOrWhiteSpace(e.Ruc))</strong>
                <small>Empresas con identificador tributario válido.</small>
            </article>
        </div>
    </section>
    <section class="quick-action-bar @(YaExisteEmisorActivo() ? "quick-action-bar-has-emisor" : string.Empty)" aria-label="Acciones rápidas de emisor">
        @if (!cargando && !YaExisteEmisorActivo())
        {
            <button type="button" class="quick-action-card quick-action-primary" @onclick="Nuevo">
                <span class="quick-action-icon"><i class="bi bi-building-add"></i></span>
                <span>
                    <strong>Datos del emisor</strong>
                    <small>Iniciar un nuevo registro</small>
                </span>
            </button>
        }

        <button type="button" class="quick-action-card" @onclick="IrAFirma">
            <span class="quick-action-icon quick-action-icon-green"><i class="bi bi-patch-check"></i></span>
            <span>
                <strong>Firma electrónica</strong>
                <small>Configurar certificado</small>
            </span>
        </button>

        <div class="quick-action-search">
            <i class="bi bi-search"></i>
            <input placeholder="Buscar por razón social o RUC..." @bind="filtro" @bind:event="oninput" />
        </div>
    </section>



    <section class="entity-grid">
        <section class="table-card" data-tour="emisor.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado activo</span>
                    <h3>Emisores registrados</h3>
                </div>
                <div class="table-head-actions">
                    <span class="table-badge">@filteredEmisores.Count registros</span>
                    @if (!cargando && !YaExisteEmisorActivo())
                    {
                        <button type="button" class="primary-btn" @onclick="AbrirModalFormularioEmisor">
                            <i class="bi bi-plus-lg"></i>
                            <span>Nuevo emisor</span>
                        </button>
                    }
                </div>
            </div>

            @if (isDemoMode)
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-eye"></i>
                    <span>Modo demo: puedes revisar la configuración, pero guardar, eliminar y subir archivos está bloqueado.</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(debugError))
            {
                <div class="status-banner status-banner-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@debugError</span>
                </div>
            }

            @if (cargando)
            {
                <div class="state-card">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando emisores</h3>
                    <p>Preparando la configuración fiscal y visual de las empresas registradas.</p>
                </div>
            }
            else if (!filteredEmisores.Any())
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="bi bi-building-x"></i>
                    </div>
                    <h3>No hay emisores para mostrar</h3>
                    <p>Completa el formulario para registrar los datos fiscales de tu empresa.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table entity-table entity-table-emisores mb-0">
                        <thead>
                            <tr>
                                <th>Razón social</th>
                                <th>RUC</th>
                                <th class="list-extra-col">Contacto</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in filteredEmisores)
                            {
                                <tr>
                                    <td>
                                        <div class="cell-main cell-main-stacked">
                                            <strong>@e.RazonSocial</strong>
                                            <span>@(string.IsNullOrWhiteSpace(e.NomComercial) ? "Sin nombre comercial" : e.NomComercial)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="code-pill">@(string.IsNullOrWhiteSpace(e.Ruc) ? "Sin RUC" : e.Ruc)</span>
                                    </td>
                                    <td class="list-extra-col">
                                        <div class="compact-detail">
                                            <span><i class="bi bi-envelope"></i> @(string.IsNullOrWhiteSpace(e.Email) ? "Sin correo" : e.Email)</span>
                                            <span><i class="bi bi-telephone"></i> @(string.IsNullOrWhiteSpace(e.Telefono) ? "Sin teléfono" : e.Telefono)</span>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view"
                                                    title="Ver detalle"
                                                    @onclick="() => VerDetalle(e)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (!esAsociado) // Solo se muestra si NO es asociado
                                            {
                                                <button type="button" class="action-btn action-edit"
                                                title="Editar"
                                                @onclick="() => Editar(e.Codigo)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <button type="button" class="action-btn action-delete"
                                                title="Eliminar"
                                                @onclick="() => ConfirmarEliminar(e)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (mostrarConfirmacion && emisorAEliminar is not null)
            {
                <div class="confirm-card">
                    <div class="confirm-copy">
                        <strong>Eliminar lógicamente el emisor</strong>
                        <p>@emisorAEliminar.RazonSocial</p>
                    </div>

                    <div class="confirm-actions">
                        <button type="button" class="secondary-btn" @onclick="CancelarEliminar">Cancelar</button>
                        <button type="button" class="danger-btn" @onclick="EliminarConfirmado">Sí, eliminar</button>
                    </div>
                </div>
            }
        </section>

        <div class="emisor-editor-stack" style="display:none;">
        <section class="editor-card entity-editor-card" data-tour="emisor.editor">
            <div class="editor-head">
                <div>
                    <span>  </span>
                    <h3>@(editando ? "Editar emisor" : "Registrar emisor")</h3>
                    <p>Complete los datos fiscales, de contacto y configuración de la empresa.</p>
                </div>
                
            </div>

            <div class="editor-body entity-form-legacy">

                <EditForm Model="@model" OnValidSubmit="Guardar" @key="formKey">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger small" />

                    @if (BloquearFormularioCreacion)
                    {
                        <div class="status-banner status-banner-info">
                            <i class="bi bi-lock"></i>
                            <span>@MensajeBloqueoFormulario</span>
                        </div>
                    }

                    <fieldset class="p-0 m-0 border-0" disabled="@BloquearFormularioCreacion">
                        <details class="form-accordion" open>
                        <summary class="form-section-heading">
                            <span>1</span>
                            <strong>Información fiscal</strong>
                            <i class="bi bi-chevron-down"></i>
                        </summary>
                        <div class="form-accordion-body">

                        <div class="row mb-2 mt-3">
                            <div class="col">
                                <label class="form-label small fw-bold">Razón Social</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.RazonSocial" />
                                <ValidationMessage For="@(() => model.RazonSocial)" class="text-danger small" />
                            </div>
                            <div class="col">
                                <label class="form-label small fw-bold">RUC *</label>
                                <InputText class="form-control form-control-sm"
                                           @bind-Value="model.Ruc"
                                           @onkeydown="OnRucKeyDownAsync"
                                           @onkeyup="OnRucKeyUpAsync" />
                                <ValidationMessage For="@(() => model.Ruc)" class="text-danger small" />
                                <small class="text-muted d-block mt-1">
                                    Presiona Enter para consultar automáticamente los datos del SRI.
                                </small>
                                @if (consultandoSri)
                                {
                                    <small class="text-primary d-block mt-1">Consultando datos del SRI...</small>
                                }
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Nombre Comercial</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.NomComercial" />
                            <ValidationMessage For="@(() => model.NomComercial)" class="text-danger small" />
                            <small class="text-muted d-block mt-1">
                                Debes ingresar razón social o nombre comercial. No es obligatorio completar ambos.
                            </small>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Dirección Establecimiento *</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.DirEstablecimiento" />
                            <ValidationMessage For="@(() => model.DirEstablecimiento)" class="text-danger small" />
                        </div>

                        <div class="mb-2 d-none">
                            <label class="form-label small fw-bold d-none">Lleva Contabilidad *</label>
                            <InputSelect class="form-select form-select-sm" @bind-Value="model.LlevaContabilidad">
                                <option value="">-- Seleccione --</option>
                                <option value="SI">Sí</option>
                                <option value="NO">No</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => model.LlevaContabilidad)" class="text-danger small" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Dirección Matriz *</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.DireccionMatriz" />
                            <ValidationMessage For="@(() => model.DireccionMatriz)" class="text-danger small" />
                        </div>

                        </div>
                        </details>

                        <details class="form-accordion">
                        <summary class="form-section-heading">
                            <span>2</span>
                            <strong>Identidad visual</strong>
                            <i class="bi bi-chevron-down"></i>
                        </summary>
                        <div class="form-accordion-body">

                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small fw-bold text-primary">
                                    <i class="bi bi-image me-1"></i>Logo Empresa
                                </label>

                                <div class="logo-file-picker">
                                    <InputFile id="logo-empresa-input-page"
                                               class="logo-file-picker-input"
                                               accept=".jpg,.jpeg,.png,image/jpeg,image/png"
                                               OnChange="SubirLogo" />
                                    <label class="logo-file-picker-button" for="logo-empresa-input-page">
                                        Seleccionar archivo
                                    </label>
                                    <span class="logo-file-picker-name">@TextoLogoArchivo</span>
                                </div>

                                <ValidationMessage For="@(() => model.LogoImagen)" class="text-danger small" />

                                <small class="text-muted d-block mt-1">
                                    Dimensiones recomendadas: mínimo 200 × 100 px y máximo 1200 × 600 px. Formatos JPG, JPEG o PNG de hasta 2 MB.
                                </small>

                                @if (!string.IsNullOrWhiteSpace(model.LogoImagen))
                                {
                                    <div class="mt-2 text-center border rounded p-2 bg-light position-relative">
                                        <img src="@model.LogoImagen"
                                             style="max-height: 60px; max-width: 100%; object-fit: contain;"
                                             alt="Logo" />
                                        <button type="button"
                                                class="btn-close position-absolute top-0 end-0 m-1"
                                                style="font-size: 0.5rem;"
                                                title="Quitar logo"
                                                @onclick="QuitarLogo"></button>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-12 mt-2 d-none">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="RetencionesBool" />
                                <label class="form-check-label fw-semibold">
                                    ¿Es agente de Retención?
                                </label>
                            </div>
                        </div>

                        </div>
                        </details>

                        <details class="form-accordion">
                        <summary class="form-section-heading">
                            <span>3</span>
                            <strong>Contacto</strong>
                            <i class="bi bi-chevron-down"></i>
                        </summary>
                        <div class="form-accordion-body">

                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small">Teléfono *</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.Telefono" />
                                <ValidationMessage For="@(() => model.Telefono)" class="text-danger small" />
                            </div>
                        <div class="col">
                            <label class="form-label small">Correo Electrónico</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.Email" />
                            <ValidationMessage For="@(() => model.Email)" class="text-danger small" />
                        </div>
                        </div>

                        </div>
                        </details>

                    </fieldset>

                    <div class="form-actions entity-form-actions">
                        <button class="primary-btn" type="submit" disabled="@(BloquearFormularioCreacion || isDemoMode)">
                            <i class="bi bi-save me-1"></i> @(isDemoMode ? "Guardar bloqueado" : (editando ? "Guardar cambios" : "Crear emisor"))
                        </button>
                        <button type="button"
                                class="secondary-btn clear-action-btn"
                                @onclick="Nuevo"
                                disabled="@BloquearFormularioCreacion">
                            <i class="bi bi-eraser"></i>
                            Limpiar formulario
                        </button>
                    </div>
                </EditForm>
            </div>
        </section>
        </div>
    </section>

    <section class="quick-tips-section" aria-label="Consejos rápidos de emisor">
        <div class="quick-tips-head">
            <span class="quick-tips-head-icon"><i class="bi bi-lightbulb"></i></span>
            <div>
                <strong>Consejos rápidos</strong>
                <small>Revisa estos puntos antes de emitir comprobantes con tu empresa.</small>
            </div>
        </div>

        <div class="quick-tip-grid">
            <article class="quick-tip-item">
                <span class="quick-tip-item-icon quick-tip-item-icon-blue"><i class="bi bi-building-check"></i></span>
                <div>
                    <strong>Datos fiscales completos</strong>
                    <p>Verifica razón social, RUC y direcciones antes de guardar el emisor.</p>
                </div>
            </article>

            <article class="quick-tip-item">
                <span class="quick-tip-item-icon quick-tip-item-icon-green"><i class="bi bi-patch-check"></i></span>
                <div>
                    <strong>Firma electrónica</strong>
                    <p>Configura el certificado para autorizar facturas y guías sin interrupciones.</p>
                </div>
            </article>

            <article class="quick-tip-item">
                <span class="quick-tip-item-icon quick-tip-item-icon-violet"><i class="bi bi-image"></i></span>
                <div>
                    <strong>Identidad visual</strong>
                    <p>Sube un logo liviano para mejorar la presentación de tus documentos PDF.</p>
                </div>
            </article>
        </div>
    </section>

</div>

@if (mostrarModalFormularioEmisor)
{
    <div class="modal fade show d-block" data-no-backdrop-dismiss="true" style="background: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onpointerdown:stopPropagation="true">
        <div class="modal-dialog modal-dialog-centered modal-xl" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onpointerdown:stopPropagation="true">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 18px;">
                <div class="modal-header text-white" style="background-color: var(--n-blue); border-radius: 18px 18px 0 0;">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-building me-2"></i>@(editando ? "Editar emisor" : "Registrar emisor")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalFormularioEmisor"></button>
                </div>
                <div class="modal-body p-4" style="max-height: calc(100vh - 180px); overflow-y:auto;">
                    <section class="editor-card entity-editor-card">
                        <div class="editor-body entity-form-legacy">
                            <EditForm Model="@model" OnValidSubmit="Guardar" @key="formKey">
                                <DataAnnotationsValidator />
                                <ValidationSummary class="text-danger small" />

                                @if (BloquearFormularioCreacion)
                                {
                                    <div class="status-banner status-banner-info">
                                        <i class="bi bi-lock"></i>
                                        <span>@MensajeBloqueoFormulario</span>
                                    </div>
                                }

                                <fieldset class="p-0 m-0 border-0" disabled="@BloquearFormularioCreacion">
                                    <details class="form-accordion" open>
                                        <summary class="form-section-heading">
                                            <span>1</span>
                                            <strong>Información fiscal</strong>
                                            <i class="bi bi-chevron-down"></i>
                                        </summary>
                                        <div class="form-accordion-body">
                                            <div class="row mb-2 mt-3">
                                                <div class="col">
                                                    <label class="form-label small fw-bold">Razón Social</label>
                                                    <InputText class="form-control form-control-sm" @bind-Value="model.RazonSocial" />
                                                    <ValidationMessage For="@(() => model.RazonSocial)" class="text-danger small" />
                                                </div>
                                                <div class="col">
                                                    <label class="form-label small fw-bold">RUC *</label>
                                                    <InputText class="form-control form-control-sm"
                                                               @bind-Value="model.Ruc"
                                                               @onkeydown="OnRucKeyDownAsync"
                                                               @onkeyup="OnRucKeyUpAsync" />
                                                    <ValidationMessage For="@(() => model.Ruc)" class="text-danger small" />
                                                    <small class="text-muted d-block mt-1">
                                                        Presiona Enter para consultar automáticamente los datos del SRI.
                                                    </small>
                                                    @if (consultandoSri)
                                                    {
                                                        <small class="text-primary d-block mt-1">Consultando datos del SRI...</small>
                                                    }
                                                </div>
                                            </div>

                                            <div class="mb-2">
                                                <label class="form-label small">Nombre Comercial</label>
                                                <InputText class="form-control form-control-sm" @bind-Value="model.NomComercial" />
                                                <ValidationMessage For="@(() => model.NomComercial)" class="text-danger small" />
                                                <small class="text-muted d-block mt-1">
                                                    Debes ingresar razón social o nombre comercial. No es obligatorio completar ambos.
                                                </small>
                                            </div>

                                            <div class="mb-2">
                                                <label class="form-label small">Dirección Establecimiento *</label>
                                                <InputText class="form-control form-control-sm" @bind-Value="model.DirEstablecimiento" />
                                                <ValidationMessage For="@(() => model.DirEstablecimiento)" class="text-danger small" />
                                            </div>

                                            <div class="mb-2 d-none">
                                                <label class="form-label small fw-bold d-none">Lleva Contabilidad *</label>
                                                <InputSelect class="form-select form-select-sm" @bind-Value="model.LlevaContabilidad">
                                                    <option value="">-- Seleccione --</option>
                                                    <option value="SI">Sí</option>
                                                    <option value="NO">No</option>
                                                </InputSelect>
                                                <ValidationMessage For="@(() => model.LlevaContabilidad)" class="text-danger small" />
                                            </div>

                                            <div class="mb-2">
                                                <label class="form-label small">Dirección Matriz *</label>
                                                <InputText class="form-control form-control-sm" @bind-Value="model.DireccionMatriz" />
                                                <ValidationMessage For="@(() => model.DireccionMatriz)" class="text-danger small" />
                                            </div>
                                        </div>
                                    </details>

                                    <details class="form-accordion">
                                        <summary class="form-section-heading">
                                            <span>2</span>
                                            <strong>Identidad visual</strong>
                                            <i class="bi bi-chevron-down"></i>
                                        </summary>
                                        <div class="form-accordion-body">
                                            <div class="row mb-2">
                                                <div class="col">
                                                    <label class="form-label small fw-bold text-primary">
                                                        <i class="bi bi-image me-1"></i>Logo Empresa
                                                    </label>
                                                    <div class="logo-file-picker">
                                                        <InputFile id="logo-empresa-input-modal"
                                                                   class="logo-file-picker-input"
                                                                   accept=".jpg,.jpeg,.png,image/jpeg,image/png"
                                                                   OnChange="SubirLogo" />
                                                        <label class="logo-file-picker-button" for="logo-empresa-input-modal">
                                                            Seleccionar archivo
                                                        </label>
                                                        <span class="logo-file-picker-name">@TextoLogoArchivo</span>
                                                    </div>
                                                    <ValidationMessage For="@(() => model.LogoImagen)" class="text-danger small" />
                                                    <small class="text-muted d-block mt-1">
                                                        Dimensiones recomendadas: mínimo 200 × 100 px y máximo 1200 × 600 px. Formatos JPG, JPEG o PNG de hasta 2 MB.
                                                    </small>
                                                    @if (!string.IsNullOrWhiteSpace(model.LogoImagen))
                                                    {
                                                        <div class="mt-2 text-center border rounded p-2 bg-light position-relative">
                                                            <img src="@model.LogoImagen"
                                                                 style="max-height: 60px; max-width: 100%; object-fit: contain;"
                                                                 alt="Logo" />
                                                            <button type="button"
                                                                    class="btn-close position-absolute top-0 end-0 m-1"
                                                                    style="font-size: 0.5rem;"
                                                                    title="Quitar logo"
                                                                    @onclick="QuitarLogo"></button>
                                                        </div>
                                                    }
                                                </div>
                                            </div>

                                            <div class="col-12 mt-2 d-none">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox class="form-check-input" @bind-Value="RetencionesBool" />
                                                    <label class="form-check-label fw-semibold">
