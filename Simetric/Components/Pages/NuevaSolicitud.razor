                        {
                            <div class="solicitud-alert solicitud-alert-warning">
                                <i class="bi bi-camera-video-fill"></i>
                                <span>Al ser mayor de 65 años, en el siguiente paso se solicitará también un video corto de aceptación.</span>
                            </div>
                        }

                        <div class="solicitud-actions">
                            <button type="button" class="primary-btn solicitud-action-main" @onclick="IrAPasoDocumentos">
                                Continuar con documentos <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                }
            </section>
        }
        else
        {
            <section class="solicitud-card" data-tour="solicitud.step2">
                <div class="solicitud-card-header">
                    <div class="solicitud-step-pill">Paso 2</div>
                    <div>
                        <h3>Adjunta la documentación requerida</h3>
                        <p>Los archivos se validan por formato y tamaño antes de enviar la solicitud.</p>
                    </div>
                </div>

                <div class="solicitud-config-banner">
                    <span class="solicitud-config-chip">@GetFormatoFirmaLabel()</span>
                    <span class="solicitud-config-chip">@GetVigenciaLabel(solicitud.SolVigencia)</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensajeArchivos))
                {
                    <div class="solicitud-alert solicitud-alert-danger">
                        <i class="bi bi-paperclip"></i>
                        <span>@mensajeArchivos</span>
                    </div>
                }

                <div class="solicitud-grid solicitud-upload-grid" data-tour="solicitud.uploads">
                    @foreach (var documento in ObtenerDocumentosVisibles())
                    {
                        <div class="solicitud-upload-card @(TieneArchivo(documento.Tipo) ? "solicitud-upload-card-loaded" : string.Empty) @(documento.Tipo == "VIDEO_ACEPTACION" ? "solicitud-upload-card-warning" : string.Empty)">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">@documento.Titulo</label>
                                <span class="solicitud-field-tag">@(documento.EsObligatorio ? "Obligatorio" : "Opcional")</span>
                            </div>

                            <p class="solicitud-upload-help">@documento.Ayuda</p>

                            <InputFile OnChange="@(e => OnFile(e, documento.Tipo))"
                                       class="solicitud-upload-input"
                                       accept="@documento.Accept" />

                            @if (TieneArchivo(documento.Tipo))
                            {
                                <div class="solicitud-upload-ok">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>@ObtenerNombreArchivo(documento.Tipo)</span>
                                </div>
                            }

                            @if (erroresDocumentos.TryGetValue(documento.Tipo, out var errorDocumento))
                            {
                                <div class="solicitud-field-error">@errorDocumento</div>
                            }

                            <small class="solicitud-upload-meta">
                                Formatos: @documento.FormatosTexto | Máximo: @FormatearTamano(documento.TamanoMaximoBytes)
                            </small>
                        </div>
                    }
                </div>

                <div class="solicitud-actions solicitud-actions-between" data-tour="solicitud.submit">
                    <button type="button" class="secondary-btn" @onclick="RegresarAPasoUno">
                        <i class="bi bi-arrow-left"></i> Regresar
                    </button>

                    <button type="submit" class="primary-btn solicitud-action-main" disabled="@enviando">
                        @if (enviando)
                        {
                            <span>Enviando solicitud...</span>
                        }
                        else
                        {
                            <span>Finalizar y enviar</span>
                        }
                    </button>
                </div>
            </section>
        }
    </EditForm>
</div>

