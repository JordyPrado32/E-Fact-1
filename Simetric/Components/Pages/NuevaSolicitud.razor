                                        <option value="@provincia.Nombre">@provincia.Nombre</option>
                                    }
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolProvincia)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Cantón *</label>
                                <span class="solicitud-field-tag">Seleccione</span>
                            </div>
