@page "/solicitud/nueva"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.Models
@using Simetric.Services
@inject PagoService PagoService
@inject SolicitudService SolicitudService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject SelectedAppServiceStateService SelectedAppServiceState

<div class="solicitud-shell" data-tour="solicitud.page">
    <section class="solicitud-hero" data-tour="solicitud.hero">
        <div>
            <span class="solicitud-kicker">Firma electrónica</span>
            <h2>Solicitud guiada en dos pasos</h2>
            <p>
                Primero define el tipo de firma y la vigencia requerida. Después completa tus datos
                y adjunta la documentación obligatoria.
            </p>
        </div>

        <div class="solicitud-hero-badges">
            <span class="solicitud-hero-chip"><i class="bi bi-shield-check"></i> Validación completa</span>
        </div>
    </section>

    <EditForm EditContext="editContext" OnValidSubmit="Enviar">
        <DataAnnotationsValidator />

        @if (mostrarResumenValidacion)
        {
            <ValidationSummary class="solicitud-validation-summary" />
        }

        @if (!string.IsNullOrWhiteSpace(mensajeGeneralFormulario))
        {
            <div class="solicitud-alert solicitud-alert-danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@mensajeGeneralFormulario</span>
            </div>
        }

        @if (paso == 1)
        {
            <section class="solicitud-card" data-tour="solicitud.step1">
                <div class="solicitud-card-header">
                    <div class="solicitud-step-pill">Paso 1</div>
                    <div>
                        <h3>Configura la firma que necesitas</h3>
                        <p>Esta selección desbloquea el resto del formulario y deja el flujo en el orden correcto.</p>
                    </div>
                </div>

                <div class="solicitud-setup-shell">
                    <div class="solicitud-setup-card">
                        <div class="solicitud-field-top">
                            <label class="solicitud-field-label">Tipo de firma requerida *</label>
                            <span class="solicitud-field-tag">Servicio</span>
                        </div>

                        <div class="solicitud-choice-grid">
                            <button type="button"
                                    class="solicitud-choice-card is-selected"
                                    @onclick='() => SeleccionarFormatoFirma("ARCHIVO_P12")'>
                                <span class="solicitud-choice-icon">
                                    <i class="bi bi-file-earmark-lock"></i>
                                </span>
                                <span class="solicitud-choice-copy">
                                    <strong>Archivo .P12</strong>
                                    <small>Descargable para usarlo desde tu equipo.</small>
                                </span>
                            </button>

                        </div>

                        <ValidationMessage For="@(() => solicitud.SolFormatoFirma)" class="solicitud-field-error" />
                    </div>

                    <div class="solicitud-setup-card">
                        <div class="solicitud-field-top">
                            <label class="solicitud-field-label">Vigencia requerida *</label>
                            <span class="solicitud-field-tag">Tiempo</span>
                        </div>

                        <div class="solicitud-duration-grid">
                            @foreach (var vigencia in VigenciasDisponibles)
                            {
                                <button type="button"
                                        class="solicitud-duration-pill @(solicitud.SolVigencia == vigencia ? "is-selected" : string.Empty)"
                                        @onclick='() => SeleccionarVigencia(vigencia)'>
                                    <div>
                                        <strong>@GetVigenciaLabel(vigencia)</strong>
                                        <small>@GetPrecioVigencia(vigencia)</small>
                                    </div>
                                </button>
                            }
                        </div>

                        <ValidationMessage For="@(() => solicitud.SolVigencia)" class="solicitud-field-error" />
                        <div class="solicitud-empty-state mt-3">
                            <i class="bi bi-cash-coin"></i>
                            <div>
                                <strong>Precio final al cliente.</strong>
                                <span>Los valores mostrados incluyen nuestro servicio, acompañamiento y valor agregado sobre el costo base del proveedor.</span>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!ConfiguracionFirmaCompleta)
                {
                    <div class="solicitud-empty-state">
                        <i class="bi bi-arrow-up-right-circle"></i>
                        <div>
                            <strong>Completa primero la configuración de la firma.</strong>
                            <span>En cuanto selecciones el tipo y la vigencia, aparecerá el formulario completo.</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="solicitud-config-banner">
                        <span class="solicitud-config-chip">@GetFormatoFirmaLabel()</span>
                        <span class="solicitud-config-chip">@GetVigenciaLabel(solicitud.SolVigencia)</span>
                    </div>
                    <section class="solicitud-persona-panel">
                        <div class="solicitud-persona-header">
                            <span class="solicitud-section-kicker">Tipo de persona</span>
                            <h4>Selecciona el titular</h4>
                        </div>

                        <div class="solicitud-persona-grid">
                            @foreach (var tipoPersona in TiposPersonaDisponibles)
                            {
                                var tipoPersonaSeleccionado = string.Equals(
                                    solicitud.SolTipoPersona,
                                    tipoPersona.Valor,
                                    StringComparison.OrdinalIgnoreCase);

                                <button type="button"
                                        class="solicitud-persona-card @(tipoPersonaSeleccionado ? "is-selected" : string.Empty)"
                                        @onclick='() => SeleccionarTipoPersona(tipoPersona.Valor)'>
                                    <span class="solicitud-persona-icon">
                                        <i class="@tipoPersona.Icono"></i>
                                    </span>
                                    <span class="solicitud-persona-copy">
                                        <strong>@tipoPersona.Titulo</strong>
                                        <small>@tipoPersona.Descripcion</small>
                                    </span>
                                </button>
                            }
                        </div>

                        <ValidationMessage For="@(() => solicitud.SolTipoPersona)" class="solicitud-field-error" />
                    </section>

                    <div class="solicitud-section-head">
                        <span class="solicitud-section-kicker">Datos personales</span>
                        <h4>Completa la información del solicitante</h4>
                    </div>

                    <div class="solicitud-grid" data-tour="solicitud.form">
                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Tipo de documento *</label>
                                <span class="solicitud-field-tag">Identidad</span>
                            </div>
                            <div class="solicitud-input-shell solicitud-input-shell-select">
                                <i class="bi bi-person-vcard solicitud-input-icon"></i>
                                <InputSelect @bind-Value="solicitud.SolTipoIdentificacion"
                                             class="solicitud-field-input"
                                             @onchange="OnTipoIdentificacionChanged">
                                    <option value="">Seleccione...</option>
                                    <option value="CEDULA">Cédula</option>
                                    <option value="PASAPORTE">Pasaporte</option>
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolTipoIdentificacion)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Identificación *</label>
                                <span class="solicitud-field-tag">Documento</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-credit-card solicitud-input-icon"></i>
                                @if (solicitud.SolTipoIdentificacion == "CEDULA")
                                {
                                    <InputText @bind-Value="solicitud.SolIdentificacion"
                                               class="solicitud-field-input solicitud-field-input-code"
                                               maxlength="10"
                                               placeholder="Ej: 1723456789"
                                               autocomplete="off"
                                               inputmode="numeric"
                                               spellcheck="false"
                                               oninput="this.value = this.value.replace(/\D/g, '').slice(0, 10);" />
                                }
                                else
                                {
                                    <InputText @bind-Value="solicitud.SolIdentificacion"
                                               class="solicitud-field-input solicitud-field-input-code"
                                               maxlength="20"
                                               placeholder="Ej: AB1234567"
                                               autocomplete="off"
                                               spellcheck="false"
                                               oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9-]/g, '').slice(0, 20);" />
                                }
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolIdentificacion)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card solicitud-ruc-card">
                            <div class="solicitud-field-top solicitud-field-top-ruc">
                                <span class="solicitud-field-label">Posee RUC?</span>

                                @if (solicitud.SolTipoPersona == TipoPersonaJuridica)
                                {
                                    <div class="solicitud-switch solicitud-switch-locked solicitud-switch-locked-compact">
                                        <span class="solicitud-switch-lock">
                                            <i class="bi bi-lock-fill"></i>
                                        </span>
                                        <span>Obligatorio</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check form-switch solicitud-switch solicitud-switch-inline">
                                        <InputCheckbox @bind-Value="solicitud.SolTieneRuc" class="form-check-input" id="checkRuc" aria-label="Posee RUC" />
                                    </div>
                                }
                            </div>

                            <div class="solicitud-inline-input-shell @(!solicitud.SolTieneRuc ? "solicitud-input-shell-disabled" : string.Empty)">
                                <i class="bi bi-receipt-cutoff solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolNroRuc"
                                           class="solicitud-field-input solicitud-field-input-code"
                                           maxlength="13"
                                           placeholder="Ingrese los 13 digitos del RUC"
                                           autocomplete="off"
                                           inputmode="numeric"
                                           spellcheck="false"
                                           disabled="@(!solicitud.SolTieneRuc)"
                                           oninput="this.value = this.value.replace(/\D/g, '').slice(0, 13);" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolNroRuc)" class="solicitud-field-error" />
                        </div>

                        @if (solicitud.SolTipoIdentificacion == "CEDULA")
                        {
                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Código dactilar *</label>
                                    <span class="solicitud-field-tag">Cédula</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-fingerprint solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolCodigoDactilar"
                                               class="solicitud-field-input solicitud-field-input-uppercase solicitud-field-input-code"
                                               maxlength="10"
                                               placeholder="Ej: A1234B5678"
                                               autocomplete="off"
                                               spellcheck="false"
                                               oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 10);" />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolCodigoDactilar)" class="solicitud-field-error" />
                            </div>
                        }

                        @if (solicitud.SolTipoPersona == TipoPersonaJuridica)
                        {
                            <div class="solicitud-section-head solicitud-section-head-corporate solicitud-field-wide">
                                <span class="solicitud-section-kicker">Datos de la empresa</span>
                                <h4>Información corporativa</h4>
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Razón social de la empresa *</label>
                                    <span class="solicitud-field-tag">Empresa</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-building-fill-gear solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolCompanyName"
                                               class="solicitud-field-input"
                                               maxlength="150"
                                               placeholder="Ej: SIMETRIC S.A." />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolCompanyName)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Departamento</label>
                                    <span class="solicitud-field-tag solicitud-field-tag-soft">Opcional</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-diagram-3 solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolDepartment"
                                               class="solicitud-field-input"
                                               maxlength="100"
                                               placeholder="Ej: TI / Financiero" />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolDepartment)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Cargo *</label>
                                    <span class="solicitud-field-tag">Empresa</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-person-workspace solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolPosition"
                                               class="solicitud-field-input"
                                               maxlength="100"
                                               placeholder="Ej: Gerente General" />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolPosition)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Motivo de firma *</label>
                                    <span class="solicitud-field-tag">Empresa</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-patch-question-fill solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolReason"
                                               class="solicitud-field-input"
                                               maxlength="250"
                                               placeholder="Ej: Facturacion Electronica" />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolReason)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-section-head solicitud-section-head-manager solicitud-field-wide">
                                <span class="solicitud-section-kicker">Representante legal</span>
                                <h4>Información del representante</h4>
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Tipo de documento *</label>
                                    <span class="solicitud-field-tag">Representante</span>
                                </div>
                                <div class="solicitud-input-shell solicitud-input-shell-select">
                                    <i class="bi bi-person-vcard solicitud-input-icon"></i>
                                    <InputSelect @bind-Value="solicitud.SolIdentificationTypeManager"
                                                 class="solicitud-field-input">
                                        <option value="">Seleccione...</option>
                                        <option value="CEDULA">Cédula</option>
                                        <option value="PASAPORTE">Pasaporte</option>
                                    </InputSelect>
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolIdentificationTypeManager)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Identificación *</label>
                                    <span class="solicitud-field-tag">Representante</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-credit-card solicitud-input-icon"></i>
                                    @if (solicitud.SolIdentificationTypeManager == "CEDULA")
                                    {
                                        <InputText @bind-Value="solicitud.SolIdentificationManager"
                                                   class="solicitud-field-input solicitud-field-input-code"
                                                   maxlength="10"
                                                   placeholder="Ej: 1723456789"
                                                   autocomplete="off"
                                                   inputmode="numeric"
                                                   spellcheck="false"
                                                   oninput="this.value = this.value.replace(/\D/g, '').slice(0, 10);" />
                                    }
                                    else
                                    {
                                        <InputText @bind-Value="solicitud.SolIdentificationManager"
                                                   class="solicitud-field-input solicitud-field-input-code"
                                                   maxlength="20"
                                                   placeholder="Ej: AB1234567"
                                                   autocomplete="off"
                                                   spellcheck="false"
                                                   oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9-]/g, '').slice(0, 20);" />
                                    }
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolIdentificationManager)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Nombres del Representante *</label>
                                    <span class="solicitud-field-tag">Representante</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-person-fill solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolNamesManager"
                                               class="solicitud-field-input"
                                               maxlength="100"
                                               oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ' -]/g, '').slice(0, 100);" />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolNamesManager)" class="solicitud-field-error" />
                            </div>

                            <div class="solicitud-field-card">
                                <div class="solicitud-field-top">
                                    <label class="solicitud-field-label">Apellidos del Representante *</label>
                                    <span class="solicitud-field-tag">Representante</span>
                                </div>
                                <div class="solicitud-input-shell">
                                    <i class="bi bi-person-fill solicitud-input-icon"></i>
                                    <InputText @bind-Value="solicitud.SolLastNameManager"
                                               class="solicitud-field-input"
                                               maxlength="100"
                                               oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ' -]/g, '').slice(0, 100);" />
                                </div>
                                <ValidationMessage For="@(() => solicitud.SolLastNameManager)" class="solicitud-field-error" />
                            </div>
                        }

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Nombres *</label>
                                <span class="solicitud-field-tag">Personal</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-person solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolNombres"
                                           class="solicitud-field-input"
                                           maxlength="100"
                                           autocomplete="given-name"
                                           oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ' -]/g, '').slice(0, 100);" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolNombres)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Primer apellido *</label>
                                <span class="solicitud-field-tag">Personal</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-person solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolPrimerApellido"
                                           class="solicitud-field-input"
                                           maxlength="100"
                                           autocomplete="family-name"
                                           oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ' -]/g, '').slice(0, 100);" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolPrimerApellido)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Segundo apellido</label>
                                <span class="solicitud-field-tag solicitud-field-tag-soft">Opcional</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-person solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolSegundoApellido"
                                           class="solicitud-field-input"
                                           maxlength="100"
                                           autocomplete="additional-name"
                                           oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ' -]/g, '').slice(0, 100);" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolSegundoApellido)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Fecha de nacimiento *</label>
                                <span class="solicitud-field-tag">Edad</span>
                            </div>
                            <div class="solicitud-input-shell solicitud-input-shell-date">
                                <i class="bi bi-calendar-event solicitud-input-icon"></i>
                                <InputDate TValue="DateTime"
                                           @bind-Value="solicitud.SolFechaNacimiento"
                                           @onblur="@(_ => VerificarEdad())"
                                           class="solicitud-field-input"
                                           max="@fechaMaximaNacimiento" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolFechaNacimiento)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Sexo *</label>
                                <span class="solicitud-field-tag">Perfil</span>
                            </div>
                            <div class="solicitud-input-shell solicitud-input-shell-select">
                                <i class="bi bi-gender-ambiguous solicitud-input-icon"></i>
                                <InputSelect @bind-Value="solicitud.SolSexo" class="solicitud-field-input">
                                    <option value="">Seleccione...</option>
                                    <option value="M">Hombre</option>
                                    <option value="F">Mujer</option>
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolSexo)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Nacionalidad *</label>
                                <span class="solicitud-field-tag">Catálogo</span>
                            </div>
                            <div class="solicitud-input-shell solicitud-input-shell-select">
                                <i class="bi bi-globe-americas solicitud-input-icon"></i>
                                <InputSelect @bind-Value="solicitud.SolNacionalidad" class="solicitud-field-input">
                                    <option value="">Seleccione...</option>
                                    @foreach (var item in catalogoNacionalidades)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolNacionalidad)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Celular *</label>
                                <span class="solicitud-field-tag">Contacto</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-phone solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolTelefono1"
                                           class="solicitud-field-input solicitud-field-input-code"
                                           maxlength="10"
                                           placeholder="Ej: 0998887766"
                                           autocomplete="tel"
                                           inputmode="numeric"
                                           spellcheck="false"
                                           oninput="this.value = this.value.replace(/\D/g, '').slice(0, 10);" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolTelefono1)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Correo principal *</label>
                                <span class="solicitud-field-tag">Contacto</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-envelope solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolCorreo1"
                                           class="solicitud-field-input"
                                           type="email"
                                           maxlength="150"
                                           placeholder="correo@ejemplo.com"
                                           autocomplete="email"
                                           inputmode="email"
                                           autocapitalize="off"
                                           spellcheck="false" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolCorreo1)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Teléfono secundario</label>
                                <span class="solicitud-field-tag solicitud-field-tag-soft">Opcional</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-telephone solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolTelefono2"
                                           class="solicitud-field-input solicitud-field-input-code"
                                           maxlength="10"
                                           autocomplete="tel"
                                           inputmode="numeric"
                                           spellcheck="false"
                                           oninput="this.value = this.value.replace(/\D/g, '').slice(0, 10);" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolTelefono2)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Correo secundario</label>
                                <span class="solicitud-field-tag solicitud-field-tag-soft">Opcional</span>
                            </div>
                            <div class="solicitud-input-shell">
                                <i class="bi bi-envelope-paper solicitud-input-icon"></i>
                                <InputText @bind-Value="solicitud.SolCorreo2"
                                           class="solicitud-field-input"
                                           type="email"
                                           maxlength="150"
                                           placeholder="correo@ejemplo.com"
                                           autocomplete="email"
                                           inputmode="email"
                                           autocapitalize="off"
                                           spellcheck="false" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolCorreo2)" class="solicitud-field-error" />
                        </div>

                        <div class="solicitud-field-card">
                            <div class="solicitud-field-top">
                                <label class="solicitud-field-label">Provincia *</label>
                                <span class="solicitud-field-tag">Seleccione</span>
                            </div>
                            <div class="solicitud-input-shell solicitud-input-shell-select">
                                <i class="bi bi-geo-alt solicitud-input-icon"></i>
                                <InputSelect TValue="string"
                                             Value="@solicitud.SolProvincia"
                                             ValueChanged="@((string value) => OnProvinciaChanged(value))"
                                             ValueExpression="@(() => solicitud.SolProvincia)"
                                             class="solicitud-field-input">
                                    <option value="">Seleccione...</option>
                                    @foreach (var provincia in provinciasEcuador)
