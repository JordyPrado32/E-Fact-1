                                           class="solicitud-field-input"
                                           maxlength="300"
                                           placeholder="Calle principal y secundaria"
                                           autocomplete="street-address" />
                            </div>
                            <ValidationMessage For="@(() => solicitud.SolDireccion)" class="solicitud-field-error" />
                        </div>

