        "2 AÑOS" => "2 años",
        "3 AÑOS" => "3 años",
        "4 AÑOS" => "4 años",
        _ => vigencia
    };

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(solicitud);
        catalogoNacionalidades = NacionalidadesCatalogo.ToList();
        provinciasEcuador = CatalogoUbicacionEcuador.Provincias;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst("IdUsuario")?.Value;
        usuarioActualId = int.TryParse(idClaim, out var parsedId) ? parsedId : 0;
        solicitud.SolFormatoFirma = "ARCHIVO_P12";
        solicitud.SolVigencia = "30 DIAS";
        solicitud.SolMontoPago = 12.29m;
        solicitud.SolTipoPersona = TipoPersonaNatural;
        SincronizarTipoPersonaConRuc();
        ActualizarCantonesDisponibles();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SelectedAppServiceState.SetCurrentServiceKeyAsync("e-sign");
        }
    }

    private void VerificarEdad()
    {
        if (solicitud.SolFechaNacimiento == default)
        {
            solicitud.SolEsMayor65 = false;
            return;
        }

        var edad = DateTime.Today.Year - solicitud.SolFechaNacimiento.Year;
        if (solicitud.SolFechaNacimiento.Date > DateTime.Today.AddYears(-edad))
        {
            edad--;
        }

        solicitud.SolEsMayor65 = edad >= 65;
    }
    private void SeleccionarTipoPersona(string tipoPersona)
    {
        solicitud.SolTipoPersona = tipoPersona;

        if (tipoPersona == TipoPersonaJuridica)
        {
            solicitud.SolTieneRuc = true;
        }
        else
        {
            solicitud.SolTieneRuc = false;
            solicitud.SolNroRuc = null;
        }

        editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolTipoPersona));
        editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolNroRuc));
    }

    private void OnTipoIdentificacionChanged(ChangeEventArgs e)
    {
        solicitud.SolTipoIdentificacion = e.Value?.ToString() ?? string.Empty;

        if (!string.Equals(solicitud.SolTipoIdentificacion, "CEDULA", StringComparison.OrdinalIgnoreCase))
        {
            solicitud.SolCodigoDactilar = null;
            editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolCodigoDactilar));
        }
    }

    private void OnProvinciaChanged(string? provincia)
    {
        solicitud.SolProvincia = provincia ?? string.Empty;
        solicitud.SolCanton = string.Empty;
        ActualizarCantonesDisponibles();
        editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolProvincia));
        editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolCanton));
    }

