    {
        mostrarResumenValidacion = true;
        mensajeGeneralFormulario = null;
        NormalizarSolicitud();
        VerificarEdad();

        if (!editContext.Validate())
        {
            return;
        }

        paso = 2;
    }

    private void RegresarAPasoUno()
    {
        mensajeArchivos = null;
        mensajeGeneralFormulario = null;
        paso = 1;
    }

    private async Task OnFile(InputFileChangeEventArgs e, string tipo)
    {
        mensajeArchivos = null;
        mensajeGeneralFormulario = null;
        erroresDocumentos.Remove(tipo);

        if (archivosTemporales.TryGetValue(tipo, out var oldFile))
        {
            SolicitudService.EliminarArchivoTemporal(oldFile.TempFileName);
            archivosTemporales.Remove(tipo);
        }

        if (!documentos.TryGetValue(tipo, out var config) || e.FileCount == 0)
        {
            return;
        }

        var archivo = e.File;
        var extension = Path.GetExtension(archivo.Name);

        if (string.IsNullOrWhiteSpace(extension) ||
            !config.ExtensionesPermitidas.Contains(extension, StringComparer.OrdinalIgnoreCase))
        {
            erroresDocumentos[tipo] = $"Formato no permitido. Use: {config.FormatosTexto}.";
            return;
        }

        if (archivo.Size > config.TamanoMaximoBytes)
        {
            erroresDocumentos[tipo] = $"El archivo supera el tamaño máximo de {FormatearTamano(config.TamanoMaximoBytes)}.";
            return;
        }

        try
        {
            var tempName = await SolicitudService.GuardarArchivoTemporalAsync(archivo, tipo, config.TamanoMaximoBytes);
            archivosTemporales[tipo] = new ArchivoTemporal(tempName, archivo.Name);
        }
        catch (Exception ex)
        {
            erroresDocumentos[tipo] = $"Error al guardar archivo temporal: {ex.Message}";
        }
    }

    private bool ValidarArchivos()
    {
        mensajeArchivos = null;

        foreach (var item in ObtenerDocumentosVisibles())
        {
            if (!item.EsObligatorio)
            {
                continue;
            }

            if (!archivosTemporales.ContainsKey(item.Tipo) && !erroresDocumentos.ContainsKey(item.Tipo))
            {
                erroresDocumentos[item.Tipo] = $"Adjunte {item.Titulo.ToLowerInvariant()}.";
            }
        }

        var hayErrores = ObtenerDocumentosVisibles().Any(item =>
            (item.EsObligatorio && !archivosTemporales.ContainsKey(item.Tipo)) ||
            erroresDocumentos.ContainsKey(item.Tipo));

        if (hayErrores)
        {
            mensajeArchivos = "Revisa los documentos obligatorios y corrige los archivos con errores antes de enviar.";
            return false;
        }

        return true;
    }

    private async Task Enviar()
    {
        mensajeGeneralFormulario = null;
        mensajeArchivos = null;
        mostrarResumenValidacion = true;
        NormalizarSolicitud();
        VerificarEdad();

        if (!ValidarArchivos())
        {
            return;
        }

        enviando = true;

        try
        {
            if (usuarioActualId <= 0)
            {
                mensajeGeneralFormulario = "No se pudo identificar al usuario actual. Cierra sesion e ingresa nuevamente.";
                paso = 1;
                return;
            }

            solicitud.SolIdUsuarioCliente = usuarioActualId;

            var archivosEnviar = archivosTemporales
                .Select(x => (x.Value.TempFileName, x.Key))
                .ToList();

            var ok = await SolicitudService.CrearSolicitudFullAsync(solicitud, archivosEnviar);
            if (ok)
            {
                var notifyUrl = Navigation
                    .ToAbsoluteUri($"/api/pagomedios/notificacion")
                    .ToString();

                string? urlPago = await PagoService.GenerarSolicitudPago(solicitud, notifyUrl);

                if (!string.IsNullOrEmpty(urlPago))
                {
                    // 3. Redirigir al checkout de Pagomedios
                    Navigation.NavigateTo(urlPago);
                    return;
                }
                else
                {
                    mensajeGeneralFormulario = "Error al conectar con la pasarela de pagos.";
                    return;
                }
            }

            mensajeGeneralFormulario = string.IsNullOrWhiteSpace(SolicitudService.UltimoErrorCrearSolicitud)
                ? "No se pudo procesar la solicitud. Intente nuevamente en unos minutos."
                : $"No se pudo procesar la solicitud: {SolicitudService.UltimoErrorCrearSolicitud}";
        }
        finally
        {
            enviando = false;
        }
    }

    private IEnumerable<DocumentoConfig> ObtenerDocumentosVisibles()
    {
        yield return documentos["CEDULA_FRONTAL"];
        yield return documentos["CEDULA_POSTERIOR"];
        yield return documentos["SELFIE_CEDULA"];

        if (solicitud.SolEsMayor65)
        {
            yield return documentos["VIDEO_ACEPTACION"];
        }

        if (solicitud.SolTieneRuc)
        {
            yield return documentos["RUC_FILE"];
        }

        if (string.Equals(solicitud.SolTipoPersona, "JURIDICA", StringComparison.OrdinalIgnoreCase))
        {
            yield return documentos["NOMBRAMIENTO"];
            yield return documentos["CONSTITUCION"];
            yield return documentos["CEDULA_REPRESENTANTE"];
            yield return documentos["AUTORIZACION"];
            yield return documentos["ACEPTACION_NOMBRAMIENTO"];
        }

        yield return documentos["ARCHIVO_ADICIONAL"];
    }

    private bool TieneArchivo(string tipo) => archivosTemporales.ContainsKey(tipo);

    private string ObtenerNombreArchivo(string tipo)
        => archivosTemporales.TryGetValue(tipo, out var archivo) ? archivo.NombreOriginal : string.Empty;

    private string GetFormatoFirmaLabel() => solicitud.SolFormatoFirma switch
    {
        "ARCHIVO_P12" => "Archivo .P12",
        "NUBE" => "Firma en la nube",
        _ => "Firma"
    };

    private void NormalizarSolicitud()
    {
        solicitud.SolTipoPersona = NormalizarMayusculas(solicitud.SolTipoPersona);
        solicitud.SolTipoIdentificacion = NormalizarMayusculas(solicitud.SolTipoIdentificacion);
        solicitud.SolIdentificacion = solicitud.SolTipoIdentificacion == "CEDULA"
            ? SoloDigitos(solicitud.SolIdentificacion)
            : NormalizarMayusculasSinEspacios(solicitud.SolIdentificacion);
        solicitud.SolCodigoDactilar = solicitud.SolTipoIdentificacion == "CEDULA"
            ? NormalizarMayusculasSinEspacios(solicitud.SolCodigoDactilar)
            : null;
        solicitud.SolNombres = NormalizarTexto(solicitud.SolNombres);
        solicitud.SolPrimerApellido = NormalizarTexto(solicitud.SolPrimerApellido);
        solicitud.SolSegundoApellido = NormalizarTexto(solicitud.SolSegundoApellido);
        solicitud.SolNacionalidad = NormalizarMayusculas(solicitud.SolNacionalidad);
        solicitud.SolSexo = NormalizarMayusculas(solicitud.SolSexo);
        solicitud.SolTelefono1 = SoloDigitos(solicitud.SolTelefono1);
        solicitud.SolTelefono2 = SoloDigitos(solicitud.SolTelefono2);
        solicitud.SolCorreo1 = NormalizarEmail(solicitud.SolCorreo1);
        solicitud.SolCorreo2 = NormalizarEmail(solicitud.SolCorreo2);
        solicitud.SolNroRuc = solicitud.SolTieneRuc
            ? SoloDigitos(solicitud.SolNroRuc)
            : null;
        solicitud.SolProvincia = CatalogoUbicacionEcuador.ObtenerProvinciaCanonical(solicitud.SolProvincia)
            ?? NormalizarTexto(solicitud.SolProvincia);
        solicitud.SolCanton = CatalogoUbicacionEcuador.ObtenerCantonCanonical(solicitud.SolProvincia, solicitud.SolCanton)
            ?? NormalizarTexto(solicitud.SolCanton);
        solicitud.SolDireccion = NormalizarTexto(solicitud.SolDireccion);
        solicitud.SolFormatoFirma = NormalizarMayusculas(solicitud.SolFormatoFirma);
        solicitud.SolVigencia = NormalizarMayusculas(solicitud.SolVigencia);

        if (solicitud.SolTipoPersona == TipoPersonaJuridica)
        {
            solicitud.SolCompanyName = NormalizarTexto(solicitud.SolCompanyName);
            solicitud.SolDepartment = NormalizarTexto(solicitud.SolDepartment);
            solicitud.SolPosition = NormalizarTexto(solicitud.SolPosition);
            solicitud.SolReason = NormalizarTexto(solicitud.SolReason);
            solicitud.SolIdentificationTypeManager = NormalizarMayusculas(solicitud.SolIdentificationTypeManager);
            solicitud.SolIdentificationManager = solicitud.SolIdentificationTypeManager == "CEDULA"
                ? SoloDigitos(solicitud.SolIdentificationManager)
                : NormalizarMayusculasSinEspacios(solicitud.SolIdentificationManager);
            solicitud.SolNamesManager = NormalizarTexto(solicitud.SolNamesManager);
            solicitud.SolLastNameManager = NormalizarTexto(solicitud.SolLastNameManager);
        }
        else
        {
            solicitud.SolCompanyName = null;
            solicitud.SolDepartment = null;
            solicitud.SolPosition = null;
            solicitud.SolReason = null;
            solicitud.SolIdentificationTypeManager = null;
            solicitud.SolIdentificationManager = null;
            solicitud.SolNamesManager = null;
            solicitud.SolLastNameManager = null;
        }

        SincronizarTipoPersonaConRuc();
        ActualizarCantonesDisponibles();
    }

    private void SincronizarTipoPersonaConRuc()
    {
        if (solicitud.SolTipoPersona == TipoPersonaJuridica)
        {
            solicitud.SolTieneRuc = true;
            return;
        }

        if (!solicitud.SolTieneRuc)
        {
            solicitud.SolNroRuc = null;
        }
    }

    private void ActualizarCantonesDisponibles()
    {
        cantonesDisponibles = CatalogoUbicacionEcuador.ObtenerCantones(solicitud.SolProvincia).ToList();

        if (cantonesDisponibles.Count == 0)
        {
            solicitud.SolCanton = string.Empty;
            return;
        }

        var cantonCanonical = CatalogoUbicacionEcuador.ObtenerCantonCanonical(solicitud.SolProvincia, solicitud.SolCanton);
        solicitud.SolCanton = cantonCanonical ?? string.Empty;
    }

    private static string NormalizarTexto(string? valor)
        => string.Join(" ", (valor ?? string.Empty).Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries));

    private static string NormalizarMayusculas(string? valor)
        => NormalizarTexto(valor).ToUpperInvariant();

    private static string NormalizarMayusculasSinEspacios(string? valor)
        => NormalizarTexto(valor).Replace(" ", string.Empty, StringComparison.Ordinal).ToUpperInvariant();

    private static string NormalizarEmail(string? valor)
        => NormalizarTexto(valor).ToLowerInvariant();

    private static string SoloDigitos(string? valor)
        => System.Text.RegularExpressions.Regex.Replace(valor ?? string.Empty, @"\D", string.Empty);

    private static string FormatearTamano(long bytes)
    {
        const long kilo = 1024;
        const long mega = kilo * 1024;

        return bytes >= mega
            ? $"{bytes / (double)mega:0.#} MB"
            : $"{bytes / (double)kilo:0.#} KB";
    }
}
