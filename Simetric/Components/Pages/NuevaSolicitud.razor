    private string GetPrecioVigencia(string vigencia)
    {
        return vigencia switch
        {
            "30 DIAS" => "12,29$",
            "1 AÑO" => "21,91$",
            "2 AÑOS" => "34,60$",
            "3 AÑOS" => "46,14$",
            "4 AÑOS" => "57,68$",
            _ => ""
        };
    }
    private bool ConfiguracionFirmaCompleta =>
        !string.IsNullOrWhiteSpace(solicitud.SolFormatoFirma) &&
        !string.IsNullOrWhiteSpace(solicitud.SolVigencia);

    private void SeleccionarFormatoFirma(string formato)
    {
        solicitud.SolFormatoFirma = formato;
        editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolFormatoFirma));
    }

    private void SeleccionarVigencia(string vigencia)
    {
        solicitud.SolVigencia = vigencia;

        solicitud.SolMontoPago = vigencia switch
        {
            "30 DIAS" => 12.29m,
            "1 AÑO" => 21.91m,
            "2 AÑOS" => 34.60m,
            "3 AÑOS" => 46.14m,
            "4 AÑOS" => 57.68m,
            _ => 0m
        };

        editContext.NotifyFieldChanged(FieldIdentifier.Create(() => solicitud.SolVigencia));
        StateHasChanged();
    }

    private static string GetVigenciaLabel(string vigencia) => vigencia switch
