        cajaErrors.Remove(nameof(tempCaja.SerieDebitos));
        var valor = tempCaja.SerieDebitos?.Trim() ?? string.Empty;

        if (!string.IsNullOrWhiteSpace(valor) && !EsSerieValida(valor))
            cajaErrors[nameof(tempCaja.SerieDebitos)] = "La serie de débitos debe tener formato 001-001.";
    }

    private bool EsSerieValida(string valor)
    {
        return System.Text.RegularExpressions.Regex.IsMatch(valor, @"^\d{3}-\d{3}$");
    }

    private async Task GuardarTodo()
    {
        errorMessage = null;
        isSaving = true;
        bool exito = false;

        try
        {
            if (activeTab == "pagos")
            {
                tempPago.Codigo = tempPago.Codigo?.Trim() ?? string.Empty;
                tempPago.Descripcion = tempPago.Descripcion?.Trim() ?? string.Empty;
                tempPago.DescripcionSri = tempPago.DescripcionSri?.Trim() ?? string.Empty;

                if (!ValidarPagos())
                {
                    errorMessage = "Corrige los campos marcados antes de guardar.";
                    return;
                }

                exito = await ConfigService.SaveFormasPagoAsync(tempPago);
            }
            else if (activeTab == "docs")
            {
                tempDoc.Codigo = tempDoc.Codigo?.Trim() ?? string.Empty;
                tempDoc.Descripcion = tempDoc.Descripcion?.Trim() ?? string.Empty;

                if (!ValidarDocumentos())
                {
                    errorMessage = "Corrige los campos marcados antes de guardar.";
                    return;
                }

                exito = await ConfigService.SaveTipoDocumentoAsync(tempDoc);
            }
            else if (activeTab == "cajas")
            {
                tempCaja.SerieFactura = NormalizarSerieCajaInput(tempCaja.SerieFactura);
                tempCaja.SerieNotasCred = NormalizarSerieCajaInput(tempCaja.SerieNotasCred);
                tempCaja.SerieGuia = NormalizarSerieCajaInput(tempCaja.SerieGuia);
                tempCaja.SerieCompras = NormalizarSerieCajaInput(tempCaja.SerieCompras);
                tempCaja.SerieDebitos = NormalizarSerieCajaInput(tempCaja.SerieDebitos);

                if (!ValidarCajas())
                {
                    errorMessage = "Corrige los campos marcados antes de guardar.";
                    return;
                }

                bool existe = tempCaja.IdUsuario is > 0
                    && await ConfigService.UsuarioTieneCajaAsync(tempCaja.IdUsuario.Value, tempCaja.Sec);
                if (existe)
                {
                    errorMessage = "El usuario seleccionado ya posee una caja asignada.";
                    return;
                }

                tempCaja.idJefe ??= idUsuarioActual > 0 ? idUsuarioActual : tempCaja.idJefe;
                exito = await ConfigService.SaveCajaAsync(tempCaja);
            }

            if (exito)
            {
                showModal = false;
                await Cargar();
                StateHasChanged();
            }
            else if (string.IsNullOrWhiteSpace(errorMessage))
            {
                if (activeTab == "pagos")
                    errorMessage = "No se pudo guardar la forma de pago. Verifica si el código ya existe o si faltan datos.";
                else if (activeTab == "docs")
                    errorMessage = "No se pudo guardar el tipo de documento. Verifica si el código o la descripción ya existen.";
                else
                    errorMessage = "No se pudo guardar la caja. Verifica si el usuario ya tiene una caja o si las series tienen formato incorrecto.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
