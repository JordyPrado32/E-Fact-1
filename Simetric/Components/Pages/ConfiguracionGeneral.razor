    private bool ParseCheckboxValue(object? value)
    {
        if (value is bool boolValue)
            return boolValue;

        if (value is string text && bool.TryParse(text, out var parsed))
            return parsed;

        return false;
    }

    private int? ParseNullableInt(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (int.TryParse(value, out var result))
            return result;

        return null;
    }

    private string NormalizarSerieCajaInput(string? value)
    {
        var digits = new string((value ?? string.Empty).Where(char.IsDigit).Take(6).ToArray());

        if (digits.Length <= 3)
            return digits;

        return $"{digits[..3]}-{digits[3..]}";
    }

    private string FormatearSerieCaja(string? value)
    {
        var trimmed = value?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(trimmed))
            return string.Empty;

        if (EsSerieValida(trimmed))
            return trimmed;

        var digits = new string(trimmed.Where(char.IsDigit).Take(6).ToArray());

        return digits.Length == 6
            ? $"{digits[..3]}-{digits[3..]}"
            : trimmed;
    }

    private bool ValidarPagos()
    {
        pagoErrors.Clear();
        ValidarCampoPagoCodigo();
        ValidarCampoPagoDescripcion();
        ValidarCampoPagoDescripcionSri();
        ValidarCampoPagoTipoUso();
        return pagoErrors.Count == 0;
    }

    private void ValidarCampoPagoCodigo()
    {
        pagoErrors.Remove(nameof(tempPago.Codigo));
        var codigo = tempPago.Codigo?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(codigo))
            pagoErrors[nameof(tempPago.Codigo)] = "El código es obligatorio.";
        else if (!codigo.All(char.IsDigit))
            pagoErrors[nameof(tempPago.Codigo)] = "El código solo puede contener números.";
        else if (codigo.Length > 2)
            pagoErrors[nameof(tempPago.Codigo)] = "El código no puede tener más de 2 dígitos.";
    }

    private void ValidarCampoPagoDescripcion()
    {
        pagoErrors.Remove(nameof(tempPago.Descripcion));
        var descripcion = tempPago.Descripcion?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(descripcion))
            pagoErrors[nameof(tempPago.Descripcion)] = "La descripción es obligatoria.";
    }

