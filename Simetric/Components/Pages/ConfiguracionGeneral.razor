    private void CerrarConfirmacionEliminar()
    {
        showDeleteConfirm = false;
        deleteConfirmTitle = string.Empty;
        deleteConfirmMessage = string.Empty;
        deleteConfirmAction = null;
    }

    private async Task ConfirmarEliminarAsync()
    {
        if (deleteConfirmAction is null)
        {
            CerrarConfirmacionEliminar();
            return;
        }

        isDeleting = true;
        errorMessage = null;

        try
        {
            var exito = await deleteConfirmAction.Invoke();
            if (exito)
            {
                CerrarConfirmacionEliminar();
                await Cargar();
                AjustarPaginaActual();
            }
            else
            {
                errorMessage = "No se pudo completar la eliminacion.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

