    private async Task OnTransferFileSelected(InputFileChangeEventArgs e)
    {
        mensajeModalPago = null;
        modalPagoExitoso = false;
        transferArchivoNombre = null;
        transferComprobanteBytes = null;
        transferComprobantePreviewUrl = null;
        transferComprobanteMensaje = null;

        var archivo = e.File;
        var extension = Path.GetExtension(archivo.Name).ToLowerInvariant();
        var esImagenPermitida =
            archivo.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) ||
            extension is ".jpg" or ".jpeg" or ".png";

        if (archivo.Size > 5 * 1024 * 1024)
        {
            transferComprobanteMensaje = "El comprobante no debe superar 5MB.";
            return;
        }

        if (!esImagenPermitida)
        {
            transferComprobanteMensaje = "El comprobante debe ser una imagen JPG o PNG.";
            return;
        }

        try
        {
            archivo = await archivo.RequestImageFileAsync("image/jpeg", TransferPreviewMaxWidth, TransferPreviewMaxHeight);
        }
        catch
        {
        }

        await using var stream = archivo.OpenReadStream(maxAllowedSize: MaxTransferUploadBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        transferComprobanteBytes = ms.ToArray();
        transferArchivoNombre = archivo.Name;

        var mime = archivo.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase)
            ? archivo.ContentType
            : extension == ".png" ? "image/png" : "image/jpeg";

        transferComprobantePreviewUrl = $"data:{mime};base64,{Convert.ToBase64String(transferComprobanteBytes)}";
        transferComprobanteMensaje = "Comprobante cargado correctamente.";
        StateHasChanged();
    }

    private bool TieneComprobanteTransferencia =>
        transferComprobanteBytes != null && transferComprobanteBytes.Length > 0;

    private void OnTransferCuentaOrigenChanged(string? value)
    {
        var valor = value ?? string.Empty;
        transferCuentaOrigen = new string(valor.Where(char.IsDigit).ToArray());
    }

    private void OnTransferNumeroComprobanteChanged(string? value)
    {
        var valor = value ?? string.Empty;
        transferNumeroComprobante = new string(valor.Where(char.IsLetterOrDigit).Take(12).ToArray()).ToUpperInvariant();
    }

    private async Task RegistrarTransferenciaDocumentosAsync()
    {
        mensajeModalPago = null;
        modalPagoExitoso = false;
        resultadoPago = null;

        if (!ValidarDatosPago(out var error))
        {
            MostrarResultadoPago(error, exitoso: false);
            return;
        }

        if (!ValidarFormularioTransferencia(out var errorTransferencia))
        {
            MostrarResultadoPago(errorTransferencia, exitoso: false);
            return;
        }

        if (!TieneComprobanteTransferencia)
        {
            MostrarResultadoPago("Adjunta el comprobante de deposito o transferencia.", exitoso: false);
            return;
        }

        enviandoPago = true;
        CompraDocumentosHistorialItem? compraPendiente = null;

        try
        {
            compraPendiente = await CrearCompraPendienteAsync();

            await using var context = await DbFactory.CreateDbContextAsync();
            var solicitud = new ReporteVentaBackOffice
            {
                Cliente = TruncarTexto($"{ObtenerNombrePagador()} | {ObtenerCorreoPagador()}", 150),
                Producto = "e-fact",
                PlanPaquete = TruncarTexto(EsPlanIlimitado ? "Plan ilimitado anual documentos" : $"Recarga de {docsInput} documentos", 100),
                Valor = decimal.Round(montoInput, 2, MidpointRounding.AwayFromZero),
                Fecha = DateTime.Now,
                Canal = "Transferencia Web",
                Vendedor = "Solicitud en linea",
                Estado = "pendiente",
                FormaPago = "Transferencia Bancaria",
                Observacion = TruncarTexto(
                    $"[CompraDocs:{compraPendiente.Id}] Banco: {transferBanco.Trim()}. Cuenta origen: {transferCuentaOrigen.Trim()}. N. comprobante: {transferNumeroComprobante.Trim()}. Titular: {transferTitular.Trim()}. Solicitud pendiente de aprobacion por compra de documentos.",
                    500),
                ComprobanteArchivo = transferComprobanteBytes
            };

            context.ReporteVentasBackOffice.Add(solicitud);
            await context.SaveChangesAsync();

            mensajePago = "Tu transferencia fue registrada. La transaccion sera revisada y aprobada o rechazada dentro de 24 horas; veras el estado en tu historial de compras.";
            await CargarUsuarioActualAsync();
            LimpiarFormularioTransferencia();
            MostrarResultadoPago(mensajePago, exitoso: true);
        }
        catch (Exception ex)
        {
            if (compraPendiente is not null)
            {
                await EliminarCompraPendienteAsync(compraPendiente.Id);
            }

            MostrarResultadoPago($"No se pudo registrar la transferencia: {ex.Message}", exitoso: false);
        }
        finally
        {
            enviandoPago = false;
        }
    }

    private bool ValidarFormularioTransferencia(out string error)
    {
        if (string.IsNullOrWhiteSpace(transferBanco))
        {
            error = "Selecciona el banco desde donde realizaste la transferencia.";
            return false;
        }

        var cuenta = transferCuentaOrigen?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(cuenta))
        {
            error = "Ingresa el numero de cuenta origen.";
            return false;
        }

        if (!cuenta.All(char.IsDigit))
        {
            error = "El numero de cuenta origen solo debe contener numeros.";
            return false;
        }

        var numeroComprobante = transferNumeroComprobante?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(numeroComprobante))
        {
            error = "Ingresa el numero de comprobante de la transferencia.";
            return false;
        }

        if (numeroComprobante.Length > 12 || !numeroComprobante.All(char.IsLetterOrDigit))
        {
            error = "El numero de comprobante debe tener maximo 12 caracteres alfanumericos.";
            return false;
        }

        var partesTitular = (transferTitular ?? string.Empty)
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (partesTitular.Length < 2 || partesTitular.Count(parte => parte.Length >= 3 && parte.All(char.IsLetter)) < 2)
        {
            error = "El titular de la cuenta debe incluir al menos un nombre y un apellido de minimo 3 letras cada uno.";
            return false;
        }

        error = string.Empty;
        return true;
    }

    private void LimpiarFormularioTransferencia()
    {
        transferBanco = string.Empty;
        transferCuentaOrigen = string.Empty;
        transferNumeroComprobante = string.Empty;
        transferTitular = string.Empty;
        transferArchivoNombre = null;
        transferComprobanteBytes = null;
        transferComprobantePreviewUrl = null;
        transferComprobanteMensaje = null;
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarioActualAsync();
    }

    private async Task CargarUsuarioActualAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst("IdUsuario")?.Value;

        if (!int.TryParse(idClaim, out var usuarioId) || usuarioId <= 0)
        {
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();
        usuarioSesion = await context.Usuarios
            .AsNoTracking()
            .FirstOrDefaultAsync(item => item.IdUsuario == usuarioId);

        usuarioActual = usuarioSesion;

        emisorPagador = null;

        if (usuarioSesion is not null)
        {
            var idUsuarioEmisor = usuarioSesion.estadoAsociado == true && usuarioSesion.idJefe is > 0
                ? usuarioSesion.idJefe.Value
                : usuarioId;

            if (idUsuarioEmisor != usuarioSesion.IdUsuario)
            {
                usuarioActual = await context.Usuarios
                    .AsNoTracking()
                    .FirstOrDefaultAsync(item => item.IdUsuario == idUsuarioEmisor);
            }

            emisorPagador = await context.Emisores
                .AsNoTracking()
                .Where(item => item.IdUsuario == idUsuarioEmisor && item.Estado)
                .OrderByDescending(item => item.Codigo)
                .FirstOrDefaultAsync();
        }

        usuarioCuentaDocumentos = usuarioActual;
        historialCompras = LeerHistorial(usuarioCuentaDocumentos?.HistorialComprasDocumentosJson);
        compraRetornada = ObtenerCompraRetornada();
        await EmisorOnboardingService.RefreshRequirementAsync(usuarioId);
        emisionEstado = await EmisionControlService.ObtenerEstadoAsync(context, usuarioId);

        if (RetornoAprobado && compraRetornada?.SaldoAplicado == true)
        {
            EmisionControlService.NotifyChanged();
        }
    }

    private async Task ProcesarSeleccionAsync()
    {
        mensajePago = null;
        resultadoPago = null;

        if (!ValidarDatosPago(out var error))
        {
            mensajePago = error;
            return;
        }

        enviandoPago = true;

        try
        {
            var compraPendiente = await CrearCompraPendienteAsync();
            var notifyUrl = BuildNotifyUrl(compraPendiente.Id);
            var request = BuildCompraRequest(notifyUrl, compraPendiente.CustomValue!);

            resultadoPago = await PagoService.SendJsonAsync(
                HttpMethod.Post,
                "/payment-requests",
                request);

            if (resultadoPago.IsSuccess && !string.IsNullOrWhiteSpace(resultadoPago.PaymentUrl))
            {
                Navigation.NavigateTo(resultadoPago.PaymentUrl, forceLoad: true);
                return;
            }

            await EliminarCompraPendienteAsync(compraPendiente.Id);
            mensajePago = resultadoPago.IsSuccess
                ? "Pagomedios respondio, pero no devolvio la URL del checkout."
                : resultadoPago.ErrorMessage ?? "No se pudo procesar la recarga.";
            mensajeModalPago = mensajePago;
        }
        catch (InvalidOperationException ex)
        {
            await CargarUsuarioActualAsync();
            mensajePago = ex.Message;
            mensajeModalPago = ex.Message;
        }
        finally
        {
            enviandoPago = false;
        }
    }

    private async Task AbrirPdfFacturaRetornadaAsync()
    {
        if (abriendoPdfFactura || compraRetornada?.FacturaAutorizada != true || compraRetornada.CodFactura is not > 0)
            return;

        abriendoPdfFactura = true;
        try
        {
            var pdfUrl = await FacturacionService.AsegurarPdfFacturaAsync(compraRetornada.CodFactura.Value);
            if (!string.IsNullOrWhiteSpace(pdfUrl))
                await JS.InvokeVoidAsync("open", pdfUrl, "_blank");
            else
                mensajePago = "La factura esta autorizada, pero no se pudo generar el PDF.";
        }
        finally
        {
            abriendoPdfFactura = false;
        }
    }

    private bool ValidarDatosPago(out string error)
    {
        if (TienePlanIlimitadoActivo)
        {
            error = MensajeRecargaBloqueadaPlanIlimitado;
            return false;
        }

        if (!EsPlanIlimitado && docsInput < DocumentosMinimosPersonalizados)
        {
            error = $"La recarga mínima corresponde a {DocumentosMinimosPersonalizados} documentos.";
            return false;
        }

        if (montoInput < MontoMinimoPersonalizado)
        {
            error = $"El monto mínimo de recarga es de $ {MontoMinimoPersonalizado.ToString("N2", CultureInfo.GetCultureInfo("es-EC"))}.";
            return false;
        }

        if (MontoMaximoExcedido)
        {
            error = $"El monto maximo permitido es de $ {MontoMaximoPersonalizado.ToString("N2", CultureInfo.InvariantCulture)}.";
            return false;
        }

        if (docsInput <= 0 && !EsPlanIlimitado)
        {
            error = "No fue posible calcular una cantidad valida de documentos.";
            return false;
        }

        if (usuarioActual is null)
        {
            error = "No se pudo identificar al usuario actual.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(ObtenerDocumentoPagador()))
        {
            error = "Tu perfil no tiene identificacion configurada para enviar a Pagomedios.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(ObtenerCorreoPagador()))
        {
            error = "Tu perfil no tiene correo configurado para enviar a Pagomedios.";
            return false;
        }

        error = string.Empty;
        return true;
    }

    private PagomediosRequest BuildCompraRequest(string notifyUrl, string customValue)
    {
        var total = decimal.Round(montoInput, 2, MidpointRounding.AwayFromZero);

        return new PagomediosRequest
        {
            Integration = true,
            Third = new ThirdParty
            {
                Document = ObtenerDocumentoPagador(),
                DocumentType = ObtenerTipoDocumentoPagomedios(),
                Name = ObtenerNombrePagador(),
                Email = ObtenerCorreoPagador(),
                Phones = ObtenerTelefonoPagador(),
                Address = ObtenerDireccionPagador(),
                Type = ObtenerTipoClientePagomedios()
            },
            GenerateInvoice = 0,
            Description = EsPlanIlimitado
                ? "Plan E-FACT de documentos ilimitados por 1 año"
                : $"Recarga de {docsInput} documentos E-FACT",
            Amount = total,
            AmountWithTax = SubtotalGravado,
            AmountWithoutTax = 0m,
            TaxValue = IvaTotal,
            NotifyUrl = notifyUrl,
            CustomValue = customValue,
            HasCards = 0,
            HasDeUna = 1,
            HasPaypal = 0,
            HasSafetypay = false
        };
    }

    private string BuildNotifyUrl(string compraId)
    {
        var userId = usuarioCuentaDocumentos?.IdUsuario ?? usuarioActual?.IdUsuario ?? 0;
        var baseUri = Navigation.ToAbsoluteUri("/api/pagomedios/notificacion-compra-documentos").ToString().TrimEnd('/');
        return $"{baseUri}?uid={userId}&purchase={Uri.EscapeDataString(compraId)}";
    }

    private string BuildCustomValue(string compraId)
    {
        var userId = usuarioCuentaDocumentos?.IdUsuario ?? usuarioActual?.IdUsuario ?? 0;
        var plan = EsPlanIlimitado ? "|plan:ilimitado-anual" : string.Empty;
        return $"recarga-documentos|purchase:{compraId}|user:{userId}|docs:{docsInput}|total:{montoInput.ToString("0.00", CultureInfo.InvariantCulture)}{plan}";
    }

    private async Task<CompraDocumentosHistorialItem> CrearCompraPendienteAsync()
    {
        var userId = usuarioCuentaDocumentos?.IdUsuario ?? usuarioActual?.IdUsuario ?? 0;
        var compraId = Guid.NewGuid().ToString("N");
        var customValue = BuildCustomValue(compraId);
        var compra = new CompraDocumentosHistorialItem
        {
            Id = compraId,
            Fecha = DateTime.Now,
            Documentos = docsInput,
            MontoTotal = decimal.Round(montoInput, 2, MidpointRounding.AwayFromZero),
            Estado = "Pendiente",
            Descripcion = EsPlanIlimitado
                ? "Plan de documentos ilimitados por 1 año"
                : $"Recarga de {docsInput} documentos E-FACT",
            CustomValue = customValue,
            EmailDestino = ObtenerCorreoPagador(),
            EsIlimitado = EsPlanIlimitado
        };

        await using var context = await DbFactory.CreateDbContextAsync();
        var usuario = await context.Usuarios.FirstOrDefaultAsync(item => item.IdUsuario == userId)
            ?? throw new InvalidOperationException("No se pudo identificar la cuenta que recibira los documentos.");

        var estadoEmision = await EmisionControlService.ObtenerEstadoAsync(context, userId);
        if (estadoEmision.PlanIlimitadoActivo)
        {
            throw new InvalidOperationException(MensajeRecargaBloqueadaPlanIlimitado);
        }

        var historial = LeerHistorial(usuario.HistorialComprasDocumentosJson);
        historial.Insert(0, compra);
        usuario.HistorialComprasDocumentosJson = SerializarHistorial(historial);
        await context.SaveChangesAsync();

        historialCompras = historial;
        return compra;
    }

    private async Task EliminarCompraPendienteAsync(string compraId)
    {
        var userId = usuarioCuentaDocumentos?.IdUsuario ?? usuarioActual?.IdUsuario ?? 0;

        await using var context = await DbFactory.CreateDbContextAsync();
        var usuario = await context.Usuarios.FirstOrDefaultAsync(item => item.IdUsuario == userId);
        if (usuario is null)
        {
            return;
        }

        var historial = LeerHistorial(usuario.HistorialComprasDocumentosJson);
        historial.RemoveAll(item =>
            !item.SaldoAplicado &&
            string.Equals(item.Id, compraId, StringComparison.OrdinalIgnoreCase));

        usuario.HistorialComprasDocumentosJson = SerializarHistorial(historial);
        await context.SaveChangesAsync();
        historialCompras = historial;
    }

    private string ObtenerDocumentoBasePagador()
    {
        if (!string.IsNullOrWhiteSpace(UsuarioPagador?.Identificacion))
        {
            return UsuarioPagador.Identificacion.Trim();
        }

        if (!string.IsNullOrWhiteSpace(emisorPagador?.Ruc))
        {
            return emisorPagador.Ruc.Trim();
        }

        return string.Empty;
    }

    private string ObtenerDocumentoPagador()
    {
        var documento = ObtenerDocumentoBasePagador();
        var tipoDocumento = ObtenerTipoDocumentoPagomedios();

        return tipoDocumento is "04" or "05"
            ? SoloDigitos(documento)
            : NormalizarDocumentoLibre(documento);
    }

    private string ObtenerNombrePagador()
    {
        if (!string.IsNullOrWhiteSpace(UsuarioPagador?.NombreEmpresa))
        {
            return UsuarioPagador.NombreEmpresa.Trim();
        }

        var nombrePersona = $"{UsuarioPagador?.Nombres} {UsuarioPagador?.Apellidos}".Trim();
        if (!string.IsNullOrWhiteSpace(nombrePersona))
        {
            return nombrePersona;
        }

        if (!string.IsNullOrWhiteSpace(emisorPagador?.RazonSocial))
        {
            return emisorPagador.RazonSocial.Trim();
        }

        return emisorPagador?.NomComercial?.Trim() ?? string.Empty;
    }

    private string ObtenerCorreoPagador() =>
        !string.IsNullOrWhiteSpace(UsuarioPagador?.Email)
            ? UsuarioPagador.Email.Trim().ToLowerInvariant()
            : emisorPagador?.Email?.Trim().ToLowerInvariant() ?? string.Empty;

    private string ObtenerTelefonoPagador() =>
        string.IsNullOrWhiteSpace(SoloDigitos(UsuarioPagador?.Celular ?? string.Empty))
            ? "0999999999"
            : SoloDigitos(UsuarioPagador?.Celular ?? string.Empty);

    private string ObtenerDireccionPagador() =>
        !string.IsNullOrWhiteSpace((UsuarioPagador?.DireccionEmpresa ?? string.Empty).Trim())
            ? UsuarioPagador!.DireccionEmpresa!.Trim()
            : !string.IsNullOrWhiteSpace((emisorPagador?.DirEstablecimiento ?? string.Empty).Trim())
                ? emisorPagador!.DirEstablecimiento!.Trim()
                : !string.IsNullOrWhiteSpace((emisorPagador?.DireccionMatriz ?? string.Empty).Trim())
                    ? emisorPagador!.DireccionMatriz!.Trim()
                    : "Quito";

    private string ObtenerTipoDocumentoPagomedios()
    {
        var identificacion = SoloDigitos(ObtenerDocumentoBasePagador());

        if (identificacion.Length == 13)
        {
            return "04";
        }

        if (identificacion.Length == 10)
        {
            return "05";
        }

        return "06";
    }

    private string ObtenerTipoClientePagomedios() =>
        !string.IsNullOrWhiteSpace(UsuarioPagador?.NombreEmpresa) ||
        !string.IsNullOrWhiteSpace(emisorPagador?.RazonSocial)
            ? "Company"
            : "Individual";

    private async Task ActualizarDesdeMontoAsync()
    {
        if (TienePlanIlimitadoActivo)
            return;

        planSeleccionadoDocs = null;
        mensajePago = null;

        // Parse and compute immediately (so cantidad reflects current typing)
        var textoActual = montoTexto;
        var parsed = ParseDecimal(textoActual);
        if (parsed > 0m)
        {
            montoInput = parsed;
            CalcularDesdeDinero();
            cantidadTexto = docsInput > 0 ? docsInput.ToString(CultureInfo.InvariantCulture) : string.Empty;
        }
        else if (string.IsNullOrWhiteSpace(textoActual))
        {
            // Allow the user to clear the field entirely
            montoInput = 0m;
            docsInput = 0;
            cantidadTexto = string.Empty;
        }
        // Do NOT rewrite montoTexto here — let the user keep typing
    }

    private void ActualizarDesdeMonto()
    {
        _ = ActualizarDesdeMontoAsync();
    }

    private Task FormatearMontoRecarga()
    {
        if (TienePlanIlimitadoActivo)
            return Task.CompletedTask;

        if (montoInput > 0m)
            montoTexto = montoInput.ToString("0.00", CultureInfo.InvariantCulture);
        else if (string.IsNullOrWhiteSpace(montoTexto))
            montoTexto = string.Empty;

        return Task.CompletedTask;
    }

    private void ActualizarDesdeCantidad()
    {
        if (TienePlanIlimitadoActivo)
        {
            return;
        }

        planSeleccionadoDocs = null;
        cantidadTexto = SoloDigitos(cantidadTexto);
        docsInput = ParseEnteroPositivo(cantidadTexto);
        CalcularDesdeDocs();
        montoTexto = montoInput > 0m ? montoInput.ToString("0.00", CultureInfo.InvariantCulture) : string.Empty;
        mensajePago = null;
    }

    private void CalcularDesdeDocs()
    {
        if (docsInput <= 0)
        {
            docsInput = 0;
            montoInput = 0m;
            return;
        }

        montoInput = EFactDocumentPricing.CalcularTotalPorCantidad(docsInput);
    }

    private void CalcularDesdeDinero()
    {
        if (montoInput <= 0)
        {
            montoInput = 0m;
            docsInput = 0;
            return;
        }

        var precioDocActual = ObtenerPrecioPorDocumentoSegunMonto(montoInput);
        docsInput = CalcularDocumentosSeguros(montoInput, precioDocActual);
    }

    private void SeleccionarPlan(int docs)
    {
        if (TienePlanIlimitadoActivo)
        {
            return;
        }

        planSeleccionadoDocs = docs;
        docsInput = docs;
        montoInput = EFactBillingConfig.EFactPlans.FirstOrDefault(p => p.CantidadDocs == docs)?.Precio
            ?? EFactDocumentPricing.CalcularTotalPorCantidad(docsInput);
        cantidadTexto = docsInput.ToString(CultureInfo.InvariantCulture);
        montoTexto = montoInput.ToString("0.00", CultureInfo.InvariantCulture);
        mensajePago = null;
    }

    private void SeleccionarPlanIlimitado()
    {
        if (TienePlanIlimitadoActivo)
        {
            return;
        }

        planSeleccionadoDocs = PlanIlimitadoMarker;
        docsInput = 0;
        cantidadTexto = string.Empty;
        montoInput = PrecioPlanIlimitado;
        montoTexto = PrecioPlanIlimitado.ToString("0.00", CultureInfo.InvariantCulture);
        mensajePago = null;
    }

    private static decimal ObtenerPrecioPorDocumentoSegunCantidad(int documentos)
    {
        return EFactDocumentPricing.ObtenerPrecioPorDocumentoSegunCantidad(documentos);
    }

    private static decimal ObtenerPrecioPorDocumentoSegunMonto(decimal monto)
    {
        return EFactDocumentPricing.ObtenerPrecioPorDocumentoSegunMonto(monto);
    }

    private static int CalcularDocumentosSeguros(decimal monto, decimal precioDocActual)
    {
        return EFactDocumentPricing.CalcularDocumentosPorMonto(monto, precioDocActual);
    }

    private List<CompraDocumentosHistorialItem> LeerHistorial(string? historialJson)
    {
        if (string.IsNullOrWhiteSpace(historialJson))
        {
            return new List<CompraDocumentosHistorialItem>();
        }

        try
        {
            return (JsonSerializer.Deserialize<List<CompraDocumentosHistorialItem>>(historialJson, HistorialJsonOptions) ?? new List<CompraDocumentosHistorialItem>())
                .OrderByDescending(item => item.Fecha)
                .ToList();
        }
        catch (JsonException)
        {
            return new List<CompraDocumentosHistorialItem>();
        }
    }

    private static string SerializarHistorial(List<CompraDocumentosHistorialItem> historial)
    {
        var historialNormalizado = historial
            .OrderByDescending(item => item.Fecha)
            .Take(40)
            .ToList();

        var planPermanente = historial
            .Where(item => item.SaldoAplicado && item.EsIlimitado && item.EsPermanente)
            .OrderByDescending(item => item.Fecha)
            .FirstOrDefault();

        if (planPermanente is not null && !historialNormalizado.Contains(planPermanente))
        {
            if (historialNormalizado.Count >= 40)
            {
                historialNormalizado.RemoveAt(historialNormalizado.Count - 1);
            }

            historialNormalizado.Add(planPermanente);
        }

        return JsonSerializer.Serialize(historialNormalizado, HistorialJsonOptions);
    }

    private CompraDocumentosHistorialItem? ObtenerCompraRetornada()
    {
        if (historialCompras.Count == 0)
        {
            return null;
        }

        return historialCompras.FirstOrDefault(item =>
            (!string.IsNullOrWhiteSpace(CompraRetornoId) &&
             string.Equals(item.Id, CompraRetornoId, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrWhiteSpace(ReferenceRetorno) &&
             string.Equals(item.Reference, ReferenceRetorno, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrWhiteSpace(AuthorizationRetorno) &&
             string.Equals(item.AuthorizationCode, AuthorizationRetorno, StringComparison.OrdinalIgnoreCase)));
    }

    private static string ObtenerClaseEstado(string? estado)
    {
        if (string.IsNullOrWhiteSpace(estado))
        {
            return "is-pending";
        }

        if (estado.Contains("aprob", StringComparison.OrdinalIgnoreCase))
        {
            return "is-approved";
        }

        if (estado.Contains("rech", StringComparison.OrdinalIgnoreCase))
        {
            return "is-rejected";
        }

        if (estado.Contains("rever", StringComparison.OrdinalIgnoreCase))
        {
            return "is-reversed";
        }

        return "is-pending";
    }

    private static decimal ParseDecimal(object? value)
    {
        var text = Convert.ToString(value, CultureInfo.InvariantCulture) ?? string.Empty;
        text = new string(text.Trim()
            .Where(character => char.IsDigit(character) || character is '.' or ',' or '-')
            .ToArray());

        if (string.IsNullOrWhiteSpace(text))
        {
            return 0m;
        }

        var lastDot = text.LastIndexOf('.');
        var lastComma = text.LastIndexOf(',');
        var decimalSeparatorIndex = Math.Max(lastDot, lastComma);

        if (decimalSeparatorIndex >= 0)
        {
            var integerPart = new string(text[..decimalSeparatorIndex].Where(char.IsDigit).ToArray());
            var decimalPart = new string(text[(decimalSeparatorIndex + 1)..].Where(char.IsDigit).ToArray());
            text = string.IsNullOrEmpty(decimalPart)
                ? integerPart
                : $"{integerPart}.{decimalPart}";
        }
        else
        {
            text = new string(text.Where(char.IsDigit).ToArray());
        }

        return decimal.TryParse(text, NumberStyles.AllowDecimalPoint, CultureInfo.InvariantCulture, out var result)
            ? result
            : 0m;
    }

    private static int ParseEnteroPositivo(string? value)
    {
        var text = SoloDigitos(value ?? string.Empty);
        return int.TryParse(text, NumberStyles.Integer, CultureInfo.InvariantCulture, out var result) && result > 0
            ? result
            : 0;
    }

    private static string SoloDigitos(string valor) =>
        new(valor.Where(char.IsDigit).ToArray());

    private static string NormalizarDocumentoLibre(string valor) =>
        new(valor
            .Where(char.IsLetterOrDigit)
            .Select(char.ToUpperInvariant)
            .ToArray());

    private static string TruncarTexto(string? valor, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(valor))
        {
            return string.Empty;
        }

        var limpio = valor.Trim();
        return limpio.Length <= maxLength ? limpio : limpio[..maxLength];
    }
