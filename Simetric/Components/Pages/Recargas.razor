@page "/compra-documentos"
@rendermode InteractiveServer
@using System.Globalization
@using System.IO
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.DTOs
@using Simetric.Models
@using EmisorModel = Simetric.Models.Emisor
@using Simetric.Services
@inject PagoService PagoService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<AppDbContext> DbFactory
@inject EmisionControlService EmisionControlService
@inject EmisorOnboardingService EmisorOnboardingService
@inject FacturacionService FacturacionService
@inject IJSRuntime JS

<PageTitle>Compra de documentos | Numerica e-fact</PageTitle>

<div class="recargas-shell" data-tour="recargas.page">
    @if (MostrarVolverInicioOnboarding)
    {
        <div class="breadcrumb-container">
            <button type="button" class="breadcrumb-home-btn" @onclick='() => Navigation.NavigateTo("/dashboard")'>
                <i class="bi bi-house-door"></i>
                <span>Volver al inicio</span>
            </button>
        </div>
    }

    <section class="recargas-header" data-tour="recargas.hero">
        <div class="recargas-title-wrap">
            <span class="page-kicker">1. Recarga tu cuenta</span>
            <h1>Compra documentos por recarga</h1>
            <p>Elige la cantidad de documentos que necesitas. El saldo se acredita al instante cuando se aprueba el pago.</p>
        </div>

        <div class="header-stats">
            <article class="header-stat">
                <span>Saldo actual</span>
                <strong>@SaldoActualResumen</strong>
                <small>@SaldoActualDetalle</small>
            </article>

            <article class="header-stat">
                <span>Ultima recarga</span>
                <strong>@FechaUltimaRecargaResumen</strong>
                <small>@(TotalComprasRegistradas == 0 ? "Sin movimientos" : $"{TotalComprasRegistradas} compra(s) registrada(s)")</small>
            </article>
        </div>
    </section>

    @if (MostrarRetornoPago)
    {
        <section class="return-banner @(RetornoAprobado ? "is-approved" : "is-pending")">
            <div class="return-copy">
                <strong>@TituloRetornoPago</strong>
                <span>@MensajeRetornoPago</span>
            </div>

            <div class="return-meta">
                @if (compraRetornada is not null)
                {
                    <div class="return-pill">
                        <span>@(compraRetornada.EsIlimitado ? "Plan acreditado" : "Documentos acreditados")</span>
                        <strong>@(compraRetornada.EsIlimitado ? "Ilimitado por 1 año" : compraRetornada.Documentos.ToString(CultureInfo.InvariantCulture))</strong>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(ReferenceRetorno))
                {
                    <div class="return-pill">
                        <span>Referencia</span>
                        <strong>@ReferenceRetorno</strong>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(AuthorizationRetorno))
                {
                    <div class="return-pill">
                        <span>Autorizacion</span>
                        <strong>@AuthorizationRetorno</strong>
                    </div>
                }

                @if (compraRetornada?.FacturaAutorizada == true && compraRetornada.CodFactura is > 0)
                {
                    <button type="button" class="return-pdf-btn" @onclick="AbrirPdfFacturaRetornadaAsync">
                        <i class="bi bi-file-earmark-pdf"></i>
                        Abrir PDF autorizado
                    </button>
                }
            </div>

            @if (TieneErrorFacturaRetornada)
            {
                <div class="return-invoice-error" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <strong>No se pudo completar la facturacion automatica</strong>
                        <span>@MensajeErrorFacturaRetornada</span>
                    </div>
                </div>
            }
        </section>
    }

    @if (TienePlanIlimitadoActivo)
    {
        <section class="unlimited-plan-lock" role="status">
            <i class="bi bi-shield-check" aria-hidden="true"></i>
            <div>
                <strong>Tu plan ilimitado está activo</strong>
                <span>@MensajeBloqueoRecargas</span>
            </div>
        </section>
    }

    <section class="commerce-grid recharge-commerce">
        <div class="plans-panel" data-tour="recargas.plans">
            <div class="custom-recharge custom-recharge-top">
                <div class="custom-recharge-copy">
                    <span class="section-kicker">Recarga personalizada</span>
                    <strong>Compra por documentos o por dinero</strong>
                    <small>Edita cualquiera de los dos valores y el sistema calcula automaticamente el otro.</small>
                </div>

                <label class="recharge-field">
                    <span>¿Cuantos documentos deseas comprar?</span>
                    <input type="text"
                           inputmode="numeric"
                           class="recharge-input"
                           placeholder="Ingresa la cantidad"
                           autocomplete="off"
                           disabled="@TienePlanIlimitadoActivo"
                           @bind="cantidadTexto"
                           @bind:event="oninput"
                           @bind:after="ActualizarDesdeCantidad" />
                    <small>Mínimo @DocumentosMinimosPersonalizados documentos (equivalente a una recarga desde $5,00)</small>
                </label>

                <label class="recharge-field">
                    <span>Valor de la recarga</span>
                    <span class="custom-money-field">
                        <span class="money-prefix" aria-hidden="true">$</span>
                        <input type="text"
                               inputmode="decimal"
                               class="custom-input"
                               placeholder="0.00"
                               autocomplete="off"
                               aria-label="Valor de la recarga en dolares"
                               disabled="@TienePlanIlimitadoActivo"
                               @bind="montoTexto"
                               @bind:event="oninput"
                               @bind:after="ActualizarDesdeMonto"
                               @onblur="FormatearMontoRecarga" />
                        <span class="money-code">USD</span>
                    </span>
                    <small>Monto mínimo de recarga: $5,00</small>
                </label>

            </div>

            <div class="panel-head recommended-head">
                <div>
                    <span class="section-kicker">Opciones recomendadas</span>
                    <h2>Elige una recarga rapida</h2>
                </div>
                <span class="panel-hint">Precios finales con IVA incluido</span>
            </div>

            <div class="plans-grid">
                @foreach (var plan in EFactBillingConfig.EFactPlans.Where(p => p.CantidadDocs != 0))
                {
                    bool isSelected = plan.CantidadDocs == -1 ? EsPlanIlimitado : PlanSeleccionadoDocs == plan.CantidadDocs;
                    string cardClass = plan.CantidadDocs == -1 ? "plan-card-annual" : plan.EsRecomendado ? "plan-card-featured" : "";
                    
                    <button type="button"
                            class="plan-card @cardClass @(isSelected ? "is-selected" : string.Empty)"
                            disabled="@TienePlanIlimitadoActivo"
                            @onclick="() => { if (plan.CantidadDocs == -1) SeleccionarPlanIlimitado(); else SeleccionarPlan(plan.CantidadDocs); }">
                        <span class="plan-card-head">
                            <span class="plan-symbol plan-symbol-@plan.ColorClase"><i class="bi @plan.Icono"></i></span>
                            @if (plan.CantidadDocs == -1)
                            {
                                <span class="plan-highlight is-green">Mayor ahorro</span>
                            }
                            else if (plan.EsRecomendado)
                            {
                                <span class="plan-highlight">Recomendado</span>
                            }
                            <span class="plan-selected-check"><i class="bi bi-check-lg"></i></span>
                        </span>
                        <span class="plan-main">
                            <span class="plan-copy">
                                @if (plan.CantidadDocs == -1)
                                {
                                    <strong class="plan-docs plan-docs-unlimited">Ilimitados</strong>
                                    <span class="plan-docs-label">durante 1 año</span>
                                }
                                else
                                {
                                    <strong class="plan-docs">@plan.CantidadDocs</strong>
                                    <span class="plan-docs-label">documentos</span>
                                }
                            </span>
                            <span class="plan-price"><small>USD</small> $@plan.Precio.ToString("F2", CultureInfo.InvariantCulture)</span>
                        </span>
                        <span class="plan-description">@plan.Descripcion</span>
                        <span class="plan-cta"><span>Elegir plan</span><i class="bi bi-arrow-right"></i></span>
                    </button>
                }
            </div>

            @if (MontoMaximoExcedido)
            {
                <div class="custom-warning">
                    El monto maximo permitido para compra es $@MontoMaximoPersonalizado.ToString("N2", CultureInfo.InvariantCulture). Reduce el monto o la cantidad para continuar.
                </div>
            }
        </div>

        <aside class="checkout-panel" data-tour="recargas.checkout">
            <div class="checkout-card">
                <div class="panel-head panel-head-compact">
                    <span class="section-kicker">Resumen de compra</span>
                    <h2>@TituloResumenCompra</h2>
                </div>

                <div class="summary-box">
                    <div class="summary-row summary-documents">
                        <span>Documentos</span>
                        <strong>@DocumentosResumen</strong>
                    </div>
                    @if (EsPlanIlimitado)
                    {
                        <div class="summary-row">
                            <span>Vigencia</span>
                            <strong>1 año</strong>
                        </div>
                    }
                    <div class="summary-row">
                        <span>Subtotal</span>
                        <strong>$@SubtotalGravado.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div class="summary-row">
                        <span>IVA 15%</span>
                        <strong>$@IvaTotal.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div class="summary-row summary-row-total">
                        <span>Total a pagar</span>
                        <strong><small>USD</small> $@montoInput.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                </div>

                <button type="button"
                        class="btn-buy"
                        disabled="@(enviandoPago || !PuedeProcesarPago)"
                        @onclick="AbrirModalPagoDocumentos">
                    @(TienePlanIlimitadoActivo
                        ? "Recarga no disponible"
                        : enviandoPago
                            ? "Procesando..."
                            : "Confirmar recarga")
                </button>

                @if (!string.IsNullOrWhiteSpace(mensajePago))
                {
                    <div class="payment-message @(resultadoPago is { IsSuccess: false } ? "is-error" : "is-info")">
                        @mensajePago
                    </div>
                }

                <div class="checkout-footnote">
                    <i class="bi bi-lock"></i>
                    <span><strong>Pago 100% seguro</strong> El saldo se acredita automaticamente al aprobarse el pago.</span>
                </div>
            </div>
        </aside>
    </section>

    <section class="recharge-benefits" aria-label="Beneficios de las recargas">
        <article>
            <i class="bi bi-person"></i>
            <span><strong>Todas las recargas son para 1 usuario</strong><small>Los documentos aplican unicamente para el usuario actual.</small></span>
        </article>
        <article>
            <i class="bi bi-people"></i>
            <span><strong>¿Necesitas mas usuarios?</strong><small>Contactanos para informacion sobre usuarios adicionales.</small></span>
        </article>
        <article>
            <i class="bi bi-calendar2-check"></i>
            <span><strong>Sin vencimientos</strong><small>Tus documentos no vencen y puedes usarlos cuando los necesites.</small></span>
        </article>
    </section>

    <section class="history-section" data-tour="recargas.history">
        <div class="history-head">
            <div>
                <span class="section-kicker">Mi historial de compras</span>
                <h2>Ultimos movimientos</h2>
            </div>
            <p>@HistorialResumen</p>
        </div>

        @if (historialCompras.Count == 0)
        {
            <div class="empty-state">
                <strong>Aun no registras compras aprobadas.</strong>
                <span>Cuando completes tu primera recarga, aqui veras el monto, la referencia y los documentos acreditados.</span>
            </div>
        }
        else
        {
            <div class="purchase-table-card recargas-history-table-card">
                <div class="purchase-table-wrap">
                    <table class="purchase-table recargas-history-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Descripcion</th>
                                <th>Documentos</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th>Saldo aplicado</th>
                                <th>Referencia</th>
                                <th>Autorizacion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in historialCompras.Take(4))
                            {
                                <tr>
                                    <td class="purchase-col-date">
                                        <strong>@item.Fecha.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture)</strong>
                                        <span>@item.Fecha.ToString("HH:mm", CultureInfo.InvariantCulture)</span>
                                    </td>
                                    <td class="purchase-col-description">
                                        <strong>@item.Descripcion</strong>
                                        <span>@(item.EsIlimitado ? "Plan ilimitado" : "Recarga documental")</span>
                                    </td>
                                    <td class="purchase-col-docs">@(item.EsIlimitado ? "Ilimitados" : item.Documentos.ToString(CultureInfo.InvariantCulture))</td>
                                    <td class="purchase-col-money purchase-col-money-total">$ @item.MontoTotal.ToString("F2", CultureInfo.InvariantCulture)</td>
                                    <td class="purchase-col-status">
                                        <span class="purchase-status-chip @ObtenerClaseEstado(item.Estado)">
                                            <i class="bi bi-circle-fill"></i>
                                            <span>@item.Estado</span>
                                        </span>
                                    </td>
                                    <td class="purchase-col-application">@(item.SaldoAplicado ? "Si" : "No")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Reference) ? "Sin referencia" : item.Reference)</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.AuthorizationCode) ? "Sin autorizacion" : item.AuthorizationCode)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
</div>

@if (mostrarModalPagoDocumentos)
{
    <div class="recarga-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="recargaPaymentTitle" @onclick="CerrarModalPagoDocumentos">
        <div class="recarga-payment-modal" @onclick:stopPropagation>
            <header class="recarga-payment-header">
                <div>
                    <span class="section-kicker">Resumen de pago</span>
                    <h3 id="recargaPaymentTitle">Compra de documentos</h3>
                    <p>Elige pagar de inmediato o registrar una transferencia para validacion.</p>
                </div>
                <button type="button" class="recarga-modal-close" @onclick="CerrarModalPagoDocumentos" disabled="@enviandoPago" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="recarga-payment-body">
                <section class="recarga-modal-summary">
                    <div>
                        <span>Documentos</span>
                        <strong>@DocumentosResumen</strong>
                    </div>
                    <div>
                        <span>Subtotal</span>
                        <strong>$@SubtotalGravado.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div>
                        <span>IVA 15%</span>
                        <strong>$@IvaTotal.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div class="is-total">
                        <span>Total</span>
                        <strong>USD $@montoInput.ToString("F2", CultureInfo.InvariantCulture)</strong>
                    </div>
                </section>

                <section class="recarga-payment-methods">
                    <button type="button"
                            class="recarga-method-card @(metodoPagoDocumentos == "online" ? "is-active" : "")"
                            @onclick='() => SeleccionarMetodoPagoDocumentos("online")'
                            disabled="@enviandoPago">
                        <i class="bi bi-phone"></i>
                        <span>
                            <strong>DeUna / Pago en linea</strong>
                            <small>Abre el checkout seguro y se acredita al aprobarse.</small>
                        </span>
                    </button>
                    <button type="button"
                            class="recarga-method-card @(metodoPagoDocumentos == "transferencia" ? "is-active" : "")"
                            @onclick='() => SeleccionarMetodoPagoDocumentos("transferencia")'
                            disabled="@enviandoPago">
                        <i class="bi bi-bank"></i>
                        <span>
                            <strong>Transferencia bancaria</strong>
                            <small>Se valida manualmente en un plazo maximo de 24 horas.</small>
                        </span>
                    </button>
                </section>

                @if (metodoPagoDocumentos == "transferencia")
                {
                    <section class="recarga-transfer-grid">
                        <div class="recarga-transfer-form">
                            <h4>Informacion de pago</h4>
                            <div class="recarga-field-grid">
                                <label class="recarga-modal-field">
                                    <span>Banco *</span>
                                    <select @bind="transferBanco" disabled="@enviandoPago">
                                        <option value="">Seleccione...</option>
                                        @foreach (var banco in BancosTransferencia)
                                        {
                                            <option value="@banco">@banco</option>
                                        }
                                    </select>
                                </label>
                                <label class="recarga-modal-field">
                                    <span>Titular de la cuenta *</span>
                                    <input type="text" @bind="transferTitular" disabled="@enviandoPago" placeholder="Nombre del titular" />
                                </label>
                                <label class="recarga-modal-field">
                                    <span>N. cuenta de origen *</span>
                                    <input type="text"
                                           @bind:get="transferCuentaOrigen"
                                           @bind:set="OnTransferCuentaOrigenChanged"
                                           @bind:event="oninput"
                                           inputmode="numeric"
                                           pattern="[0-9]*"
                                           disabled="@enviandoPago"
                                           placeholder="Cuenta desde donde pagaste" />
                                </label>
                                <label class="recarga-modal-field">
                                    <span>N. comprobante *</span>
                                    <input type="text"
                                           @bind:get="transferNumeroComprobante"
                                           @bind:set="OnTransferNumeroComprobanteChanged"
                                           @bind:event="oninput"
                                           maxlength="12"
                                           inputmode="text"
                                           disabled="@enviandoPago"
                                           placeholder="Hasta 12 letras o numeros" />
                                </label>
                            </div>

                            <div class="recarga-modal-field recarga-comprobante-field">
                                <span>Comprobante *</span>
                                <label class="recarga-upload-zone @(TieneComprobanteTransferencia ? "has-file" : string.Empty)" for="recarga-transfer-file">
                                    <div class="recarga-upload-copy">
                                        <i class="bi bi-image"></i>
                                        <strong>@(TieneComprobanteTransferencia ? "Comprobante cargado" : "Arrastra o selecciona el comprobante")</strong>
                                        <small>@(string.IsNullOrWhiteSpace(transferArchivoNombre) ? "JPG o PNG. Maximo 5MB. Haz clic en cualquier parte del cuadro." : transferArchivoNombre)</small>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(transferComprobantePreviewUrl))
                                    {
                                        <img class="recarga-upload-preview" src="@transferComprobantePreviewUrl" alt="Vista previa del comprobante" />
                                    }
                                    <InputFile id="recarga-transfer-file"
                                               class="recarga-upload-input"
                                               OnChange="OnTransferFileSelected"
                                               accept=".jpg,.jpeg,.png,image/png,image/jpeg"
                                               disabled="@enviandoPago"
                                               style="display:none" />
                                </label>
                                @if (!string.IsNullOrWhiteSpace(transferComprobanteMensaje))
                                {
                                    <small class="recarga-upload-message">@transferComprobanteMensaje</small>
                                }
                            </div>
                        </div>

                        <aside class="recarga-bank-card">
                            <strong>Pagar a</strong>
                            <dl>
                                <div><dt>Banco:</dt><dd>Banco Pichincha</dd></div>
                                <div><dt>Tipo de cuenta:</dt><dd>Cuenta corriente</dd></div>
                                <div><dt>Numero de cuenta:</dt><dd>22100346647</dd></div>
                                <div><dt>RUC:</dt><dd>1793233799001</dd></div>
                                <div><dt>Nombre:</dt><dd>NUMERICASOFTWARE S.A.S.</dd></div>
                                <div><dt>e-mail:</dt><dd>contabilidad@numericasoftware.com</dd></div>
                            </dl>
                            <p>Realiza la transferencia y adjunta la imagen del comprobante para validar la recarga.</p>
                        </aside>
                    </section>
                }
                else
                {
                    <section class="recarga-online-note">
                        <i class="bi bi-shield-check"></i>
                        <span>Continuaras al checkout seguro. No se modifica el flujo actual de pago aprobado automaticamente.</span>
                    </section>
                }
            </div>

            <footer class="recarga-payment-footer">
                <button type="button" class="recarga-modal-secondary" @onclick="CerrarModalPagoDocumentos" disabled="@enviandoPago">
                    Cancelar
                </button>
                <button type="button" class="recarga-modal-primary" @onclick="ConfirmarMetodoPagoDocumentosAsync" disabled="@enviandoPago">
                    @if (enviandoPago)
                    {
                        <span>Procesando...</span>
                    }
                    else
                    {
                        <span>@(metodoPagoDocumentos == "transferencia" ? "Enviar transferencia" : "Pagar con DeUna")</span>
                    }
                </button>
            </footer>

            @if (mostrarResultadoPagoModal && !string.IsNullOrWhiteSpace(mensajeModalPago))
            {
                <div class="recarga-result-overlay">
                    <div class="recarga-result-dialog @(modalPagoExitoso ? "is-success" : "is-error")">
                        <span class="recarga-result-icon">
                            <i class="bi @(modalPagoExitoso ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                        </span>
                        <h4>@(modalPagoExitoso ? "Solicitud registrada" : "Revisa la informacion")</h4>
                        <p>@mensajeModalPago</p>
                        <button type="button" class="recarga-result-ok" @onclick="AceptarResultadoPagoModal">
                            OK
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private const decimal MontoMaximoPersonalizado = EFactDocumentPricing.MontoMaximoPersonalizado;
    private const decimal MontoMinimoPersonalizado = EFactDocumentPricing.MontoMinimoPersonalizado;
    private static int DocumentosMinimosPersonalizados => EFactDocumentPricing.DocumentosMinimosPersonalizados;
    private const int PlanIlimitadoMarker = -1;
    private static decimal PrecioPlanIlimitado => EFactBillingConfig.EFactPlans.FirstOrDefault(p => p.CantidadDocs == -1)?.Precio ?? EFactDocumentPricing.PrecioPlanIlimitado;
    private const string MensajeRecargaBloqueadaPlanIlimitado =
        "No puedes comprar documentos ni otro plan mientras tu plan ilimitado esté activo.";

    private static readonly JsonSerializerOptions HistorialJsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    private decimal montoInput;
    private string montoTexto = string.Empty;
    private string cantidadTexto = string.Empty;
    private int docsInput;
    private bool enviandoPago;
    private string? mensajePago;
    private bool mostrarModalPagoDocumentos;
    private string metodoPagoDocumentos = "online";
    private string? mensajeModalPago;
    private bool modalPagoExitoso;
    private bool mostrarResultadoPagoModal;
    private string transferBanco = string.Empty;
    private string transferCuentaOrigen = string.Empty;
    private string transferNumeroComprobante = string.Empty;
    private string transferTitular = string.Empty;
    private string? transferArchivoNombre;
    private byte[]? transferComprobanteBytes;
    private string? transferComprobantePreviewUrl;
    private string? transferComprobanteMensaje;
    private const long MaxTransferUploadBytes = 5 * 1024 * 1024;
    private const int TransferPreviewMaxWidth = 1600;
    private const int TransferPreviewMaxHeight = 1600;
    private static readonly string[] BancosTransferencia =
    {
        "Banco Pichincha",
        "Banco Guayaquil",
        "Banco Internacional",
        "Banco Pacifico",
        "Banco Produbanco",
        "Banco Bolivariano",
        "Cooperativa JEP",
        "Otra institucion"
    };
    private PagomediosApiResult? resultadoPago;
    private Usuario? usuarioActual;
    private Usuario? usuarioSesion;
    private Usuario? usuarioCuentaDocumentos;
    private EmisorModel? emisorPagador;
    private EmisionEstado? emisionEstado;
    private List<CompraDocumentosHistorialItem> historialCompras = new();
