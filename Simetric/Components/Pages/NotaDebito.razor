                </table>
            </div>

            @if (modoEmision == ModoEmisionNotaDebito.Manual)
            {
                <div class="nc-detail-actions">
                    <button type="button" class="n-btn n-btn-secondary" @onclick="AgregarLineaNotaDebito">
