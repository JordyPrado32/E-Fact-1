        StateHasChanged();
    }

    private static string NormalizarSerieRaw(string? valor)
    {
        var limpio = SoloDigitosNd(valor);
        return limpio.Length >= 6 ? limpio[..6] : limpio;
    }

    private static string NormalizarSecuencial(string? valor)
    {
        var limpio = SoloDigitosNd(valor);
        return string.IsNullOrWhiteSpace(limpio) ? (valor ?? string.Empty).Trim() : limpio.PadLeft(9, '0');
    }

    private static string ConstruirDocumentoModificadoCompleto(string? serie, string? secuencial)
    {
        var serieLimpia = NormalizarSerieRaw(serie);
        var secuencialLimpio = NormalizarSecuencial(secuencial);
        return serieLimpia.Length == 6 ? $"{serieLimpia}{secuencialLimpio}" : secuencialLimpio;
    }

    private static string SoloDigitosNd(string? valor)
        => new((valor ?? string.Empty).Where(char.IsDigit).ToArray());

    private static string FormatearDocumentoModificadoInput(string? valor)
    {
        var limpio = SoloDigitosNd(valor);
        if (limpio.Length > 15)
            limpio = limpio[..15];

        if (limpio.Length <= 3)
            return limpio;

        if (limpio.Length <= 6)
            return $"{limpio[..3]}-{limpio[3..]}";

        return $"{limpio[..3]}-{limpio.Substring(3, 3)}-{limpio[6..]}";
    }

