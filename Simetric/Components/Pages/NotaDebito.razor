    private void OnDocumentoModificadoInput(ChangeEventArgs e)
    {
        var digitos = SoloDigitosNd(e.Value?.ToString());
        if (digitos.Length > 15)
            digitos = digitos[..15];

        var serieManual = ObtenerSerieFacturaManualRaw();
        if (modoEmision != ModoEmisionNotaDebito.Factura && serieManual.Length == 6)
        {
            factura.Serie = serieManual;
            factura.Numfactura = digitos.StartsWith(serieManual, StringComparison.Ordinal)
                ? (digitos.Length > 6 ? digitos[6..] : string.Empty)
                : digitos;
            serieFacturaVisual = FormatearSerie(factura.Serie);
            return;
        }

        factura.Serie = digitos.Length <= 6 ? digitos : digitos[..6];
        factura.Numfactura = digitos.Length > 6 ? digitos[6..] : string.Empty;
        serieFacturaVisual = FormatearSerie(factura.Serie);
    }

