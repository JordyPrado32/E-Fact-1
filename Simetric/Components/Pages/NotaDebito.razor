    private static decimal Red2(decimal valor)
        => Math.Round(valor, 2, MidpointRounding.AwayFromZero);

    private static string FormatearSerie(string? raw)
    {
        var limpio = (raw ?? string.Empty).Replace("-", string.Empty).Trim();
        return limpio.Length >= 6
            ? $"{limpio[..3]}-{limpio.Substring(3, 3)}"
            : limpio;
    }

