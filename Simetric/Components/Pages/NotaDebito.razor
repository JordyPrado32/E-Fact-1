    private async Task SincronizarClienteCreadoDesdeModalNotaAsync(string? identificacionObjetivo = null)
    {
        var identificacion = string.IsNullOrWhiteSpace(identificacionObjetivo)
            ? cliente.Numeroidentificacion?.Trim()
            : identificacionObjetivo.Trim();

        if (string.IsNullOrWhiteSpace(identificacion))
            return;

        var coincidencias = await FacturacionService.BuscarClientesFiltroAsync(currentUserId, identificacion);
        var clienteCreado = coincidencias.FirstOrDefault(c =>
            string.Equals(c.Numeroidentificacion?.Trim(), identificacion, StringComparison.Ordinal));

        if (clienteCreado is null)
        {
            clienteDetectadoEnCatalogoNota = false;
            return;
        }

        await SeleccionarClienteNotaAsync(clienteCreado);
    }

    private void NormalizarCorreosOpcionalesNota()
    {
        foreach (var correo in correosOpcionalesNota)
            correo.Correo = (correo.Correo ?? string.Empty).Trim();
    }

    private List<FacturaCorreoDestinoDto> ObtenerCorreosOpcionalesNota()
    {
        NormalizarCorreosOpcionalesNota();

        return correosOpcionalesNota
            .Where(x => !string.IsNullOrWhiteSpace(x.Correo))
            .Select(x => new FacturaCorreoDestinoDto
            {
                Correo = x.Correo,
                GuardarEnCliente = x.EsPersistidoCliente ? false : x.GuardarEnCliente
            })
            .ToList();
    }

    private async Task CargarCorreosOpcionalesClienteNotaAsync()
    {
        correosOpcionalesNota = new();
        correosPersistidosClienteNota = new();

        if (cliente.Codcliente <= 0)
            return;

        correosPersistidosClienteNota = (await FacturacionService.GetCorreosAdicionalesClienteAsync(currentUserId, cliente.Codcliente))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(MaxCorreosOpcionalesNota)
            .ToList();

        foreach (var correo in correosPersistidosClienteNota)
        {
            correosOpcionalesNota.Add(new CorreoOpcionalNotaInput
            {
                Correo = correo,
                GuardarEnCliente = true,
                EsPersistidoCliente = true
            });
        }
    }

    private string? ValidarCorreosNotaDebito()
    {
        NormalizarCorreosOpcionalesNota();

        var repetidos = correosOpcionalesNota
            .Where(x => !string.IsNullOrWhiteSpace(x.Correo))
            .GroupBy(x => x.Correo, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault(g => g.Count() > 1);

        if (repetidos != null)
            return $"El correo '{repetidos.Key}' esta repetido en los destinatarios adicionales.";

        foreach (var item in correosOpcionalesNota.Where(x => !string.IsNullOrWhiteSpace(x.Correo)))
        {
            try
            {
                _ = new System.Net.Mail.MailAddress(item.Correo);
            }
            catch
            {
                return $"El correo '{item.Correo}' no tiene un formato valido.";
            }

            if (string.Equals(item.Correo, cliente.Correo?.Trim(), StringComparison.OrdinalIgnoreCase))
                return $"El correo '{item.Correo}' ya esta registrado como correo principal del cliente.";
        }

        return null;
    }

