                NumAutorizacion = null,
                Subtotal = SubtotalGeneral,
                Iva = IvaTotal,
                Descuentos = DescuentoTotal,
                ValorTotal = TotalGeneral,
                CodClave = factura.Numautorizacion,
                Autorizado = string.Empty
            };

            return new NotaDebitoDetalleViewDto
            {
                NotaDebito = nota,
                Cliente = cliente,
                Emisor = emisor,
                TipoIdentificacionCliente = ObtenerTipoIdentificacionNombre(cliente?.Tipoidentificacion),
                NumeroCompleto = $"{FormatearSerie(serieLimpia)}-{secuencialLimpio.PadLeft(9, '0')}",
