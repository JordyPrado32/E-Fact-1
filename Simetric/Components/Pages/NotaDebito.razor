    private async Task BuscarFacturaAsync()
    {
        errorCarga = null;

        if (string.IsNullOrWhiteSpace(numFacturaBuscar) || numFacturaBuscar.Trim().Length < 3)
        {
            estadoCarga = "Escribe al menos 3 digitos";
            return;
        }

        try
        {
            estadoCarga = "Buscando factura...";

            var url = $"api/facturas/por-numero?numFactura={Uri.EscapeDataString(numFacturaBuscar.Trim())}&idUsuario={currentUserId}";
            var resp = await Http.GetAsync(url);
            var raw = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                estadoCarga = "Error";
                errorCarga = $"API {(int)resp.StatusCode} {resp.ReasonPhrase}: {raw}";
                return;
            }

            var dto = JsonSerializer.Deserialize<FacturaViewDto>(
                raw,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (dto?.Factura == null)
            {
                estadoCarga = "No se encontro la factura.";
                return;
            }

            factura = dto.Factura;
            cliente = dto.Cliente ?? new Cliente();
            emisor = dto.Emisor;
            serieFacturaVisual = FormatearSerie(factura.Serie);
            fechaVenceNota = factura.Fechavence ?? DateTime.Today;
            await CargarCorreosOpcionalesClienteNotaAsync();

            ResetearEstadoDetalles();
            detallesNd = new List<DetalleNdDto> { CrearDetalleNotaDebitoVacio() };

            if (string.IsNullOrWhiteSpace(motivoNota))
                motivoNota = $"Ajuste sobre factura {FacturaReferenciaVisual}";

            estadoCarga = "Factura cargada correctamente";

            await RecargarSecuencialNdAsync();
        }
        catch (Exception ex)
        {
            estadoCarga = "Error";
            errorCarga = ex.Message;
        }
    }

    private async Task AsegurarEmisorActivoAsync()
