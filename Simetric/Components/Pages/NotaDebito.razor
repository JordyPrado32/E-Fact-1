        {
            listaFacturas.Clear();
            mostrarListaFacturas = false;
            estadoCarga = "Sin cargar";
            return;
        }

        try
        {
            listaFacturas = await NotaDebitoService.BuscarFacturasAutocompleteAsync(numFacturaBuscar, currentUserId);
            mostrarListaFacturas = listaFacturas.Any();
            estadoCarga = listaFacturas.Any()
                ? $"{listaFacturas.Count} coincidencia(s) encontrada(s)"
                : "No se encontraron coincidencias";
