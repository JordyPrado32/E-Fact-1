@if (mostrarVistaPreviaPdfTemporal)
{
    <div class="n-product-modal-backdrop" style="position: fixed; inset: 0; background: rgba(15, 23, 42, 0.44); backdrop-filter: blur(4px); z-index: 2990;" @onclick="CerrarVistaPreviaPdfTemporalAsync"></div>
    <div class="n-product-modal-shell" style="position: fixed; inset: 0; width: 100vw; height: 100vh; z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2vh 2vw;" role="dialog" aria-modal="true" aria-labelledby="pdfPreviewNdTitulo" @onclick="CerrarVistaPreviaPdfTemporalAsync">
        <div class="n-modal n-product-modal-content n-pdf-preview-modal" style="width: min(96vw, 1280px); height: min(94vh, 920px); display: flex; flex-direction: column; background: #ffffff; border-radius: 18px; box-shadow: 0 20px 50px rgba(15, 23, 42, 0.15); overflow: hidden; border: 1px solid #dceaf5;" @onclick:stopPropagation>
            <div class="n-modal-header" style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; background: linear-gradient(180deg, #ffffff, #f7fbff); border-bottom: 1px solid rgba(15, 23, 42, 0.08); flex-shrink: 0;">
                <div style="display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;">
                    <h5 id="pdfPreviewNdTitulo" style="margin: 0; font-size: 1.15rem; font-weight: 800; color: #0f172a;">@(pdfVistaEsTemporal ? "Vista previa PDF temporal" : "Nota de debito autorizada")</h5>
                    <span style="font-size: 0.72rem; font-weight: 800; color: #006bb5; background: rgba(0, 107, 181, 0.12); padding: 0.25rem 0.75rem; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.04em;">@(pdfVistaEsTemporal ? "Temporal" : "Definitivo")</span>
                    <span style="color: #64748b; font-size: 0.82rem; font-weight: 500;">@(pdfVistaEsTemporal ? "Vista ampliada para revisar el PDF completo antes de emitir." : "PDF regenerado con la autorizacion del SRI.")</span>
                </div>
                <button type="button" @onclick="CerrarVistaPreviaPdfTemporalAsync" style="background: transparent; border: 0; color: #64748b; font-size: 1.34rem; cursor: pointer; transition: color 0.18s; padding: 0.2rem;" aria-label="Cerrar vista previa" onmouseover="this.style.color='#006bb5'" onmouseout="this.style.color='#64748b'">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="n-modal-body" style="flex: 1 1 auto; min-height: 0; padding: 0; background: #f4f8fc; position: relative;">
                @if (!string.IsNullOrWhiteSpace(urlPdfTemporal))
                {
                    <iframe src="@urlPdfTemporal" style="width: 100%; height: 100%; min-height: 0; border: 0; background: #ffffff;" title="Vista previa PDF temporal"></iframe>
                }
                else
                {
                    <div style="height: 100%; display: grid; place-items: center; gap: 0.75rem; padding: 2rem; color: #143451;">
                        <div class="spinner-border text-primary" role="status"></div>
                        <strong>Generando PDF...</strong>
                    </div>
                }
            </div>

            <div class="n-modal-footer" style="display: flex; align-items: center; justify-content: flex-end; padding: 0.8rem 1.5rem; background: #ffffff; border-top: 1px solid rgba(15, 23, 42, 0.08); flex-shrink: 0;">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarVistaPreviaPdfTemporalAsync">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    private enum ModoDescuento
    {
        Porcentaje,
        Moneda
    }

    private enum ModoEmisionNotaDebito
    {
        Factura,
        Manual,
        Xml
    }

    private bool guardando;
    private int currentUserId;
    private EmisionEstado? emisionEstado;

    private string numFacturaBuscar = string.Empty;
    private string estadoCarga = "Sin cargar";
    private string? errorCarga;
    private ModoEmisionNotaDebito modoEmision = ModoEmisionNotaDebito.Factura;
    private string? mensajeXmlNotaDebito;
    private const long MaxNotaDebitoXmlSize = 10 * 1024 * 1024;

    private Factura factura = new();
    private Cliente cliente = new();
    private EmisorModel? emisor;
    private Caja? cajaUsuario;
    private List<DetalleNdDto> detallesNd = new();
    private List<Cliente> sugerenciasClientesNota = new();
    private string? campoClienteNotaActivo;
    private bool clienteDetectadoEnCatalogoNota;
    private bool continuarConClienteSinRegistro;
    private bool mostrarCrudClientesNota;

    private List<FacturaBusquedaDto> listaFacturas = new();
    private bool mostrarListaFacturas;
    private bool seleccionandoFacturaDesdeLista;
    private const int MaxCorreosOpcionalesNota = 4;
    private List<CorreoOpcionalNotaInput> correosOpcionalesNota = new();
    private List<string> correosPersistidosClienteNota = new();

    private string serieNdVisual = "--";
    private string secuencialNdVisual = "--";
    private string secuencialNdAutomatico = string.Empty;
    private string serieNdRawActual = string.Empty;
    private string estadoSecuencialNd = string.Empty;
    private string serieFacturaVisual = "--";
    private bool mostrarModalSecuenciaInicial;
    private bool? usuarioYaEmitioAntes;
    private string secuenciaAnteriorManual = string.Empty;
    private string? errorSecuenciaInicial;
    private bool mostrarHistorialNotasDebito;
    private bool previsualizandoPdf;
    private bool mostrarVistaPreviaPdfTemporal;
    private string? urlPdfTemporal;
    private bool pdfVistaEsTemporal = true;
    private string? mensajeRapidoEmision;
    private bool mensajeRapidoEsError;
    private string? documentoGeneradoPdfUrl;

    private string motivoNota = string.Empty;
    private DateTime fechaVenceNota = DateTime.Today;

    private bool mostrarPanelProductos;
    private bool cargandoProductos;
    private string filtroProductos = string.Empty;

    private List<ProductoDisponibleDto> productosDisponibles = new();
    private List<ProductoDisponibleDto> productosDisponiblesFiltrados = new();
    private List<CajaSerieResolucion> seriesDocumento = new();
    private List<Tipocliente> tiposCliente = new();
    private List<Identificacion> identificaciones = new();
    private List<EmisorModel> emisores = new();
    private Dictionary<string, int> tarifasIvaPorCodigo = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<DetalleNdDto, string> valoresTemporalesPct = new();
    private readonly Dictionary<DetalleNdDto, string> valoresTemporalesDescuentoMoneda = new();
    private readonly Dictionary<DetalleNdDto, decimal> porcentajesDescuentoDetalle = new();
    private readonly Dictionary<DetalleNdDto, ModoDescuento> modosDescuentoDetalle = new();
    private string numeroAutorizacionDocumentoModificado = string.Empty;
    private static readonly int[] TarifasIvaNotaDebito = { 0, 13, 15, 5, 8 };

    private class CorreoOpcionalNotaInput
    {
        public string Correo { get; set; } = string.Empty;
        public bool GuardarEnCliente { get; set; }
        public bool EsPersistidoCliente { get; set; }
    }

    private bool BloqueadoPorSaldoDocumentos => emisionEstado?.RequiereCompraDocumentos == true;
    private string MensajeBloqueoDocumentos => emisionEstado?.Mensaje ?? EmisionControlService.MensajeSaldoAgotado;
    private bool CamposClienteEditables => modoEmision == ModoEmisionNotaDebito.Manual;
    private bool ClienteIngresadoSinRegistro =>
        CamposClienteEditables &&
        cliente.Codcliente <= 0 &&
        !clienteDetectadoEnCatalogoNota &&
        !string.IsNullOrWhiteSpace(cliente.Numeroidentificacion) &&
        cliente.Numeroidentificacion.Trim().Length is 10 or 13;
    private bool ClienteSinRegistroPendienteDecision => ClienteIngresadoSinRegistro && !continuarConClienteSinRegistro;
    private bool RequiereFacturaInterna => modoEmision == ModoEmisionNotaDebito.Factura;
    private string ModoEmisionTitulo => modoEmision == ModoEmisionNotaDebito.Xml ? "Factura cargada desde XML" : "Captura manual";
