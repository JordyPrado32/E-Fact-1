        currentUserId = int.TryParse(userClaim, out var id) ? id : 0;
        await CargarEstadoEmisionAsync();

        tiposCliente = await FacturacionService.GetTiposClienteAsync();
        identificaciones = await IdentificacionService.GetAllActiveAsync();
        emisores = await FacturacionService.GetEmisoresActivosAsync(currentUserId);
        emisor = emisores.FirstOrDefault();

        cajaUsuario = await FacturacionService.GetCajaUsuarioAsync(currentUserId);
        seriesDocumento = await FacturacionService.GetSeriesFacturaHabilitadasAsync(currentUserId);
