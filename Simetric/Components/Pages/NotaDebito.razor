    private async Task AbrirVistaPreviaPdfTemporalAsync()
    {
        if (previsualizandoPdf || emisor?.Codigo is null || emisor.Codigo <= 0)
            return;

        previsualizandoPdf = true;
        pdfVistaEsTemporal = true;
        mostrarVistaPreviaPdfTemporal = true;
        urlPdfTemporal = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var rutaTemporal = await NotaDebitoPdfService.GenerarPdfNotaDebitoTemporalAsync(VistaPreviaNotaDebito);
            urlPdfTemporal = $"{rutaTemporal}?v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
        }
        catch (Exception ex)
        {
            urlPdfTemporal = null;
            mostrarVistaPreviaPdfTemporal = false;
            errorCarga = $"No se pudo generar la vista previa del PDF: {ex.Message}";
        }
        finally
        {
            previsualizandoPdf = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CerrarVistaPreviaPdfTemporalAsync()
    {
        var rutaTemporal = urlPdfTemporal;
        var debeEliminar = pdfVistaEsTemporal;

        urlPdfTemporal = null;
        mostrarVistaPreviaPdfTemporal = false;
        pdfVistaEsTemporal = true;
        await InvokeAsync(StateHasChanged);

        if (debeEliminar && !string.IsNullOrWhiteSpace(rutaTemporal))
        {
            try
            {
                await NotaDebitoPdfService.EliminarPdfNotaDebitoTemporalAsync(rutaTemporal);
            }
            catch
            {
            }
        }
    }

