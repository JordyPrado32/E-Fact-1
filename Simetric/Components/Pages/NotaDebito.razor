    private async Task OnNotaDebitoXmlSelectedAsync(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        modoEmision = ModoEmisionNotaDebito.Xml;
        mensajeXmlNotaDebito = null;
        errorCarga = null;
        estadoCarga = "Leyendo XML...";
        mostrarPanelProductos = false;

        if (archivo is null)
            return;

        if (archivo.Size > MaxNotaDebitoXmlSize)
        {
            await MostrarAlertaAsync("warning", "XML demasiado grande", "Selecciona un archivo XML menor a 10 MB.");
            return;
        }

        try
        {
            await AsegurarEmisorActivoAsync();
            PrepararFormularioNuevoNotaDebito();

            await using var stream = archivo.OpenReadStream(MaxNotaDebitoXmlSize);
            using var reader = new StreamReader(stream, Encoding.UTF8, detectEncodingFromByteOrderMarks: true);
            var contenidoXml = await reader.ReadToEndAsync();

            CargarDatosFacturaDesdeXml(contenidoXml);
            await RecargarSecuencialNdAsync();

            mensajeXmlNotaDebito = $"XML cargado: {archivo.Name}. Ingresa el motivo y valor antes de guardar.";
            estadoCarga = "XML cargado";
        }
        catch (Exception ex)
        {
            estadoCarga = "Error";
            mensajeXmlNotaDebito = null;
            await MostrarAlertaAsync("error", "No se pudo leer el XML", ex.Message);
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CargarDatosFacturaDesdeXml(string contenidoXml)
    {
        var documento = ObtenerDocumentoComprobanteXml(contenidoXml);
        var infoTributaria = PrimerElemento(documento, "infoTributaria")
            ?? throw new InvalidOperationException("El XML no contiene infoTributaria.");
        var infoFactura = PrimerElemento(documento, "infoFactura")
            ?? throw new InvalidOperationException("El XML no contiene infoFactura.");

        var estab = ValorXml(infoTributaria, "estab");
        var ptoEmi = ValorXml(infoTributaria, "ptoEmi");
        var secuencial = ValorXml(infoTributaria, "secuencial");
        var autorizacion = ValorXml(infoTributaria, "claveAcceso")
            ?? ObtenerCampoAdicionalXml(documento, "NumeroAutorizacion")
            ?? ObtenerCampoAdicionalXml(documento, "numAutorizacion")
            ?? string.Empty;
        var fechaFactura = ParseFechaXml(ValorXml(infoFactura, "fechaEmision")) ?? DateTime.Today;

        factura = new Factura
        {
            Serie = ObtenerSerieFacturaManualRaw() is { Length: 6 } serieActiva ? serieActiva : $"{estab}{ptoEmi}",
            Numfactura = secuencial,
            Fchautorizacion = fechaFactura,
            Numautorizacion = autorizacion,
            Coddocumento = 1,
            Idusuario = currentUserId,
            Codemisor = emisor?.Codigo
        };
        serieFacturaVisual = FormatearSerie(factura.Serie);
        fechaVenceNota = fechaFactura;
        numeroAutorizacionDocumentoModificado = autorizacion;

        cliente = new Cliente
        {
            Usuario = currentUserId,
            Estado = true,
            Tipoidentificacion = ValorXml(infoFactura, "tipoIdentificacionComprador") ?? "05",
            Numeroidentificacion = ValorXml(infoFactura, "identificacionComprador"),
            Nombrerazonsocial = ValorXml(infoFactura, "razonSocialComprador"),
            Direccion = ValorXml(infoFactura, "direccionComprador"),
            Correo = ObtenerCampoAdicionalXml(documento, "email")
                ?? ObtenerCampoAdicionalXml(documento, "correo")
                ?? ObtenerCampoAdicionalXml(documento, "EmailCliente"),
            Celular = ObtenerCampoAdicionalXml(documento, "telefono")
                ?? ObtenerCampoAdicionalXml(documento, "celular")
                ?? ObtenerCampoAdicionalXml(documento, "TelefonoCliente"),
            TipoCliente = tiposCliente.FirstOrDefault()?.TclCodigo
        };

        correosOpcionalesNota = new();
        correosPersistidosClienteNota = new();
        ResetearEstadoDetalles();
        detallesNd = new List<DetalleNdDto> { CrearDetalleNotaDebitoVacio() };
    }

    private DetalleNdDto ConstruirDetalleDesdeXml(XElement detalleXml)
    {
        var cantidad = Math.Max(0.01m, ParseDecimalXml(ValorXml(detalleXml, "cantidad")));
        var precio = Math.Max(0.01m, ParseDecimalXml(ValorXml(detalleXml, "precioUnitario")));
        var descuento = Math.Max(0m, ParseDecimalXml(ValorXml(detalleXml, "descuento")));
        var bruto = Red2(cantidad * precio);
        var impuesto = detalleXml.Descendants().FirstOrDefault(x => x.Name.LocalName == "impuesto");
        var iva = NormalizarTarifaIvaNotaDebito((int)Math.Round(ParseDecimalXml(ValorXml(impuesto, "tarifa")), MidpointRounding.AwayFromZero));
        var baseImp = Math.Max(0m, Red2(bruto - descuento));

        return new DetalleNdDto
        {
            Codproducto = 0,
            CodPrincipal = ValorXml(detalleXml, "codigoPrincipal") ?? ValorXml(detalleXml, "codigoInterno") ?? string.Empty,
            CodAuxiliar = ValorXml(detalleXml, "codigoAuxiliar"),
            Descripcion = ValorXml(detalleXml, "descripcion") ?? string.Empty,
            Detalle = ValorXml(detalleXml, "descripcion") ?? string.Empty,
            Cantidad = cantidad,
            Preciounitario = precio,
            Descuento = Math.Min(Red2(descuento), bruto),
            Subtotal = baseImp,
            Iva = iva,
            Total = Red2(baseImp + (baseImp * Math.Max(0, iva) / 100m)),
            CodigoImp = 2,
            CodigoPorcentajeSri = ObtenerCodigoPorcentajeDetalle(new DetalleNdDto { Iva = iva })
        };
    }

    private static XDocument ObtenerDocumentoComprobanteXml(string contenidoXml)
    {
        var documento = XDocument.Parse(contenidoXml, LoadOptions.PreserveWhitespace);
        var comprobante = documento
            .Descendants()
            .FirstOrDefault(x => x.Name.LocalName == "comprobante")
            ?.Value;

        return string.IsNullOrWhiteSpace(comprobante)
            ? documento
            : XDocument.Parse(comprobante, LoadOptions.PreserveWhitespace);
    }

    private static XElement? PrimerElemento(XContainer contenedor, string nombre)
        => contenedor.Descendants().FirstOrDefault(x => x.Name.LocalName == nombre);

    private static string? ValorXml(XContainer? contenedor, string nombre)
        => contenedor?
            .Descendants()
            .FirstOrDefault(x => x.Name.LocalName == nombre)
            ?.Value
            ?.Trim();

    private static string? ObtenerCampoAdicionalXml(XContainer documento, string nombre)
        => documento
            .Descendants()
            .Where(x => x.Name.LocalName == "campoAdicional")
            .FirstOrDefault(x => string.Equals(x.Attribute("nombre")?.Value?.Trim(), nombre, StringComparison.OrdinalIgnoreCase))
            ?.Value
            ?.Trim();

    private static decimal ParseDecimalXml(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return 0m;

        return decimal.TryParse(valor.Trim(), NumberStyles.Any, CultureInfo.InvariantCulture, out var numero)
            ? numero
            : decimal.TryParse(valor.Trim().Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out numero)
                ? numero
                : 0m;
    }

    private static DateTime? ParseFechaXml(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return null;

        var formatos = new[] { "dd/MM/yyyy", "yyyy-MM-dd", "dd-MM-yyyy" };
        return DateTime.TryParseExact(valor.Trim(), formatos, CultureInfo.InvariantCulture, DateTimeStyles.None, out var fecha)
            ? fecha
            : DateTime.TryParse(valor, CultureInfo.InvariantCulture, DateTimeStyles.None, out fecha)
                ? fecha
                : null;
    }

    private async Task ToggleProductosAsync()
    {
        if (modoEmision == ModoEmisionNotaDebito.Xml)
            return;

        mostrarPanelProductos = !mostrarPanelProductos;

        if (mostrarPanelProductos && !productosDisponibles.Any())
            await CargarProductosAsync();
    }

    private async Task CargarProductosAsync()
    {
        cargandoProductos = true;

        try
        {
            var lookups = await Http.GetFromJsonAsync<ProductosLookupResponse>($"api/productos/lookups?userId={currentUserId}");
            tarifasIvaPorCodigo = (lookups?.Ivas ?? new List<IvaLookupDto>())
                .Where(x => !string.IsNullOrWhiteSpace(x.Codigo))
                .GroupBy(x => x.Codigo!.Trim(), StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    g => g.Key,
                    g => ParseTarifaIvaCatalogo(g.First().Valor, g.Key),
                    StringComparer.OrdinalIgnoreCase);

            productosDisponibles = await Http.GetFromJsonAsync<List<ProductoDisponibleDto>>(
                $"api/productos?userId={currentUserId}") ?? new List<ProductoDisponibleDto>();

            AplicarFiltroProductos();
        }
        catch (Exception ex)
        {
            await MostrarAlertaAsync("error", "Error al cargar productos", ex.Message);
        }
        finally
        {
            cargandoProductos = false;
            StateHasChanged();
        }
    }

    private void OnFiltroProductosChanged(ChangeEventArgs e)
    {
        filtroProductos = e.Value?.ToString() ?? string.Empty;
        AplicarFiltroProductos();
    }

    private void AplicarFiltroProductos()
    {
        var filtro = filtroProductos.Trim();

        productosDisponiblesFiltrados = productosDisponibles
            .Where(p =>
                string.IsNullOrWhiteSpace(filtro) ||
                (p.Nombre?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.CodigoPrincipal?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false) ||
                p.Codigo.ToString().Contains(filtro, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.Nombre)
            .ToList();
    }

    private void AgregarProductoADetalle(ProductoDisponibleDto p)
    {
        var precio = p.ValorUnitario ?? 0m;
        var codigoPorcentajeSri = (p.Porcentajeimpuesto ?? string.Empty).Trim();
        var iva = NormalizarTarifaIvaNotaDebito(ParseTarifaIvaDesdeCodigo(codigoPorcentajeSri));
        var codigoImp = ParseCodigoImpuesto(p.Codigoimpuesto);

        var nuevo = new DetalleNdDto
        {
            Codproducto = p.Codigo,
            CodPrincipal = p.CodigoPrincipal ?? string.Empty,
            CodAuxiliar = string.Empty,
            Descripcion = p.Nombre ?? string.Empty,
            Detalle = p.Nombre ?? string.Empty,
            Cantidad = 1m,
            Preciounitario = precio,
            Descuento = 0m,
            Iva = iva,
            CodigoImp = codigoImp,
            CodigoPorcentajeSri = string.IsNullOrWhiteSpace(codigoPorcentajeSri) ? ObtenerCodigoPorcentajeDetalle(new DetalleNdDto { Iva = iva }) : codigoPorcentajeSri
        };

        nuevo.Subtotal = GetBaseImponibleDetalle(nuevo);
        nuevo.Total = GetTotalDetalle(nuevo);

        detallesNd.Add(nuevo);
        modosDescuentoDetalle[nuevo] = ModoDescuento.Porcentaje;
    }

    private int ParseTarifaIvaDesdeCodigo(string? codigo)
    {
        if (string.IsNullOrWhiteSpace(codigo))
            return 0;

        var limpio = codigo.Trim();
        if (tarifasIvaPorCodigo.TryGetValue(limpio, out var tarifa))
            return tarifa;

        return ObtenerTarifaDesdeCodigoPorcentajeSri(limpio);
    }

    private int ParseTarifaIvaCatalogo(string? valor, string? codigo)
    {
        if (!string.IsNullOrWhiteSpace(valor))
        {
            var limpio = valor.Replace("%", string.Empty).Trim();

            if (decimal.TryParse(limpio, NumberStyles.Any, CultureInfo.InvariantCulture, out var n1) ||
                decimal.TryParse(limpio, NumberStyles.Any, new CultureInfo("es-EC"), out n1) ||
                decimal.TryParse(limpio.Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out n1))
            {
                if (n1 > 0m && n1 <= 1m)
                    n1 *= 100m;

                return (int)Math.Round(n1, 0, MidpointRounding.AwayFromZero);
            }
        }

        return ObtenerTarifaDesdeCodigoPorcentajeSri(codigo);
    }

    private int ParseCodigoImpuesto(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return 2;

        return int.TryParse(valor, out var codigo) ? codigo : 2;
    }

    private void OnCantidadChanged(DetalleNdDto detalle, string? valor)
    {
        if (!TryParseDecimalFlexible(valor, out var cantidad))
            return;

        detalle.Cantidad = Math.Max(0m, cantidad);
        RecalcularDescuentoPorModo(detalle);
        detalle.Subtotal = GetBaseImponibleDetalle(detalle);
        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void OnPrecioChanged(DetalleNdDto detalle, string? valor)
    {
        if (!TryParseDecimalFlexible(valor, out var precio))
            return;

        detalle.Preciounitario = Math.Max(0m, precio);
        RecalcularDescuentoPorModo(detalle);
        detalle.Subtotal = GetBaseImponibleDetalle(detalle);
        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void OnDescuentoChanged(DetalleNdDto detalle, string? valor)
    {
        if (!TryParseDecimalFlexible(valor, out var descuento))
            return;

        var maximo = GetSubtotalBrutoDetalle(detalle);
        detalle.Descuento = Math.Min(Math.Max(0m, descuento), maximo);
        detalle.Subtotal = GetBaseImponibleDetalle(detalle);
        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void OnDescuentoDetalleInput(DetalleNdDto detalle, string? valor)
    {
        if (GetModoDescuentoDetalle(detalle) == ModoDescuento.Moneda)
        {
            valoresTemporalesDescuentoMoneda[detalle] = valor ?? "0";

            if (TryParseDecimalFlexible(valor, out var monto))
            {
                detalle.Descuento = Math.Clamp(Red2(monto), 0m, GetSubtotalBrutoDetalle(detalle));
                porcentajesDescuentoDetalle[detalle] = 0m;
                valoresTemporalesDescuentoMoneda[detalle] = detalle.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
            }
            else
            {
                detalle.Descuento = 0m;
            }

            detalle.Subtotal = GetBaseImponibleDetalle(detalle);
            detalle.Total = GetTotalDetalle(detalle);
            StateHasChanged();
            return;
        }

        valoresTemporalesPct[detalle] = valor ?? "0";
        valoresTemporalesDescuentoMoneda.Remove(detalle);
        modosDescuentoDetalle[detalle] = ModoDescuento.Porcentaje;

        if (!TryParseDecimalFlexible(valor, out var pct))
        {
            porcentajesDescuentoDetalle[detalle] = 0m;
            detalle.Descuento = 0m;
            StateHasChanged();
            return;
        }

        pct = Math.Clamp(pct, 0m, 100m);
        porcentajesDescuentoDetalle[detalle] = pct;
        detalle.Descuento = Red2(GetSubtotalBrutoDetalle(detalle) * (pct / 100m));
        detalle.Subtotal = GetBaseImponibleDetalle(detalle);
        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void RecalcularDescuentoPorModo(DetalleNdDto detalle)
    {
        var bruto = GetSubtotalBrutoDetalle(detalle);
        if (GetModoDescuentoDetalle(detalle) == ModoDescuento.Porcentaje)
        {
            detalle.Descuento = Red2(bruto * (GetPorcentajeDescuentoDetalle(detalle) / 100m));
            return;
        }

        detalle.Descuento = Math.Clamp(detalle.Descuento, 0m, bruto);
        valoresTemporalesDescuentoMoneda[detalle] = detalle.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private void OnIvaDetalleChanged(DetalleNdDto detalle, string? valor)
    {
        if (int.TryParse(valor, NumberStyles.Integer, CultureInfo.InvariantCulture, out var iva))
            detalle.Iva = NormalizarTarifaIvaNotaDebito(iva);

        detalle.CodigoPorcentajeSri = ObtenerCodigoPorcentajeDetalle(detalle);
        detalle.Subtotal = GetBaseImponibleDetalle(detalle);
        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void OnIceDetalleChanged(DetalleNdDto detalle, string? valor)
    {
        if (valor != "1")
            detalle.ValorIce = 0m;

        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void OnValorIceChanged(DetalleNdDto detalle, string? valor)
    {
        if (!TryParseDecimalFlexible(valor, out var ice))
            ice = 0m;

        detalle.ValorIce = Red2(Math.Max(0m, ice));
        detalle.Total = GetTotalDetalle(detalle);
        StateHasChanged();
    }

    private void OnFechaVenceChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var fecha))
            fechaVenceNota = fecha.Date;
    }

    private async Task QuitarDetalle(int index)
    {
        if (index < 0 || index >= detallesNd.Count)
            return;

        var detalle = detallesNd[index];
        valoresTemporalesPct.Remove(detalle);
        valoresTemporalesDescuentoMoneda.Remove(detalle);
        porcentajesDescuentoDetalle.Remove(detalle);
        modosDescuentoDetalle.Remove(detalle);
        detallesNd.RemoveAt(index);
        if (!detallesNd.Any())
            detallesNd.Add(CrearDetalleNotaDebitoVacio());
        await InvokeAsync(StateHasChanged);
    }

    private async Task GuardarNotaDebitoAsync()
    {
        if (BloqueadoPorSaldoDocumentos)
        {
            await MostrarAlertaAsync("warning", "Documentos agotados", MensajeBloqueoDocumentos);
            return;
        }

        if (string.IsNullOrWhiteSpace(factura?.Numfactura))
        {
            await MostrarAlertaAsync("warning", "Factura requerida", "Ingresa o carga el numero de la Factura Modificada.");
            return;
        }

        if (RequiereFacturaInterna && factura.Codfactura <= 0)
        {
            await MostrarAlertaAsync("warning", "Factura requerida", "Primero busca y carga una factura valida.");
            return;
        }

        if (!RequiereFacturaInterna)
        {
            var serieDocModificado = NormalizarSerieRaw(factura.Serie);
            var numeroDocModificado = SoloDigitosNd(factura.Numfactura);
            if (serieDocModificado.Length != 6 || string.IsNullOrWhiteSpace(numeroDocModificado))
            {
                await MostrarAlertaAsync("warning", "Factura Modificada requerida", "Ingresa la Factura Modificada con formato 001-001-000000001.");
                return;
            }

            if (!factura.Fchautorizacion.HasValue)
            {
                await MostrarAlertaAsync("warning", "Fecha requerida", "Ingresa la fecha de la Factura Modificada.");
                return;
            }

            if (string.IsNullOrWhiteSpace(cliente.Numeroidentificacion) || string.IsNullOrWhiteSpace(NombreClienteVisual))
            {
                await MostrarAlertaAsync("warning", "Cliente requerido", "Completa la identificacion y nombre del cliente.");
                return;
            }

            if (ClienteSinRegistroPendienteDecision)
            {
                await MostrarAlertaAsync("warning", "Cliente no registrado", "Elige Agregar ahora o Continuar para usar estos datos en la nota de debito.");
                return;
            }
        }

        if (emisor is null)
        {
            await MostrarAlertaAsync("warning", "Emisor no disponible", "No hay emisor cargado para la factura.");
            return;
        }

        var serieNdRaw = (cajaUsuario?.SerieDebitos ?? string.Empty).Replace("-", string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(serieNdRaw))
        {
            await MostrarAlertaAsync("warning", "Serie no configurada", "Configura SerieDebitos en tu caja antes de emitir una nota de debito.");
            return;
        }

        var secNdRaw = (secuencialNdVisual ?? string.Empty).Replace("-", string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(secNdRaw) || secNdRaw == "--")
        {
            await MostrarAlertaAsync("warning", "Numero no disponible", "Presiona 'Recalcular numero' para obtener el siguiente numero.");
            return;
        }

        if (!detallesNd.Any())
        {
            await MostrarAlertaAsync("warning", "Sin detalle", "Debes tener al menos una linea en la nota de debito.");
            return;
        }

        motivoNota = detallesNd.FirstOrDefault(d => !string.IsNullOrWhiteSpace(d.Descripcion))?.Descripcion.Trim()
            ?? string.Empty;

        if (string.IsNullOrWhiteSpace(motivoNota))
        {
            await MostrarAlertaAsync("warning", "Motivo requerido", "Debes ingresar un motivo para la nota de debito.");
            return;
        }

        foreach (var detalle in detallesNd)
            detalle.Cantidad = 1m;

        var validacionCorreos = ValidarCorreosNotaDebito();
        if (!string.IsNullOrWhiteSpace(validacionCorreos))
        {
            await MostrarAlertaAsync("warning", "Correos invalidos", validacionCorreos);
            return;
        }

        var lineaInvalida = detallesNd.FirstOrDefault(d =>
            d.Preciounitario <= 0m ||
                d.Descuento < 0m ||
                d.Descuento > GetSubtotalBrutoDetalle(d) ||
                string.IsNullOrWhiteSpace(d.Descripcion));

        if (lineaInvalida != null)
        {
            await MostrarAlertaAsync("warning", "Detalle invalido", $"Revisa la linea '{lineaInvalida.Descripcion}'.");
            return;
        }

        guardando = true;
        mensajeRapidoEmision = null;
        mensajeRapidoEsError = false;
        documentoGeneradoPdfUrl = null;

        try
        {
            if (!RequiereFacturaInterna)
            {
                factura.Serie = NormalizarSerieRaw(factura.Serie);
                factura.Numfactura = NormalizarSecuencial(factura.Numfactura);
                serieFacturaVisual = FormatearSerie(factura.Serie);
                cliente.Codcliente = await NotaDebitoService.ResolverClienteParaNotaDebitoAsync(currentUserId, cliente);
                factura.Codclientes = cliente.Codcliente;
            }

            foreach (var detalle in detallesNd)
            {
                detalle.ValorIce = Red2(Math.Max(0m, detalle.ValorIce));
                detalle.Subtotal = GetBaseImponibleDetalle(detalle);
                detalle.Total = GetTotalDetalle(detalle);
                detalle.Descuento = GetDescuentoEfectivoDetalle(detalle);
                detalle.CodPrincipal = string.IsNullOrWhiteSpace(detalle.CodPrincipal) ? GetCodigoVisualDetalle(detalle) : detalle.CodPrincipal.Trim();
                detalle.CodAuxiliar = string.IsNullOrWhiteSpace(detalle.CodAuxiliar) ? detalle.CodPrincipal : detalle.CodAuxiliar.Trim();
                detalle.Descripcion = (detalle.Descripcion ?? string.Empty).Trim();
                detalle.Detalle = (detalle.Detalle ?? string.Empty).Trim();
                detalle.Iva = NormalizarTarifaIvaNotaDebito(detalle.Iva);
                detalle.CodigoPorcentajeSri = ObtenerCodigoPorcentajeDetalle(detalle);
            }

            var notaDebito = new NdModel
            {
                Usuario = currentUserId,
                CodClientes = factura.Codclientes ?? (cliente.Codcliente > 0 ? cliente.Codcliente : (int?)null),
                CodEmisor = emisor.Codigo,
                CodDocumento = "05",
                Serie = serieNdRaw,
                NumNotaDebito = secNdRaw.PadLeft(9, '0'),
                FechaVence = fechaVenceNota,
                Motivo = motivoNota.Trim(),
                IdDocModificado = factura.Codfactura > 0 ? factura.Codfactura : (int?)null,
                CodDocModificado = factura.Coddocumento?.ToString() ?? "01",
                NumDocModificado = RequiereFacturaInterna
                    ? factura.Numfactura
                    : ConstruirDocumentoModificadoCompleto(factura.Serie, factura.Numfactura),
                FechaEmiDocModificado = factura.Fechaentrega ?? factura.Fchautorizacion ?? DateTime.Today,
                NumAutorizacion = string.IsNullOrWhiteSpace(numeroAutorizacionDocumentoModificado)
                    ? factura.Numautorizacion
                    : numeroAutorizacionDocumentoModificado.Trim(),
                Subtotal = SubtotalGeneral,
                Subtotal12 = Subtotal12,
                Subtotal0 = SubtotalTarifaCero,
                Iva = IvaTotal,
                NoImp = SubtotalNoObjeto,
                ExIva = SubtotalExentoIva,
                Descuentos = DescuentoTotal,
                ValorTotal = TotalGeneral,
                IdEmpresa = cajaUsuario?.IdEmpresa ?? emisor.IdEmpresa,
                IdSucursal = cajaUsuario?.IdSucursal ?? emisor.IdSucursal,
                Ambiente = 2,
                Estado = "A"
            };

            var correosNota = ObtenerCorreosOpcionalesNota();
            var id = await NotaDebitoService.CrearAsync(notaDebito, detallesNd, correosNota);
            await InitialSequencePromptService.UpdateLastSequenceAsync(
                currentUserId,
                "nota-debito",
                notaDebito.NumNotaDebito,
                serieNdRawActual);
            var respuestaSri = await NotaDebitoService.EmitirNotaDebitoSriAsync(
                id,
                currentUserId,
                intentarEnviarCorreo: true,
                correosExtra: correosNota.Select(x => x.Correo));
            var pdfAutorizadoUrl = await NotaDebitoService.AsegurarPdfNotaDebitoUsuarioAsync(id, currentUserId);
            var autorizadaSri = string.Equals(
                respuestaSri.estado,
                DocumentoAutorizacionHelper.EstadoAutorizado,
                StringComparison.OrdinalIgnoreCase) ||
                !string.IsNullOrWhiteSpace(respuestaSri.autorizacion);

            documentoGeneradoPdfUrl = autorizadaSri && !string.IsNullOrWhiteSpace(pdfAutorizadoUrl)
                ? $"{pdfAutorizadoUrl}?v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}"
                : null;
            mensajeRapidoEmision = autorizadaSri
                ? $"La nota de debito {FormatearSerie(notaDebito.Serie)}-{notaDebito.NumNotaDebito} fue autorizada por el SRI."
                : $"La nota de debito quedo guardada, pero el SRI respondio {respuestaSri.estado}: {respuestaSri.mensaje}";
            mensajeRapidoEsError = !autorizadaSri;

            await CargarEstadoEmisionAsync();
            EmisionControlService.NotifyChanged();
            await LimpiarFormularioAsync();
        }
        catch (Exception ex)
        {
            await MostrarAlertaAsync("error", "Error al guardar", ex.Message);
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task RecargarSecuencialNdAsync()
    {
        estadoSecuencialNd = "Calculando...";
        secuencialNdVisual = "--";

        try
        {
            if (currentUserId <= 0)
            {
                estadoSecuencialNd = "Usuario no valido.";
                return;
            }

            var serieNd = serieNdRawActual;
            if (string.IsNullOrWhiteSpace(serieNd))
                serieNd = await FacturacionService.GetSerieNotaDebitoRawAsync(currentUserId);
            if (string.IsNullOrWhiteSpace(serieNd))
            {
                estadoSecuencialNd = "Caja sin SerieDebitos.";
                return;
            }

            serieNdRawActual = serieNd;
            serieNdVisual = FormatearSerie(serieNd);

            var url = $"api/facturas/nd/next-secuencial?idUsuario={currentUserId}&serie={Uri.EscapeDataString(serieNd)}";
            var resp = await Http.GetAsync(url);
            var txt = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                estadoSecuencialNd = $"API {(int)resp.StatusCode}: {txt}";
                return;
            }

            using var doc = JsonDocument.Parse(txt);
            secuencialNdAutomatico = doc.RootElement.GetProperty("proximo").GetString() ?? "--";
            estadoSecuencialNd = string.Empty;
            await AplicarConfiguracionSecuenciaInicialAsync();
        }
        catch (Exception ex)
        {
            estadoSecuencialNd = ex.Message;
        }
    }

    private async Task OnSerieDocumentoChangedAsync(ChangeEventArgs e)
    {
        var serieRaw = e.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(serieRaw) ||
            string.Equals(serieNdRawActual, serieRaw, StringComparison.Ordinal))
            return;

        await FacturacionService.SavePreferredSeriesForAllDocumentsAsync(currentUserId, serieRaw);
        serieNdRawActual = serieRaw;
        serieNdVisual = FormatearSerie(serieRaw);

        if (cajaUsuario != null)
            cajaUsuario.SerieDebitos = serieNdVisual;

        await RecargarSecuencialNdAsync();
        AplicarSerieFacturaManualDesdeEncabezado();
    }

    private string ObtenerSerieFacturaManualRaw()
    {
        var serie = NormalizarSerieRaw(serieNdRawActual);
        if (serie.Length == 6)
            return serie;

        return NormalizarSerieRaw(seriesDocumento.FirstOrDefault()?.SerieRaw);
    }

    private void AplicarSerieFacturaManualDesdeEncabezado()
    {
        if (modoEmision == ModoEmisionNotaDebito.Factura || factura.Codfactura > 0)
            return;

        var serie = ObtenerSerieFacturaManualRaw();
        if (serie.Length != 6)
            return;

        factura.Serie = serie;
        serieFacturaVisual = FormatearSerie(serie);
    }

    private async Task AplicarConfiguracionSecuenciaInicialAsync()
    {
        var estado = await InitialSequencePromptService.GetStateAsync(currentUserId, "nota-debito", serieNdRawActual);

        if (!estado.Initialized)
        {
            mostrarModalSecuenciaInicial = true;
            secuencialNdVisual = "--";
            return;
        }

        mostrarModalSecuenciaInicial = false;
        secuencialNdVisual = InitialSequencePromptService.ResolveNextSequence(secuencialNdAutomatico, estado);
    }

    private void OnCambioRespuestaSecuencia(bool? value)
    {
        usuarioYaEmitioAntes = value;
        errorSecuenciaInicial = null;

        if (value != true)
            secuenciaAnteriorManual = string.Empty;
    }

    private void OnSecuenciaAnteriorManualChanged(string value)
    {
        secuenciaAnteriorManual = value ?? string.Empty;
        errorSecuenciaInicial = null;
    }

    private async Task ConfirmarSecuenciaInicialAsync()
    {
        errorSecuenciaInicial = null;

        if (usuarioYaEmitioAntes == null)
        {
            errorSecuenciaInicial = "Debes indicar si ya habias generado notas de debito antes.";
            return;
        }

        var secuenciaNormalizada = string.Empty;

        if (usuarioYaEmitioAntes == true &&
            !InitialSequencePromptService.TryNormalizeSequence(secuenciaAnteriorManual, out secuenciaNormalizada))
        {
            errorSecuenciaInicial = "Ingresa una secuencia valida de hasta 9 digitos.";
            return;
        }

        var estado = new InitialSequencePromptState
        {
            Initialized = true,
            HadPreviousDocuments = usuarioYaEmitioAntes.Value,
            PreviousSequence = usuarioYaEmitioAntes.Value ? secuenciaNormalizada : string.Empty
        };

        await InitialSequencePromptService.SaveStateAsync(currentUserId, "nota-debito", serieNdRawActual, estado);

        secuenciaAnteriorManual = secuenciaNormalizada;
        mostrarModalSecuenciaInicial = false;
        secuencialNdVisual = usuarioYaEmitioAntes.Value
            ? InitialSequencePromptService.ResolveNextSequence(secuencialNdAutomatico, estado)
            : secuencialNdAutomatico;
    }

