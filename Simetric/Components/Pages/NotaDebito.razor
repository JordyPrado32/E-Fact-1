                    Cantidad = 1m,
                    PrecioUnitario = detalle.Preciounitario,
                    Descuento = GetDescuentoEfectivoDetalle(detalle),
                    Subtotal = GetBaseImponibleDetalle(detalle),
                    TarifaIva = detalle.Iva,
                    ValorIce = detalle.ValorIce,
                    ValorIva = GetIvaDetalle(detalle),
                    Total = GetTotalDetalle(detalle)
                }).ToList()
            };
        }
