    private void AgregarCorreoOpcionalNota()
    {
        if (correosOpcionalesNota.Count >= MaxCorreosOpcionalesNota)
            return;

        var correoPersistidoPendiente = correosPersistidosClienteNota
            .FirstOrDefault(correoGuardado =>
                !correosOpcionalesNota.Any(x =>
                    string.Equals((x.Correo ?? string.Empty).Trim(), correoGuardado, StringComparison.OrdinalIgnoreCase)));

        if (!string.IsNullOrWhiteSpace(correoPersistidoPendiente))
        {
            correosOpcionalesNota.Add(new CorreoOpcionalNotaInput
            {
                Correo = correoPersistidoPendiente,
                GuardarEnCliente = true,
                EsPersistidoCliente = true
            });
            return;
        }

        correosOpcionalesNota.Add(new CorreoOpcionalNotaInput());
    }

    private void EliminarCorreoOpcionalNota(int index)
    {
        if (index < 0 || index >= correosOpcionalesNota.Count)
            return;

        correosOpcionalesNota.RemoveAt(index);
