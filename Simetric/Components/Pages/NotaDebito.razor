    private bool TryParseDecimalFlexible(string? valor, out decimal numero)
    {
        numero = 0m;
        if (string.IsNullOrWhiteSpace(valor))
            return false;

        valor = valor.Trim();

        return decimal.TryParse(valor, NumberStyles.Any, CultureInfo.InvariantCulture, out numero)
            || decimal.TryParse(valor, NumberStyles.Any, new CultureInfo("es-EC"), out numero)
            || decimal.TryParse(valor.Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out numero);
    }

    private decimal GetSubtotalBrutoDetalle(DetalleNdDto d)
        => Red2(Math.Max(0m, d.Cantidad) * Math.Max(0m, d.Preciounitario));

    private decimal GetDescuentoEfectivoDetalle(DetalleNdDto d)
        => Red2(Math.Max(0m, d.Descuento));

    private decimal GetPorcentajeDescuentoDetalle(DetalleNdDto d)
        => porcentajesDescuentoDetalle.TryGetValue(d, out var pct) ? pct : 0m;

    private ModoDescuento GetModoDescuentoDetalle(DetalleNdDto d)
    {
        if (modosDescuentoDetalle.TryGetValue(d, out var modo))
            return modo;

        return d.Descuento > 0m ? ModoDescuento.Moneda : ModoDescuento.Porcentaje;
    }

    private string GetDescuentoDetalleVisual(DetalleNdDto d)
    {
        if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda)
        {
            if (valoresTemporalesDescuentoMoneda.TryGetValue(d, out var moneda))
                return moneda;

            return d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        if (valoresTemporalesPct.TryGetValue(d, out var pct))
            return pct;

        return GetPorcentajeDescuentoDetalle(d).ToString("0.##", CultureInfo.InvariantCulture);
    }

    private void CambiarModoDescuentoDetalle(DetalleNdDto d, ModoDescuento modo)
    {
        var modoActual = GetModoDescuentoDetalle(d);
        if (modoActual == modo)
            return;

        modosDescuentoDetalle[d] = modo;
        valoresTemporalesPct.Remove(d);
        valoresTemporalesDescuentoMoneda.Remove(d);

        var bruto = GetSubtotalBrutoDetalle(d);
        if (modo == ModoDescuento.Porcentaje)
        {
            var pct = bruto > 0m ? Math.Clamp(Red2((d.Descuento / bruto) * 100m), 0m, 100m) : 0m;
            porcentajesDescuentoDetalle[d] = pct;
            d.Descuento = Red2(bruto * (pct / 100m));
        }
        else
        {
            porcentajesDescuentoDetalle[d] = 0m;
            d.Descuento = Math.Clamp(d.Descuento, 0m, bruto);
        }

        StateHasChanged();
    }

    private decimal GetBaseImponibleDetalle(DetalleNdDto d)
        => Red2(Math.Max(0m, GetSubtotalBrutoDetalle(d) - GetDescuentoEfectivoDetalle(d)));

    private decimal GetIvaDetalle(DetalleNdDto d)
        => Red2(GetBaseImponibleDetalle(d) * Math.Max(0, d.Iva) / 100m);

    private decimal GetTotalDetalle(DetalleNdDto d)
        => Red2(GetBaseImponibleDetalle(d) + GetIvaDetalle(d) + Math.Max(0m, d.ValorIce));

    private static string GetIceSeleccionadoDetalle(DetalleNdDto d)
        => d.ValorIce > 0m ? "1" : "0";

    private static string ObtenerCodigoPorcentajeDetalle(DetalleNdDto detalle)
    {
        if (!string.IsNullOrWhiteSpace(detalle.CodigoPorcentajeSri))
            return detalle.CodigoPorcentajeSri.Trim();

        return detalle.Iva switch
        {
            0 => "0",
            5 => "5",
            8 => "8",
            12 => "2",
            13 => "10",
            14 => "3",
            15 => "4",
            _ => detalle.Iva > 0 ? "2" : "0"
        };
    }

    private static int ObtenerTarifaDesdeCodigoPorcentajeSri(string? codigoPorcentaje)
    {
        return (codigoPorcentaje ?? string.Empty).Trim() switch
        {
            "0" => 0,
            "2" => 12,
            "3" => 14,
            "4" => 15,
            "5" => 5,
            "6" => 0,
            "7" => 0,
            "8" => 8,
            "10" => 13,
            _ => 0
        };
    }

    private decimal SubtotalGravado => detallesNd
        .Where(d => d.Iva > 0)
        .Sum(GetBaseImponibleDetalle);

    private decimal SubtotalTarifaCero => detallesNd
        .Where(d => d.Iva == 0)
        .Sum(GetBaseImponibleDetalle);

    private decimal SubtotalNoObjeto => 0m;

    private decimal SubtotalExentoIva => 0m;

    private decimal Subtotal12 => SubtotalGravado;
    private decimal Subtotal0 => Red2(SubtotalTarifaCero + SubtotalNoObjeto + SubtotalExentoIva);
    private decimal DescuentoTotal => detallesNd.Sum(GetDescuentoEfectivoDetalle);
    private decimal IceTotal => Red2(detallesNd.Sum(d => Math.Max(0m, d.ValorIce)));
    private decimal IvaTotal => detallesNd.Sum(GetIvaDetalle);
    private decimal SubtotalGeneral => Red2(SubtotalGravado + SubtotalTarifaCero + SubtotalNoObjeto + SubtotalExentoIva);
    private decimal SubtotalMasIce => Red2(SubtotalGeneral + IceTotal);
    private List<(int Tarifa, decimal Valor)> IvasPorTarifa => detallesNd
        .Where(d => d.Iva > 0)
        .GroupBy(d => d.Iva)
        .OrderBy(g => g.Key)
        .Select(g => (Tarifa: g.Key, Valor: g.Sum(GetIvaDetalle)))
        .ToList();
    private decimal TotalGeneral => Red2(SubtotalGeneral + IceTotal + IvaTotal);

