@if (IsVisible)
{
    <style>
        .n-loader-backdrop {
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at top left, rgba(187, 208, 226, 0.42), transparent 30%),
                radial-gradient(circle at bottom right, rgba(126, 161, 191, 0.34), transparent 32%),
                linear-gradient(140deg, rgba(102, 140, 173, 0.9), rgba(133, 170, 199, 0.84) 52%, rgba(160, 191, 215, 0.78));
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10500;
            font-family: 'Montserrat', sans-serif;
            background-size: 130% 130%;
            animation: n-loader-backdrop-drift 7s ease-in-out infinite alternate;
        }

        .n-loader-card {
            position: relative;
            overflow: hidden;
            min-width: min(92vw, 540px);
            background:
                linear-gradient(180deg, rgba(239, 246, 251, 0.96), rgba(223, 235, 244, 0.94));
            padding: 3rem 4rem;
            border-radius: 28px;
            border: 1px solid rgba(190, 210, 224, 0.95);
            box-shadow: 0 30px 60px rgba(36, 67, 94, 0.18);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            animation: n-loader-card-float 3s ease-in-out infinite;
        }

        .n-loader-card::before {
            content: "";
            position: absolute;
            inset: -55% 35% 35% -30%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.72), transparent 64%);
            pointer-events: none;
            animation: n-loader-shine 4.6s ease-in-out infinite alternate;
        }

        .n-loader-card > * {
            position: relative;
            z-index: 1;
        }

        .n-loader-visual {
            position: relative;
            width: 85px;
            height: 85px;
            margin-bottom: 1.8rem;
            display: flex;
            justify-content: center;
            align-items: center;
            filter: drop-shadow(0 12px 18px rgba(50, 94, 130, 0.16));
            animation: n-loader-visual-breathe 1.8s ease-in-out infinite;
        }

        .n-loader-ring {
            position: absolute;
            inset: 0;
            border: 4px solid rgba(177, 198, 214, 0.72);
            border-top-color: #6c95b7;
            border-right-color: #6c95b7;
            border-radius: 50%;
            animation: n-spin 1.5s cubic-bezier(0.55, 0.15, 0.45, 0.85) infinite;
        }

        .n-loader-ring::after {
            content: "";
            position: absolute;
            inset: -8px;
            border: 2px solid transparent;
            border-bottom-color: #8ca9c1;
            border-left-color: #8ca9c1;
            border-radius: 50%;
            animation: n-spin-reverse 2s linear infinite;
        }

        .n-numbers-container {
            position: relative;
            width: 55px;
            height: 35px;
            overflow: hidden;
            display: flex;
            justify-content: center;
            gap: 6px;
            font-family: "Conthrax SemiBold", "Conthrax", "Montserrat", sans-serif;
            font-size: 1.25rem;
            color: #5e86a8;
            z-index: 10;
        }

        .n-numbers-container::before,
        .n-numbers-container::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            height: 10px;
            z-index: 2;
        }

        .n-numbers-container::before {
            top: 0;
            background: linear-gradient(to bottom, rgba(234, 242, 247, 1), transparent);
        }

        .n-numbers-container::after {
            bottom: 0;
            background: linear-gradient(to top, rgba(225, 236, 244, 1), transparent);
        }

        .col-num {
            display: flex;
            flex-direction: column;
            animation: scroll-nums 1s infinite linear;
        }

        .col-num.delay-1 {
            animation-duration: 1.4s;
            animation-direction: reverse;
        }

        .col-num.delay-2 {
            animation-duration: 1.2s;
        }

        .n-loader-title {
            color: #27455f;
            font-weight: 800;
            font-size: 1.45rem;
            letter-spacing: 0.02em;
            margin: 0 0 0.5rem 0;
            animation: n-pulse 2s ease-in-out infinite;
        }

        .n-loader-msg {
            color: #5f758b;
            font-size: 0.98rem;
            margin: 0;
        }

        @@keyframes n-loader-backdrop-drift {
            0% { background-position: 0% 0%; }
            100% { background-position: 100% 100%; }
        }

        @@keyframes n-loader-card-float {
            0%, 100% { transform: translateY(0); box-shadow: 0 30px 60px rgba(36, 67, 94, 0.18); }
            50% { transform: translateY(-9px); box-shadow: 0 38px 72px rgba(36, 67, 94, 0.24); }
        }

        @@keyframes n-loader-shine {
            0% { transform: translate3d(-6%, -3%, 0) scale(0.9); opacity: 0.45; }
            100% { transform: translate3d(42%, 28%, 0) scale(1.15); opacity: 0.82; }
        }

        @@keyframes n-loader-visual-breathe {
            0%, 100% { transform: scale(0.96); }
            50% { transform: scale(1.05); }
        }

        @@keyframes n-spin {
            to { transform: rotate(360deg); }
        }

        @@keyframes n-spin-reverse {
            to { transform: rotate(-360deg); }
        }

        @@keyframes scroll-nums {
            to { transform: translateY(-50%); }
        }

        @@keyframes n-pulse {
            0%, 100% { opacity: 1; transform: translateY(0); }
            50% { opacity: 0.68; transform: translateY(-1px); }
        }

        @@media (prefers-reduced-motion: reduce) {
            .n-loader-backdrop,
            .n-loader-card,
            .n-loader-card::before,
            .n-loader-visual,
            .n-loader-ring,
            .n-loader-ring::after,
            .col-num,
            .n-loader-title {
                animation: none;
            }
        }

        @@media (max-width: 640px) {
            .n-loader-card {
                min-width: min(92vw, 360px);
                padding: 2.2rem 1.6rem;
                border-radius: 24px;
            }

            .n-loader-title {
                font-size: 1.25rem;
            }

            .n-loader-msg {
                font-size: 0.9rem;
            }
        }

    </style>

    <div class="n-loader-backdrop">
        <div class="n-loader-card">
            <div class="n-loader-visual">
                <div class="n-loader-ring"></div>
                <div class="n-numbers-container">
                    <div class="col-num">
                        <span>0</span><span>7</span><span>3</span><span>9</span><span>1</span><span>5</span>
                        <span>0</span><span>7</span><span>3</span><span>9</span><span>1</span><span>5</span>
                    </div>
                    <div class="col-num delay-1">
                        <span>4</span><span>1</span><span>8</span><span>2</span><span>6</span><span>0</span>
                        <span>4</span><span>1</span><span>8</span><span>2</span><span>6</span><span>0</span>
                    </div>
                    <div class="col-num delay-2">
                        <span>9</span><span>5</span><span>2</span><span>7</span><span>4</span><span>1</span>
                        <span>9</span><span>5</span><span>2</span><span>7</span><span>4</span><span>1</span>
                    </div>
                </div>
            </div>

            <h4 class="n-loader-title">@Titulo</h4>
            <p class="n-loader-msg">@Mensaje</p>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Titulo { get; set; } = "Procesando Solicitud";
    [Parameter] public string Mensaje { get; set; } = "Por favor, espera un momento...";
}
