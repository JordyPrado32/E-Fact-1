@page "/perfil"
@page "/e-sign/configuracion/perfil"
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Models
@using Simetric.Auth
@using Simetric.Services
@using Simetric.ViewModels
@using System.IO
@using Simetric.Data
@using Microsoft.EntityFrameworkCore
@inject IUsuarioService UsuarioService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject IDbContextFactory<AppDbContext> DbFactory

@{
    var nombreCompleto = GetNombreCompleto();
}

<PageTitle>Mi Perfil | @PageBrandTitle</PageTitle>

<div class="profile-shell @(IsESignContext ? "profile-shell-esign" : string.Empty)" data-tour="perfil.page">
    @if (perfil == null)
    {
        <section class="profile-state-card">
            <div class="profile-state-icon">
                <span class="spinner-border text-primary" role="status"></span>
            </div>
            <h3>Cargando tu perfil</h3>
            <p>Preparando tu informacion.</p>
        </section>
    }
    else
    {
        <EditForm Model="@perfil" OnValidSubmit="GuardarCambios">
            <DataAnnotationsValidator />

            <div class="profile-grid">
                <aside class="profile-aside-card" data-tour="perfil.avatar">
                    <div class="profile-panel-head">
                        <div>
                            <span class="panel-kicker">Avatar</span>
                            <h3>Imagen</h3>
                        </div>

                        <span class="profile-pill">@GetAvatarCountLabel()</span>
                    </div>

                    <div class="profile-avatar-stage">
                        <div class="profile-avatar-frame">
                            <img src="@GetAvatarPreviewSrc()" class="profile-avatar-preview" alt="Vista previa del avatar" />
                        </div>

                        <div class="profile-avatar-copy">
                            <strong>@nombreCompleto</strong>
                            <span>@GetAvatarCaption()</span>
                            <div class="mt-2 text-center">
                                <InputFile OnChange="UploadOwnPhotoAsync" accept="image/png, image/jpeg, image/jpg" class="d-none" id="fileOwnAvatar" />
                                <label for="fileOwnAvatar" class="btn btn-sm btn-outline-secondary cursor-pointer" style="border-radius: 8px; font-size: 0.8rem; padding: 0.25rem 0.5rem; font-weight: 600;">
                                    <i class="bi bi-cloud-arrow-up"></i> Subir Foto Propia
                                </label>
                                @if (subiendoArchivo)
                                {
                                    <div class="spinner-border spinner-border-sm text-primary mt-1" role="status" style="width: 1rem; height: 1rem; display: block; margin: 0.25rem auto;"></div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="profile-avatar-library">
                        <div class="profile-section-head">
                            <h4>Seleccion</h4>
                            <span class="profile-section-caption">Biblioteca</span>
                        </div>

                        @if (listaAvatares.Any())
                        {
                            <div class="profile-avatar-grid">
                                @{
                                    var esInitialsActual = !string.IsNullOrWhiteSpace(perfil.AvatarUrl) && perfil.AvatarUrl.Contains("avatar_initials_");
                                    var initialsPreview = GenerarSvgIniciales();
                                }
                                <button type="button"
                                        title="Iniciales del nombre"
                                        class="avatar-picker @(esInitialsActual ? "avatar-picker-active" : string.Empty)"
                                        @onclick="() => SeleccionarAvatarInitials()">
                                    <img src="@initialsPreview" alt="Iniciales" />
                                </button>
                                @foreach (var imgNombre in listaAvatares)
                                {
                                    var rutaRelativa = $"images/Avatars/{imgNombre}";
                                    var avatarSrc = $"/images/Avatars/{imgNombre}";
                                    var esAvatarActual = string.Equals(perfil.AvatarUrl, rutaRelativa, StringComparison.OrdinalIgnoreCase);

                                    <button type="button"
                                            title="@imgNombre"
                                            class="avatar-picker @(esAvatarActual ? "avatar-picker-active" : string.Empty)"
                                            @onclick="() => SeleccionarAvatar(imgNombre)">
                                        <img src="@avatarSrc" alt="Avatar disponible @imgNombre" />
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="profile-avatar-empty">
                                <i class="bi bi-images"></i>
                                <span>Sin avatares disponibles.</span>
                            </div>
                        }
                    </div>

                    <section class="profile-legal-section" aria-labelledby="profile-legal-title">
                        <div class="profile-section-head">
                            <h4 id="profile-legal-title">Legal</h4>
                            <span class="profile-section-caption">Documentos</span>
                        </div>

                        <a href="/politica-privacidad?returnUrl=@(Uri.EscapeDataString(IsESignContext ? "/e-sign/configuracion/perfil" : "/perfil"))" class="profile-legal-link">
                            <span class="profile-legal-icon">
                                <i class="bi bi-shield-check"></i>
                            </span>

                            <span class="profile-legal-copy">
                                <strong>Politica de Privacidad</strong>
                                <small>Ver acuerdo vigente</small>
                            </span>

                            <i class="bi bi-box-arrow-up-right profile-legal-arrow" aria-hidden="true"></i>
                        </a>
                    </section>
                </aside>

                <section class="profile-form-card" data-tour="perfil.form">
                    <div class="profile-panel-head profile-panel-head-form">
                        <div>
                            <span class="panel-kicker">Cuenta</span>
                            <h3>Informacion</h3>
                        </div>

                        @if (IsESignContext)
                        {
                            <span class="profile-pill profile-pill-soft">eRúbrica activo</span>
                        }
                    </div>

                    <ValidationSummary class="profile-validation" />

                    @if (IsESignContext)
                    {
                        <section class="profile-context-banner">
                            <div class="profile-context-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div class="profile-context-copy">
                                <strong>Perfil operativo para eRúbrica</strong>
                                <span>Estos datos se usan para notificaciones, renovaciones y control de tu identidad digital.</span>
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="profile-context-banner">
                            <div class="profile-context-icon">
                                <i class="bi bi-receipt"></i>
                            </div>
                            <div class="profile-context-copy">
                                <strong>Datos para facturacion</strong>
                                <span>Esta informacion se utilizara para emitir correctamente tus comprobantes y documentos de facturacion.</span>
                            </div>
                        </section>
                    }

                    <div class="profile-form-grid">
                        <div class="profile-field-card profile-field-wide profile-field-card-readonly">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Correo electronico</label>
                                
                            </div>

                            <div class="profile-input-shell profile-input-shell-readonly">
                                <span class="profile-input-icon">
                                    <i class="bi bi-envelope-paper-heart"></i>
                                </span>
                                <input type="text" class="profile-field-input profile-field-input-readonly" value="@perfil.Email" readonly />
                            </div>
                        </div>

                        <div class="profile-field-card">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Tipo de cliente</label>
                            </div>
                            <div class="profile-input-shell">
                                <span class="profile-input-icon"><i class="bi bi-person-badge"></i></span>
                                <InputSelect @bind-Value="perfil.TipoCliente" class="profile-field-input">
                                    <option value="">Seleccione</option>
                                    @foreach (var tipo in tiposCliente)
                                    {
                                        <option value="@tipo.TclCodigo">@tipo.TclDescripcion</option>
                                    }
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => perfil.TipoCliente)" class="profile-field-error" />
                        </div>

                        <div class="profile-field-card">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Tipo de identificacion</label>
                            </div>
                            <div class="profile-input-shell">
                                <span class="profile-input-icon"><i class="bi bi-card-heading"></i></span>
                                <InputSelect @bind-Value="perfil.IdTipoIdentificacion" class="profile-field-input">
                                    <option value="">Seleccione</option>
                                    @foreach (var tipo in tiposIdentificacion)
                                    {
                                        <option value="@tipo.IdTipoIdentificacion">@tipo.NombreTipo</option>
                                    }
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => perfil.IdTipoIdentificacion)" class="profile-field-error" />
                        </div>

                        <div class="profile-field-card profile-field-wide">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Identificación (Cédula o RUC)</label>
                            </div>

                            <div class="profile-input-shell">
                                <span class="profile-input-icon">
                                    <i class="bi bi-card-text"></i>
                                </span>
                                <InputText @bind-Value="perfil.Identificacion" class="profile-field-input" maxlength="13" />
                            </div>
                            <ValidationMessage For="@(() => perfil.Identificacion)" class="profile-field-error" />
                        </div>

                        @if (perfil.TipoCliente == 2)
                        {
                            <div class="profile-field-card profile-field-wide">
                                <div class="profile-field-top">
                                    <label class="profile-field-label">Razon social</label>
                                </div>
                                <div class="profile-input-shell">
                                    <span class="profile-input-icon"><i class="bi bi-building"></i></span>
                                    <InputText @bind-Value="perfil.NombreEmpresa" class="profile-field-input" maxlength="150" />
                                </div>
                                <ValidationMessage For="@(() => perfil.NombreEmpresa)" class="profile-field-error" />
                            </div>
                        }

                        <div class="profile-field-card">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Nombres</label>
                                
                            </div>

                            <div class="profile-input-shell">
                                <span class="profile-input-icon">
                                    <i class="bi bi-person-badge"></i>
                                </span>
                                <InputText @bind-Value="perfil.Nombres" class="profile-field-input" maxlength="60" />
                            </div>

                            <ValidationMessage For="@(() => perfil.Nombres)" class="profile-field-error" />
                        </div>

                        <div class="profile-field-card">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Apellidos</label>
                                
                            </div>

                            <div class="profile-input-shell">
                                <span class="profile-input-icon">
                                    <i class="bi bi-person-vcard"></i>
                                </span>
                                <InputText @bind-Value="perfil.Apellidos" class="profile-field-input" maxlength="60" />
                            </div>

                            <ValidationMessage For="@(() => perfil.Apellidos)" class="profile-field-error" />
                        </div>

                        <div class="profile-field-card profile-field-wide">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Celular</label>
                            </div>
                            <div class="profile-input-shell">
                                <span class="profile-input-icon"><i class="bi bi-phone"></i></span>
                                <InputText @bind-Value="perfil.Celular" class="profile-field-input" maxlength="10" />
                            </div>
                            <ValidationMessage For="@(() => perfil.Celular)" class="profile-field-error" />
                        </div>

                        <div class="profile-field-card profile-field-wide">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Direccion</label>
                            </div>
                            <div class="profile-input-shell">
                                <span class="profile-input-icon"><i class="bi bi-geo-alt"></i></span>
                                <InputText @bind-Value="perfil.DireccionEmpresa" class="profile-field-input" maxlength="200" />
                            </div>
                            <ValidationMessage For="@(() => perfil.DireccionEmpresa)" class="profile-field-error" />
                        </div>

                        <div class="profile-field-card profile-field-wide">
                            <div class="profile-field-top">
                                <label class="profile-field-label">Fecha de nacimiento</label>
                            </div>

                            <div class="profile-input-shell">
                                <span class="profile-input-icon">
                                    <i class="bi bi-calendar3"></i>
                                </span>
                                <InputDate @bind-Value="perfil.FechaNacimiento"
                                           class="profile-field-input"
                                           min="@FechaNacimientoMinima"
                                           max="@FechaNacimientoMaxima" />
                            </div>

                            <ValidationMessage For="@(() => perfil.FechaNacimiento)" class="profile-field-error" />
                        </div>

                    </div>

                    <section class="profile-security-card" data-tour="perfil.security">
                        <div class="profile-security-head">
                            <div>
                                <span class="panel-kicker">Seguridad</span>
                                <h4>Clave de acceso</h4>
                            </div>

                            <div class="profile-security-controls">
                                <span class="profile-security-badge @(cambiarPassword ? "profile-security-badge-active" : string.Empty)">
                                    @GetEstadoSeguridad()
                                </span>

                                <label class="profile-toggle">
                                    <input type="checkbox" @bind="cambiarPassword" />
                                    <span class="profile-toggle-track"></span>
                                    <span class="profile-toggle-label">Cambiar</span>
                                </label>
                            </div>
                        </div>

                        @if (cambiarPassword)
                        {
                            <div class="profile-password-grid">
                                <div class="profile-field-card">
                                    <div class="profile-field-top">
                                        <label class="profile-field-label">Nueva contraseña</label>
                                        <span class="profile-field-tag">Privada</span>
                                    </div>

                                    <div class="profile-input-shell">
                                        <span class="profile-input-icon">
                                            <i class="bi bi-shield-lock"></i>
                                        </span>
                                        <InputText @bind-Value="perfil.NuevaPassword" type="password" class="profile-field-input" />
                                    </div>

                                    <ValidationMessage For="@(() => perfil.NuevaPassword)" class="profile-field-error" />
                                </div>

                                <div class="profile-field-card">
                                    <div class="profile-field-top">
                                        <label class="profile-field-label">Confirmar contraseña</label>
                                        <span class="profile-field-tag">Verificar</span>
                                    </div>

                                    <div class="profile-input-shell">
                                        <span class="profile-input-icon">
                                            <i class="bi bi-patch-check"></i>
                                        </span>
                                        <InputText @bind-Value="perfil.ConfirmarPassword" type="password" class="profile-field-input" />
                                    </div>

                                    <ValidationMessage For="@(() => perfil.ConfirmarPassword)" class="profile-field-error" />
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="profile-security-placeholder">
                                <div class="profile-security-placeholder-icon">
                                    <i class="bi bi-shield-check"></i>
                                </div>

                                <div class="profile-security-placeholder-copy">
                                    <strong>Sin cambios en contraseña</strong>
                                    <span></span>
                                </div>
                            </div>
                        }
                    </section>

                    <div class="profile-form-footer" data-tour="perfil.save">
                        

                        <button type="submit" class="primary-btn profile-save-btn @(guardandoPerfil ? "n-auto-loading" : null)" disabled="@guardandoPerfil">
                            @if (!guardandoPerfil)
                            {
                                <i class="bi bi-save2-fill"></i>
                            }
                            <span>@(guardandoPerfil ? "Guardando..." : "Guardar cambios")</span>
                        </button>
                    </div>
                </section>
            </div>
        </EditForm>
    }
</div>

@code {
    private const string DefaultAvatarUrl = "/images/avatars/Avatar-Boy.jpg";
    private string PageBrandTitle => IsBackOfficeContext ? "Numerica BackOffice" : Nav.Uri.Contains("/e-sign", StringComparison.OrdinalIgnoreCase) ? "Numerica eRúbrica" : "Numerica e-fact";
    private bool IsESignContext => Nav.Uri.Contains("/e-sign", StringComparison.OrdinalIgnoreCase);
    private bool IsBackOfficeContext => Nav.Uri.Contains("/backoffice", StringComparison.OrdinalIgnoreCase);
    private PerfilViewModel? perfil;
    private List<string> listaAvatares = new();
    private List<TipoIdentificacion> tiposIdentificacion = new();
    private List<Tipocliente> tiposCliente = new();
    private bool cambiarPassword;
    private bool guardandoPerfil;
    private int? usuarioIdActual;
    private bool esAdmin;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claimIdUsuario = authState.User.FindFirst("IdUsuario")?.Value;
        var claimTipoUsuario = authState.User.FindFirst("IdTipoUsuario")?.Value;

        // Validamos si el ID corresponde al administrador (Asumiendo que Admin es 1)
        // Ajusta el "1" si tu ID de administrador en la base de datos es distinto
        esAdmin = claimTipoUsuario == "2";
        CargarListaAvatares();

        await using (var catalogosDb = await DbFactory.CreateDbContextAsync())
        {
            tiposIdentificacion = await catalogosDb.TipoIdentificacion.AsNoTracking().OrderBy(x => x.IdTipoIdentificacion).ToListAsync();
            tiposCliente = await catalogosDb.Tipoclientes.AsNoTracking().OrderBy(x => x.TclCodigo).ToListAsync();
        }

        
        if (!int.TryParse(claimIdUsuario, out var idUsuario))
        {
            Nav.NavigateTo("/login");
            return;
        }

        usuarioIdActual = idUsuario;

        try
        {
            var userDb = await UsuarioService.ObtenerUsuarioPorId(idUsuario);
            if (userDb is not null)
            {
                perfil = new PerfilViewModel
                {
                    Nombres = userDb.Nombres,
                    Apellidos = userDb.Apellidos,
                    Email = userDb.Email,
                    AvatarUrl = userDb.AvatarUrl,
                    FechaNacimiento = userDb.FechaNacimiento,
                    FotoByte = userDb.FirmaElectronica,
                    Identificacion = userDb.Identificacion,
                    TipoCliente = userDb.TipoCliente,
                    IdTipoIdentificacion = userDb.IdTipoIdentificacion,
                    NombreEmpresa = userDb.NombreEmpresa,
                    DireccionEmpresa = userDb.DireccionEmpresa,
                    Celular = userDb.Celular
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
    }

    private void CargarListaAvatares()
    {
        try
        {
            var folderPath = Path.Combine(Env.WebRootPath, "images", "Avatars");
            if (Directory.Exists(folderPath))
            {
                // Nombre exacto del archivo que mencionaste
                string avatarRestringido = "avatar_18e35752-9dbd-40a4-8c62-970a2dfc1dfb.png";

                var archivos = Directory.GetFiles(folderPath)
                    .Select(Path.GetFileName)
                    .Where(f => !string.IsNullOrEmpty(f) &&
                                !f.Equals("Avatar-Boy.jpg", StringComparison.OrdinalIgnoreCase) &&
                                (f.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                                 f.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                                 f.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)));

                // FILTRO: Si NO es administrador, excluimos el avatar restringido
                if (!esAdmin)
                {
                    archivos = archivos.Where(f => f is not null && !f.Equals(avatarRestringido, StringComparison.OrdinalIgnoreCase));
                }

                listaAvatares = archivos
                    .OrderByDescending(f => f != null && f.StartsWith("Bandera-", StringComparison.OrdinalIgnoreCase))
                    .ThenBy(f => f, StringComparer.OrdinalIgnoreCase)
                    .ToList()!;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar avatares: {ex.Message}");
        }
    }

    private async Task SeleccionarAvatar(string nombreArchivo)
    {
        if (perfil is null || usuarioIdActual is null)
        {
            return;
        }

        perfil.AvatarUrl = $"images/Avatars/{nombreArchivo}";
        perfil.FotoByte = null;
        var actualizado = await UsuarioService.ActualizarAvatar(usuarioIdActual.Value, perfil.AvatarUrl);
        if (!actualizado)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Error", "No se pudo actualizar el avatar.", "error");
            return;
        }

        var usuarioActualizado = await UsuarioService.ObtenerUsuarioPorId(usuarioIdActual.Value);
        if (usuarioActualizado is not null && AuthStateProvider is CustomAuthStateProvider authProvider)
        {
            await authProvider.UpdateAuthenticationState(usuarioActualizado);
        }

    }

    private bool subiendoArchivo;

    private async Task UploadOwnPhotoAsync(InputFileChangeEventArgs e)
    {
        if (perfil is null || usuarioIdActual is null)
        {
            return;
        }

        subiendoArchivo = true;
        StateHasChanged();
        try
        {
            var file = e.File;
            if (file != null)
            {
                // Limitar tamaño a 1MB
                if (file.Size > 1 * 1024 * 1024)
                {
                    await JS.InvokeVoidAsync("Swal.fire", "Error", "La imagen no debe superar 1MB.", "error");
                    return;
                }

                var extension = Path.GetExtension(file.Name).ToLower();
                if (extension != ".png" && extension != ".jpg" && extension != ".jpeg")
                {
                    await JS.InvokeVoidAsync("Swal.fire", "Error", "Formato de imagen no permitido. Use PNG, JPG o JPEG.", "error");
                    return;
                }

                var uploadsFolder = Path.Combine(Env.WebRootPath, "images", "Avatars", "uploads");
                if (!Directory.Exists(uploadsFolder))
                {
                    Directory.CreateDirectory(uploadsFolder);
                }

                // Eliminar avatar anterior del usuario si ya era uno subido físicamente para no acumular basura
                if (!string.IsNullOrWhiteSpace(perfil.AvatarUrl) && perfil.AvatarUrl.Contains("images/Avatars/uploads/"))
                {
                    try
                    {
                        var oldPath = Path.Combine(Env.WebRootPath, perfil.AvatarUrl.TrimStart('/'));
                        if (File.Exists(oldPath))
                        {
                            File.Delete(oldPath);
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error al eliminar avatar anterior: {ex.Message}");
                    }
                }

                var uniqueName = $"avatar_user_{usuarioIdActual}_{Guid.NewGuid()}{extension}";
                var filePath = Path.Combine(uploadsFolder, uniqueName);

                using (var stream = file.OpenReadStream(1 * 1024 * 1024))
                using (var fileStream = new FileStream(filePath, FileMode.Create))
                {
                    await stream.CopyToAsync(fileStream);
                }

                perfil.AvatarUrl = $"images/Avatars/uploads/{uniqueName}";
                perfil.FotoByte = null;

                // Guardado automático del avatar subido
                var actualizado = await UsuarioService.ActualizarAvatar(usuarioIdActual.Value, perfil.AvatarUrl);
                if (!actualizado)
                {
                    await JS.InvokeVoidAsync("Swal.fire", "Error", "No se pudo guardar la foto propia en base de datos.", "error");
                    return;
                }

                var usuarioActualizado = await UsuarioService.ObtenerUsuarioPorId(usuarioIdActual.Value);
                if (usuarioActualizado is not null && AuthStateProvider is CustomAuthStateProvider authProvider)
                {
                    await authProvider.UpdateAuthenticationState(usuarioActualizado);
                }

            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al subir imagen: {ex.Message}");
            await JS.InvokeVoidAsync("Swal.fire", "Error", "No se pudo procesar la imagen seleccionada.", "error");
        }
        finally
        {
            subiendoArchivo = false;
            StateHasChanged();
        }
    }

    private async Task GuardarCambios()
    {
        if (guardandoPerfil || perfil == null || usuarioIdActual is null)
        {
             return; 
    }

        // Alerta de confirmación
        var result = await JS.InvokeAsync<SweetAlertResult>("Swal.fire", new
        {
            title = "¿Guardar cambios?",
            text = "Se actualizará la información de tu perfil.",
            icon = "question",
            showCancelButton = true,
            confirmButtonText = "Sí, guardar",
            cancelButtonText = "Cancelar",
            confirmButtonColor = "#3085d6",
            cancelButtonColor = "#d33"
        });

        // Si el usuario confirma, procedemos con la lógica existente
        if (result.IsConfirmed)
        {
            guardandoPerfil = true;
            try
            {
            if (!cambiarPassword)
            {
                 perfil.NuevaPassword = null; 
                 perfil.ConfirmarPassword = null; 
            }

             perfil.Nombres = NormalizarTexto(perfil.Nombres); 
             perfil.Apellidos = NormalizarTexto(perfil.Apellidos); 
             perfil.NombreEmpresa = perfil.NombreEmpresa?.Trim();
             perfil.DireccionEmpresa = perfil.DireccionEmpresa?.Trim();
             perfil.Celular = perfil.Celular?.Trim();
             perfil.Identificacion = perfil.Identificacion?.Trim();

            if (!string.IsNullOrWhiteSpace(perfil.AvatarUrl) && perfil.AvatarUrl.Contains("avatar_initials_"))
            {
                try
                {
                    var initials = GetInitials();
                    var bgColor = GetBackgroundColorForInitials(initials);
                    var svgContent = $"<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100' width='100' height='100'>" +
                                     $"<rect width='100' height='100' fill='{bgColor}'/>" +
                                     $"<text x='50%' y='55%' font-family='Arial, sans-serif' font-size='40' font-weight='bold' fill='#ffffff' text-anchor='middle' dominant-baseline='middle'>{initials}</text>" +
                                     $"</svg>";

                    var uploadsFolder = Path.Combine(Env.WebRootPath, "images", "Avatars", "uploads");
                    var uniqueName = $"avatar_initials_{usuarioIdActual}_{Guid.NewGuid()}.svg";
                    var newFilePath = Path.Combine(uploadsFolder, uniqueName);

                    await File.WriteAllTextAsync(newFilePath, svgContent, System.Text.Encoding.UTF8);

                    try
                    {
                        var oldPath = Path.Combine(Env.WebRootPath, perfil.AvatarUrl.TrimStart('/'));
                        if (File.Exists(oldPath))
                        {
                            File.Delete(oldPath);
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error al eliminar avatar anterior al regenerar: {ex.Message}");
                    }

                    perfil.AvatarUrl = $"images/Avatars/uploads/{uniqueName}";
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error al regenerar avatar con iniciales tras cambio de nombre: {ex.Message}");
                }
            }

             var exito = await UsuarioService.ActualizarPerfil(usuarioIdActual.Value, perfil); 

            if (exito)
            {
                 var usuarioActualizado = await UsuarioService.ObtenerUsuarioPorId(usuarioIdActual.Value); 
                 if (usuarioActualizado is not null && AuthStateProvider is CustomAuthStateProvider authProvider)
                {
                     await authProvider.UpdateAuthenticationState(usuarioActualizado); 
            }

                 await JS.InvokeVoidAsync("Swal.fire", "¡Éxito!", "Perfil actualizado correctamente.", "success"); 
             cambiarPassword = false; 
        }
            else
            {
                 await JS.InvokeVoidAsync("Swal.fire", "Error", "No se pudo actualizar el perfil.", "error");
            }
            }
            finally
            {
                guardandoPerfil = false;
            }
        }
    }
