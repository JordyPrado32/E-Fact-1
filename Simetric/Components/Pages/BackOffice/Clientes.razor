    private async Task Guardar()
    {
        if (isSaving)
            return;

        isSaving = true;
        errorFormularioUsuario = await ValidarFormularioUsuarioAsync();
        if (!string.IsNullOrWhiteSpace(errorFormularioUsuario))
        {
            isSaving = false;
            return;
        }

        try
        {
            PrepararUsuarioParaGuardar();
            var esNuevoUsuario = tempUser.IdUsuario == 0;
            var claveInicial = esNuevoUsuario ? nuevaClave.Trim() : null;
            var esUsuarioInternoBackOffice = EsVistaUsuariosInternos();

            if (esNuevoUsuario)
            {
                tempUser.PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(claveInicial!);
                tempUser.TokenRecuperacion = Simetric.Components.Helpers.SecurityHelper.HashPassword(claveInicial!);
                tempUser.FechaExpiracionToken = null;
                tempUser.ClaveTemporal = !esUsuarioInternoBackOffice;
            }
            else if (esUsuarioInternoBackOffice && !string.IsNullOrWhiteSpace(nuevaClave))
            {
                tempUser.PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(nuevaClave.Trim());
                tempUser.TokenRecuperacion = null;
                tempUser.FechaExpiracionToken = null;
                tempUser.ClaveTemporal = false;
            }

            await UserService.SaveUsuarioAsync(tempUser);
            await SincronizarPerfilVendedorBackOfficeAsync(tempUser, esNuevoUsuario);

            string? advertenciaCorreo = null;
            if (esNuevoUsuario && !string.IsNullOrWhiteSpace(tempUser.Email) && !string.IsNullOrWhiteSpace(claveInicial))
            {
                try
                {
                    if (esUsuarioInternoBackOffice)
                    {
                        await EmailService.EnviarCredencialesBackOfficeAsync(
                            tempUser.Email,
                            ObtenerNombreCompleto(tempUser),
                            GetRolBackOfficeDisplay(tempUser),
                            NavManager.ToAbsoluteUri("/login").ToString(),
                            tempUser.Email,
                            claveInicial);
                    }
                    else
                    {
                        await EmailService.EnviarCuentaCreadaAsync(tempUser.Email, tempUser.Nombres, claveInicial);
                    }
                }
                catch (Exception ex)
                {
                    advertenciaCorreo = $"El usuario se guardo, pero no se pudo enviar el correo de bienvenida. {ObtenerMensajeError(ex)}";
                }
            }

            await RefrescarSesionActualSiCorrespondeAsync(tempUser.IdUsuario);
            showModal = false;
            errorFormularioUsuario = null;
            await LoadData();
            if (!string.IsNullOrWhiteSpace(advertenciaCorreo))
            {
                await JS.ShowAlertAsync("Usuario creado con advertencia", advertenciaCorreo, "warning");
            }
            else
            {
                await JS.ShowToastAsync(esNuevoUsuario ? "Usuario creado correctamente" : "Usuario actualizado correctamente");
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorFormularioUsuario = $"No se pudo guardar el usuario. {ObtenerMensajeError(ex)}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RefrescarSesionActualSiCorrespondeAsync(int idUsuario)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claimIdUsuario = authState.User.FindFirst("IdUsuario")?.Value;

        if (!int.TryParse(claimIdUsuario, out var idUsuarioActual) || idUsuarioActual != idUsuario)
        {
            return;
        }

        var usuarioActualizado = await UserService.GetUsuarioByIdAsync(idUsuario);
        if (usuarioActualizado is null)
        {
            return;
        }

        var authProvider = (CustomAuthStateProvider)AuthStateProvider;
        await authProvider.UpdateAuthenticationState(usuarioActualizado);
    }

