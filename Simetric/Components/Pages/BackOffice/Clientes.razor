    private async Task ResetearPassword(Usuario u)
    {
        if (!PuedeGestionarUsuario(u))
        {
            await JS.ShowAlertAsync("Accion no permitida", "Los usuarios BackOffice bloqueados o inactivos no admiten mas acciones desde esta pantalla.", "warning");
            return;
        }

        const string passDefault = "00000000";
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Resetear contrasena de {ObtenerNombreCompleto(u)} a '{passDefault}'?");
        if (!confirm)
        {
            return;
        }

        var codigoAcceso = string.Empty;

        try
        {
            const int minutosExpira = RecoveryCodeHelper.MinutosExpiracionPorDefecto;
            codigoAcceso = RecoveryCodeHelper.GenerarCodigoNumerico();

            await using var context = await DbFactory.CreateDbContextAsync();
            var usuarioDb = await context.Usuarios.FindAsync(u.IdUsuario);

            if (usuarioDb == null)
            {
                await JS.ShowAlertAsync("No se pudo completar", "No se encontro el usuario para resetear la contrasena.", "warning");
                return;
            }

            usuarioDb.PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(passDefault);
            usuarioDb.ClaveTemporal = true;
            usuarioDb.CuentaBloqueada = false;
            usuarioDb.IntentosFallidos = 0;
            usuarioDb.FechaDesbloqueo = null;
            usuarioDb.FechaExpiracionToken = DateTime.Now.AddMinutes(minutosExpira);
            usuarioDb.TokenRecuperacion = Simetric.Components.Helpers.SecurityHelper.HashPassword(codigoAcceso);

            await context.SaveChangesAsync();
            await EmailService.EnviarClaveTemporal(usuarioDb.Email, codigoAcceso, minutosExpira, "Reseteo de contrasena por administrador");
            await JS.ShowAlertAsync("Clave restablecida", "El usuario debe ingresar con '00000000' y usar el codigo enviado al correo para cambiarla.", "success");
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync("Clave restablecida con advertencia", $"La clave se cambio a '{passDefault}', pero no se pudo enviar el correo. Codigo de acceso manual: {codigoAcceso}. Error: {ObtenerMensajeError(ex)}", "warning");
        }
        finally
        {
            await LoadData();
        }
    }

    private async Task VerEstadisticas(Usuario u)
    {
        if (!PuedeVerEstadisticas(u))
        {
            await JS.ShowAlertAsync("Accion no permitida", "Esta cuenta BackOffice no tiene estadisticas disponibles desde esta pantalla.", "warning");
            return;
        }

        usuarioStats = u;
        showStatsModal = true;
        
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            usuarioSuscripciones.Clear();
            serviciosList.Clear();
            compraDocumentosHistorial.Clear();
            auditoriasUsuario.Clear();
            totalFacturasEmitidas = 0;
            totalNotasCreditoEmitidas = 0;
            ventasVendedorCount = 0;
            ventasVendedorTotal = 0;
            ultimaVentaVendedor = null;

            if (EsVendedorBackOffice(u))
            {
                var vendedor = await VendedorBackOfficeService.ObtenerPerfilUsuarioAsync(u.IdUsuario, ObtenerNombreCompleto(u));
                var vendedorId = vendedor?.IdVendedor ?? u.IdVendedor;

                if (vendedorId.HasValue)
                {
                    ventasVendedorCount = await context.Facturas.CountAsync(f => f.Idvendedor == vendedorId.Value);
                    ventasVendedorTotal = await context.Facturas
                        .Where(f => f.Idvendedor == vendedorId.Value)
                        .SumAsync(f => f.Valortotal ?? 0m);
                    ultimaVentaVendedor = await context.Facturas
                        .Where(f => f.Idvendedor == vendedorId.Value && f.Fchautorizacion.HasValue)
                        .OrderByDescending(f => f.Fchautorizacion)
                        .Select(f => f.Fchautorizacion)
                        .FirstOrDefaultAsync();
                }

                return;
            }

            if (EsContadorBackOffice(u))
            {
                auditoriasUsuario = await context.Auditorias
                    .AsNoTracking()
                    .Where(a => a.IdUsuario == u.IdUsuario)
                    .OrderByDescending(a => a.Fecha)
                    .Take(25)
                    .ToListAsync();
                return;
            }
            
            // 1. Cargar suscripciones del usuario
            usuarioSuscripciones = await context.UsuarioServicioSuscripciones
                .Where(s => s.IdUsuario == u.IdUsuario)
                .ToListAsync();
                
            // 2. Cargar servicios para obtener nombres
            serviciosList = await context.AppServicios.ToListAsync();
            
            // 3. Deserializar el historial de compras de documentos
            compraDocumentosHistorial = LeerHistorial(u.HistorialComprasDocumentosJson);
            
            // 4. Contar facturas emitidas por el usuario
            totalFacturasEmitidas = await context.Facturas
                .CountAsync(f => f.Idusuario == u.IdUsuario);
                
            // 5. Contar notas de crédito emitidas
            totalNotasCreditoEmitidas = await context.NotaCreditos
                .CountAsync(nc => nc.Usuario == u.IdUsuario);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

