                            </div>
                        </article>
                    </div>
                }
                else if (EsContadorBackOffice(usuarioStats))
                {
                    <div class="stats-kpi-grid">
                        <article class="kpi-card">
                            <div class="kpi-icon kpi-icon-blue">
                                <i class="bi bi-clipboard-data"></i>
                            </div>
                            <div class="kpi-data">
                                <span class="kpi-label">Eventos de auditoria</span>
                                <strong>@auditoriasUsuario.Count</strong>
                                <small>Registros asociados al usuario.</small>
                            </div>
                        </article>
                        <article class="kpi-card">
                            <div class="kpi-icon kpi-icon-success">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <div class="kpi-data">
                                <span class="kpi-label">Ultimo evento</span>
                                <strong>@(auditoriasUsuario.FirstOrDefault()?.Fecha.ToString("dd/MM/yyyy HH:mm") ?? "Sin registros")</strong>
                                <small>Actividad mas reciente.</small>
                            </div>
                        </article>
                        <article class="kpi-card">
                            <div class="kpi-icon kpi-icon-warning">
                                <i class="bi bi-tag"></i>
                            </div>
                            <div class="kpi-data">
                                <span class="kpi-label">Ultima accion</span>
                                <strong>@(auditoriasUsuario.FirstOrDefault()?.Accion ?? "Sin registros")</strong>
                                <small>Accion registrada en auditoria.</small>
                            </div>
                        </article>
                    </div>
                    <div class="stats-section-card">
                        <div class="stats-section-header">
                            <i class="bi bi-journal-text"></i>
                            <h4>Auditoria del usuario</h4>
                        </div>
                        <div class="stats-table-wrap">
                            @if (!auditoriasUsuario.Any())
                            {
                                <div class="stats-empty-state">
                                    <i class="bi bi-info-circle"></i>
                                    <span>Este usuario no registra eventos de auditoria.</span>
                                </div>
                            }
                            else
                            {
                                <table class="table stats-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Accion</th>
                                            <th>Detalle</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in auditoriasUsuario)
                                        {
                                            <tr>
                                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.Accion) ? "Sin accion" : item.Accion)</td>
                                                <td>
                                                    <span class="stats-desc-text" title="@item.Detalles">@item.Detalles</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                }
                else
                {
                <!-- KPI cards grid styled like the premium dashboard -->
                <div class="stats-kpi-grid">
                    <article class="kpi-card">
                        <div class="kpi-icon kpi-icon-blue">
                            <i class="bi bi-file-earmark-bar-graph"></i>
                        </div>
                        <div class="kpi-data">
                            <span class="kpi-label">Saldo de Documentos</span>
                            <strong>@usuarioStats.SaldoDocumentos</strong>
                            <small>Documentos disponibles para emisión</small>
                        </div>
                    </article>

                    <article class="kpi-card">
                        <div class="kpi-icon kpi-icon-success">
                            <i class="bi bi-file-earmark-arrow-up"></i>
                        </div>
                        <div class="kpi-data">
                            <span class="kpi-label">Facturas Emitidas</span>
                            <strong>@totalFacturasEmitidas</strong>
                            <small>Invoices registradas en el sistema</small>
                        </div>
                    </article>

                    <article class="kpi-card">
                        <div class="kpi-icon kpi-icon-warning">
                            <i class="bi bi-file-earmark-minus"></i>
                        </div>
                        <div class="kpi-data">
                            <span class="kpi-label">Notas de Crédito</span>
                            <strong>@totalNotasCreditoEmitidas</strong>
                            <small>Notas de crédito emitidas</small>
                        </div>
                    </article>

                    <article class="kpi-card">
                        <div class="kpi-icon kpi-icon-danger">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <div class="kpi-data">
                            <span class="kpi-label">Suscripciones Activas</span>
                            <strong>@usuarioSuscripciones.Count(s => s.Estado == "ACTIVO")</strong>
                            <small>Servicios con acceso habilitado</small>
                        </div>
                    </article>
                </div>

                <!-- Banner de Estado de Licencias / Servicios -->
                <div class="license-status-banner">
                    @if (usuarioSuscripciones.Any(s => s.Estado == "ACTIVO") || usuarioStats.SaldoDocumentos > 0)
                    {
                        <div class="license-status-badge license-active">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>Estado: Activo</span>
                        </div>
                        <div class="license-summary-text">
                            @if (usuarioStats.SaldoDocumentos > 0)
                            {
                                <span>Posee <strong>@usuarioStats.SaldoDocumentos</strong> documentos para facturar. </span>
                            }
                            @if (usuarioSuscripciones.Any(s => s.Estado == "ACTIVO"))
                            {
                                var activeCount = usuarioSuscripciones.Count(s => s.Estado == "ACTIVO");
                                <span>Tiene <strong>@activeCount</strong> suscripción(es) eRúbrica activa(s).</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="license-status-badge license-inactive">
                            <i class="bi bi-x-circle-fill"></i>
                            <span>Sin Servicios Activos</span>
                        </div>
                        <div class="license-summary-text">
                            El usuario no posee documentos disponibles ni firmas electrónicas activas.
                        </div>
                    }
                </div>

                <!-- Resumen Estadístico Gráfico de Usuario -->
                <div class="user-stats-charts-container">
                    <div class="stats-chart-card">
                        <h5>Consumo de Documentos</h5>
                        <p class="chart-desc">Proporción de documentos emitidos vs saldo disponible</p>
                        @{
                            var totalEmitidos = totalFacturasEmitidas + totalNotasCreditoEmitidas;
                            bool esIlimitado = compraDocumentosHistorial.Any(c => c.EsIlimitado && (c.SaldoAplicado || (c.Estado ?? "").Contains("aprob", StringComparison.OrdinalIgnoreCase) || (c.Estado ?? "").Contains("autoriz", StringComparison.OrdinalIgnoreCase) || (c.Estado ?? "").Contains("complet", StringComparison.OrdinalIgnoreCase) || (c.Estado ?? "").Contains("aplic", StringComparison.OrdinalIgnoreCase)));
                            var totalCapacidad = totalEmitidos + usuarioStats.SaldoDocumentos;
                            double emitidosPct = 0;
                            double saldoPct = 0;
                            if (esIlimitado)
                            {
                                saldoPct = 100;
                            }
                            else
                            {
                                emitidosPct = totalCapacidad > 0 ? (double)totalEmitidos / totalCapacidad * 100 : 0;
                                saldoPct = totalCapacidad > 0 ? (double)usuarioStats.SaldoDocumentos / totalCapacidad * 100 : 0;
                            }
                        }
                        @if (esIlimitado)
                        {
                            <div class="progress-bar-container">
                                <div class="progress-segment user-saldo-bg" style="width: 100%" title="Plan Ilimitado"></div>
                            </div>
                            <div class="chart-legend">
                                <div class="legend-item">
                                    <span class="legend-dot user-emitidos-bg"></span>
                                    <span>Emitidos: <strong>@totalEmitidos</strong></span>
                                </div>
                                <div class="legend-item">
                                    <span class="legend-dot user-saldo-bg"></span>
                                    <span>Disponibles: <strong>Ilimitado</strong></span>
                                </div>
                            </div>
                        }
                        else if (totalCapacidad > 0)
                        {
                            <div class="progress-bar-container">
                                <div class="progress-segment user-emitidos-bg" style="width: @(emitidosPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Emitidos: @totalEmitidos"></div>
                                <div class="progress-segment user-saldo-bg" style="width: @(saldoPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Saldo disponible: @usuarioStats.SaldoDocumentos"></div>
                            </div>
                            <div class="chart-legend">
                                <div class="legend-item">
                                    <span class="legend-dot user-emitidos-bg"></span>
                                    <span>Emitidos: <strong>@totalEmitidos</strong> (@(Math.Round(emitidosPct, 1))%)</span>
                                </div>
                                <div class="legend-item">
                                    <span class="legend-dot user-saldo-bg"></span>
                                    <span>Disponibles: <strong>@usuarioStats.SaldoDocumentos</strong> (@(Math.Round(saldoPct, 1))%)</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="no-activity-badge">Sin documentos registrados</div>
                        }
                    </div>

                    <div class="stats-chart-card">
                        <h5>Volumen de Emisiones</h5>
                        <p class="chart-desc">Facturas vs Notas de Crédito emitidas por el usuario</p>
                        @{
                            var totalEmis = totalFacturasEmitidas + totalNotasCreditoEmitidas;
                            double factPct = totalEmis > 0 ? (double)totalFacturasEmitidas / totalEmis * 100 : 0;
                            double ncPct = totalEmis > 0 ? (double)totalNotasCreditoEmitidas / totalEmis * 100 : 0;
                        }
                        @if (totalEmis > 0)
                        {
                            <div class="progress-bar-container">
                                <div class="progress-segment user-fact-bg" style="width: @(factPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Facturas: @totalFacturasEmitidas"></div>
                                <div class="progress-segment user-nc-bg" style="width: @(ncPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Notas de Crédito: @totalNotasCreditoEmitidas"></div>
                            </div>
                            <div class="chart-legend">
                                <div class="legend-item">
                                    <span class="legend-dot user-fact-bg"></span>
                                    <span>Facturas: <strong>@totalFacturasEmitidas</strong> (@(Math.Round(factPct, 1))%)</span>
                                </div>
                                <div class="legend-item">
                                    <span class="legend-dot user-nc-bg"></span>
                                    <span>Notas de Crédito: <strong>@totalNotasCreditoEmitidas</strong> (@(Math.Round(ncPct, 1))%)</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="no-activity-badge">Sin emisiones registradas</div>
                        }
                    </div>
                </div>

                <div class="stats-detail-grid">
                    <!-- Section 1: Suscripciones (Visual Cards) -->
                    <div class="stats-section-card">
                        <div class="stats-section-header">
                            <i class="bi bi-shield-check"></i>
                            <h4>Detalle de Licencias y Suscripciones</h4>
                        </div>
                        <div class="subscriptions-visual-list">
                            @if (!usuarioSuscripciones.Any())
                            {
                                <div class="stats-empty-state">
                                    <i class="bi bi-info-circle"></i>
                                    <span>Este usuario no posee suscripciones registradas.</span>
                                </div>
                            }
                            else
                            {
                                @foreach (var sub in usuarioSuscripciones)
                                {
                                    var servicio = serviciosList.FirstOrDefault(s => s.ServicioId == sub.ServicioId);
                                    var servName = servicio?.Nombre ?? $"Servicio #{sub.ServicioId}";
                                    var plan = string.IsNullOrWhiteSpace(sub.PlanActual) ? "Básico" : sub.PlanActual;
                                    var ciclo = string.IsNullOrWhiteSpace(sub.CicloActual) ? "Mensual" : sub.CicloActual;
                                    
                                    <div class="subscription-visual-card">
                                        <div class="sub-card-top">
                                            <div class="sub-card-title-group">
                                                @if (!string.IsNullOrWhiteSpace(servicio?.Icono))
                                                {
                                                    <i class="bi @servicio.Icono sub-service-icon" style="color: @(servicio.ColorHex ?? "#0f1c3f")"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-cpu sub-service-icon"></i>
                                                }
                                                <div class="sub-names">
                                                    <h5>@servName</h5>
                                                    <span class="sub-plan-badge">Plan @plan (@ciclo)</span>
                                                </div>
                                            </div>
                                            <div class="sub-status">
                                                <span class="status-badge @(sub.Estado == "ACTIVO" ? "status-badge-active" : "status-badge-pending")">
                                                    @sub.Estado
                                                </span>
                                            </div>
                                        </div>

                                        <div class="sub-card-progress-section">
                                            @if (sub.EsVitalicia)
                                            {
                                                <div class="sub-progress-header">
                                                    <span class="progress-label">Tiempo Restante de Licencia</span>
                                                    <strong class="progress-desc text-success">Acceso Vitalicio</strong>
                                                </div>
                                                <div class="progress-bar-container">
                                                    <div class="progress-segment sub-vitalicio-bg" style="width: 100%"></div>
                                                </div>
                                                <span class="sub-date-range">Vigencia: Sin límite de expiración</span>
                                            }
                                            else
                                            {
                                                var dateInicio = sub.FechaInicio ?? DateTime.Now;
                                                var dateFin = sub.FechaFin ?? DateTime.Now.AddMonths(1);
                                                var totalDays = (dateFin - dateInicio).Days;
                                                var remainingDays = (dateFin - DateTime.Now).Days;
                                                if (totalDays <= 0) totalDays = 30;
                                                
                                                double pctLeft = totalDays > 0 ? (double)remainingDays / totalDays * 100 : 0;
                                                pctLeft = Math.Clamp(pctLeft, 0, 100);
                                                
                                                var progressColorClass = remainingDays <= 7 ? "sub-critical-bg" : 
                                                                         remainingDays <= 30 ? "sub-warning-bg" : 
                                                                         "sub-success-bg";

                                                <div class="sub-progress-header">
                                                    <span class="progress-label">Tiempo Restante de Licencia</span>
                                                    @if (remainingDays > 0)
                                                    {
                                                        <strong class="progress-desc">@remainingDays días restantes</strong>
                                                    }
                                                    else
                                                    {
                                                        <strong class="progress-desc text-danger">Expirada</strong>
                                                    }
                                                </div>
                                                <div class="progress-bar-container">
                                                    <div class="progress-segment @progressColorClass" style="width: @(pctLeft.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                                </div>
                                                <div class="sub-progress-footer">
                                                    <span class="sub-date-range">Vigencia: @(sub.FechaInicio?.ToString("dd/MM/yyyy") ?? "-") al @(sub.FechaFin?.ToString("dd/MM/yyyy") ?? "-")</span>
                                                    <span class="sub-total-days">Ciclo total: @totalDays días</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <!-- Section 2: Historial de compras -->
                    <div class="stats-section-card">
                        <div class="stats-section-header">
                            <i class="bi bi-journal-text"></i>
                            <h4>Historial de Compras de Documentos</h4>
                        </div>
                        <div class="stats-table-wrap">
                            @if (!compraDocumentosHistorial.Any())
                            {
                                <div class="stats-empty-state">
                                    <i class="bi bi-info-circle"></i>
                                    <span>Este usuario no registra historial de compras de documentos.</span>
                                </div>
                            }
                            else
                            {
                                <table class="table stats-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Documentos</th>
                                            <th>Monto</th>
                                            <th>Detalle</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var comp in compraDocumentosHistorial)
                                        {
                                            <tr>
                                                <td>@comp.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    <strong>@comp.Documentos</strong>
                                                    @if (comp.EsIlimitado)
                                                    {
                                                        <span class="badge bg-info ms-1">Ilimitado</span>
                                                    }
                                                </td>
                                                <td>$@comp.MontoTotal.ToString("F2")</td>
                                                <td>
                                                    <span class="stats-desc-text" title="@comp.Descripcion">@comp.Descripcion</span>
                                                </td>
                                                <td>
                                                    <span class="status-badge @(comp.Estado.Contains("aprob", StringComparison.OrdinalIgnoreCase) || comp.Estado.Contains("Aprob", StringComparison.OrdinalIgnoreCase) ? "status-badge-active" : "status-badge-pending")">
                                                        @comp.Estado
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
                }
            </div>


        </div>
    </div>
}

@code {
    [Parameter]
    public string? ClientType { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "action")]
    public string? ActionQuery { get; set; }

    private List<Usuario> usuariosList = new();
    private List<TipoUsuario> rolesList = new();
    private List<string> avatarFiles = new();
    private Usuario tempUser = new();
    private string nuevaClave = string.Empty;

    private bool showModal;
    private bool showAvatarSelector;
    private bool showAvatarManager;
    private bool showDetailModal;
    private bool isLoading = true;
    private bool isSaving;
    private bool mostrarClave;
    private Usuario? usuarioSeleccionado;
    private string? errorFormularioUsuario;

    // Estadísticas
    private bool showStatsModal;
    private Usuario? usuarioStats;
    private List<UsuarioServicioSuscripcion> usuarioSuscripciones = new();
    private List<AppServicio> serviciosList = new();
    private List<CompraDocumentosHistorialItem> compraDocumentosHistorial = new();
    private List<Auditoria> auditoriasUsuario = new();
    private int totalFacturasEmitidas;
    private int totalNotasCreditoEmitidas;
    private int ventasVendedorCount;
    private decimal ventasVendedorTotal;
    private DateTime? ultimaVentaVendedor;

    private List<TipoIdentificacion> tipoIdentificaciones = new();
    private List<Tipocliente> tipoClientesList = new();

    private string _searchString = string.Empty;
    private string searchString
    {
        get => _searchString;
        set
        {
            if (_searchString != value)
            {
                _searchString = value;
                currentPage = 1; // Reset to page 1 on search
            }
        }
    }
    private string activeFilter = "Todos"; // "Todos", "Bloqueados"

    private int currentPage = 1;
    private int pageSize = 5;
    private Dictionary<int, List<UsuarioServicioSuscripcion>> suscripcionesClientePorUsuario = new();
    private Dictionary<int, AppServicio> serviciosCatalogo = new();

    private int UsuariosActivos => usuariosList.Count(u => u.Estado == true && u.CuentaBloqueada != true);
    private int UsuariosBloqueados => usuariosList.Count(u => u.CuentaBloqueada == true || u.Estado == false);

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
        CargarAvatares();

        if (string.Equals(ActionQuery, "create", StringComparison.OrdinalIgnoreCase) && !showModal)
        {
            ActionQuery = null;
            AbrirModal();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            
            bool isInternal = string.Equals(ClientType, "internal", StringComparison.OrdinalIgnoreCase) || string.Equals(ClientType, "backoffice", StringComparison.OrdinalIgnoreCase);
            int targetRole = isInternal ? 7 : 1;

            // Cargar usuarios filtrando por el rol correspondiente
            usuariosList = await context.Usuarios
                .Include(u => u.IdTipoUsuarioNavigation)
                .Include(u => u.IdTipoIdentificacionNavigation)
                .Where(u => isInternal
                    ? u.IdTipoUsuario == 7
                    : u.IdTipoUsuario == targetRole)
                .OrderByDescending(u => u.FechaCreacion)
                .ToListAsync();

            if (!isInternal && usuariosList.Count > 0)
            {
                var usuarioIds = usuariosList.Select(u => u.IdUsuario).ToList();

                var suscripciones = await context.UsuarioServicioSuscripciones
                    .Where(s => usuarioIds.Contains(s.IdUsuario))
                    .ToListAsync();

                suscripcionesClientePorUsuario = suscripciones
                    .GroupBy(s => s.IdUsuario)
                    .ToDictionary(g => g.Key, g => g.OrderBy(s => s.FechaFin ?? DateTime.MaxValue).ToList());

                serviciosCatalogo = await context.AppServicios
                    .AsNoTracking()
                    .ToDictionaryAsync(s => s.ServicioId);
            }
            else
            {
                suscripcionesClientePorUsuario.Clear();
                serviciosCatalogo.Clear();
            }

            // Cargar roles únicamente del tipo objetivo
            var allRoles = await UserService.GetTiposUsuarioAsync();
            rolesList = allRoles.Where(r => r.IdTipoUsuario == targetRole).ToList();

            // Cargar auxiliares
            tipoIdentificaciones = await context.TipoIdentificacion.OrderBy(ti => ti.IdTipoIdentificacion).ToListAsync();
            tipoClientesList = await context.Tipoclientes.OrderBy(tc => tc.TclCodigo).ToListAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<Usuario> GetUsuariosVisibles()
    {
        var query = usuariosList.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchString))
        {
            query = query.Where(u =>
                (u.Nombres ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (u.Apellidos ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (u.Email ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (u.Identificacion ?? "").Contains(searchString, StringComparison.OrdinalIgnoreCase)
            );
        }

        if (activeFilter == "Bloqueados")
        {
            query = query.Where(u => u.CuentaBloqueada == true || u.Estado == false);
        }
        else
        {
            // "Todos" muestra los activos o con bloqueo temporal, omitiendo los dados de baja total
            query = query.Where(u => u.Estado == true || u.CuentaBloqueada == true);
        }

        return query.ToList();
    }

    private string GetEmailDisplay(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return "Sin correo disponible";
        if (email.StartsWith("BAJA-", StringComparison.OrdinalIgnoreCase))
        {
            return "Sin correo disponible";
        }
        if (email.StartsWith("NULL-", StringComparison.OrdinalIgnoreCase))
        {
            return "Sin correo disponible";
        }
        return email;
    }

    private sealed record ClienteNovedad(string Texto, string Clase);

    private IEnumerable<ClienteNovedad> ObtenerNovedadesCliente(Usuario usuario)
    {
        if (EsVistaUsuariosInternos())
        {
            yield break;
        }

        var tieneNovedades = false;
        if (TienePlanIlimitado(usuario))
        {
            yield return new ClienteNovedad("Plan ilimitado", "novedad-pill-ok");
            tieneNovedades = true;
        }
        else
        {
            var saldo = Math.Max(0, usuario.SaldoDocumentos);
            if (saldo <= 2)
            {
                yield return new ClienteNovedad($"{saldo} documentos", "novedad-pill-danger");
                tieneNovedades = true;
            }
            else if (saldo <= 10)
            {
                yield return new ClienteNovedad($"{saldo} documentos", "novedad-pill-warning");
                tieneNovedades = true;
            }
            else
            {
                yield return new ClienteNovedad($"{saldo} documentos", "novedad-pill-ok");
                tieneNovedades = true;
            }
        }

        var novedadFirma = ObtenerNovedadFirma(usuario.IdUsuario);
        if (novedadFirma is not null)
        {
            yield return novedadFirma;
            tieneNovedades = true;
        }

        if (!tieneNovedades)
        {
            yield return new ClienteNovedad("Al día", "novedad-pill-ok");
        }
    }

    private bool TienePlanIlimitado(Usuario usuario)
    {
        return LeerHistorial(usuario.HistorialComprasDocumentosJson).Any(compra =>
            compra.EsIlimitado &&
            (compra.SaldoAplicado ||
             (compra.Estado ?? "").Contains("aprob", StringComparison.OrdinalIgnoreCase) ||
             (compra.Estado ?? "").Contains("autoriz", StringComparison.OrdinalIgnoreCase) ||
             (compra.Estado ?? "").Contains("complet", StringComparison.OrdinalIgnoreCase) ||
             (compra.Estado ?? "").Contains("aplic", StringComparison.OrdinalIgnoreCase)));
    }

    private ClienteNovedad? ObtenerNovedadFirma(int idUsuario)
    {
        if (!suscripcionesClientePorUsuario.TryGetValue(idUsuario, out var suscripciones))
        {
            return null;
        }

        var hoy = DateTime.Today;
        var firmaActiva = suscripciones
            .Where(s => string.Equals(s.Estado, "ACTIVO", StringComparison.OrdinalIgnoreCase) && EsSuscripcionFirma(s))
            .OrderBy(s => s.FechaFin ?? DateTime.MaxValue)
            .FirstOrDefault();

        if (firmaActiva?.FechaFin is null)
        {
            return null;
        }

        var dias = (firmaActiva.FechaFin.Value.Date - hoy).Days;
        if (dias < 0)
        {
            return new ClienteNovedad("Firma vencida", "novedad-pill-danger");
        }

        if (dias <= 30)
        {
            return new ClienteNovedad($"Firma caduca en {dias} días", dias <= 7 ? "novedad-pill-danger" : "novedad-pill-warning");
        }

        return null;
    }

    private bool EsSuscripcionFirma(UsuarioServicioSuscripcion suscripcion)
    {
        if (!serviciosCatalogo.TryGetValue(suscripcion.ServicioId, out var servicio))
        {
            return false;
        }

        var texto = $"{servicio.Clave} {servicio.Nombre} {servicio.Descripcion}".ToLowerInvariant();
        return texto.Contains("firma") ||
               texto.Contains("rubrica") ||
               texto.Contains("rúbrica") ||
               texto.Contains("sign") ||
               texto.Contains("certificado");
    }

