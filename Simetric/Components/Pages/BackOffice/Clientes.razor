@page "/backoffice/clientes"
@page "/backoffice/clientes/{ClientType}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Auth
@using Simetric.Components.Helpers
@using Simetric.Data
@using Simetric.Models
@using Simetric.Services
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using Simetric.DTOs
@using System.Globalization
@inject UserService UserService
@inject IEmailService EmailService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IDbContextFactory<AppDbContext> DbFactory
@inject Simetric.Services.VendedorBackOfficeService VendedorBackOfficeService

@{
    var isInternal = string.Equals(ClientType, "internal", StringComparison.OrdinalIgnoreCase) || string.Equals(ClientType, "backoffice", StringComparison.OrdinalIgnoreCase);
    var usuariosVisibles = GetUsuariosVisibles();
    var totalPages = (int)Math.Ceiling(usuariosVisibles.Count / (double)pageSize);
    if (currentPage > totalPages && totalPages > 0)
    {
        currentPage = totalPages;
    }
    var paginatedUsuarios = usuariosVisibles.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
}

<PageTitle>@(isInternal ? "Usuarios Backoffice" : "Clientes") - BackOffice | Numerica</PageTitle>

<div class="users-shell animate__animated animate__fadeIn">
    <!-- Hero Header -->
    <section class="users-hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Administración de Accesos</span>
            <h2>@(isInternal ? "Usuarios Backoffice" : "Clientes")</h2>
            <p>
                @(isInternal
                    ? "Gestione las cuentas del personal administrativo y operativo de BackOffice, controlando accesos, roles y el estado de seguridad operativa."
                    : "Gestione las cuentas de clientes de la plataforma, controlando accesos, roles y el estado de seguridad operativa.")
            </p>
        </div>

        <div class="hero-actions">
            <button type="button" class="secondary-btn" @onclick="AbrirGestorAvatares">
                <i class="bi bi-images"></i>
                <span>Galería de avatares</span>
            </button>

            <button type="button" class="primary-btn" @onclick="() => AbrirModal()">
                <i class="bi bi-person-plus-fill"></i>
                <span>Nuevo usuario</span>
            </button>
        </div>

        <!-- summary KPIs -->
        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Usuarios registrados</span>
                <strong>@usuariosList.Count</strong>
                <small>Total de perfiles registrados.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Usuarios activos</span>
                <strong>@UsuariosActivos</strong>
                <small>Perfiles con acceso habilitado.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Cuentas bloqueadas</span>
                <strong>@UsuariosBloqueados</strong>
                <small>Cuentas bloqueadas o inactivas.</small>
            </article>
        </div>
    </section>

    <!-- Toolbar Filters -->
    <section class="toolbar-card">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Filtros y Búsqueda</span>
            <h3>Búsqueda rápida</h3>
            <p>Filtre por nombre, correo electrónico o identificación de usuario.</p>
        </div>

        <div class="filter-group">
            <button type="button" class="filter-chip @(activeFilter == "Todos" ? "filter-chip-active" : "")" @onclick='() => SetActiveFilter("Todos")'>Todos</button>
            <button type="button" class="filter-chip @(activeFilter == "Bloqueados" ? "filter-chip-active" : "")" @onclick='() => SetActiveFilter("Bloqueados")'>Bloqueados</button>
        </div>

        <div class="search-box">
            <span class="search-icon">
                <i class="bi bi-search"></i>
            </span>
            <input class="search-input"
                   placeholder="Buscar usuario..."
                   @bind="searchString"
                   @bind:event="oninput" />
        </div>
    </section>

    <!-- Table Directory -->
    <section class="table-card">
        <div class="table-card-head">
            <div>
                <span class="table-kicker">@(isInternal ? "Usuarios Backoffice" : "Directorio de Clientes")</span>
                <h3>@(isInternal ? "Lista de Usuarios Backoffice" : "Lista de Clientes")</h3>
            </div>
            <div class="table-actions-group">
                <span class="table-badge">@usuariosVisibles.Count encontrados</span>
                <a href="/backoffice/clientes/reporte?role=@(isInternal ? 7 : 1)&filter=@activeFilter&search=@(Uri.EscapeDataString(searchString ?? ""))" class="btn-reporte">
                    <i class="bi bi-file-earmark-pdf-fill"></i> Reporte PDF
                </a>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="state-card">
                <div class="state-icon">
                    <i class="bi bi-arrow-repeat"></i>
                </div>
                <h3>Cargando usuarios</h3>
                <p>Preparando la información de acceso, roles y configuración de seguridad.</p>
            </div>
        }
        else if (!usuariosVisibles.Any())
        {
            <div class="state-card state-card-empty">
                <div class="state-icon">
                    <i class="bi bi-people"></i>
                </div>
                <h3>No hay usuarios</h3>
                <p>No se encontraron perfiles con el filtro o término de búsqueda ingresado.</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="table users-table mb-0">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            @if (!isInternal)
                            {
                                <th>Celular</th>
                                <th>Novedades</th>
                            }
                            else
                            {
                                <th>Rol</th>
                            }
                            <th>Seguridad</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in paginatedUsuarios)
                        {
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        @if (TieneAvatar(u.AvatarUrl))
                                        {
                                            <img src="@u.AvatarUrl"
                                                 alt="Avatar de @u.Nombres @u.Apellidos"
                                                 class="user-avatar" />
                                        }
                                        else
                                        {
                                            <span class="user-avatar avatar-default">
                                                <i class="bi bi-person-fill"></i>
                                            </span>
                                        }
                                        <div class="cell-main">
                                            <strong>@u.Nombres @u.Apellidos</strong>
                                            <span>@GetEmailDisplay(u.Email)</span>
                                        </div>
                                    </div>
                                </td>
                                @if (!isInternal)
                                {
                                    <td>
                                        <span>@(string.IsNullOrWhiteSpace(u.Celular) ? "-" : u.Celular)</span>
                                    </td>
                                    <td>
                                        <div class="novedad-stack">
                                            @foreach (var novedad in ObtenerNovedadesCliente(u))
                                            {
                                                <span class="novedad-pill @novedad.Clase">@novedad.Texto</span>
                                            }
                                        </div>
                                    </td>
                                }
                                else
                                {
                                    <td>
                                        <span class="role-pill">@GetRolBackOfficeDisplay(u)</span>
                                    </td>
                                }
                                <td>
                                    <div class="security-stack">
                                        <span class="security-pill @(u.CuentaBloqueada == true || u.Estado == false ? "security-pill-danger" : "security-pill-neutral")">
                                            <i class="bi @(u.CuentaBloqueada == true || u.Estado == false ? "bi-lock-fill" : "bi-unlock-fill")"></i>
                                            @if (isInternal)
                                            {
                                                @(u.CuentaBloqueada == true ? "Bloqueado" : (u.Estado == false ? "Inactivo" : "Sin bloqueo"))
                                            }
                                        </span>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <div class="action-group">
                                        <button type="button"
                                                class="action-btn action-view"
                                                title="Ver detalles"
                                                @onclick="() => VerDetalle(u)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button"
                                                class="action-btn action-edit"
                                                title="Editar usuario"
                                                disabled="@(!PuedeGestionarUsuario(u))"
                                                @onclick="() => AbrirModal(u)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button type="button"
                                                class="action-btn action-reset"
                                                title="Resetear clave"
                                                disabled="@(!PuedeGestionarUsuario(u))"
                                                @onclick="() => ResetearPassword(u)">
                                            <i class="bi bi-shield-lock"></i>
                                        </button>
                                        <button type="button"
                                                class="action-btn action-stats"
                                                title="Estadísticas de uso"
                                                disabled="@(!PuedeVerEstadisticas(u))"
                                                @onclick="() => VerEstadisticas(u)">
                                            <i class="@GetIconoEstadisticas(u)"></i>
                                        </button>
                                        @if (u.Estado == true)
                                        {
                                            <button type="button"
                                                    class="action-btn action-delete"
                                                    title="Dar de baja"
                                                    disabled="@(!PuedeGestionarUsuario(u))"
                                                    @onclick="() => ConfirmarBaja(u.IdUsuario)">
                                                <i class="bi bi-person-x"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            <div class="pagination-wrap">
                <button type="button" 
                        class="pagination-btn" 
                        disabled="@(currentPage == 1)" 
                        @onclick="() => SetPage(currentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                    <span>Anterior</span>
                </button>

                <div class="pagination-pages">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNumber = i;
                        <button type="button" 
                                class="page-number-btn @(currentPage == pageNumber ? "page-number-active" : "")" 
                                @onclick="() => SetPage(pageNumber)">
                            @pageNumber
                        </button>
                    }
                </div>

                <button type="button" 
                        class="pagination-btn" 
                        disabled="@(currentPage == totalPages || totalPages == 0)" 
                        @onclick="() => SetPage(currentPage + 1)">
                    <span>Siguiente</span>
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        }
    </section>
</div>

<!-- Modal: Crear/Editar Usuario -->
@if (showModal)
{
    <div class="users-modal-backdrop"></div>
    <div class="users-modal users-modal-lg" role="dialog" aria-modal="true">
        <div class="users-modal-content">
            <div class="users-modal-header users-modal-header-primary">
                <div>
                    <span class="modal-kicker">Perfil de usuario</span>
                    <h3>@(tempUser.IdUsuario == 0 ? "Nuevo registro de usuario" : "Modificar usuario")</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarModal" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="users-modal-body">
                @if (!string.IsNullOrWhiteSpace(errorFormularioUsuario))
                {
                    <div class="alert alert-danger rounded-3 border-0 shadow-sm mb-3">
                        @errorFormularioUsuario
                    </div>
                }

                <div class="form-layout">
                    <aside class="avatar-panel">
                        <div class="avatar-preview-wrap">
                            @if (TieneAvatar(tempUser.AvatarUrl))
                            {
                                <img src="@tempUser.AvatarUrl"
                                     alt="Avatar del usuario"
                                     class="avatar-preview" />
                            }
                            else
                            {
                                <span class="avatar-preview avatar-default avatar-default-large">
                                    <i class="bi bi-person-fill"></i>
                                </span>
                            }
                            <button type="button" class="avatar-trigger" @onclick="ToggleAvatarSelector">
                                <i class="bi bi-camera"></i>
                            </button>
                        </div>

                        <div class="avatar-copy">
                            <strong>Imagen de perfil</strong>
                            <span>Seleccione un avatar del catálogo disponible.</span>
                        </div>

                        @if (showAvatarSelector)
                        {
                            <div class="avatar-selector">
                                @foreach (var avatar in avatarFiles)
                                {
                                    var avatarUrl = $"images/avatars/{avatar}";
                                    <button type="button"
                                            class="avatar-selector-item @(tempUser.AvatarUrl == avatarUrl ? "avatar-selector-item-selected" : string.Empty)"
                                            @onclick='() => SeleccionarAvatar(avatarUrl)'>
                                        <img src="@avatarUrl" alt="Avatar disponible" />
                                    </button>
                                }
                            </div>
                        }
                    </aside>

                    <div class="form-grid">
                        <div class="form-field">
                            <label class="field-label">Nombres</label>
                            <input @bind="tempUser.Nombres" class="form-control field-input" />
                        </div>

                        <div class="form-field">
                            <label class="field-label">Apellidos</label>
                            <input @bind="tempUser.Apellidos" class="form-control field-input" />
                        </div>

                        <div class="form-field">
                            <label class="field-label">Email corporativo</label>
                            <input @bind="tempUser.Email" type="email" class="form-control field-input" />
                        </div>

                        @if (isInternal)
                        {
                            <div class="form-field">
                                <label class="field-label">Perfil BackOffice</label>
                                <select @bind="tempUser.TipoCliente" class="form-select field-input">
                                    <option value="1">Administrador BackOffice</option>
                                    <option value="2">Vendedor</option>
                                    <option value="3">Cobranzas</option>
                                </select>
                            </div>
                        }

                        @if (!isInternal)
                        {
                            <div class="form-field">
                                <label class="field-label">Fecha de nacimiento</label>
                                <input type="date"
                                       class="form-control field-input"
                                       value="@FormatFechaNacimiento(tempUser.FechaNacimiento)"
                                       @onchange="OnFechaNacimientoChanged" />
                            </div>

                            <div class="form-field">
                                <label class="field-label">Tipo de Identificación</label>
                                <select @bind="tempUser.IdTipoIdentificacion" class="form-select field-input">
                                    <option value="">Seleccione tipo</option>
                                    @foreach (var ti in tipoIdentificaciones)
                                    {
                                        <option value="@ti.IdTipoIdentificacion">@ti.NombreTipo</option>
                                    }
                                </select>
                            </div>

                            <div class="form-field">
                                <label class="field-label">Identificación</label>
                                <input @bind="tempUser.Identificacion" class="form-control field-input" />
                            </div>

                            <div class="form-field">
                                <label class="field-label">Tipo de Cliente</label>
                                <select @bind="tempUser.TipoCliente" class="form-select field-input">
                                    <option value="">Seleccione tipo de cliente</option>
                                    @foreach (var tc in tipoClientesList)
                                    {
                                        <option value="@tc.TclCodigo">@tc.TclDescripcion</option>
                                    }
                                </select>
                            </div>

                            <div class="form-field form-field-wide">
                                <label class="field-label">Dirección</label>
                                <input @bind="tempUser.DireccionEmpresa" class="form-control field-input" placeholder="Dirección del usuario o empresa" />
                            </div>
                        }


                        @if (!isInternal)
                        {
                            @if (tempUser.TipoCliente == 2)
                            {
                                <div class="form-field form-field-wide">
                                    <label class="field-label">Razon social</label>
                                    <input @bind="tempUser.NombreEmpresa" class="form-control field-input" placeholder="Razon social o nombre comercial" />
                                </div>
                            }

                            <div class="form-field">
                                <label class="field-label">Celular</label>
                                <input @bind="tempUser.Celular" class="form-control field-input" maxlength="10" placeholder="0999999999" />
                            </div>

                            <div class="form-note form-field-wide">
                                <i class="bi bi-receipt"></i>
                                <span>Estos datos se utilizaran para la facturacion del usuario.</span>
                            </div>
                        }

                        @if (tempUser.IdUsuario == 0 || isInternal)
                        {
                            <div class="form-field @(isInternal ? "" : "form-field-wide")">
                                <label class="field-label">Contraseña inicial</label>
                                <div class="password-input-container">
                                    <input @bind="nuevaClave"
                                           type="@(mostrarClave ? "text" : "password")"
                                           class="form-control field-input field-input-accent"
                                           placeholder="Mínimo 8 caracteres" />
                                    <button type="button" class="btn-toggle-password" @onclick="ToggleMostrarClave">
                                        <i class="bi @(mostrarClave ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="users-modal-footer">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal">
                    Cancelar
                </button>
                <button type="button" class="primary-btn" disabled="@isSaving" @onclick="Guardar">
                    <i class="bi @(isSaving ? "bi-hourglass-split" : "bi-save")"></i>
                    <span>@(isSaving ? "Guardando..." : "Guardar cambios")</span>
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Detalle de Usuario -->
@if (showDetailModal && usuarioSeleccionado != null)
{
    <div class="users-modal-backdrop"></div>
    <div class="users-modal users-modal-lg" role="dialog" aria-modal="true">
        <div class="users-modal-content">
            <div class="users-modal-header users-modal-header-secondary">
                <div>
                    <span class="modal-kicker">Detalle de usuario</span>
                    <h3>@usuarioSeleccionado.Nombres @usuarioSeleccionado.Apellidos</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarDetalle" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="users-modal-body">
                <div class="detail-layout">
                    <aside class="detail-profile">
                        @if (TieneAvatar(usuarioSeleccionado.AvatarUrl))
                        {
                            <img src="@usuarioSeleccionado.AvatarUrl"
                                 alt="Avatar del usuario"
                                 class="detail-avatar" />
                        }
                        else
                        {
                            <span class="detail-avatar avatar-default avatar-default-large">
                                <i class="bi bi-person-fill"></i>
                            </span>
                        }
                        <h4>@usuarioSeleccionado.Nombres @usuarioSeleccionado.Apellidos</h4>
                        <span class="role-pill">@GetRolBackOfficeDisplay(usuarioSeleccionado)</span>
                        <span class="status-pill @(usuarioSeleccionado.Estado == true ? "status-pill-active" : "status-pill-inactive")">
                            @(usuarioSeleccionado.Estado == true ? "Usuario activo" : "Usuario inactivo")
                        </span>
                    </aside>

                    <div class="detail-sections">
                        <section class="detail-section">
                            <span class="detail-kicker">Contacto e identificación</span>
                            <div class="detail-grid">
                                <article class="detail-item">
                                    <span>Email</span>
                                    <strong>@usuarioSeleccionado.Email</strong>
                                </article>
                                <article class="detail-item">
                                    <span>Fecha de nacimiento</span>
                                    <strong>@FormatFechaNacimientoDetalle(usuarioSeleccionado.FechaNacimiento)</strong>
                                </article>
                                <article class="detail-item">
                                    <span>Identificación</span>
                                    <strong>@(string.IsNullOrWhiteSpace(usuarioSeleccionado.Identificacion) ? "No registrada" : usuarioSeleccionado.Identificacion)</strong>
                                </article>
                            </div>
                        </section>

                        <section class="detail-section">
                            <span class="detail-kicker">Información de Cuenta</span>
                            <div class="detail-grid">
                                <article class="detail-item">
                                    <span>Tipo de Identificación</span>
                                    <strong>@(usuarioSeleccionado.IdTipoIdentificacionNavigation?.NombreTipo ?? "No registrado")</strong>
                                </article>
                                <article class="detail-item">
                                    <span>Tipo de Cliente</span>
                                    <strong>@(GetTipoClienteDescripcion(usuarioSeleccionado.TipoCliente))</strong>
                                </article>
                                <article class="detail-item detail-item-wide">
                                    <span>Dirección</span>
                                    <strong>@(string.IsNullOrWhiteSpace(usuarioSeleccionado.DireccionEmpresa) ? "No registrada" : usuarioSeleccionado.DireccionEmpresa)</strong>
                                </article>
                            </div>
                        </section>

                        <section class="detail-section">
                            <span class="detail-kicker">Seguridad de la cuenta</span>
                            <div class="detail-grid">
                                <article class="detail-item">
                                    <span>Bloqueo</span>
                                    <strong>@(usuarioSeleccionado.CuentaBloqueada == true ? "Cuenta bloqueada" : "Sin bloqueo")</strong>
                                </article>
                                <article class="detail-item">
                                    <span>Estado de clave</span>
                                    <strong>@(usuarioSeleccionado.ClaveTemporal == true ? "Temporal" : "Permanente")</strong>
                                </article>
                            </div>
                        </section>
                    </div>
                </div>
            </div>


        </div>
    </div>
}

<!-- Modal: Gestor de Avatares -->
@if (showAvatarManager)
{
    <div class="users-modal-backdrop"></div>
    <div class="users-modal users-modal-xl" role="dialog" aria-modal="true">
        <div class="users-modal-content">
            <div class="users-modal-header users-modal-header-dark">
                <div>
                    <span class="modal-kicker">Biblioteca visual</span>
                    <h3>Galería de avatares</h3>
                </div>
                <button type="button" class="modal-close" @onclick="() => showAvatarManager = false" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="users-modal-body">
                <label class="upload-dropzone">
                    <span class="upload-icon">
                        <i class="bi bi-cloud-arrow-up"></i>
                    </span>
                    <strong>Subir nuevo avatar</strong>
                    <small>Formatos admitidos: JPG, JPEG y PNG. Tamaño máximo 2 MB.</small>
                    <InputFile OnChange="SubirNuevoAvatar" accept=".jpg,.jpeg,.png" class="d-none" />
                </label>

                <div class="avatar-gallery-grid">
                    @foreach (var avatar in avatarFiles)
                    {
                        var avatarUrl = $"images/avatars/{avatar}";
                        <article class="avatar-gallery-card">
                            @if (!string.Equals(avatar, "default.png", StringComparison.OrdinalIgnoreCase))
                            {
                                <button type="button"
                                        class="avatar-gallery-remove"
                                        @onclick="() => EliminarArchivoAvatar(avatar)"
                                        title="Eliminar avatar"
                                        aria-label="Eliminar avatar">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            }
                            <img src="@avatarUrl" alt="Avatar almacenado" class="avatar-gallery-image" />
                        </article>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Estadísticas de Usuario -->
@if (showStatsModal && usuarioStats != null)
{
    <div class="users-modal-backdrop"></div>
    <div class="users-modal users-modal-xl" role="dialog" aria-modal="true">
        <div class="users-modal-content stats-modal-content">
            <div class="users-modal-header users-modal-header-primary">
                <div>
                    <span class="modal-kicker">Métricas y Consumo</span>
                    <h3>Estadísticas de @usuarioStats.Nombres @usuarioStats.Apellidos</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarEstadisticas" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="users-modal-body stats-modal-body">
                @if (EsVendedorBackOffice(usuarioStats))
                {
                    <div class="stats-kpi-grid">
                        <article class="kpi-card">
                            <div class="kpi-icon kpi-icon-blue">
                                <i class="bi bi-receipt-cutoff"></i>
                            </div>
                            <div class="kpi-data">
                                <span class="kpi-label">Facturas vendidas</span>
                                <strong>@ventasVendedorCount</strong>
                                <small>Facturas asociadas al vendedor.</small>
                            </div>
                        </article>
                        <article class="kpi-card">
                            <div class="kpi-icon kpi-icon-success">
                                <i class="bi bi-cash-coin"></i>
                            </div>
                            <div class="kpi-data">
                                <span class="kpi-label">Monto vendido</span>
                                <strong>$@ventasVendedorTotal.ToString("F2", CultureInfo.InvariantCulture)</strong>
                                <small>Total facturado.</small>
                            </div>
                        </article>
                        <article class="kpi-card">
                            <div class="kpi-icon kpi-icon-warning">
                                <i class="bi bi-calendar-event"></i>
                            </div>
                            <div class="kpi-data">
                                <span class="kpi-label">Ultima venta</span>
                                <strong>@(ultimaVentaVendedor?.ToString("dd/MM/yyyy") ?? "Sin registros")</strong>
