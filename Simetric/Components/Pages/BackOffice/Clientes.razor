    private async Task SincronizarPerfilVendedorBackOfficeAsync(Usuario usuario, bool esNuevoUsuario)
    {
        if (usuario.IdUsuario <= 0)
        {
            return;
        }

        var nombreCompleto = ObtenerNombreCompleto(usuario);
        var esVendedorBackOffice = usuario.IdTipoUsuario == 7 && usuario.TipoCliente == 2;

        await using var context = await DbFactory.CreateDbContextAsync();
        var vendedor = await context.VendedoresBackOffice
            .FirstOrDefaultAsync(v => v.CodigoReferencia == $"usr_{usuario.IdUsuario}");

        if (esVendedorBackOffice)
        {
            var currentAuth = await AuthStateProvider.GetAuthenticationStateAsync();
            var creadorId = int.TryParse(currentAuth.User.FindFirst("IdUsuario")?.Value, out var actorId) ? actorId : 0;

            if (vendedor is null)
            {
                context.VendedoresBackOffice.Add(new VendedorBackOffice
                {
                    Nombre = nombreCompleto,
                    CodigoReferencia = $"usr_{usuario.IdUsuario}",
                    Activo = usuario.Estado == true,
                    EsSistema = false,
                    IdUsuarioCreacion = creadorId > 0 ? creadorId : null,
                    FechaCreacion = DateTime.Now
                });
            }
            else
            {
                vendedor.Nombre = nombreCompleto;
                vendedor.Activo = usuario.Estado == true;
            }
        }
        else if (vendedor is not null)
        {
            vendedor.Activo = false;
        }

        await context.SaveChangesAsync();
    }

    private List<CompraDocumentosHistorialItem> LeerHistorial(string? historialJson)
    {
        if (string.IsNullOrWhiteSpace(historialJson))
        {
            return new List<CompraDocumentosHistorialItem>();
        }

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return (JsonSerializer.Deserialize<List<CompraDocumentosHistorialItem>>(historialJson, options) ?? new List<CompraDocumentosHistorialItem>())
                .OrderByDescending(item => item.Fecha)
                .ToList();
        }
        catch
        {
            return new List<CompraDocumentosHistorialItem>();
        }
    }

