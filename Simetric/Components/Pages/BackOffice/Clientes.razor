            {
                var usuariosConAvatar = await context.Usuarios
                    .Where(u => u.AvatarUrl == avatarUrl)
                    .ToListAsync();

                if (usuariosConAvatar.Any())
                {
                    foreach (var usuario in usuariosConAvatar)
                    {
                        usuario.AvatarUrl = null;
                    }

                    await context.SaveChangesAsync();
                }
            }

            if (string.Equals(tempUser.AvatarUrl, avatarUrl, StringComparison.OrdinalIgnoreCase))
            {
                tempUser.AvatarUrl = null;
            }

            if (usuarioSeleccionado is not null &&
                string.Equals(usuarioSeleccionado.AvatarUrl, avatarUrl, StringComparison.OrdinalIgnoreCase))
            {
                usuarioSeleccionado.AvatarUrl = null;
            }

            CargarAvatares();
            await LoadData();
            await JS.ShowToastAsync("Avatar eliminado");
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync("No se pudo eliminar", ex.Message, "error");
        }
    }

    private async Task<string?> ValidarFormularioUsuarioAsync()
    {
        bool isInternal = string.Equals(ClientType, "internal", StringComparison.OrdinalIgnoreCase) || string.Equals(ClientType, "backoffice", StringComparison.OrdinalIgnoreCase);
        tempUser.IdTipoUsuario = isInternal ? 7 : 1;
        if (isInternal && tempUser.TipoCliente is null or 0)
        {
            tempUser.TipoCliente = 1;
        }

        tempUser.Nombres = (tempUser.Nombres ?? string.Empty).Trim();
        tempUser.Apellidos = (tempUser.Apellidos ?? string.Empty).Trim();
        tempUser.Email = (tempUser.Email ?? string.Empty).Trim();
        tempUser.Identificacion = (tempUser.Identificacion ?? string.Empty).Trim();
        tempUser.DireccionEmpresa = (tempUser.DireccionEmpresa ?? string.Empty).Trim();
        tempUser.NombreEmpresa = (tempUser.NombreEmpresa ?? string.Empty).Trim();
        tempUser.Celular = (tempUser.Celular ?? string.Empty).Trim();
        nuevaClave = (nuevaClave ?? string.Empty).Trim();

        if (!isInternal && tempUser.TipoCliente == 2)
        {
            if (string.IsNullOrWhiteSpace(tempUser.NombreEmpresa) || tempUser.NombreEmpresa.Length < 2)
                return "La razon social es obligatoria y debe tener al menos 2 caracteres.";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(tempUser.Nombres) || tempUser.Nombres.Length < 2)
                return "Los nombres son obligatorios y deben tener al menos 2 caracteres.";

            if (string.IsNullOrWhiteSpace(tempUser.Apellidos) || tempUser.Apellidos.Length < 2)
                return "Los apellidos son obligatorios y deben tener al menos 2 caracteres.";
        }

        if (string.IsNullOrWhiteSpace(tempUser.Email))
            return "El correo corporativo es obligatorio.";

        if (!EsCorreoValido(tempUser.Email))
            return "El correo corporativo no tiene un formato válido.";

        if (await ExisteCorreoRegistradoAsync(tempUser.Email, tempUser.IdUsuario))
            return "Ya existe otro usuario registrado con ese correo.";

        if (!isInternal)
        {
            if (tempUser.FechaNacimiento == null)
                return "La fecha de nacimiento es obligatoria.";

            if (tempUser.IdTipoIdentificacion == null || tempUser.IdTipoIdentificacion == 0)
                return "El tipo de identificación es obligatorio.";

            if (string.IsNullOrWhiteSpace(tempUser.Identificacion))
                return "El número de identificación es obligatorio.";

            if (tempUser.TipoCliente == null || tempUser.TipoCliente == 0)
                return "El tipo de cliente es obligatorio.";

            if (string.IsNullOrWhiteSpace(tempUser.DireccionEmpresa))
                return "La dirección es obligatoria.";
        }

        if (!isInternal && !System.Text.RegularExpressions.Regex.IsMatch(tempUser.Celular, @"^09\d{8}$"))
            return "El celular debe tener 10 digitos y empezar con 09.";

        if (tempUser.IdTipoUsuario is null or 0)
            return "Debes seleccionar un rol para el usuario.";

        if (isInternal && tempUser.TipoCliente != 1 && tempUser.TipoCliente != 2 && tempUser.TipoCliente != 3)
            return "Selecciona un perfil BackOffice valido.";

        if (tempUser.IdTipoUsuario != 1 && tempUser.IdTipoUsuario != 7)
            return "El rol seleccionado no es válido. Solo se admiten roles Usuario y Backoffice.";

        if (!isInternal)
        {
            // Cédula Validation
            var tipoSel = tipoIdentificaciones.FirstOrDefault(t => t.IdTipoIdentificacion == tempUser.IdTipoIdentificacion);
            if (tipoSel != null && (tipoSel.NombreTipo.Contains("cedula", StringComparison.OrdinalIgnoreCase) || 
                                    tipoSel.NombreTipo.Contains("cédula", StringComparison.OrdinalIgnoreCase) ||
                                    tipoSel.Descripcion.Contains("cedula", StringComparison.OrdinalIgnoreCase) ||
                                    tipoSel.Descripcion.Contains("cédula", StringComparison.OrdinalIgnoreCase)))
            {
                if (tempUser.Identificacion.Length != 10)
                {
                    return "La cédula debe tener exactamente 10 dígitos.";
                }
                if (!ValidarCedulaEcuatoriana(tempUser.Identificacion))
                {
                    return "La cédula ingresada no es una cédula ecuatoriana válida.";
                }
            }
            else
            {
                // Standard length fallback validation
                if (!string.IsNullOrWhiteSpace(tempUser.Identificacion) && !EsIdentificacionValida(tempUser.Identificacion))
                    return "La identificación debe tener entre 10 o 13 dígitos numéricos.";
            }
        }

        if (tempUser.IdUsuario == 0)
        {
            if (string.IsNullOrWhiteSpace(nuevaClave))
                return "Debes establecer una contraseña inicial.";

            if (nuevaClave.Length < 8)
                return "La contraseña inicial debe tener al menos 8 caracteres.";
        }
        
        if (tempUser.IdUsuario != 0 && isInternal && !string.IsNullOrWhiteSpace(nuevaClave) && nuevaClave.Length < 8)
            return "La nueva contraseÃ±a debe tener al menos 8 caracteres.";

        return null;
    }

    private void PrepararUsuarioParaGuardar()
    {
        bool isInternal = string.Equals(ClientType, "internal", StringComparison.OrdinalIgnoreCase) || string.Equals(ClientType, "backoffice", StringComparison.OrdinalIgnoreCase);
        tempUser.IdTipoUsuario = isInternal ? 7 : 1;
        tempUser.Estado ??= true;
        tempUser.CuentaBloqueada ??= false;
        tempUser.IntentosFallidos ??= 0;
        tempUser.ClaveTemporal = isInternal ? false : (tempUser.ClaveTemporal ?? tempUser.IdUsuario == 0);

        if (!isInternal)
        {
            if (tempUser.TipoCliente == 2)
            {
                tempUser.Nombres = tempUser.NombreEmpresa!;
                tempUser.Apellidos = string.Empty;
            }
            return;
        }

        tempUser.TipoCliente = tempUser.TipoCliente == 2 ? 2 : tempUser.TipoCliente == 3 ? 3 : 1;

        tempUser.NombreEmpresa = string.IsNullOrWhiteSpace(tempUser.NombreEmpresa)
            ? "Backoffice"
            : tempUser.NombreEmpresa.Trim();
        tempUser.DireccionEmpresa = string.IsNullOrWhiteSpace(tempUser.DireccionEmpresa)
            ? "Backoffice"
            : tempUser.DireccionEmpresa.Trim();
        tempUser.Celular = string.IsNullOrWhiteSpace(tempUser.Celular)
            ? "0999999999"
            : tempUser.Celular.Trim();
        tempUser.Identificacion = string.IsNullOrWhiteSpace(tempUser.Identificacion)
            ? null
            : tempUser.Identificacion.Trim();
        tempUser.IdTipoIdentificacion = null;
        tempUser.FechaNacimiento = null;
    }

    private async Task<bool> ExisteCorreoRegistradoAsync(string email, int idUsuarioActual)
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        var emailNormalizado = (email ?? string.Empty).Trim().ToLower();

        return await context.Usuarios
            .AsNoTracking()
            .AnyAsync(u =>
                u.IdUsuario != idUsuarioActual &&
                u.Email != null &&
                u.Email.Trim().ToLower() == emailNormalizado);
    }

    private static string ObtenerMensajeError(Exception ex)
    {
        var baseException = ex.GetBaseException();
        return string.IsNullOrWhiteSpace(baseException.Message) ? ex.Message : baseException.Message;
    }

    private static bool ValidarCedulaEcuatoriana(string cedula)
    {
        cedula = new string((cedula ?? "").Where(char.IsDigit).ToArray());

        if (cedula.Length != 10)
            return false;

        int[] coeficientes = { 2, 1, 2, 1, 2, 1, 2, 1, 2 };
        var provincia = int.Parse(cedula[..2]);
        var tercerDigito = int.Parse(cedula.Substring(2, 1));

        if (provincia < 1 || provincia > 24 || tercerDigito > 5)
            return false;

        var suma = 0;
        for (var i = 0; i < 9; i++)
        {
            var valor = int.Parse(cedula[i].ToString()) * coeficientes[i];
            suma += valor > 9 ? valor - 9 : valor;
        }

        var digitoRecibido = int.Parse(cedula[9].ToString());
        var digitoCalculado = (10 - (suma % 10)) % 10;
        return digitoCalculado == digitoRecibido;
    }

    private static bool TieneAvatar(string? avatarUrl) =>
        !string.IsNullOrWhiteSpace(avatarUrl) &&
        !avatarUrl.EndsWith("/default.png", StringComparison.OrdinalIgnoreCase) &&
        !avatarUrl.EndsWith("\\default.png", StringComparison.OrdinalIgnoreCase);

    private static string FormatFechaNacimiento(DateTime? fecha) =>
        fecha.HasValue ? fecha.Value.ToString("yyyy-MM-dd") : string.Empty;

    private static string FormatFechaNacimientoDetalle(DateTime? fecha) =>
        fecha.HasValue ? fecha.Value.ToString("dd/MM/yyyy") : "No registrada";

    private static bool EsCorreoValido(string correo)
    {
        try
        {
            _ = new System.Net.Mail.MailAddress(correo);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool EsIdentificacionValida(string identificacion) =>
        identificacion.All(char.IsDigit) && identificacion.Length is 10 or 13;

    private string GetTipoClienteDescripcion(int? tipoCliente)
    {
        if (tipoCliente == null) return "No registrado";
        return tipoClientesList.FirstOrDefault(tc => tc.TclCodigo == tipoCliente.Value)?.TclDescripcion ?? $"Tipo #{tipoCliente.Value}";
    }

