@page "/backoffice/configuracion"
@page "/backoffice/configuracion/usuarios"
@page "/backoffice/configuracion/sistemas"
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.Components
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Configuracion - BackOffice | Numerica</PageTitle>

<div class="bo-config-page animate__animated animate__fadeIn">
    <section class="config-header">
        <div>
            <span class="config-eyebrow">BackOffice</span>
            <h2>Configuracion operativa</h2>
            <p>Administra servicios, precios, equipo interno, canales comerciales y parametros base del negocio.</p>
        </div>
    </section>


    <section class="config-summary-grid">
        <article class="config-summary-card">
            <span>Servicios activos</span>
            <strong>@ServiciosActivos</strong>
            <small>@servicios.Count servicio(s) registrados</small>
        </article>
        <article class="config-summary-card">
            <span>Canales de venta</span>
            <strong>@canalesVenta.Count</strong>
            <small>Consolidado comercial</small>
        </article>
        <article class="config-summary-card">
            <span>Usuarios internos</span>
            <strong>@usuariosInternos.Count</strong>
            <small>Equipo activo en BackOffice</small>
        </article>
        <article class="config-summary-card">
            <span>Vendedores activos</span>
            <strong>@topVendedores.Count</strong>
            <small>Detectados desde ventas registradas</small>
        </article>
    </section>

    <section class="config-content">
        @if (isLoading)
        {
            <div class="config-empty">
                <i class="ri-loader-4-line"></i>
                <strong>Cargando configuracion</strong>
                <span>Un momento...</span>
            </div>
        }
        else if (activeTab == "servicios")
        {
            <div class="config-section-head">
                <div>
                    <h3>Servicios y Planes</h3>
                    <p>Activa, ordena y revisa los módulos disponibles y sus planes comerciales.</p>
                </div>
                <button type="button" class="config-secondary-btn" @onclick="AbrirModalNuevoServicio"><i class="ri-add-line"></i> Nuevo servicio</button>
            </div>

            <div class="config-split-layout">
                <!-- Panel izquierdo: Servicios -->
                <div class="split-left-panel">
                    <div class="config-table-wrap">
                        <table class="config-table">
                            <thead>
                                <tr>
                                    <th>Servicio</th>
                                    <th>Clave</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var servicio in servicios)
                                {
                                    <tr @onclick='() => SeleccionarServicio(servicio.Clave)' class="service-row @(selectedServiceKey == servicio.Clave ? "is-selected" : "")">
                                        <td>
                                            <div class="table-name-cell">
                                                <span class="service-icon" style="background:@(servicio.ColorHex ?? "#111827")"><i class="@(servicio.Icono ?? "ri-apps-2-line")"></i></span>
                                                <div>
                                                    <strong>@GetServicioDisplayName(servicio)</strong>
                                                    <small>@GetServicioDescription(servicio)</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@servicio.Clave</td>
                                        <td><span class="status-chip @(servicio.Estado ? "ok" : "off")">@(servicio.Estado ? "Activo" : "Inactivo")</span></td>
                                        <td>
                                            <div class="service-actions">
                                                <button type="button" class="btn-icon" title="Editar servicio" @onclick:stopPropagation="true" @onclick="() => AbrirModalEditarServicio(servicio)">
                                                    <i class="ri-pencil-line"></i>
                                                </button>
                                                <button type="button" class="btn-icon" title="Cambiar estado" @onclick:stopPropagation="true" @onclick="() => AlternarEstadoServicioAsync(servicio)">
                                                    <i class="@(servicio.Estado ? "ri-toggle-fill" : "ri-toggle-line")"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Panel derecho: Tarifas -->
                <div class="split-right-panel">
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <div>
                                <h4>Planes de @selectedServiceKey</h4>
                                <p>Lista base de planes y tarifas comerciales configuradas.</p>
                            </div>
                            <button type="button" class="config-secondary-btn btn-sm" @onclick="AbrirModalNuevoPrecio">
                                <i class="ri-add-line"></i>
                                Nuevo plan
                            </button>
                        </div>
                        <div class="panel-card-body">
                            @if (!GetPreciosDeServicio().Any())
                            {
                                <div class="prices-empty">
                                    <i class="ri-price-tag-3-line"></i>
                                    <span>No hay planes configurados.</span>
                                </div>
                            }
                            else
                            {
                                <div class="prices-list">
                                    @foreach (var precio in GetPreciosDeServicio())
                                    {
                                        <div class="price-item-card">
                                            <div class="price-item-info">
                                                <span class="price-cycle" style="font-weight: 700;">@precio.Ciclo</span>
                                                @if (!string.IsNullOrWhiteSpace(precio.Incluye))
                                                {
                                                    <span class="price-includes" style="font-size: 0.85rem; color: #64748b; margin-top: 0.25rem;">@precio.Incluye</span>
                                                }
                                                <strong class="price-value" style="margin-top: 0.5rem; display: block;">$ @precio.Valor.ToString("N2")</strong>
                                            </div>
                                            <button type="button" class="btn-icon" @onclick="() => AbrirModalEditarPrecio(precio)" title="Editar plan">
                                                <i class="ri-pencil-line"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        else if (activeTab == "__canales_retirado__")
        {
            <div class="config-section-head animate__animated animate__fadeIn">
                <div>
                    <h3>Canales y Roles</h3>
                    <p>Administre los canales comerciales de venta y consulte los roles asignados a clientes de la plataforma.</p>
                </div>
            </div>

            <div class="config-split-layout equal-split animate__animated animate__fadeIn">
                <!-- Panel izquierdo: Canales de venta -->
                <div class="split-left-panel">
                    <div class="panel-card" style="height: 100%;">
                        <div class="panel-card-header">
                            <div>
                                <h4>Canales de Venta</h4>
                                <p>Orígenes comerciales usados en reportes y ventas.</p>
                            </div>
                            <span class="table-inline-note">Fuente: ventas registradas</span>
                        </div>
                        <div class="config-grid-cards">
                            @foreach (var canal in canalesVenta)
                            {
                                <article class="config-mini-card">
                                    <span class="channel-dot" style="background:@canal.Color; color:@canal.Color;"></span>
                                    <div style="display: flex; flex-direction: column;">
                                        <span class="card-title-strong">@canal.Nombre</span>
                                        <small class="card-desc-small">@canal.Transacciones transacciones</small>
                                    </div>
                                </article>
                            }
                        </div>
                    </div>
                </div>

                <!-- Panel derecho: Roles de usuario -->
                <div class="split-right-panel">
                    <div class="panel-card" style="height: 100%;">
                        <div class="panel-card-header">
                            <div>
                                <h4>Roles de Clientes</h4>
                                <p>Roles permitidos para administración y acceso.</p>
                            </div>
                        </div>
                        <div class="config-grid-cards">
                            @foreach (var rol in rolesClientes)
                            {
                                <article class="config-mini-card column-layout">
                                    <span class="card-meta-label">Rol permitido</span>
                                    <span class="card-title-strong">@rol.NombreTipo</span>
                                    <small class="card-desc-small">@(rol.Descripcion ?? "Disponible para administración de clientes")</small>
                                </article>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Sección vacía -->
        }
    </section>

    @if (showServiceModal)
    {
        <div class="precio-modal-backdrop" @onclick="CerrarServicioModal"></div>
        <div class="precio-modal" role="dialog" aria-modal="true">
            <div class="precio-modal-content animate__animated animate__zoomIn">
                <div class="precio-modal-header">
                    <h3>@(isEditService ? "Editar servicio" : "Nuevo servicio")</h3>
                    <button type="button" class="btn-close" @onclick="CerrarServicioModal" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">
                        <i class="ri-close-line"></i>
                    </button>
                </div>
                <div class="precio-modal-body">
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Clave</label>
                        <input @bind="tempService.Clave" class="form-control field-input" placeholder="Ej. e-fact" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                    </div>
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Nombre</label>
                        <input @bind="tempService.Nombre" class="form-control field-input" placeholder="Nombre comercial" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                    </div>
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Descripcion</label>
                        <textarea @bind="tempService.Descripcion" class="form-control field-input" rows="2" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px; font-family:inherit; resize:vertical;"></textarea>
                    </div>
                    <div class="config-grid-2">
                        <div class="form-field">
                            <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Ruta</label>
                            <input @bind="tempService.RutaAcceso" class="form-control field-input" placeholder="/mi-servicio" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                        </div>
                        <div class="form-field">
                            <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Icono</label>
                            <input @bind="tempService.Icono" class="form-control field-input" placeholder="ri-apps-2-line" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                        </div>
                    </div>
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Color</label>
                        <input @bind="tempService.ColorHex" class="form-control field-input" placeholder="#111827" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                    </div>
                </div>
                <div class="precio-modal-footer" style="padding:1rem 1.5rem; background:#f8fafc; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:0.75rem;">
                    <button type="button" class="config-secondary-btn" @onclick="CerrarServicioModal">Cancelar</button>
                    <button type="button" class="config-primary-btn" @onclick="GuardarServicioAsync">Guardar</button>
                </div>
            </div>
        </div>
    }

    @if (showPrecioModal)
    {
        <div class="precio-modal-backdrop" @onclick="CerrarPrecioModal"></div>
        <div class="precio-modal" role="dialog" aria-modal="true">
            <div class="precio-modal-content animate__animated animate__zoomIn">
                <div class="precio-modal-header">
                    <h3>@(isEditPrecio ? "Modificar Plan" : "Nuevo Plan")</h3>
                    <button type="button" class="btn-close" @onclick="CerrarPrecioModal" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">
                        <i class="ri-close-line"></i>
                    </button>
                </div>
                <div class="precio-modal-body">
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Servicio</label>
                        <input class="form-control field-input" value="@GetServicioDisplayName(tempPrecio.Servicio)" readonly disabled style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px; background:#f3f4f6;" />
                    </div>
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Nombre del Plan / Ciclo</label>
                        <input @bind="tempPrecio.Ciclo" class="form-control field-input" placeholder="Ej. Mensual, Anual, 1 año" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                    </div>
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Qué incluye / Descripción</label>
                        <textarea @bind="tempPrecio.Incluye" class="form-control field-input" placeholder="Ej. Certificado digital y validación de documentos" rows="2" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px; font-family:inherit; resize:vertical;"></textarea>
                    </div>
                    <div class="form-field">
                        <label class="field-label" style="display:block; margin-bottom:0.25rem; font-weight:bold; font-size:0.85rem; color:#4b5563;">Precio / Valor ($)</label>
                        <input type="number" step="0.01" @bind="tempPrecio.Valor" class="form-control field-input" style="width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                    </div>
                </div>
                <div class="precio-modal-footer" style="padding:1rem 1.5rem; background:#f8fafc; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:0.75rem;">
                    <button type="button" class="config-secondary-btn" @onclick="CerrarPrecioModal">Cancelar</button>
                    <button type="button" class="config-primary-btn" @onclick="GuardarPrecio">Guardar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "tab")]
    public string? TabQuery { get; set; }

    private bool isLoading = true;
    private string activeTab = "servicios";
    private List<AppServicio> servicios = new();
    private List<Usuario> usuariosInternos = new();
    private List<TipoUsuario> rolesClientes = new();
    private List<CanalConfigDto> canalesVenta = new();
    private List<VendedorConfigDto> topVendedores = new();

    private int ServiciosActivos => servicios.Count(s => s.Estado);

    private readonly List<ConfigTabDto> tabs =
    [
        new("servicios", "Servicios y Planes", "ri-apps-2-line")
    ];

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(TabQuery))
        {
            activeTab = TabQuery;
            if (activeTab == "paquetes")
            {
                activeTab = "servicios";
            }
            else if (activeTab == "roles" || activeTab == "canales")
            {
                activeTab = "servicios";
            }
        }
    }

    private bool showServiceModal;
    private bool isEditService;
    private AppServicio tempService = new();
    private AppServicio? originalService;

    private void AbrirModalNuevoServicio()
    {
        tempService = new AppServicio
        {
            Estado = true,
            RequiereSuscripcion = true,
            OrdenVisual = servicios.Any() ? servicios.Max(s => s.OrdenVisual) + 1 : 1,
            ColorHex = "#111827",
            Icono = "ri-apps-2-line"
        };
        originalService = null;
        isEditService = false;
        showServiceModal = true;
    }

    private void AbrirModalEditarServicio(AppServicio servicio)
    {
        originalService = servicio;
        tempService = new AppServicio
        {
            ServicioId = servicio.ServicioId,
            Clave = servicio.Clave,
            Nombre = servicio.Nombre,
            Descripcion = servicio.Descripcion,
            RutaAcceso = servicio.RutaAcceso,
            RequiereSuscripcion = servicio.RequiereSuscripcion,
            Estado = servicio.Estado,
            OrdenVisual = servicio.OrdenVisual,
            Icono = servicio.Icono,
            ColorHex = servicio.ColorHex,
            FechaCreacion = servicio.FechaCreacion
        };
        isEditService = true;
        showServiceModal = true;
    }

    private void CerrarServicioModal() => showServiceModal = false;

    private async Task GuardarServicioAsync()
    {
        if (string.IsNullOrWhiteSpace(tempService.Clave) || string.IsNullOrWhiteSpace(tempService.Nombre))
        {
            await JS.ShowToastAsync("La clave y el nombre son obligatorios", "error");
            return;
        }

        await using var context = await DbFactory.CreateDbContextAsync();
        var clave = tempService.Clave.Trim();
        var duplicated = await context.AppServicios.AnyAsync(s => s.Clave == clave && s.ServicioId != tempService.ServicioId);
        if (duplicated)
        {
            await JS.ShowToastAsync("Ya existe un servicio con esa clave", "error");
            return;
        }

        if (isEditService && originalService is not null)
        {
            var dbItem = await context.AppServicios.FirstOrDefaultAsync(s => s.ServicioId == originalService.ServicioId);
            if (dbItem is null)
            {
                await JS.ShowToastAsync("No se encontro el servicio", "error");
                return;
            }

            dbItem.Clave = clave;
            dbItem.Nombre = tempService.Nombre.Trim();
            dbItem.Descripcion = tempService.Descripcion?.Trim();
            dbItem.RutaAcceso = tempService.RutaAcceso?.Trim();
            dbItem.Icono = tempService.Icono?.Trim();
            dbItem.ColorHex = tempService.ColorHex?.Trim();
            dbItem.OrdenVisual = tempService.OrdenVisual;
        }
        else
        {
            context.AppServicios.Add(new AppServicio
            {
                Clave = clave,
                Nombre = tempService.Nombre.Trim(),
                Descripcion = tempService.Descripcion?.Trim(),
                RutaAcceso = tempService.RutaAcceso?.Trim(),
                Icono = tempService.Icono?.Trim(),
                ColorHex = tempService.ColorHex?.Trim(),
                OrdenVisual = tempService.OrdenVisual,
                Estado = true,
                RequiereSuscripcion = true,
                FechaCreacion = DateTime.Now
            });
        }

        await context.SaveChangesAsync();
        showServiceModal = false;
        await CargarConfiguracionAsync();
        await JS.ShowToastAsync(isEditService ? "Servicio actualizado" : "Servicio creado", "success");
    }

    private async Task AlternarEstadoServicioAsync(AppServicio servicio)
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        var dbItem = await context.AppServicios.FirstOrDefaultAsync(s => s.ServicioId == servicio.ServicioId);
        if (dbItem is null)
            return;

        dbItem.Estado = !dbItem.Estado;
        await context.SaveChangesAsync();
        await CargarConfiguracionAsync();
        await JS.ShowToastAsync(dbItem.Estado ? "Servicio activado" : "Servicio desactivado", "success");
    }

    private async Task MostrarMensajeDesarrollo()
    {
        await JS.ShowToastAsync("Módulo en desarrollo", "info");
    }

    private List<PrecioConfigDto> preciosBase = new();

    private string selectedServiceKey = "E-FACT";
    private bool showPrecioModal;
    private bool isEditPrecio;
    private PrecioConfigDto tempPrecio = new();
    private PrecioConfigDto? originalPrecio;

    private List<PrecioConfigDto> GetPreciosDeServicio()
    {
        return preciosBase.Where(p => string.Equals(p.Servicio, selectedServiceKey, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void SeleccionarServicio(string clave)
    {
        selectedServiceKey = clave;
    }

    private void AbrirModalNuevoPrecio()
    {
        tempPrecio = new PrecioConfigDto(selectedServiceKey, "", 0.00m, "");
        isEditPrecio = false;
        showPrecioModal = true;
    }

    private void AbrirModalEditarPrecio(PrecioConfigDto precio)
    {
        originalPrecio = precio;
        tempPrecio = new PrecioConfigDto(precio.Servicio, precio.Ciclo, precio.Valor, precio.Incluye);
        isEditPrecio = true;
        showPrecioModal = true;
    }

    private void CerrarPrecioModal()
    {
        showPrecioModal = false;
    }

    private async Task GuardarPrecio()
    {
        if (string.IsNullOrWhiteSpace(tempPrecio.Ciclo))
        {
            await JS.ShowToastAsync("El ciclo es obligatorio", "error");
            return;
        }
        if (tempPrecio.Valor < 0)
        {
            await JS.ShowToastAsync("El precio no puede ser negativo", "error");
            return;
        }

        if (isEditPrecio && originalPrecio != null)
        {
            originalPrecio.Ciclo = tempPrecio.Ciclo;
            originalPrecio.Valor = tempPrecio.Valor;
            originalPrecio.Incluye = tempPrecio.Incluye;
            await JS.ShowToastAsync("Precio actualizado", "success");
        }
        else
        {
            preciosBase.Add(new PrecioConfigDto(tempPrecio.Servicio, tempPrecio.Ciclo, tempPrecio.Valor, tempPrecio.Incluye));
            await JS.ShowToastAsync("Nuevo precio añadido", "success");
        }

        if (string.Equals(tempPrecio.Servicio, "E-FACT", StringComparison.OrdinalIgnoreCase))
        {
            SincronizarPlanesEFact();
        }

        showPrecioModal = false;
    }

    private void SincronizarPlanesEFact()
    {
        var efactPrecios = preciosBase.Where(p => string.Equals(p.Servicio, "E-FACT", StringComparison.OrdinalIgnoreCase)).ToList();
        var nuevosPlanes = new List<EFactPlanDto>();
        foreach (var p in efactPrecios)
        {
            int cantidad = 0;
            string color = "slate";
            string icono = "bi-file-earmark";
            bool recomendado = false;

            if (p.Ciclo.Contains("25", StringComparison.OrdinalIgnoreCase))
            {
                cantidad = 25;
                color = "blue";
                icono = "bi-cup-hot";
            }
            else if (p.Ciclo.Contains("120", StringComparison.OrdinalIgnoreCase))
            {
                cantidad = 120;
                color = "orange";
                icono = "bi-box2-heart";
                recomendado = true;
            }
            else if (p.Ciclo.Contains("600", StringComparison.OrdinalIgnoreCase))
            {
                cantidad = 600;
                color = "mint";
                icono = "bi-boxes";
            }
            else if (p.Ciclo.Contains("ilimitado", StringComparison.OrdinalIgnoreCase) || p.Ciclo.Contains("ilimitados", StringComparison.OrdinalIgnoreCase))
            {
                cantidad = -1;
                color = "green";
                icono = "bi-stars";
            }

            nuevosPlanes.Add(new EFactPlanDto
            {
                Nombre = p.Ciclo,
                CantidadDocs = cantidad,
                Precio = p.Valor,
                Descripcion = p.Incluye,
                ColorClase = color,
                Icono = icono,
                EsRecomendado = recomendado
            });
        }

        if (nuevosPlanes.Any())
        {
            EFactBillingConfig.EFactPlans = nuevosPlanes;
        }
    }

    private readonly List<ParametroConfigDto> parametrosBase =
    [
        new("Moneda", "USD", "Formato monetario de ventas y reportes"),
        new("IVA vigente", "15%", "Porcentaje usado en comprobantes"),
        new("Canal web unificado", "Web", "Nombre unico para ventas de portal")
    ];

    protected override async Task OnInitializedAsync()
    {
        await CargarConfiguracionAsync();
        CargarPreciosBase();
    }

    private void CargarPreciosBase()
    {
        preciosBase.Clear();
        foreach (var plan in EFactBillingConfig.EFactPlans)
        {
            preciosBase.Add(new PrecioConfigDto("E-FACT", plan.Nombre, plan.Precio, plan.Descripcion));
        }

        preciosBase.Add(new PrecioConfigDto("e-sign", "1 año", 21.91m, "eRúbrica válida por 1 año para facturación y documentos."));
        preciosBase.Add(new PrecioConfigDto("e-sign", "2 años", 34.60m, "eRúbrica válida por 2 años con descuento comercial."));
        preciosBase.Add(new PrecioConfigDto("e-sign", "3 años", 46.14m, "eRúbrica válida por 3 años, óptimo para empresas medianas."));
        preciosBase.Add(new PrecioConfigDto("e-sign", "4 años", 57.68m, "eRúbrica válida por 4 años con el mejor precio anualizado."));
    }

    private async Task CargarConfiguracionAsync()
    {
        isLoading = true;
        await using var context = await DbFactory.CreateDbContextAsync();

        servicios = await context.AppServicios
            .AsNoTracking()
            .OrderBy(s => s.OrdenVisual)
            .ThenBy(s => s.Nombre)
            .ToListAsync();

        usuariosInternos = await context.Usuarios
            .AsNoTracking()
            .Include(u => u.IdTipoUsuarioNavigation)
            .Where(u => u.IdTipoUsuario == 7)
            .OrderBy(u => u.Nombres)
            .ThenBy(u => u.Apellidos)
            .ToListAsync();

        var ventasCanales = await context.ReporteVentasBackOffice
            .AsNoTracking()
            .Where(v => v.Canal != null)
            .GroupBy(v => v.Canal!)
            .Select(g => new { Canal = g.Key, Transacciones = g.Count() })
            .ToListAsync();

        canalesVenta = ventasCanales
            .GroupBy(c => NormalizarCanal(c.Canal))
            .Select(g => new CanalConfigDto(g.Key, g.Sum(x => x.Transacciones), GetCanalColor(g.Key)))
            .OrderBy(c => c.Nombre)
            .ToList();

        var topVendedoresRaw = await context.ReporteVentasBackOffice
            .AsNoTracking()
            .Where(v => !string.IsNullOrWhiteSpace(v.Vendedor) && v.Estado != "anulada")
            .GroupBy(v => new { v.Vendedor, v.Canal })
            .Select(g => new
            {
                Nombre = g.Key.Vendedor!,
                Canal = g.Key.Canal,
                Transacciones = g.Count(),
                Total = g.Sum(x => x.Valor)
            })
            .OrderByDescending(v => v.Total)
            .ThenBy(v => v.Nombre)
            .Take(8)
            .ToListAsync();

        topVendedores = topVendedoresRaw
            .Select(v => new VendedorConfigDto(v.Nombre, NormalizarCanal(v.Canal), v.Transacciones, v.Total))
            .ToList();

        if (!canalesVenta.Any())
        {
            canalesVenta =
            [
                new("Web", 0, GetCanalColor("Web")),
                new("Números Asesores", 0, GetCanalColor("Números Asesores")),
                new("Punto de Venta", 0, GetCanalColor("Punto de Venta")),
                new("API e-Fact", 0, GetCanalColor("API e-Fact"))
            ];
        }


        isLoading = false;
    }

    private static string NormalizarCanal(string? canal)
    {
        var value = canal?.Trim();
        if (string.IsNullOrWhiteSpace(value)) return "Web";
        if (value.Contains("web", StringComparison.OrdinalIgnoreCase) || value.Contains("portal", StringComparison.OrdinalIgnoreCase)) return "Web";
        if (value.Contains("asesor", StringComparison.OrdinalIgnoreCase) || value.Contains("admin", StringComparison.OrdinalIgnoreCase) || value.Contains("backoffice", StringComparison.OrdinalIgnoreCase)) return "Números Asesores";
        if (value.Contains("api", StringComparison.OrdinalIgnoreCase)) return "API e-Fact";
        return value;
    }

    private static string GetCanalColor(string canal)
    {
        if (canal.Contains("Web", StringComparison.OrdinalIgnoreCase)) return "#2563eb";
        if (canal.Contains("Asesores", StringComparison.OrdinalIgnoreCase)) return "#7c3aed";
        if (canal.Contains("API", StringComparison.OrdinalIgnoreCase)) return "#0891b2";
        if (canal.Contains("Punto", StringComparison.OrdinalIgnoreCase)) return "#f97316";
        return "#475569";
    }

    private static string GetServicioDisplayName(AppServicio servicio)
    {
        return GetServicioDisplayName(servicio.Clave, servicio.Nombre);
    }

    private static string GetServicioDisplayName(string? servicio)
    {
        return GetServicioDisplayName(servicio, servicio);
    }

    private static string GetServicioDisplayName(string? clave, string? nombre)
    {
        if (EsServicioRubrica(clave) || EsServicioRubrica(nombre))
            return "eRúbrica";

        return string.IsNullOrWhiteSpace(nombre) ? "Servicio" : nombre.Trim();
    }

    private static string GetServicioDescription(AppServicio servicio)
    {
        if (EsServicioRubrica(servicio.Clave) || EsServicioRubrica(servicio.Nombre))
            return "eRúbrica para firma electronica y certificado digital de documentos en linea.";

        return servicio.Descripcion ?? "Sin descripción";
    }

    private static bool EsServicioRubrica(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return false;

        return value.Contains("e-sign", StringComparison.OrdinalIgnoreCase)
            || value.Contains("esign", StringComparison.OrdinalIgnoreCase)
            || value.Contains("E-SIGN", StringComparison.OrdinalIgnoreCase)
            || value.Contains("firma electronica", StringComparison.OrdinalIgnoreCase)
            || value.Contains("firma electrónica", StringComparison.OrdinalIgnoreCase)
            || value.Contains("eRúbrica", StringComparison.OrdinalIgnoreCase);
    }

    private sealed record VendedorConfigDto(string Nombre, string Canal, int Transacciones, decimal Total);
    private sealed record ConfigTabDto(string Key, string Label, string Icon);
    private class PrecioConfigDto
    {
        public string Servicio { get; set; } = "";
        public string Ciclo { get; set; } = "";
        public decimal Valor { get; set; }
        public string Incluye { get; set; } = "";
        
        public PrecioConfigDto() {}
        public PrecioConfigDto(string servicio, string ciclo, decimal valor, string incluye = "")
        {
            Servicio = servicio;
            Ciclo = ciclo;
            Valor = valor;
            Incluye = incluye;
        }
    }
    private sealed record ParametroConfigDto(string Nombre, string Valor, string Descripcion);
    private sealed record CanalConfigDto(string Nombre, int Transacciones, string Color);
}

