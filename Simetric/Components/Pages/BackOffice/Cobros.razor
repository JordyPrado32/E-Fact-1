    // Activar Licencia Logic
    private async Task ActivarLicenciaUsuario(ReporteVentaBackOffice venta)
    {
        var parts = venta.Cliente.Split('|');
        if (parts.Length < 2) return;
        var email = parts[1].Trim();

        using var context = await DbFactory.CreateDbContextAsync();
        var user = await context.Usuarios.FirstOrDefaultAsync(u => u.Email == email);
        if (user == null) return;

        if (venta.Producto == "e-sign")
        {
            var service = await context.AppServicios.FirstOrDefaultAsync(s => s.Clave.ToLower().Contains("sign"));
            if (service == null) return;

            var sub = await context.UsuarioServicioSuscripciones
                .FirstOrDefaultAsync(s => s.IdUsuario == user.IdUsuario && s.ServicioId == service.ServicioId);

            if (sub == null)
            {
                sub = new UsuarioServicioSuscripcion
                {
                    IdUsuario = user.IdUsuario,
                    ServicioId = service.ServicioId,
                    FechaCreacion = DateTime.Now
                };
                context.UsuarioServicioSuscripciones.Add(sub);
            }

            sub.Estado = "ACTIVO";
            sub.FechaInicio = DateTime.Today;
            sub.PlanActual = venta.PlanPaquete;
            sub.FechaActualizacion = DateTime.Now;

            if (venta.PlanPaquete.Contains("Vitalicio", StringComparison.OrdinalIgnoreCase))
            {
                sub.EsVitalicia = true;
                sub.FechaFin = null;
                sub.CicloActual = "Vitalicio";
            }
            else
            {
                int years = 1;
                var matchYears = System.Text.RegularExpressions.Regex.Match(venta.PlanPaquete, @"\d+");
                if (matchYears.Success)
                {
                    years = int.Parse(matchYears.Value);
                }

                sub.EsVitalicia = false;
                var baseDate = (sub.FechaFin.HasValue && sub.FechaFin.Value > DateTime.Today) ? sub.FechaFin.Value : DateTime.Today;
                sub.FechaFin = baseDate.AddYears(years);
                sub.CicloActual = $"{years} {(years == 1 ? "Año" : "Años")}";
            }

            sub.Observacion = $"Activado automáticamente por cobro Ref #{venta.IdReporte}. Canal: {venta.Canal}. Forma de Pago: {venta.FormaPago}.";
            await context.SaveChangesAsync();
        }
        else if (venta.Producto == "e-fact")
        {
            bool isIlimitado = venta.PlanPaquete.Contains("Ilimitado", StringComparison.OrdinalIgnoreCase);
            int docsCount = 0;

            if (!isIlimitado)
            {
                var match = System.Text.RegularExpressions.Regex.Match(venta.PlanPaquete, @"\d+");
                docsCount = match.Success ? int.Parse(match.Value) : 50;
                user.SaldoDocumentos += docsCount;
            }

            var history = LeerHistorial(user.HistorialComprasDocumentosJson);
            var compraId = ObtenerCompraDocumentosId(venta);
            var itemExistente = string.IsNullOrWhiteSpace(compraId)
                ? null
                : history.FirstOrDefault(item => string.Equals(item.Id, compraId, StringComparison.OrdinalIgnoreCase));

            if (itemExistente is not null)
            {
                itemExistente.Estado = "Aprobado";
                itemExistente.SaldoAplicado = true;
                itemExistente.Reference = $"BO-{venta.IdReporte}";
                itemExistente.AuthorizationCode = GetComprobanteRef(venta.Observacion);
                itemExistente.Descripcion = $"Transferencia aprobada: {venta.PlanPaquete}";
                itemExistente.EsIlimitado = isIlimitado;
                itemExistente.EsPermanente = isIlimitado;
                itemExistente.VigenciaHasta = isIlimitado ? null : itemExistente.VigenciaHasta;
            }
            else
            {
                var newItem = new CompraDocumentosHistorialItem
                {
                    Id = Guid.NewGuid().ToString("N"),
                    Fecha = DateTime.Now,
                    Documentos = docsCount,
                    MontoTotal = venta.Valor,
                    Estado = "Aprobado",
                    Descripcion = $"Venta BackOffice: {venta.PlanPaquete} (Ref #{venta.IdReporte})",
                    SaldoAplicado = true,
                    EsIlimitado = isIlimitado,
                    EsPermanente = true,
                    VigenciaHasta = null,
                    Reference = $"BO-{venta.IdReporte}",
                    AuthorizationCode = GetComprobanteRef(venta.Observacion)
                };
                history.Insert(0, newItem);
            }

            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            user.HistorialComprasDocumentosJson = JsonSerializer.Serialize(history, options);

            if (isIlimitado)
            {
                var service = await context.AppServicios.FirstOrDefaultAsync(s => s.Clave.ToLower().Contains("fact"));
                if (service != null)
                {
                    var sub = await context.UsuarioServicioSuscripciones
                        .FirstOrDefaultAsync(s => s.IdUsuario == user.IdUsuario && s.ServicioId == service.ServicioId);

                    if (sub == null)
                    {
                        sub = new UsuarioServicioSuscripcion
                        {
                            IdUsuario = user.IdUsuario,
                            ServicioId = service.ServicioId,
                            FechaCreacion = DateTime.Now
                        };
                        context.UsuarioServicioSuscripciones.Add(sub);
                    }

                    sub.Estado = "ACTIVO";
                    sub.FechaInicio = DateTime.Today;
                    sub.EsVitalicia = true;
                    sub.FechaFin = null;
                    sub.PlanActual = "Plan Ilimitado";
                    sub.CicloActual = "Vitalicio";
                    sub.FechaActualizacion = DateTime.Now;
                    sub.Observacion = $"Activado automáticamente por plan ilimitado Ref #{venta.IdReporte}. Canal: {venta.Canal}. Forma de Pago: {venta.FormaPago}.";
                }
            }

            context.Entry(user).State = EntityState.Modified;
            await context.SaveChangesAsync();
        }
    }

    private List<CompraDocumentosHistorialItem> LeerHistorial(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<CompraDocumentosHistorialItem>();

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<CompraDocumentosHistorialItem>>(json, options) 
                   ?? new List<CompraDocumentosHistorialItem>();
        }
        catch
        {
            return new List<CompraDocumentosHistorialItem>();
        }
    }

    private async Task<CompraDocumentosFacturaResultado> EmitirFacturaTransferenciaAsync(ReporteVentaBackOffice venta)
    {
        var email = GetClientEmail(venta.Cliente);
        var compraId = ObtenerCompraDocumentosId(venta);
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(compraId))
        {
            return CompraDocumentosFacturaResultado.Error("No se pudo identificar la compra o el usuario.");
        }

        using var context = await DbFactory.CreateDbContextAsync();
        var usuario = await context.Usuarios.FirstOrDefaultAsync(u => u.Email == email);
        if (usuario is null)
        {
            return CompraDocumentosFacturaResultado.Error("No se encontro el usuario titular de la compra.");
        }

        var historial = LeerHistorial(usuario.HistorialComprasDocumentosJson);
        var compra = historial.FirstOrDefault(x => string.Equals(x.Id, compraId, StringComparison.OrdinalIgnoreCase));
        if (compra is null)
        {
            return CompraDocumentosFacturaResultado.Error("No se encontro la compra aprobada en el historial.");
        }

        var saldoYaAplicado = compra.SaldoAplicado;
        var esIlimitado = compra.EsIlimitado || venta.PlanPaquete.Contains("Ilimitado", StringComparison.OrdinalIgnoreCase);
        if (!saldoYaAplicado && !esIlimitado)
        {
            usuario.SaldoDocumentos = Math.Max(0, usuario.SaldoDocumentos) + Math.Max(0, compra.Documentos);
        }

        compra.Estado = "Aprobado";
        compra.SaldoAplicado = true;
        compra.EsIlimitado = esIlimitado;
        compra.EsPermanente = esIlimitado;
        compra.Reference = $"BO-{venta.IdReporte}";
        compra.AuthorizationCode = GetComprobanteRef(venta.Observacion);
        compra.Descripcion = $"Transferencia aprobada: {venta.PlanPaquete}";
        usuario.FechaUltimaRecargaDocumentos = DateTime.Now;

        if (!saldoYaAplicado && esIlimitado)
        {
            var serviceId = await context.AppServicios
                .AsNoTracking()
                .Where(s => s.Clave.ToLower().Contains("fact"))
                .Select(s => (int?)s.ServicioId)
                .FirstOrDefaultAsync();
            if (serviceId.HasValue)
            {
                var subscription = await context.UsuarioServicioSuscripciones
                    .FirstOrDefaultAsync(s => s.IdUsuario == usuario.IdUsuario && s.ServicioId == serviceId.Value);
                if (subscription is null)
                {
                    subscription = new UsuarioServicioSuscripcion
                    {
                        IdUsuario = usuario.IdUsuario,
                        ServicioId = serviceId.Value,
                        FechaCreacion = DateTime.Now
                    };
                    context.UsuarioServicioSuscripciones.Add(subscription);
                }

                subscription.Estado = "ACTIVO";
                subscription.FechaInicio = DateTime.Today;
                subscription.EsVitalicia = true;
                subscription.FechaFin = null;
                subscription.PlanActual = "Plan Ilimitado";
                subscription.CicloActual = "Vitalicio";
                subscription.FechaActualizacion = DateTime.Now;
                subscription.Observacion = $"Activado automaticamente por plan ilimitado Ref #{venta.IdReporte}.";
            }
        }

        var resultado = await CompraDocumentosFacturacionService.EmitirFacturaAsync(
            usuario.IdUsuario,
            compra,
            $"BO-{venta.IdReporte}",
            GetComprobanteRef(venta.Observacion));

        compra.CodFactura = resultado.CodFactura > 0 ? resultado.CodFactura : compra.CodFactura;
        compra.NumeroFactura = !string.IsNullOrWhiteSpace(resultado.NumeroFactura)
            ? resultado.NumeroFactura
            : compra.NumeroFactura;
        compra.FechaFactura ??= resultado.CodFactura > 0 ? DateTime.Now : null;
        compra.FacturaAutorizada = resultado.CodFactura > 0 ? resultado.Autorizada : compra.FacturaAutorizada;
        compra.EstadoFactura = !string.IsNullOrWhiteSpace(resultado.EstadoSri)
            ? resultado.EstadoSri
            : compra.EstadoFactura;
        compra.MensajeFactura = resultado.Mensaje;

        usuario.HistorialComprasDocumentosJson = JsonSerializer.Serialize(
            historial,
            new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        await context.SaveChangesAsync();

        return resultado;
    }

