    // File input handlers
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        selectedFile = e.File;
        if (selectedFile != null)
        {
            if (selectedFile.Size > MaxUploadBytes)
            {
                uploadError = "El archivo supera el límite de 5 MB.";
                selectedFile = null;
                return;
            }
            if (!selectedFile.ContentType.StartsWith("image/"))
            {
                uploadError = "Solo se permiten archivos de imagen.";
                selectedFile = null;
                return;
            }

            try
            {
                selectedFile = await selectedFile.RequestImageFileAsync("image/jpeg", MaxImageWidth, MaxImageHeight);
            }
            catch
            {
            }
        }
    }

    private void RemoveSelectedFile()
    {
        selectedFile = null;
        uploadError = null;
    }

    // Action execution saves
    private async Task SaveCobro()
    {
        if (selectedVenta == null || string.IsNullOrWhiteSpace(comprobanteRef)) return;

        modalError = null;
        modalSuccess = null;
        isSaving = true;
        
        try
        {
            byte[]? fileBytes = null;

            // Handle image upload save if any
            if (selectedFile != null)
            {
                try
                {
                    using var stream = selectedFile.OpenReadStream(maxAllowedSize: MaxUploadBytes);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    fileBytes = ms.ToArray();
                }
                catch (Exception fileEx)
                {
                    modalError = $"Error al leer el archivo: {fileEx.Message}";
                    isSaving = false;
                    return;
                }
            }

            using var context = await DbFactory.CreateDbContextAsync();
            var dbVenta = await context.ReporteVentasBackOffice.FindAsync(selectedVenta.IdReporte);

            if (dbVenta != null && dbVenta.Estado != "pagada")
            {
                // Set payment properties
                dbVenta.Estado = "pagada";
                dbVenta.Fecha = fechaPago;
                dbVenta.FormaPago = TruncateStr(metodoPago, 50);

                if (fileBytes != null)
                {
                    dbVenta.ComprobanteArchivo = fileBytes;
                }

                var cleanObs = string.IsNullOrWhiteSpace(observaciones) ? "" : observaciones.Trim();
                dbVenta.Observacion = TruncateStr($"[Comprobante: {comprobanteRef.Trim()}] {cleanObs}", 500);

                await context.SaveChangesAsync();

                // Call license activation
                await ActivarLicenciaUsuario(dbVenta);

                modalSuccess = "¡Cobro registrado exitosamente! El servicio ha sido aprovisionado.";
                
                // Refresh background lists
                await LoadVentasData();
                
                // Keep modal open briefly to show success, then close
                await Task.Delay(1500);
                CloseCobroModal();
            }
            else
            {
                modalError = "El registro de venta no existe o ya ha sido marcado como pagado.";
                isSaving = false;
            }
        }
        catch (Exception ex)
        {
            modalError = $"Error de base de datos al registrar cobro: {ex.Message}";
            isSaving = false;
        }
    }

    private async Task AprobarSolicitudDocumentosAsync(ReporteVentaBackOffice venta)
    {
        if (!EsSolicitudTransferenciaDocumentos(venta) || isSaving)
        {
            return;
        }

        var cliente = GetClientCleanName(venta.Cliente);
        mensajeConfirmacionAprobacion = $"Se aprobara la recarga de {cliente} por ${venta.Valor:N2}. Esta accion acreditara los documentos y generara la factura automatica.";
        ventaPendienteConfirmacion = venta;
        mostrarConfirmacionAprobacion = true;
        return;
    }

    private async Task ConfirmarYAprobarSolicitudDocumentosAsync()
    {
        if (ventaPendienteConfirmacion is null || isSaving)
        {
            return;
        }

        var venta = ventaPendienteConfirmacion;
        isSaving = true;
        mostrarConfirmacionAprobacion = false;
        aprobandoTransferenciaId = venta.IdReporte;
        facturaAutorizadaPdfUrl = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            var dbVenta = await context.ReporteVentasBackOffice
                .AsNoTracking()
                .FirstOrDefaultAsync(v => v.IdReporte == venta.IdReporte);
            if (dbVenta is null || dbVenta.Estado == "pagada")
            {
                ShowFeedback("La solicitud ya no esta pendiente.", false);
                return;
            }

            var fechaAprobacion = DateTime.Now;
            var observacionOriginal = dbVenta.Observacion;

            CompraDocumentosFacturaResultado resultadoFactura;
            try
            {
                resultadoFactura = await EmitirFacturaTransferenciaAsync(dbVenta);
            }
            catch (Exception ex)
            {
                resultadoFactura = CompraDocumentosFacturaResultado.Error(ex.Message);
            }

            var observacionAprobada = TruncateStr($"Aprobado por BackOffice. {observacionOriginal}", 500);
            context.Database.SetCommandTimeout(10);
            var filasActualizadas = await context.ReporteVentasBackOffice
                .Where(v => v.IdReporte == dbVenta.IdReporte && v.Estado != "pagada")
                .ExecuteUpdateAsync(setters => setters
                    .SetProperty(v => v.Estado, "pagada")
                    .SetProperty(v => v.Fecha, fechaAprobacion)
                    .SetProperty(v => v.FormaPago, "Transferencia Bancaria")
                    .SetProperty(v => v.Observacion, observacionAprobada));
            if (filasActualizadas == 0)
            {
                ShowFeedback("La solicitud ya fue procesada por otro usuario.", false);
                return;
            }

            dbVenta.Estado = "pagada";
            dbVenta.Fecha = fechaAprobacion;
            dbVenta.FormaPago = "Transferencia Bancaria";
            dbVenta.Observacion = observacionAprobada;

            await AuditService.TryRegistrarAuditoriaAsync(
                currentUserId,
                "APROBACION_TRANSFERENCIA_FACTURA_BACKOFFICE",
                new
                {
                    dbVenta.IdReporte,
                    Estado = "pendiente",
                    Observacion = observacionOriginal
                },
                new
                {
                    dbVenta.IdReporte,
                    dbVenta.Estado,
                    dbVenta.Fecha,
                    dbVenta.FormaPago,
                    dbVenta.Observacion,
                    FacturaGenerada = resultadoFactura.Exito,
                    resultadoFactura.CodFactura,
                    resultadoFactura.NumeroFactura,
                    resultadoFactura.Autorizada,
                    resultadoFactura.EstadoSri
                },
                new
                {
                    AprobadoPorUsuario = currentUserId,
                    FechaAprobacion = fechaAprobacion,
                    HoraAprobacion = fechaAprobacion.ToString("HH:mm:ss"),
                    Cliente = GetClientCleanName(dbVenta.Cliente),
                    Email = GetClientEmail(dbVenta.Cliente),
                    dbVenta.Producto,
                    dbVenta.PlanPaquete,
                    dbVenta.Valor,
                    Comprobante = GetComprobanteRef(observacionOriginal),
                    resultadoFactura.Mensaje
                });

            venta.Estado = dbVenta.Estado;
            venta.Fecha = dbVenta.Fecha;
            venta.FormaPago = dbVenta.FormaPago;
            venta.Observacion = dbVenta.Observacion;
            countSolicitudesDocumentosPendientes = Math.Max(0, countSolicitudesDocumentosPendientes - 1);
            countPendientes = Math.Max(0, countPendientes - 1);
            montoPendiente = Math.Max(0, montoPendiente - dbVenta.Valor);

            var cliente = GetClientCleanName(dbVenta.Cliente);
            if (resultadoFactura.Autorizada && resultadoFactura.CodFactura > 0)
            {
                facturaAutorizadaPdfUrl = await FacturacionService.AsegurarPdfFacturaAsync(resultadoFactura.CodFactura);
            }

            ShowFeedback(
                resultadoFactura.Autorizada
