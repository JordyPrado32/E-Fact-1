                        : $"Solicitud aprobada para {cliente}, pero no se pudo guardar o emitir la factura automatica: {resultadoFactura.Mensaje}",
                resultadoFactura.Autorizada);
            await LoadVentasPageAsync();
            _ = LoadVentasKpisAsync();
        }
        catch (Exception ex)
        {
            ShowFeedback($"No se pudo aprobar la solicitud: {ex.Message}", false);
        }
        finally
        {
            ventaPendienteConfirmacion = null;
            mensajeConfirmacionAprobacion = string.Empty;
            aprobandoTransferenciaId = null;
            isSaving = false;
        }
