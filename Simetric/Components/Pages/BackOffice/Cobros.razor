    private async Task CargarUsuarioActualAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var role = auth.User.FindFirst("IdTipoUsuario")?.Value ?? auth.User.FindFirst(ClaimTypes.Role)?.Value;
        var tipoCliente = auth.User.FindFirst("TipoCliente")?.Value;
        var idRaw = auth.User.FindFirst("IdUsuario")?.Value ?? auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        currentUserId = int.TryParse(idRaw, out var id) && id > 0 ? id : null;

        if (currentUserId.HasValue)
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var dbUser = await context.Usuarios.AsNoTracking().FirstOrDefaultAsync(u => u.IdUsuario == currentUserId.Value);
            if (dbUser is not null)
            {
                esAdministradorBackOffice = dbUser.IdTipoUsuario == 7 &&
                                             dbUser.TipoCliente != 2 &&
                                             dbUser.TipoCliente != 3;
                return;
            }
        }

        esAdministradorBackOffice = string.Equals(role, "7", StringComparison.OrdinalIgnoreCase) &&
                                     !string.Equals(tipoCliente, "2", StringComparison.OrdinalIgnoreCase) &&
                                     !string.Equals(tipoCliente, "3", StringComparison.OrdinalIgnoreCase);
    }

    private async Task LoadVentasData()
    {
        await LoadVentasPageAsync();
        _ = LoadVentasKpisAsync();
    }

    private async Task LoadVentasPageAsync()
    {
        if (!firstLoadCompleted)
        {
            isLoading = true;
        }
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var filteredQuery = BuildVentasQuery(context);
            if (currentPage < 1) currentPage = 1;

            var pageRows = await filteredQuery
                .OrderByDescending(v => v.Fecha)
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize + 1)
                .Select(v => new ReporteVentaBackOffice
                {
                    IdReporte = v.IdReporte,
                    Cliente = v.Cliente,
                    Producto = v.Producto,
                    PlanPaquete = v.PlanPaquete,
                    Valor = v.Valor,
                    Fecha = v.Fecha,
                    Canal = v.Canal,
                    Vendedor = v.Vendedor,
                    Estado = v.Estado,
                    FormaPago = v.FormaPago,
                    Observacion = v.Observacion
                })
                .ToListAsync();

            hasMoreVentasPages = pageRows.Count > pageSize;
            paginatedRows = hasMoreVentasPages
                ? pageRows.Take(pageSize).ToList()
                : pageRows;
            filteredRows = paginatedRows.ToList();
            totalFilteredVentasCount = ((currentPage - 1) * pageSize) + paginatedRows.Count + (hasMoreVentasPages ? 1 : 0);
            totalPages = hasMoreVentasPages ? currentPage + 1 : currentPage;

            var currentIds = paginatedRows
                .Select(v => v.IdReporte)
                .ToList();

            ventasConComprobanteArchivo = currentIds.Count == 0
                ? new HashSet<int>()
                : await context.ReporteVentasBackOffice
                    .AsNoTracking()
                    .Where(v => currentIds.Contains(v.IdReporte) && v.ComprobanteArchivo != null)
                    .Select(v => v.IdReporte)
                    .ToHashSetAsync();

            firstLoadCompleted = true;
        }
        catch (Exception ex)
        {
            ShowFeedback($"Error al cargar los datos: {ex.Message}", false);
        }
        finally
        {
            if (!firstLoadCompleted)
            {
                isLoading = false;
            }
        }
    }

    private async Task LoadVentasKpisAsync()
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var now = DateTime.Now;
            var ventasBaseQuery = context.ReporteVentasBackOffice.AsNoTracking();

            montoPendiente = await ventasBaseQuery
                .Where(v => v.Estado == "pendiente")
                .SumAsync(v => (decimal?)v.Valor) ?? 0;

            countPendientes = await ventasBaseQuery
                .CountAsync(v => v.Estado == "pendiente");

            countSolicitudesDocumentosPendientes = await ventasBaseQuery
                .CountAsync(v =>
                    v.Estado == "pendiente" &&
                    v.Producto == "e-fact" &&
                    v.Canal.Contains("Transferencia Web") &&
                    v.Observacion != null &&
                    v.Observacion.Contains("[CompraDocs:"));

            montoCobradoMes = await ventasBaseQuery
                .Where(v => v.Estado == "pagada" && v.Fecha.Month == now.Month && v.Fecha.Year == now.Year)
                .SumAsync(v => (decimal?)v.Valor) ?? 0;

            countCobradoMes = await ventasBaseQuery
                .CountAsync(v => v.Estado == "pagada" && v.Fecha.Month == now.Month && v.Fecha.Year == now.Year);

            countTotalCobrados = await ventasBaseQuery
                .CountAsync(v => v.Estado == "pagada");

            kpisLoaded = true;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            kpisLoaded = false;
        }
    }

    private IQueryable<ReporteVentaBackOffice> BuildVentasQuery(AppDbContext context)
    {
        var query = context.ReporteVentasBackOffice.AsNoTracking().AsQueryable();

        query = activeTab == "pendientes"
            ? query.Where(v => v.Estado == "pendiente")
            : query.Where(v => v.Estado == "pagada");

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var cleanSearch = searchQuery.Trim();
            query = query.Where(v =>
                v.Cliente.Contains(cleanSearch) ||
                v.PlanPaquete.Contains(cleanSearch) ||
                (v.Vendedor != null && v.Vendedor.Contains(cleanSearch)) ||
                (v.Observacion != null && v.Observacion.Contains(cleanSearch)));
        }

        if (filterProducto != "ALL")
        {
            query = query.Where(v => v.Producto == filterProducto);
        }

        if (filterFechaInicio.HasValue)
        {
            var fechaInicio = filterFechaInicio.Value.Date;
            query = query.Where(v => v.Fecha >= fechaInicio);
        }

        if (filterFechaFin.HasValue)
        {
            var fechaFinExclusive = filterFechaFin.Value.Date.AddDays(1);
            query = query.Where(v => v.Fecha < fechaFinExclusive);
        }

        return query;
    }

    private void ApplyFilters()
    {
        if (activeTab == "auditoria")
        {
            var auditQuery = allAuditoriasTransferencias.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var cleanSearch = searchQuery.Trim().ToLowerInvariant();
                auditQuery = auditQuery.Where(a =>
                    a.Contador.ToLowerInvariant().Contains(cleanSearch) ||
                    a.ContadorEmail.ToLowerInvariant().Contains(cleanSearch) ||
                    a.Cliente.ToLowerInvariant().Contains(cleanSearch) ||
                    a.EmailCliente.ToLowerInvariant().Contains(cleanSearch) ||
                    a.Comprobante.ToLowerInvariant().Contains(cleanSearch) ||
                    a.NumeroFactura.ToLowerInvariant().Contains(cleanSearch) ||
                    a.Mensaje.ToLowerInvariant().Contains(cleanSearch));
            }

            if (filterProducto != "ALL")
            {
                auditQuery = auditQuery.Where(a => a.Producto.Equals(filterProducto, StringComparison.OrdinalIgnoreCase));
            }

            if (filterFechaInicio.HasValue)
            {
                auditQuery = auditQuery.Where(a => a.FechaAprobacion.Date >= filterFechaInicio.Value.Date);
            }

            if (filterFechaFin.HasValue)
            {
                auditQuery = auditQuery.Where(a => a.FechaAprobacion.Date <= filterFechaFin.Value.Date);
            }

            filteredAuditRows = auditQuery.ToList();
            totalPages = (int)Math.Ceiling(filteredAuditRows.Count / (double)pageSize);
            if (currentPage < 1) currentPage = 1;
            if (totalPages > 0 && currentPage > totalPages) currentPage = totalPages;
            Paginate();
            return;
        }
    }

    private async Task LoadAuditoriasTransferenciasAsync()
    {
        isLoading = true;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var auditoriasDb = await context.Auditorias
                .AsNoTracking()
                .Where(a => a.Accion == AccionAprobacionTransferencia)
                .OrderByDescending(a => a.Fecha)
                .Select(a => new Auditoria
                {
                    IdAuditoria = a.IdAuditoria,
                    IdUsuario = a.IdUsuario,
                    Fecha = a.Fecha,
                    Accion = a.Accion,
                    ValorNuevo = a.ValorNuevo,
                    Detalles = a.Detalles
                })
                .Take(200)
                .ToListAsync();

            var usuariosIds = auditoriasDb
                .Where(a => a.IdUsuario.HasValue)
                .Select(a => a.IdUsuario!.Value)
                .Distinct()
                .ToList();

            var usuarios = usuariosIds.Count == 0
                ? new Dictionary<int, Usuario>()
                : await context.Usuarios
                    .AsNoTracking()
                    .Where(u => usuariosIds.Contains(u.IdUsuario))
                    .ToDictionaryAsync(u => u.IdUsuario);

            foreach (var auditoria in auditoriasDb)
            {
                if (auditoria.IdUsuario.HasValue && usuarios.TryGetValue(auditoria.IdUsuario.Value, out var usuario))
                {
                    auditoria.Usuario = usuario;
                }
            }

            allAuditoriasTransferencias = auditoriasDb
                .Select(MapAuditoriaTransferencia)
                .ToList();
            countAuditoriasTransferencias = allAuditoriasTransferencias.Count;
            auditoriasCargadas = true;
            ApplyFilters();
        }
        catch (Exception ex)
        {
            ShowFeedback($"Error al cargar auditoria de contadores: {ex.Message}", false);
            allAuditoriasTransferencias = new();
            filteredAuditRows = new();
            paginatedAuditRows = new();
            countAuditoriasTransferencias = 0;
            auditoriasCargadas = true;
            ApplyFilters();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void Paginate()
    {
        if (activeTab == "auditoria")
        {
            paginatedAuditRows = filteredAuditRows
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
        }
    }

    private async Task SetActiveTab(string tab)
    {
        activeTab = tab;
        currentPage = 1;

        if (activeTab == "auditoria" && !esAdministradorBackOffice)
        {
            activeTab = "pendientes";
        }

        if (activeTab == "auditoria" && !auditoriasCargadas)
        {
            await LoadAuditoriasTransferenciasAsync();
            return;
        }

        await LoadVentasData();
    }

    private async Task SetPage(int pageNum)
    {
        if (pageNum < 1)
        {
            return;
        }

        if (activeTab != "auditoria" && pageNum > currentPage && !hasMoreVentasPages)
        {
            return;
        }

        currentPage = pageNum;
        if (activeTab == "auditoria")
        {
            Paginate();
            return;
        }

        await LoadVentasData();
    }

    private async Task OnSearchChanged()
    {
        currentPage = 1;
        if (activeTab == "auditoria")
        {
            ApplyFilters();
            return;
        }

        await LoadVentasData();
    }

    private async Task OnFiltersChanged()
    {
        currentPage = 1;
        if (activeTab == "auditoria")
        {
            ApplyFilters();
            return;
        }

        await LoadVentasData();
    }

    private bool HasActiveFilters()
    {
        return !string.IsNullOrWhiteSpace(searchQuery) ||
               filterProducto != "ALL" ||
               filterFechaInicio.HasValue ||
               filterFechaFin.HasValue;
    }

    private async Task ClearFilters()
    {
        searchQuery = "";
        filterProducto = "ALL";
        filterFechaInicio = null;
        filterFechaFin = null;
        currentPage = 1;

        if (activeTab == "auditoria")
        {
            ApplyFilters();
            return;
        }

        await LoadVentasData();
    }

