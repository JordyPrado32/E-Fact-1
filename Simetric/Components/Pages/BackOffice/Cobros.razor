@page "/backoffice/cobros"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.DTOs
@using Simetric.Services
@using System.Security.Claims
@using System.Text.Json
@using System.IO
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavManager
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject CompraDocumentosFacturacionService CompraDocumentosFacturacionService
@inject FacturacionService FacturacionService
@inject AuthenticationStateProvider AuthStateProvider
@inject AuditService AuditService
@inject IJSRuntime JS

<PageTitle>Cobros y Caja - BackOffice | Numerica</PageTitle>

<div class="cobros-wrapper animate__animated animate__fadeIn">
    @if (aprobandoTransferenciaId is > 0)
    {
        <div class="invoice-emission-overlay" role="status" aria-live="polite">
            <div class="invoice-emission-card">
                <span class="spinner-border text-primary" aria-hidden="true"></span>
                <strong>Aprobando recarga y emitiendo factura</strong>
                <p>Estamos enviando la factura al SRI. No cierres esta pantalla.</p>
            </div>
        </div>
    }
    @if (mostrarConfirmacionAprobacion && ventaPendienteConfirmacion is not null)
    {
        <div class="modal-overlay" @onclick="CancelarConfirmacionAprobacion">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header">
                    <h5>Confirmar aprobacion</h5>
                    <button type="button" class="btn-close" @onclick="CancelarConfirmacionAprobacion"></button>
                </div>
                <div class="modal-body">
                    <p>@mensajeConfirmacionAprobacion</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="CancelarConfirmacionAprobacion" disabled="@isSaving">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmarYAprobarSolicitudDocumentosAsync" disabled="@isSaving">Si, aprobar</button>
                </div>
            </div>
        </div>
    }
    <!-- Header Section -->
    <header class="cobros-header">
        <div class="header-text">
            <h2>Gestión de Cobros y Caja</h2>
            <p>Control operativo de ventas por cobrar, registro de cobros, conciliación de comprobantes y activación de licencias.</p>
        </div>
    </header>

    @if (false && isLoading)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando transacciones...</span>
            </div>
            <p class="mt-3 text-muted fw-bold">Cargando información de cobros...</p>
        </div>
    }
    else
    {
        <!-- Action Feedback Alert Banner -->
        @if (!string.IsNullOrEmpty(feedbackMessage))
        {
            <div class="action-notification-alert @(feedbackIsSuccess ? "success" : "error")">
                <i class="bi @(feedbackIsSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                <span>@feedbackMessage</span>
                @if (!string.IsNullOrWhiteSpace(facturaAutorizadaPdfUrl))
                {
                    <button type="button" class="authorized-pdf-btn" @onclick="AbrirFacturaAutorizadaAsync">
                        <i class="bi bi-file-earmark-pdf"></i> Abrir PDF autorizado
                    </button>
                }
            </div>
        }

        @if (countSolicitudesDocumentosPendientes > 0)
        {
            <div class="action-notification-alert info">
                <i class="bi bi-bell-fill"></i>
                <span>@countSolicitudesDocumentosPendientes usuario(s) solicita(n) aprobacion de transaccion de documentos por transferencia.</span>
            </div>
        }

        <!-- KPI Summary Cards -->
        <section class="kpi-grid">
            <div class="kpi-card is-warning">
                <div class="kpi-card-content">
                    <span class="kpi-title">Pendiente por Cobrar</span>
                    <strong class="kpi-value text-warning">$@montoPendiente.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                    <span class="kpi-desc">@countPendientes transacciones pendientes</span>
                </div>
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
            <div class="kpi-card is-success">
                <div class="kpi-card-content">
                    <span class="kpi-title">Cobrado (Mes Actual)</span>
                    <strong class="kpi-value text-success">$@montoCobradoMes.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                    <span class="kpi-desc">@countCobradoMes cobros en @DateTime.Now.ToString("MMMM", new System.Globalization.CultureInfo("es-ES"))</span>
                </div>
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-cash-coin"></i>
                </div>
            </div>
            <div class="kpi-card is-primary">
                <div class="kpi-card-content">
                    <span class="kpi-title">Cobros Históricos</span>
                    <strong class="kpi-value text-primary">@countTotalCobrados</strong>
                    <span class="kpi-desc">Conciliaciones totales exitosas</span>
                </div>
                <div class="kpi-icon-wrapper">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
        </section>

        <!-- Navigation Tabs -->
        <div class="tabs-container">
            <button type="button" class="tab-btn @(activeTab == "pendientes" ? "active" : "")" @onclick='() => SetActiveTab("pendientes")'>
                Ventas por Cobrar (@countPendientes)
            </button>
            <button type="button" class="tab-btn @(activeTab == "pagados" ? "active" : "")" @onclick='() => SetActiveTab("pagados")'>
                Historial de Pagos Recibidos (@countTotalCobrados)
            </button>
            @if (esAdministradorBackOffice)
            {
                <button type="button" class="tab-btn @(activeTab == "auditoria" ? "active" : "")" @onclick='() => SetActiveTab("auditoria")'>
                    Auditoria contadores (@countAuditoriasTransferencias)
                </button>
            }
        </div>

        <!-- Filters / Search toolbar -->
        <div class="filters-toolbar">
            <div class="filters-grid">
                <div class="filter-input-wrap">
                    <i class="bi bi-search filter-input-icon"></i>
                    <input type="text" class="filter-input" placeholder="Buscar por cliente, plan, comprobante..." @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchChanged" />
                </div>
                <div>
                    <select class="filter-select" @bind="filterProducto" @bind:after="OnFiltersChanged">
                        <option value="ALL">Todos los servicios</option>
                        <option value="e-fact">e-Fact (Documentos)</option>
                        <option value="e-sign">eRúbrica (Firma)</option>
                    </select>
                </div>
                <div class="date-filter-group">
                    <span>Desde:</span>
                    <input type="date" class="filter-date" @bind="filterFechaInicio" @bind:after="OnFiltersChanged" />
                </div>
                <div class="date-filter-group">
                    <span>Hasta:</span>
                    <input type="date" class="filter-date" @bind="filterFechaFin" @bind:after="OnFiltersChanged" />
                </div>
                @if (HasActiveFilters())
                {
                    <button type="button" class="btn-clear-filters" @onclick="ClearFilters">
                        <i class="bi bi-x-lg"></i> Limpiar Filtros
                    </button>
                }
            </div>
        </div>

        <!-- Data Table Container -->
        <div class="table-card">
            <div class="table-card-head">
                @if (activeTab == "auditoria")
                {
                    <h3>Auditoria de Aprobaciones por Transferencia</h3>
                    <p>Registro de contadores que aprobaron transferencias, con fecha, hora, cliente, comprobante y resultado de factura.</p>
                }
                else
                {
                <h3>
                    @(activeTab == "pendientes" ? "Ventas y Solicitudes Pendientes de Conciliación" : "Registro Histórico de Cobros e Ingresos")
                </h3>
                <p>
                    @(activeTab == "pendientes" 
                        ? "Listado de ventas manuales o solicitudes en línea esperando la confirmación de pago y carga de evidencia bancaria." 
                        : "Detalle de cobros acreditados con su respectiva fecha de pago, método de pago, referencia de comprobante e imagen de soporte.")
                </p>
                }
            </div>

            <div class="table-wrap">
                <table class="cobros-table @(activeTab == "pendientes" ? "is-pending" : activeTab == "auditoria" ? "is-audit" : "is-paid")">
                    <thead>
                        @if (activeTab == "pendientes")
                        {
                            <tr>
                                <th>Cliente</th>
                                <th>Servicio</th>
                                <th>Paquete / Plan</th>
                                <th>Valor</th>
                                <th>Fecha Venta</th>
                                <th>Canal</th>
                                <th>Vendedor</th>
                                <th style="text-align: right;">Acciones</th>
                            </tr>
                        }
                        else if (activeTab == "auditoria")
                        {
                            <tr>
                                <th>Contador</th>
                                <th>Fecha / Hora</th>
                                <th>Cliente</th>
                                <th>Servicio</th>
                                <th>Valor</th>
                                <th>Comprobante</th>
                                <th>Factura</th>
                                <th>Resultado</th>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <th>Cliente</th>
                                <th>Servicio</th>
                                <th>Paquete / Plan</th>
                                <th>Monto Cobrado</th>
                                <th>Fecha Pago</th>
                                <th>Método Pago</th>
                                <th>Comprobante</th>
                                <th>Observaciones</th>
                            </tr>
                        }
                    </thead>
                    <tbody>
                        @if (activeTab == "auditoria")
                        {
                            @if (!paginatedAuditRows.Any())
                            {
                                <tr>
                                    <td colspan="8" class="table-empty">
                                        <i class="bi bi-info-circle"></i>
                                        No se encontraron aprobaciones de transferencia con los filtros actuales.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var audit in paginatedAuditRows)
                                {
                                    <tr>
                                        <td>
                                            <div class="client-cell">
                                                <span class="client-name">@audit.Contador</span>
                                                <span class="client-email">@audit.ContadorEmail</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="date-text">@audit.FechaAprobacion.ToString("dd/MM/yyyy HH:mm:ss")</span>
                                        </td>
                                        <td>
                                            <div class="client-cell">
                                                <span class="client-name">@audit.Cliente</span>
                                                <span class="client-email">@audit.EmailCliente</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="product-badge @(audit.Producto == "e-sign" ? "esign" : "efact")">
                                                <i class="bi @(audit.Producto == "e-sign" ? "bi-key-fill" : "bi-file-earmark-check-fill")"></i>
                                                @GetProductoDisplayName(audit.Producto)
                                            </span>
                                            <div class="audit-plan">@GetCleanPlanName(audit.PlanPaquete)</div>
                                        </td>
                                        <td>
                                            <span class="value-bold text-success">$@audit.Valor.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</span>
                                        </td>
                                        <td>
                                            <span class="comprobante-ref">@audit.Comprobante</span>
                                        </td>
                                        <td>
                                            <span class="audit-chip @(audit.FacturaGenerada ? "success" : "warning")">
                                                @(audit.FacturaGenerada ? (string.IsNullOrWhiteSpace(audit.NumeroFactura) ? $"#{audit.CodFactura}" : audit.NumeroFactura) : "No generada")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="date-text observacion-text" title="@audit.Mensaje">@audit.Mensaje</span>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                        else if (!paginatedRows.Any())
                        {
                            <tr>
                                <td colspan="@(activeTab == "pendientes" ? 8 : 8)" class="table-empty">
                                    <i class="bi bi-info-circle"></i>
                                    No se encontraron registros de cobros que coincidan con los filtros.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in paginatedRows)
                            {
                                <tr>
                                    <td>
                                        <div class="client-cell">
                                            <span class="client-name">@GetClientCleanName(row.Cliente)</span>
                                            <span class="client-email">@GetClientEmail(row.Cliente)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="product-badge @(row.Producto == "e-sign" ? "esign" : "efact")">
                                            <i class="bi @(row.Producto == "e-sign" ? "bi-key-fill" : "bi-file-earmark-check-fill")"></i>
                                            @GetProductoDisplayName(row.Producto)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="value-bold">@GetCleanPlanName(row.PlanPaquete)</span>
                                    </td>
                                    <td>
                                        <span class="value-bold @(activeTab == "pendientes" ? "text-warning" : "text-success")">
                                            $@row.Valor.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="date-text">@row.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                                    </td>
                                    @if (activeTab == "pendientes")
                                    {
                                        <td>
                                            <span class="date-text">@row.Canal</span>
                                        </td>
                                        <td>
                                            <span class="date-text">@(string.IsNullOrEmpty(row.Vendedor) ? "Sistema" : row.Vendedor)</span>
                                        </td>
                                        <td>
                                            <div class="actions-cell">
                                                @if (EsSolicitudTransferenciaDocumentos(row))
                                                {
                                                    @if (HasComprobanteImage(row))
                                                    {
                                                        <button type="button" class="btn-action evidence" title="Ver comprobante" @onclick="() => ShowEvidencePreview(row)">
                                                            <i class="bi bi-image"></i> Ver
                                                        </button>
                                                    }
                                                    <button type="button" class="btn-action collect" @onclick="() => AprobarSolicitudDocumentosAsync(row)" disabled="@isSaving">
                                                        <i class="bi bi-check-circle"></i> @(aprobandoTransferenciaId == row.IdReporte ? "Emitiendo..." : "Aprobar")
                                                    </button>
                                                    <button type="button" class="btn-action void" @onclick="() => ConfirmAnularVenta(row)">
                                                        <i class="bi bi-x-circle"></i> Rechazar
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn-action collect" @onclick="() => OpenRegistrarCobroModal(row)">
                                                        <i class="bi bi-wallet2"></i> Cobrar
                                                    </button>
                                                    <button type="button" class="btn-action void" @onclick="() => ConfirmAnularVenta(row)">
                                                        <i class="bi bi-x-circle"></i> Anular
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            <span class="payment-method-badge">@row.FormaPago</span>
                                        </td>
                                        <td>
                                            <div class="comprobante-cell">
                                                <span class="comprobante-ref">@GetComprobanteRef(row.Observacion)</span>
                                                @if (HasComprobanteImage(row))
                                                {
                                                    <button type="button" class="btn-view-evidence" title="Ver captura de comprobante" @onclick="() => ShowEvidencePreview(row)">
                                                        <i class="bi bi-image"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="date-text observacion-text" title="@GetObservacionLimpia(row.Observacion)">@GetObservacionLimpia(row.Observacion)</span>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Grid -->
            @if (totalPages > 1)
            {
                <div class="pager-container">
                    <span class="pager-info">
                        Mostrando del @((currentPage - 1) * pageSize + 1) al @Math.Min(currentPage * pageSize, CurrentFilteredCount) de @CurrentFilteredCount registros
                    </span>
                    <div class="pager-buttons">
                        <button type="button" class="pager-btn" disabled="@(currentPage == 1)" @onclick="() => SetPage(1)">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                        <button type="button" class="pager-btn" disabled="@(currentPage == 1)" @onclick="() => SetPage(currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                        {
                            int pageNum = i;
                            <button type="button" class="pager-btn @(currentPage == pageNum ? "active" : "")" @onclick="() => SetPage(pageNum)">
                                @pageNum
                            </button>
                        }
                        <button type="button" class="pager-btn" disabled="@(currentPage == totalPages)" @onclick="() => SetPage(currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                        <button type="button" class="pager-btn" disabled="@(currentPage == totalPages)" @onclick="() => SetPage(totalPages)">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal: Registrar Cobro -->
@if (showCobroModal && selectedVenta != null)
{
    <div class="modal-overlay">
        <div class="modal-content-container animate__animated animate__zoomIn">
            <header class="modal-header-n">
                <h4>Confirmar Pago y Registrar Cobro</h4>
                <button type="button" class="btn-close-n" @onclick="CloseCobroModal" disabled="@isSaving">&times;</button>
            </header>
            <div class="modal-body-n">
                <!-- Modal Level Notifications -->
                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="action-notification-alert error" style="margin-bottom: 1rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@modalError</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(modalSuccess))
                {
                    <div class="action-notification-alert success" style="margin-bottom: 1rem;">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@modalSuccess</span>
                    </div>
                }

                <!-- Summary of sale -->
                <div class="modal-detail-banner">
                    <div class="banner-item">
                        <label>Cliente</label>
                        <span>@GetClientCleanName(selectedVenta.Cliente)</span>
                    </div>
                    <div class="banner-item">
                        <label>Total a Cobrar</label>
                        <span class="price">$@selectedVenta.Valor.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</span>
                    </div>
                    <div class="banner-item">
                        <label>Servicio</label>
                        <span>@selectedVenta.Producto.ToUpper()</span>
                    </div>
                    <div class="banner-item">
                        <label>Plan / Paquete</label>
                        <span>@GetCleanPlanName(selectedVenta.PlanPaquete)</span>
                    </div>
                </div>

                <!-- Date of payment -->
                <div class="form-group-n">
                    <label>Fecha de Pago *</label>
                    <input type="date" class="input-n-premium" @bind="fechaPago" disabled="@isSaving" />
                </div>

                <!-- Method of payment -->
                <div class="form-group-n">
                    <label>Método de Pago *</label>
                    <select class="input-n-premium" @bind="metodoPago" disabled="@isSaving">
                        <option value="Transferencia">Transferencia Bancaria</option>
                        <option value="Depósito Bancario">Depósito Bancario</option>
                        <option value="Tarjeta de Crédito">Tarjeta de Crédito</option>
                        <option value="Efectivo">Efectivo</option>
                        <option value="Otros">Otros</option>
                    </select>
                </div>

                <!-- Voucher reference -->
                <div class="form-group-n">
                    <label>Comprobante / Referencia *</label>
                    <input type="text" class="input-n-premium" placeholder="Ej. N° de transferencia o depósito" @bind="comprobanteRef" disabled="@isSaving" />
                </div>

                <!-- Image evidence upload -->
                <div class="form-group-n">
                    <label>Captura del Comprobante (Opcional)</label>
                    <label for="evidence-upload" class="upload-zone" style='display: @(selectedFile == null ? "flex" : "none");'>
                        <i class="bi bi-cloud-arrow-up-fill"></i>
                        <span class="upload-text">Haz clic aquí para cargar captura de pago</span>
                        <span class="upload-sub">Formatos permitidos: JPG, PNG (máx. 5MB)</span>
                    </label>
                    <InputFile OnChange="HandleFileSelected" id="evidence-upload" style="display: none;" accept="image/*" />

                    @if (selectedFile != null)
                    {
                        <div class="file-preview-banner">
                            <div class="file-preview-info">
                                <i class="bi bi-file-earmark-image-fill"></i>
                                <span>@selectedFile.Name (@(Math.Round(selectedFile.Size / 1024.0, 1)) KB)</span>
                            </div>
                            <button type="button" class="btn-remove-file" title="Eliminar archivo" @onclick="RemoveSelectedFile" disabled="@isSaving">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(uploadError))
                    {
                        <span class="text-danger font-sm fw-bold mt-1">@uploadError</span>
                    }
                </div>

                <!-- Additional comments -->
                <div class="form-group-n">
                    <label>Observaciones Adicionales</label>
                    <textarea class="input-n-premium" rows="3" placeholder="Detalles de conciliación, banco, etc." @bind="observaciones" disabled="@isSaving"></textarea>
                </div>
            </div>
            <footer class="modal-footer-n">
                <button type="button" class="btn-cancel-n" @onclick="CloseCobroModal" disabled="@isSaving">Cancelar</button>
                <button type="button" class="btn-save-n" @onclick="SaveCobro" disabled="@(isSaving || string.IsNullOrWhiteSpace(comprobanteRef))">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true" style="width: 1rem; height: 1rem;"></span>
                        <span>Procesando...</span>
                    }
                    else
                    {
                        <span>Confirmar Cobro</span>
                    }
                </button>
            </footer>
        </div>
    </div>
}

<!-- Modal: Vista Previa Comprobante -->
@if (!string.IsNullOrEmpty(previewImageUrl))
{
    <div class="modal-overlay" @onclick="CloseEvidencePreview">
        <div class="modal-content-container large animate__animated animate__zoomIn" @onclick:stopPropagation>
            <header class="modal-header-n">
                <h4>Evidencia de Comprobante de Pago</h4>
                <button type="button" class="btn-close-n" @onclick="CloseEvidencePreview">&times;</button>
            </header>
            <div class="modal-body-n">
                <div class="preview-image-wrap">
                    <img src="@previewImageUrl" class="preview-img-tag" alt="Comprobante de cobro" />
                </div>
            </div>
            <footer class="modal-footer-n">
                <a href="@previewImageUrl" target="_blank" class="btn-save-n text-decoration-none" style="display: inline-flex; align-items: center; gap: 0.5rem;">
                    <i class="bi bi-box-arrow-up-right"></i> Abrir en pestaña nueva
                </a>
                <button type="button" class="btn-cancel-n" @onclick="CloseEvidencePreview">Cerrar</button>
            </footer>
        </div>
    </div>
}

<!-- Modal: Confirmar Anulación -->
@if (showAnularModal && selectedVenta != null)
{
    <div class="modal-overlay">
        <div class="modal-content-container animate__animated animate__zoomIn">
            <header class="modal-header-n" style="background: #9f1239;">
                <h4>@(EsSolicitudTransferenciaDocumentos(selectedVenta) ? "Rechazar Transaccion" : "Anular Transaccion")</h4>
                <button type="button" class="btn-close-n" @onclick="CloseAnularModal">&times;</button>
            </header>
            <div class="modal-body-n">
                <p class="text-slate-700">@(EsSolicitudTransferenciaDocumentos(selectedVenta) ? "Esta seguro de rechazar esta solicitud de compra de documentos?" : "Esta seguro de que desea anular esta venta registrada?")</p>
                <div class="modal-detail-banner" style="background-color: #fff1f2; border-color: #fecdd3;">
                    <div class="banner-item">
                        <label>Cliente</label>
                        <span>@GetClientCleanName(selectedVenta.Cliente)</span>
                    </div>
                    <div class="banner-item">
                        <label>Monto</label>
                        <span class="price" style="color: #be123c;">$@selectedVenta.Valor.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</span>
                    </div>
                    <div class="banner-item">
                        <label>Servicio</label>
                        <span>@selectedVenta.Producto.ToUpper()</span>
                    </div>
                    <div class="banner-item">
                        <label>Plan / Paquete</label>
                        <span>@GetCleanPlanName(selectedVenta.PlanPaquete)</span>
                    </div>
                </div>
                <p class="text-danger small fw-bold">@(EsSolicitudTransferenciaDocumentos(selectedVenta) ? "Esta accion notificara el rechazo en el historial del usuario y no acreditara documentos." : "Esta accion marcara el estado de la venta como anulada y no aprovisionara ningun servicio.")</p>
            </div>
            <footer class="modal-footer-n">
                <button type="button" class="btn-cancel-n" @onclick="CloseAnularModal">Cancelar</button>
                <button type="button" class="btn-save-n" style="background: linear-gradient(135deg, #e11d48, #be123c); box-shadow: 0 2px 4px rgba(225, 29, 72, 0.2);" @onclick="SaveAnulacion">
                    @(EsSolicitudTransferenciaDocumentos(selectedVenta) ? "Confirmar Rechazo" : "Confirmar Anulacion")
                </button>
            </footer>
        </div>
    </div>
}

