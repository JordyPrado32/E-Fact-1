    private string GetCleanPlanName(string planName)
    {
        if (string.IsNullOrEmpty(planName)) return string.Empty;
        return planName.Replace("Venta BackOffice: ", "").Split('(')[0].Trim();
    }

    private string GetProductoDisplayName(string? producto)
    {
        return string.Equals(producto, "e-sign", StringComparison.OrdinalIgnoreCase)
            ? "eRúbrica"
            : producto ?? string.Empty;
    }

    private string GetComprobanteRef(string? obs)
    {
        if (string.IsNullOrEmpty(obs)) return "S/N";
        if (obs.StartsWith("[Comprobante:"))
        {
            var endIdx = obs.IndexOf(']');
            if (endIdx > 13)
            {
                return obs.Substring(13, endIdx - 13).Trim();
            }
        }

        const string comprobanteTransferencia = "N. comprobante:";
        var comprobanteIdx = obs.IndexOf(comprobanteTransferencia, StringComparison.OrdinalIgnoreCase);
        if (comprobanteIdx >= 0)
        {
            var valueStart = comprobanteIdx + comprobanteTransferencia.Length;
            var endIdx = obs.IndexOf('.', valueStart);
            var value = endIdx > valueStart
                ? obs.Substring(valueStart, endIdx - valueStart)
                : obs.Substring(valueStart);

            value = value.Trim();
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "S/N";
    }

    private bool HasComprobanteImage(ReporteVentaBackOffice row)
    {
        if (ventasConComprobanteArchivo.Contains(row.IdReporte)) return true;
        var obs = row.Observacion;
        if (string.IsNullOrEmpty(obs)) return false;
        return obs.Contains("[Imagen:") && obs.Contains("/uploads/comprobantes/");
    }

    private string GetEvidenceImageUrl(string? obs)
    {
        if (string.IsNullOrEmpty(obs)) return "";
        var startTag = "[Imagen:";
        var startIdx = obs.IndexOf(startTag);
        if (startIdx >= 0)
        {
            var contentStart = startIdx + startTag.Length;
            var endIdx = obs.IndexOf(']', contentStart);
            if (endIdx > contentStart)
            {
                return obs.Substring(contentStart, endIdx - contentStart).Trim();
            }
        }
        return "";
    }

    private string GetObservacionLimpia(string? obs)
    {
        if (string.IsNullOrEmpty(obs)) return string.Empty;
        if (obs.StartsWith("Aprobado por BackOffice", StringComparison.OrdinalIgnoreCase))
        {
            return "Aprobado por BackOffice";
        }

        if (obs.Contains("[AprobadoBackOffice:", StringComparison.OrdinalIgnoreCase))
        {
            return "Aprobado por BackOffice";
        }

        var workingObs = obs;
        
        // Remove Comprobante tag
        if (workingObs.StartsWith("[Comprobante:"))
        {
            var endIdx = workingObs.IndexOf(']');
            if (endIdx > 0)
            {
                workingObs = workingObs.Substring(endIdx + 1).Trim();
            }
        }

        // Remove Imagen tag
        var imgTagIdx = workingObs.IndexOf("[Imagen:");
        if (imgTagIdx >= 0)
        {
            var endIdx = workingObs.IndexOf(']', imgTagIdx);
            if (endIdx > 0)
            {
                workingObs = (workingObs.Substring(0, imgTagIdx) + workingObs.Substring(endIdx + 1)).Trim();
            }
        }

        const string compraDocsTag = "[CompraDocs:";
        if (workingObs.Contains(compraDocsTag, StringComparison.OrdinalIgnoreCase) &&
            workingObs.Contains("Solicitud pendiente", StringComparison.OrdinalIgnoreCase))
        {
            return "Solicitud pendiente de aprobacion por compra de documentos.";
        }

        return workingObs.Length > 95 ? $"{workingObs[..95].Trim()}..." : workingObs;
    }

    private static bool EsSolicitudTransferenciaDocumentos(ReporteVentaBackOffice? row)
    {
        if (row is null)
        {
            return false;
        }

        return row.Producto.Equals("e-fact", StringComparison.OrdinalIgnoreCase) &&
               row.Canal.Contains("Transferencia Web", StringComparison.OrdinalIgnoreCase) &&
               !string.IsNullOrWhiteSpace(ObtenerCompraDocumentosId(row));
    }

    private static string ObtenerCompraDocumentosId(ReporteVentaBackOffice row)
    {
        var obs = row.Observacion;
        if (string.IsNullOrWhiteSpace(obs))
        {
            return string.Empty;
        }

        const string startTag = "[CompraDocs:";
        var startIdx = obs.IndexOf(startTag, StringComparison.OrdinalIgnoreCase);
        if (startIdx < 0)
        {
            return string.Empty;
        }

        var contentStart = startIdx + startTag.Length;
        var endIdx = obs.IndexOf(']', contentStart);
        return endIdx > contentStart
            ? obs.Substring(contentStart, endIdx - contentStart).Trim()
            : string.Empty;
    }

    private async Task ActualizarHistorialCompraDocumentosAsync(ReporteVentaBackOffice venta, bool aprobado)
    {
        var compraId = ObtenerCompraDocumentosId(venta);
        if (string.IsNullOrWhiteSpace(compraId))
        {
            return;
        }

        var email = GetClientEmail(venta.Cliente);
        if (string.IsNullOrWhiteSpace(email))
        {
            return;
        }

        using var context = await DbFactory.CreateDbContextAsync();
        var user = await context.Usuarios.FirstOrDefaultAsync(u => u.Email == email);
        if (user is null)
        {
            return;
        }

        var history = LeerHistorial(user.HistorialComprasDocumentosJson);
        var item = history.FirstOrDefault(x => string.Equals(x.Id, compraId, StringComparison.OrdinalIgnoreCase));
        if (item is null)
        {
            return;
        }

        item.Estado = aprobado ? "Aprobado" : "Rechazado";
        item.SaldoAplicado = aprobado;
        item.Reference = $"BO-{venta.IdReporte}";
        item.AuthorizationCode = GetComprobanteRef(venta.Observacion);
        item.Descripcion = aprobado
            ? $"Transferencia aprobada: {venta.PlanPaquete}"
            : $"Transferencia rechazada: {venta.PlanPaquete}";

        var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        user.HistorialComprasDocumentosJson = JsonSerializer.Serialize(history, options);
        context.Entry(user).State = EntityState.Modified;
        await context.SaveChangesAsync();
    }

