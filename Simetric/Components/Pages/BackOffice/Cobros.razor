    private static AuditoriaTransferenciaDto MapAuditoriaTransferencia(Auditoria auditoria)
    {
        using var detalles = TryParseJson(auditoria.Detalles);
        using var nuevo = TryParseJson(auditoria.ValorNuevo);

        var contador = auditoria.Usuario?.NombreCompleto;
        if (string.IsNullOrWhiteSpace(contador))
        {
            contador = auditoria.IdUsuario.HasValue ? $"Usuario #{auditoria.IdUsuario}" : "Usuario no registrado";
        }

        var fechaAprobacion = GetJsonDateTime(detalles, "FechaAprobacion") ?? auditoria.Fecha;
        var producto = GetJsonString(detalles, "Producto");

        return new AuditoriaTransferenciaDto
        {
            IdAuditoria = auditoria.IdAuditoria,
            IdUsuario = auditoria.IdUsuario,
            Contador = contador,
            ContadorEmail = auditoria.Usuario?.Email ?? string.Empty,
            FechaAprobacion = fechaAprobacion,
            Cliente = GetJsonString(detalles, "Cliente", "Cliente no disponible"),
            EmailCliente = GetJsonString(detalles, "Email"),
            Producto = string.IsNullOrWhiteSpace(producto) ? "e-fact" : producto,
            PlanPaquete = GetJsonString(detalles, "PlanPaquete"),
            Valor = GetJsonDecimal(detalles, "Valor"),
            Comprobante = GetJsonString(detalles, "Comprobante", "Sin referencia"),
            FacturaGenerada = GetJsonBool(nuevo, "FacturaGenerada"),
            CodFactura = GetJsonInt(nuevo, "CodFactura"),
            NumeroFactura = GetJsonString(nuevo, "NumeroFactura"),
            Mensaje = GetJsonString(detalles, "Mensaje", "Aprobacion registrada")
        };
    }

    private static JsonDocument? TryParseJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return null;
        }

        try
        {
            return JsonDocument.Parse(json);
        }
        catch
        {
            return null;
        }
    }

    private static string GetJsonString(JsonDocument? document, string propertyName, string fallback = "")
    {
        if (document?.RootElement.TryGetProperty(propertyName, out var property) == true)
        {
            return property.ValueKind switch
            {
                JsonValueKind.String => property.GetString() ?? fallback,
                JsonValueKind.Number => property.GetRawText(),
                JsonValueKind.True => "Si",
                JsonValueKind.False => "No",
                _ => fallback
            };
        }

        return fallback;
    }

    private static DateTime? GetJsonDateTime(JsonDocument? document, string propertyName)
    {
        var raw = GetJsonString(document, propertyName);
        return DateTime.TryParse(raw, out var value) ? value : null;
    }

    private static decimal GetJsonDecimal(JsonDocument? document, string propertyName)
    {
        if (document?.RootElement.TryGetProperty(propertyName, out var property) == true)
        {
            if (property.ValueKind == JsonValueKind.Number && property.TryGetDecimal(out var value))
            {
                return value;
            }

            if (property.ValueKind == JsonValueKind.String &&
                decimal.TryParse(property.GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out value))
            {
                return value;
            }
        }

        return 0m;
    }

    private static int GetJsonInt(JsonDocument? document, string propertyName)
    {
        if (document?.RootElement.TryGetProperty(propertyName, out var property) == true)
        {
            if (property.ValueKind == JsonValueKind.Number && property.TryGetInt32(out var value))
            {
                return value;
            }

            if (property.ValueKind == JsonValueKind.String && int.TryParse(property.GetString(), out value))
            {
                return value;
            }
        }

        return 0;
    }

    private static bool GetJsonBool(JsonDocument? document, string propertyName)
    {
        if (document?.RootElement.TryGetProperty(propertyName, out var property) == true)
        {
            if (property.ValueKind == JsonValueKind.True || property.ValueKind == JsonValueKind.False)
            {
                return property.GetBoolean();
            }

            if (property.ValueKind == JsonValueKind.String && bool.TryParse(property.GetString(), out var value))
            {
                return value;
            }
        }

        return false;
    }

