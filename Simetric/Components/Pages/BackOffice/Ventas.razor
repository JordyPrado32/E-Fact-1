<!-- Modal Editar Venta -->
@if (mostrarModal)
{
    <div class="ventas-modal-overlay">
        <div class="ventas-modal-dialog">
            <div class="ventas-modal-header">
                <h3>
                    <i class="bi bi-pencil-square"></i>
                    Editar Venta Registrada
                </h3>
                <button type="button" class="ventas-modal-close-btn" @onclick="CerrarModal" disabled="@isSaving">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="ventas-modal-body">
                <!-- Modal Level Notifications -->
                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="action-notification-alert error" style="margin-bottom: 1.25rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@modalError</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(modalSuccess))
                {
                    <div class="action-notification-alert success" style="margin-bottom: 1.25rem;">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@modalSuccess</span>
                    </div>
                }

                <div class="form-grid">
                    <!-- Client Selector -->
                    <div class="form-group form-group-full">
                        <label class="form-label">Cliente (Usuario del sistema)</label>
                        @if (selectedUser != null)
                        {
                            <div class="selected-user-badge">
                                <div class="selected-user-info">
                                    <strong>@selectedUser.Nombres @selectedUser.Apellidos</strong>
                                    <span class="text-muted font-xs">@selectedUser.Email | ID: @selectedUser.Identificacion</span>
                                </div>
                                <button type="button" class="btn-remove-selected-user" @onclick="DeseleccionarUsuario" title="Cambiar usuario">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="searchable-select-wrap">
                                <input type="text" 
                                       class="form-input" 
                                       placeholder="Escribe nombres, apellidos o correo para buscar..." 
                                       @bind="userSearchQuery" 
                                       @bind:event="oninput"
                                       @bind:after="BuscarClientes"
                                       @onfocus="OnSearchInputFocused" />
                                
                                @if (mostrarDropdownClientes && !string.IsNullOrWhiteSpace(userSearchQuery))
                                {
                                    <div class="search-results-dropdown">
                                        @if (!clientesEncontrados.Any())
                                        {
                                            <div class="search-no-results">No se encontraron usuarios matching.</div>
                                        }
                                        else
                                        {
                                            @foreach (var u in clientesEncontrados)
                                            {
                                                <div class="search-result-item" @onclick="() => SeleccionarUsuario(u)">
                                                    <span class="search-result-name">@u.Nombres @u.Apellidos</span>
                                                    <span class="search-result-email">@u.Email | CI: @u.Identificacion</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                        @if (mostrarErrores && selectedUser == null)
                        {
                            <span class="form-error">Debes seleccionar un cliente registrado en el sistema.</span>
                        }
                    </div>

                    <!-- Producto -->
                    <div class="form-group">
                        <label class="form-label">Producto</label>
                        <select class="form-select" @bind="modalVenta.Producto" @bind:after="OnProductoChanged">
                            <option value="e-fact">e-Fact (Documentos)</option>
                            <option value="e-sign">eRúbrica (Firma)</option>
                        </select>
                    </div>

                    <!-- Plan o Paquete -->
                    <div class="form-group">
                        <label class="form-label">Plan o Paquete</label>
                        <div class="d-flex gap-2">
                            <select class="form-select" @bind="planSeleccionado" @bind:after="OnPlanSeleccionadoChanged">
                                @if (modalVenta.Producto == "e-fact")
                                {
                                    <option value="Por documento">Por documento ($@EFactDocumentPricing.PrecioTierHasta25.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))</option>
                                    <option value="25 documentos">25 documentos</option>
                                    <option value="120 documentos">120 documentos</option>
                                    <option value="600 documentos">600 documentos</option>
                                    <option value="Ilimitados durante 1 año">Ilimitados durante 1 año</option>
                                    <option value="CUSTOM">Personalizado (Ingreso manual)</option>
                                }
                                else
                                {
                                    <option value="1 año">1 año</option>
                                    <option value="2 años">2 años</option>
                                    <option value="3 años">3 años</option>
                                    <option value="4 años">4 años</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Custom Plan Box -->
                    @if (planSeleccionado == "CUSTOM" && modalVenta.Producto == "e-fact")
                    {
                        <div class="form-group form-group-full">
                            <label class="form-label">¿Cuántos documentos deseas comprar?</label>
                            <input type="number" min="1" class="form-input" @bind="customDocsCount" @bind:event="oninput" @bind:after="RecalcularValorPlan" />
                            @if (mostrarErrores && customDocsCount < 1)
                            {
                                <span class="form-error">Debes comprar al menos 1 documento.</span>
                            }
                        </div>
                    }

                    <!-- Valor -->
                    <div class="form-group">
                        <label class="form-label">Valor ($)</label>
                        <input type="number" step="0.01" class="form-input" placeholder="0.00" @bind="modalVenta.Valor" disabled />
                        @if (mostrarErrores && modalVenta.Valor < 0)
                        {
                            <span class="form-error">El valor no puede ser negativo.</span>
                        }
                    </div>

                    <!-- Fecha -->
                    <div class="form-group">
                        <label class="form-label">Fecha de Registro</label>
                        <input type="datetime-local" class="form-input" @bind="modalVenta.Fecha" />
                    </div>

                    <!-- Canal (fijo: solo ventas manuales por Asesores; las de Web se registran automáticamente) -->
                    <div class="form-group">
                        <label class="form-label">Canal de Comercialización</label>
                        <input type="text" class="form-input" value="Números Asesores" disabled />
                    </div>

                    <!-- Vendedor -->
                    <div class="form-group">
                        <label class="form-label">Vendedor</label>
                        @if (esVendedor)
                        {
                            <input type="text" class="form-input" value="@sellerName" disabled />
                        }
                        else
                        {
                            <select class="form-select" @bind="modalVenta.Vendedor">
                                <option value="">-- Seleccione un Vendedor --</option>
                                @foreach (var vend in vendedoresList)
                                {
                                    <option value="@($"{vend.Nombres} {vend.Apellidos}")">@($"{vend.Nombres} {vend.Apellidos}")</option>
                                }
                            </select>
                            @if (mostrarErrores && string.IsNullOrWhiteSpace(modalVenta.Vendedor))
                            {
                                <span class="form-error">Debes seleccionar un vendedor.</span>
                            }
                        }
                    </div>

                    <!-- Forma de Pago -->
                    <div class="form-group">
                        <label class="form-label">Forma de Pago</label>
                        <select class="form-select" @bind="modalVenta.FormaPago">
                            <option value="Transferencia">Transferencia</option>
                            <option value="Tarjeta de Crédito">Tarjeta de Crédito</option>
                            <option value="Efectivo">Efectivo</option>
                            <option value="Depósito Bancario">Depósito Bancario</option>
                        </select>
                    </div>

                    <!-- Estado -->
                    <div class="form-group">
                        <label class="form-label">Estado de la Venta</label>
                        <select class="form-select" @bind="modalVenta.Estado">
                            <option value="pendiente">Pendiente</option>
                            <option value="pagada">Pagada</option>
                            <option value="anulada">Anulada</option>
                        </select>
                    </div>

                    <!-- Comprobante / Referencia (Only if Estado is pagada) -->
                    @if (modalVenta.Estado == "pagada")
                    {
                        <div class="form-group form-group-full">
                            <label class="form-label">Comprobante / Referencia de Pago</label>
                            <input type="text" class="form-input" placeholder="Ej. N° de transferencia o depósito" @bind="comprobanteRef" disabled="@isSaving" />
                        </div>
                    }

                    <!-- Observación -->
                    <div class="form-group form-group-full">
                        <label class="form-label">Observaciones</label>
                        <textarea class="form-textarea" placeholder="Añadir notas de cobro, números de referencia o comentarios..." @bind="modalVenta.Observacion" disabled="@isSaving"></textarea>
                    </div>

                    <!-- Captura de Comprobante (Evidencia) -->
                    <div class="form-group form-group-full" style='display: @(modalVenta.Estado == "pagada" ? "block" : "none");'>
                        <label class="form-label">Captura del Comprobante (Opcional)</label>
                        @if (selectedFile == null && HasComprobanteImage(modalVenta))
                        {
                            <div class="file-preview-banner" style="background: #f0fdf4; border-color: #bbf7d0;">
                                <div class="file-preview-info" style="color: #166534;">
                                    <i class="bi bi-image"></i>
                                    <span>Comprobante actual guardado</span>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <button type="button" class="btn-view-evidence" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;" @onclick="() => ShowEvidencePreview(modalVenta)">
                                        <i class="bi bi-eye"></i> Ver
                                    </button>
                                    <button type="button" class="btn-remove-file" title="Eliminar comprobante" @onclick="EliminarComprobanteExistente" disabled="@isSaving">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </div>
                        }

                        <label for="sales-evidence-upload" class="upload-zone" style='margin-top: 0.25rem; display: @(selectedFile == null && !HasComprobanteImage(modalVenta) ? "flex" : "none");'>
                            <i class="bi bi-cloud-arrow-up-fill" style="font-size: 1.5rem; color: #94a3b8; display: block; margin-bottom: 0.25rem;"></i>
                            <span class="upload-text" style="font-size: 0.825rem; font-weight: 600; color: #475569; display: block;">Haz clic aquí para cargar captura de pago</span>
                            <span class="upload-sub" style="font-size: 0.725rem; color: #94a3b8; display: block;">Formatos permitidos: JPG, PNG (máx. 5MB)</span>
                        </label>
                        <InputFile OnChange="HandleFileSelected" id="sales-evidence-upload" style="display: none;" accept="image/*" />

                        @if (selectedFile != null)
                        {
                            <div class="file-preview-banner">
                                <div class="file-preview-info">
                                    <i class="bi bi-file-earmark-image-fill"></i>
                                    <span>@selectedFile.Name (@(Math.Round(selectedFile.Size / 1024.0, 1)) KB)</span>
                                </div>
                                <button type="button" class="btn-remove-file" title="Eliminar archivo" @onclick="RemoveSelectedFile" disabled="@isSaving">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(uploadError))
                        {
                            <span class="text-danger font-sm fw-bold mt-1" style="font-size: 0.75rem;">@uploadError</span>
                        }
                    </div>
                </div>
            </div>
            <div class="ventas-modal-footer">
                <button type="button" class="btn-modal-cancel" @onclick="CerrarModal" disabled="@isSaving">Cancelar</button>
                <button type="button" class="btn-modal-save" @onclick="GuardarVenta" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true" style="width: 1rem; height: 1rem; border-width: 0.15em; display: inline-block;"></span>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>Guardar Cambios</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

