@code {
    private bool isLoading = true;
    private List<ReporteVentaBackOffice> ventasList = new();
    private List<ReporteVentaBackOffice> filteredVentas = new();
    private List<ReporteVentaBackOffice> paginatedVentas = new();

    // File Upload and alerts fields
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? selectedFile;
    private string? uploadError;
    private string? modalError;
    private string? modalSuccess;
    private bool isSaving = false;
    private string? feedbackMessage;
    private bool feedbackIsSuccess = true;
    private string? previewImageUrl;
    private string comprobanteRef = "";

    // Filters and Search
    private string searchString = "";
    private string filterProducto = "ALL";
    private string filterCanal = "ALL";
    private string filterEstado = "ALL";

    // Pager
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 0;

    // KPIs
    private decimal totalRecaudado;
    private decimal ventasAsesores;
    private decimal ventasWeb;
    private int countPendientes;
    private bool esVendedor;
    private string sellerName = string.Empty;
    private decimal promedioCompra = 0;

    // Seller specific
    private List<VendedorClienteDto> clientesAfiliadosList = new();
    private List<VendedorClienteDto> filteredClientesAfiliadosList = new();
    private List<VendedorClienteDto> paginatedClientes = new();
    private bool mostrarModalComprasClient = false;
    private VendedorClienteDto? clienteSeleccionadoVer;

    private void AbrirModalCompras(VendedorClienteDto dto)
    {
        clienteSeleccionadoVer = dto;
        mostrarModalComprasClient = true;
    }

    private void CerrarModalCompras()
    {
        mostrarModalComprasClient = false;
        clienteSeleccionadoVer = null;
    }

    // Charts
    private List<(string Nombre, decimal Monto)> ventasPorVendedor = new();
    private decimal totalCanales;
    private int countEFact;
    private int countESign;

    // Modal Control
    private bool mostrarModal = false;
    private ReporteVentaBackOffice modalVenta = new();
    private int? editandoVentaId;
    private string planSeleccionado = "120 documentos";
    private bool mostrarErrores = false;
    private int customDocsCount = 1;

    // Searchable Clients Dropdown
    private string userSearchQuery = "";
    private List<Usuario> clientesEncontrados = new();
    private Usuario? selectedUser;
    private bool mostrarDropdownClientes = false;
    private List<Usuario> vendedoresList = new();
    private string currentOperatorName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadVentasData();
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var name = user.Identity.Name ?? "";
            var surname = user.FindFirst(ClaimTypes.Surname)?.Value ?? "";
            currentOperatorName = $"{name} {surname}".Trim();
        }
    }

    protected override void OnParametersSet()
    {
        ApplyFilters();
    }

    private async Task LoadVentasData()
    {
        isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var role = user.FindFirst("IdTipoUsuario")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
            var tipoCliente = user.FindFirst("TipoCliente")?.Value;
            var idUsuario = int.TryParse(user.FindFirst("IdUsuario")?.Value, out var idClaim) ? idClaim : 0;
            var nombreCompleto = user.Identity?.Name ?? "Vendedor";
            
            esVendedor = string.Equals(role, "7", StringComparison.OrdinalIgnoreCase) && 
                         string.Equals(tipoCliente, "2", StringComparison.OrdinalIgnoreCase);

            using var context = await DbFactory.CreateDbContextAsync();
            if (idUsuario > 0)
            {
                var dbUser = await context.Usuarios.FindAsync(idUsuario);
                if (dbUser != null)
                {
                    role = dbUser.IdTipoUsuario?.ToString() ?? role;
                    tipoCliente = dbUser.TipoCliente?.ToString() ?? tipoCliente;
                    nombreCompleto = $"{dbUser.Nombres} {dbUser.Apellidos}".Trim();
                    if (string.IsNullOrWhiteSpace(nombreCompleto))
                        nombreCompleto = dbUser.Email ?? "Vendedor";

                    esVendedor = string.Equals(role, "7", StringComparison.OrdinalIgnoreCase) &&
                                 string.Equals(tipoCliente, "2", StringComparison.OrdinalIgnoreCase);
                }
            }

            if (esVendedor)
            {
                var sellerProfile = await VendedorBackOfficeService.ObtenerPerfilUsuarioAsync(idUsuario, nombreCompleto);
                
                sellerName = sellerProfile?.Nombre ?? string.Empty;
                var idVendedor = sellerProfile?.IdVendedor ?? 0;

                // Load all registered clients under this seller
                var rawClients = await context.Usuarios
                    .AsNoTracking()
                    .Where(u => u.IdVendedor == idVendedor)
                    .OrderByDescending(u => u.FechaCreacion)
                    .ToListAsync();

                var correosClientes = rawClients
                    .Select(u => u.Email?.Trim())
                    .Where(email => !string.IsNullOrWhiteSpace(email))
                    .Select(email => email!)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                ventasList = await LoadVentasParaCorreosAsync(context, correosClientes);

                var ventasPorCorreo = ventasList
                    .Select(v => new { Venta = v, Email = ExtraerEmailClienteReporte(v.Cliente) })
                    .Where(x => !string.IsNullOrWhiteSpace(x.Email))
                    .GroupBy(x => x.Email!, StringComparer.OrdinalIgnoreCase)
                    .ToDictionary(
                        g => g.Key,
                        g => g.Select(x => x.Venta).OrderByDescending(v => v.Fecha).ToList(),
                        StringComparer.OrdinalIgnoreCase);

                // Build client DTO list
                clientesAfiliadosList = rawClients.Select(u =>
                {
                    var emailUsuario = u.Email?.Trim() ?? string.Empty;
                    var ventasUsuario = !string.IsNullOrWhiteSpace(emailUsuario) &&
                                       ventasPorCorreo.TryGetValue(emailUsuario, out var ventasEncontradas)
                        ? ventasEncontradas
                        : ventasList.Where(v => CoincideClienteReporte(u, v.Cliente)).ToList();

                    var nombreStr = $"{u.Nombres} {u.Apellidos}".Trim();
                    if (string.IsNullOrWhiteSpace(nombreStr))
                    {
                        nombreStr = u.NombreEmpresa ?? $"Cliente #{u.IdUsuario}";
                    }

                    return new VendedorClienteDto
                    {
                        Usuario = u,
                        Nombre = nombreStr,
                        Email = u.Email ?? "",
                        Identificacion = u.Identificacion ?? "",
                        FechaRegistro = u.FechaCreacion,
                        ComprasCount = ventasUsuario.Count,
                        TotalGastado = ventasUsuario.Sum(v => v.Valor),
                        Transacciones = ventasUsuario
                    };
                }).ToList();

                filteredClientesAfiliadosList = new List<VendedorClienteDto>(clientesAfiliadosList);
                
                ventasList = clientesAfiliadosList
                    .SelectMany(c => c.Transacciones)
                    .OrderByDescending(v => v.Fecha)
                    .ToList();
            }
            else
            {
                await using var ventasContext = await DbFactory.CreateDbContextAsync();
                await using var vendedoresContext = await DbFactory.CreateDbContextAsync();

                var ventasTask = ventasContext.ReporteVentasBackOffice
                    .AsNoTracking()
                    .OrderByDescending(v => v.Fecha)
                    .ToListAsync();

                var vendedoresTask = vendedoresContext.Usuarios
                    .AsNoTracking()
                    .Where(u => u.IdTipoUsuario == 7 && u.Estado == true)
                    .OrderBy(u => u.Nombres)
                    .ToListAsync();

                await Task.WhenAll(ventasTask, vendedoresTask);

                ventasList = ventasTask.Result;
                vendedoresList = vendedoresTask.Result;
            }

            ComputeMetrics();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading ventas: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ComputeMetrics()
    {
        if (esVendedor)
        {
            totalRecaudado = clientesAfiliadosList.Sum(c => c.TotalGastado);
            var activeClientsCount = clientesAfiliadosList.Count(c => c.ComprasCount > 0);
            promedioCompra = activeClientsCount > 0 ? totalRecaudado / activeClientsCount : 0;
            
            var activeSalesOfClients = clientesAfiliadosList.SelectMany(c => c.Transacciones).Where(t => t.Estado != "anulada").ToList();
            countEFact = activeSalesOfClients.Count(t => t.Producto == "e-fact");
            countESign = activeSalesOfClients.Count(t => t.Producto == "e-sign");
            return;
        }

        // Compute KPIs (Only from valid active/paid sales, except pending which is shown separately)
        var paidSales = ventasList.Where(v => v.Estado == "pagada").ToList();
        totalRecaudado = paidSales.Sum(v => v.Valor);
        ventasAsesores = paidSales.Where(v => v.Canal == "Números Asesores").Sum(v => v.Valor);
        ventasWeb = paidSales.Where(v => v.Canal == "Web").Sum(v => v.Valor);
        countPendientes = ventasList.Count(v => v.Estado == "pendiente");

        totalCanales = ventasAsesores + ventasWeb;

        // Group active paid/pending sales by seller
        var activeSales = ventasList.Where(v => v.Estado != "anulada").ToList();
        ventasPorVendedor = activeSales
            .Where(v => !string.IsNullOrWhiteSpace(v.Vendedor) && v.Vendedor != "Sistema")
            .GroupBy(v => v.Vendedor!.Trim())
            .Select(g => (Nombre: g.Key, Monto: g.Sum(x => x.Valor)))
            .OrderByDescending(x => x.Monto)
            .ToList();

        // Product counts
        countEFact = activeSales.Count(v => v.Producto == "e-fact");
        countESign = activeSales.Count(v => v.Producto == "e-sign");
    }

    private static async Task<List<ReporteVentaBackOffice>> LoadVentasParaCorreosAsync(AppDbContext context, List<string> correos)
    {
        if (correos.Count == 0)
        {
            return new List<ReporteVentaBackOffice>();
        }

        var ventas = new List<ReporteVentaBackOffice>();
        var containsMethod = typeof(string).GetMethod(nameof(string.Contains), new[] { typeof(string) });
        if (containsMethod is null)
        {
            return ventas;
        }

        foreach (var chunk in correos.Chunk(25))
        {
            var parameter = Expression.Parameter(typeof(ReporteVentaBackOffice), "v");
            var clienteProperty = Expression.Property(parameter, nameof(ReporteVentaBackOffice.Cliente));
            var notNull = Expression.NotEqual(clienteProperty, Expression.Constant(null, typeof(string)));

            Expression? emailFilter = null;
            foreach (var email in chunk)
            {
                var containsEmail = Expression.Call(clienteProperty, containsMethod, Expression.Constant(email));
                emailFilter = emailFilter is null ? containsEmail : Expression.OrElse(emailFilter, containsEmail);
            }

            if (emailFilter is null)
            {
                continue;
            }

            var body = Expression.AndAlso(notNull, emailFilter);
            var predicate = Expression.Lambda<Func<ReporteVentaBackOffice, bool>>(body, parameter);

            var chunkVentas = await context.ReporteVentasBackOffice
                .AsNoTracking()
                .Where(predicate)
                .OrderByDescending(v => v.Fecha)
                .ToListAsync();

            ventas.AddRange(chunkVentas);
        }

        return ventas
            .GroupBy(v => v.IdReporte)
            .Select(g => g.First())
            .OrderByDescending(v => v.Fecha)
            .ToList();
    }

    private void ApplyFilters()
    {
        if (esVendedor)
        {
            if (!string.IsNullOrWhiteSpace(searchString))
            {
                var cleanSearch = searchString.Trim().ToLower();
                filteredClientesAfiliadosList = clientesAfiliadosList
                    .Where(c => c.Nombre.ToLower().Contains(cleanSearch) ||
                                c.Email.ToLower().Contains(cleanSearch) ||
                                c.Identificacion.Contains(cleanSearch))
                    .ToList();
            }
            else
            {
                filteredClientesAfiliadosList = new List<VendedorClienteDto>(clientesAfiliadosList);
            }

            totalPages = (int)Math.Ceiling((double)filteredClientesAfiliadosList.Count / pageSize);
            if (currentPage > totalPages && totalPages > 0)
            {
                currentPage = totalPages;
            }
            else if (totalPages == 0)
            {
                currentPage = 1;
            }

            paginatedClientes = filteredClientesAfiliadosList
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
                
            return;
        }

        var query = ventasList.AsQueryable();

        // Product filter
        if (filterProducto != "ALL")
        {
            query = query.Where(v => v.Producto == filterProducto);
        }

        // Channel filter
        if (filterCanal != "ALL")
        {
            query = query.Where(v => v.Canal == filterCanal);
        }

        // State filter
        if (filterEstado != "ALL")
        {
            query = query.Where(v => v.Estado == filterEstado);
        }

        // Search text
        if (!string.IsNullOrWhiteSpace(searchString))
        {
            var cleanSearch = searchString.Trim().ToLower();
            query = query.Where(v => 
                v.Cliente.ToLower().Contains(cleanSearch) || 
                (v.Vendedor != null && v.Vendedor.ToLower().Contains(cleanSearch)) ||
                v.PlanPaquete.ToLower().Contains(cleanSearch) ||
                v.FormaPago.ToLower().Contains(cleanSearch)
            );
        }

        filteredVentas = query.ToList();
        
        // Pagination
        totalPages = (int)Math.Ceiling((double)filteredVentas.Count / pageSize);
        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
        }
        else if (totalPages == 0)
        {
            currentPage = 1;
        }

        UpdatePaginatedList();
    }

    private void UpdatePaginatedList()
    {
        if (esVendedor)
        {
            paginatedClientes = filteredClientesAfiliadosList
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
            return;
        }

        paginatedVentas = filteredVentas
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private Task OnFiltersChangedAsync()
    {
        currentPage = 1;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void SetPage(int page)
    {
        currentPage = page;
        UpdatePaginatedList();
    }

