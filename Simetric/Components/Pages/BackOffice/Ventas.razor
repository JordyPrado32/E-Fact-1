@page "/backoffice/ventas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Auth
@using Simetric.Data
@using Simetric.Models
@using Simetric.Services
@using Simetric.DTOs
@using System.Security.Claims
@using System.Text.Json
@using System.IO
@using System.Linq.Expressions
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Simetric.Services.VendedorBackOfficeService VendedorBackOfficeService

<PageTitle>Registro y Control de Ventas - BackOffice</PageTitle>

<div class="ventas-wrapper animate__animated animate__fadeIn">
    <!-- Header Block -->
    <header class="ventas-header">
        <div class="header-text">
            <h2>@(esVendedor ? "Mis Ventas" : "Registro y Control de Ventas")</h2>
            <p>@(esVendedor ? "Historial de compras de tus clientes afiliados y estadísticas." : "Historial de transacciones de clientes, canales de comercialización y activación de servicios.")</p>
        </div>
    </header>

    <!-- Page Level Feedback Banner -->
    @if (!string.IsNullOrEmpty(feedbackMessage))
    {
        <div class="action-notification-alert @(feedbackIsSuccess ? "success" : "error")" style="margin-top: 1rem;">
            <i class="bi @(feedbackIsSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
            <span>@feedbackMessage</span>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando ventas...</span>
            </div>
            <p class="mt-3 text-muted fw-bold">Cargando información</p>
        </div>
    }
    else
    {
        <!-- KPI Summary Cards -->
        <section class="kpi-grid">
            @if (esVendedor)
            {
                <div class="kpi-card is-success">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Monto Total Recaudado</span>
                        <strong class="kpi-value text-success">$@totalRecaudado.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                        <span class="kpi-desc">Monto total pagado por tus clientes</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                </div>
                <div class="kpi-card is-primary">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Clientes Afiliados</span>
                        <strong class="kpi-value text-primary">@clientesAfiliadosList.Count</strong>
                        <span class="kpi-desc">Total clientes registrados con tu link</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
                <div class="kpi-card is-info">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Clientes con Compras</span>
                        <strong class="kpi-value text-info">@clientesAfiliadosList.Count(c => c.ComprasCount > 0)</strong>
                        <span class="kpi-desc">Clientes que han adquirido un servicio</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                </div>
                <div class="kpi-card is-warning">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Promedio de Compra</span>
                        <strong class="kpi-value text-warning">$@promedioCompra.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                        <span class="kpi-desc">Promedio gastado por cliente activo</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                </div>
            }
            else
            {
                <div class="kpi-card is-success">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Monto Total Recaudado</span>
                        <strong class="kpi-value text-success">$@totalRecaudado.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                        <span class="kpi-desc">Monto consolidado de ventas pagadas</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                </div>
                <div class="kpi-card is-primary">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Ventas Canal Asesores</span>
                        <strong class="kpi-value text-primary">$@ventasAsesores.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                        <span class="kpi-desc">Ventas cerradas por equipo comercial</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-headset"></i>
                    </div>
                </div>
                <div class="kpi-card is-info">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Ventas Canal Web</span>
                        <strong class="kpi-value text-info">$@ventasWeb.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong>
                        <span class="kpi-desc">Transacciones automáticas en línea</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-globe"></i>
                    </div>
                </div>
                <div class="kpi-card is-warning">
                    <div class="kpi-card-content">
                        <span class="kpi-title">Transacciones Pendientes</span>
                        <strong class="kpi-value text-warning">@countPendientes</strong>
                        <span class="kpi-desc">Ventas con cobro o validación pendiente</span>
                    </div>
                    <div class="kpi-icon-wrapper">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                </div>
            }
        </section>

        <!-- Charts Dashboard Grid -->
        <section class="charts-grid">
            @if (esVendedor)
            {
                <!-- Chart 1: Sales by Client -->
                <div class="chart-card">
                    <div class="chart-title-group">
                        <h3>Ventas por Cliente</h3>
                        <p>Monto total comprado por cada cliente registrado (Ventas Activas)</p>
                    </div>
                    <div class="bar-list-container">
                        @if (!clientesAfiliadosList.Any(c => c.TotalGastado > 0))
                        {
                            <div class="text-center text-muted py-4 font-sm">
                                <i class="bi bi-info-circle d-block mb-1 fs-5"></i>
                                Sin compras registradas por sus clientes
                            </div>
                        }
                        else
                        {
                            var topClientes = clientesAfiliadosList.Where(c => c.TotalGastado > 0).OrderByDescending(c => c.TotalGastado).Take(5).ToList();
                            var maxVal = topClientes.Max(c => c.TotalGastado);
                            if (maxVal <= 0) maxVal = 1;

                            @foreach (var c in topClientes)
                            {
                                var pct = (c.TotalGastado / maxVal) * 100;
                                <div class="bar-item">
                                    <div class="bar-info">
                                        <span class="bar-name">@c.Nombre</span>
                                        <span class="bar-value">$@c.TotalGastado.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill" style="width: @(pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Chart 2: Conversión Clientes -->
                <div class="chart-card">
                    <div class="chart-title-group">
                        <h3>Estado de Clientes</h3>
                        <p>Conversión de clientes registrados: Con Compras vs Sin Compras</p>
                    </div>
                    <div class="vs-container">
                        @{
                            var totalCli = clientesAfiliadosList.Count;
                            var conComp = clientesAfiliadosList.Count(c => c.ComprasCount > 0);
                            var sinComp = totalCli - conComp;
                            double pctCon = totalCli > 0 ? (double)conComp / totalCli * 100 : 0;
                            double pctSin = totalCli > 0 ? (double)sinComp / totalCli * 100 : 0;
                            if (totalCli == 0) { pctCon = 50; pctSin = 50; }
                        }
                        <div class="vs-bar-track">
                            <div class="vs-segment seller-bg" style="width: @(pctCon.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Con Compras: @(pctCon.ToString("F1"))%">
                                @if (pctCon >= 15) { <span>@(Math.Round(pctCon))%</span> }
                            </div>
                            <div class="vs-segment system-bg" style="width: @(pctSin.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Sin Compras: @(pctSin.ToString("F1"))%">
                                @if (pctSin >= 15) { <span>@(Math.Round(pctSin))%</span> }
                            </div>
                        </div>
                        <div class="vs-legend">
                            <div class="vs-legend-item">
                                <span class="vs-dot seller-bg"></span>
                                <span>Con Compras: <strong>@conComp</strong></span>
                            </div>
                            <div class="vs-legend-item">
                                <span class="vs-dot system-bg"></span>
                                <span>Sin Compras: <strong>@sinComp</strong></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chart 3: Distribution by Product -->
                <div class="chart-card">
                    <div class="chart-title-group">
                        <h3>Distribución por Producto</h3>
                        <p>Comparación del volumen de ventas e-Fact vs eRúbrica</p>
                    </div>
                    <div class="product-dist-container">
                        @{
                            var totalProds = countEFact + countESign;
                            double pctEFact = totalProds > 0 ? (double)countEFact / totalProds * 100 : 0;
                            double pctESign = totalProds > 0 ? (double)countESign / totalProds * 100 : 0;
                        }
                        <div class="product-row">
                            <div class="product-label-row">
                                <span class="product-name"><i class="bi bi-file-earmark-check text-success"></i> e-Fact (Documentos)</span>
                                <span>@countEFact ventas (@(totalProds > 0 ? Math.Round(pctEFact) : 0)%)</span>
                            </div>
                            <div class="product-track">
                                <div class="product-fill efact" style="width: @(pctEFact.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                        </div>
                        <div class="product-row">
                            <div class="product-label-row">
                                <span class="product-name"><i class="bi bi-shield-check text-primary"></i> eRúbrica (Firma Electrónica)</span>
                                <span>@countESign ventas (@(totalProds > 0 ? Math.Round(pctESign) : 0)%)</span>
                            </div>
                            <div class="product-track">
                                <div class="product-fill esign" style="width: @(pctESign.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Chart 1: Sales by Seller (Vendedor) -->
                <div class="chart-card">
                    <div class="chart-title-group">
                        <h3>Ventas por Vendedor</h3>
                        <p>Monto acumulado por asesor comercial (Ventas Activas)</p>
                    </div>
                    <div class="bar-list-container">
                        @if (!ventasPorVendedor.Any())
                        {
                            <div class="text-center text-muted py-4 font-sm">
                                <i class="bi bi-info-circle d-block mb-1 fs-5"></i>
                                Sin ventas registradas por vendedores
                            </div>
                        }
                        else
                        {
                            var maxVal = ventasPorVendedor.Max(v => v.Monto);
                            if (maxVal <= 0) maxVal = 1;

                            @foreach (var v in ventasPorVendedor)
                            {
                                var pct = (v.Monto / maxVal) * 100;
                                <div class="bar-item">
                                    <div class="bar-info">
                                        <span class="bar-name">@v.Nombre</span>
                                        <span class="bar-value">$@v.Monto.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill" style="width: @(pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Chart 2: Vendedor vs Sistema (Canales) -->
                <div class="chart-card">
                    <div class="chart-title-group">
                        <h3>Vendedor vs Sistema</h3>
                        <p>Comparativa de recaudación: Números Asesores vs Canal Web</p>
                    </div>
                    <div class="vs-container">
                        @{
                            double pctWeb = totalCanales > 0 ? (double)ventasWeb / (double)totalCanales * 100 : 0;
                            double pctAsesores = totalCanales > 0 ? (double)ventasAsesores / (double)totalCanales * 100 : 0;
                            if (totalCanales == 0) { pctWeb = 50; pctAsesores = 50; }
                        }
                        <div class="vs-bar-track">
                            <div class="vs-segment system-bg" style="width: @(pctWeb.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Web: @(pctWeb.ToString("F1"))%">
                                @if (pctWeb >= 15) { <span>@(Math.Round(pctWeb))%</span> }
                            </div>
                            <div class="vs-segment seller-bg" style="width: @(pctAsesores.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%" title="Asesores: @(pctAsesores.ToString("F1"))%">
                                @if (pctAsesores >= 15) { <span>@(Math.Round(pctAsesores))%</span> }
                            </div>
                        </div>
                        <div class="vs-legend">
                            <div class="vs-legend-item">
                                <span class="vs-dot system-bg"></span>
                                <span>Sistema Web: <strong>$@ventasWeb.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong></span>
                            </div>
                            <div class="vs-legend-item">
                                <span class="vs-dot seller-bg"></span>
                                <span>Asesores: <strong>$@ventasAsesores.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</strong></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chart 3: Distribution by Product -->
                <div class="chart-card">
                    <div class="chart-title-group">
                        <h3>Distribución por Producto</h3>
                        <p>Comparación del volumen de ventas e-Fact vs eRúbrica</p>
                    </div>
                    <div class="product-dist-container">
                        @{
                            var totalProds = countEFact + countESign;
                            double pctEFact = totalProds > 0 ? (double)countEFact / totalProds * 100 : 0;
                            double pctESign = totalProds > 0 ? (double)countESign / totalProds * 100 : 0;
                        }
                        <div class="product-row">
                            <div class="product-label-row">
                                <span class="product-name"><i class="bi bi-file-earmark-check text-success"></i> e-Fact (Documentos)</span>
                                <span>@countEFact ventas (@(totalProds > 0 ? Math.Round(pctEFact) : 0)%)</span>
                            </div>
                            <div class="product-track">
                                <div class="product-fill efact" style="width: @(pctEFact.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                        </div>
                        <div class="product-row">
                            <div class="product-label-row">
                                <span class="product-name"><i class="bi bi-shield-check text-primary"></i> eRúbrica (Firma Electrónica)</span>
                                <span>@countESign ventas (@(totalProds > 0 ? Math.Round(pctESign) : 0)%)</span>
                            </div>
                            <div class="product-track">
                                <div class="product-fill esign" style="width: @(pctESign.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </section>

        <!-- Filters card -->
        <section class="filters-card">
            @if (esVendedor)
            {
                <div class="filters-grid" style="grid-template-columns: 1fr;">
                    <div class="filter-input-wrap">
                        <i class="bi bi-search filter-input-icon"></i>
                        <input type="text" 
                               class="filter-input" 
                               placeholder="Buscar cliente por nombre, correo o cédula..." 
                               @bind="searchString" 
                               @bind:event="oninput"
                               @bind:after="OnFiltersChangedAsync" />
                    </div>
                </div>
            }
            else
            {
                <div class="filters-grid">
                    <div class="filter-input-wrap">
                        <i class="bi bi-search filter-input-icon"></i>
                        <input type="text" 
                               class="filter-input" 
                               placeholder="Buscar cliente, vendedor o plan..." 
                               @bind="searchString" 
                               @bind:event="oninput"
                               @bind:after="OnFiltersChangedAsync" />
                    </div>
                    <div>
                        <select class="filter-select" @bind="filterProducto" @bind:after="OnFiltersChangedAsync">
                            <option value="ALL">Todos los Productos</option>
                            <option value="e-fact">e-Fact (Documentos)</option>
                            <option value="e-sign">eRúbrica (Firmas)</option>
                        </select>
                    </div>
                    <div>
                        <select class="filter-select" @bind="filterCanal" @bind:after="OnFiltersChangedAsync">
                            <option value="ALL">Todos los Canales</option>
                            <option value="Web">Sistema Web</option>
                            <option value="Números Asesores">Números Asesores</option>
                        </select>
                    </div>
                    <div>
                        <select class="filter-select" @bind="filterEstado" @bind:after="OnFiltersChangedAsync">
                            <option value="ALL">Todos los Estados</option>
                            <option value="pendiente">Pendiente</option>
                            <option value="pagada">Pagada</option>
                            <option value="anulada">Anulada</option>
                        </select>
                    </div>
                </div>
            }
        </section>

        <!-- Sales Data Table / Clients Table -->
        <section class="table-card">
            <div class="table-wrap">
                @if (esVendedor)
                {
                    <table class="table ventas-table mb-0">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Identificación</th>
                                <th>Fecha Registro</th>
                                <th class="text-center">Compras</th>
                                <th class="text-end">Total Comprado</th>
                                <th>Estado</th>
                                <th class="text-center" style="width: 160px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!paginatedClientes.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                                        No se encontraron clientes registrados con tu enlace.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var c in paginatedClientes)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@c.Nombre</div>
                                            <div class="text-muted small">@c.Email</div>
                                        </td>
                                        <td>@c.Identificacion</td>
                                        <td>@(c.FechaRegistro?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                        <td class="text-center">@c.ComprasCount</td>
                                        <td class="text-end fw-bold text-success">$@c.TotalGastado.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</td>
                                        <td>
                                            @if (c.ComprasCount > 0)
                                            {
                                                <span class="status-badge pagada">
                                                    <i class="bi bi-check-circle-fill"></i> Activo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status-badge pendiente">
                                                    <i class="bi bi-clock-fill"></i> Inactivo
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn-row-action edit" @onclick="() => AbrirModalCompras(c)" title="Ver historial de compras">
                                                <i class="bi bi-eye"></i> Ver Compras
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <table class="table ventas-table mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Producto</th>
                                <th>Plan / Paquete</th>
                                <th class="text-end">Valor</th>
                                <th>Canal / Vendedor</th>
                                <th>Forma Pago</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!paginatedVentas.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-5">
                                        <div class="table-empty">
                                            <i class="bi bi-coin"></i>
                                            <strong>Sin registros de ventas</strong>
                                            <p class="text-muted font-sm mb-0">No se encontraron ventas para los filtros seleccionados.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var v in paginatedVentas)
                                {
                                    var parts = v.Cliente.Split('|');
                                    var clientName = parts[0].Trim();
                                    var clientEmail = parts.Length > 1 ? parts[1].Trim() : "";

                                    <tr>
                                        <td>
                                            <span class="fecha-text">@v.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                                        </td>
                                        <td>
                                            <div class="client-cell">
                                                <span class="client-name">@clientName</span>
                                                @if (!string.IsNullOrEmpty(clientEmail))
                                                {
                                                    <span class="client-email">@clientEmail</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="product-badge @(v.Producto == "e-fact" ? "efact" : "esign")">
                                                <i class="bi @(v.Producto == "e-fact" ? "bi-file-earmark-check-fill" : "bi-shield-check")"></i>
                                                @(v.Producto == "e-fact" ? "e-Fact" : "eRúbrica")
                                            </span>
                                        </td>
                                        <td>
                                            <strong class="text-dark">@v.PlanPaquete</strong>
                                        </td>
                                        <td class="text-end">
                                            <span class="valor-text">$@v.Valor.ToString("F2")</span>
                                        </td>
                                        <td>
                                            <div class="canal-cell">
                                                <i class="bi @(v.Canal == "Web" ? "bi-globe" : "bi-telephone-fill") canal-icon"></i>
                                                <div>
                                                    <span>@v.Canal</span>
                                                    @if (!string.IsNullOrWhiteSpace(v.Vendedor))
                                                    {
                                                        <span class="seller-name">Vendedor: @v.Vendedor</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="comprobante-cell">
                                                <span class="text-muted font-sm">@v.FormaPago</span>
                                                @if (HasComprobanteImage(v))
                                                {
                                                    <button type="button" class="btn-view-evidence" title="Ver captura de comprobante" @onclick="() => ShowEvidencePreview(v)">
                                                        <i class="bi bi-image"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="status-badge @(v.Estado == "pagada" ? "pagada" : v.Estado == "pendiente" ? "pendiente" : "anulada")">
                                                <i class="bi @(v.Estado == "pagada" ? "bi-check-circle-fill" : v.Estado == "pendiente" ? "bi-clock-fill" : v.Estado == "anulada" ? "bi-x-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                                                @v.Estado
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <div class="action-group">
                                                @if (v.Canal == "Web")
                                                {
                                                    <span class="automatic-badge">
                                                        <i class="bi bi-cpu"></i> Automática
                                                    </span>
                                                }
                                                else
                                                {
                                                    <div class="vertical-actions">
                                                        <button type="button" 
                                                                class="btn-row-action edit" 
                                                                title="Editar venta" 
                                                                @onclick="() => AbrirEditarModal(v)">
                                                            <i class="bi bi-pencil-square"></i>
                                                            <span>Editar</span>
                                                        </button>
                                                        @if (v.Estado != "anulada")
                                                        {
                                                            <button type="button" 
                                                                    class="btn-row-action void" 
                                                                    title="Anular venta" 
                                                                    @onclick="() => AnularVenta(v)">
                                                                <i class="bi bi-x-circle"></i>
                                                                <span>Anular</span>
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            </div>

            <!-- Pager -->
            <div class="pager-container">
                <span class="pager-info">
                    @if (esVendedor)
                    {
                        <span>Mostrando del @(filteredClientesAfiliadosList.Any() ? (currentPage - 1) * pageSize + 1 : 0) al @(Math.Min(currentPage * pageSize, filteredClientesAfiliadosList.Count)) de @filteredClientesAfiliadosList.Count registros</span>
                    }
                    else
                    {
                        <span>Mostrando del @(filteredVentas.Any() ? (currentPage - 1) * pageSize + 1 : 0) al @(Math.Min(currentPage * pageSize, filteredVentas.Count)) de @filteredVentas.Count registros</span>
                    }
                </span>
                <div class="pager-buttons">
                    <button type="button" class="pager-btn" disabled="@(currentPage == 1)" @onclick="() => SetPage(1)">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>
                    <button type="button" class="pager-btn" disabled="@(currentPage == 1)" @onclick="() => SetPage(currentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        var pageNumber = i;
                        <button type="button" class="pager-btn @(currentPage == pageNumber ? "active" : "")" @onclick="() => SetPage(pageNumber)">
                            @pageNumber
                        </button>
                    }
                    <button type="button" class="pager-btn" disabled="@(currentPage == totalPages || totalPages == 0)" @onclick="() => SetPage(currentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    <button type="button" class="pager-btn" disabled="@(currentPage == totalPages || totalPages == 0)" @onclick="() => SetPage(totalPages)">
                        <i class="bi bi-chevron-double-right"></i>
                    </button>
                </div>
            </div>
        </section>
    }
</div>

<!-- Modal Historial de Compras del Cliente -->
