    // Save/Update
    private async Task GuardarVenta()
    {
        if (esVendedor)
        {
            modalVenta.Vendedor = sellerName;
        }

        // Validation
        mostrarErrores = true;
        if (selectedUser == null) return;
        if (planSeleccionado == "CUSTOM" && string.IsNullOrWhiteSpace(modalVenta.PlanPaquete)) return;
        if (modalVenta.Valor < 0) return;
        if (string.IsNullOrWhiteSpace(modalVenta.Vendedor)) return;

        modalError = null;
        modalSuccess = null;
        isSaving = true;

        try
        {
            byte[]? fileBytes = null;

            // Handle image upload save if any
            if (selectedFile != null)
            {
                try
                {
                    using var stream = selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    fileBytes = ms.ToArray();
                }
                catch (Exception fileEx)
                {
                    modalError = $"Error al leer el archivo: {fileEx.Message}";
                    isSaving = false;
                    return;
                }
            }

            using var context = await DbFactory.CreateDbContextAsync();
            bool triggerActivation = false;

            if (editandoVentaId.HasValue)
            {
                // Modification: check if status changes to "pagada"
                var dbVenta = await context.ReporteVentasBackOffice.FindAsync(editandoVentaId.Value);
                if (dbVenta != null)
                {
                    if (dbVenta.Estado != "pagada" && modalVenta.Estado == "pagada")
                    {
                        triggerActivation = true;
                    }

                    // Copy new values with truncation
                    dbVenta.Cliente = TruncateStr(modalVenta.Cliente, 150);
                    dbVenta.Producto = TruncateStr(modalVenta.Producto, 50);
                    dbVenta.PlanPaquete = TruncateStr(modalVenta.PlanPaquete, 100);
                    dbVenta.Valor = modalVenta.Valor;
                    dbVenta.Fecha = modalVenta.Fecha;
                    dbVenta.Canal = TruncateStr(modalVenta.Canal, 50);
                    dbVenta.Vendedor = TruncateStr(modalVenta.Vendedor, 100);
                    dbVenta.Estado = TruncateStr(modalVenta.Estado, 50);
                    dbVenta.FormaPago = TruncateStr(modalVenta.FormaPago, 50);

                    // Update ComprobanteArchivo
                    if (fileBytes != null)
                    {
                        dbVenta.ComprobanteArchivo = fileBytes;
                    }
                    else if (modalVenta.ComprobanteArchivo == null)
                    {
                        dbVenta.ComprobanteArchivo = null;
                    }

                    var cleanObs = GetObservacionLimpia(modalVenta.Observacion);
                    var compTag = !string.IsNullOrWhiteSpace(comprobanteRef) ? $"[Comprobante: {comprobanteRef.Trim()}]" : "";

                    dbVenta.Observacion = TruncateStr($"{compTag} {cleanObs}".Trim(), 500);

                    await context.SaveChangesAsync();
                }
            }
            else
            {
                // Creation — truncate before persisting
                modalVenta.Cliente = TruncateStr(modalVenta.Cliente, 150);
                modalVenta.Producto = TruncateStr(modalVenta.Producto, 50);
                modalVenta.PlanPaquete = TruncateStr(modalVenta.PlanPaquete, 100);
                modalVenta.Canal = TruncateStr(modalVenta.Canal, 50);
                modalVenta.Vendedor = TruncateStr(modalVenta.Vendedor, 100);
                modalVenta.Estado = TruncateStr(modalVenta.Estado, 50);
                modalVenta.FormaPago = TruncateStr(modalVenta.FormaPago, 50);

                if (fileBytes != null)
                {
                    modalVenta.ComprobanteArchivo = fileBytes;
                }

                var cleanObs = GetObservacionLimpia(modalVenta.Observacion);
                var compTag = !string.IsNullOrWhiteSpace(comprobanteRef) ? $"[Comprobante: {comprobanteRef.Trim()}]" : "";

                modalVenta.Observacion = TruncateStr($"{compTag} {cleanObs}".Trim(), 500);

                if (modalVenta.Estado == "pagada")
                {
                    triggerActivation = true;
                }

                context.ReporteVentasBackOffice.Add(modalVenta);
                await context.SaveChangesAsync();
            }

            // License Activation if applicable
            if (triggerActivation)
            {
                await ActivarLicenciaUsuario(modalVenta);
            }

            modalSuccess = "¡Venta registrada exitosamente!";
            ShowFeedback("Venta guardada correctamente.", true);

            // Reload data in background
            await LoadVentasData();

            // Delay closing to show modalSuccess
            await Task.Delay(1200);
            mostrarModal = false;
            isSaving = false;
        }
        catch (Exception ex)
        {
            modalError = $"Error al guardar la venta: {ex.Message}";
            isSaving = false;
        }
    }

