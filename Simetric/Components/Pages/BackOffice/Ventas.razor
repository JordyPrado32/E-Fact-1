    // License Activation Core Logic
    private async Task ActivarLicenciaUsuario(ReporteVentaBackOffice venta)
    {
        var parts = venta.Cliente.Split('|');
        if (parts.Length < 2) return;
        var email = parts[1].Trim();

        using var context = await DbFactory.CreateDbContextAsync();
        var user = await context.Usuarios.FirstOrDefaultAsync(u => u.Email == email);
        if (user == null) return;

        if (venta.Producto == "e-sign")
        {
            // Activate / Renew eRúbrica subscription
            var service = await context.AppServicios.FirstOrDefaultAsync(s => s.Clave.ToLower().Contains("sign"));
            if (service == null) return;

            var sub = await context.UsuarioServicioSuscripciones
                .FirstOrDefaultAsync(s => s.IdUsuario == user.IdUsuario && s.ServicioId == service.ServicioId);

            if (sub == null)
            {
                sub = new UsuarioServicioSuscripcion
                {
                    IdUsuario = user.IdUsuario,
                    ServicioId = service.ServicioId,
                    FechaCreacion = DateTime.Now
                };
                context.UsuarioServicioSuscripciones.Add(sub);
            }

            sub.Estado = "ACTIVO";
            sub.FechaInicio = DateTime.Today;
            sub.PlanActual = venta.PlanPaquete;
            sub.FechaActualizacion = DateTime.Now;

            if (venta.PlanPaquete.Contains("Vitalicio", StringComparison.OrdinalIgnoreCase))
            {
                sub.EsVitalicia = true;
                sub.FechaFin = null;
                sub.CicloActual = "Vitalicio";
            }
            else
            {
                int years = 1;
                var matchYears = System.Text.RegularExpressions.Regex.Match(venta.PlanPaquete, @"\d+");
                if (matchYears.Success)
                {
                    years = int.Parse(matchYears.Value);
                }

                sub.EsVitalicia = false;
                var baseDate = (sub.FechaFin.HasValue && sub.FechaFin.Value > DateTime.Today) ? sub.FechaFin.Value : DateTime.Today;
                sub.FechaFin = baseDate.AddYears(years);
                sub.CicloActual = $"{years} {(years == 1 ? "Año" : "Años")}";
            }

            sub.Observacion = $"Activado automáticamente por venta pagada Ref #{venta.IdReporte}. Canal: {venta.Canal}. Forma de Pago: {venta.FormaPago}.";
            await context.SaveChangesAsync();
        }
        else if (venta.Producto == "e-fact")
        {
            // Activate e-Fact documents or Plan Ilimitado
            bool isIlimitado = venta.PlanPaquete.Contains("Ilimitado", StringComparison.OrdinalIgnoreCase);
            int docsCount = 0;

            if (!isIlimitado)
            {
                var match = System.Text.RegularExpressions.Regex.Match(venta.PlanPaquete, @"\d+");
                docsCount = match.Success ? int.Parse(match.Value) : 50; // default 50 if not parsed
                user.SaldoDocumentos += docsCount;
            }

            // Append to purchase history
            var history = LeerHistorial(user.HistorialComprasDocumentosJson);
            var newItem = new CompraDocumentosHistorialItem
            {
                Id = Guid.NewGuid().ToString("N"),
                Fecha = DateTime.Now,
                Documentos = docsCount,
                MontoTotal = venta.Valor,
                Estado = "Aprobado",
                Descripcion = $"Venta BackOffice: {venta.PlanPaquete} (Ref #{venta.IdReporte})",
                SaldoAplicado = true,
                EsIlimitado = isIlimitado,
                EsPermanente = true,
                VigenciaHasta = null
            };
            history.Insert(0, newItem);

            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            user.HistorialComprasDocumentosJson = JsonSerializer.Serialize(history, options);

            // If it is an unlimited plan, we also create/update an e-Fact subscription in USUARIO_SERVICIO_SUSCRIPCION table!
            if (isIlimitado)
            {
                var service = await context.AppServicios.FirstOrDefaultAsync(s => s.Clave.ToLower().Contains("fact"));
                if (service != null)
                {
                    var sub = await context.UsuarioServicioSuscripciones
                        .FirstOrDefaultAsync(s => s.IdUsuario == user.IdUsuario && s.ServicioId == service.ServicioId);

                    if (sub == null)
                    {
                        sub = new UsuarioServicioSuscripcion
                        {
                            IdUsuario = user.IdUsuario,
                            ServicioId = service.ServicioId,
                            FechaCreacion = DateTime.Now
                        };
                        context.UsuarioServicioSuscripciones.Add(sub);
                    }

                    sub.Estado = "ACTIVO";
                    sub.FechaInicio = DateTime.Today;
                    sub.EsVitalicia = true;
                    sub.FechaFin = null;
                    sub.PlanActual = "Plan Ilimitado";
                    sub.CicloActual = "Vitalicio";
                    sub.FechaActualizacion = DateTime.Now;
                    sub.Observacion = $"Activado automáticamente por plan ilimitado Ref #{venta.IdReporte}. Canal: {venta.Canal}. Forma de Pago: {venta.FormaPago}.";
                }
            }

            context.Entry(user).State = EntityState.Modified;
            await context.SaveChangesAsync();
        }
    }

    private List<CompraDocumentosHistorialItem> LeerHistorial(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<CompraDocumentosHistorialItem>();

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<CompraDocumentosHistorialItem>>(json, options) 
                   ?? new List<CompraDocumentosHistorialItem>();
        }
        catch
        {
            return new List<CompraDocumentosHistorialItem>();
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        selectedFile = e.File;
        if (selectedFile != null)
        {
            if (selectedFile.Size > 5 * 1024 * 1024)
            {
                uploadError = "El archivo supera el límite de 5 MB.";
                selectedFile = null;
                return;
            }
            if (!selectedFile.ContentType.StartsWith("image/"))
            {
                uploadError = "Solo se permiten archivos de imagen.";
                selectedFile = null;
                return;
            }
        }
    }

    private void RemoveSelectedFile()
    {
        selectedFile = null;
        uploadError = null;
    }

    private void EliminarComprobanteExistente()
    {
        modalVenta.ComprobanteArchivo = null;
        var cleanObs = GetObservacionLimpia(modalVenta.Observacion);
        var compRef = GetComprobanteRef(modalVenta.Observacion);
        var compTag = compRef != "S/N" ? $"[Comprobante: {compRef}]" : "";
        modalVenta.Observacion = $"{compTag} {cleanObs}".Trim();
    }

    private bool HasComprobanteImage(ReporteVentaBackOffice row)
    {
        if (row.ComprobanteArchivo != null && row.ComprobanteArchivo.Length > 0) return true;
        var obs = row.Observacion;
        if (string.IsNullOrEmpty(obs)) return false;
        return obs.Contains("[Imagen:") && obs.Contains("/uploads/comprobantes/");
    }

    private string GetEvidenceImageUrl(string? obs)
    {
        if (string.IsNullOrEmpty(obs)) return "";
        var startTag = "[Imagen:";
        var startIdx = obs.IndexOf(startTag);
        if (startIdx >= 0)
        {
            var contentStart = startIdx + startTag.Length;
            var endIdx = obs.IndexOf(']', contentStart);
            if (endIdx > contentStart)
            {
                return obs.Substring(contentStart, endIdx - contentStart).Trim();
            }
        }
        return "";
    }

    private string GetComprobanteRef(string? obs)
    {
        if (string.IsNullOrEmpty(obs)) return "S/N";
        if (obs.StartsWith("[Comprobante:"))
        {
            var endIdx = obs.IndexOf(']');
            if (endIdx > 13)
            {
                return obs.Substring(13, endIdx - 13).Trim();
            }
        }
        return "S/N";
    }

    private string GetObservacionLimpia(string? obs)
    {
        if (string.IsNullOrEmpty(obs)) return string.Empty;
        var workingObs = obs;
        
        // Remove Comprobante tag
        if (workingObs.StartsWith("[Comprobante:"))
        {
            var endIdx = workingObs.IndexOf(']');
            if (endIdx > 0)
            {
                workingObs = workingObs.Substring(endIdx + 1).Trim();
            }
        }

        // Remove Imagen tag
        var imgTagIdx = workingObs.IndexOf("[Imagen:");
        if (imgTagIdx >= 0)
        {
            var endIdx = workingObs.IndexOf(']', imgTagIdx);
            if (endIdx > 0)
            {
                workingObs = (workingObs.Substring(0, imgTagIdx) + workingObs.Substring(endIdx + 1)).Trim();
            }
        }

        return workingObs;
    }

    private void ShowEvidencePreview(ReporteVentaBackOffice row)
    {
        if (row.ComprobanteArchivo != null && row.ComprobanteArchivo.Length > 0)
        {
            var base64 = Convert.ToBase64String(row.ComprobanteArchivo);
            previewImageUrl = $"data:image/png;base64,{base64}";
        }
        else
        {
            previewImageUrl = GetEvidenceImageUrl(row.Observacion);
        }
    }

    private void CloseEvidencePreview()
    {
        previewImageUrl = null;
    }

    private void ShowFeedback(string message, bool isSuccess)
    {
        feedbackMessage = message;
        feedbackIsSuccess = isSuccess;
        
        // Auto-clear feedback after 8 seconds
        Task.Delay(8000).ContinueWith(_ => {
            feedbackMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private static string TruncateStr(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Length <= maxLength ? value : value[..maxLength];
    }

    private static bool CoincideClienteReporte(Usuario usuario, string? cliente)
    {
        if (string.IsNullOrWhiteSpace(cliente)) return false;
        var parts = cliente.Split('|');
        var emailPart = parts.Length > 1 ? parts[1].Trim() : "";

        // 1. Exact Email Match (most reliable)
        if (!string.IsNullOrWhiteSpace(usuario.Email) && !string.IsNullOrWhiteSpace(emailPart))
        {
            if (string.Equals(usuario.Email.Trim(), emailPart, StringComparison.OrdinalIgnoreCase))
                return true;
        }

        // 2. Contains Email fallback
        if (!string.IsNullOrWhiteSpace(usuario.Email) && cliente.Contains(usuario.Email.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    private static string ExtraerEmailClienteReporte(string? cliente)
    {
        if (string.IsNullOrWhiteSpace(cliente))
        {
            return string.Empty;
        }

        var parts = cliente.Split('|');
        if (parts.Length <= 1)
        {
            return string.Empty;
        }

        return parts[1].Trim();
    }

