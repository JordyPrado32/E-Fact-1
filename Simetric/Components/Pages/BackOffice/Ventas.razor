    private void RecalcularValorPlan()
    {
        if (modalVenta.Producto == "e-fact")
        {
            if (planSeleccionado == "CUSTOM")
            {
                if (customDocsCount < 1) customDocsCount = 1;
                modalVenta.Valor = EFactDocumentPricing.CalcularTotalPorCantidad(customDocsCount);
                modalVenta.PlanPaquete = $"{customDocsCount} {(customDocsCount == 1 ? "documento" : "documentos")}";
            }
            else
            {
                var plan = EFactBillingConfig.EFactPlans.FirstOrDefault(p => string.Equals(p.Nombre, planSeleccionado, StringComparison.OrdinalIgnoreCase));
                if (plan != null)
                {
                    modalVenta.Valor = plan.Precio;
                }
            }
        }
        else if (modalVenta.Producto == "e-sign")
        {
            modalVenta.Valor = planSeleccionado switch
            {
                "1 año" => 21.91m,
                "2 años" => 34.60m,
                "3 años" => 46.14m,
                "4 años" => 57.68m,
                _ => modalVenta.Valor
            };
        }
    }

