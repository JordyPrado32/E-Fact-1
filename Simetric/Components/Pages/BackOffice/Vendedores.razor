@code {
    private List<VendedorBackOffice> vendors = new();

    // crear
    private bool showModal;
    private bool showAvatarSelector;
    private bool mostrarClave;
    private bool saving;
    private string? errorModal;
    private string? selectedAvatar;
    private string? nuevoNombres;
    private string? nuevoApellidos;
    private string? nuevoEmail;
    private string? nuevaClave;
    private List<string> avatarFiles = new();

    // editar
    private bool showEditModal;
    private VendedorBackOffice? vendorEditando;
    private int editUsuarioId;
    private string? editNombre;
    private string? editNombres;
    private string? editApellidos;
    private string? editEmail;
    private string? editNuevaClave;
    private bool mostrarClaveEdit;
    private string? editSelectedAvatar;
    private bool showEditAvatarSelector;

    // bloquear
    private bool showBloqueoModal;
    private VendedorBackOffice? vendorBloqueo;

    // qr modal
    private bool showQrModal;
    private string qrModalNombre = string.Empty;
    private string qrModalLink = string.Empty;

    // feedback
    private bool success;
    private string? message;
    private bool esVendedor;
    private bool isLoading = true;
    private readonly Dictionary<string, string> qrCache = new(StringComparer.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        await VendedorBackOfficeService.EnsureSchemaAsync();
        await VendedorBackOfficeService.ObtenerSistemaAsync();
        await CargarAsync();
        CargarAvatares();
    }

    private void CargarAvatares()
    {
        try
        {
            var path = Path.Combine(WebHostEnvironment.WebRootPath, "images", "avatars");
            if (!Directory.Exists(path)) return;
            avatarFiles = Directory.GetFiles(path)
                .Select(Path.GetFileName)
                .Where(f => !string.IsNullOrWhiteSpace(f) &&
                            (f!.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                             f.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                             f.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)))
                .OrderBy(f => string.Equals(f, "default.png", StringComparison.OrdinalIgnoreCase) ? 0 : 1)
                .ThenBy(f => f, StringComparer.OrdinalIgnoreCase)
                .ToList()!;
        }
        catch { }
    }

    // ── Modal Crear ──
    private void AbrirModal()
    {
        nuevoNombres = string.Empty; nuevoApellidos = string.Empty;
        nuevoEmail = string.Empty; nuevaClave = string.Empty;
        selectedAvatar = null; mostrarClave = false;
        showAvatarSelector = false; errorModal = null; showModal = true;
    }
    private void CerrarModal() { showModal = false; showAvatarSelector = false; errorModal = null; mostrarClave = false; }
    private void ToggleAvatarSelector() => showAvatarSelector = !showAvatarSelector;
    private void SeleccionarAvatar(string url) { selectedAvatar = url; showAvatarSelector = false; }
    private void ToggleMostrarClave() => mostrarClave = !mostrarClave;
    private void AbrirQrModal(string nombre, string link) { qrModalNombre = nombre; qrModalLink = link; showQrModal = true; }
    private void CerrarQrModal() { showQrModal = false; }

    // ── Modal Editar ──
    private async Task AbrirEditar(VendedorBackOffice v)
    {
        vendorEditando = v;
        editNombre = v.Nombre;
        editNombres = string.Empty;
        editApellidos = string.Empty;
        editEmail = string.Empty;
        editNuevaClave = string.Empty;
        mostrarClaveEdit = false;
        editSelectedAvatar = null;
        showEditAvatarSelector = false;
        errorModal = null;
        editUsuarioId = 0;

        await using var ctx = await DbFactory.CreateDbContextAsync();

        // 1) Intentar por CodigoReferencia: usr_{id}
        if (v.CodigoReferencia?.StartsWith("usr_", StringComparison.OrdinalIgnoreCase) == true &&
            int.TryParse(v.CodigoReferencia[4..], out var uid) && uid > 0)
        {
            var u = await ctx.Usuarios.FindAsync(uid);
            if (u != null)
            {
                editUsuarioId = uid;
                editNombres   = u.Nombres  ?? string.Empty;
                editApellidos = u.Apellidos ?? string.Empty;
                editEmail     = u.Email     ?? string.Empty;
                editSelectedAvatar = u.AvatarUrl;
                showEditModal = true;
                return;
            }
        }

        // 2) Fallback: buscar por nombre en Usuarios (para vendedores sin CodigoReferencia usr_)
        {
            var parts = v.Nombre.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
            editNombres   = parts.Length > 0 ? parts[0] : v.Nombre;
            editApellidos = parts.Length > 1 ? parts[1] : string.Empty;
        }

        showEditModal = true;
    }

    private void CerrarEditar()
    {
        showEditModal = false; vendorEditando = null; errorModal = null;
        mostrarClaveEdit = false; showEditAvatarSelector = false;
    }
    private void ToggleEditAvatarSelector() => showEditAvatarSelector = !showEditAvatarSelector;
    private void SeleccionarEditAvatar(string url) { editSelectedAvatar = url; showEditAvatarSelector = false; }
    private void ToggleMostrarClaveEdit() => mostrarClaveEdit = !mostrarClaveEdit;

    private async Task GuardarEdicion()
    {
        if (vendorEditando == null) return;

        var nombresVal    = (editNombres    ?? string.Empty).Trim();
        var apellidosVal  = (editApellidos  ?? string.Empty).Trim();
        var emailVal      = (editEmail      ?? string.Empty).Trim();
        var passVal       = (editNuevaClave ?? string.Empty).Trim();
        var nombreCompleto = $"{nombresVal} {apellidosVal}".Trim();

        if (nombresVal.Length < 1) { errorModal = "El nombre es obligatorio."; return; }

        // Email requerido solo cuando no hay Usuario vinculado aún
        bool tieneEmail = !string.IsNullOrWhiteSpace(emailVal);
        if (tieneEmail && !EsCorreoValido(emailVal)) { errorModal = "El correo ingresado no es válido."; return; }

        // Si hay email pero no Usuario vinculado → necesita contraseña para crear la cuenta
        if (tieneEmail && editUsuarioId == 0 && string.IsNullOrWhiteSpace(passVal))
        {
            errorModal = "Para vincular un correo nuevo debes ingresar una contraseña (mínimo 8 caracteres).";
            return;
        }
        if (!string.IsNullOrWhiteSpace(passVal) && passVal.Length < 8)
        {
            errorModal = "La contraseña debe tener al menos 8 caracteres.";
            return;
        }

        saving = true; errorModal = null; message = null; success = false;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            string? correoBienvenidaPendiente = null;
            string? nombreBienvenidaPendiente = null;
            int? idUsuarioBienvenidaPendiente = null;
            string? codigoAccesoPendiente = null;

            // ── A) Actualizar nombre del VendedorBackOffice ──
            var vend = await ctx.VendedoresBackOffice.FindAsync(vendorEditando.IdVendedor);
            if (vend != null) vend.Nombre = nombreCompleto;

            // ── B) Usuario vinculado existente ──
            if (editUsuarioId > 0)
            {
                if (tieneEmail)
                {
                    var emailTaken = await ctx.Usuarios.AnyAsync(u => u.Estado == true && u.Email == emailVal && u.IdUsuario != editUsuarioId);
                    if (emailTaken) { errorModal = "Ya existe otro usuario con ese correo."; saving = false; return; }
                }

                var usr = await ctx.Usuarios.FindAsync(editUsuarioId);
                if (usr != null)
                {
                    var emailAnterior = usr.Email?.Trim() ?? string.Empty;
                    var correoCambio = tieneEmail &&
                        !string.Equals(emailAnterior, emailVal, StringComparison.OrdinalIgnoreCase);
                    var claveCambio = !string.IsNullOrWhiteSpace(passVal);

                    usr.Nombres   = nombresVal;
                    usr.Apellidos = apellidosVal;
                    if (tieneEmail) usr.Email = emailVal;
                    usr.AvatarUrl = editSelectedAvatar;
                    if (claveCambio)
                    {
                        usr.PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(passVal);
                        usr.ClaveTemporal = false;
                    }

                    if (correoCambio || claveCambio)
                    {
                        correoBienvenidaPendiente = tieneEmail ? emailVal : emailAnterior;
                        nombreBienvenidaPendiente = nombreCompleto;
                        idUsuarioBienvenidaPendiente = usr.IdUsuario;
                        codigoAccesoPendiente = claveCambio ? passVal : null;
                    }
                }
            }
            // ── C) Crear Usuario nuevo y vincularlo ──
            else if (tieneEmail && !string.IsNullOrWhiteSpace(passVal))
            {
                var emailTaken = await ctx.Usuarios.AnyAsync(u => u.Estado == true && u.Email == emailVal);
                if (emailTaken) { errorModal = "Ya existe un usuario con ese correo."; saving = false; return; }

                var newUser = new Usuario
                {
                    Nombres          = nombresVal,
                    Apellidos        = apellidosVal,
                    Email            = emailVal,
                    PasswordHash     = Simetric.Components.Helpers.SecurityHelper.HashPassword(passVal),
                    IdTipoUsuario    = 7,
                    TipoCliente      = 2,
                    Estado           = true,
                    NombreEmpresa    = "Backoffice",
                    DireccionEmpresa = "Backoffice",
                    ClaveTemporal    = false,
                    AvatarUrl        = editSelectedAvatar,
                    FechaCreacion    = DateTime.Now
                };
                ctx.Usuarios.Add(newUser);
                await ctx.SaveChangesAsync(); // necesitamos el IdUsuario generado

                // Actualizar CodigoReferencia del vendedor para vincularlo
                if (vend != null) vend.CodigoReferencia = $"usr_{newUser.IdUsuario}";
                correoBienvenidaPendiente = emailVal;
                nombreBienvenidaPendiente = nombreCompleto;
                idUsuarioBienvenidaPendiente = newUser.IdUsuario;
                codigoAccesoPendiente = passVal;
            }

            await ctx.SaveChangesAsync();
            if (!string.IsNullOrWhiteSpace(correoBienvenidaPendiente) &&
                idUsuarioBienvenidaPendiente.HasValue &&
                !string.IsNullOrWhiteSpace(codigoAccesoPendiente))
            {
                var (correoEnviado, errorCorreo) = await EnviarCorreoBienvenidaVendedorAsync(correoBienvenidaPendiente, nombreBienvenidaPendiente ?? nombreCompleto, idUsuarioBienvenidaPendiente.Value, codigoAccesoPendiente);
                success = correoEnviado;
                message = correoEnviado
                    ? $"Perfil de \"{nombreCompleto}\" actualizado correctamente y correo enviado a {correoBienvenidaPendiente}."
                    : $"Perfil de \"{nombreCompleto}\" actualizado, pero no se pudo enviar el correo a {correoBienvenidaPendiente}: {errorCorreo}";
            }

            if (string.IsNullOrWhiteSpace(message))
            {
                success = true;
                message = $"Perfil de \"{nombreCompleto}\" actualizado correctamente.";
            }
            CerrarEditar();
            await CargarAsync();
        }
        catch (Exception ex) { errorModal = $"Error al guardar: {ex.Message}"; }
        finally { saving = false; }
    }


    // ── Modal Bloquear ──
    private void AbrirBloqueo(VendedorBackOffice v) { vendorBloqueo = v; showBloqueoModal = true; }
    private void CerrarBloqueo() { showBloqueoModal = false; vendorBloqueo = null; }

    private async Task ConfirmarBloqueo()
    {
        if (vendorBloqueo == null) return;
        saving = true;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var v = await ctx.VendedoresBackOffice.FindAsync(vendorBloqueo.IdVendedor);
            if (v != null)
            {
                v.Activo = !v.Activo;
                await ctx.SaveChangesAsync();
                success = true;
                message = v.Activo
                    ? $"\"{v.Nombre}\" fue activado correctamente."
                    : $"\"{v.Nombre}\" fue bloqueado. Su enlace dejará de funcionar.";
            }
            CerrarBloqueo();
            await CargarAsync();
        }
        catch (Exception ex) { message = $"Error: {ex.Message}"; success = false; CerrarBloqueo(); }
        finally { saving = false; }
    }

    private async Task CargarAsync()
    {
        isLoading = true;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var role = user.FindFirst("IdTipoUsuario")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        var tipoCliente = user.FindFirst("TipoCliente")?.Value;
        var nombreCompleto = user.Identity?.Name ?? "Vendedor";

        var idUsuario = int.TryParse(user.FindFirst("IdUsuario")?.Value, out var id) ? id : 0;
        if (idUsuario > 0)
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            var dbUser = await context.Usuarios.FindAsync(idUsuario);
            if (dbUser != null)
            {
                role = dbUser.IdTipoUsuario?.ToString() ?? role;
                tipoCliente = dbUser.TipoCliente?.ToString() ?? tipoCliente;
                nombreCompleto = $"{dbUser.Nombres} {dbUser.Apellidos}".Trim();
                if (string.IsNullOrWhiteSpace(nombreCompleto))
                    nombreCompleto = dbUser.Email ?? "Vendedor";
            }
        }

        esVendedor = string.Equals(role, "7", StringComparison.OrdinalIgnoreCase) &&
                     string.Equals(tipoCliente, "2", StringComparison.OrdinalIgnoreCase);

        var allVendors = await VendedorBackOfficeService.ListarAsync();

        if (esVendedor)
        {
            var sellerProfile = await VendedorBackOfficeService.ObtenerPerfilUsuarioAsync(idUsuario, nombreCompleto);
            vendors = sellerProfile is null ? new List<VendedorBackOffice>() : new List<VendedorBackOffice> { sellerProfile };
        }
        else
        {
            await using var filterContext = await DbFactory.CreateDbContextAsync();
            var linkedUserIds = allVendors
                .Where(v => v.CodigoReferencia?.StartsWith("usr_", StringComparison.OrdinalIgnoreCase) == true)
                .Select(v => int.TryParse(v.CodigoReferencia![4..], out var uid) ? uid : 0)
                .Where(uid => uid > 0)
                .Distinct()
                .ToList();

            var sellerUserIds = linkedUserIds.Count == 0
                ? new HashSet<int>()
                : await filterContext.Usuarios
                    .AsNoTracking()
                    .Where(u => linkedUserIds.Contains(u.IdUsuario) && u.IdTipoUsuario == 7 && u.TipoCliente == 2)
                    .Select(u => u.IdUsuario)
                    .ToHashSetAsync();

            vendors = allVendors
                .Where(v =>
                    v.EsSistema ||
                    v.CodigoReferencia?.StartsWith("usr_", StringComparison.OrdinalIgnoreCase) != true ||
                    (int.TryParse(v.CodigoReferencia[4..], out var uid) && sellerUserIds.Contains(uid)))
                .ToList();
        }

        isLoading = false;
    }

    private async Task CrearAsync()
    {
        saving = true; errorModal = null; message = null; success = false;

        var nombresVal = (nuevoNombres ?? string.Empty).Trim();
        var apellidosVal = (nuevoApellidos ?? string.Empty).Trim();
        var emailVal = (nuevoEmail ?? string.Empty).Trim();
        var passVal = (nuevaClave ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(nombresVal)) { errorModal = "El nombre es obligatorio."; saving = false; return; }
        if (string.IsNullOrWhiteSpace(emailVal) || !EsCorreoValido(emailVal)) { errorModal = "Ingresa un correo válido."; saving = false; return; }
        if (string.IsNullOrWhiteSpace(passVal) || passVal.Length < 8) { errorModal = "La contraseña debe tener al menos 8 caracteres."; saving = false; return; }

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            if (await context.Usuarios.AnyAsync(u => u.Estado == true && u.Email == emailVal)) { errorModal = "Ya existe un usuario con ese correo."; saving = false; return; }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var currentUser = authState.User;
            var currentUserId = int.TryParse(currentUser.FindFirst("IdUsuario")?.Value, out var id) ? id : 0;
            var nameVal = $"{nombresVal} {apellidosVal}".Trim();

            var dbUser = new Usuario
            {
                Nombres = nombresVal, Apellidos = apellidosVal, Email = emailVal,
                PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(passVal),
                IdTipoUsuario = 7, TipoCliente = 2, Estado = true,
                NombreEmpresa = "Backoffice", DireccionEmpresa = "Backoffice",
                ClaveTemporal = false, AvatarUrl = selectedAvatar, FechaCreacion = DateTime.Now
            };
            context.Usuarios.Add(dbUser);
            await context.SaveChangesAsync();

            context.VendedoresBackOffice.Add(new VendedorBackOffice
            {
                Nombre = nameVal, CodigoReferencia = $"usr_{dbUser.IdUsuario}",
                Activo = true, EsSistema = false,
                IdUsuarioCreacion = currentUserId > 0 ? currentUserId : null,
                FechaCreacion = DateTime.Now
            });
            await context.SaveChangesAsync();

            var (correoEnviado, errorCorreo) = await EnviarCorreoBienvenidaVendedorAsync(emailVal, nameVal, dbUser.IdUsuario, passVal);
            success = correoEnviado;
            message = correoEnviado
                ? $"Vendedor \"{nameVal}\" creado correctamente y correo enviado a {emailVal}."
                : $"Vendedor \"{nameVal}\" creado correctamente, pero no se pudo enviar el correo a {emailVal}: {errorCorreo}";
            CerrarModal();
            await CargarAsync();
        }
        catch (Exception ex) { errorModal = $"Error al crear: {ex.Message}"; }
        finally { saving = false; }
    }

    private async Task<(bool Enviado, string? Error)> EnviarCorreoBienvenidaVendedorAsync(string email, string nombreVendedor, int idUsuario, string codigoAcceso)
    {
        try
        {
            var loginUrl = NavManager.ToAbsoluteUri("/login").ToString();
            await EmailService.EnviarBienvenidaVendedorBackOfficeAsync(
                email,
                nombreVendedor,
                loginUrl,
                email,
                codigoAcceso,
                null,
                null);
            return (true, null);
        }
        catch (Exception ex)
        {
            return (false, ex.GetBaseException().Message);
        }
    }

