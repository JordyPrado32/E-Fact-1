    private static string ObtenerMensajeCopiado(string nombreVendedor, bool esCodigo) =>
        esCodigo ? $"Código secreto de {nombreVendedor} copiado." : $"Link de {nombreVendedor} copiado.";

    private async Task DescargarQrAsync(string nombreVendedor, string enlace)
    {
        var qr = ObtenerQrVendedor(enlace);
        var nombreArchivo = $"qr-{SanitizarNombreArchivo(nombreVendedor)}.png";

        await JS.InvokeVoidAsync(
            "numericaUi.downloadVendorQrCard",
            "/images/QR.png",
            qr,
            nombreVendedor,
            nombreArchivo);

        await JS.ShowToastAsync($"QR de {nombreVendedor} descargado.");
    }

    private static string SanitizarNombreArchivo(string valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
        {
            return "vendedor";
        }

        var invalidos = Path.GetInvalidFileNameChars();
        var limpio = new string(valor
            .Trim()
            .Select(ch => invalidos.Contains(ch) ? '-' : ch)
            .ToArray());

        return string.IsNullOrWhiteSpace(limpio) ? "vendedor" : limpio.Replace(' ', '-');
    }

