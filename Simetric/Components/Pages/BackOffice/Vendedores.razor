@page "/backoffice/vendedores"
@attribute [Authorize]
@layout Simetric.Components.Layout.BackOfficeLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using QRCoder
@using Simetric.Components
@using Simetric.Components.Helpers
@using Simetric.Models
@using Simetric.Services
@using Microsoft.EntityFrameworkCore
@using System.IO
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject VendedorBackOfficeService VendedorBackOfficeService
@inject IDbContextFactory<Simetric.Data.AppDbContext> DbFactory
@inject IWebHostEnvironment WebHostEnvironment
@inject IEmailService EmailService

<PageTitle>Vendedores | BackOffice</PageTitle>

<style>
    /* ── Page shell ── */
    .vp-page { display:grid; gap:1.5rem; }

    /* ── Hero ── */
    .vp-hero {
        background:#0d1f3f;
        border-radius:28px; padding:1.75rem 2rem;
        display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;
        box-shadow:0 24px 56px rgba(13,31,63,.26);
    }
    .vp-hero-copy { display:grid; gap:.35rem; }
    .vp-hero-kicker {
        font-size:.72rem; font-weight:800; letter-spacing:.15em; text-transform:uppercase;
        color:rgba(255,255,255,.55);
    }
    .vp-hero h2 { margin:0; color:#fff; font-size:1.55rem; }
    .vp-hero-note { color:rgba(255,255,255,.65); font-size:.9rem; max-width:540px; margin:0; }

    /* ── Feedback banner ── */
    .vp-banner {
        border-radius:16px; padding:.95rem 1.2rem; font-weight:600; font-size:.93rem;
        display:flex; align-items:center; gap:.65rem;
    }
    .vp-banner.ok { background:linear-gradient(135deg,#d1faed,#a7f3d0); color:#065f46; border:1px solid #6ee7b7; }
    .vp-banner.err { background:linear-gradient(135deg,#fee2e2,#fecaca); color:#991b1b; border:1px solid #fca5a5; }

    /* ── Vendors grid ── */
    .vp-grid { display:grid; gap:1.25rem; }
    .vp-empty {
        background:#fff; border:2px dashed #d0e3f7; border-radius:24px; padding:3rem;
        text-align:center; color:#7b93ae;
    }
    .vp-empty i { font-size:2.8rem; display:block; margin-bottom:.75rem; color:#b8cde4; }

    /* ── Vendor card ── */
    .vc {
        background:#fff;
        border:1px solid rgba(180,210,240,.7);
        border-radius:28px;
        box-shadow:0 12px 40px rgba(14,35,72,.07);
        overflow:hidden;
        transition:box-shadow .22s, transform .22s;
    }
    .vc:hover { box-shadow:0 20px 56px rgba(14,35,72,.13); transform:translateY(-2px); }
    .vc.blocked { opacity:.65; border-style:dashed; }

    /* card header strip */
    .vc-header {
        display:flex; align-items:center; gap:1rem;
        padding:1.25rem 1.4rem;
        background:linear-gradient(135deg,#f5f9ff,#edf3fd);
        border-bottom:1px solid rgba(200,220,245,.8);
    }
    .vc-avatar {
        width:52px; height:52px; border-radius:16px; flex-shrink:0;
        background:linear-gradient(135deg,#0b67c2,#1f9cff);
        display:flex; align-items:center; justify-content:center;
        font-size:1.35rem; font-weight:800; color:#fff;
        box-shadow:0 8px 20px rgba(11,103,194,.28);
        letter-spacing:0;
    }
    .vc-avatar img {
        width:100%; height:100%; object-fit:cover; border-radius:14px;
    }
    .vc-meta { flex:1; min-width:0; display:grid; gap:.3rem; }
    .vc-name { margin:0; font-size:1.05rem; font-weight:700; color:#112a4e; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .vc-badges { display:flex; flex-wrap:wrap; gap:.4rem; }
    .vc-code {
        display:inline-flex; align-items:center; padding:.18rem .55rem; border-radius:999px;
        background:#e0eeff; color:#0b5ebb; font-size:.76rem; font-weight:700;
    }
    .vc-status-active {
        display:inline-flex; align-items:center; gap:.3rem; padding:.18rem .55rem; border-radius:999px;
        background:#d1fae5; color:#065f46; font-size:.76rem; font-weight:700;
    }
    .vc-status-blocked {
        display:inline-flex; align-items:center; gap:.3rem; padding:.18rem .55rem; border-radius:999px;
        background:#fee2e2; color:#991b1b; font-size:.76rem; font-weight:700;
    }
    .vc-status-system {
        display:inline-flex; align-items:center; gap:.3rem; padding:.18rem .55rem; border-radius:999px;
        background:#ede9fe; color:#5b21b6; font-size:.76rem; font-weight:700;
    }
    .vc-date { font-size:.78rem; color:#7b93ae; }

    /* header action buttons */
    .vc-actions { display:flex; gap:.5rem; flex-shrink:0; }
    .vc-btn {
        border:none; border-radius:12px; padding:.55rem .85rem;
        display:inline-flex; align-items:center; gap:.38rem;
        font-size:.82rem; font-weight:700; cursor:pointer;
        transition:all .18s;
    }
    .vc-btn-edit { background:#e8f2ff; color:#0b67c2; }
    .vc-btn-edit:hover { background:#0b67c2; color:#fff; }
    .vc-btn-block { background:#fff0f0; color:#b91c1c; }
    .vc-btn-block:hover { background:#b91c1c; color:#fff; }
    .vc-btn-unblock { background:#d1fae5; color:#065f46; }
    .vc-btn-unblock:hover { background:#059669; color:#fff; }
    .vc-btn-view { background:#f0f4ff; color:#4338ca; }
    .vc-btn-view:hover { background:#4338ca; color:#fff; }

    /* card body: share + qr */
    .vc-body {
        position:relative;
        display:grid; grid-template-columns:minmax(0,1fr) minmax(260px,320px);
        gap:1rem; align-items:stretch;
        padding:1rem;
        background:
            radial-gradient(circle at top right, rgba(31,156,255,.13), transparent 34%),
            radial-gradient(circle at bottom left, rgba(13,103,194,.10), transparent 30%),
            linear-gradient(180deg,#fbfdff 0%,#f3f8ff 100%);
    }
    .vc-body::after {
        content:"";
        position:absolute;
        inset:18px;
        border-radius:24px;
        border:1px solid rgba(255,255,255,.72);
        pointer-events:none;
    }

    /* qr panel */
    .vc-qr {
        position:relative;
        display:flex; flex-direction:column; align-items:center; justify-content:center;
        gap:.85rem; padding:1.35rem 1.25rem;
        background:linear-gradient(180deg,#ffffff 0%,#f7fbff 100%);
        border:1px solid rgba(195,220,247,.92);
        border-radius:24px;
        box-shadow:0 18px 40px rgba(11,103,194,.10);
        overflow:hidden;
    }
    .vc-qr::before {
        content:"";
        position:absolute;
        inset:auto -25% 72% auto;
        width:180px; height:180px;
        border-radius:50%;
        background:radial-gradient(circle, rgba(31,156,255,.20) 0%, rgba(31,156,255,0) 70%);
        pointer-events:none;
    }
    .vc-qr-badge {
        position:relative;
        display:inline-flex; align-items:center; gap:.38rem;
        padding:.38rem .72rem;
        border-radius:999px;
        background:rgba(11,103,194,.08);
        color:#0b67c2;
        font-size:.72rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;
    }
    .vc-qr-frame {
        position:relative;
        display:grid; place-items:center;
        width:240px; height:240px;
        border-radius:30px;
        padding:.9rem;
        background:
            linear-gradient(135deg, rgba(255,255,255,.98), rgba(240,248,255,.96)),
            linear-gradient(135deg,#60a5fa,#0b67c2);
        box-shadow:
            0 24px 50px rgba(11,103,194,.16),
            inset 0 1px 0 rgba(255,255,255,.95);
        border:1px solid rgba(171,209,247,.95);
        cursor:pointer;
        transition:transform .18s ease, box-shadow .18s ease;
    }
    .vc-qr-frame:hover { transform:scale(1.02); box-shadow:0 28px 55px rgba(11,103,194,.20), inset 0 1px 0 rgba(255,255,255,.95); }
    .vc-qr-frame::after {
        content:"";
        position:absolute;
        inset:10px;
        border-radius:22px;
        border:1px solid rgba(201,226,250,.95);
        pointer-events:none;
    }
    .vc-qr-img {
        width:100%; height:100%; border-radius:22px; object-fit:contain;
        background:#fff; padding:.7rem;
        box-shadow:0 10px 26px rgba(15,28,63,.12); border:1px solid #d0e4ff;
    }
    .vc-qr-caption { font-size:.8rem; color:#58718f; text-align:center; line-height:1.45; max-width:220px; margin:0; }

    /* share panel */
    .vc-share {
        display:grid; gap:1rem; padding:1.35rem;
        align-content:center;
        background:linear-gradient(180deg,#f9fcff 0%,#eef6ff 100%);
        border-radius:24px;
        color:#163455;
        box-shadow:0 18px 36px rgba(11,103,194,.08);
        border:1px solid rgba(195,220,247,.92);
        position:relative;
        overflow:hidden;
    }
    .vc-share::before {
        content:"";
        position:absolute;
        inset:-35% auto auto -10%;
        width:220px; height:220px;
        border-radius:50%;
        background:radial-gradient(circle, rgba(88,190,255,.18) 0%, rgba(88,190,255,0) 70%);
        pointer-events:none;
    }
    .vc-share > * { position:relative; z-index:1; }
    .vc-share-kicker {
        font-size:.72rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase;
        color:#5b7ba3;
    }
    .vc-share-title {
        margin:0;
        font-size:1.2rem;
        font-weight:800;
        color:#fff;
    }
    .vc-share-note {
        margin:0;
        font-size:.9rem;
        line-height:1.5;
        color:rgba(220,234,252,.84);
        max-width:520px;
    }
    .vc-linkbox {
        background:linear-gradient(180deg,#f7fbff 0%,#edf5ff 100%);
        color:#163455;
        border:1px solid rgba(182,215,247,.70);
        border-radius:20px; padding:1rem 1.05rem;
        word-break:break-all; font-size:.9rem; line-height:1.6;
        box-shadow:inset 0 1px 0 rgba(255,255,255,.85);
    }
    .vc-link-label {
        display:block;
        margin-bottom:.45rem;
        font-size:.72rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;
        color:#6c88ab;
    }
    .vc-link-value {
        display:block;
        font-weight:700;
        color:#173a66;
    }
    .vc-copy-row { display:flex; flex-wrap:wrap; gap:.65rem; }
    .vc-copy-btn {
        border:none; border-radius:12px; padding:.55rem .85rem;
        display:inline-flex; align-items:center; gap:.38rem;
        font-size:.82rem; font-weight:700; cursor:pointer; transition:all .18s;
    }
    .vc-copy-btn.primary { background:linear-gradient(135deg,#0b67c2,#1f9cff); color:#fff; box-shadow:0 8px 18px rgba(11,103,194,.22); }
    .vc-copy-btn.primary:hover { transform:translateY(-1px); box-shadow:0 12px 24px rgba(11,103,194,.3); }
    .vc-copy-btn.secondary {
        background:#ffffff;
        color:#0b67c2;
        border:1px solid rgba(171,209,247,.95);
    }
    .vc-copy-btn.secondary:hover {
        background:#eff7ff;
        transform:translateY(-1px);
    }
    .vp-modal-qr { width:min(760px,100%); }
    .vp-qr-modal-body {
        display:grid;
        gap:1.1rem;
        justify-items:center;
        padding:1.6rem;
        background:linear-gradient(180deg,#f8fbff 0%,#eef5ff 100%);
    }
    .vp-qr-modal-frame {
        display:grid;
        place-items:center;
        width:min(100%,520px);
        aspect-ratio:1;
        padding:1rem;
        border-radius:32px;
        background:#fff;
        border:1px solid #d7e8fb;
        box-shadow:0 22px 55px rgba(11,103,194,.14);
    }
    .vp-qr-modal-frame img {
        width:100%;
        height:100%;
        object-fit:contain;
        border-radius:22px;
    }
    .vp-qr-modal-name {
        font-size:1.15rem;
        font-weight:800;
        color:#163455;
        text-align:center;
        margin:0;
    }

    /* ── Shared modal styles ── */
    .vp-backdrop {
        position:fixed; inset:0; background:rgba(10,26,47,.54);
        backdrop-filter:blur(6px); z-index:1040;
    }
    .vp-modal {
        position:fixed; inset:0; display:flex; align-items:center;
        justify-content:center; padding:1.5rem; z-index:1050;
    }
    .vp-modal-content {
        background:#fff; border-radius:28px; width:min(880px,100%);
        box-shadow:0 32px 80px rgba(10,26,60,.18);
        display:flex; flex-direction:column; max-height:90vh; overflow:hidden;
    }
    .vp-modal-sm { width:min(460px,100%); }
    .vp-modal-header {
        display:flex; align-items:center; justify-content:space-between;
        padding:1.4rem 1.6rem; border-radius:28px 28px 0 0;
    }
    .vp-modal-header.blue { background:#0f1c3f; color:#fff; }
    .vp-modal-header.blue h3 { color:#fff; margin:0; }
    .vp-modal-header.blue .vp-modal-kicker {
        font-size:.72rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase;
        color:rgba(255,255,255,.55); display:block; margin-bottom:.2rem;
    }
    .vp-modal-header.danger { background:linear-gradient(135deg,#7f1d1d,#b91c1c); color:#fff; }
    .vp-modal-header.danger h3 { color:#fff; margin:0; }
    .vp-modal-header.danger .vp-modal-kicker {
        font-size:.72rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase;
        color:rgba(255,200,200,.7); display:block; margin-bottom:.2rem;
    }
    .vp-modal-close {
        background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2);
        border-radius:12px; color:#fff; width:36px; height:36px;
        display:flex; align-items:center; justify-content:center;
        cursor:pointer; font-size:1rem; transition:background .2s;
    }
    .vp-modal-close:hover { background:rgba(255,255,255,.24); }
    .vp-modal-body { padding:1.6rem; overflow-y:auto; flex:1; }
    .vp-modal-footer {
        display:flex; justify-content:flex-end; gap:.75rem;
        padding:1rem 1.6rem; border-top:1px solid #e7edf5;
        background:#f7fafd; border-radius:0 0 28px 28px;
    }

    /* form inside modal */
    .vp-form-layout { display:grid; grid-template-columns:200px 1fr; gap:1.5rem; align-items:start; }
    .vp-avatar-panel {
        display:flex; flex-direction:column; align-items:center; gap:.85rem;
        background:#f5f9ff; border:1px solid #dce8f7; border-radius:20px; padding:1.1rem;
    }
    .vp-avatar-preview-wrap { position:relative; display:inline-block; }
    .vp-avatar-preview {
        width:90px; height:90px; border-radius:50%; object-fit:cover;
        border:3px solid #d0e4ff; box-shadow:0 8px 24px rgba(11,103,194,.14);
    }
    .vp-avatar-default {
        width:90px; height:90px; border-radius:50%; font-size:2.2rem;
        color:#6b8fbe; border:3px solid #d0e4ff; background:#e8f0fb;
        display:flex; align-items:center; justify-content:center;
    }
    .vp-avatar-trigger {
        position:absolute; bottom:1px; right:1px; width:26px; height:26px;
        border-radius:50%; background:#0b67c2; border:2px solid #fff;
        color:#fff; display:flex; align-items:center; justify-content:center;
        cursor:pointer; font-size:.72rem;
    }
    .vp-avatar-copy { text-align:center; }
    .vp-avatar-copy strong { display:block; font-size:.88rem; color:#163455; }
    .vp-avatar-copy span { font-size:.78rem; color:#516173; }
    .vp-avatar-selector {
        display:flex; flex-direction:row; flex-wrap:nowrap;
        gap:.45rem; width:100%; overflow-x:auto; overflow-y:hidden;
        padding-bottom:.35rem;
        scrollbar-width:thin;
        scrollbar-color:#b8d4f7 transparent;
    }
    .vp-avatar-selector::-webkit-scrollbar { height:5px; }
    .vp-avatar-selector::-webkit-scrollbar-track { background:transparent; }
    .vp-avatar-selector::-webkit-scrollbar-thumb { background:#c3d8f5; border-radius:10px; }
    .vp-avatar-item {
        background:none; border:2px solid transparent; border-radius:10px;
        cursor:pointer; padding:.15rem; transition:border-color .18s, transform .18s;
        flex-shrink:0; width:52px; height:52px;
        display:flex; align-items:center; justify-content:center;
    }
    .vp-avatar-item img { width:100%; border-radius:9px; object-fit:cover; }
    .vp-avatar-item:hover { border-color:#93c0ff; transform:scale(1.05); }
    .vp-avatar-item.selected { border-color:#0b67c2 !important; box-shadow:0 0 0 3px rgba(11,103,194,.18); }
    .vp-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem 1.2rem; align-self:start; }
    .vp-field { display:flex; flex-direction:column; gap:.42rem; }
    .vp-field-wide { grid-column:1/-1; }
    .vp-label { font-size:.72rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:#475a72; }
    .vp-input {
        border:1px solid #d6deea; border-radius:14px; padding:.82rem .9rem;
        font-size:.94rem; color:#163455; background:#fff; outline:none;
        transition:border-color .18s, box-shadow .18s; width:100%;
    }
    .vp-input:focus { border-color:#0b67c2; box-shadow:0 0 0 3px rgba(11,103,194,.12); }
    .vp-input-accent { border-color:#b8d4f7; }
    .vp-pw-wrap { position:relative; display:flex; align-items:center; }
    .vp-pw-wrap .vp-input { padding-right:2.75rem !important; }
    .vp-pw-toggle {
        position:absolute; right:.82rem; background:none; border:none; padding:0;
        color:#64748b; cursor:pointer; font-size:1.18rem; transition:color .2s;
    }
    .vp-pw-toggle:hover { color:#1e293b; }

    /* confirm block panel */
    .vp-confirm-box {
        display:flex; flex-direction:column; align-items:center;
        gap:1rem; text-align:center; padding:.5rem 0 .25rem;
    }
    .vp-confirm-icon {
        width:64px; height:64px; border-radius:50%; display:flex; align-items:center;
        justify-content:center; font-size:1.8rem;
    }
    .vp-confirm-icon.lock { background:#fee2e2; color:#b91c1c; }
    .vp-confirm-icon.unlock { background:#d1fae5; color:#065f46; }
    .vp-confirm-text { color:#475a72; font-size:.95rem; line-height:1.55; }
    .vp-confirm-name { font-weight:700; color:#163455; }

    /* shared buttons */
    .vp-btn-primary {
        background:linear-gradient(135deg,#0c7adf,#1f9cff); color:#fff; border:none;
        border-radius:14px; padding:.8rem 1.35rem; font-weight:700; font-size:.93rem;
        cursor:pointer; display:inline-flex; align-items:center; gap:.5rem;
        box-shadow:0 10px 26px rgba(12,122,223,.22); transition:transform .18s, box-shadow .18s;
    }
    .vp-btn-primary:hover { transform:translateY(-1px); box-shadow:0 14px 32px rgba(12,122,223,.3); }
    .vp-btn-primary:disabled { opacity:.6; cursor:not-allowed; transform:none; }
    .vp-btn-danger {
        background:linear-gradient(135deg,#b91c1c,#ef4444); color:#fff; border:none;
        border-radius:14px; padding:.8rem 1.35rem; font-weight:700; font-size:.93rem;
        cursor:pointer; display:inline-flex; align-items:center; gap:.5rem;
        box-shadow:0 10px 26px rgba(185,28,28,.22); transition:transform .18s;
    }
    .vp-btn-danger:hover { transform:translateY(-1px); }
    .vp-btn-success {
        background:linear-gradient(135deg,#059669,#10b981); color:#fff; border:none;
        border-radius:14px; padding:.8rem 1.35rem; font-weight:700; font-size:.93rem;
        cursor:pointer; display:inline-flex; align-items:center; gap:.5rem;
        box-shadow:0 10px 26px rgba(5,150,105,.22); transition:transform .18s;
    }
    .vp-btn-success:hover { transform:translateY(-1px); }
    .vp-btn-quiet {
        background:#fff; color:#475a72; border:1px solid #d6deea;
        border-radius:14px; padding:.8rem 1.35rem; font-weight:600; font-size:.93rem; cursor:pointer;
        transition:background .18s;
    }
    .vp-btn-quiet:hover { background:#f5f9ff; }

    /* hero button */
    .vp-new-btn {
        background:rgba(255,255,255,.18); color:#fff; border:1.5px solid rgba(255,255,255,.35);
        border-radius:16px; padding:.8rem 1.35rem; font-weight:700; font-size:.93rem;
        cursor:pointer; display:inline-flex; align-items:center; gap:.5rem;
        backdrop-filter:blur(6px); transition:all .2s;
    }
    .vp-new-btn:hover { background:rgba(255,255,255,.28); border-color:rgba(255,255,255,.55); }

    @@media (max-width:900px) {
        .vc-body { grid-template-columns:1fr; }
        .vc-qr { border-top:none; }
        .vp-form-layout { grid-template-columns:1fr; }
    }
    @@media (max-width:620px) {
        .vc-header { flex-wrap:wrap; }
        .vc-actions { width:100%; }
        .vc-body, .vc-share, .vc-qr { padding:1rem; }
        .vc-qr-frame { width:200px; height:200px; }
        .vp-form-grid { grid-template-columns:1fr; }
    }
</style>

<div class="vp-page">
    @if (isLoading)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary" role="status" style="width:3rem;height:3rem;">
                <span class="visually-hidden">Cargando informacion</span>
            </div>
            <p class="mt-3 text-muted fw-bold">Cargando informacion</p>
        </div>
    }
    else
    {
    <!-- ── Hero ── -->
    <section class="vp-hero">
        <div class="vp-hero-copy">
            <span class="vp-hero-kicker">BackOffice · Comercial</span>
            <h2>@(esVendedor ? "Mi QR y Enlace" : "Vendedores y Links de Venta")</h2>
            <p class="vp-hero-note">@(esVendedor ? "Comparte tu enlace o QR para registrar clientes asociados a tu perfil." : "Cada vendedor tiene un enlace y QR únicos que se resuelven en backend sin exponer su nombre en la URL.")</p>
        </div>
        @if (!esVendedor)
        {
            <button type="button" class="vp-new-btn" @onclick='() => NavManager.NavigateTo("/backoffice/clientes/backoffice")'>
                <i class="bi bi-people-fill"></i>
                Crear desde Usuarios Backoffice
            </button>
        }
    </section>

    <!-- ── Feedback banner ── -->
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="vp-banner @(success ? "ok" : "err")">
            <i class="bi @(success ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
            @message
        </div>
    }

    <!-- ── Vendor list ── -->
    <div class="vp-grid">
        @if (!vendors.Any())
        {
            <div class="vp-empty">
                <i class="bi bi-people"></i>
                <strong>@(esVendedor ? "Tu perfil de vendedor aún no está disponible" : "Sin vendedores todavía")</strong>
                <p style="margin:.5rem 0 0; font-size:.92rem;">@(esVendedor ? "Actualiza la página para volver a generar tu enlace." : "Usa el botón \"Nuevo vendedor\" del encabezado para crear el primer perfil.")</p>
            </div>
        }
        else
        {
            @foreach (var vendor in vendors)
            {
                var codigoSecreto = VendedorBackOfficeService.ObtenerCodigoSecreto(vendor);
                var route = VendedorBackOfficeService.ConstruirRutaRegistro(vendor);
                var absoluteLink = $"{NavManager.BaseUri.TrimEnd('/')}{route}";
                var isBlocked = vendor.Activo == false;
                var initials = GetInitials(vendor.Nombre);

                <article class="vc @(isBlocked ? "blocked" : string.Empty)">

                    <!-- card header -->
                    <div class="vc-header">
                        <div class="vc-avatar">
                            @if (!string.IsNullOrWhiteSpace(GetVendorAvatar(vendor)))
                            {
                                <img src="@GetVendorAvatar(vendor)" alt="@vendor.Nombre" />
                            }
                            else
                            {
                                @initials
                            }
                        </div>

                        <div class="vc-meta">
                            <h4 class="vc-name">@vendor.Nombre</h4>
                            <div class="vc-badges">
                                <span class="vc-code"><i class="bi bi-hash"></i>@vendor.CodigoReferencia</span>
                                @if (vendor.EsSistema)
                                {
                                    <span class="vc-status-system"><i class="bi bi-shield-fill"></i>Sistema</span>
                                }
                                else if (isBlocked)
                                {
                                    <span class="vc-status-blocked"><i class="bi bi-lock-fill"></i>Bloqueado</span>
                                }
                                else
                                {
                                    <span class="vc-status-active"><i class="bi bi-check-circle-fill"></i>Activo</span>
                                }
                            </div>
                            <div class="vc-date">Creado: @vendor.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>

                        @if (!esVendedor && !vendor.EsSistema)
                        {
                            <div class="vc-actions">
                                <button type="button" class="vc-btn vc-btn-edit" @onclick="async () => await AbrirEditar(vendor)" title="Editar perfil">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                                @if (isBlocked)
                                {
                                    <button type="button" class="vc-btn vc-btn-unblock" @onclick="() => AbrirBloqueo(vendor)" title="Desbloquear vendedor">
                                        <i class="bi bi-unlock-fill"></i> Activar
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="vc-btn vc-btn-block" @onclick="() => AbrirBloqueo(vendor)" title="Bloquear vendedor">
                                        <i class="bi bi-lock-fill"></i> Bloquear
                                    </button>
                                }
                                <button type="button" class="vc-btn vc-btn-view" @onclick="() => AbrirLinkAsync(absoluteLink)" title="Abrir enlace de registro">
                                    <i class="bi bi-eye-fill"></i> Ver
                                </button>
                            </div>
                        }
                    </div>

                    <!-- card body: share + qr -->
                    <div class="vc-body">
                        <div class="vc-share">
                            <span class="vc-share-kicker">Invitacion digital</span>
                            <div class="vc-linkbox">
                                <span class="vc-link-label">Enlace personalizado</span>
                                <span class="vc-link-value">@absoluteLink</span>
                            </div>
                            <div class="vc-copy-row">
                                <button type="button" class="vc-copy-btn primary"
                                        @onclick="() => CopiarTextoAsync(absoluteLink, ObtenerMensajeCopiado(vendor.Nombre, false))">
                                    <i class="bi bi-link-45deg"></i> Copiar link
                                </button>
                                <button type="button" class="vc-copy-btn secondary"
                                        @onclick="() => DescargarQrAsync(vendor.Nombre, absoluteLink)">
                                    <i class="bi bi-download"></i> Descargar QR
                                </button>
                            </div>
                        </div>

                        <div class="vc-qr">
                            <span class="vc-qr-badge"><i class="bi bi-qr-code-scan"></i> QR</span>
                            <button type="button" class="vc-qr-frame" @onclick="() => AbrirQrModal(vendor.Nombre, absoluteLink)" title="Ver QR grande">
                                <img src="@ObtenerQrVendedor(absoluteLink)" alt="QR @vendor.Nombre" class="vc-qr-img" />
                            </button>
                            <p class="vc-qr-caption">Escanea y registra.</p>
                        </div>
                    </div>

                </article>
            }
        }
    </div>
    }
</div>

