    }

    private string ObtenerQrVendedor(string contenido)
    {
        if (qrCache.TryGetValue(contenido, out var qr)) return qr;
        using QRCodeGenerator qrGenerator = new();
        using QRCodeData qrCodeData = qrGenerator.CreateQrCode(contenido, QRCodeGenerator.ECCLevel.Q);
        using PngByteQRCode qrCode = new(qrCodeData);
        qr = $"data:image/png;base64,{Convert.ToBase64String(qrCode.GetGraphic(28))}";
        qrCache[contenido] = qr;
        return qr;
    }

