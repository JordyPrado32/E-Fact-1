    // e-Fact Filter & Pagination Logic
    private void OnSearchEFactChanged()
    {
        currentEFactPage = 1;
        ApplyEFactFilters();
    }

    private void OnFilterEFactChanged()
    {
        currentEFactPage = 1;
        ApplyEFactFilters();
    }

    private void ApplyEFactFilters()
    {
        var query = efactAllRows.AsQueryable();

        // Search text filter
        if (!string.IsNullOrWhiteSpace(searchEFact))
        {
            var txt = searchEFact.ToLower().Trim();
            query = query.Where(r => r.Cliente.ToLower().Contains(txt) || 
                                     r.Email.ToLower().Contains(txt) || 
                                     r.PaqueteContratado.ToLower().Contains(txt));
        }

        // Status dropdown filter
        if (filterEFactEstado != "ALL")
        {
            query = query.Where(r => r.Estado == filterEFactEstado);
        }

        filteredEFactRows = query.ToList();
        totalEFactPages = (int)Math.Ceiling((double)filteredEFactRows.Count / pageSize);
        if (currentEFactPage > totalEFactPages) currentEFactPage = Math.Max(1, totalEFactPages);

        PaginateEFact();
    }

    private void PaginateEFact()
    {
        paginatedEFactRows = filteredEFactRows
            .Skip((currentEFactPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void SetEFactPage(int pageNum)
    {
        currentEFactPage = pageNum;
        PaginateEFact();
    }

