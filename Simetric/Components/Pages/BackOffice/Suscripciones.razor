    // Helper loaders
    private List<CompraDocumentosHistorialItem> LeerHistorial(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<CompraDocumentosHistorialItem>();

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<CompraDocumentosHistorialItem>>(json, options) 
                   ?? new List<CompraDocumentosHistorialItem>();
        }
        catch
        {
            return new List<CompraDocumentosHistorialItem>();
        }
    }

    private static int? ObtenerIdReporte(string? texto)
    {
        var match = System.Text.RegularExpressions.Regex.Match(texto ?? string.Empty, @"Ref #(\d+)");
        return match.Success && int.TryParse(match.Groups[1].Value, out var idReporte)
            ? idReporte
            : null;
    }

    private DateTime CalcularExpiracion(UsuSolicitudFirma sol)
    {
        var baseDate = sol.SolFechaAprobacion ?? sol.SolFechaSolicitud;
        var vigencia = sol.SolVigencia?.ToLowerInvariant() ?? "";
        if (vigencia.Contains("30") || vigencia.Contains("mes"))
            return baseDate.AddDays(30);
        if (vigencia.Contains("2"))
            return baseDate.AddYears(2);
        if (vigencia.Contains("3"))
            return baseDate.AddYears(3);
        if (vigencia.Contains("4"))
            return baseDate.AddYears(4);
        if (vigencia.Contains("5"))
            return baseDate.AddYears(5);
        return baseDate.AddYears(1); // Default 1 year
    }

