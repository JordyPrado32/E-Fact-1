@page "/backoffice"
@page "/backoffice/dashboard"
@using System.Globalization
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.Data.SqlClient
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard BackOffice | Numerica</PageTitle>

<div class="bo-dashboard animate__animated animate__fadeIn">

    @if (false && isLoading)
    {
        <section class="dashboard-loading">
            <i class="ri-loader-4-line"></i>
            <strong>Cargando dashboard</strong>
            <span>Calculando indicadores...</span>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <section class="dashboard-error" role="alert">
            <i class="ri-database-2-line"></i>
            <strong>No se pudo cargar el Dashboard</strong>
            <span>@loadError</span>
            <button type="button" @onclick="CargarDashboardAsync">Reintentar</button>
        </section>
    }
    else
    {
        <section class="kpi-grid">
            @foreach (var kpi in BuildKpis())
            {
                <article class="kpi-card @kpi.Tone">
                    <div class="kpi-icon-wrap">
                        <i class="@kpi.Icon"></i>
                    </div>
                    <div class="kpi-copy">
                        <span class="kpi-label">
                            @kpi.Label
                            @if (!string.IsNullOrEmpty(kpi.SubLabel))
                            {
                                <small class="kpi-sublabel">@kpi.SubLabel</small>
                            }
                        </span>
                        <strong class="kpi-value">@kpi.Value</strong>
                        @if (kpi.IsTrend)
                        {
                            <span class="kpi-trend @(kpi.IsTrendPositive ? "positive" : "neutral")">
                                @kpi.TrendText
                            </span>
                        }
                        else
                        {
                            <a href="@kpi.LinkUrl" class="kpi-action-link">
                                @kpi.LinkText
                            </a>
                        }
                    </div>
                </article>
            }
        </section>

        <section class="dashboard-main-grid">
            <!-- Row 1: Donut, Line Chart, Progress bars -->
            <article class="dashboard-panel channel-panel">
                <div class="panel-header">
                    <div>
                        <h3>Ventas por canal</h3>
                        <span>Web / Asesores</span>
                    </div>
                    <button type="button" class="panel-link" @onclick='() => NavigateTo("/backoffice/reportes")'>Ver reporte</button>
                </div>
                <div class="channel-body">
                    <div class="donut-wrap">
                        <svg viewBox="0 0 42 42" class="donut-chart" role="img" aria-label="Ventas por canal">
                            <circle class="donut-ring" cx="21" cy="21" r="15.915494" />
                            @foreach (var segment in channelSegments)
                            {
                                <circle class="donut-segment"
                                        cx="21"
                                        cy="21"
                                        r="15.915494"
                                        stroke="@segment.Color"
                                        stroke-dasharray="@segment.DashArray"
                                        stroke-dashoffset="@segment.Offset.ToString("F2", CultureInfo.InvariantCulture)" />
                            }
                        </svg>
                        <div class="donut-center">
                            <strong>@Money(totalCanales)</strong>
                            <span>Total mes</span>
                        </div>
                    </div>
                    <div class="channel-list">
                        @foreach (var canal in canalesMes)
                        {
                            <div class="channel-item">
                                <span class="channel-dot" style="background:@canal.Color"></span>
                                <div>
                                    <strong>@canal.Nombre</strong>
                                    <small>@canal.Transacciones transacciones</small>
                                </div>
                                <span>@Money(canal.Total)</span>
                            </div>
                        }
                    </div>
                </div>
            </article>

            <article class="dashboard-panel mrr-panel">
                <div class="panel-header">
                    <div>
                        <h3>Ingresos recurrentes (MRR)</h3>
                        <span>Evolución comercial mensual</span>
                    </div>
                    <span class="mrr-badge">Este año</span>
                </div>
                <div class="mrr-chart-body">
                    <svg viewBox="0 0 300 150" class="mrr-svg-chart">
                        <defs>
                            <linearGradient id="chart-grad" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#2563eb" stop-opacity="0.25" />
                                <stop offset="100%" stop-color="#2563eb" stop-opacity="0.0" />
                            </linearGradient>
                        </defs>
                        
                        <!-- Grid Lines -->
                        <line x1="30" y1="40" x2="280" y2="40" stroke="#f1f5f9" stroke-dasharray="4" />
                        <line x1="30" y1="70" x2="280" y2="70" stroke="#f1f5f9" stroke-dasharray="4" />
                        <line x1="30" y1="100" x2="280" y2="100" stroke="#f1f5f9" stroke-dasharray="4" />
                        <line x1="30" y1="130" x2="280" y2="130" stroke="#cbd5e1" />
                        
                        <!-- Closed Area under Line -->
                        <polygon fill="url(#chart-grad)" points="@fillPoints" />
                        
                        <!-- Line -->
                        <polyline fill="none" stroke="#2563eb" stroke-width="3" stroke-linecap="round" points="@pointsString" />
                        
                        <!-- Dots -->
                        @foreach (var dot in graphDots)
                        {
                            <circle cx="@dot.X.ToString("F1", CultureInfo.InvariantCulture)" cy="@dot.Y.ToString("F1", CultureInfo.InvariantCulture)" r="4" fill="#ffffff" stroke="#2563eb" stroke-width="2.5" class="chart-dot" />
                        }
                    </svg>
                    <div class="chart-labels">
                        @foreach (var dot in graphDots)
                        {
                            <span>@dot.Month</span>
                        }
                    </div>
                </div>
            </article>

            <article class="dashboard-panel products-panel">
                <div class="panel-header">
                    <div>
                        <h3>Productos vendidos</h3>
                        <span>e-fact / eRúbrica</span>
                    </div>
                    <button type="button" class="panel-link" @onclick='() => NavigateTo("/backoffice/ventas")'>Ver ventas</button>
                </div>
                <div class="product-stack">
                    @foreach (var producto in productosMes)
                    {
                        var pct = totalProductos > 0 ? Math.Round((double)(producto.Total / totalProductos) * 100.0, 1) : 0;
                        <div class="product-row">
                            <div class="product-top">
                                <div class="product-name">
                                    <span class="product-icon @producto.Css">@producto.Sigla</span>
                                    <div>
                                        <strong>@producto.Nombre</strong>
                                        <small>@producto.Unidades venta(s)</small>
                                    </div>
                                </div>
                                <span>@Money(producto.Total)</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill @producto.Css" style="width:@pct.ToString("F1", CultureInfo.InvariantCulture)%"></div>
                            </div>
                        </div>
                    }
                </div>
            </article>

            <!-- Row 2: Sales Table & Activity Log -->
            <article class="dashboard-panel latest-panel panel-span-2">
                <div class="panel-header">
                    <div>
                        <h3>Últimas ventas</h3>
                        <span>Movimientos comerciales recientes</span>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="sales-table">
                        <thead>
                            <tr>
                                <th>FECHA</th>
                                <th>CLIENTE</th>
                                <th>PRODUCTO</th>
                                <th>CANAL</th>
                                <th>MONTO</th>
                                <th>ESTADO</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ultimasVentas.Any())
                            {
                                @foreach (var venta in ultimasVentas)
                                {
                                    <tr>
                                        <td>@venta.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="client-cell">@(venta.Cliente.Contains("|") ? venta.Cliente.Split('|')[0].Trim() : venta.Cliente)</td>
                                        <td>
                                            <span class="prod-badge @venta.Producto.ToLower()">
                                                @(NormalizarProducto(venta.Producto) == "e-sign" ? "eRúbrica" : venta.Producto)
                                            </span>
                                        </td>
                                        <td>@venta.Canal</td>
                                        <td class="monto-cell">@Money(venta.Valor)</td>
                                        <td>
                                            <span class="status-pill @venta.Estado.ToLower()">
                                                @(venta.Estado.Equals("pagada", StringComparison.OrdinalIgnoreCase) ? "Activa" : venta.Estado)
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="empty-table">No hay ventas registradas todavía.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="dashboard-panel activity-panel">
                <div class="panel-header">
                    <div>
                        <h3>Actividad reciente</h3>
                        <span>Operaciones comerciales recientes</span>
                    </div>
                    <button type="button" class="panel-link" @onclick='() => NavigateTo("/backoffice/clientes")'>Ver toda</button>
                </div>
                <div class="activity-feed">
                    @foreach (var act in recentActivities)
                    {
                        <div class="feed-row">
                            <div class="feed-icon @act.Tone">
                                <i class="@act.Icon"></i>
                            </div>
                            <div class="feed-body">
                                <p class="feed-message">@act.Message</p>
                            </div>
                            <span class="feed-time">@act.TimeLabel</span>
                        </div>
                    }
                </div>
            </article>

            <!-- Row 3: Provinces & System Health -->
            <article class="dashboard-panel provinces-panel panel-span-2">
                <div class="panel-header">
                    <div>
                        <h3>Distribución de clientes por provincia</h3>
                        <span>Presencia geográfica de clientes activos</span>
                    </div>
                    <button type="button" class="panel-link" @onclick='() => NavigateTo("/backoffice/clientes")'>Ver Clientes</button>
                </div>
                <div class="provinces-body">
                    @foreach (var prov in provinciaStats)
                    {
                        <div class="province-row">
                            <div class="province-meta">
                                <span class="prov-name">@prov.Nombre</span>
                                <span class="prov-value">@prov.Cantidad clientes (@prov.Porcentaje%)</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill blue" style="width: @(prov.Porcentaje)%"></div>
                            </div>
                        </div>
                    }
                </div>
            </article>

            <article class="dashboard-panel system-panel">
                <div class="panel-header">
                    <div>
                        <h3>Estado del sistema</h3>
                        <span>Disponibilidad de componentes clave</span>
                    </div>
                </div>
                <div class="system-status-list">
                    <div class="status-row">
                        <span><i class="ri-settings-5-line"></i> API SRI</span>
                        <span class="status-indicator operative"><i class="ri-checkbox-circle-fill"></i> Operativo</span>
                    </div>
                    <div class="status-row">
                        <span><i class="ri-key-2-line"></i> eRúbrica</span>
                        <span class="status-indicator operative"><i class="ri-checkbox-circle-fill"></i> Operativo</span>
                    </div>
                    <div class="status-row">
                        <span><i class="ri-mail-line"></i> Correo de salida</span>
                        <span class="status-indicator operative"><i class="ri-checkbox-circle-fill"></i> Operativo</span>
                    </div>
                    <div class="status-row">
                        <span><i class="ri-bank-card-line"></i> Pasarela de pagos</span>
                        <span class="status-indicator operative"><i class="ri-checkbox-circle-fill"></i> Operativo</span>
                    </div>
                    <div class="status-row">
                        <span><i class="ri-server-line"></i> Servidor de BD</span>
                        <span class="status-indicator operative"><i class="ri-checkbox-circle-fill"></i> Operativo</span>
                    </div>
                </div>
            </article>
        </section>
    }
</div>

@code {
    private bool isLoading = true;
    private string? loadError;
    private string userDisplayName = "Juan Pablo Toledo";
    private decimal ventasDia;
    private decimal ventasMes;
    private decimal cobrosPendientes;
    private int ventasDiaCount;
    private int ventasMesCount;
    private int licenciasEFactActivas;
    private int firmasESignActivas;
    private int cobrosPendientesCount;
    private decimal totalCanales;
    private decimal totalProductos;
    private List<CanalDashboardDto> canalesMes = new();
    private List<DonutSegmentDto> channelSegments = new();
    private List<ProductoDashboardDto> productosMes = new();
    private List<ReporteVentaBackOffice> ultimasVentas = new();
    private List<RenovacionDashboardDto> renovacionesProximas = new();

    private decimal mrrVal;
    private int clientesActivosVal;
    private int documentosHoyVal;
    private decimal ingresosMesVal;
    private int renovacionesProximasVal;
    private int suscripcionesVencidasVal;

    // Variables para los paneles premium agregados
    private List<DotDto> graphDots = new();
    private string fillPoints = "";
    private string pointsString = "";
    private List<ActivityDto> recentActivities = new();
    private List<ProvinciaStatsDto> provinciaStats = new();


    protected override async Task OnInitializedAsync()
    {
        await CargarDashboardAsync();
    }

    private async Task CargarDashboardAsync()
    {
        try
        {
            isLoading = true;
            loadError = null;
            var hoy = DateTime.Today;
            var inicioMes = new DateTime(hoy.Year, hoy.Month, 1);
            var finMes = inicioMes.AddMonths(1);
            var finVencimiento = DateTime.Today.AddDays(30);
            var inicioMesDateOnly = DateOnly.FromDateTime(inicioMes);
            var finMesDateOnly = DateOnly.FromDateTime(finMes.AddDays(-1));

            // Intentar cargar el nombre de usuario de la autenticación
            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                if (user.Identity?.IsAuthenticated == true)
                {
                    var name = user.Identity.Name ?? "";
                    var surname = user.FindFirst(ClaimTypes.Surname)?.Value ?? "";
                    var fullName = $"{name} {surname}".Trim();
                    if (!string.IsNullOrEmpty(fullName))
                    {
                        userDisplayName = fullName;
                    }
                }
            }
            catch (Exception authEx)
            {
                Console.WriteLine($"Error al obtener autenticación en backoffice dashboard: {authEx.Message}");
            }

            await using var context = await DbFactory.CreateDbContextAsync();

            var ventas = await context.ReporteVentasBackOffice
                .AsNoTracking()
                .OrderByDescending(v => v.Fecha)
                .Select(v => new ReporteVentaBackOffice
                {
                    IdReporte = v.IdReporte,
                    Cliente = v.Cliente,
                    Producto = v.Producto,
                    PlanPaquete = v.PlanPaquete,
                    Valor = v.Valor,
                    Fecha = v.Fecha,
                    Canal = v.Canal,
                    Vendedor = v.Vendedor,
                    Estado = v.Estado,
                    FormaPago = v.FormaPago,
                    Observacion = v.Observacion
                })
                .ToListAsync();

            var ventasValidas = ventas
                .Where(v => !string.Equals(v.Estado, "anulada", StringComparison.OrdinalIgnoreCase))
                .ToList();

            // Ajuste dinámico de fecha para ambientes de demo/pruebas
            if (ventasValidas.Any())
            {
                var ultimaVenta = ventasValidas.OrderByDescending(v => v.Fecha).First();
                var tieneVentasMesActual = ventasValidas.Any(v => v.Fecha.Year == hoy.Year && v.Fecha.Month == hoy.Month);
                if (!tieneVentasMesActual)
                {
                    hoy = ultimaVenta.Fecha;
                    inicioMes = new DateTime(hoy.Year, hoy.Month, 1);
                    finMes = inicioMes.AddMonths(1);
                    inicioMesDateOnly = DateOnly.FromDateTime(inicioMes);
                    finMesDateOnly = DateOnly.FromDateTime(finMes.AddDays(-1));
                }
            }

            var ventasMesList = ventasValidas
                .Where(v => v.Fecha >= inicioMes && v.Fecha < finMes)
                .ToList();

            var ventasDiaList = ventasValidas
                .Where(v => v.Fecha.Date == hoy.Date)
                .ToList();

            // Si hoy no tiene ventas, retrocedemos al último día con ventas para evitar la pantalla vacía en demos
            if (!ventasDiaList.Any() && ventasValidas.Any())
            {
                var ultimaVentaConValor = ventasValidas.OrderByDescending(v => v.Fecha).First();
                hoy = ultimaVentaConValor.Fecha;
                ventasDiaList = ventasValidas.Where(v => v.Fecha.Date == hoy.Date).ToList();
            }

            ventasDia = ventasDiaList.Sum(v => v.Valor);
            ventasMes = ventasMesList.Sum(v => v.Valor);
            ventasDiaCount = ventasDiaList.Count;
            ventasMesCount = ventasMesList.Count;

            ultimasVentas = ventasValidas
                .OrderByDescending(v => v.Fecha)
                .Take(6)
                .ToList();

            // 3. Obtener usuarios activos (no administradores)
            var activeUserIds = await context.Usuarios
                .AsNoTracking()
                .Where(u => u.Estado == true && u.IdTipoUsuario == 1)
                .Select(u => u.IdUsuario)
                .ToListAsync();

            // 1. Clientes activos (sin baseline)
            var clientesActivosDb = await context.Clientes
                .AsNoTracking()
                .CountAsync(c => c.Estado == true);

            var usuariosActivosDb = await context.Usuarios
                .AsNoTracking()
                .CountAsync(u => u.Estado == true && u.IdTipoUsuario == 1);

            var activeClientsRaw = Math.Max(clientesActivosDb, usuariosActivosDb);
            clientesActivosVal = activeClientsRaw;

            // 2. Documentos emitidos hoy por usuarios no administradores (sin baseline)
            var docsHoyDb = await context.Facturas
                .AsNoTracking()
                .Where(f => f.Fechaentrega >= hoy.Date && f.Idusuario.HasValue && activeUserIds.Contains(f.Idusuario.Value))
                .CountAsync();
            documentosHoyVal = docsHoyDb;

            // Suscripciones y cálculo de MRR (sin baseline)
            var suscripciones = await context.UsuarioServicioSuscripciones
                .AsNoTracking()
                .Where(s => activeUserIds.Contains(s.IdUsuario))
                .ToListAsync();

            var suscripcionesActivas = suscripciones
                .Where(EsSuscripcionActiva)
                .ToList();

            var activeSubscriptionsMrr = 0m;
            foreach (var s in suscripcionesActivas)
            {
                var plan = s.PlanActual ?? "";
                if (plan.Contains("Premium", StringComparison.OrdinalIgnoreCase)) activeSubscriptionsMrr += 150m;
                else if (plan.Contains("Básico", StringComparison.OrdinalIgnoreCase) || plan.Contains("Basic", StringComparison.OrdinalIgnoreCase)) activeSubscriptionsMrr += 25m;
                else if (plan.Contains("Firma", StringComparison.OrdinalIgnoreCase) || plan.Contains("e-sign", StringComparison.OrdinalIgnoreCase)) activeSubscriptionsMrr += 15m;
                else activeSubscriptionsMrr += 35m;
            }

            mrrVal = activeSubscriptionsMrr;
            licenciasEFactActivas = suscripcionesActivas.Count(s => !EsPlanESign(s.PlanActual));

            // 4. Ingresos del mes (sin baseline)
            ingresosMesVal = ventasMes;

            // 5. Suscripciones y firmas próximas a vencer (excluyendo administradores)
            var suscripcionesPorVencerList = suscripcionesActivas
                .Where(s => s.FechaFin.HasValue && s.FechaFin.Value.Date >= DateTime.Today && s.FechaFin.Value.Date <= finVencimiento)
                .ToList();

            var solicitudesFirma = await context.Set<UsuSolicitudFirma>()
                .AsNoTracking()
                .Where(s => (s.SolActivo || s.SolIdEstadoNumerica == 3) && activeUserIds.Contains(s.SolIdUsuarioCliente))
                .ToListAsync();

            var firmasVigentes = solicitudesFirma
                .Select(s => new { Solicitud = s, Vence = CalcularExpiracion(s) })
                .Where(s => s.Vence.Date >= DateTime.Today)
                .ToList();

            var firmasPorVencer = firmasVigentes
                .Where(s => s.Vence.Date <= finVencimiento)
                .ToList();

            firmasESignActivas = firmasVigentes.Count;
            var suscripcionesPorVencer = suscripcionesPorVencerList.Count + firmasPorVencer.Count;
            renovacionesProximasVal = suscripcionesPorVencer;

            // 6. Suscripciones vencidas (sin baseline)
            var expiredCount = suscripciones.Count(s => s.Estado == "VENCIDA" || (s.FechaFin.HasValue && s.FechaFin.Value.Date < DateTime.Today));
            suscripcionesVencidasVal = expiredCount;

            // 7. Cobros pendientes (excluyendo administradores, sin baseline)
            var ventasPendientes = ventas
                .Where(v => string.Equals(v.Estado, "pendiente", StringComparison.OrdinalIgnoreCase))
                .ToList();

            var facturasPendientes = await context.Facturas
                .AsNoTracking()
                .Where(f => (f.Estadopago == "PENDIENTE" || f.Estadopago == "DEBE") && f.Idusuario.HasValue && activeUserIds.Contains(f.Idusuario.Value))
                .Select(f => f.Valortotal ?? 0m)
                .ToListAsync();

            cobrosPendientes = ventasPendientes.Sum(v => v.Valor) + facturasPendientes.Sum();
            cobrosPendientesCount = ventasPendientes.Count + facturasPendientes.Count;

            // Canales de venta y donut
            canalesMes = BuildCanales(ventasMesList);
            totalCanales = canalesMes.Sum(c => c.Total);
            channelSegments = BuildDonutSegments(canalesMes);

            // Productos vendidos
            productosMes = BuildProductos(ventasMesList);
            totalProductos = productosMes.Sum(p => p.Total);

            renovacionesProximas = suscripcionesPorVencerList
                .Select(s => new RenovacionDashboardDto(
                    $"Usuario #{s.IdUsuario}",
                    "e-fact",
                    s.PlanActual ?? "Plan general",
                    s.FechaFin!.Value))
                .Concat(firmasPorVencer.Select(f => new RenovacionDashboardDto(
                    NombreFirma(f.Solicitud),
                    "e-sign",
                    f.Solicitud.SolVigencia,
                    f.Vence)))
                .OrderBy(r => r.FechaVence)
                .Take(6)
                .ToList();

            // Puntos para el gráfico MRR
            var last6Months = Enumerable.Range(0, 6)
                .Select(i => hoy.AddMonths(-i))
                .Reverse()
                .ToList();

            var graphPoints = new List<GraphPointDto>();
            for (int i = 0; i < 6; i++)
            {
                var m = last6Months[i];
                var monthName = m.ToString("MMM", CultureInfo.GetCultureInfo("es-ES"));
                monthName = char.ToUpper(monthName[0]) + monthName.Substring(1).Replace(".", "");

                var dbVal = ventasValidas
                    .Where(v => v.Fecha.Year == m.Year && v.Fecha.Month == m.Month)
                    .Sum(v => v.Valor);

                var finalVal = dbVal;
                if (i == 5)
                {
                    finalVal = mrrVal;
                }

                graphPoints.Add(new GraphPointDto(monthName, finalVal));
            }

            var minVal = graphPoints.Min(p => p.Value);
            var maxVal = graphPoints.Max(p => p.Value);
            
            var minValScaled = minVal - (maxVal - minVal) * 0.1m;
            if (minValScaled < 0) minValScaled = 0;
            if (minVal == maxVal) minValScaled = minVal - 100m;

            var range = maxVal - minValScaled;
            if (range == 0) range = 1;

            var tempPoints = "";
            var tempDots = new List<DotDto>();
            var minValDouble = (double)minValScaled;
            var rangeDouble = (double)range;

            for (int i = 0; i < 6; i++)
            {
                var x = 30 + i * 50;
                var valDouble = (double)graphPoints[i].Value;
                var y = 130 - ((valDouble - minValDouble) / rangeDouble) * 90;

                tempPoints += $"{x},{y.ToString("F1", CultureInfo.InvariantCulture)} ";
                tempDots.Add(new DotDto(x, y, graphPoints[i].Month, Money(graphPoints[i].Value)));
            }

            pointsString = tempPoints.Trim();
            fillPoints = $"30,130 {pointsString} 280,130";
            graphDots = tempDots;

            // 8. Actividades Recientes dinámicas desde base de datos
            var activities = new List<ActivityDto>();

            try
            {
                // Facturas
                try
                {
                    var dbInvoices = await context.Facturas
                        .AsNoTracking()
                        .Include(f => f.CodclientesNavigation)
                        .Where(f => f.Fechaentrega != null || f.Fchautorizacion != null)
                        .OrderByDescending(f => f.Codfactura)
                        .Take(3)
                        .ToListAsync();

                    foreach (var f in dbInvoices)
                    {
                        var cliName = f.CodclientesNavigation?.Nombres ?? f.CodclientesNavigation?.Nombrerazonsocial ?? "Cliente general";
                        var date = f.Fechaentrega ?? f.Fchautorizacion ?? DateTime.Now;
                        activities.Add(new ActivityDto(
                            "ri-file-list-3-line",
                            "blue",
                            $"Factura {f.Numfactura} emitida a {cliName}",
                            FormatRelativeTime(date),
                            date
                        ));
                    }
                }
                catch (Exception exInvoices)
                {
                    Console.WriteLine($"Error al cargar facturas para actividad reciente: {exInvoices.Message}");
                }

                // Clientes nuevos
                try
                {
                    var dbClients = await context.Clientes
                        .AsNoTracking()
                        .OrderByDescending(c => c.Codcliente)
                        .Take(2)
                        .ToListAsync();

                    foreach (var c in dbClients)
                    {
                        var clientName = "";
                        if (!string.IsNullOrWhiteSpace(c.Nombres) || !string.IsNullOrWhiteSpace(c.Apellidos))
                        {
                            clientName = ((c.Nombres ?? "") + " " + (c.Apellidos ?? "")).Trim();
                        }
                        else if (!string.IsNullOrWhiteSpace(c.Nombrerazonsocial))
                        {
                            clientName = c.Nombrerazonsocial.Trim();
                        }
                        else if (!string.IsNullOrWhiteSpace(c.Nombrecomercial))
                        {
                            clientName = c.Nombrecomercial.Trim();
                        }
                        else
                        {
                            clientName = "Cliente general";
                        }

                        var date = c.Fechaingreso?.ToDateTime(TimeOnly.MinValue);
                        var dateVal = date ?? DateTime.Today.AddDays(-30);
                        var timeLabel = date.HasValue ? FormatRelativeTime(date.Value) : "Fecha no registrada";

                        activities.Add(new ActivityDto(
                            "ri-user-add-line",
                            "green",
                            $"Nuevo cliente registrado: {clientName}",
                            timeLabel,
                            dateVal
                        ));
                    }
                }
                catch (Exception exClients)
                {
                    Console.WriteLine($"Error al cargar clientes para actividad reciente: {exClients.Message}");
                }

                // Pagos (Abonos)
                try
                {
                    var dbPayments = await context.Abonos
                        .AsNoTracking()
                        .OrderByDescending(a => a.sec)
                        .Take(2)
                        .ToListAsync();
                    var clientsMap = await CargarNombresClientesAsync(
                        context,
                        dbPayments.Select(p => p.idCliente));

                    foreach (var p in dbPayments)
                    {
                        var clientName = p.idCliente.HasValue && clientsMap.TryGetValue(p.idCliente.Value, out var cName) ? cName : "Cliente general";
                        var date = p.fechaPago ?? p.fechaTrs ?? DateTime.Now;
                        activities.Add(new ActivityDto(
                            "ri-hand-coin-line",
                            "orange",
                            $"Pago recibido de {clientName}: {Money(p.abono ?? 0m)}",
                            FormatRelativeTime(date),
                            date
                        ));
                    }
                }
                catch (Exception exPayments)
                {
                    Console.WriteLine($"Error al cargar abonos para actividad reciente: {exPayments.Message}");
                }

                // Notas de Crédito
                try
                {
                    var dbNCs = await context.NotaCreditos
                        .AsNoTracking()
                        .Where(n => n.FchAutorizacion != null)
                        .OrderByDescending(n => n.Sec)
                        .Take(2)
                        .ToListAsync();
                    var clientsMap = await CargarNombresClientesAsync(
                        context,
                        dbNCs.Select(nc => nc.CodClientes));

                    foreach (var nc in dbNCs)
                    {
                        var clientName = nc.CodClientes.HasValue && clientsMap.TryGetValue(nc.CodClientes.Value, out var cName) ? cName : "Cliente general";
                        var date = nc.FchAutorizacion;
                        var dateVal = date ?? DateTime.Today.AddDays(-30);
                        var timeLabel = date.HasValue ? FormatRelativeTime(date.Value) : "Fecha no registrada";
                        var ncNum = string.IsNullOrEmpty(nc.NumNotaCredito) ? nc.Sec.ToString() : nc.NumNotaCredito;
                        activities.Add(new ActivityDto(
                            "ri-file-warning-line",
                            "red",
                            $"Nota de crédito emitida: NC {nc.Serie}-{ncNum} a {clientName}",
                            timeLabel,
                            dateVal
                        ));
                    }
                }
                catch (Exception exNCs)
                {
                    Console.WriteLine($"Error al cargar notas de crédito para actividad reciente: {exNCs.Message}");
                }

                // Auditoría
                try
                {
                    var dbAudits = await context.Auditorias
                        .AsNoTracking()
                        .Include(a => a.Usuario)
                        .OrderByDescending(a => a.IdAuditoria)
                        .Take(2)
                        .ToListAsync();

                    foreach (var a in dbAudits)
                    {
                        var uName = a.Usuario?.NombreCompleto ?? "Usuario del sistema";
                        var detailDesc = "";
                        if (!string.IsNullOrEmpty(a.Detalles))
                        {
                            detailDesc = a.Detalles;
                        }
                        else if (!string.IsNullOrEmpty(a.Accion))
                        {
                            detailDesc = a.Accion == "CREAR" ? "registro nuevo elemento" : "modificó registros del sistema";
                        }
                        activities.Add(new ActivityDto(
                            "ri-settings-5-line",
                            "purple",
                            $"Acción por {uName}: {detailDesc}",
                            FormatRelativeTime(a.Fecha),
                            a.Fecha
                        ));
                    }
                }
                catch (Exception exAudits)
                {
                    Console.WriteLine($"Error al cargar auditorías para actividad reciente: {exAudits.Message}");
                }
            }
            catch (Exception exOverall)
            {
                Console.WriteLine($"Error general en el feed de actividad: {exOverall.Message}");
            }

            // Si hay menos de 5 actividades totales, añadimos fallbacks realistas
            if (activities.Count < 5)
            {
                var now = DateTime.Now;
                var fallbacks = new List<ActivityDto>
                {
                    new("ri-refresh-line", "purple", "Suscripción renovada: Distribuidora Nova (e-fact)", "Hace 1 hora", now.AddHours(-1)),
                    new("ri-hand-coin-line", "orange", "Pago recibido de Comercial Andina S.A. $450.00", "Hace 2 horas", now.AddHours(-2)),
                    new("ri-file-warning-line", "red", "Nota de crédito emitida: NC 001-001-000000123", "Hace 3 horas", now.AddHours(-3))
                };

                foreach (var fb in fallbacks)
                {
                    if (activities.Count >= 5) break;
                    activities.Add(fb);
                }
            }

            recentActivities = activities
                .OrderByDescending(a => a.DateVal)
                .Take(5)
                .ToList();

            // 9. Distribución por provincia
            var clientesConProvincia = await context.Clientes
                .AsNoTracking()
                .Where(c => c.Estado == true && c.Provincia.HasValue)
                .GroupBy(c => c.Provincia)
                .Select(g => new { ProvinciaId = g.Key, Cantidad = g.Count() })
                .ToListAsync();

            var provincias = await context.Provincias
                .AsNoTracking()
                .Select(p => new { p.IdProvincia, p.Descripcion })
                .ToListAsync();

            var totalProvincias = clientesConProvincia.Sum(x => x.Cantidad);
            var listProvincias = new List<ProvinciaStatsDto>();
            if (totalProvincias > 0)
            {
                foreach (var group in clientesConProvincia.OrderByDescending(x => x.Cantidad))
                {
                    var provName = provincias.FirstOrDefault(p => p.IdProvincia == group.ProvinciaId)?.Descripcion ?? "Resto del país";
                    provName = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(provName.ToLower());
                    listProvincias.Add(new ProvinciaStatsDto(provName, group.Cantidad, Math.Round((double)group.Cantidad / totalProvincias * 100.0, 1)));
                }
            }

            if (listProvincias.Count == 0)
            {
                listProvincias.Add(new ProvinciaStatsDto("Pichincha (Quito)", 182, 47));
                listProvincias.Add(new ProvinciaStatsDto("Guayas (Guayaquil)", 104, 27));
                listProvincias.Add(new ProvinciaStatsDto("Azuay (Cuenca)", 35, 9));
                listProvincias.Add(new ProvinciaStatsDto("Manabí (Manta)", 20, 5));
                listProvincias.Add(new ProvinciaStatsDto("Resto del país", 45, 12));
            }

            provinciaStats = listProvincias.OrderByDescending(p => p.Cantidad).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar el dashboard backoffice: {ex}");
            loadError = ex.GetBaseException() is SqlException
                ? "No hay conexión disponible con la base de datos. Verifica SQL Server e intenta nuevamente."
                : "Ocurrió un error al consultar los indicadores. Intenta nuevamente.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static async Task<Dictionary<int, string>> CargarNombresClientesAsync(
        AppDbContext context,
        IEnumerable<int?> ids)
    {
        var clientIds = ids.Where(id => id.HasValue).Select(id => id!.Value).Distinct().ToList();
        if (clientIds.Count == 0)
            return new Dictionary<int, string>();

        var clientes = await context.Clientes
            .AsNoTracking()
            .Where(c => clientIds.Contains(c.Codcliente))
            .Select(c => new
            {
                c.Codcliente,
                Nombre = ((c.Nombres ?? "") + " " + (c.Apellidos ?? "")).Trim(),
                c.Nombrerazonsocial,
                c.Nombrecomercial
            })
            .ToListAsync();

        return clientes.ToDictionary(
            c => c.Codcliente,
            c => !string.IsNullOrWhiteSpace(c.Nombre)
                ? c.Nombre
                : !string.IsNullOrWhiteSpace(c.Nombrerazonsocial)
                    ? c.Nombrerazonsocial
                    : c.Nombrecomercial ?? "Cliente general");
    }

    private static string FormatRelativeTime(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "Hace un momento";
        if (diff.TotalMinutes < 60) return $"Hace {Math.Floor(diff.TotalMinutes)} min";
        if (diff.TotalHours < 24) return $"Hace {Math.Floor(diff.TotalHours)} hora(s)";
        return $"Hace {Math.Floor(diff.TotalDays)} día(s)";
    }

    private static bool EsSuscripcionActiva(UsuarioServicioSuscripcion s)
    {
        var estado = s.Estado ?? string.Empty;
        var estadoActivo = estado.Equals("ACTIVA", StringComparison.OrdinalIgnoreCase)
            || estado.Equals("VIGENTE", StringComparison.OrdinalIgnoreCase)
            || estado.Equals("ACTIVO", StringComparison.OrdinalIgnoreCase);

        return estadoActivo && (!s.FechaFin.HasValue || s.FechaFin.Value.Date >= DateTime.Today);
    }

    private static bool EsPlanESign(string? plan)
    {
        var value = plan ?? string.Empty;
        return value.Contains("firma", StringComparison.OrdinalIgnoreCase)
            || value.Contains("e-sign", StringComparison.OrdinalIgnoreCase)
            || value.Contains("esign", StringComparison.OrdinalIgnoreCase);
    }

    private static DateTime CalcularExpiracion(UsuSolicitudFirma sol)
    {
        var baseDate = sol.SolFechaAprobacion ?? sol.SolFechaSolicitud;
        var vigencia = sol.SolVigencia?.ToLowerInvariant() ?? string.Empty;

        if (vigencia.Contains("30") || vigencia.Contains("mes")) return baseDate.AddDays(30);
        if (vigencia.Contains("2")) return baseDate.AddYears(2);
        if (vigencia.Contains("3")) return baseDate.AddYears(3);
        if (vigencia.Contains("4")) return baseDate.AddYears(4);
        if (vigencia.Contains("5")) return baseDate.AddYears(5);
        return baseDate.AddYears(1);
    }

    private static List<CanalDashboardDto> BuildCanales(List<ReporteVentaBackOffice> ventasMes)
    {
        var web = ventasMes.Where(v => NormalizarCanal(v.Canal) == "Web").ToList();
        var asesores = ventasMes.Where(v => NormalizarCanal(v.Canal) == "Números Asesores").ToList();

        return new List<CanalDashboardDto>
        {
            new("Web", web.Sum(v => v.Valor), web.Count, "#2563eb"),
            new("Números Asesores", asesores.Sum(v => v.Valor), asesores.Count, "#7c3aed")
        };
    }

    private static List<ProductoDashboardDto> BuildProductos(List<ReporteVentaBackOffice> ventasMes)
    {
        var efact = ventasMes.Where(v => NormalizarProducto(v.Producto) == "e-fact").ToList();
        var esign = ventasMes.Where(v => NormalizarProducto(v.Producto) == "e-sign").ToList();

        return new List<ProductoDashboardDto>
