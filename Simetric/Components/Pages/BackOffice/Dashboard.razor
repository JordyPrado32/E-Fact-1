            new("e-fact", "EF", efact.Sum(v => v.Valor), efact.Count, "efact"),
            new("eRúbrica", "ER", esign.Sum(v => v.Valor), esign.Count, "esign")
        };
    }

    private static List<DonutSegmentDto> BuildDonutSegments(List<CanalDashboardDto> canales)
    {
        var total = canales.Sum(c => c.Total);
        var offset = 25.0;
        var segments = new List<DonutSegmentDto>();

        // Enforce a minimum of 8.0% for any channel with sales > 0 so that it's visible in the donut
        var activeChannels = canales.Where(c => c.Total > 0).ToList();
        var pctMap = new Dictionary<string, double>();

        if (activeChannels.Count == 1)
        {
            pctMap[activeChannels[0].Nombre] = 100.0;
        }
        else if (activeChannels.Count > 1)
        {
            var minPct = 8.0;
            var rawPcts = canales.Select(c => new { c.Nombre, Pct = total > 0 ? (double)(c.Total / total) * 100.0 : 0.0 }).ToList();
            
            var adjustedPcts = new Dictionary<string, double>();
            var extraNeeded = 0.0;
            var flexibleTotal = 0.0;

            foreach (var rp in rawPcts)
            {
                if (rp.Pct > 0 && rp.Pct < minPct)
                {
                    adjustedPcts[rp.Nombre] = minPct;
                    extraNeeded += (minPct - rp.Pct);
                }
                else
                {
                    adjustedPcts[rp.Nombre] = rp.Pct;
                    if (rp.Pct > 0) flexibleTotal += rp.Pct;
                }
            }

            if (extraNeeded > 0 && flexibleTotal > 0)
            {
                var keys = adjustedPcts.Keys.ToList();
                foreach (var k in keys)
                {
                    if (adjustedPcts[k] > minPct)
                    {
                        var ratio = adjustedPcts[k] / flexibleTotal;
                        adjustedPcts[k] -= extraNeeded * ratio;
                        if (adjustedPcts[k] < minPct) adjustedPcts[k] = minPct;
                    }
                }
            }

            var sum = adjustedPcts.Values.Sum();
            if (sum > 0)
            {
                foreach (var k in adjustedPcts.Keys)
                {
                    pctMap[k] = (adjustedPcts[k] / sum) * 100.0;
                }
            }
        }

        foreach (var canal in canales)
        {
            var pct = pctMap.ContainsKey(canal.Nombre) ? pctMap[canal.Nombre] : 0.0;
            segments.Add(new DonutSegmentDto($"{pct.ToString("F2", CultureInfo.InvariantCulture)} {(100 - pct).ToString("F2", CultureInfo.InvariantCulture)}", offset, canal.Color));
            offset -= pct;
        }

        return segments;
    }

    private static string NormalizarCanal(string? canal)
    {
        var value = canal ?? string.Empty;
        if (value.Contains("asesor", StringComparison.OrdinalIgnoreCase)
            || value.Contains("admin", StringComparison.OrdinalIgnoreCase)
            || value.Contains("backoffice", StringComparison.OrdinalIgnoreCase)
            || value.Contains("back office", StringComparison.OrdinalIgnoreCase))
        {
            return "Números Asesores";
        }
        return "Web";
    }

    private static string NormalizarProducto(string? producto)
    {
        var value = producto ?? string.Empty;
        if (value.Contains("sign", StringComparison.OrdinalIgnoreCase) || value.Contains("firma", StringComparison.OrdinalIgnoreCase)) return "e-sign";
        return "e-fact";
    }

    private static string NombreFirma(UsuSolicitudFirma sol)
    {
        return $"{sol.SolNombres} {sol.SolPrimerApellido} {sol.SolSegundoApellido}".Trim();
    }

    private static string GetEstadoCss(string estado)
    {
        if (estado.Equals("pagada", StringComparison.OrdinalIgnoreCase)) return "ok";
        if (estado.Equals("pendiente", StringComparison.OrdinalIgnoreCase)) return "warn";
        return "off";
    }

