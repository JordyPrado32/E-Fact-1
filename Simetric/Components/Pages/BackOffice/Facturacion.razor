    private async Task ConsultarIdentificacionAsync()
    {
        if (!tieneAcceso)
            return;

        var identificacionNormalizada = NormalizarIdentificacion(identificacionBusqueda);
        if (identificacionNormalizada.Length is not (10 or 13))
        {
            SetFeedback("Ingresa una cedula de 10 digitos o un RUC de 13 digitos para consultar.", false);
            return;
        }

        consultandoIdentificacion = true;
        try
        {
            var resultado = await CedulaLookupService.ConsultarAsync(identificacionNormalizada);
            if (!resultado.Success)
            {
                SetFeedback(resultado.Mensaje ?? "No fue posible consultar la identificacion.", false);
                return;
            }

            if (!resultado.Found)
            {
                SetFeedback(resultado.Mensaje ?? "No se encontraron datos para la identificacion consultada.", false);
                return;
            }

            AplicarResultadoIdentificacion(resultado, identificacionNormalizada);
        }
        catch (Exception ex)
        {
            SetFeedback(ex.Message, false);
        }
        finally
        {
            consultandoIdentificacion = false;
        }
    }

    private async Task GuardarSecuenciaAsync()
    {
        if (!tieneAcceso)
            return;

        guardandoSecuencia = true;
        try
        {
            var resultado = await EmisorSistemaService.GuardarSecuenciaFacturaSistemaAsync(
                currentUserId,
                secuenciaForm.YaFacturoAntes,
                secuenciaForm.UltimaSecuencia);

            SetFeedback(resultado.Message, resultado.Success);
            if (resultado.Success)
            {
                secuenciaSistema = await EmisorSistemaService.GetSecuenciaFacturaSistemaAsync();
                secuenciaForm = SecuenciaSistemaFormModel.FromInfo(secuenciaSistema);
            }
        }
        catch (Exception ex)
        {
            SetFeedback(ex.Message, false);
        }
        finally
        {
            guardandoSecuencia = false;
        }
    }

    private async Task GuardarCajaSistemaAsync()
    {
        if (!tieneAcceso || ownerUserId <= 0)
            return;

        var establecimiento = NormalizarCodigo(cajaForm.Establecimiento);
        var punto = NormalizarCodigo(cajaForm.PuntoEmision);

        if (establecimiento is null || punto is null)
        {
            SetFeedback("La caja del sistema requiere establecimiento y punto de emision validos de 3 digitos.", false);
            return;
        }

        guardandoCaja = true;
        try
        {
            var serie = $"{establecimiento}-{punto}";
            var modelo = cajaSistemaSeleccionada is null
                ? CrearNuevaCajaSistemaBase()
                : ClonarCaja(cajaSistemaSeleccionada);

            modelo.IdUsuario = ownerUserId;
            modelo.EsCajaSistema = true;
            modelo.SerieFactura = serie;
            modelo.SerieNotasCred = serie;
            modelo.SerieGuia = serie;
            modelo.SerieCompras = serie;
            modelo.SerieDebitos = serie;
            modelo.Estado = true;

            var ok = await ConfiguracionService.SaveCajaAsync(modelo, currentUserId);
            if (!ok)
            {
                SetFeedback("No se pudo guardar la caja del sistema. Verifica que la serie no este duplicada y que la cuenta tenga datos validos.", false);
                return;
            }

            SetFeedback($"Caja del sistema guardada correctamente con la serie {serie}.", true);
            await RecargarAsync();
        }
        catch (Exception ex)
        {
            SetFeedback(ex.Message, false);
        }
        finally
        {
            guardandoCaja = false;
        }
    }

