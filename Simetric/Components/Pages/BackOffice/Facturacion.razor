                Email = emisor.Email ?? string.Empty,
                Telefono = emisor.Telefono ?? string.Empty,
                LlevaContabilidad = string.IsNullOrWhiteSpace(emisor.LlevaContabilidad) ? "SI" : emisor.LlevaContabilidad,
                TipoAmbiente = string.IsNullOrWhiteSpace(emisor.TipoAmbiente) ? "2" : emisor.TipoAmbiente,
