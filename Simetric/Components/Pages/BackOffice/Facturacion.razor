@page "/backoffice/facturacion"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Hosting
@using Simetric.DTOs
@using Simetric.Models
@using Simetric.Services
@using System.IO
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject CedulaLookupService CedulaLookupService
@inject EmisorSistemaService EmisorSistemaService
@inject FacturacionService FacturacionService
@inject ConfiguracionService ConfiguracionService
@inject IWebHostEnvironment HostEnvironment
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject SweetAlertService AlertService

@rendermode InteractiveServer

<PageTitle>Facturacion - BackOffice | Numerica</PageTitle>

<div class="bo-facturacion-page animate__animated animate__fadeIn">
    <section class="hero-card">
        <div>
            <span class="hero-kicker">BackOffice</span>
            <h2>Emisor maestro y facturas del sistema</h2>
            <p>
                Desde aqui se configura el emisor global exclusivo de la empresa y se revisan las facturas
                emitidas automaticamente por recargas.
            </p>
        </div>
        <div class="hero-status-group">
            <div class="hero-status">
                <span>Emisor maestro</span>
                <strong>@(emisorConfigurado ? "Configurado" : "Pendiente")</strong>
            </div>
            <div class="hero-status">
                <span>Firma</span>
                <strong>@(firmaConfigurada ? "Lista" : "Pendiente")</strong>
            </div>
            <div class="hero-status">
                <span>Facturas sistema</span>
                <strong>@facturasSistema.Count</strong>
            </div>
        </div>
    </section>

    @if (tieneAcceso && !cargando)
    {
        <section class="panel-card summary-panel">
            <div class="sequence-summary">
                <div class="sequence-chip">
                    <span>RUC emisor</span>
                    <strong>@RucEmisorActual</strong>
                </div>
                <div class="sequence-chip">
                    <span>Razon social</span>
                    <strong>@RazonSocialEmisorActual</strong>
                </div>
                <div class="sequence-chip">
                    <span>Serie principal</span>
                    <strong>@SeriePrincipalSistemaActual</strong>
                </div>
                <div class="sequence-chip">
                    <span>Ultima factura sistema</span>
                    <strong>@UltimaFacturaSistema</strong>
                </div>
                <div class="sequence-chip">
                    <span>Autorizadas</span>
                    <strong>@TotalFacturasAutorizadasSistema</strong>
                </div>
                <div class="sequence-chip">
                    <span>Pendientes</span>
                    <strong>@TotalFacturasPendientesSistema</strong>
                </div>
            </div>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(feedbackMessage))
    {
        <div class="feedback-banner @(feedbackIsSuccess ? "is-success" : "is-error")">
            @feedbackMessage
        </div>
    }

    @if (cargando)
    {
        <div class="state-card">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Cargando configuracion de facturacion del sistema...</p>
        </div>
    }
    else if (!tieneAcceso)
    {
        <div class="state-card">
            <h3>Acceso restringido</h3>
            <p>Solo los usuarios autorizados pueden revisar o editar el emisor maestro del sistema.</p>
        </div>
    }
    else
    {
        <div class="content-grid">
            <section class="panel-card">
                <div class="panel-head">
                    <div>
                        <span class="panel-kicker">Configuracion global</span>
                        <h3>Emisor maestro del sistema</h3>
                    </div>
                    <button type="button" class="secondary-btn" @onclick="RecargarAsync" disabled="@guardando">
                        Actualizar
                    </button>
                </div>

                <EditForm Model="@formModel" OnValidSubmit="@GuardarAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger small" />

                    <div class="field field-full lookup-panel">
                        <label>Busqueda rapida RUC / cedula</label>
                        <div class="lookup-row">
                            <InputText @bind-Value="identificacionBusqueda"
                                       class="field-input"
                                       name="backoffice_emisor_maestro_busqueda"
                                       placeholder="Ingresa 10 digitos para cedula o 13 para RUC"
                                       autocomplete="new-password"
                                       autocorrect="off"
                                       autocapitalize="off"
                                       spellcheck="false"
                                       data-form-type="other"
                                       data-lpignore="true"
                                       inputmode="numeric" />
                            <button type="button"
                                    class="secondary-btn lookup-btn"
                                    @onclick="ConsultarIdentificacionAsync"
                                    disabled="@consultandoIdentificacion">
                                @(consultandoIdentificacion ? "Consultando..." : "Buscar")
                            </button>
                        </div>
                        <small class="field-help">
                            Si consultas RUC, se carga el emisor maestro completo. Si consultas cedula, se precarga la razon social y podras completar luego el RUC definitivo.
                        </small>
                    </div>

                    <details class="form-accordion" open>
                        <summary class="form-section-heading">
                            <span>1</span>
                            <strong>Informacion fiscal</strong>
                            <i class="bi bi-chevron-down"></i>
                        </summary>
                        <div class="form-accordion-body form-grid">
                            <div class="field">
                                <label>Razon social</label>
                                <InputText @bind-Value="formModel.RazonSocial" class="field-input" />
                            </div>
                            <div class="field">
                                <label>RUC</label>
                                <InputText @bind-Value="formModel.Ruc" class="field-input" autocomplete="off" inputmode="numeric" />
                            </div>
                            <div class="field field-full">
                                <label>Nombre comercial</label>
                                <InputText @bind-Value="formModel.NomComercial" class="field-input" />
                                <small class="field-help">Debes ingresar razon social o nombre comercial. No es obligatorio completar ambos.</small>
                            </div>
                            <div class="field">
                                <label>Lleva contabilidad</label>
                                <InputSelect @bind-Value="formModel.LlevaContabilidad" class="field-input">
                                    <option value="SI">SI</option>
                                    <option value="NO">NO</option>
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label>Ambiente</label>
                                <InputSelect @bind-Value="formModel.TipoAmbiente" class="field-input">
                                    <option value="1">Pruebas</option>
                                    <option value="2">Produccion</option>
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label>Tipo emision</label>
                                <InputSelect @bind-Value="formModel.TipoEmision" class="field-input">
                                    <option value="1">Normal</option>
                                </InputSelect>
                            </div>
                            <div class="field">
                                <label>Establecimiento</label>
                                <InputText @bind-Value="formModel.CodEstablecimiento" class="field-input" maxlength="3" />
                            </div>
                            <div class="field">
                                <label>Punto emision</label>
                                <InputText @bind-Value="formModel.CodPuntoEmision" class="field-input" maxlength="3" />
                            </div>
                            <div class="field field-full">
                                <label>Direccion matriz</label>
                                <InputText @bind-Value="formModel.DireccionMatriz" class="field-input" />
                            </div>
                            <div class="field field-full">
                                <label>Direccion establecimiento</label>
                                <InputText @bind-Value="formModel.DirEstablecimiento" class="field-input" />
                            </div>
                        </div>
                    </details>

                    <details class="form-accordion">
                        <summary class="form-section-heading">
                            <span>2</span>
                            <strong>Contacto y firma</strong>
                            <i class="bi bi-chevron-down"></i>
                        </summary>
                        <div class="form-accordion-body form-grid">
                            <div class="field">
                                <label>Telefono</label>
                                <InputText @bind-Value="formModel.Telefono" class="field-input" />
                            </div>
                            <div class="field">
                                <label>Email</label>
                                <InputText @bind-Value="formModel.Email" class="field-input" autocomplete="off" />
                            </div>
                            <div class="field">
                                <label>Certificado .p12</label>
                                <InputFile OnChange="SubirPathCertificado" accept=".p12" class="field-input file-input" />
                                @if (!string.IsNullOrWhiteSpace(nombrePathCertificadoActual))
                                {
                                    <small class="field-help">Actual: @nombrePathCertificadoActual</small>
                                }
                            </div>
                            <div class="field">
                                <label>Clave certificado</label>
                                <div class="password-field">
                                    <InputText @bind-Value="formModel.ClaveCertificado"
                                               type="@(mostrarClaveCertificado ? "text" : "password")"
                                               class="field-input password-input"
                                               autocomplete="off" />
                                    <button type="button"
                                            class="password-toggle-btn"
                                            @onclick="ToggleClaveCertificado"
                                            aria-label="@(mostrarClaveCertificado ? "Ocultar clave del certificado" : "Mostrar clave del certificado")"
                                            title="@(mostrarClaveCertificado ? "Ocultar clave" : "Mostrar clave")">
                                        <i class="bi @(mostrarClaveCertificado ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </details>
                    <div class="form-actions">
                        <button type="submit" class="primary-btn" disabled="@guardando">
                            @(guardando ? "Guardando..." : "Guardar emisor maestro")
                        </button>
                    </div>
                </EditForm>
            </section>

            <section class="panel-card">
                <div class="panel-head">
                    <div>
                        <span class="panel-kicker">Facturacion automatica</span>
                        <h3>Facturas del sistema por recargas</h3>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="secondary-btn" @onclick="IrAMisFacturasBackOffice">
                            Mis facturas backoffice
                        </button>
                        <button type="button" class="secondary-btn" @onclick="RecargarFacturasAsync">
                            Recargar
                        </button>
                    </div>
                </div>

                @if (!facturasSistema.Any())
                {
                    <div class="state-card compact">
                        <p>No hay facturas de recargas emitidas con el emisor maestro todavia.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="facturas-table">
                            <thead>
                                <tr>
                                    <th>Numero</th>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th>Identificacion</th>
                                    <th>Total</th>
                                    <th>Estado SRI</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var factura in facturasSistema)
                                {
                                    <tr>
                                        <td>@factura.NumeroCompleto</td>
                                        <td>@factura.FechaEmision?.ToString("dd/MM/yyyy")</td>
                                        <td>@factura.Cliente</td>
                                        <td>@factura.IdentificacionCliente</td>
                                        <td>$ @(factura.Total?.ToString("N2") ?? "0.00")</td>
                                        <td>
                                            <span class="state-pill @(DocumentoAutorizacionHelper.EstaAutorizado(factura.Autorizado, factura.EstadoSri) ? "ok" : "warn")">
                                                @(string.IsNullOrWhiteSpace(factura.EstadoSri) ? "PENDIENTE" : factura.EstadoSri)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="table-actions">
                                                <button type="button" class="link-btn" @onclick="() => VerFacturaAsync(factura.Codfactura)">Ver</button>
                                                <button type="button" class="link-btn" @onclick="() => AbrirXmlAsync(factura.Codfactura)">XML</button>
                                                <button type="button" class="link-btn" @onclick="() => AbrirPdfAsync(factura.Codfactura)">PDF</button>
                                                <button type="button" class="link-btn" @onclick="() => ReintentarSriAsync(factura)">SRI</button>
                                                <button type="button" class="link-btn" @onclick="() => ReenviarCorreoAsync(factura)">Correo</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>

        <section class="panel-card">
            <div class="panel-head">
                <div>
                    <span class="panel-kicker">Historial real</span>
                    <h3>Mis facturas backoffice</h3>
                </div>
            </div>

            <div class="state-card compact">
                <p>Las facturas del backoffice ahora viven en una vista separada para no mezclar la configuracion maestra con tu historial personal.</p>
                <div class="form-actions">
                    <button type="button" class="secondary-btn" @onclick="IrAMisFacturasBackOffice">
                        Abrir mis facturas backoffice
                    </button>
                </div>
            </div>
        </section>

        <section class="panel-card">
            <div class="panel-head">
                <div>
                    <span class="panel-kicker">Punto de emision</span>
                    <h3>Caja maestra del sistema</h3>
                </div>
            </div>

            @if (ownerUserId <= 0)
            {
                <div class="state-card compact">
                    <p>Configura primero el emisor maestro para poder activar su caja principal.</p>
                </div>
            }
            else
            {
                <div class="sequence-summary">
                    <div class="sequence-chip">
                        <span>Caja principal</span>
                        <strong>@(cajasSistema.FirstOrDefault(c => (c.NumCaja ?? 0) == 1) is Caja cajaPrincipal ? FormatearSerie(cajaPrincipal.SerieFactura) : "No configurada")</strong>
                    </div>
                    <div class="sequence-chip">
                        <span>Puntos activos</span>
                        <strong>@cajasSistema.Count</strong>
                    </div>
                    <div class="sequence-chip">
                        <span>Serie usada por sistema</span>
                        <strong>@(secuenciaSistema?.SerieVisual ?? "--")</strong>
                    </div>
                </div>

                <div class="box-form">
                    <div class="field field-sequence">
                        <label>Establecimiento</label>
                        <InputText @bind-Value="cajaForm.Establecimiento" class="field-input" maxlength="3" />
                    </div>
                    <div class="field field-sequence">
                        <label>Punto de emision</label>
                        <InputText @bind-Value="cajaForm.PuntoEmision" class="field-input" maxlength="3" />
                    </div>
                </div>

                <div class="field-help">Serie vista previa: <strong>@SerieCajaPreview</strong></div>

                <div class="form-actions">
                    <button type="button" class="primary-btn" @onclick="GuardarCajaSistemaAsync" disabled="@guardandoCaja">
                        @(guardandoCaja ? "Guardando..." : "Guardar caja del sistema")
                    </button>
                </div>

                @if (cajasSistema.Any())
                {
                    <div class="table-wrap top-gap">
                        <table class="facturas-table">
                            <thead>
                                <tr>
                                    <th>Caja</th>
                                    <th>Serie</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var caja in cajasSistema.OrderBy(c => c.NumCaja).ThenBy(c => c.Sec))
                                {
                                    <tr>
                                        <td>@(caja.NumCaja ?? 0)</td>
                                        <td>@FormatearSerie(caja.SerieFactura)</td>
                                        <td>@((caja.NumCaja ?? 0) == 1 ? "Principal" : "Activa")</td>
                                        <td>
                                            <div class="table-actions">
                                                <button type="button" class="link-btn" @onclick="() => SeleccionarCajaSistema(caja)">Editar</button>
                                                @if ((caja.NumCaja ?? 0) != 1)
                                                {
                                                    <button type="button" class="link-btn" @onclick="() => MarcarCajaPrincipalSistemaAsync(caja)">Marcar principal</button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </section>

        <section class="panel-card">
            <div class="panel-head">
                <div>
                    <span class="panel-kicker">Control de secuencia</span>
                    <h3>Secuencia del facturador del sistema</h3>
                </div>
            </div>

            @if (secuenciaSistema is null)
            {
                <div class="state-card compact">
                    <p>Configura primero el emisor maestro y asegúrate de que la cuenta dueña tenga caja activa para poder definir la secuencia.</p>
                </div>
            }
            else
            {
                <div class="sequence-summary">
                    <div class="sequence-chip">
                        <span>Serie actual</span>
                        <strong>@secuenciaSistema.SerieVisual</strong>
                    </div>
                    <div class="sequence-chip">
                        <span>Ultima secuencia registrada</span>
                        <strong>@(string.IsNullOrWhiteSpace(secuenciaSistema.UltimaSecuencia) ? "No definida" : secuenciaSistema.UltimaSecuencia)</strong>
                    </div>
                    <div class="sequence-chip">
                        <span>Siguiente factura</span>
                        <strong>@(string.IsNullOrWhiteSpace(secuenciaSistema.SiguienteSecuencia) ? "000000001" : secuenciaSistema.SiguienteSecuencia)</strong>
                    </div>
                </div>

                <div class="sequence-form">
                    <label class="check-row">
                        <input type="checkbox" @bind="secuenciaForm.YaFacturoAntes" />
                        <span>El sistema ya emitio facturas antes con esta serie</span>
                    </label>

                    @if (secuenciaForm.YaFacturoAntes)
                    {
                        <div class="field field-sequence">
                            <label>Ultima secuencia emitida</label>
                            <InputText @bind-Value="secuenciaForm.UltimaSecuencia" class="field-input" placeholder="Ej: 000000125" />
                            <small class="field-help">Aqui debes indicar la ultima factura ya usada. El sistema emitira la siguiente para evitar duplicados.</small>
                        </div>
                    }

                    <div class="form-actions">
                        <button type="button" class="primary-btn" @onclick="GuardarSecuenciaAsync" disabled="@guardandoSecuencia">
                            @(guardandoSecuencia ? "Guardando..." : "Guardar secuencia del sistema")
                        </button>
                    </div>
                </div>
            }
        </section>

        @if (facturaSeleccionada?.Factura != null)
        {
            <section class="panel-card detail-card">
                <div class="panel-head">
                    <div>
                        <span class="panel-kicker">Detalle</span>
                        <h3>Factura @($"{facturaSeleccionada.Factura.Serie}-{facturaSeleccionada.Factura.Numfactura}")</h3>
                    </div>
                </div>
                <div class="detail-grid">
                    <div><strong>Cliente:</strong> @(facturaSeleccionada.Cliente?.Nombrerazonsocial ?? $"{facturaSeleccionada.Cliente?.Nombres} {facturaSeleccionada.Cliente?.Apellidos}".Trim())</div>
                    <div><strong>Identificacion:</strong> @facturaSeleccionada.Cliente?.Numeroidentificacion</div>
                    <div><strong>Total:</strong> $ @(facturaSeleccionada.Factura.Valortotal?.ToString("N2") ?? "0.00")</div>
                    <div><strong>Estado SRI:</strong> @facturaSeleccionada.Factura.Estadoenviosri</div>
                    <div class="detail-full"><strong>Notas:</strong> @facturaSeleccionada.Factura.Notas</div>
                </div>
            </section>
        }
    }
</div>

@code {
    private const long MaxCertificadoSize = 5 * 1024 * 1024;

    private readonly List<FacturaListDto> facturasSistema = new();
    private EmisorSistemaFormModel formModel = new();
    private FacturaViewDto? facturaSeleccionada;
    private bool cargando = true;
    private bool guardando;
    private bool tieneAcceso;
    private bool emisorConfigurado;
    private bool firmaConfigurada;
    private bool guardandoSecuencia;
    private bool guardandoCaja;
    private bool consultandoIdentificacion;
    private bool mostrarClaveCertificado;
    private int currentUserId;
    private int ownerUserId;
    private string? feedbackMessage;
    private bool feedbackIsSuccess;
    private string? nombrePathCertificadoActual;
    private string identificacionBusqueda = string.Empty;
    private EmisorSistemaSecuenciaInfo? secuenciaSistema;
    private SecuenciaSistemaFormModel secuenciaForm = new();
    private readonly List<Caja> cajasSistema = new();
    private Caja? cajaSistemaSeleccionada;
    private CajaSistemaFormModel cajaForm = new();
    private string SerieCajaPreview => $"{NormalizarCodigoPreview(cajaForm.Establecimiento)}-{NormalizarCodigoPreview(cajaForm.PuntoEmision)}";
    private string RucEmisorActual => string.IsNullOrWhiteSpace(formModel.Ruc) ? "--" : formModel.Ruc;
    private string RazonSocialEmisorActual => FirstNonEmpty(formModel.RazonSocial, formModel.NomComercial) ?? "--";
    private string SeriePrincipalSistemaActual => FormatearSerie(cajasSistema.OrderBy(c => c.NumCaja).ThenBy(c => c.Sec).FirstOrDefault()?.SerieFactura);
    private string UltimaFacturaSistema => facturasSistema.FirstOrDefault()?.NumeroCompleto ?? "--";
    private int TotalFacturasAutorizadasSistema => facturasSistema.Count(f => DocumentoAutorizacionHelper.EstaAutorizado(f.Autorizado, f.EstadoSri));
    private int TotalFacturasPendientesSistema => Math.Max(facturasSistema.Count - TotalFacturasAutorizadasSistema, 0);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        currentUserId = int.TryParse(
            user.FindFirst(ClaimTypes.NameIdentifier)?.Value ??
            user.FindFirst("IdUsuario")?.Value,
            out var idUsuario)
            ? idUsuario
            : 0;

        var role = user.FindFirst("IdTipoUsuario")?.Value;
        tieneAcceso = currentUserId > 0 && (role == "7" || role == "2");
        await RecargarAsync();
    }

    private async Task RecargarAsync()
    {
        cargando = true;
        try
        {
            if (!tieneAcceso)
                return;

            var emisor = await EmisorSistemaService.GetEmisorSistemaAsync();
            emisorConfigurado = emisor != null;
            firmaConfigurada = !string.IsNullOrWhiteSpace(emisor?.PathCertificado) &&
                               !string.IsNullOrWhiteSpace(emisor?.ClaveCertificado);
            ownerUserId = emisor?.IdUsuario ?? 0;
            nombrePathCertificadoActual = string.IsNullOrWhiteSpace(emisor?.PathCertificado)
                ? null
                : Path.GetFileName(emisor.PathCertificado);
            formModel = EmisorSistemaFormModel.FromEntity(emisor);
            secuenciaSistema = await EmisorSistemaService.GetSecuenciaFacturaSistemaAsync();
            secuenciaForm = SecuenciaSistemaFormModel.FromInfo(secuenciaSistema);
            await RecargarCajasSistemaAsync();

            await RecargarFacturasAsync();
        }
        catch (Exception ex)
        {
            SetFeedback(ex.Message, false);
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task RecargarFacturasAsync()
    {
        if (!tieneAcceso)
            return;

        facturasSistema.Clear();
        facturasSistema.AddRange(await EmisorSistemaService.ListarFacturasRecargasSistemaAsync());

    }

    private async Task RecargarCajasSistemaAsync()
    {
        cajasSistema.Clear();
        cajaSistemaSeleccionada = null;
        cajaForm = new();

        cajasSistema.AddRange(await ConfiguracionService.GetCajasSistemaActivasAsync());
        cajaSistemaSeleccionada = cajasSistema.OrderBy(c => c.NumCaja).ThenBy(c => c.Sec).FirstOrDefault();
        if (cajaSistemaSeleccionada != null)
            cajaForm = CajaSistemaFormModel.FromCaja(cajaSistemaSeleccionada);
    }

    private async Task GuardarAsync()
    {
        if (!tieneAcceso || currentUserId <= 0)
            return;

        guardando = true;
        try
        {
            SincronizarSerieEmisorCaja();
            var resultado = await EmisorSistemaService.GuardarAsync(currentUserId, formModel.ToEntity());
            SetFeedback(resultado.Message, resultado.Success);
            if (resultado.Success)
                await RecargarAsync();
        }
        catch (Exception ex)
        {
            SetFeedback(ex.Message, false);
        }
        finally
        {
            guardando = false;
        }
    }

