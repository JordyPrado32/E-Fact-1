    private Task SubirPathCertificado(InputFileChangeEventArgs e)
    {
        return SubirArchivoP12(e, relativePath =>
        {
            formModel.PathCertificado = relativePath;
            nombrePathCertificadoActual = e.File?.Name;
        });
    }

    private async Task SubirArchivoP12(InputFileChangeEventArgs e, Action<string> asignarRuta)
    {
        if (e.FileCount != 1 || e.File is null)
        {
            SetFeedback("Debes seleccionar un unico archivo .p12.", false);
            return;
        }

        var file = e.File;
        if (!string.Equals(Path.GetExtension(file.Name), ".p12", StringComparison.OrdinalIgnoreCase))
        {
            SetFeedback("Solo se permiten archivos .p12.", false);
            return;
        }

        if (file.Size <= 0 || file.Size > MaxCertificadoSize)
        {
            SetFeedback("El certificado debe ser valido y no superar 5 MB.", false);
            return;
        }

        await using var source = file.OpenReadStream(MaxCertificadoSize);
        await using var ms = new MemoryStream();
        await source.CopyToAsync(ms);
        var relativePath = await GuardarArchivoCertificadoAsync(ms.ToArray());
        asignarRuta(relativePath);
        SetFeedback("Certificado cargado correctamente. Guarda para confirmar el cambio.", true);
    }

    private async Task<string> GuardarArchivoCertificadoAsync(byte[] bytes)
    {
        var relativePath = $"certs/system/{Guid.NewGuid():N}.p12";
        var physicalPath = Path.Combine(
            HostEnvironment.ContentRootPath,
            "App_Data",
            relativePath.Replace('/', Path.DirectorySeparatorChar));

        var directory = Path.GetDirectoryName(physicalPath);
        if (!string.IsNullOrWhiteSpace(directory) && !Directory.Exists(directory))
            Directory.CreateDirectory(directory);

        await File.WriteAllBytesAsync(physicalPath, bytes);
        return relativePath;
    }

    private void SetFeedback(string message, bool success)
    {
        feedbackMessage = message;
        feedbackIsSuccess = success;
