    private void AplicarResultadoIdentificacion(CedulaLookupResult resultado, string identificacionNormalizada)
    {
        identificacionBusqueda = resultado.Ruc ?? resultado.Cedula ?? identificacionNormalizada;

        var razonSocial = FirstNonEmpty(resultado.RazonSocial, resultado.NombreCompleto);
        if (!string.IsNullOrWhiteSpace(razonSocial))
        {
            formModel.RazonSocial = razonSocial;
            if (string.IsNullOrWhiteSpace(formModel.NomComercial))
                formModel.NomComercial = razonSocial;
        }

        var nombreComercial = FirstNonEmpty(resultado.NombreComercial, resultado.RazonSocial, resultado.NombreCompleto);
        if (!string.IsNullOrWhiteSpace(nombreComercial))
            formModel.NomComercial = nombreComercial;

        var llevaContabilidad = NormalizarLlevaContabilidad(resultado.ObligadoLlevarContabilidad);
        if (!string.IsNullOrWhiteSpace(llevaContabilidad))
            formModel.LlevaContabilidad = llevaContabilidad;

        var direccion = FirstNonEmpty(resultado.DireccionEstablecimiento, resultado.DireccionMatriz);
        if (!string.IsNullOrWhiteSpace(resultado.DireccionMatriz))
            formModel.DireccionMatriz = resultado.DireccionMatriz.Trim();
        if (!string.IsNullOrWhiteSpace(direccion))
            formModel.DirEstablecimiento = direccion.Trim();

        var establecimiento = NormalizarCodigo(resultado.NumeroEstablecimiento);
        if (!string.IsNullOrWhiteSpace(establecimiento))
        {
            formModel.CodEstablecimiento = establecimiento;
            cajaForm.Establecimiento = establecimiento;
        }

        if (string.IsNullOrWhiteSpace(cajaForm.PuntoEmision) || NormalizarCodigo(cajaForm.PuntoEmision) is null)
            cajaForm.PuntoEmision = NormalizarCodigo(formModel.CodPuntoEmision) ?? "001";

        formModel.CodPuntoEmision = NormalizarCodigo(cajaForm.PuntoEmision) ?? "001";

        if (string.Equals(resultado.Tipo, "ruc", StringComparison.OrdinalIgnoreCase))
        {
            formModel.Ruc = resultado.Ruc ?? identificacionNormalizada;
            SetFeedback(
                string.IsNullOrWhiteSpace(establecimiento)
                    ? "Datos del emisor maestro cargados desde la consulta de RUC."
                    : $"Datos del emisor maestro cargados desde la consulta de RUC. Se detecto el establecimiento {establecimiento} y se precargo tambien en la caja del sistema.",
                true);
            return;
        }

        SetFeedback("Datos base cargados desde la cedula. Recuerda completar el RUC definitivo del emisor maestro antes de guardar.", true);
    }

    private Caja CrearNuevaCajaSistemaBase()
    {
        var principal = cajasSistema.OrderBy(c => c.NumCaja).ThenBy(c => c.Sec).FirstOrDefault();
        var siguienteNumero = cajasSistema.Select(c => c.NumCaja ?? 0).DefaultIfEmpty(0).Max() + 1;

        return new Caja
        {
            IdUsuario = ownerUserId,
            NumCaja = siguienteNumero,
            idJefe = ownerUserId,
            IdEmpresa = principal?.IdEmpresa is > 0 ? principal.IdEmpresa : 1,
            IdSucursal = principal?.IdSucursal is > 0 ? principal.IdSucursal : 1
        };
    }

    private static Caja ClonarCaja(Caja caja) => new()
    {
        Sec = caja.Sec,
        NumCaja = caja.NumCaja,
        IdUsuario = caja.IdUsuario,
        IdEmpresa = caja.IdEmpresa,
        IdSucursal = caja.IdSucursal,
        SerieFactura = caja.SerieFactura,
        SerieCompras = caja.SerieCompras,
        SerieGuia = caja.SerieGuia,
        SerieDebitos = caja.SerieDebitos,
        SerieNotasCred = caja.SerieNotasCred,
        Estado = caja.Estado
    };

    private static string FormatearSerie(string? serie)
    {
        var digits = new string((serie ?? string.Empty).Where(char.IsDigit).ToArray());
        if (digits.Length >= 6)
            return $"{digits[..3]}-{digits.Substring(3, 3)}";

        return string.IsNullOrWhiteSpace(serie) ? "--" : serie.Trim();
    }

    private static string? NormalizarCodigo(string? value)
    {
        var digits = new string((value ?? string.Empty).Where(char.IsDigit).ToArray());
        if (digits.Length == 0 || digits == "000")
            return null;

        return digits.Length >= 3 ? digits[^3..] : digits.PadLeft(3, '0');
    }

    private static string NormalizarCodigoPreview(string? value)
        => NormalizarCodigo(value) ?? "000";

    private static string NormalizarIdentificacion(string? value)
        => new string((value ?? string.Empty).Where(char.IsDigit).ToArray());

    private static string? FirstNonEmpty(params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value))?.Trim();

    private static string NormalizarLlevaContabilidad(string? value)
        => string.Equals(value?.Trim(), "SI", StringComparison.OrdinalIgnoreCase) ? "SI" : "NO";

