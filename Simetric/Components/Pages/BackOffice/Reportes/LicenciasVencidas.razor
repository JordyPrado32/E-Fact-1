@page "/backoffice/reportes/licencias-vencidas"
@namespace Simetric.Components.Pages.BackOffice
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.DTOs
@using System.Globalization
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject NavigationManager NavManager

<PageTitle>Licencias Vencidas - BackOffice</PageTitle>

<link href="css/reportes-compartido.css" rel="stylesheet" />

<div class="reports-container">
    <div class="report-header-card no-print animate__animated animate__fadeIn">
        <div class="report-header-top">
            <h2 class="report-page-title">
                <i class="bi bi-shield-slash-fill"></i> Reporte Licencias Vencidas
            </h2>
            <button type="button" class="btn-export" @onclick="DescargarReportePdf">
                <i class="bi bi-file-earmark-pdf-fill"></i> Descargar PDF Directo
            </button>
        </div>
        <div class="report-header-filters">
            <div class="filter-group">
                <span class="filter-label">Desde:</span>
                <input type="date" @bind="fechaInicio" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-group">
                <span class="filter-label">Hasta:</span>
                <input type="date" @bind="fechaFin" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-presets">
                <button type="button" class="btn-preset @(presetActivo == "mes" ? "active" : "")" @onclick='() => AplicarPreset("mes")'>Este Mes</button>
                <button type="button" class="btn-preset @(presetActivo == "trimestre" ? "active" : "")" @onclick='() => AplicarPreset("trimestre")'>Últimos 90 Días</button>
                <button type="button" class="btn-preset @(presetActivo == "anio" ? "active" : "")" @onclick='() => AplicarPreset("anio")'>Este Año</button>
                <button type="button" class="btn-preset @(presetActivo == "todo" ? "active" : "")" @onclick='() => AplicarPreset("todo")'>Todo</button>
            </div>
        </div>
    </div>

    <!-- Sliding Viewport Container -->
    <div class="reports-viewport printable-report" id="report-view-area">
        <div class="report-slide report-slide-active">
            <div class="visual-header">
                <h3 class="visual-title">Reporte de Licencias Vencidas</h3>
                <p class="visual-subtitle">Listado de suscripciones caducadas que requieren renovación o cobranza.</p>
            </div>

            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando datos...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="kpis-grid">
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-red"><i class="bi bi-shield-slash"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Licencias Vencidas</span>
                            <strong class="kpi-card-value">@licenciasVencidasList.Count</strong>
                            <span class="kpi-card-trend trend-down">Suscripciones inactivas</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-orange"><i class="bi bi-piggy-bank"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Vencidas 30 dias</span>
                            <strong class="kpi-card-value">@licenciasVencidasRecientes</strong>
                            <span class="kpi-card-trend trend-neutral">Cartera en riesgo</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-purple"><i class="bi bi-shield-exclamation"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Tasa de Churn</span>
                            <strong class="kpi-card-value">@tasaChurn.ToString("N2") %</strong>
                            <span class="kpi-card-trend trend-neutral">Vencidas vs activas</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-blue"><i class="bi bi-envelope-fill"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Casos por renovar</span>
                            <strong class="kpi-card-value">@licenciasVencidasList.Count</strong>
                            <span class="kpi-card-trend trend-neutral">Avisos automáticos</span>
                        </div>
                    </div>
                </div>

                <div class="report-visual-card">
                    <div class="visual-header">
                        <h4 class="visual-title">Histórico de Churn y Licencias Vencidas</h4>
                        <p class="visual-subtitle">Cantidad de licencias vencidas acumuladas en los últimos meses.</p>
                    </div>
                    <div class="chart-container">
                        @if (licenciasVencidasChartData.Any())
                        {
                            <svg class="svg-chart" viewBox="0 0 800 300" preserveAspectRatio="none">
                                <!-- Grid Lines -->
                                @for (int i = 0; i <= 5; i++)
                                {
                                    var y = 30 + i * 44;
                                    <line class="chart-grid-line" x1="50" y1="@y" x2="750" y2="@y" />
                                    var val = Math.Round((double)maxLicenciasVencidasChart * (5 - i) / 5.0);
                                    <g><text class="chart-axis-text" x="15" y="@(y + 4)">@val</text></g>
                                }

                                <!-- X Axis Labels -->
                                @for (int i = 0; i < licenciasVencidasChartData.Count; i++)
                                {
                                    var x = 80 + i * (620.0 / Math.Max(1, licenciasVencidasChartData.Count - 1));
                                    <g><text class="chart-axis-text" x="@x" y="275" text-anchor="middle">@licenciasVencidasChartData[i].Etiqueta</text></g>
                                    <line class="chart-axis-line" x1="@x" y1="250" x2="@x" y2="255" />
                                }

                                <!-- Path line -->
                                <path d="@GetLicenciasVencidasLinePath()" fill="none" stroke="#dc2626" stroke-width="3" class="chart-line" />

                                <!-- Points -->
                                @for (int i = 0; i < licenciasVencidasChartData.Count; i++)
                                {
                                    var x = 80 + i * (620.0 / Math.Max(1, licenciasVencidasChartData.Count - 1));
                                    var y = GetYCoordinate(licenciasVencidasChartData[i].Valor, (decimal)maxLicenciasVencidasChart);
                                    <circle class="chart-dot" cx="@x" cy="@y" r="5" fill="#ffffff" stroke="#dc2626" stroke-width="2.5" />
                                }
                            </svg>
                        }
                    </div>
                </div>

                <div class="report-table-card">
                    <div class="table-header-row">
                        <h4 class="table-title">Detalle de Suscripciones Caducadas</h4>
                    </div>
                    <table class="bo-table">
                        <thead>
                            <tr>
                                <th>Cliente ID</th>
                                <th>Plan Contratado</th>
                                <th>Ciclo</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Vencimiento</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (licenciasVencidasPaginadas.Any())
                            {
                                @foreach (var l in licenciasVencidasPaginadas)
                                {
                                    <tr>
                                        <td><strong>Cliente # @l.IdUsuario</strong></td>
                                        <td>@l.PlanActual</td>
                                        <td>@l.CicloActual</td>
                                        <td>@l.FechaInicio?.ToString("dd/MM/yyyy")</td>
                                        <td class="text-danger">@l.FechaFin?.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="status-pill status-pill-danger">@l.Estado</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No hay licencias vencidas registradas.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="pagination-controls">
                        <span class="page-indicator">Página @(pageLicVencidas + 1) de @MaxPaginaLicVencidas</span>
                        <div class="pagination-btn-group">
                            <button type="button" class="btn-pagination" disabled="@(pageLicVencidas == 0)" @onclick="() => CambiarPaginaLicVencidas(-1)">
                                <i class="bi bi-chevron-left"></i> Ant.
                            </button>
                            <button type="button" class="btn-pagination" disabled="@(pageLicVencidas >= MaxPaginaLicVencidas - 1)" @onclick="() => CambiarPaginaLicVencidas(1)">
                                Sig. <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private DateTime fechaInicio = DateTime.Now.AddMonths(-3);
    private DateTime fechaFin = DateTime.Now;
    private string presetActivo = "trimestre";
    private bool loading = true;

    private int licenciasVencidasRecientes = 0;
    private decimal tasaChurn = 0;

    private List<UsuarioServicioSuscripcion> licenciasVencidasList = new();
    private List<ChartItemDto> licenciasVencidasChartData = new();
    private int maxLicenciasVencidasChart = 10;
    private const double ChartTop = 38.0;
    private const double ChartBottom = 245.0;

    private int pageLicVencidas = 0;
    private const int PageSize = 10;
    private int MaxPaginaLicVencidas => Math.Max(1, (int)Math.Ceiling(licenciasVencidasList.Count / (double)PageSize));
    private List<UsuarioServicioSuscripcion> licenciasVencidasPaginadas => licenciasVencidasList.Skip(pageLicVencidas * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        AplicarPreset("trimestre");
    }

    private async Task OnDatesChanged()
    {
        presetActivo = "";
        await CargarDatosReportesAsync();
    }

    private void AplicarPreset(string preset)
    {
        presetActivo = preset;
        var hoy = DateTime.Now;
        if (preset == "mes")
        {
            fechaInicio = new DateTime(hoy.Year, hoy.Month, 1);
            fechaFin = hoy;
        }
        else if (preset == "trimestre")
        {
            fechaInicio = hoy.AddDays(-90);
            fechaFin = hoy;
        }
        else if (preset == "anio")
        {
            fechaInicio = new DateTime(hoy.Year, 1, 1);
            fechaFin = hoy;
        }
        else if (preset == "todo")
        {
            fechaInicio = new DateTime(2020, 1, 1);
            fechaFin = hoy;
        }
        _ = CargarDatosReportesAsync();
    }

    private async Task CargarDatosReportesAsync()
    {
        loading = true;
        StateHasChanged();

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();

            var activeUserIds = await context.Usuarios
                .Where(u => u.IdTipoUsuario == 1)
                .Select(u => u.IdUsuario)
                .ToListAsync();

            var licenciasActivasCount = await context.UsuarioServicioSuscripciones
                .AsNoTracking()
                .CountAsync(s => activeUserIds.Contains(s.IdUsuario) && (s.Estado == "ACTIVA" || s.Estado == "VIGENTE"));

            licenciasVencidasList = await context.UsuarioServicioSuscripciones
                .AsNoTracking()
                .Where(s => activeUserIds.Contains(s.IdUsuario) && (s.Estado == "VENCIDA" || s.Estado == "CADUCADA" || (s.FechaFin.HasValue && s.FechaFin.Value < DateTime.Now)))
                .OrderByDescending(s => s.FechaFin)
                .ToListAsync();

            if (licenciasVencidasList.Any())
            {
                licenciasVencidasRecientes = licenciasVencidasList.Count(s => s.FechaFin.HasValue && s.FechaFin.Value >= DateTime.Now.AddDays(-30));
                tasaChurn = licenciasActivasCount > 0
                    ? Math.Round((decimal)licenciasVencidasList.Count * 100m / licenciasActivasCount, 2)
                    : 0m;

                licenciasVencidasChartData = licenciasVencidasList
                    .GroupBy(l => l.FechaFin.HasValue ? l.FechaFin.Value.ToString("MMM") : "S/F")
                    .Select(g => new ChartItemDto { Etiqueta = g.Key, Valor = (decimal)g.Count() })
                    .ToList();
                maxLicenciasVencidasChart = licenciasVencidasChartData.Any() ? (int)licenciasVencidasChartData.Max(x => x.Valor) : 10;
            }
            else
            {
                licenciasVencidasRecientes = 0;
                tasaChurn = 0;
                licenciasVencidasChartData = new List<ChartItemDto>();
                maxLicenciasVencidasChart = 10;
            }
        }
        catch (Exception)
        {
            // Fail silent
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private void CambiarPaginaLicVencidas(int step)
    {
        pageLicVencidas += step;
        if (pageLicVencidas < 0) pageLicVencidas = 0;
        if (pageLicVencidas >= MaxPaginaLicVencidas) pageLicVencidas = MaxPaginaLicVencidas - 1;
    }

    private string GetLicenciasVencidasLinePath()
    {
        if (!licenciasVencidasChartData.Any()) return "";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < licenciasVencidasChartData.Count; i++)
        {
            var x = 80 + i * (620.0 / Math.Max(1, licenciasVencidasChartData.Count - 1));
            var y = GetYCoordinate(licenciasVencidasChartData[i].Valor, (decimal)maxLicenciasVencidasChart);
            if (i == 0)
                sb.Append($"M {x.ToString("F1", CultureInfo.InvariantCulture)} {y.ToString("F1", CultureInfo.InvariantCulture)}");
            else
                sb.Append($" L {x.ToString("F1", CultureInfo.InvariantCulture)} {y.ToString("F1", CultureInfo.InvariantCulture)}");
        }
        return sb.ToString();
    }

    private double GetYCoordinate(decimal value, decimal maxValue)
    {
        if (maxValue <= 0) return ChartBottom;
        var safeValue = Math.Max(0m, Math.Min(value, maxValue));
        var ratio = (double)(safeValue / maxValue);
        return ChartBottom - (ratio * (ChartBottom - ChartTop));
    }

    private async Task DescargarReportePdf()
    {
        var filename = $"Reporte_Licencias_Vencidas_{DateTime.Now:yyyyMMdd_HHmm}.pdf";
        await JS.InvokeVoidAsync("window.downloadPdfReport", "report-view-area", filename);
    }
}
