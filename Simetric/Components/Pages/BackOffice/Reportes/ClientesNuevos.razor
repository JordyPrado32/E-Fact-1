@page "/backoffice/reportes/clientes-nuevos"
@namespace Simetric.Components.Pages.BackOffice
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.DTOs
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject NavigationManager NavManager

<PageTitle>Clientes Nuevos - BackOffice</PageTitle>

<link href="css/reportes-compartido.css" rel="stylesheet" />

<div class="reports-container">
    <div class="report-header-card no-print animate__animated animate__fadeIn">
        <div class="report-header-top">
            <h2 class="report-page-title">
                <i class="bi bi-people-fill"></i> Reporte Clientes Nuevos
            </h2>
            <button type="button" class="btn-export" @onclick="DescargarReportePdf">
                <i class="bi bi-file-earmark-pdf-fill"></i> Descargar PDF Directo
            </button>
        </div>
        <div class="report-header-filters">
            <div class="filter-group">
                <span class="filter-label">Desde:</span>
                <input type="date" @bind="fechaInicio" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-group">
                <span class="filter-label">Hasta:</span>
                <input type="date" @bind="fechaFin" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-presets">
                <button type="button" class="btn-preset @(presetActivo == "mes" ? "active" : "")" @onclick='() => AplicarPreset("mes")'>Este Mes</button>
                <button type="button" class="btn-preset @(presetActivo == "trimestre" ? "active" : "")" @onclick='() => AplicarPreset("trimestre")'>Últimos 90 Días</button>
                <button type="button" class="btn-preset @(presetActivo == "anio" ? "active" : "")" @onclick='() => AplicarPreset("anio")'>Este Año</button>
                <button type="button" class="btn-preset @(presetActivo == "todo" ? "active" : "")" @onclick='() => AplicarPreset("todo")'>Todo</button>
            </div>
        </div>
    </div>

    <!-- Sliding Viewport Container -->
    <div class="reports-viewport printable-report" id="report-view-area">
        <div class="report-slide report-slide-active">
            <div class="visual-header">
                <h3 class="visual-title">Reporte de Clientes Nuevos</h3>
                <p class="visual-subtitle">Adquisición de nuevos contribuyentes y registros en el BackOffice.</p>
            </div>

            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando datos...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="kpis-grid">
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-green"><i class="bi bi-people-fill"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Registros Nuevos</span>
                            <strong class="kpi-card-value">@clientesNuevosList.Count</strong>
                            <span class="kpi-card-trend trend-up">Contribuyentes añadidos</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-blue"><i class="bi bi-person-fill"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Persona Natural</span>
                            <strong class="kpi-card-value">@totalClientesNaturales</strong>
                            <span class="kpi-card-trend trend-neutral">Física / Natural</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-purple"><i class="bi bi-building"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Personas Jurídicas</span>
                            <strong class="kpi-card-value">@totalClientesEmpresas</strong>
                            <span class="kpi-card-trend trend-neutral">Sociedades / RUC</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-orange"><i class="bi bi-percent"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Tasa de Conversión</span>
                            <strong class="kpi-card-value">84.2 %</strong>
                            <span class="kpi-card-trend trend-up"><i class="bi bi-arrow-up"></i> Activos</span>
                        </div>
                    </div>
                </div>

                <div class="report-visual-card">
                    <div class="visual-header">
                        <h4 class="visual-title">Adquisición de Clientes Nuevos</h4>
                        <p class="visual-subtitle">Cantidad de registros nuevos en el período por tipo de identificación.</p>
                    </div>
                    <div class="chart-container">
                        @if (clientesNuevosChartData.Any())
                        {
                            <svg class="svg-chart" viewBox="0 0 800 300" preserveAspectRatio="none">
                                <!-- Grid Lines -->
                                @for (int i = 0; i <= 5; i++)
                                {
                                    var y = 30 + i * 44;
                                    <line class="chart-grid-line" x1="50" y1="@y" x2="750" y2="@y" />
                                    var val = Math.Round((double)maxClientesNuevosChart * (5 - i) / 5.0);
                                    <g><text class="chart-axis-text" x="15" y="@(y + 4)">@val</text></g>
                                }

                                <!-- X Axis Labels -->
                                @for (int i = 0; i < clientesNuevosChartData.Count; i++)
                                {
                                    var x = 80 + i * (620.0 / Math.Max(1, clientesNuevosChartData.Count - 1));
                                    <g><text class="chart-axis-text" x="@x" y="275" text-anchor="middle">@clientesNuevosChartData[i].Etiqueta</text></g>
                                    <line class="chart-axis-line" x1="@x" y1="250" x2="@x" y2="255" />
                                }

                                <!-- Bars -->
                                @for (int i = 0; i < clientesNuevosChartData.Count; i++)
                                {
                                    var item = clientesNuevosChartData[i];
                                    var x = 60 + i * (620.0 / Math.Max(1, clientesNuevosChartData.Count - 1));
                                    var barHeight = maxClientesNuevosChart > 0 ? (double)(item.Valor / (decimal)maxClientesNuevosChart) * 220.0 : 0.0;
                                    var y = 250 - barHeight;
                                    <rect class="chart-bar" x="@x" y="@y" width="40" height="@barHeight" rx="6" fill="#16a34a" />
                                }
                            </svg>
                        }
                    </div>
                </div>

                <div class="report-table-card">
                    <div class="table-header-row">
                        <h4 class="table-title">Detalle de Nuevos Contribuyentes</h4>
                    </div>
                    <table class="bo-table">
                        <thead>
                            <tr>
                                <th>Cliente / Razón Social</th>
                                <th>Identificación</th>
                                <th>Tipo</th>
                                <th>Contacto</th>
                                <th>Fecha Ingreso</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (clientesNuevosPaginados.Any())
                            {
                                @foreach (var c in clientesNuevosPaginados)
                                {
                                    <tr>
                                        <td><strong>@(c.Nombrerazonsocial ?? $"{c.Nombres} {c.Apellidos}")</strong></td>
                                        <td>@c.Numeroidentificacion</td>
                                        <td>
                                            <span class="status-pill @(c.Personanatural == true ? "status-pill-info" : "status-pill-success")">
                                                @(c.Personanatural == true ? "Natural" : "Jurídico")
                                            </span>
                                        </td>
                                        <td>@c.Correo<br/><span class="text-muted">@c.Celular</span></td>
                                        <td>@c.Fechaingreso?.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No hay clientes nuevos registrados en este rango de fechas.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="pagination-controls">
                        <span class="page-indicator">Página @(pageClientes + 1) de @MaxPaginaClientes</span>
                        <div class="pagination-btn-group">
                            <button type="button" class="btn-pagination" disabled="@(pageClientes == 0)" @onclick="() => CambiarPaginaClientes(-1)">
                                <i class="bi bi-chevron-left"></i> Ant.
                            </button>
                            <button type="button" class="btn-pagination" disabled="@(pageClientes >= MaxPaginaClientes - 1)" @onclick="() => CambiarPaginaClientes(1)">
                                Sig. <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private DateTime fechaInicio = DateTime.Now.AddMonths(-3);
    private DateTime fechaFin = DateTime.Now;
    private string presetActivo = "trimestre";
    private bool loading = true;

    private int totalClientesNaturales = 0;
    private int totalClientesEmpresas = 0;

    private List<Cliente> clientesNuevosList = new();
    private List<ChartItemDto> clientesNuevosChartData = new();
    private int maxClientesNuevosChart = 10;

    private int pageClientes = 0;
    private const int PageSize = 10;
    private int MaxPaginaClientes => Math.Max(1, (int)Math.Ceiling(clientesNuevosList.Count / (double)PageSize));
    private List<Cliente> clientesNuevosPaginados => clientesNuevosList.Skip(pageClientes * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        AplicarPreset("trimestre");
    }

    private async Task OnDatesChanged()
    {
        presetActivo = "";
        await CargarDatosReportesAsync();
    }

    private void AplicarPreset(string preset)
    {
        presetActivo = preset;
        var hoy = DateTime.Now;
        if (preset == "mes")
        {
            fechaInicio = new DateTime(hoy.Year, hoy.Month, 1);
            fechaFin = hoy;
        }
        else if (preset == "trimestre")
        {
            fechaInicio = hoy.AddDays(-90);
            fechaFin = hoy;
        }
        else if (preset == "anio")
        {
            fechaInicio = new DateTime(hoy.Year, 1, 1);
            fechaFin = hoy;
        }
        else if (preset == "todo")
        {
            fechaInicio = new DateTime(2020, 1, 1);
            fechaFin = hoy;
        }
        _ = CargarDatosReportesAsync();
    }

    private async Task CargarDatosReportesAsync()
    {
        loading = true;
        StateHasChanged();

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();

            var dateInicioOnly = DateOnly.FromDateTime(fechaInicio);
            var dateFinOnly = DateOnly.FromDateTime(fechaFin);

            var newClients = await context.Clientes
                .AsNoTracking()
                .Where(c => c.Fechaingreso >= dateInicioOnly && c.Fechaingreso <= dateFinOnly)
                .OrderByDescending(c => c.Fechaingreso)
                .ToListAsync();

            clientesNuevosList = newClients;
            totalClientesNaturales = clientesNuevosList.Count(c => c.Personanatural == true);
            totalClientesEmpresas = clientesNuevosList.Count(c => c.Personanatural == false);

            var groupedByIdentification = clientesNuevosList
                .GroupBy(c => c.Tipoidentificacion ?? "Otros")
                .Select(g => new ChartItemDto
                {
                    Etiqueta = NormalizarTipoIdentificacion(g.Key),
                    Valor = g.Count()
                })
                .ToList();

            clientesNuevosChartData = groupedByIdentification;
            maxClientesNuevosChart = clientesNuevosChartData.Any()
                ? (int)clientesNuevosChartData.Max(x => x.Valor)
                : 10;
            if (maxClientesNuevosChart <= 0) maxClientesNuevosChart = 10;
        }
        catch (Exception)
        {
            // Fail silent
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private void CambiarPaginaClientes(int step)
    {
        pageClientes += step;
        if (pageClientes < 0) pageClientes = 0;
        if (pageClientes >= MaxPaginaClientes) pageClientes = MaxPaginaClientes - 1;
    }

    private static string NormalizarTipoIdentificacion(string tipo)
    {
        if (tipo == "04") return "RUC";
        if (tipo == "05") return "Cédula";
        if (tipo == "06") return "Pasaporte";
        return "Otros";
    }

    private async Task DescargarReportePdf()
    {
        var filename = $"Reporte_Clientes_Nuevos_{DateTime.Now:yyyyMMdd_HHmm}.pdf";
        await JS.InvokeVoidAsync("window.downloadPdfReport", "report-view-area", filename);
    }
}
