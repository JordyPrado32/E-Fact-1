@page "/backoffice/reportes/ventas-periodo"
@namespace Simetric.Components.Pages.BackOffice
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.DTOs
@using System.Globalization
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject NavigationManager NavManager

<PageTitle>Ventas por Periodo - BackOffice</PageTitle>

<link href="css/reportes-compartido.css" rel="stylesheet" />

<div class="reports-container">
    <div class="report-header-card no-print animate__animated animate__fadeIn">
        <div class="report-header-top">
            <h2 class="report-page-title">
                <i class="bi bi-calendar-range-fill"></i> Reporte Ventas Periodo
            </h2>
            <button type="button" class="btn-export" @onclick="DescargarReportePdf">
                <i class="bi bi-file-earmark-pdf-fill"></i> Descargar PDF Directo
            </button>
        </div>
        <div class="report-header-filters">
            <div class="filter-group">
                <span class="filter-label">Desde:</span>
                <input type="date" @bind="fechaInicio" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-group">
                <span class="filter-label">Hasta:</span>
                <input type="date" @bind="fechaFin" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-presets">
                <button type="button" class="btn-preset @(presetActivo == "mes" ? "active" : "")" @onclick='() => AplicarPreset("mes")'>Este Mes</button>
                <button type="button" class="btn-preset @(presetActivo == "trimestre" ? "active" : "")" @onclick='() => AplicarPreset("trimestre")'>Últimos 90 Días</button>
                <button type="button" class="btn-preset @(presetActivo == "anio" ? "active" : "")" @onclick='() => AplicarPreset("anio")'>Este Año</button>
                <button type="button" class="btn-preset @(presetActivo == "todo" ? "active" : "")" @onclick='() => AplicarPreset("todo")'>Todo</button>
            </div>
        </div>
    </div>

    <!-- Sliding Viewport Container -->
    <div class="reports-viewport printable-report" id="report-view-area">
        <div class="report-slide report-slide-active">
            <div class="visual-header">
                <h3 class="visual-title">Reporte de Ventas por Período</h3>
                <p class="visual-subtitle">Análisis temporal de ingresos brutos y transacciones. Rango: @fechaInicio.ToString("dd/MM/yyyy") al @fechaFin.ToString("dd/MM/yyyy")</p>
            </div>

            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando datos...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="kpis-grid">
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-blue"><i class="bi bi-cash-stack"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Ingreso Total</span>
                            <strong class="kpi-card-value">$ @totalVentasPeriodo.ToString("N2")</strong>
                            <span class="kpi-card-trend trend-neutral">Facturado en el rango</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-green"><i class="bi bi-receipt"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Comprobantes</span>
                            <strong class="kpi-card-value">@ventasPeriodoList.Count</strong>
                            <span class="kpi-card-trend trend-neutral">SRI Autorizados</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-purple"><i class="bi bi-graph-up-arrow"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Promedio Ticket</span>
                            <strong class="kpi-card-value">$ @ticketPromedioPeriodo.ToString("N2")</strong>
                            <span class="kpi-card-trend trend-neutral">Promedio por comprobante</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-orange"><i class="bi bi-percent"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Descuentos</span>
                            <strong class="kpi-card-value">$ @totalDescuentosPeriodo.ToString("N2")</strong>
                            <span class="kpi-card-trend trend-neutral">Descuentos aplicados</span>
                        </div>
                    </div>
                </div>

                <div class="report-visual-card">
                    <div class="visual-header">
                        <h4 class="visual-title">Tendencia de Ventas Diarias / Semanales</h4>
                        <p class="visual-subtitle">Gráfico estadístico de facturación histórica consolidada en el período.</p>
                    </div>
                    <div class="chart-container">
                        @if (ventasPeriodoChartData.Any())
                        {
                            <svg class="svg-chart" viewBox="0 0 800 300" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="ventasGrad" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.3"/>
                                        <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
                                    </linearGradient>
                                </defs>
                                
                                <!-- Grid Lines -->
                                @for (int i = 0; i <= 5; i++)
                                {
                                    var y = ChartTop + i * ((ChartBottom - ChartTop) / 5.0);
                                    <line class="chart-grid-line" x1="50" y1="@y" x2="750" y2="@y" />
                                    var val = Math.Round((double)maxVentaPeriodoChart * (5 - i) / 5.0, 0);
                                    <g><text class="chart-axis-text" x="15" y="@(y + 4)">$@val.ToString("N0")</text></g>
                                }

                                <!-- X Axis Labels -->
                                @for (int i = 0; i < ventasPeriodoChartData.Count; i++)
                                {
                                    var x = 50 + i * (700.0 / Math.Max(1, ventasPeriodoChartData.Count - 1));
                                    <g><text class="chart-axis-text" x="@x" y="275" text-anchor="middle">@ventasPeriodoChartData[i].Etiqueta</text></g>
                                    <line class="chart-axis-line" x1="@x" y1="@ChartBottom" x2="@x" y2="255" />
                                }

                                <!-- Area under path -->
                                <path d="@GetVentasPeriodoAreaPath()" fill="url(#ventasGrad)" />
                                <!-- Line Path -->
                                <path d="@GetVentasPeriodoLinePath()" fill="none" stroke="#0284c7" stroke-width="3" class="chart-line" />
                            </svg>
                        }
                    </div>
                </div>

                <div class="report-table-card">
                    <div class="table-header-row">
                        <h4 class="table-title">Detalle de Transacciones del Período</h4>
                    </div>
                    <table class="bo-table">
                        <thead>
                            <tr>
                                <th>Factura #</th>
                                <th>Fecha Emisión</th>
                                <th>Cliente</th>
                                <th>Subtotal</th>
                                <th>IVA (15%)</th>
                                <th>Total Factura</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ventasPeriodoPaginadas.Any())
                            {
                                @foreach (var v in ventasPeriodoPaginadas)
                                {
                                    <tr>
                                        <td><strong>@v.Serie-@v.Numfactura</strong></td>
                                        <td>@v.Fechaentrega?.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@(v.CodclientesNavigation?.Nombrerazonsocial ?? v.CodclientesNavigation?.Nombres ?? "Cliente General")</td>
                                        <td>$ @(v.Subtotal?.ToString("N2") ?? "0.00")</td>
                                        <td>$ @(v.Iva?.ToString("N2") ?? "0.00")</td>
                                        <td><strong class="text-blue">$ @(v.Valortotal?.ToString("N2") ?? "0.00")</strong></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No hay facturas registradas en este período.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="pagination-controls">
                        <span class="page-indicator">Página @(pageVentas + 1) de @MaxPaginaVentas</span>
                        <div class="pagination-btn-group">
                            <button type="button" class="btn-pagination" disabled="@(pageVentas == 0)" @onclick="() => CambiarPaginaVentas(-1)">
                                <i class="bi bi-chevron-left"></i> Ant.
                            </button>
                            <button type="button" class="btn-pagination" disabled="@(pageVentas >= MaxPaginaVentas - 1)" @onclick="() => CambiarPaginaVentas(1)">
                                Sig. <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private DateTime fechaInicio = DateTime.Now.AddMonths(-3);
    private DateTime fechaFin = DateTime.Now;
    private string presetActivo = "trimestre";
    private bool loading = true;

    private List<Factura> ventasPeriodoList = new();
    private decimal totalVentasPeriodo = 0;
    private decimal totalDescuentosPeriodo = 0;
    private decimal ticketPromedioPeriodo = 0;

    private List<ChartItemDto> ventasPeriodoChartData = new();
    private decimal maxVentaPeriodoChart = 100;
    private const double ChartTop = 38.0;
    private const double ChartBottom = 245.0;

    private int pageVentas = 0;
    private const int PageSize = 10;
    private int MaxPaginaVentas => Math.Max(1, (int)Math.Ceiling(ventasPeriodoList.Count / (double)PageSize));
    private List<Factura> ventasPeriodoPaginadas => ventasPeriodoList.Skip(pageVentas * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        AplicarPreset("trimestre");
    }

    private async Task OnDatesChanged()
    {
        presetActivo = "";
        await CargarDatosReportesAsync();
    }

    private void AplicarPreset(string preset)
    {
        presetActivo = preset;
        var hoy = DateTime.Now;
        if (preset == "mes")
        {
            fechaInicio = new DateTime(hoy.Year, hoy.Month, 1);
            fechaFin = hoy;
        }
        else if (preset == "trimestre")
        {
            fechaInicio = hoy.AddDays(-90);
            fechaFin = hoy;
        }
        else if (preset == "anio")
        {
            fechaInicio = new DateTime(hoy.Year, 1, 1);
            fechaFin = hoy;
        }
        else if (preset == "todo")
        {
            fechaInicio = new DateTime(2020, 1, 1);
            fechaFin = hoy;
        }
        _ = CargarDatosReportesAsync();
    }

    private async Task CargarDatosReportesAsync()
    {
        loading = true;
        StateHasChanged();

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            ventasPeriodoList = await context.Facturas
                .AsNoTracking()
                .Include(f => f.CodclientesNavigation)
                .Where(f => f.Fechaentrega >= fechaInicio && f.Fechaentrega <= fechaFin)
                .OrderByDescending(f => f.Fechaentrega)
                .ToListAsync();

            totalVentasPeriodo = (decimal)ventasPeriodoList.Sum(f => f.Valortotal ?? 0m);
            totalDescuentosPeriodo = (decimal)ventasPeriodoList.Sum(f => f.Descuentos ?? 0m);
            ticketPromedioPeriodo = ventasPeriodoList.Any() ? totalVentasPeriodo / ventasPeriodoList.Count : 0m;

            var groupedSales = ventasPeriodoList
                .GroupBy(f => f.Fechaentrega.HasValue ? f.Fechaentrega.Value.ToString("dd/MM") : "S/F")
                .Select(g => new ChartItemDto { Etiqueta = g.Key, Valor = g.Sum(f => f.Valortotal ?? 0m) })
                .Reverse()
                .Take(12)
                .Reverse()
                .ToList();

            ventasPeriodoChartData = groupedSales;
            maxVentaPeriodoChart = ventasPeriodoChartData.Any()
                ? ObtenerMaximoGrafico(ventasPeriodoChartData.Max(x => x.Valor))
                : 100;
            if (maxVentaPeriodoChart <= 0) maxVentaPeriodoChart = 100;
        }
        catch (Exception)
        {
            // Fail silent or handle
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private void CambiarPaginaVentas(int step)
    {
        pageVentas += step;
        if (pageVentas < 0) pageVentas = 0;
        if (pageVentas >= MaxPaginaVentas) pageVentas = MaxPaginaVentas - 1;
    }

    private string GetVentasPeriodoLinePath()
    {
        if (!ventasPeriodoChartData.Any()) return "";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < ventasPeriodoChartData.Count; i++)
        {
            var x = 50 + i * (700.0 / Math.Max(1, ventasPeriodoChartData.Count - 1));
            var y = GetYCoordinate(ventasPeriodoChartData[i].Valor, maxVentaPeriodoChart);
            if (i == 0)
                sb.Append($"M {x.ToString("F1", CultureInfo.InvariantCulture)} {y.ToString("F1", CultureInfo.InvariantCulture)}");
            else
                sb.Append($" L {x.ToString("F1", CultureInfo.InvariantCulture)} {y.ToString("F1", CultureInfo.InvariantCulture)}");
        }
        return sb.ToString();
    }

    private string GetVentasPeriodoAreaPath()
    {
        if (!ventasPeriodoChartData.Any()) return "";
        var linePath = GetVentasPeriodoLinePath();
        var startX = 50.0;
        var endX = 50.0 + (ventasPeriodoChartData.Count - 1) * (700.0 / Math.Max(1, ventasPeriodoChartData.Count - 1));
        return $"{linePath} L {endX.ToString("F1", CultureInfo.InvariantCulture)} {ChartBottom.ToString("F1", CultureInfo.InvariantCulture)} L {startX.ToString("F1", CultureInfo.InvariantCulture)} {ChartBottom.ToString("F1", CultureInfo.InvariantCulture)} Z";
    }

    private double GetYCoordinate(decimal value, decimal maxValue)
    {
        if (maxValue <= 0) return ChartBottom;
        var safeValue = Math.Max(0m, Math.Min(value, maxValue));
        var ratio = (double)(safeValue / maxValue);
        return ChartBottom - (ratio * (ChartBottom - ChartTop));
    }

    private static decimal ObtenerMaximoGrafico(decimal maxValue)
    {
        if (maxValue <= 0) return 100m;
        var padded = Math.Ceiling((double)maxValue * 1.15);
        if (padded <= 10) return (decimal)Math.Ceiling(padded);
        var magnitude = Math.Pow(10, Math.Floor(Math.Log10(padded)));
        var normalized = padded / magnitude;
        var niceNormalized = normalized <= 1 ? 1 : normalized <= 2 ? 2 : normalized <= 5 ? 5 : 10;
        return (decimal)(niceNormalized * magnitude);
    }

    private async Task DescargarReportePdf()
    {
        var filename = $"Reporte_Ventas_Periodo_{DateTime.Now:yyyyMMdd_HHmm}.pdf";
        await JS.InvokeVoidAsync("window.downloadPdfReport", "report-view-area", filename);
    }
}
