@page "/backoffice/reportes/ventas-producto"
@namespace Simetric.Components.Pages.BackOffice
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.DTOs
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject NavigationManager NavManager

<PageTitle>Ventas por Producto - BackOffice</PageTitle>

<link href="css/reportes-compartido.css" rel="stylesheet" />

<div class="reports-container">
    <div class="report-header-card no-print animate__animated animate__fadeIn">
        <div class="report-header-top">
            <h2 class="report-page-title">
                <i class="bi bi-box-seam-fill"></i> Reporte Ventas Producto
            </h2>
            <button type="button" class="btn-export" @onclick="DescargarReportePdf">
                <i class="bi bi-file-earmark-pdf-fill"></i> Descargar PDF Directo
            </button>
        </div>
        <div class="report-header-filters">
            <div class="filter-group">
                <span class="filter-label">Desde:</span>
                <input type="date" @bind="fechaInicio" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-group">
                <span class="filter-label">Hasta:</span>
                <input type="date" @bind="fechaFin" @bind:after="OnDatesChanged" class="filter-input" />
            </div>
            <div class="filter-presets">
                <button type="button" class="btn-preset @(presetActivo == "mes" ? "active" : "")" @onclick='() => AplicarPreset("mes")'>Este Mes</button>
                <button type="button" class="btn-preset @(presetActivo == "trimestre" ? "active" : "")" @onclick='() => AplicarPreset("trimestre")'>Últimos 90 Días</button>
                <button type="button" class="btn-preset @(presetActivo == "anio" ? "active" : "")" @onclick='() => AplicarPreset("anio")'>Este Año</button>
                <button type="button" class="btn-preset @(presetActivo == "todo" ? "active" : "")" @onclick='() => AplicarPreset("todo")'>Todo</button>
            </div>
        </div>
    </div>

    <!-- Sliding Viewport Container -->
    <div class="reports-viewport printable-report" id="report-view-area">
        <div class="report-slide report-slide-active">
            <div class="visual-header">
                <h3 class="visual-title">Reporte de Ventas por Producto</h3>
                <p class="visual-subtitle">Consolidado de unidades vendidas y montos de facturación agrupados por artículo.</p>
            </div>

            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando datos...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="kpis-grid">
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-teal"><i class="bi bi-box-seam-fill"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Más Vendido</span>
                            <strong class="kpi-card-value">@productoMasVendido</strong>
                            <span class="kpi-card-trend trend-up">Artículo líder</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-blue"><i class="bi bi-tag-fill"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Ingreso Catálogo</span>
                            <strong class="kpi-card-value">$ @totalIngresosProductos.ToString("N2")</strong>
                            <span class="kpi-card-trend trend-up">Facturado neto</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-purple"><i class="bi bi-archive-fill"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Unidades Vendidas</span>
                            <strong class="kpi-card-value">@totalUnidadesVendidas.ToString("N0")</strong>
                            <span class="kpi-card-trend trend-neutral">Items entregados</span>
                        </div>
                    </div>
                    <div class="bo-kpi-card">
                        <div class="kpi-icon-container kpi-icon-green"><i class="bi bi-calculator"></i></div>
                        <div class="kpi-details">
                            <span class="kpi-card-title">Items Distintos</span>
                            <strong class="kpi-card-value">@ventasProductoList.Count</strong>
                            <span class="kpi-card-trend trend-neutral">Productos en catálogo</span>
                        </div>
                    </div>
                </div>

                <div class="report-visual-card">
                    <div class="visual-header">
                        <h4 class="visual-title">Top 5 Productos con Mayores Ingresos</h4>
                        <p class="visual-subtitle">Gráfico de barras de los productos más rentables en el rango de fechas.</p>
                    </div>
                    <div class="chart-container">
                        @if (ventasProductoChartData.Any())
                        {
                            <svg class="svg-chart" viewBox="0 0 800 280">
                                @for (int i = 0; i < ventasProductoChartData.Count; i++)
                                {
                                    var item = ventasProductoChartData[i];
                                    var y = 25 + i * 45;
                                    var barWidth = maxVentaProductoChart > 0 ? (double)(item.Valor / maxVentaProductoChart) * 500.0 : 0.0;
                                    var etiqueta = item.Etiqueta.Length > 20 ? item.Etiqueta.Substring(0, 18) + ".." : item.Etiqueta;
                                    <g><text class="chart-axis-text" x="10" y="@(y + 16)">@etiqueta</text></g>
                                    <rect class="chart-bar" x="180" y="@y" width="@barWidth" height="24" rx="4" fill="#0f766e" />
                                    <g><text class="chart-axis-text" x="@(180 + barWidth + 10)" y="@(y + 16)" font-weight="bold">$ @item.Valor.ToString("N2")</text></g>
                                }
                            </svg>
                        }
                    </div>
                </div>

                <div class="report-table-card">
                    <div class="table-header-row">
                        <h4 class="table-title">Detalle de Ventas por Producto</h4>
                    </div>
                    <table class="bo-table">
                        <thead>
                            <tr>
                                <th>Nombre Producto</th>
                                <th>Código Principal</th>
                                <th>Cantidad Vendida</th>
                                <th>Precio Promedio</th>
                                <th>Ingreso Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ventasProductoPaginadas.Any())
                            {
                                @foreach (var p in ventasProductoPaginadas)
                                {
                                    <tr>
                                        <td><strong>@p.NombreProducto</strong></td>
                                        <td>@p.CodigoPrincipal</td>
                                        <td>@p.CantidadVendida.ToString("N0")</td>
                                        <td>$ @p.PrecioPromedio.ToString("N2")</td>
                                        <td><strong class="text-blue">$ @p.TotalFacturado.ToString("N2")</strong></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No hay ventas registradas para productos.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="pagination-controls">
                        <span class="page-indicator">Página @(pageProductos + 1) de @MaxPaginaProductos</span>
                        <div class="pagination-btn-group">
                            <button type="button" class="btn-pagination" disabled="@(pageProductos == 0)" @onclick="() => CambiarPaginaProductos(-1)">
                                <i class="bi bi-chevron-left"></i> Ant.
                            </button>
                            <button type="button" class="btn-pagination" disabled="@(pageProductos >= MaxPaginaProductos - 1)" @onclick="() => CambiarPaginaProductos(1)">
                                Sig. <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private DateTime fechaInicio = DateTime.Now.AddMonths(-3);
    private DateTime fechaFin = DateTime.Now;
    private string presetActivo = "trimestre";
    private bool loading = true;

    private string productoMasVendido = "Ninguno";
    private decimal totalIngresosProductos = 0;
    private decimal totalUnidadesVendidas = 0;

    private List<ProductoVentaDto> ventasProductoList = new();
    private List<ChartItemDto> ventasProductoChartData = new();
    private decimal maxVentaProductoChart = 100;

    private int pageProductos = 0;
    private const int PageSize = 10;
    private int MaxPaginaProductos => Math.Max(1, (int)Math.Ceiling(ventasProductoList.Count / (double)PageSize));
    private List<ProductoVentaDto> ventasProductoPaginadas => ventasProductoList.Skip(pageProductos * PageSize).Take(PageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        AplicarPreset("trimestre");
    }

    private async Task OnDatesChanged()
    {
        presetActivo = "";
        await CargarDatosReportesAsync();
    }

    private void AplicarPreset(string preset)
    {
        presetActivo = preset;
        var hoy = DateTime.Now;
        if (preset == "mes")
        {
            fechaInicio = new DateTime(hoy.Year, hoy.Month, 1);
            fechaFin = hoy;
        }
        else if (preset == "trimestre")
        {
            fechaInicio = hoy.AddDays(-90);
            fechaFin = hoy;
        }
        else if (preset == "anio")
        {
            fechaInicio = new DateTime(hoy.Year, 1, 1);
            fechaFin = hoy;
        }
        else if (preset == "todo")
        {
            fechaInicio = new DateTime(2020, 1, 1);
            fechaFin = hoy;
        }
        _ = CargarDatosReportesAsync();
    }

    private async Task CargarDatosReportesAsync()
    {
        loading = true;
        StateHasChanged();

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();

            var detailsInPeriod = await context.Detallefacturas
                .AsNoTracking()
                .Include(d => d.Factura)
                .Where(d => d.Factura != null && d.Factura.Fechaentrega >= fechaInicio && d.Factura.Fechaentrega <= fechaFin)
                .ToListAsync();

            var groupedProd = detailsInPeriod
                .GroupBy(d => d.Descripproducto ?? "Producto General")
                .Select(g => new ProductoVentaDto
                {
                    NombreProducto = g.Key,
                    CodigoPrincipal = g.First().Codprincipal ?? "S/C",
                    CantidadVendida = g.Sum(d => d.Cantproducto),
                    PrecioPromedio = g.Average(d => d.Precioproducto),
                    TotalFacturado = g.Sum(d => d.Valortotal)
                })
                .OrderByDescending(p => p.TotalFacturado)
                .ToList();

            ventasProductoList = groupedProd;
            productoMasVendido = ventasProductoList.FirstOrDefault()?.NombreProducto ?? "Ninguno";
            totalIngresosProductos = ventasProductoList.Sum(p => p.TotalFacturado);
            totalUnidadesVendidas = (decimal)ventasProductoList.Sum(p => p.CantidadVendida);

            ventasProductoChartData = ventasProductoList
                .Take(5)
                .Select(p => new ChartItemDto { Etiqueta = p.NombreProducto, Valor = p.TotalFacturado })
                .ToList();
            maxVentaProductoChart = ventasProductoChartData.Any() ? ventasProductoChartData.Max(x => x.Valor) : 100;
        }
        catch (Exception)
        {
            // Fail silent
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private void CambiarPaginaProductos(int step)
    {
        pageProductos += step;
        if (pageProductos < 0) pageProductos = 0;
        if (pageProductos >= MaxPaginaProductos) pageProductos = MaxPaginaProductos - 1;
    }

    private async Task DescargarReportePdf()
    {
        var filename = $"Reporte_Ventas_Producto_{DateTime.Now:yyyyMMdd_HHmm}.pdf";
        await JS.InvokeVoidAsync("window.downloadPdfReport", "report-view-area", filename);
    }

    private class ProductoVentaDto
    {
        public string NombreProducto { get; set; } = "";
        public string CodigoPrincipal { get; set; } = "";
        public decimal CantidadVendida { get; set; }
        public decimal PrecioPromedio { get; set; }
        public decimal TotalFacturado { get; set; }
    }
}
