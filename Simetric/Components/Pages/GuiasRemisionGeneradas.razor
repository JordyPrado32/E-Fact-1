    private async Task DescargarReporteAsync()
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync("Modo demo: la exportación Excel está bloqueada.");
            return;
        }

        var guiasFiltradas = GuiasFiltradas;
        if (guiasFiltradas.Count == 0)
        {
            await AlertService.ShowInfoAsync("No hay guias para exportar con los filtros actuales.");
            return;
        }

        var archivo = SimpleExcelExportService.Create(
            $"guias_remision_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx",
            new ExcelSheetData(
                "GuiasRemision",
                new[]
                {
                    "Fecha",
                    "Guia",
                    "Destinatario",
                    "Identificacion destinatario",
                    "Transportista",
                    "Inicio traslado",
                    "Fin traslado",
                    "Estado SRI",
                    "Numero autorizacion",
                    "Motivo traslado"
                },
                guiasFiltradas
                    .Select(g => (IReadOnlyList<string>)new[]
                    {
                        g.FechaEmision?.ToString("yyyy-MM-dd") ?? string.Empty,
                        g.NumeroCompleto ?? string.Empty,
                        g.Destinatario ?? string.Empty,
                        g.IdentificacionDestinatario ?? string.Empty,
                        g.Transportista ?? string.Empty,
                        g.FechaInicioTransporte?.ToString("yyyy-MM-dd") ?? string.Empty,
                        g.FechaFinTransporte?.ToString("yyyy-MM-dd") ?? string.Empty,
                        ObtenerEstadoSriTexto(g),
                        ObtenerNumeroAutorizacionTexto(g),
                        g.MotivoTraslado ?? string.Empty
                    })
                    .ToList()));

        await using var stream = new MemoryStream(archivo.Content);
        using var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("downloadFileFromStream", archivo.FileName, streamRef, archivo.ContentType);
    }

