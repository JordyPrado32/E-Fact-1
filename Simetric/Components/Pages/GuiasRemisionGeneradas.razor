            return;
        }

        if (AccionesBloqueadas)
            return;

        var destinatario = System.Net.WebUtility.HtmlEncode(guia.Destinatario ?? "Sin destinatario");
        var resultadoConfirmacion = await JS.InvokeAsync<JsonElement>("Swal.fire", new
        {
            icon = "question",
            title = "Reenviar guia por correo",
            html = $@"
                <div style='text-align:left'>
                    <div style='margin-bottom:8px;'><strong>Guia:</strong> {guia.NumeroCompleto}</div>
                    <div style='margin-bottom:8px;'><strong>Destinatario:</strong> {destinatario}</div>
