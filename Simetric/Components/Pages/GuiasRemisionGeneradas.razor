                    </div>
                </div>",
            showCancelButton = true,
            confirmButtonText = "SÃ­, reenviar",
            cancelButtonText = "Cancelar",
            reverseButtons = true,
            focusCancel = true,
            buttonsStyling = false,
            customClass = new
            {
                popup = "numerica-swal-popup",
