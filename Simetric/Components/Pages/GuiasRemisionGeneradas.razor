@page "/facturacion/guias-remision-generadas"
@page "/demo/guias-remision-generadas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.DTOs
@using Simetric.Services
@using System.Text.Json
@attribute [AllowAnonymous]

@inject GuiaRemisionService GuiaRemisionService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject SweetAlertService AlertService
@inject IJSRuntime JS
@inject ISimpleExcelExportService SimpleExcelExportService

<PageTitle>Guias de Remision Generadas</PageTitle>

@{
    var guiasFiltradas = GuiasFiltradas;
    var guiasPaginaActual = GuiasPaginaActual;
    var autorizadas = guiasFiltradas.Count(EstaAutorizada);
    var noAutorizadas = guiasFiltradas.Count(x => ObtenerEstadoSriTexto(x) == DocumentoAutorizacionHelper.EstadoNoAutorizado);
    var pendientes = guiasFiltradas.Count - autorizadas - noAutorizadas;
}

<div class="facturas-shell" data-tour="grgen.page">
    @if (idDocumentoMenuAbierto.HasValue)
    {
        <div class="row-menu-backdrop" @onclick="CerrarMenus"></div>
    }
    <section class="facturas-hero" data-tour="grgen.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Traslados emitidos</span>
            <h2>Mis guias de remision con filtros, reporte y acciones unificadas</h2>
            <p>
                Filtra por destinatario, transportista o numero, exporta tu consulta y abre cada
                comprobante con el mismo patron visual del resto de documentos.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Guias filtradas</span>
                <strong>@guiasFiltradas.Count</strong>
                <small>@ResumenRangoFechas</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Autorizadas</span>
                <strong>@autorizadas</strong>
                <small>Pendientes: @pendientes | No autorizadas: @noAutorizadas</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Guias visibles</span>
                <strong>@guiasPaginaActual.Count</strong>
                <small>Consulta activa con buscador, fechas y reporte rapido.</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="grgen.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Busqueda y control</span>
            <h3>Guias de remision generadas</h3>
            <p>Filtra por destinatario, transportista o numero y abre el XML o PDF en segundos.</p>
            @if (isDemoMode)
            {
                <p class="text-muted mb-0">Modo demo: puedes navegar la consulta y los detalles, pero XML, PDF y exportaciones están bloqueados.</p>
            }
        </div>

        <div class="toolbar-actions toolbar-actions-expanded">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>

                <input class="search-input"
                       placeholder="Buscar por guia, destinatario, identificacion o transportista"
                       @bind="Filtro"
                       @bind:event="oninput" />

                @if (!string.IsNullOrWhiteSpace(Filtro))
                {
                    <button class="search-clear" type="button" @onclick="LimpiarTexto" aria-label="Limpiar busqueda">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>

            <div class="date-filter-group">
                <label class="date-filter-box">
                    <span>Desde</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaDesde" />
                </label>

                <label class="date-filter-box">
                    <span>Hasta</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaHasta" />
                </label>
            </div>

            <button class="report-btn" type="button" @onclick="DescargarReporteAsync">
                <i class="bi bi-file-earmark-spreadsheet"></i>
                <span>Descargar Excel</span>
            </button>

            <button class="refresh-btn" type="button" @onclick="Recargar">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refrescar</span>
            </button>

            @if (HayFiltrosActivos)
            {
                <button class="filter-reset-btn" type="button" @onclick="LimpiarFiltros">
                    <i class="bi bi-eraser"></i>
                    <span>Limpiar filtros</span>
                </button>
            }
        </div>
    </section>

    @if (cargando)
    {
        <section class="state-card">
            <div class="state-icon">
                <span class="spinner-border"></span>
            </div>
            <h3>Cargando guias de remision</h3>
            <p>Estamos organizando tu historial de traslados para mostrarlo completo.</p>
        </section>
    }
    else if (guiasFiltradas.Count == 0)
    {
        <section class="state-card state-card-empty">
            <div class="state-icon">
                <i class="bi bi-inbox"></i>
            </div>
            <h3>No hay resultados</h3>
            <p>
                @(HayFiltrosActivos
                    ? "No encontramos guias con los filtros aplicados. Ajusta el texto o las fechas."
                    : "Todavia no existen guias de remision para mostrar en este panel.")
            </p>
        </section>
    }
    else
    {
        <section class="table-card" data-tour="grgen.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado</span>
                    <h3>Guias de remision</h3>
                    <p>Consulta destinatario, transportista, traslado y estado en una sola tabla.</p>
                </div>

                <div class="table-head-actions">
                    <label class="page-size-box">
                        <span>Ver</span>
                        <select class="page-size-select" @bind="RegistrosPorPagina">
                            @foreach (var opcion in pageSizeOptions)
                            {
                                <option value="@opcion">@opcion</option>
                            }
                        </select>
                        <span>registros</span>
                    </label>
                </div>
            </div>

            <div class="table-wrap list-table-wrap">
                <table class="table table-hover align-middle mb-0 facturas-table responsive-list-table">
                    <thead>
                        <tr>
                            <th style="width: 128px;">Fecha</th>
                            <th style="width: 188px;">Guia</th>
                            <th>Destinatario</th>
                            <th style="width: 190px;">Transportista</th>
                            <th style="width: 150px;">Traslado</th>
                            <th style="width: 148px;">Estado SRI</th>
                            <th class="text-end actions-header-otros">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var guiaEntry in guiasPaginaActual.Select((item, index) => new { Item = item, Index = index }))
                        {
                            var item = guiaEntry.Item;
                            var openUp = guiaEntry.Index >= Math.Max(0, guiasPaginaActual.Count - (guiasPaginaActual.Count <= 2 ? 1 : 2));
                            <tr>
                                <td data-label="Fecha">
                                    <span class="invoice-date">
                                        @(item.FechaEmision?.ToString("dd/MM/yyyy") ?? "-")
                                    </span>
                                </td>

                                <td data-label="Guia">
                                    <span class="invoice-pill">
                                        @item.NumeroCompleto
                                    </span>
                                </td>

                                <td data-label="Destinatario">
                                    <div class="client-cell">
                                        <strong>@item.Destinatario</strong>
                                        <span>@item.IdentificacionDestinatario</span>
                                    </div>
                                </td>

                                <td data-label="Transportista">
                                    <div class="client-cell">
                                        <strong>@item.Transportista</strong>
                                        <span>@(string.IsNullOrWhiteSpace(item.MotivoTraslado) ? "Sin motivo registrado" : item.MotivoTraslado)</span>
                                    </div>
                                </td>

                                <td data-label="Traslado">
                                    <div class="client-cell">
                                        <strong>@(item.FechaInicioTransporte?.ToString("dd/MM/yyyy") ?? "-")</strong>
                                        <span>@(item.FechaFinTransporte?.ToString("dd/MM/yyyy") ?? "-")</span>
                                    </div>
                                </td>

                                 <td data-label="Estado SRI">
                                     <div class="client-cell">
                                         <span class="status-pill @ObtenerEstadoSriClase(item)">
                                             @ObtenerEstadoSriTexto(item)
                                         </span>
                                         <span class="authorization-number" title="@ObtenerNumeroAutorizacionTexto(item)">
                                             Autorizacion: @ObtenerNumeroAutorizacionTexto(item)
                                         </span>
                                     </div>
                                 </td>
                                  <td class="text-end" data-label="Acciones">
                                      <!-- Desktop: Inline summarized compact icon buttons -->
                                      <div class="actions-desktop-inline gap-1 justify-content-end row-actions-inline-desktop">
                                          <button class="row-action-btn row-action-view"
                                                  type="button"
                                                  title="Ver"
                                                  @onclick="() => VerGuiaAsync(item.Sec)">
                                              <i class="bi bi-eye"></i>
                                          </button>

                                          <button class="row-action-btn row-action-xml"
                                                  type="button"
                                                  title="Descargar XML"
                                                  @onclick="() => AbrirXmlAsync(item.Sec)">
                                              <i class="bi bi-filetype-xml"></i>
                                          </button>

                                           <button class="row-action-btn row-action-pdf"
                                                  type="button"
                                                  title="Descargar PDF"
                                                  @onclick="() => AbrirPdfAsync(item.Sec)">
                                               <i class="bi bi-file-earmark-pdf"></i>
                                           </button>

                                            @if (PuedeReenviarSri(item))
                                            {
                                                <button class="row-action-btn row-action-sri"
                                                        type="button"
                                                        title="Reenviar al SRI"
                                                        disabled="@AccionesBloqueadas"
                                                        @onclick="() => EmitirSriAsync(item.Sec)">
                                                    <i class="bi @(guiaEmitiendoSri == item.Sec ? "bi-hourglass-split" : "bi-send")"></i>
                                                </button>
                                            }

                                           <button class="row-action-btn row-action-mail"
                                                   type="button"
                                                   title="Reenviar correo"
                                                   disabled="@AccionesBloqueadas"
                                                   @onclick="() => ReenviarCorreoAsync(item)">
                                               <i class="bi bi-envelope"></i>
                                           </button>

                                           <button class="row-action-btn row-action-danger"
                                                   type="button"
                                                   title="Anular guia de remision"
                                                   disabled="@AccionesBloqueadas"
                                                   @onclick="() => ConfirmarAnularGuiaAsync(item)">
                                               <i class="bi bi-trash"></i>
                                           </button>
                                       </div>

                                      <!-- Mobile: Dropdown -->
                                      <div class="actions-mobile-dropdown row-actions-dropdown @(openUp ? "dropdown-open-up" : "")">
                                          <button class="row-actions-trigger" type="button" @onclick="() => ToggleMenu(item.Sec)" @onclick:stopPropagation>
                                              <i class="bi bi-three-dots"></i>
                                          </button>
                                          @if (idDocumentoMenuAbierto == item.Sec)
                                          {
                                              <div class="action-dropdown-menu">
                                                   <button class="action-dropdown-item item-view" type="button" @onclick="async () => { CerrarMenus(); await VerGuiaAsync(item.Sec); }">
                                                      <i class="bi bi-eye"></i>
                                                      <span>Ver</span>
                                                  </button>
                                                   <button class="action-dropdown-item item-xml" type="button" @onclick="async () => { CerrarMenus(); await AbrirXmlAsync(item.Sec); }">
                                                      <i class="bi bi-filetype-xml"></i>
                                                      <span>Descargar XML</span>
                                                  </button>
                                                    <button class="action-dropdown-item item-pdf" type="button" @onclick="async () => { CerrarMenus(); await AbrirPdfAsync(item.Sec); }">
                                                      <i class="bi bi-file-earmark-pdf"></i>
                                                      <span>Descargar PDF</span>
                                                   </button>
                                                    @if (PuedeReenviarSri(item))
                                                    {
                                                        <button class="action-dropdown-item item-sri" type="button" disabled="@AccionesBloqueadas" @onclick="async () => { CerrarMenus(); await EmitirSriAsync(item.Sec); }">
                                                            <i class="bi bi-send-check"></i>
                                                            <span>Reenviar al SRI</span>
                                                        </button>
                                                    }
                                                   <button class="action-dropdown-item item-mail" type="button" disabled="@AccionesBloqueadas" @onclick="async () => { CerrarMenus(); await ReenviarCorreoAsync(item); }">
                                                       <i class="bi bi-envelope-arrow-up"></i>
                                                       <span>Reenviar correo</span>
                                                   </button>
                                                   <button class="action-dropdown-item item-cancel" type="button" disabled="@AccionesBloqueadas" @onclick="async () => { CerrarMenus(); await ConfirmarAnularGuiaAsync(item); }">
                                                       <i class="bi bi-trash3"></i>
                                                       <span>Anular guia de remision</span>
                                                   </button>
                                               </div>
                                           }
                                       </div>
                                  </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <div class="footer-metrics">
                    <div class="footer-metric">
                        <span class="footer-label">Resultados visibles</span>
                        <strong>@guiasPaginaActual.Count</strong>
                    </div>

                    <div class="footer-metric">
                        <span class="footer-label">Resultados filtrados</span>
                        <strong>@guiasFiltradas.Count</strong>
                    </div>

                    <div class="footer-metric footer-metric-highlight">
                        <span class="footer-label">Autorizadas</span>
                        <strong>@autorizadas</strong>
                    </div>
                </div>

                @if (TotalPaginas > 1)
                {
                    <nav class="pagination-nav" aria-label="Paginacion de guias de remision">
                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaAnterior"
                                disabled="@(paginaActual == 1)">
                            <i class="bi bi-chevron-left"></i>
                            <span>Anterior</span>
                        </button>

                        @foreach (var pagina in PaginasVisibles)
                        {
                            <button class="pagination-btn @(pagina == paginaActual ? "is-active" : null)"
                                    @onclick="() => IrAPagina(pagina)">
                                @pagina
                            </button>
                        }

                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaSiguiente"
                                disabled="@(paginaActual == TotalPaginas)">
                            <span>Siguiente</span>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </nav>
                }
            </div>
        </section>
    }

</div>

@if (mostrarModal && guiaSeleccionada != null)
{
    <div class="factura-modal-backdrop" @onclick="CerrarModal"></div>

    <div class="modal fade show d-block factura-modal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable factura-modal-dialog">
            <div class="modal-content factura-modal-content">

                <div class="modal-header factura-modal-header">
                    <div>
                        <span class="modal-kicker">Comprobante generado</span>
                        <h5 class="modal-title mb-0">
                            Guia de Remision @guiaSeleccionada.NumeroCompleto
                        </h5>
                    </div>

                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>

                <div class="modal-body factura-modal-body">
                    <div class="gr-preview-shell">
                        <div class="gr-preview-top">
                            <div class="gr-company-card">
                                <h4>@(guiaSeleccionada.Emisor?.RazonSocial ?? "EMISOR")</h4>
                                <div><strong>RUC:</strong> @(guiaSeleccionada.Emisor?.Ruc ?? "")</div>
                                <div><strong>Direccion:</strong> @(guiaSeleccionada.Emisor?.DireccionMatriz ?? "")</div>
                                <div><strong>Establecimiento:</strong> @(guiaSeleccionada.Emisor?.DirEstablecimiento ?? "")</div>
                            </div>

                            <div class="gr-doc-card">
                                <div class="gr-doc-title">GUIA DE REMISION</div>
                                <div><strong>No.:</strong> @guiaSeleccionada.NumeroCompleto</div>
                                <div><strong>Estado SRI:</strong> @ObtenerEstadoSriTexto(guiaSeleccionada.Guia.EstadoSRI, guiaSeleccionada.Guia.NumAutorizacion)</div>
                                <div><strong>Numero de autorizacion:</strong> @ObtenerNumeroAutorizacionTexto(guiaSeleccionada.Guia.EstadoSRI, guiaSeleccionada.Guia.NumAutorizacion)</div>
                                @if (!EstaAutorizadaGuia(guiaSeleccionada.Guia.EstadoSRI, guiaSeleccionada.Guia.NumAutorizacion))
                                {
                                    <div><strong>Clave acceso:</strong> @(guiaSeleccionada.Guia.CodClave ?? "")</div>
                                }
                            </div>
                        </div>

                        <div class="gr-section-card">
                            <div class="gr-section-title">Transportista y traslado</div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <strong>Transportista:</strong><br />
                                    @(guiaSeleccionada.Transportista?.RazonSocial ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Identificacion:</strong><br />
                                    @(guiaSeleccionada.Transportista?.NumeroIdentificacion ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Placa:</strong><br />
                                    @(guiaSeleccionada.Guia.Placa ?? guiaSeleccionada.Transportista?.Placa ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Fecha inicio:</strong><br />
                                    @(guiaSeleccionada.Guia.FechaIniTransporte?.ToString("dd/MM/yyyy") ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Fecha fin:</strong><br />
                                    @(guiaSeleccionada.Guia.FechaFinTransporte?.ToString("dd/MM/yyyy") ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Telefono:</strong><br />
                                    @(guiaSeleccionada.Transportista?.Telefono ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Obl. contabilidad:</strong><br />
                                    @(string.IsNullOrWhiteSpace(guiaSeleccionada.Transportista?.OblCont) ? "-" : guiaSeleccionada.Transportista?.OblCont)
                                </div>

                                <div class="col-md-8">
                                    <strong>Direccion transportista:</strong><br />
                                    @(guiaSeleccionada.Transportista?.Direccion ?? "")
                                </div>

                                <div class="col-12">
                                    <strong>Direccion de partida:</strong><br />
                                    @(guiaSeleccionada.Guia.DireccionPartida ?? "")
                                </div>
                            </div>
                        </div>

                        <div class="gr-section-card">
                            <div class="gr-section-title">Destinatario</div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <strong>Destinatario:</strong><br />
                                    @(guiaSeleccionada.Destinatario?.RazonSocial ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Identificacion:</strong><br />
                                    @(guiaSeleccionada.Destinatario?.IdDestinatario ?? "")
                                </div>

                                <div class="col-md-4">
                                    <strong>Motivo:</strong><br />
                                    @(guiaSeleccionada.Destinatario?.MotivoTraslado ?? "")
                                </div>

                                <div class="col-md-6">
                                    <strong>Direccion entrega:</strong><br />
                                    @(guiaSeleccionada.Destinatario?.Direccion ?? "")
                                </div>

                                <div class="col-md-6">
                                    <strong>Fecha sustento:</strong><br />
                                    @(guiaSeleccionada.Destinatario?.FechaEmiSustento?.ToString("dd/MM/yyyy") ?? "")
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(guiaSeleccionada.Guia.Mensaje))
                        {
                            <div class="gr-section-card">
                                <div class="gr-section-title">Detalle adicional</div>
                                <div class="gr-note-box">
                                    @guiaSeleccionada.Guia.Mensaje
                                </div>
                            </div>
                        }

                        <div class="gr-section-card">
                            <div class="gr-section-title">Detalle</div>

                            <div class="table-wrap modal-table-wrap">
                                <table class="table table-hover align-middle mb-0 facturas-table">
                                    <thead>
                                        <tr>
                                            <th>Codigo interno</th>
                                            <th>Codigo adicional</th>
                                            <th>Descripcion</th>
                                            <th class="text-end">Cantidad</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (guiaSeleccionada.Detalles.Any())
                                        {
                                            @foreach (var d in guiaSeleccionada.Detalles)
                                            {
                                                <tr>
                                                    <td>@d.CodigoInterno</td>
                                                    <td>@d.CodigoAdicional</td>
                                                    <td>@d.Descripcion</td>
                                                    <td class="text-end">@d.Cantidad.ToString("N2")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-4">
                                                    No se encontraron detalles registrados.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer factura-modal-footer">
                    <button class="secondary-btn secondary-btn-accent modal-link-btn" @onclick="() => AbrirXmlAsync(guiaSeleccionada.Guia.Sec)">
                        Abrir XML
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn" @onclick="() => AbrirPdfAsync(guiaSeleccionada.Guia.Sec)">
                        Abrir PDF A4
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn" @onclick="() => AbrirPdfAsync(guiaSeleccionada.Guia.Sec, FormatoImpresionDocumento.Termica80mm)">
                        Termica 80mm
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn" @onclick="() => AbrirPdfAsync(guiaSeleccionada.Guia.Sec, FormatoImpresionDocumento.Termica50mm)">
                        Termica 50mm
                    </button>

                    <button class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal">
                        Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private int? idDocumentoMenuAbierto;

    private void ToggleMenu(int id)
    {
        if (idDocumentoMenuAbierto == id)
            idDocumentoMenuAbierto = null;
        else
            idDocumentoMenuAbierto = id;
    }

    private void CerrarMenus()
    {
        idDocumentoMenuAbierto = null;
    }
    private int currentUserId;
    private bool cargando = true;
    private int? guiaEmitiendoSri;
    private bool procesandoCorreo;
    private bool procesandoAnulacion;
    private bool isDemoMode;
    private List<GuiaRemisionListDto> guias = new();
    private readonly int[] pageSizeOptions = { 5, 10, 20, 50 };
    private int paginaActual = 1;
    private int registrosPorPagina = 10;
    private string filtro = string.Empty;
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;
    private bool mostrarModal;
    private GuiaRemisionDetalleViewDto? guiaSeleccionada;

    private string Filtro
    {
        get => filtro;
        set
        {
            if (filtro == value)
                return;

            filtro = value;
            paginaActual = 1;
        }
    }

    private DateTime? FechaDesde
    {
        get => fechaDesde;
        set
        {
            if (fechaDesde == value)
                return;

            fechaDesde = value;
            paginaActual = 1;
        }
    }

    private DateTime? FechaHasta
    {
        get => fechaHasta;
        set
        {
            if (fechaHasta == value)
                return;

            fechaHasta = value;
            paginaActual = 1;
        }
    }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(Filtro) || FechaDesde.HasValue || FechaHasta.HasValue;

    private string ResumenRangoFechas
    {
        get
        {
            if (FechaDesde.HasValue && FechaHasta.HasValue)
                return $"{FechaDesde.Value:dd/MM/yyyy} al {FechaHasta.Value:dd/MM/yyyy}";

            if (FechaDesde.HasValue)
                return $"Desde {FechaDesde.Value:dd/MM/yyyy}";

            if (FechaHasta.HasValue)
                return $"Hasta {FechaHasta.Value:dd/MM/yyyy}";

            return "Todas las fechas";
        }
    }

    private int RegistrosPorPagina
    {
        get => registrosPorPagina;
        set
        {
            registrosPorPagina = value;
            paginaActual = 1;
        }
    }

    private List<GuiaRemisionListDto> GuiasFiltradas =>
        guias
            .Where(CumpleFiltroGuia)
            .ToList();

    private List<GuiaRemisionListDto> GuiasPaginaActual =>
        GuiasFiltradas
            .Skip((paginaActual - 1) * registrosPorPagina)
            .Take(registrosPorPagina)
            .ToList();

    private int TotalPaginas =>
        Math.Max(1, (int)Math.Ceiling(GuiasFiltradas.Count / (double)registrosPorPagina));

    private int RegistroInicialPagina =>
        GuiasFiltradas.Count == 0 ? 0 : ((paginaActual - 1) * registrosPorPagina) + 1;

    private int RegistroFinalPagina =>
        GuiasFiltradas.Count == 0 ? 0 : Math.Min(paginaActual * registrosPorPagina, GuiasFiltradas.Count);

    private bool AccionesBloqueadas => guiaEmitiendoSri.HasValue || procesandoCorreo || procesandoAnulacion;

    private IEnumerable<int> PaginasVisibles
    {
        get
        {
            var inicio = Math.Max(1, paginaActual - 2);
            var fin = Math.Min(TotalPaginas, inicio + 4);
            inicio = Math.Max(1, fin - 4);
            return Enumerable.Range(inicio, fin - inicio + 1);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        isDemoMode = EsRutaDemoGuias();
        await Recargar();
    }

    private async Task Recargar()
    {
        cargando = true;

        if (isDemoMode)
        {
            guias = CrearDemoGuias();
            paginaActual = 1;
            cargando = false;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaim = authState.User.FindFirst("IdUsuario")?.Value;
        currentUserId = int.TryParse(userClaim, out var id) ? id : 0;

        if (currentUserId <= 0)
        {
            NavManager.NavigateTo("/", true);
            return;
        }

        guias = await GuiaRemisionService.ListarGuiasRemisionUsuarioAsync(currentUserId);
        paginaActual = 1;
        cargando = false;
    }

    private bool CumpleFiltroGuia(GuiaRemisionListDto guia)
    {
        if (!string.IsNullOrWhiteSpace(Filtro))
        {
            var filtroActual = Filtro.Trim();
            var coincideTexto =
                (guia.NumeroCompleto ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (guia.Destinatario ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (guia.IdentificacionDestinatario ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (guia.Transportista ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (guia.MotivoTraslado ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (guia.FacturaSustento ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (guia.NumeroAutorizacion ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                ObtenerEstadoSriTexto(guia).Contains(filtroActual, StringComparison.OrdinalIgnoreCase);

            if (!coincideTexto)
                return false;
        }

        var fechaGuia = guia.FechaEmision?.Date;

        if (FechaDesde.HasValue && (!fechaGuia.HasValue || fechaGuia.Value < FechaDesde.Value.Date))
            return false;

        if (FechaHasta.HasValue && (!fechaGuia.HasValue || fechaGuia.Value > FechaHasta.Value.Date))
            return false;

        return true;
    }

    private static bool EstaAutorizada(GuiaRemisionListDto guia) =>
        EstaAutorizadaGuia(guia.EstadoSri, guia.NumeroAutorizacion);

    private static bool PuedeReenviarSri(GuiaRemisionListDto guia) =>
        ObtenerEstadoSriTexto(guia) == DocumentoAutorizacionHelper.EstadoPendiente;

    private static bool EstaAutorizadaGuia(string? estadoSri, string? numeroAutorizacion) =>
        DocumentoAutorizacionHelper.EstaAutorizado(estadoSri) ||
        (!string.IsNullOrWhiteSpace(numeroAutorizacion) && !DocumentoAutorizacionHelper.EsNoAutorizado(estadoSri));

    private static string ObtenerEstadoSriTexto(GuiaRemisionListDto guia) =>
        ObtenerEstadoSriTexto(guia.EstadoSri, guia.NumeroAutorizacion);

    private static string ObtenerEstadoSriTexto(string? estadoSri, string? numeroAutorizacion) =>
        DocumentoAutorizacionHelper.ObtenerEstadoVisual(
            estadoSri,
            EstaAutorizadaGuia(estadoSri, numeroAutorizacion));

    private static string ObtenerNumeroAutorizacionTexto(GuiaRemisionListDto guia) =>
        ObtenerNumeroAutorizacionTexto(guia.EstadoSri, guia.NumeroAutorizacion);

    private static string ObtenerNumeroAutorizacionTexto(string? estadoSri, string? numeroAutorizacion) =>
        DocumentoAutorizacionHelper.ObtenerNumeroAutorizacionVisual(
            estadoSri,
            EstaAutorizadaGuia(estadoSri, numeroAutorizacion),
            numeroAutorizacion);

    private static string ObtenerEstadoSriClase(GuiaRemisionListDto guia)
    {
        var estado = ObtenerEstadoSriTexto(guia);

        return estado == DocumentoAutorizacionHelper.EstadoAutorizado
            ? "status-pill-success"
            : estado == DocumentoAutorizacionHelper.EstadoNoAutorizado
                ? "status-pill-danger"
                : "status-pill-info";
    }

