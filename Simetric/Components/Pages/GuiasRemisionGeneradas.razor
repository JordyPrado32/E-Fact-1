    private async Task EmitirSriAsync(int sec)
    {
        if (isDemoMode || guiaEmitiendoSri.HasValue)
            return;

        guiaEmitiendoSri = sec;
        try
        {
            var respuesta = await GuiaRemisionService.EmitirGuiaRemisionSriAsync(sec, currentUserId);
            var autorizada = string.Equals(
                respuesta.estado,
                DocumentoAutorizacionHelper.EstadoAutorizado,
                StringComparison.OrdinalIgnoreCase) ||
                !string.IsNullOrWhiteSpace(respuesta.autorizacion);

            if (autorizada)
                await AlertService.ShowSuccessAsync($"Guia autorizada por el SRI. Autorizacion: {respuesta.autorizacion}.", "Guia autorizada");
            else
                await AlertService.ShowWarningAsync($"El SRI respondio {respuesta.estado}: {respuesta.mensaje}", "Guia no autorizada");

            await Recargar();
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync(ex.Message, "No se pudo enviar la guia al SRI");
        }
        finally
        {
            guiaEmitiendoSri = null;
        }
    }

    private async Task ReenviarCorreoAsync(GuiaRemisionListDto guia)
    {
        if (isDemoMode)
