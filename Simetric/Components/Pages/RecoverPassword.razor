@page "/recover-password"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@layout Simetric.Components.Layout.EmptyLayout
@implements IAsyncDisposable

@using Microsoft.EntityFrameworkCore
@using Simetric.Components.Helpers
@using Simetric.Data
@using Simetric.Models

@inject IDbContextFactory<AppDbContext> DbFactory
@inject IEmailService EmailService
@inject NavigationManager Nav
@inject IJSRuntime JS
<PageTitle>Recuperar Clave | Numérica software</PageTitle>

<style>
    @FontFaceCss

    :root {
        --n-blue: #006bb5;
        --n-blue-dark: #004a7c;
        --n-blue-light: #e6f0f8;
        --n-dark: #2c3e50;
        --white: #ffffff;
        --bg-color: #f4f7f6;
    }

    body {
        font-family: 'Montserrat', sans-serif;
        background-color: var(--bg-color);
        margin: 0;
        min-height: 100dvh;
        overflow-x: hidden;
        overflow-y: auto;
    }

    /* Pantalla de Carga Global */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        color: var(--n-blue);
    }

    .main-viewport {
        display: flex;
        min-height: max(100vh, 100dvh);
        height: auto;
        width: 100%;
        overflow-x: hidden;
        overflow-y: visible;
    }

    /* Eliminadas las reglas CSS de .auth-ps3-shell y .auth-ps3-form para mantener limpieza */

    /* Panel Izquierdo */
    .brand-side {
        flex: 1 1 56%;
        background: linear-gradient(135deg, var(--n-blue) 0%, var(--n-blue-dark) 100%);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(2.5rem, 4vw, 5rem);
        position: relative;
        overflow: hidden;
        min-width: 0;
        min-height: 0;
    }

        .brand-side::before, .brand-side::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            z-index: 0;
        }

        .brand-side::before {
            width: 400px;
            height: 400px;
            top: -100px;
            left: -100px;
        }

        .brand-side::after {
            width: 600px;
            height: 600px;
            bottom: -200px;
            right: -150px;
        }

    .numeric-digits-layer {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
    }

    .numerica-digit {
        position: absolute;
        z-index: 1;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1;
        user-select: none;
        mix-blend-mode: screen;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.34), 0 0 42px rgba(255, 255, 255, 0.22), 0 0 64px rgba(184, 220, 255, 0.1);
        font-variant-numeric: tabular-nums;
        will-change: transform, opacity;
    }

    @KeyframesDigitFloatCss

    .numeric-digits-layer::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        background: radial-gradient(circle at 18% 24%, rgba(255, 255, 255, 0.14), transparent 34%), radial-gradient(circle at 74% 72%, rgba(255, 255, 255, 0.11), transparent 30%);
        opacity: 0.78;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        padding: clamp(2.15rem, 3vw, 3.25rem);
        width: min(100%, 34rem);
        max-width: 34rem;
        min-height: clamp(23rem, 50vh, 27rem);
        position: relative;
        z-index: 2;
        box-shadow: 0 25px 50px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: clamp(1.35rem, 2vw, 1.9rem);
        text-align: center;
    }

    .brand-logo-shell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        max-width: 100%;
        padding: 0.8rem 1.1rem;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.08));
        border: 1px solid rgba(255, 255, 255, 0.26);
        box-shadow: 0 16px 30px rgba(2, 35, 66, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.18);
        backdrop-filter: blur(10px);
    }

    .brand-lockup {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(0.95rem, 1.4vw, 1.25rem);
        max-width: 100%;
    }

        .brand-logo,
        .brand-logo-shell > img {
            width: clamp(4.6rem, 8vw, 5.75rem);
            height: clamp(4.6rem, 8vw, 5.75rem);
            max-width: 100%;
            display: block;
            object-fit: contain;
            filter: drop-shadow(0 8px 18px rgba(1, 21, 40, 0.24)) saturate(1.04) contrast(1.04);
        }

        .brand-logo-shell > img {
            margin-bottom: 0 !important;
        }

    .login-brand-heading {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-weight: 600;
        font-size: clamp(2rem, 3.2vw, 2.85rem);
        letter-spacing: 0;
        line-height: 0.96;
        display: flex;
        flex-direction: column;
        margin: 0;
        text-align: left;
    }

    .brand-tagline {
        margin: 0;
        max-width: 28rem;
        color: rgba(255, 255, 255, 0.78);
        font-size: clamp(1.08rem, 1.55vw, 1.35rem);
        font-weight: 400;
        line-height: 1.55;
    }

    .brand-version-row {
        display: flex;
        justify-content: center;
        width: 100%;
    }

    .brand-mobile-lockup {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .brand-mobile-logo {
        width: 58px;
        height: 58px;
        display: inline-block;
        object-fit: contain;
        filter: drop-shadow(0 10px 18px rgba(37, 76, 205, 0.2));
    }

    .brand-mobile-name {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-size: 1.15rem;
        font-weight: 600;
        line-height: 0.98;
        color: var(--n-dark);
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    /* Panel Derecho */
    .form-side {
        flex: 1 1 44%;
        background: var(--white);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: clamp(1rem, 2vw, 2rem);
        min-width: 0;
        min-height: 0;
        overflow-x: hidden;
        overflow-y: auto;
    }

    .login-container-pro {
        width: 100%;
        max-width: 440px;
        animation: slideUp 0.6s ease-out forwards;
        background: white;
        padding: clamp(1.75rem, 2.4vw, 3rem) clamp(1.4rem, 2vw, 2rem);
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0,0,0,0.02);
        max-height: none;
        overflow: visible;
    }

        .login-container-pro .mb-5 {
            margin-bottom: 2rem !important;
        }

    .form-label-n {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--n-dark);
        margin-bottom: 8px;
        display: block;
        letter-spacing: 0.5px;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-n-premium {
        width: 100%;
        padding: 14px 14px 14px 45px;
        border: 2px solid #edf2f7;
        border-radius: 12px;
        background: #f8fafc;
        font-size: 0.95rem;
        color: var(--n-dark);
        transition: all 0.3s ease;
    }

        .input-n-premium:focus {
            border-color: var(--n-blue);
            background: white;
            box-shadow: 0 0 0 4px rgba(0, 107, 181, 0.1);
            outline: none;
        }

    .input-icon-n {
        position: absolute;
        left: 16px;
        color: #a0aec0;
        font-size: 1.2rem;
        transition: color 0.3s ease;
    }

    .input-n-premium:focus + .input-icon-n,
    .input-n-premium:not(:placeholder-shown) + .input-icon-n {
        color: var(--n-blue);
    }

    .btn-n-login {
        background: linear-gradient(135deg, var(--n-blue) 0%, var(--n-blue-dark) 100%);
        color: white;
        padding: 16px;
        border-radius: 12px;
        width: 100%;
        border: none;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.5px;
        box-shadow: 0 8px 20px rgba(0, 107, 181, 0.25);
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

        .btn-n-login:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(0, 107, 181, 0.35);
        }

        .btn-n-login:disabled {
            background: #a0aec0;
            box-shadow: none;
            cursor: not-allowed;
        }

    @SlideUpAndMediaCss
</style>

@if (estaCargando)
{
    <div class="loading-overlay">
        <div class="spinner-border text-primary" style="width: 3.5rem; height: 3.5rem;" role="status"></div>
        <h4 class="mt-4 fw-bold text-dark">Procesando Solicitud</h4>
        <p class="text-muted">Generando clave de seguridad...</p>
    </div>
}

<div class="main-viewport">
    <AuthBrandPanel DigitLayerId="numericaDigitsLayerRecover" />

    <div class="form-side auth-ps3-form">
        <div class="login-container-pro">
            <div class="text-center mb-5">
                <div class="brand-mobile-lockup d-lg-none mb-3">
                    <img src="/images/company-logo.png" class="brand-mobile-logo" alt="Numérica software" onerror="this.style.display='none'" />
                    <div class="brand-mobile-name">
                        <span>Numérica</span>
                        <span>software</span>
                    </div>
                </div>
                <h2 class="fw-bold text-dark mb-1">Recuperar Acceso</h2>
                <p class="text-muted small">Ingresa tu correo para recibir un codigo de acceso</p>
            </div>

            <EditForm Model="@model" OnValidSubmit="EnviarClave" FormName="recoverForm">
                <DataAnnotationsValidator />

                <div class="mb-4">
                    <label class="form-label-n">Correo Electrónico Registrado</label>
                    <div class="input-wrapper">
                        <InputText @bind-Value="model.Email" class="input-n-premium" placeholder="usuario@empresa.com" disabled="@estaCargando" autocomplete="email" />
                        <i class="bi bi-envelope input-icon-n"></i>
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1 d-block" />
                </div>

                <button type="submit" class="btn-n-login" disabled="@estaCargando">
                    RECUPERAR CLAVE
                </button>

                <div class="text-center mt-4">
                    <span class="text-muted small">¿Recordaste tu contraseña?</span>
                    <a href="/" class="text-primary fw-bold text-decoration-none ms-1 small">Volver al Login</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private static readonly MarkupString FontFaceCss = (MarkupString)@"
    @font-face {
        font-family: ""Conthrax SemiBold"";
        src: url(""/fonts/Conthrax-SemiBold.otf"") format(""opentype"");
        font-style: normal;
        font-weight: 600;
        font-display: swap;
    }
    ";

    private static readonly MarkupString KeyframesDigitFloatCss = (MarkupString)@"
    @keyframes numericaDigitFloat {
        0% {
            opacity: 0;
            transform: translate3d(0, 18px, 0) scale(0.88) rotate(var(--rotate, 0deg));
        }

        18% {
            opacity: var(--peak-opacity, 0.42);
        }

        72% {
            opacity: calc(var(--peak-opacity, 0.42) * 0.7);
        }

        100% {
            opacity: 0;
            transform: translate3d(var(--drift-x, 0px), var(--drift-y, -38px), 0) scale(1.05) rotate(calc(var(--rotate, 0deg) + 6deg));
        }
    }
    ";

    private static readonly MarkupString SlideUpAndMediaCss = (MarkupString)@"
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-height: 860px) {
        .main-viewport {
            height: auto;
        }

        .brand-side {
            padding: 2.5rem;
        }

        .glass-card {
            padding: 1.85rem;
            min-height: 25.75rem;
            gap: 1rem;
        }

        .brand-side,
        .form-side {
            padding-top: 1.25rem;
            padding-bottom: 1.25rem;
        }

        .login-container-pro {
            padding: 1.6rem 1.35rem;
        }
    }

    @media (max-width: 992px) {
        .main-viewport {
            flex-direction: column;
            height: auto;
            min-height: max(100vh, 100dvh);
            overflow: visible;
        }

        .form-side {
            min-height: 100dvh;
            padding: 0.9rem;
            background: var(--bg-color);
            overflow: visible;
        }

        .login-container-pro {
            padding: 1.75rem 1.25rem;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
        }
    }
    ";

    private RecoverPasswordModel model = new();
    private bool estaCargando = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("NumericaDigits.init", "numericaDigitsLayerRecover");
        }
    }

    private async Task EnviarClave()
    {
        if (estaCargando) return;

        estaCargando = true;
        StateHasChanged();

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            var correo = (model.Email ?? string.Empty).Trim().ToLower();

            var usuario = await context.Usuarios.FirstOrDefaultAsync(u => u.Email == correo);

            // Respuesta genérica por seguridad (evita enumeración de usuarios)
            if (usuario == null)
            {
                await ShowAlert("success", "Correo Enviado", "Se ha enviado un mensaje a tu correo para poder recuperar tu clave. Si no llega, verifica que el correo ingresado sea el correcto.");
                return;
            }

            const int minutosExpira = RecoveryCodeHelper.MinutosExpiracionPorDefecto;
            const string passwordTemporal = "00000000";
            string codigoAcceso = RecoveryCodeHelper.GenerarCodigoNumerico();

            var passwordHashAnterior = usuario.PasswordHash;
            var claveTemporalAnterior = usuario.ClaveTemporal;
            var cuentaBloqueadaAnterior = usuario.CuentaBloqueada;
            var intentosFallidosAnteriores = usuario.IntentosFallidos;
            var fechaDesbloqueoAnterior = usuario.FechaDesbloqueo;
            var fechaExpiracionAnterior = usuario.FechaExpiracionToken;
            var tokenRecuperacionAnterior = usuario.TokenRecuperacion;

            // Actualizar usuario
            usuario.PasswordHash = SecurityHelper.HashPassword(passwordTemporal);
            usuario.ClaveTemporal = true;
            usuario.CuentaBloqueada = false;
            usuario.IntentosFallidos = 0;
            usuario.FechaDesbloqueo = null;
            usuario.FechaExpiracionToken = DateTime.Now.AddMinutes(minutosExpira);
            usuario.TokenRecuperacion = SecurityHelper.HashPassword(codigoAcceso);

            await context.SaveChangesAsync();

            try
            {
                await EmailService.EnviarClaveTemporal(usuario.Email, codigoAcceso, minutosExpira, "Recuperacion de acceso");
            }
            catch (Exception ex)
            {
                usuario.PasswordHash = passwordHashAnterior;
                usuario.ClaveTemporal = claveTemporalAnterior;
                usuario.CuentaBloqueada = cuentaBloqueadaAnterior;
                usuario.IntentosFallidos = intentosFallidosAnteriores;
                usuario.FechaDesbloqueo = fechaDesbloqueoAnterior;
                usuario.FechaExpiracionToken = fechaExpiracionAnterior;
                usuario.TokenRecuperacion = tokenRecuperacionAnterior;

                try
                {
                    await context.SaveChangesAsync();
                }
                catch (Exception revertEx)
                {
                    Console.WriteLine($"Error revirtiendo recuperacion de clave para {correo}: {revertEx.Message}");
                }

                Console.WriteLine($"Error enviando codigo de acceso a {correo}: {ex.Message}");
                await ShowAlert("error", "Error de Envío", "Hubo un problema al enviar el correo. Por favor, intenta de nuevo más tarde.");
                return;
            }

            // Éxito real — mismo mensaje genérico para no revelar si el correo existe
            await ShowAlert("success", "Correo Enviado", "Se ha enviado un mensaje a tu correo con las instrucciones para recuperar tu clave. Si no llega, verifica que el correo ingresado sea el correcto.");

            await Task.Delay(2000); // Pequeña pausa para que el usuario lea la alerta
            Nav.NavigateTo($"/cambiar-clave/{usuario.IdUsuario}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            await ShowAlert("error", "Error Inesperado", "Ocurrió un error en el servidor al procesar la solicitud.");
        }
    }

    private async Task ShowAlert(string icon, string title, string text)
    {
        // Apagamos el estado de carga y forzamos renderizado antes de la alerta
        estaCargando = false;
        StateHasChanged();

        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = icon,
            title = title,
            text = text,
            confirmButtonColor = "#006bb5",
            timer = icon == "success" ? 3000 : 5000,
            backdrop = true
        });
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("NumericaDigits.destroy", "numericaDigitsLayerRecover");
        }
        catch
        {
        }
    }
}
