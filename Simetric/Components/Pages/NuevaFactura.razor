    private bool TryParseDecimalFlexible(string? s, out decimal value)
    {
        value = 0m;
        if (string.IsNullOrWhiteSpace(s)) return false;

        return decimal.TryParse(
            s,
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.CurrentCulture,
            out value)
            || decimal.TryParse(
                s,
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out value);
    }

    // ===================== DETALLE VISUAL =====================
    private decimal Red2(decimal v) => Math.Round(v, 2);

    private static DetalleFacturaDto CrearDetalleFacturaVacio() => new()
    {
        Cantidad = 1m,
        Precio = 0m,
        Descuento = 0m,
        PorcentajeDescuento = 0m,
        Tarifa = 15,
        TarifaPersonalizada = false,
        TarifaManual = 15,
        Descripcion = string.Empty,
        Detalle = string.Empty
    };

    private static bool EsDetalleFacturaVacio(DetalleFacturaDto d) =>
        d.Codproducto <= 0 &&
        string.IsNullOrWhiteSpace(d.Codprincipal) &&
        string.IsNullOrWhiteSpace(d.Codauxiliar) &&
        string.IsNullOrWhiteSpace(d.Descripcion) &&
        string.IsNullOrWhiteSpace(d.Detalle) &&
        d.Cantidad == 1m &&
        d.Precio <= 0m &&
        d.Descuento <= 0m &&
        d.PorcentajeDescuento <= 0m;

    private IEnumerable<DetalleFacturaDto> ObtenerDetallesFacturables() =>
        detallesDto.Where(d => !EsDetalleFacturaVacio(d));

    private void AsegurarFilaVaciaDetalle()
    {
        detallesDto ??= new();

        if (detallesDto.Any(EsDetalleFacturaVacio))
            return;

        var detalleVacio = CrearDetalleFacturaVacio();
        detallesDto.Add(detalleVacio);
        modosDescuentoDetalle[detalleVacio] = ModoDescuento.Porcentaje;
    }

    private void AsegurarFilaVaciaDespuesDeEdicion()
    {
        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
    }

    private DetalleFacturaDto ObtenerFilaDisponibleParaProducto()
    {
        var detalleDisponible = detallesDto.FirstOrDefault(EsDetalleFacturaVacio);
        if (detalleDisponible is not null)
            return detalleDisponible;

        var nuevoDetalle = CrearDetalleFacturaVacio();
        detallesDto.Add(nuevoDetalle);
        modosDescuentoDetalle[nuevoDetalle] = ModoDescuento.Porcentaje;
        return nuevoDetalle;
    }

    private void CargarProductoEnDetalle(
        DetalleFacturaDto detalle,
        ProductoLookupDetalleDto producto,
        decimal cantidad = 1m,
        decimal? precio = null,
        decimal descuentoValor = 0m,
        decimal descuentoPorcentaje = 0m,
        ModoDescuento modoDescuento = ModoDescuento.Porcentaje,
        bool cargarDetalleAutomatico = false)
    {
        detalle.Codproducto = producto.Codproducto;
        detalle.Codprincipal = producto.Codprincipal;
        detalle.Codauxiliar = producto.Codauxiliar;
        detalle.Cantidad = cantidad;
        detalle.Descripcion = producto.Descripcion ?? string.Empty;
        detalle.Detalle = cargarDetalleAutomatico ? (producto.Subcategoria ?? producto.Categoria) : string.Empty;
        detalle.Precio = precio ?? producto.PrecioUnitario;
        detalle.PorcentajeDescuento = descuentoPorcentaje;
        detalle.Descuento = descuentoValor;
        detalle.Tarifa = Math.Max(0, producto.TarifaIva);
        detalle.TarifaPersonalizada = false;
        detalle.TarifaManual = null;
        modosDescuentoDetalle[detalle] = modoDescuento;
    }

    private string GetCodigoVisualDetalle(DetalleFacturaDto d)
    {
        if (d.Codproducto > 0)
            return string.IsNullOrWhiteSpace(d.Codprincipal)
                ? d.Codproducto.ToString(CultureInfo.InvariantCulture)
                : d.Codprincipal;

        return EsDetalleFacturaVacio(d) ? string.Empty : "Manual";
    }

    private decimal GetSubtotalBrutoDetalle(DetalleFacturaDto d)
    {
        return Red2(d.Cantidad * d.Precio);
    }

    private decimal GetDescuentoUnitarioDetalle(DetalleFacturaDto d)
    {
        var bruto = GetSubtotalBrutoDetalle(d);

        if (GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje && d.PorcentajeDescuento > 0)
            return Red2(bruto * (d.PorcentajeDescuento / 100m));

        return Red2(d.Descuento);
    }

    private decimal GetDescuentoEfectivoDetalle(DetalleFacturaDto d)
    {
        if (d.PorcentajeDescuento > 0 || d.Descuento > 0)
            return GetDescuentoUnitarioDetalle(d);

        return 0m;
    }

    private decimal GetDescuentoGlobalAplicadoDetalle(DetalleFacturaDto d) => 0m;

    private decimal GetDescuentoGlobalMonedaAplicadoDetalle(DetalleFacturaDto d)
    {
        var totalBruto = detallesDto.Sum(GetSubtotalBrutoDetalle);
        if (totalBruto <= 0)
            return 0m;

        var descuentoMaximo = Math.Min(descuentoGlobalValor, totalBruto);
        return Red2(descuentoMaximo * (GetSubtotalBrutoDetalle(d) / totalBruto));
    }

    private decimal GetBaseImponibleDetalle(DetalleFacturaDto d)
    {
        return Math.Max(0m, Red2(GetSubtotalBrutoDetalle(d) - GetDescuentoEfectivoDetalle(d)));
    }

    private decimal GetIvaDetalle(DetalleFacturaDto d)
    {
        var tarifa = GetTarifaEfectiva(d);
        return Red2(GetBaseImponibleDetalle(d) * (tarifa / 100m));
    }

    private decimal GetTotalDetalle(DetalleFacturaDto d)
    {
        return Red2(GetBaseImponibleDetalle(d) + GetIvaDetalle(d));
    }

    private string GetCantidadVisual(DetalleFacturaDto d)
    {
        if (valoresTemporalesCantidad.TryGetValue(d, out var v)) return v;
        return d.Cantidad.ToString("0", CultureInfo.InvariantCulture);
    }

    private string GetPrecioVisual(DetalleFacturaDto d)
    {
        if (valoresTemporalesPrecio.TryGetValue(d, out var v)) return v;
        return d.Precio.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private string GetPorcentajeVisual(DetalleFacturaDto d)
    {
        if (valoresTemporalesPorcentaje.TryGetValue(d, out var valor)) return valor;
        return d.PorcentajeDescuento.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private ModoDescuento GetModoDescuentoDetalle(DetalleFacturaDto d)
    {
        if (modosDescuentoDetalle.TryGetValue(d, out var modo))
            return modo;

        return d.Descuento > 0 && d.PorcentajeDescuento <= 0
            ? ModoDescuento.Moneda
            : ModoDescuento.Porcentaje;
    }

    private string GetDescuentoDetalleVisual(DetalleFacturaDto d)
    {
        if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda)
        {
            if (valoresTemporalesDescuentoMoneda.TryGetValue(d, out var moneda))
                return moneda;

            return d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        return GetPorcentajeVisual(d);
    }

    private void CambiarModoDescuentoDetalle(DetalleFacturaDto d, ModoDescuento modo)
    {
        var modoActual = GetModoDescuentoDetalle(d);
        if (modoActual == modo)
            return;

        modosDescuentoDetalle[d] = modo;
        valoresTemporalesPorcentaje.Remove(d);
        valoresTemporalesDescuentoMoneda.Remove(d);

        var bruto = GetSubtotalBrutoDetalle(d);

        if (modo == ModoDescuento.Porcentaje)
        {
            d.PorcentajeDescuento = bruto > 0 ? Math.Clamp(Red2((d.Descuento / bruto) * 100m), 0m, 100m) : 0m;
            d.Descuento = Red2(bruto * (d.PorcentajeDescuento / 100m));
        }
        else
        {
            d.Descuento = GetDescuentoUnitarioDetalle(d);
            d.PorcentajeDescuento = 0m;
        }

        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void OnDescuentoDetalleInput(DetalleFacturaDto d, string? v)
    {
        if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda)
        {
            valoresTemporalesDescuentoMoneda[d] = v ?? "0";

            if (TryParseDecimalFlexible(v, out var monto))
            {
                d.PorcentajeDescuento = 0m;
                d.Descuento = Math.Clamp(Red2(monto), 0m, GetSubtotalBrutoDetalle(d));
                valoresTemporalesDescuentoMoneda[d] = d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
            }
            else
            {
                d.Descuento = 0m;
            }
        }
        else
        {
            OnPorcentajeDescuentoDetalleInput(d, v);
            return;
        }

        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void OnCantidadDetalleInput(DetalleFacturaDto d, string? v)
    {
        valoresTemporalesCantidad[d] = v ?? "1";

        if (!TryParseDecimalFlexible(v, out var cant))
            return;

        var cantidadEntera = Math.Max(1m, decimal.Truncate(cant));
        d.Cantidad = cantidadEntera;
        valoresTemporalesCantidad[d] = cantidadEntera.ToString("0", CultureInfo.InvariantCulture);

        if (d.PorcentajeDescuento > 0)
        {
            var bruto = d.Cantidad * d.Precio;
            d.Descuento = Math.Round(bruto * (d.PorcentajeDescuento / 100m), 2);
        }
        else if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda && d.Descuento > 0)
        {
            d.Descuento = Math.Min(d.Descuento, GetSubtotalBrutoDetalle(d));
            valoresTemporalesDescuentoMoneda[d] = d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void OnPrecioDetalleInput(DetalleFacturaDto d, string? v)
    {
        valoresTemporalesPrecio[d] = v ?? "0";

        if (!TryParseDecimalFlexible(v, out var precio))
            return;

        d.Precio = Math.Max(0.01m, precio);

        if (d.PorcentajeDescuento > 0)
        {
            var bruto = d.Cantidad * d.Precio;
            d.Descuento = Math.Round(bruto * (d.PorcentajeDescuento / 100m), 2);
        }
        else if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda && d.Descuento > 0)
        {
            d.Descuento = Math.Min(d.Descuento, GetSubtotalBrutoDetalle(d));
            valoresTemporalesDescuentoMoneda[d] = d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void OnPorcentajeDescuentoDetalleInput(DetalleFacturaDto d, string? v)
    {
        modosDescuentoDetalle[d] = ModoDescuento.Porcentaje;
        valoresTemporalesPorcentaje[d] = v ?? "0";
        valoresTemporalesDescuentoMoneda.Remove(d);

        if (TryParseDecimalFlexible(v, out var porc))
        {
            porc = Math.Clamp(porc, 0m, 100m);
            d.PorcentajeDescuento = porc;

            var subtotalBruto = d.Cantidad * d.Precio;
            d.Descuento = Math.Round(subtotalBruto * (porc / 100m), 2);
        }
        else
        {
            d.PorcentajeDescuento = 0;
            d.Descuento = 0;
        }

        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private string GetDescuentoGlobalVisual()
    {
        return modoDescuentoGlobalTipo == ModoDescuento.Moneda
            ? descuentoGlobalValor.ToString("0.##", CultureInfo.InvariantCulture)
            : descuentoGlobalPorcentaje.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private void CambiarModoDescuentoGlobal(ModoDescuento modo)
    {
        if (modoDescuentoGlobalTipo == modo)
            return;

        var subtotalBruto = detallesDto.Sum(GetSubtotalBrutoDetalle);

        if (modo == ModoDescuento.Moneda)
        {
            descuentoGlobalValor = descuentoGlobalPorcentaje > 0
                ? Math.Min(Red2(subtotalBruto * (descuentoGlobalPorcentaje / 100m)), subtotalBruto)
                : 0m;
            descuentoGlobalPorcentaje = 0m;
        }
        else
        {
            descuentoGlobalPorcentaje = subtotalBruto > 0 && descuentoGlobalValor > 0
                ? Math.Clamp(Red2((descuentoGlobalValor / subtotalBruto) * 100m), 0m, 100m)
                : 0m;
            descuentoGlobalValor = 0m;
        }

        modoDescuentoGlobalTipo = modo;
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void OnDescuentoGlobalInput(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();

        if (TryParseDecimalFlexible(s, out var v) && modoDescuentoGlobalTipo == ModoDescuento.Moneda)
        {
            descuentoGlobalValor = Math.Clamp(Red2(v), 0m, detallesDto.Sum(GetSubtotalBrutoDetalle));
            descuentoGlobalPorcentaje = 0m;
        }
        else if (TryParseDecimalFlexible(s, out v))
        {
            descuentoGlobalPorcentaje = Math.Clamp(v, 0m, 100m);
            descuentoGlobalValor = 0m;
        }
        else
        {
            descuentoGlobalPorcentaje = 0m;
            descuentoGlobalValor = 0m;
        }

        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void LimpiarTodosLosDescuentos()
    {
        foreach (var d in detallesDto)
        {
            d.Descuento = 0;
            d.PorcentajeDescuento = 0;
        }

        descuentoGlobalPorcentaje = 0;
        descuentoGlobalValor = 0;
        modoDescuentoGlobalTipo = ModoDescuento.Porcentaje;
        modoDescuentoGlobal = false;
        valoresTemporalesPorcentaje.Clear();
        valoresTemporalesDescuentoMoneda.Clear();
        modosDescuentoDetalle.Clear();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private static string ConstruirDescripcionComprobante(DetalleFacturaDto d)
    {
        var concepto = (d.Descripcion ?? string.Empty).Trim();
        var detalle = (d.Detalle ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(detalle))
            return concepto;

        if (string.IsNullOrWhiteSpace(concepto))
            return detalle;

        if (concepto.Contains(detalle, StringComparison.OrdinalIgnoreCase))
            return concepto;

        return $"{concepto} - {detalle}";
    }

