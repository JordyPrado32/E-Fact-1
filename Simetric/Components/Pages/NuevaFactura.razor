@* ======================= MODAL NUEVO PRODUCTO ======================= *@
@if (mostrarModalProducto)
{
    <div class="n-product-modal-backdrop n-product-create-backdrop" @onclick="CerrarModalProducto"></div>
    <div class="n-product-modal-shell n-product-create-shell" role="dialog" aria-modal="true" aria-labelledby="nuevoProductoModalTitulo">
        <div class="n-modal n-product-modal-content n-history-modal-content n-product-create-modal">
            <div class="n-modal-header">
                <div class="n-modal-header-main n-modal-header-main-product">
                    <span class="n-product-create-icon">
                        <i class="bi bi-box-seam"></i>
                    </span>
                    <div class="n-modal-copy n-modal-copy-product">
                        <div class="n-modal-title-row">
                            <div id="nuevoProductoModalTitulo" class="n-modal-title">Registrar producto</div>
                            <span class="n-modal-head-chip n-modal-head-chip-accent">Nuevo</span>
                        </div>
