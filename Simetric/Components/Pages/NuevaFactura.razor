    // ===================== TOTALES =====================
    private void CalcularTotalesFactura()
    {
        descuentoGlobalPorcentaje = 0m;
        descuentoGlobalValor = 0m;
        modoDescuentoGlobalTipo = ModoDescuento.Porcentaje;

        var gruposPorTarifa = detallesDto
            .GroupBy(x => GetTarifaEfectiva(x))
            .Select(g => new
            {
                Tarifa = g.Key,
                Bruto = g.Sum(x => GetSubtotalBrutoDetalle(x)),
                Descuento = g.Sum(x => GetDescuentoEfectivoDetalle(x)),
                Base = g.Sum(x => GetBaseImponibleDetalle(x)),
                Iva = g.Sum(x => GetIvaDetalle(x))
            })
            .ToList();

        factura.Subtotal = gruposPorTarifa.Sum(x => x.Base);
        factura.Descuentos = gruposPorTarifa.Sum(x => x.Descuento);
        factura.Iva = gruposPorTarifa.Sum(x => x.Iva);
        factura.Valortotal = (factura.Subtotal ?? 0) + (factura.Iva ?? 0);

        factura.Subtotal0 = gruposPorTarifa.Where(x => x.Tarifa == 0).Sum(x => x.Base);
        factura.Subtotal12 = gruposPorTarifa.Where(x => x.Tarifa > 0).Sum(x => x.Base);

        factura.Subcerototal = factura.Subtotal0;
        factura.Subdocetotal = factura.Subtotal12;
        factura.Subnoimptotal = 0;
        factura.Subexivatotal = 0;
        factura.Noimp = 0;
        factura.Exiva = 0;
        factura.Valorice = 0;
        factura.Valorapagar = factura.Valortotal;
        factura.DescuentoGlobalPct = 0m;
        factura.DescuentoGlobalValor = 0m;
    }

    // ===================== VALIDACIONES =====================
    private string? ValidarFormularioAntesDeGuardar()
    {
        if (sinCaja)
            return "Debes crear tu caja (serie) antes de facturar.";

        if (BloqueadoPorSaldoDocumentos)
            return MensajeBloqueoDocumentos;

        if (factura.Codemisor == null || factura.Codemisor <= 0)
            return "Debes seleccionar un emisor.";

        if (string.IsNullOrWhiteSpace(factura.Serie))
            return "Debes seleccionar un punto de emision valido.";

        if (string.IsNullOrWhiteSpace(factura.Numfactura))
            return "Debes configurar la secuencia del punto de emision seleccionado antes de facturar.";

        if (string.IsNullOrWhiteSpace(formaPagoSeleccionada))
            return "Debes seleccionar una forma de pago.";

        if (string.IsNullOrWhiteSpace(cliente.Numeroidentificacion))
            return "Debes ingresar el número de identificación del cliente.";

        cliente.Numeroidentificacion = cliente.Numeroidentificacion.Trim();

        if (cliente.Numeroidentificacion.Length != 10 && cliente.Numeroidentificacion.Length != 13)
            return "La identificación del cliente debe tener 10 o 13 dígitos.";

        if (!cliente.Numeroidentificacion.All(char.IsDigit))
            return "La identificación del cliente solo debe contener números.";

        if (string.IsNullOrWhiteSpace(cliente.Tipoidentificacion))
            return "El cliente no tiene un tipo de identificación válido.";

        if (cliente.TipoCliente == null || cliente.TipoCliente <= 0)
            return "Debes seleccionar el tipo de cliente.";

        var omitirCamposOpcionalesClienteNuevo = ClienteIngresadoSinRegistro && continuarConClienteSinRegistro;

        if (EsEmpresaSeleccionada)
        {
            if (!omitirCamposOpcionalesClienteNuevo && string.IsNullOrWhiteSpace(cliente.Nombrecomercial))
                return "Si el cliente es PERSONA JURÍDICA, debes llenar Nombre Comercial.";

            if (string.IsNullOrWhiteSpace(cliente.Nombrerazonsocial))
                return "Si el cliente es PERSONA JURÍDICA, debes llenar Razón Social.";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(cliente.Nombres))
                return "Debes ingresar los nombres del cliente.";

            if (string.IsNullOrWhiteSpace(cliente.Apellidos))
                return "Debes ingresar los apellidos del cliente.";
        }

        if (!string.IsNullOrWhiteSpace(cliente.Celular))
        {
            cliente.Celular = cliente.Celular.Trim();
            if (cliente.Celular.Length != 10 || !cliente.Celular.All(char.IsDigit))
                return "El celular debe tener exactamente 10 dígitos.";
        }

        if (!string.IsNullOrWhiteSpace(cliente.Telefonoconvencional))
        {
            cliente.Telefonoconvencional = cliente.Telefonoconvencional.Trim();
            if (!cliente.Telefonoconvencional.All(char.IsDigit))
                return "El teléfono convencional solo debe contener números.";
        }

        if (ClienteSinRegistroPendienteDecision)
            return "Este cliente no esta registrado. Elige Agregar ahora o Continuar para usar estos datos en la factura.";

        if (!string.IsNullOrWhiteSpace(cliente.Correo))
        {
            cliente.Correo = cliente.Correo.Trim();
            var emailOk = Regex.IsMatch(cliente.Correo, @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
            if (!emailOk)
                return "El correo electrónico no tiene un formato válido.";
        }

        NormalizarCorreosOpcionalesFactura();

        var correosUsados = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(cliente.Correo))
            correosUsados.Add(cliente.Correo);

        for (int i = 0; i < correosOpcionalesFactura.Count; i++)
        {
            var correoExtra = correosOpcionalesFactura[i];

            if (string.IsNullOrWhiteSpace(correoExtra.Correo))
                continue;

            var emailOk = Regex.IsMatch(correoExtra.Correo, @"^[^@\s]+@[^@\s]+\.[^@\s]+$");
            if (!emailOk)
                return $"El correo opcional #{i + 1} no tiene un formato válido.";

            if (!correosUsados.Add(correoExtra.Correo))
                return $"El correo {correoExtra.Correo} está repetido entre los destinatarios de la factura.";
        }

        if (agregarGuiaRemision)
        {
            if (!TieneSerieGuiaDisponible)
                return "Tu caja no tiene configurada una serie de guia.";

            if (!(guiaRemisionEstab.Length == 3 && guiaRemisionPunto.Length == 3 && guiaRemisionSecuencial.Length == 9))
                return "No se pudo generar correctamente la guia de remision para la factura.";
        }

        if (ContarPalabras(cliente.Referencia) > 100)
            return "La referencia no puede superar las 100 palabras.";

        var detallesFacturables = ObtenerDetallesFacturables().ToList();

        if (!detallesFacturables.Any())
            return "Debe agregar al menos un producto al detalle.";

        for (int i = 0; i < detallesFacturables.Count; i++)
        {
            var d = detallesFacturables[i];
            var bruto = GetSubtotalBrutoDetalle(d);
            var descuentoEfectivo = GetDescuentoEfectivoDetalle(d);

            if (string.IsNullOrWhiteSpace(ConstruirDescripcionComprobante(d)))
                return $"En la línea #{i + 1} el concepto o detalle del producto es obligatorio.";

            if (d.Cantidad <= 0)
                return $"En la línea #{i + 1} la cantidad debe ser mayor a 0.";

            if (d.Cantidad != decimal.Truncate(d.Cantidad))
                return $"En la línea #{i + 1} la cantidad debe ser un número entero.";

            if (d.Precio <= 0)
                return $"En la línea #{i + 1} el precio debe ser mayor a 0.";

            if (d.PorcentajeDescuento < 0 || d.PorcentajeDescuento > 100)
                return $"En la línea #{i + 1} el porcentaje de descuento es inválido.";

            if (descuentoEfectivo < 0)
                return $"En la línea #{i + 1} el descuento no puede ser negativo.";

            if (descuentoEfectivo > bruto)
                return $"En la línea #{i + 1} el descuento no puede ser mayor al subtotal del producto.";

            var tarifa = GetTarifaEfectiva(d);
            if (tarifa < 0 || tarifa > 100)
                return $"En la línea #{i + 1} la tarifa IVA es inválida.";
        }

        return null;
    }

    // ===================== GUARDAR FACTURA =====================
    private async Task ProcesarGuardado(EditContext editContext)
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync("Modo demo: la emision esta bloqueada para invitados.");
            return;
        }

        if (agregarGuiaRemision)
            await PrepararGuiaRemisionFacturaAsync();
        else
            LimpiarGuiaRemisionFactura();

        factura.Serie = serieVisual.Replace("-", "").Trim();

        if (!sinCaja && factura.Codemisor is > 0 && !string.IsNullOrWhiteSpace(factura.Serie))
        {
            var debePreguntarSecuencia = await FacturacionService.DebePreguntarSecuenciaInicialAsync(currentUserId, factura.Codemisor, factura.Serie);
            if (debePreguntarSecuencia)
            {
                usuarioYaFacturoAntes = null;
                secuenciaAnteriorManual = string.Empty;
                errorSecuenciaInicial = null;
                seriePendienteModalRaw = factura.Serie;
                mostrarModalSecuenciaInicial = true;
                factura.Numfactura = "000000001";
                return;
            }

            if (string.IsNullOrWhiteSpace(factura.Numfactura))
                factura.Numfactura = await FacturacionService.GetNextFacturaNumeroAsync(currentUserId, factura.Codemisor, factura.Serie);
        }

        var error = ValidarFormularioAntesDeGuardar();
        if (!string.IsNullOrWhiteSpace(error))
        {
            await AlertService.ShowErrorAsync(error);
            return;
        }

        if (EsEmpresaSeleccionada)
        {
            cliente.Nombres = null;
            cliente.Apellidos = null;
        }
        else
        {
            cliente.Nombrecomercial = null;
            cliente.Nombrerazonsocial = null;
            SincronizarNombres();
        }

        factura.Tipopago = formaPagoSeleccionada;
        factura.Ambiente = 2; // producción
        factura.Serie = serieVisual.Replace("-", "").Trim();
        factura.Idusuario = currentUserId;
        factura.Coddocumento ??= 1;
        factura.Estado = true;
        factura.Autorizado = false;
        factura.Fchautorizacion = null;
        factura.Fechaautosri = null;
        factura.Notas = string.IsNullOrWhiteSpace(factura.Notas) ? null : factura.Notas.Trim();

        cliente.Usuario = currentUserId;
        cliente.Estado = true;

        CalcularTotalesFactura();
        var correosFactura = ObtenerCorreosOpcionalesFactura();
        var detallesFacturables = ObtenerDetallesFacturables().ToList();

        var detallesParaGuardar = new List<Simetric.Models.Detallefactura>();

        foreach (var d in detallesFacturables)
        {
            var tarifa = GetTarifaEfectiva(d);
            var descuento = GetDescuentoEfectivoDetalle(d);
            var baseImp = GetBaseImponibleDetalle(d);
            var iva = GetIvaDetalle(d);
            var total = GetTotalDetalle(d);

            detallesParaGuardar.Add(new Simetric.Models.Detallefactura
            {
                Codproducto = d.Codproducto,
                Codprincipal = d.Codprincipal,
                Codauxiliar = d.Codauxiliar,
                Cantproducto = d.Cantidad,
                Precioproducto = d.Precio,
                Descuento = GetDescuentoUnitarioDetalle(d),
                Tarifa = tarifa,
                Descripproducto = ConstruirDescripcionComprobante(d),
                Valortproducto = baseImp,
                Valoriva = iva,
                Valortotal = total
            });
        }

        var facturaGuardada = false;
        mensajeRapidoEmision = null;
        mensajeRapidoEsError = false;
        documentoGeneradoPdfUrl = null;

        try
        {
            mostrarPantallaCargaEmision = true;
            mensajeRapidoFactura = null;
            mensajeRapidoFacturaEsError = false;
            facturaGeneradaPdfUrl = null;
            await InvokeAsync(StateHasChanged);
            var exito = await FacturacionService.GuardarFacturaCompletaAsync(
                currentUserId,
                factura,
                cliente,
                detallesParaGuardar,
                correosFactura);

            if (!exito)
            {
                var mensajeError = FacturacionService.UltimoErrorGuardarFactura ?? "No se pudo guardar la factura.";
                await AlertService.CloseAsync();
                await AlertService.ShowErrorAsync(mensajeError);
                return;
            }

            facturaGuardada = true;
            var mensajeResultado = "";
            try
            {

                string rutaXml = await FacturacionService.ProcesarXmlFacturaAsync(factura.Codfactura);

                string pathCertificado = "";
                string pass = "";
                if (!emisores.Any())
                    emisores = await FacturacionService.GetEmisoresActivosAsync(currentUserId);
                mensajeSRI m = new mensajeSRI();
                var emisorFirma = emisores.FirstOrDefault(x => x.Codigo == factura.Codemisor) ?? emisores.FirstOrDefault();
                if (emisorFirma != null)
                {
                    pathCertificado = ResolverRutaFirmaElectronica(emisorFirma.PathCertificado);
                    if (!File.Exists(pathCertificado))
                        throw new FileNotFoundException($"No se encontro la firma electronica dentro de wwwroot/App_Data/certs en la ruta esperada: {pathCertificado}");

                    pass = emisorFirma.ClaveCertificado;
                    if (string.IsNullOrWhiteSpace(pass))
                        throw new InvalidOperationException("La firma electronica configurada no tiene clave registrada.");

                    //EnviarXmlAApiFrameworkAsync(rutaXml, pathCertificado, pass).Wait();
                    m = await EnviarXmlAApiFrameworkAsync(rutaXml, pathCertificado, pass);
                }
                if (string.Equals(m.estado, "AUTORIZADO", StringComparison.OrdinalIgnoreCase))
                {
                    await FacturacionService.ActualizarAutorizacionFacturaAsync(factura.Codfactura, m.autorizacion, m.fecha, "ok",true);
                    var resultadoCorreo = await FacturacionService.IntentarEnviarFacturaPorCorreoAsync(factura.Codfactura, rutaXml, m);
                    await AlertService.CloseAsync();
                    mensajeResultado = resultadoCorreo.Enviado || resultadoCorreo.YaEnviado
                        ? resultadoCorreo.Mensaje
                        : $"Factura autorizada, con observaciones en el correo: {resultadoCorreo.Mensaje}";
                    var pdfUrl = await FacturacionService.AsegurarPdfFacturaUsuarioAsync(factura.Codfactura, currentUserId);
                    documentoGeneradoPdfUrl = AgregarVersionPdf(pdfUrl);
                    mensajeRapidoEmision = mensajeResultado;
                    mensajeRapidoEsError = false;
                }
                else
                {
                    var mensajeSri = string.IsNullOrWhiteSpace(m.mensaje) ? "Sin respuesta autorizada del SRI." : m.mensaje;
                    var detalleSri = string.IsNullOrWhiteSpace(m.xml) ? mensajeSri : m.xml;
                    await FacturacionService.ActualizarAutorizacionFacturaAsync(factura.Codfactura, m.autorizacion ?? "", m.fecha ?? DateTime.Now.ToString(), detalleSri, false);
                    await AlertService.CloseAsync();
                    mensajeRapidoEmision = "Factura guardada no autorizada: " + mensajeSri + " Puede reenviar la factura desde el listado.";
                    mensajeRapidoEsError = true;
                }
            }
            catch (FileNotFoundException exFirma)
            {
                await AlertService.CloseAsync();
                MostrarAvisoRapidoFactura(exFirma.Message, true);
                return;
            }
            catch (TaskCanceledException exTimeout)
            {
                await FacturacionService.ActualizarAutorizacionFacturaAsync(factura.Codfactura, "", DateTime.Now.ToString(), "Timeout SRI/XML: " + exTimeout.Message, false);
                await AlertService.CloseAsync();
                MostrarAvisoRapidoFactura("Factura guardada, pero no se pudo emitir al SRI por tiempo agotado. Puede reenviarla desde el listado.", true);
            }
            catch (Exception exXml)
            {
                await FacturacionService.ActualizarAutorizacionFacturaAsync(factura.Codfactura, "",DateTime.Now.ToString(), "error interno: " + exXml.Message,false);
                mensajeResultado = $"Factura guardada, pero hubo un error al generar los archivos electrónicos: {exXml.Message}";
                await AlertService.CloseAsync();
                MostrarAvisoRapidoFactura(mensajeResultado, true);
            }

           
            await AlertService.CloseAsync();
            await LimpiarFormulario();
            //await AlertService.ShowSuccessAsync(mensajeResultado, "Factura guardada");
            //_ = RefrescarEstadoEmisionDespuesDeGuardadoAsync();
        }
        catch (TaskCanceledException)
        {
            usuarioYaFacturoAntes = null;
            secuenciaAnteriorManual = "";
            errorSecuenciaInicial = null;
            mostrarModalSecuenciaInicial = false;
            await AlertService.CloseAsync();
            MostrarAvisoRapidoFactura("La emisión tardó demasiado en completarse. Intenta nuevamente.", true);
        }
        catch (Exception ex)
        {
            usuarioYaFacturoAntes = null;
            secuenciaAnteriorManual = "";
            errorSecuenciaInicial = null;
            mostrarModalSecuenciaInicial = false;
            var mensajeError = $"Error al guardar la factura: {ex.Message}";
            await AlertService.CloseAsync();
            if (facturaGuardada)
            {
                MostrarAvisoRapidoFactura($"La factura se guardó, pero el flujo de emisión terminó con una novedad: {ex.Message}", true);
                return;
            }
            MostrarAvisoRapidoFactura(mensajeError, true);
        }
        finally
        {
            mostrarPantallaCargaEmision = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async Task<mensajeSRI> EnviarXmlAApiFrameworkAsync(string rutaArchivoxml, string rutaFirma, string password)
    {
        try
        {
            string apiUrl = "http://localhost:8090/api/xml/process"; //produccion
            //string apiUrl = "https://localhost:44372/api/xml/process"; //pruebas

            if (!File.Exists(rutaArchivoxml))
            {
                throw new FileNotFoundException($"No se encontró el archivo XML en la ruta: {rutaArchivoxml}");
            }
            if (!File.Exists(rutaFirma))
            {
                throw new FileNotFoundException($"No se encontró la firma electrónica en wwwroot/App_Data/certs/path: {rutaFirma}");
            }
            var solicitudData = new
            {
                RutaXml = rutaArchivoxml,
                RutaFirma = rutaFirma,
                PasswordFirma = password
            };

            string jsonPayload = System.Text.Json.JsonSerializer.Serialize(solicitudData);
            var jsonContent = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

            var request = new HttpRequestMessage(HttpMethod.Post, apiUrl)
            {
                Content = jsonContent
            };

            request.Headers.Add("X-Api-Key", "E-factSimetricNumericaKey2026*#");
            request.Headers.UserAgent.ParseAdd("NumericaSoftwareClient/1.0");

            var handler = new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true
            };

            using (var client = new HttpClient(handler))
            {
                client.Timeout = TimeSpan.FromSeconds(90);
                HttpResponseMessage response = await client.SendAsync(request).ConfigureAwait(false);
                string xmlRespuesta = await response.Content.ReadAsStringAsync().ConfigureAwait(false);

                if (response.IsSuccessStatusCode)
                {
                    // 2. DESERIALIZAR la respuesta XML recibida al objeto mensajeSRI
                    var serializer = new System.Xml.Serialization.XmlSerializer(typeof(mensajeSRI));
                    using (var reader = new System.IO.StringReader(xmlRespuesta))
                    {
                        var resultado = serializer.Deserialize(reader) as mensajeSRI;
                        return resultado ?? new mensajeSRI();
                    }
                }
                else
                {
                    // Si la API responde un error controlado (400, 404, 500)
                    throw new Exception($"Respuesta de error de la API: {xmlRespuesta}");
                }
            }
        }
        catch (Exception ex)
        {
            // 3. En caso de error, mapeamos la excepción a un objeto mensajeSRI de error
            // Reemplaza "xml" o las propiedades según cómo se llamen en tu clase real
            return new mensajeSRI
            {
                estado = "ERROR",
                mensaje = ex.Message,
                xml = $"<error><tipo>ExcepcionBlazor</tipo><mensaje>{System.Security.SecurityElement.Escape(ex.Message)}</mensaje></error>"
            };
        }
    }
    private static string ResolverRutaFirmaElectronica(string? rutaFirma)
    {
        var nombreArchivo = Path.GetFileName((rutaFirma ?? string.Empty).Trim().Replace('\\', '/'));
        var basePath = Directory.GetCurrentDirectory();
        var candidates = new[]
        {
            Path.Combine(basePath, "wwwroot", "App_Data", "certs", "path", nombreArchivo),
            Path.Combine(basePath, "App_Data", "certs", "path", nombreArchivo)
        };

        var ruta = candidates.FirstOrDefault(File.Exists);
        if (ruta is not null)
        {
            return ruta;
        }

        throw new FileNotFoundException($"No se encontró la firma electrónica en wwwroot/App_Data/certs/path: {nombreArchivo}");
    }

