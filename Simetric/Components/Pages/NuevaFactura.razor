    private async Task OnCodigoProductoBlur()
    {
        if (sinCaja) return;

        await Task.Delay(150);

        if (seleccionandoProductoDesdeLista)
        {
            seleccionandoProductoDesdeLista = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(nuevoCodProducto))
        {
            sugerenciasProductos = null;
            return;
        }

        if (productoLookup != null &&
            (
                string.Equals(productoLookup.Codprincipal?.Trim(), nuevoCodProducto.Trim(), StringComparison.OrdinalIgnoreCase) ||
                string.Equals(productoLookup.Codproducto.ToString(), nuevoCodProducto.Trim(), StringComparison.OrdinalIgnoreCase)
            ))
        {
            return;
        }

        productoLookup = await FacturacionService.BuscarProductoParaDetalleAsync(currentUserId, nuevoCodProducto.Trim());

        if (productoLookup == null)
        {
            msgDetalle = "No existe producto con ese código.";
            nuevoDescripcion = "";
            nuevoPrecio = 0;
        }
        else
        {
            SeleccionarProducto(productoLookup);
        }

        StateHasChanged();
    }



