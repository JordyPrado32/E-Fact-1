    private async Task PrepararGuiaRemisionFacturaAsync()
    {
        if (!TieneSerieGuiaDisponible)
        {
            agregarGuiaRemision = false;
            LimpiarGuiaRemisionFactura();
            return;
        }

        var serieGuia = FormatearSerie(cajaUsuario?.SerieGuia ?? string.Empty);
        var partesSerie = serieGuia.Split('-', StringSplitOptions.RemoveEmptyEntries);

        guiaRemisionEstab = partesSerie.Length > 0 ? partesSerie[0] : string.Empty;
        guiaRemisionPunto = partesSerie.Length > 1 ? partesSerie[1] : string.Empty;
        guiaRemisionSecuencial = await GuiaRemisionService.GetNextGuiaRemisionNumeroAsync(currentUserId);
        SincronizarGuiaRemisionFactura();
    }

    private async Task OnAgregarGuiaRemisionChanged(ChangeEventArgs e)
    {
        agregarGuiaRemision =
            e.Value is bool value
                ? value
                : string.Equals(e.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);

        if (agregarGuiaRemision)
        {
            if (!TieneSerieGuiaDisponible)
            {
                agregarGuiaRemision = false;
                LimpiarGuiaRemisionFactura();
                await AlertService.ShowWarningAsync("Tu caja no tiene serie de guia configurada.");
                return;
            }

            await PrepararGuiaRemisionFacturaAsync();
        }
        else
        {
            LimpiarGuiaRemisionFactura();
        }
    }

    private string ObtenerNombreClienteVisual(Simetric.Models.Cliente? clienteActual, string? textoBusquedaActual = null)
    {
        if (clienteActual is null)
            return string.IsNullOrWhiteSpace(textoBusquedaActual) ? "Cliente seleccionado" : textoBusquedaActual.Trim();

        var nombrePersona = $"{clienteActual.Nombres} {clienteActual.Apellidos}".Trim();
        var esJuridica = clienteActual.TipoCliente.HasValue &&
            tiposCliente.Any(x =>
                x.TclCodigo == clienteActual.TipoCliente.Value &&
                TipoClienteClasificacion.EsJuridica(x.TclDescripcion));

        if (!esJuridica && !string.IsNullOrWhiteSpace(nombrePersona))
            return nombrePersona;

        if (!string.IsNullOrWhiteSpace(clienteActual.Nombrerazonsocial))
            return clienteActual.Nombrerazonsocial.Trim();

        if (!string.IsNullOrWhiteSpace(clienteActual.Nombrecomercial))
            return clienteActual.Nombrecomercial.Trim();

        if (!string.IsNullOrWhiteSpace(nombrePersona))
            return nombrePersona;

        if (!string.IsNullOrWhiteSpace(textoBusquedaActual))
            return textoBusquedaActual.Trim();

        if (!string.IsNullOrWhiteSpace(clienteActual.Numeroidentificacion))
            return $"Cliente {clienteActual.Numeroidentificacion.Trim()}";

        return "Cliente seleccionado";
    }

