                            <div class="row g-3 n-modal-main-fields">
                                <div class="col-12">
                                    <label class="n-label">Tipo de registro *</label>
                                    <div class="n-choice-group" role="group" aria-label="Tipo de producto o servicio">
                                        <button type="button"
                                                class="n-choice-btn @(string.Equals(productoModal.TipoCompravena, "PRODUCTO", StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)"
                                                @onclick="SeleccionarTipoProductoModal">
                                            Producto
