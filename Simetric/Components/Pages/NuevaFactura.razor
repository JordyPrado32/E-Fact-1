    private void SincronizarClienteDesdeBusquedaUnificada(string valor)
    {
        var digitos = new string((valor ?? string.Empty).Where(char.IsDigit).ToArray());

        if (digitos.Length is 10 or 13)
        {
            if (!string.Equals(cliente.Numeroidentificacion, digitos, StringComparison.Ordinal))
            {
                if (ClienteTieneDatosComplementarios())
                {
                    LimpiarClienteFacturaParaNuevaBusqueda(digitos);
                }
                else
                {
                    cliente.Codcliente = 0;
                    clienteDetectadoEnCatalogoFactura = false;
                    continuarConClienteSinRegistro = false;
                }
            }

            cliente.Numeroidentificacion = digitos;
            cliente.Tipoidentificacion = InferirTipoIdentificacion(digitos);
            return;
        }

        if (cliente.Codcliente <= 0 && !string.IsNullOrWhiteSpace(cliente.Numeroidentificacion))
        {
            cliente.Numeroidentificacion = string.Empty;
            clienteDetectadoEnCatalogoFactura = false;
            continuarConClienteSinRegistro = false;
        }
    }

    private async Task OnKeyDownBusquedaIdentificacion(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            if (sugerenciasIdentificacion == null || !sugerenciasIdentificacion.Any())
            {
                await ToggleSugerenciasIdentificacionAsync();
                indiceSugerenciaIdentificacionActiva = ObtenerIndiceInicial(sugerenciasIdentificacion);
                return;
            }

            indiceSugerenciaIdentificacionActiva = MoverIndiceCircular(indiceSugerenciaIdentificacionActiva, 1, sugerenciasIdentificacion.Count);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            if (sugerenciasIdentificacion == null || !sugerenciasIdentificacion.Any())
            {
                await ToggleSugerenciasIdentificacionAsync();
                indiceSugerenciaIdentificacionActiva = sugerenciasIdentificacion?.Count > 0 ? sugerenciasIdentificacion.Count - 1 : -1;
                return;
            }

            indiceSugerenciaIdentificacionActiva = MoverIndiceCircular(indiceSugerenciaIdentificacionActiva, -1, sugerenciasIdentificacion.Count);
            return;
        }

        if (e.Key == "Escape")
        {
            sugerenciasIdentificacion = null;
            indiceSugerenciaIdentificacionActiva = -1;
            return;
        }

        if ((e.Key == "Enter" || e.Key == "Tab") &&
            sugerenciasIdentificacion != null &&
            sugerenciasIdentificacion.Any())
        {
            var indice = indiceSugerenciaIdentificacionActiva >= 0 &&
                         indiceSugerenciaIdentificacionActiva < sugerenciasIdentificacion.Count
                ? indiceSugerenciaIdentificacionActiva
                : 0;
            await SeleccionarCliente(sugerenciasIdentificacion[indice]);
        }
    }

    private async Task OnKeyDownBusquedaNombre(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowDown")
        {
            if (sugerencias == null || !sugerencias.Any())
            {
                await ToggleSugerenciasClientesAsync();
                indiceSugerenciaClienteActiva = ObtenerIndiceInicial(sugerencias);
                return;
            }

            indiceSugerenciaClienteActiva = MoverIndiceCircular(indiceSugerenciaClienteActiva, 1, sugerencias.Count);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            if (sugerencias == null || !sugerencias.Any())
            {
                await ToggleSugerenciasClientesAsync();
                indiceSugerenciaClienteActiva = sugerencias?.Count > 0 ? sugerencias.Count - 1 : -1;
                return;
            }

            indiceSugerenciaClienteActiva = MoverIndiceCircular(indiceSugerenciaClienteActiva, -1, sugerencias.Count);
            return;
        }

        if (e.Key == "Escape")
        {
            sugerencias = null;
            indiceSugerenciaClienteActiva = -1;
            return;
        }

        if ((e.Key == "Enter" || e.Key == "Tab") &&
            sugerencias != null &&
            sugerencias.Any())
        {
            var indice = indiceSugerenciaClienteActiva >= 0 &&
                         indiceSugerenciaClienteActiva < sugerencias.Count
                ? indiceSugerenciaClienteActiva
                : 0;
            await SeleccionarCliente(sugerencias[indice]);
        }
    }

    private async Task SeleccionarCliente(Simetric.Models.Cliente c)
    {
        seleccionandoClienteDesdeLista = false;
        cliente = c;
        clienteDetectadoEnCatalogoFactura = true;
        continuarConClienteSinRegistro = false;
        textoBusqueda = string.Empty;
        indiceSugerenciaClienteActiva = -1;
        indiceSugerenciaIdentificacionActiva = -1;

        if (facturaEsCredito)
        {
            if (factura.Tiempocredito == null || factura.Tiempocredito <= 0)
            {
                factura.Tiempocredito = c.DiasCredito;
            }
        }
        else
        {
            factura.Tiempocredito = null;
        }

        sugerencias = null;
        sugerenciasIdentificacion = null;

        await CargarCorreosOpcionalesClienteAsync();
        await CargarProductosFrecuentesClienteAsync();

        await InvokeAsync(StateHasChanged);

        if (cliente.Pais.HasValue && cliente.Pais > 0)
        {
            listaProvincias = await FacturacionService.GetProvinciasByPaisAsync(cliente.Pais.Value);

            if (cliente.Provincia.HasValue && cliente.Provincia > 0)
                listaCiudades = await FacturacionService.GetCiudadesByProvinciaAsync(cliente.Provincia.Value);
        }
    }

