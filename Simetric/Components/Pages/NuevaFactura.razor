        sugerencias = await FacturacionService.BuscarClientesFiltroAsync(currentUserId, textoBusqueda ?? string.Empty);
        indiceSugerenciaClienteActiva = ObtenerIndiceInicial(sugerencias);
        await InvokeAsync(StateHasChanged);
