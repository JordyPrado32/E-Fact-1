                                        <button type="button"
                                                class="n-choice-btn @(string.Equals(productoModal.TipoCompravena, "SERVICIO", StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)"
                                                @onclick="SeleccionarTipoServicioModal">
