                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => productoModal.TipoCompravena)" class="text-danger small d-block mt-2" />
                                </div>

                                <div class="col-md-8">
                                    <label class="n-label">Nombre *</label>
                                    <div class="n-field-shell">
                                        <InputText class="n-input" @bind-Value="productoModal.Nombre" placeholder="Nombre del producto o servicio" />
                                    </div>
                                    <ValidationMessage For="@(() => productoModal.Nombre)" class="text-danger small" />
                                </div>

                                <div class="col-md-4">
                                    <label class="n-label">Codigo *</label>
                                    <div class="n-field-shell">
                                        <InputText class="n-input" @bind-Value="productoModal.CodigoPrincipal" placeholder="10001" />
                                    </div>
                                    <ValidationMessage For="@(() => productoModal.CodigoPrincipal)" class="text-danger small" />
                                </div>

                                <div class="col-12">
                                    <label class="n-label">Codigo auxiliar</label>
                                    <div class="n-field-shell">
                                        <InputText class="n-input" @bind-Value="productoModal.CodAuxiliar" placeholder="Opcional" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label class="n-label">Categoria *</label>
                                    <div class="n-field-shell n-field-shell-select">
                                        <InputSelect class="n-select" @bind-Value="CategoriaProductoModalSeleccionada">
                                            <option value="">-- Seleccione --</option>
                                            @foreach (var t in modalTipos)
                                            {
                                                <option value="@t.Idtipoproducto">@t.Descripcion</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <ValidationMessage For="@(() => productoModal.TipoProducto)" class="text-danger small" />
                                </div>

                                <div class="col-md-6">
                                    <label class="n-label">Subcategoria (opcional)</label>
                                    <div class="n-field-shell n-field-shell-select">
                                        <InputSelect class="n-select"
                                                     @bind-Value="productoModal.Idsubtipo"
                                                     disabled="@(!productoModal.TipoProducto.HasValue || productoModal.TipoProducto <= 0)">
                                            <option value="">@(productoModal.TipoProducto.HasValue && productoModal.TipoProducto > 0 ? "-- Seleccione --" : "-- Seleccione una categoria primero --")</option>
                                            @foreach (var s in SubtiposFiltradosModal)
                                            {
                                                <option value="@s.Idsubtipo">@s.Descripcion</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>

                            </div>
                        </section>

                        <aside class="n-modal-side">
                            <section class="n-modal-side-card">
                                <div class="n-modal-card-head">
                                    <div class="n-modal-section-title">
                                        <span class="n-modal-section-icon">
                                            <i class="bi bi-sliders2"></i>
                                        </span>
                                        <div class="n-modal-card-h">Configuracion comercial</div>
                                    </div>
                                </div>

                                <div class="row g-3 n-modal-side-grid">
                                    <div class="col-12">
                                        <label class="n-label">Precios</label>
                                        <div class="n-product-price-stack">
                                            <div class="n-product-price-field">
                                                <div class="n-product-price-head">
                                                    <span class="n-label mb-0">Precio base *</span>
                                                    @if (PuedeAgregarCampoPrecioProductoModal)
                                                    {
                                                        <button type="button"
                                                                class="n-inline-icon-btn"
                                                                @onclick="AgregarCampoPrecioProductoModal"
                                                                title="Agregar precio adicional"
                                                                aria-label="Agregar precio adicional">
                                                            <i class="bi bi-plus-lg"></i>
                                                        </button>
                                                    }
                                                </div>
                                                <div class="n-field-shell n-field-shell-money">
                                                    <div class="n-money">
                                                        <span class="n-money-sim">$</span>
                                                        <InputNumber class="n-input text-end n-money-input" @bind-Value="productoModal.ValorUnitario" placeholder="0.00" />
                                                    </div>
                                                </div>
                                                <ValidationMessage For="@(() => productoModal.ValorUnitario)" class="text-danger small" />
                                            </div>

                                            @if (MostrarPrecioProductoModal2)
                                            {
                                                <div class="n-product-price-field n-product-price-field-secondary">
                                                    <div class="n-product-price-head">
                                                        <span class="n-label mb-0">Precio 2 (opcional)</span>
                                                        <button type="button"
                                                                class="n-inline-icon-btn n-inline-icon-btn-danger"
                                                                @onclick="() => EliminarCampoPrecioProductoModal(2)"
                                                                title="Eliminar precio 2"
                                                                aria-label="Eliminar precio 2">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                    <div class="n-field-shell n-field-shell-money">
                                                        <div class="n-money">
                                                            <span class="n-money-sim">$</span>
                                                            <InputNumber class="n-input text-end n-money-input" @bind-Value="productoModal.Precio2" placeholder="0.00" />
                                                        </div>
                                                    </div>
                                                    <ValidationMessage For="@(() => productoModal.Precio2)" class="text-danger small" />
                                                </div>
                                            }

                                            @if (MostrarPrecioProductoModal3)
                                            {
                                                <div class="n-product-price-field n-product-price-field-secondary">
                                                    <div class="n-product-price-head">
                                                        <span class="n-label mb-0">Precio 3 (opcional)</span>
                                                        <button type="button"
                                                                class="n-inline-icon-btn n-inline-icon-btn-danger"
                                                                @onclick="() => EliminarCampoPrecioProductoModal(3)"
                                                                title="Eliminar precio 3"
                                                                aria-label="Eliminar precio 3">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>
                                                    <div class="n-field-shell n-field-shell-money">
                                                        <div class="n-money">
                                                            <span class="n-money-sim">$</span>
                                                            <InputNumber class="n-input text-end n-money-input" @bind-Value="productoModal.Precio3" placeholder="0.00" />
                                                        </div>
                                                    </div>
                                                    <ValidationMessage For="@(() => productoModal.Precio3)" class="text-danger small" />
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="n-tax-box">
                                            <label class="n-label">IVA</label>
                                            <div class="n-field-shell n-field-shell-select">
                                                <InputSelect class="n-select"
                                                             @bind-Value="TarifaIvaProductoModal">
                                                    <option value="">Sin IVA</option>
                                                    @foreach (var iva in modalIvas)
                                                    {
                                                        <option value="@iva.Codigo">@ObtenerEtiquetaIvaModal(iva)</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                            <small class="text-muted d-block mt-2">
                                                Elige la tarifa desde el catálogo de IVA.
                                            </small>
                                            <ValidationMessage For="@(() => productoModal.Porcentajeimpuesto)" class="text-danger small" />
                                        </div>
                                    </div>

                                </div>
                            </section>
                        </aside>
                    </div>
                </div>

                <div class="n-modal-footer n-product-create-footer">
                    <div class="n-modal-footer-note n-product-create-note">
                        <i class="bi bi-lightning-charge"></i>
                        <span>Al guardar, el producto se buscara automaticamente por su codigo principal.</span>
                    </div>
                    <div class="n-modal-footer-actions">
                        <button type="button" class="n-btn-link" @onclick="CerrarModalProducto" disabled="@guardandoProductoModal">
                            Cancelar
                        </button>
                        <button type="submit" class="n-btn-primary" disabled="@guardandoProductoModal">
                            @if (guardandoProductoModal)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <i class="bi bi-check2-circle"></i>
                                <span>Guardar y usar</span>
                            }
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (mostrarHistorialCliente)
{
    <div class="n-product-modal-backdrop" @onclick="CerrarHistorialClienteAsync"></div>
    <div class="n-product-modal-shell" role="dialog" aria-modal="true" aria-labelledby="historialClienteModalTitulo">
        <div class="n-modal n-product-modal-content n-history-modal-content">
            <div class="n-modal-header">
                <div class="n-modal-header-main">
                    <div class="n-modal-copy">
                        <div class="n-modal-kicker">Historial del cliente</div>
                        <div id="historialClienteModalTitulo" class="n-modal-title">Facturas emitidas</div>
                        <div class="n-modal-subtitle">
                            @NombreClienteHistorial
                            @if (!string.IsNullOrWhiteSpace(cliente.Numeroidentificacion))
                            {
                                <span class="n-history-subtitle-id">| @cliente.Numeroidentificacion</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="n-modal-header-side">
                    <div class="n-modal-header-chips">
                        <span class="n-modal-head-chip">@historialFacturasCliente.Count factura(s)</span>
                    </div>
                    <button type="button" class="n-modal-close" @onclick="CerrarHistorialClienteAsync" aria-label="Cerrar historial">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <div class="n-modal-body">
                @if (!string.IsNullOrWhiteSpace(mensajeHistorialCliente))
                {
                    <div class="n-alert @(historialClienteConError ? "n-alert-danger" : "n-alert-info")">
                        <i class="bi @(historialClienteConError ? "bi-exclamation-octagon" : "bi-info-circle")"></i>
                        <span>@mensajeHistorialCliente</span>
                    </div>
                }

                @if (cargandoHistorialCliente)
                {
                    <div class="n-history-loading">
                        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
                        <span>Cargando historial de facturas...</span>
                    </div>
                }
                else if (historialFacturasCliente.Any())
                {
                    <div class="n-table-container n-history-table">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="n-table-header">
                                    <tr>
                                        <th>Factura</th>
                                        <th>Cliente</th>
                                        <th>Identificación</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-end">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in historialFacturasCliente)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@item.Numfactura</td>
                                            <td>@(string.IsNullOrWhiteSpace(item.Cliente) ? NombreClienteHistorial : item.Cliente)</td>
                                            <td>@item.IdentificacionCliente</td>
                                            <td class="text-end fw-semibold">$ @((item.Total ?? 0m).ToString("N2"))</td>
                                            <td class="text-end">
                                                <button type="button"
                                                        class="n-history-action-btn"
                                                        @onclick="() => VerFacturaHistorialAsync(item.Codfactura)">
                                                    <i class="bi bi-eye"></i>
                                                    <span>Ver</span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (!historialClienteConError)
                {
                    <div class="n-history-empty">
                        <i class="bi bi-receipt-cutoff"></i>
                        <div>
                            <strong>No hay facturas registradas para este cliente.</strong>
                            <span>Cuando el cliente tenga documentos emitidos, aparecerán en este historial.</span>
                        </div>
                    </div>
                }
            </div>

            <div class="n-modal-footer">
                <div class="n-modal-footer-note">
                    <i class="bi bi-shield-check"></i>
                    <span>Se listan las facturas asociadas a la identificación del cliente seleccionado.</span>
                </div>
                <div class="n-modal-footer-actions">
                    <button type="button" class="n-btn-link" @onclick="CerrarHistorialClienteAsync">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarVistaFacturaHistorial)
{
