@page "/facturacion/nueva"
@page "/demo/facturas/nueva"
@using Simetric.DTOs
@using Simetric.Models
@using Simetric.Services
@using Simetric.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.Text.RegularExpressions
@using System.Net.Http.Json
@using System.Globalization
@using System.Text
@using System.Text.Json
@using Simetric.Models.Glogales
@implements IAsyncDisposable

@inject IdentificacionService IdentificacionService
@inject AuthenticationStateProvider AuthStateProvider
@inject FacturacionService FacturacionService
@inject IFacturaPdfService FacturaPdfService
@inject GuiaRemisionService GuiaRemisionService
@inject SweetAlertService AlertService
@inject IJSRuntime JS
@inject HttpClient Http
@inject EmisionControlService EmisionControlService
@inject NavigationManager NavigationManager
@inject DemoCatalogService DemoCatalogService
@attribute [AllowAnonymous]

<PageTitle>Nueva Factura | Numerica e-fact</PageTitle>

<div class="container-fluid py-3 px-3 px-md-4 bg-light-modern docs-unified-page" data-tour="invoice.page">
    <DocumentoEmisionToast Message="@mensajeRapidoEmision"
                           IsError="@mensajeRapidoEsError"
                           PdfUrl="@documentoGeneradoPdfUrl"
                           OnOpenPdf="AbrirDocumentoGeneradoAsync" />

    <EditForm Model="@factura" OnValidSubmit="ProcesarGuardado">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger mb-3" />

        <InitialSequenceModal Visible="@mostrarModalSecuenciaInicial"
                              Title="Configuración inicial de secuencia"
                              Description="Antes de emitir tu primera factura en este sistema, indícanos si ya habías generado facturas anteriormente."
                              QuestionLabel="¿Ya habías generado facturas antes?"
                              SequenceLabel="Ingresa la secuencia donde te quedaste"
                              SequencePlaceholder="Ej: 000000125"
                              SequenceHint="Si te quedaste en la 125, la siguiente será la 126."
                              HadPreviousDocuments="@usuarioYaFacturoAntes"
                              HadPreviousDocumentsChanged="OnCambioRespuestaSecuencia"
                              PreviousSequence="@secuenciaAnteriorManual"
                              PreviousSequenceChanged="OnSecuenciaAnteriorManualChanged"
                              ErrorMessage="@errorSecuenciaInicial"
                              OnDismiss="CerrarModalSecuenciaInicial"
                              OnConfirm="ConfirmarSecuenciaInicialAsync" />

        @if (sinCaja)
        {
            <div class="alert alert-warning border-0 rounded-3 mb-3" style="position: sticky; top: 12px; z-index: 1050;">
                <strong>No puedes facturar.</strong> Tu usuario no tiene una caja/serie activa.
            </div>
        }
        else if (isDemoMode)
        {
            <div class="alert alert-info border-0 rounded-3 mb-3" style="position: sticky; top: 12px; z-index: 1050;">
                <strong>Modo demo.</strong> Esta factura usa datos de ejemplo y la emision esta bloqueada para invitados.
            </div>
        }

        <section class="docs-form-hero" data-tour="invoice.hero">
            <div class="docs-form-hero-body">
                <div class="docs-form-hero-copy invoice-heading-card">
                    <div class="invoice-heading-head">
                        <span class="invoice-heading-icon"><i class="bi bi-receipt-cutoff"></i></span>
                        <span class="docs-form-kicker">Documento de venta</span>
                    </div>
                    <h2 class="docs-form-title">Nueva factura</h2>
                    <p class="docs-form-text">
                        Completa cliente, detalle y cobro con una vista mas ordenada y con acceso directo
                        al historial sin salir de esta pantalla.
                    </p>
                    <div class="invoice-heading-meter"><span></span></div>

                </div>

                <div class="docs-form-toolbar">
                    <div class="n-invoice-id-strip" aria-label="Identificadores de factura">
                        <div class="n-invoice-id-pill">
                            <span>Serie</span>
                            @if (seriesFactura.Count > 1)
                            {
                                <select class="n-invoice-serie-select"
                                        value="@factura.Serie"
                                        @onchange="OnSerieFacturaChanged"
                                        disabled="@sinCaja"
                                        aria-label="Seleccionar serie de factura">
                                    @foreach (var serie in seriesFactura)
                                    {
                                        <option value="@serie.SerieRaw">
                                            @serie.SerieVisual
                                        </option>
                                    }
                                </select>
                            }
                            else
                            {
                                <strong>@serieVisual</strong>
                            }
                        </div>
                        <div class="n-invoice-id-pill">
                            <span>Numero de factura</span>
                            <strong>@factura.Numfactura</strong>
                        </div>
                    </div>

                    <button type="button" class="n-btn n-btn-secondary" @onclick="AbrirHistorialFacturasGeneralAsync">
                        <i class="bi bi-clock-history me-2"></i> Historial
                    </button>

                    <button type="button" class="n-btn n-btn-secondary" @onclick="LimpiarFormulario">
                        <i class="bi bi-arrow-clockwise me-2"></i> Limpiar pantalla
                    </button>

                </div>
            </div>
        </section>

        <section class="n-client-search-strip" data-tour="invoice.client-search">
            <div class="n-client-search-strip-copy">
                <span class="n-client-search-eyebrow">Buscador de cliente</span>
                <strong>Encuentra o completa el cliente de la factura</strong>
            </div>

            <div class="n-client-search-input position-relative">
                <div class="n-input-wrapper">
                    <i class="bi bi-search n-input-icon"></i>
                    <input type="text" class="n-input n-input-with-icon n-input-with-toggle"
                           value="@textoBusqueda"
                           @oninput="OnInputBusqueda"
                           @onfocus="MostrarSugerenciasClientesAsync"
                           @onkeydown="OnKeyDownBusquedaNombre"
                           @onblur="OnBlurBusqueda"
                           placeholder="Buscar por identificacion, nombres, apellidos o razon social"
                           autocomplete="off" />
                    <button type="button"
                            class="n-input-toggle-btn"
                            @onclick="ToggleSugerenciasClientesAsync"
                            aria-label="Mostrar sugerencias de cliente">
                        <i class="bi @((sugerencias != null && sugerencias.Any()) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                </div>
                @if (sugerencias != null && sugerencias.Any())
                {
                    <ul class="n-suggestions">
                        @for (var i = 0; i < sugerencias.Count; i++)
                        {
                            var c = sugerencias[i];
                            <li @onmousedown="PrepararSeleccionCliente"
                                class="@(indiceSugerenciaClienteActiva == i ? "is-active" : null)"
                                @onclick="() => SeleccionarCliente(c)">
                                <strong>@ObtenerNombreClienteVisual(c)</strong><br />
                                <small>@c.Numeroidentificacion @ObtenerBadgeNotificacionCliente(c)</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </section>

        @if (ClienteIngresadoSinRegistro)
        {
            <div class="n-client-create-notice n-client-create-notice-inline @(continuarConClienteSinRegistro ? "is-continued" : "")">
                <span class="n-client-create-icon">
                    <i class="bi bi-person-plus"></i>
                </span>
                <div>
                    <strong>Cliente no registrado</strong>
                    <small>@(continuarConClienteSinRegistro
                        ? "Continuaras con los datos ingresados para esta factura."
                        : "Puedes agregarlo al catalogo ahora o continuar con los datos indispensables de la factura.")</small>
                </div>
                <div class="n-client-create-actions">
                    <button type="button"
                            class="n-client-create-check"
                            @onclick="AbrirCrudClientesFacturaAsync">
                        <i class="bi bi-person-plus"></i>
                        <span>Agregar ahora</span>
                    </button>
                    <button type="button"
                            class="n-client-continue-check @(continuarConClienteSinRegistro ? "is-active" : "")"
                            @onclick="ContinuarConClienteSinRegistro">
                        <i class="bi @(continuarConClienteSinRegistro ? "bi-x-circle" : "bi-arrow-right-circle")"></i>
                        <span>@(continuarConClienteSinRegistro ? "Desmarcar" : "Continuar")</span>
                    </button>
                </div>
            </div>
        }

        @* =======================================================
            SECCIÓN CLIENTE
        ======================================================= *@
        <div class="n-card mb-4" data-tour="invoice.client-section">
            <div class="n-card-header">
                <h5><i class="bi bi-person-vcard me-2"></i> Información del Cliente</h5>
                <small class="d-none d-sm-flex"><i class="bi bi-arrow-repeat me-1"></i> Los datos se actualizarán automáticamente</small>
            </div>

            <div class="n-card-body n-client-card-body">
                <div class="row g-3 n-client-block n-client-search-block">
                    <div class="col-12">
                        <label class="n-label n-client-search-label">
                            <i class="bi bi-search"></i>
                            Buscar cliente
                        </label>
                        <div class="n-client-search-layout">
                            <div class="n-client-search-input position-relative">
                                <div class="n-input-wrapper">
                                    <i class="bi bi-search n-input-icon"></i>
                                    <input type="text" class="n-input n-input-with-icon n-input-with-toggle"
                                           value="@textoBusqueda"
                                           @oninput="OnInputBusqueda"
                                           @onfocus="MostrarSugerenciasClientesAsync"
                                           @onkeydown="OnKeyDownBusquedaNombre"
                                           @onblur="OnBlurBusqueda"
                                           placeholder="Buscar por identificación, nombres, apellidos o razón social"
                                           autocomplete="off" />
                                    <button type="button"
                                            class="n-input-toggle-btn"
                                            @onclick="ToggleSugerenciasClientesAsync"
                                            aria-label="Mostrar sugerencias de cliente">
                                        <i class="bi @((sugerencias != null && sugerencias.Any()) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                    </button>
                                </div>
                                @if (sugerencias != null && sugerencias.Any())
                                {
                                    <ul class="n-suggestions">
                                        @for (var i = 0; i < sugerencias.Count; i++)
                                        {
                                            var c = sugerencias[i];
                                            <li @onmousedown="PrepararSeleccionCliente"
                                                class="@(indiceSugerenciaClienteActiva == i ? "is-active" : null)"
                                                @onclick="() => SeleccionarCliente(c)">
                                                <strong>@ObtenerNombreClienteVisual(c)</strong><br />
                                                <small>@c.Numeroidentificacion @ObtenerBadgeNotificacionCliente(c)</small>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 n-client-block n-client-main-grid">
                    <div class="col-lg-3 col-md-6">
                        <label class="n-label">Tipo Identificación</label>
                        <div class="n-select-shell">
                            <select class="n-select" @bind="cliente.Tipoidentificacion">
                                <option value="">-- Seleccione --</option>
                                @foreach (var it in identificaciones)
                                {
                                    <option value="@it.IdeCodigo">@it.IdeDescripcion</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6 position-relative">
                        <label class="n-label">Numero de identificacion</label>
                        <div class="n-input-wrapper">
                            <i class="bi bi-person-badge n-input-icon"></i>
                            <input type="text"
                                   class="n-input n-input-with-icon n-input-with-toggle"
                                   value="@cliente.Numeroidentificacion"
                                   @oninput="OnInputBusquedaIdentificacion"
                                   @onblur="OnBlurIdentificacion"
                                   @onkeydown="OnKeyDownBusquedaIdentificacion"
                                   placeholder="Cedula o RUC"
                                   autocomplete="off" />
                            <button type="button"
                                    class="n-input-toggle-btn"
                                    @onclick="ToggleSugerenciasIdentificacionAsync"
                                    aria-label="Mostrar sugerencias por identificación">
                                <i class="bi @((sugerenciasIdentificacion != null && sugerenciasIdentificacion.Any()) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </button>
                        </div>
                        @if (sugerenciasIdentificacion != null && sugerenciasIdentificacion.Any())
                        {
                            <ul class="n-suggestions">
                                @for (var i = 0; i < sugerenciasIdentificacion.Count; i++)
                                {
                                    var c = sugerenciasIdentificacion[i];
                                    <li @onmousedown="PrepararSeleccionCliente"
                                        class="@(indiceSugerenciaIdentificacionActiva == i ? "is-active" : null)"
                                        @onclick="() => SeleccionarCliente(c)">
                                        <strong>@ObtenerNombreClienteVisual(c)</strong><br />
                                        <small>@c.Numeroidentificacion @ObtenerBadgeNotificacionCliente(c)</small>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <label class="n-label">Tipo Cliente</label>
                        <div class="n-select-shell">
                            <select class="n-select"
                                    @bind="cliente.TipoCliente"
                                    @bind:after="OnTipoClienteFacturaChanged">
                                <option value="">-- Seleccione --</option>
                                @foreach (var tc in tiposCliente)
                                {
                                    <option value="@tc.TclCodigo">@GetTipoClienteEtiqueta(tc.TclDescripcion)</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (EsPersonaPorTipoCliente())
                    {
                        <div class="col-lg-3 col-md-6">
                            <label class="n-label">Nombres</label>
                            <input type="text"
                                   class="n-input"
                                   @bind="cliente.Nombres"
                                   @onblur="@(e => SincronizarNombres())"
                                   oninput="this.value = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]/g, '');" />
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="n-label">Apellidos</label>
                            <input type="text"
                                   class="n-input"
                                   @bind="cliente.Apellidos"
                                   @onblur="@(e => SincronizarNombres())"
                                   oninput="this.value = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]/g, '');" />
                        </div>
                    }

                    @if (EsEmpresaPorTipoCliente())
                    {
                        <div class="col-lg-3 col-md-6">
                            <label class="n-label">Nombre Comercial</label>
                            <input type="text" class="n-input" @bind="cliente.Nombrecomercial" @bind:event="oninput" maxlength="100" />
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="n-label">Razón Social</label>
                            <input type="text" class="n-input" @bind="cliente.Nombrerazonsocial" @bind:event="oninput" maxlength="100" />
                        </div>
                    }
                </div>

                <div class="n-client-block n-client-contact-modern">
                    <div class="n-contact-field">
                        <label class="n-label">Direccion (Max 100)</label>
                        <div class="n-input-wrapper">
                            <i class="bi bi-geo-alt n-input-icon"></i>
                            <input type="text"
                                   class="n-input n-input-with-icon"
                                   @bind="cliente.Direccion"
                                   @bind:event="oninput"
                                   maxlength="100"
                                   placeholder="Av. Principal y Calle Secundaria..." />
                        </div>

                        <div class="n-payment-card n-payment-card-inline" data-tour="invoice.payment-section">
                            <div class="n-card-body">
                                <div class="n-payment-layout">
                                    <div class="n-payment-copy">
                                        <span class="n-payment-kicker">Cierre de cobro</span>
                                        <h6>Forma de pago del comprobante</h6>
                                        <p>
                                            Selecciona como se registra esta factura ante el SRI.
                                        </p>
                                    </div>

                                    <div class="n-payment-control">
                                        <label class="n-label">
                                            <i class="bi bi-credit-card me-2"></i>Forma de pago (SRI)
                                        </label>
                                        <select @bind="formaPagoSeleccionada" @bind:after="OnPaymentMethodChanged" class="n-select n-payment-select">
                                            @if (!FormasPagoVisibles.Any())
                                            {
                                                <option value="">Cargando formas de pago...</option>
                                            }
                                            else
                                            {
                                                <option value="">-- Seleccione --</option>
                                                @foreach (var fp in FormasPagoVisibles)
                                                {
                                                    <option value="@fp.Codigo">@GetFormaPagoNombre(fp)</option>
                                                }
                                            }
                                        </select>

                                        <div class="mt-2">
                                            <label class="n-label d-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       class="form-check-input mt-0"
                                                       @bind="facturaEsCredito"
                                                       @bind:after="OnCreditoFacturaChanged" />
                                                <span>Es una factura a crédito</span>
                                            </label>
                                        </div>

                                        @if (facturaEsCredito)
                                        {
                                            <div class="mt-2">
                                                <label class="n-label">
                                                    <i class="bi bi-calendar3 me-2"></i>Días de crédito
                                                </label>
                                                <input type="number" @bind="factura.Tiempocredito" class="n-input" min="0" placeholder="Ej. 30" />
                                                <small class="text-muted d-block mt-1">
                                                    @(cliente?.DiasCredito is > 0
                                                        ? $"Este cliente tiene asignado {cliente.DiasCredito} día(s). Si no cambias el valor, se usa ese plazo por defecto."
                                                        : "Puedes definir aquí el plazo de crédito para esta factura.")
                                                </small>
                                            </div>
                                        }

                                        @if (false && formaPagoSeleccionada == "19")
                                        {
                                            <div class="mt-2">
                                                <label class="n-label">
                                                    <i class="bi bi-calendar3 me-2"></i>Días de crédito
                                                </label>
                                                <input type="number" @bind="factura.Tiempocredito" class="n-input" min="0" placeholder="Ej. 30" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="n-contact-field n-contact-phone-field">
                        <label class="n-label">Telefono (Opcional)</label>
                        <div class="n-input-wrapper">
                            <i class="bi bi-phone n-input-icon"></i>
                            <input type="text"
                                   class="n-input n-input-with-icon"
                                   @bind="cliente.Celular"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                                   maxlength="10"
                                   placeholder="0991234567" />
                        </div>
                    </div>

                    <div class="n-contact-field n-email-main-field">
                        <div class="n-email-main-head">
                            <label class="n-label mb-0">Correo electronico principal</label>
                        </div>

                        <div class="n-email-primary-row">
                            <div class="n-input-wrapper">
                                <i class="bi bi-envelope n-input-icon"></i>
                                <input type="email"
                                       class="n-input n-input-with-icon"
                                       @bind="cliente.Correo"
                                       @bind:event="oninput"
                                       placeholder="cliente@ejemplo.com" />
                            </div>

                            <button type="button"
                                    class="n-email-add-btn"
                                    title="Agregar correo adicional"
                                    @onclick="AgregarCorreoOpcionalFactura"
                                    disabled="@(correosOpcionalesFactura.Count >= MaxCorreosOpcionalesFactura)">
                                <i class="bi bi-envelope-plus"></i>
                                <span>Agregar correo</span>
                            </button>
                        </div>

                        @if (correosOpcionalesFactura.Any())
                        {
                            <div class="n-additional-email-area">
                                <label class="n-label">Correos adicionales</label>
                                <div class="n-email-chip-grid">
                                    @for (int i = 0; i < correosOpcionalesFactura.Count; i++)
                                    {
                                        var index = i;
                                        <div class="n-email-chip-field">
                                            <input type="email"
                                                   class="n-email-chip-input"
                                                   @bind="correosOpcionalesFactura[index].Correo"
                                                   @bind:event="oninput"
                                                   placeholder="correo@ejemplo.com" />
                                            <button type="button"
                                                    class="n-email-chip-remove"
                                                    title="Quitar correo"
                                                    @onclick="() => EliminarCorreoOpcionalFactura(index)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                            @if (correosOpcionalesFactura[index].EsPersistidoCliente)
                                            {
                                                <span class="n-email-chip-note">Guardado</span>
                                            }
                                            else
                                            {
                                                <label class="n-email-save-mini" for="@($"guardar-correo-factura-modern-{index}")">
                                                    <input type="checkbox"
                                                           id="@($"guardar-correo-factura-modern-{index}")"
                                                           @bind="correosOpcionalesFactura[index].GuardarEnCliente" />
                                                    Guardar
                                                </label>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                    </div>

                    <div class="n-contact-reference">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <label class="n-label mb-0">Referencia (Max 100 palabras)</label>
                            <span class="n-word-count">Palabras: @ContarPalabras(cliente.Referencia) / 100</span>
                        </div>
                        <textarea class="n-textarea"
                                  rows="2"
                                  @bind="cliente.Referencia"
                                  @bind:event="oninput"
                                  placeholder="Ingrese notas adicionales sobre el cliente aqui..."></textarea>
                    </div>
                </div>

                <div class="row g-3 n-client-block n-contact-email-grid">
                    <div class="col-xl-3 col-lg-6">
                        <label class="n-label">Celular </label>
                        <div class="n-input-wrapper">
                            <i class="bi bi-phone n-input-icon"></i>
                            <input type="text"
                                   class="n-input n-input-with-icon"
                                   @bind="cliente.Celular"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                                   maxlength="10"
                                   placeholder="0991234567" />
                        </div>
                    </div>

                    <div class="col-xl-3 col-lg-6">
                        <label class="n-label">Correo Electrónico</label>
                        <div class="n-input-wrapper">
                            <i class="bi bi-envelope n-input-icon"></i>
                            <input type="email"
                                   class="n-input n-input-with-icon"
                                   @bind="cliente.Correo"
                                   @bind:event="oninput"
                                   placeholder="cliente@ejemplo.com" />
                        </div>
                    </div>

                    <div class="col-xl-6">
                        <div class="n-section n-email-section">
                            <div class="n-email-header">
                                <div>
                                    <label class="n-label mb-1">Correos adicionales</label>
                                    <p class="n-email-helper mb-0">
                                        También reciben esta factura.
                                    </p>
                                </div>
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm"
                                        @onclick="AgregarCorreoOpcionalFactura"
                                        disabled="@(correosOpcionalesFactura.Count >= MaxCorreosOpcionalesFactura)">
                                    <i class="bi bi-envelope-plus me-1"></i>Agregar correo adicional
                                </button>
                            </div>

                            @if (correosOpcionalesFactura.Any())
                            {
                                @for (int i = 0; i < correosOpcionalesFactura.Count; i++)
                                {
                                    var index = i;
                                    <div class="n-email-row">
                                        <div class="row g-3 align-items-end">
                                            <div class="col-12">
                                                <label class="n-label">Correo @(index + 1)</label>
                                                <div class="n-input-wrapper">
                                                    <i class="bi bi-envelope-paper n-input-icon"></i>
                                                    <input type="email"
                                                           class="n-input n-input-with-icon"
                                                           @bind="correosOpcionalesFactura[index].Correo"
                                                           placeholder="correo@ejemplo.com" />
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                @if (correosOpcionalesFactura[index].EsPersistidoCliente)
                                                {
                                                    <span class="n-email-pill">Guardado en cliente</span>
