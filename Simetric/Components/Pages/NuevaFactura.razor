                        ? (d.Codproducto > 0 ? d.Codproducto.ToString(CultureInfo.InvariantCulture) : "MANUAL")
                        : d.Codprincipal,
                    CodigoAdicional = d.Codauxiliar,
                    Descripcion = ConstruirDescripcionComprobante(d),
                    Cantidad = Math.Max(1, Convert.ToInt32(decimal.Truncate(d.Cantidad <= 0 ? 1 : d.Cantidad)))
                })
