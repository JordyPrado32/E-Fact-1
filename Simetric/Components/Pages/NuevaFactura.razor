            !string.IsNullOrWhiteSpace(seriePendienteModalRaw) &&
            !string.Equals(seriePendienteModalRaw, serieConfirmadaRaw, StringComparison.Ordinal))
        {
            SeleccionarSerieFacturaPersistida(serieConfirmadaRaw);
            seriePendienteModalRaw = null;
            await ActualizarNumeroFacturaParaSerieAsync();
        }
