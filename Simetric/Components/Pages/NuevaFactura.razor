    private class ProductoModalModel : IValidatableObject
    {
        [Required(ErrorMessage = "El nombre es requerido.")]
        [StringLength(120, ErrorMessage = "Máximo 120 caracteres.")]
        public string? Nombre { get; set; }

        [Required(ErrorMessage = "El código principal es requerido.")]
        [StringLength(50, ErrorMessage = "Máximo 50 caracteres.")]
        public string? CodigoPrincipal { get; set; }

        [StringLength(50, ErrorMessage = "Máximo 50 caracteres.")]
        public string? CodAuxiliar { get; set; }

        [Required(ErrorMessage = "El precio unitario es requerido.")]
        [Range(0.01, 999999, ErrorMessage = "Precio inválido.")]
        public decimal? ValorUnitario { get; set; }

        [Range(0, 999999, ErrorMessage = "Precio inválido.")]
        public decimal? Precio2 { get; set; }

        [Range(0, 999999, ErrorMessage = "Precio inválido.")]
        public decimal? Precio3 { get; set; }

        [Required(ErrorMessage = "Debe seleccionar si el registro es producto o servicio.")]
        public string? TipoCompravena { get; set; }

        public int? TipoProducto { get; set; }

        public int? Idsubtipo { get; set; }
        public string? Codigoimpuesto { get; set; }
        public string? Porcentajeimpuesto { get; set; }
        public bool Facturable { get; set; } = true;

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            Nombre = Nombre?.Trim();
            CodigoPrincipal = CodigoPrincipal?.Trim();
            CodAuxiliar = string.IsNullOrWhiteSpace(CodAuxiliar) ? null : CodAuxiliar.Trim();
            TipoCompravena = TipoCompravena?.Trim().ToUpperInvariant();
            Codigoimpuesto = Codigoimpuesto?.Trim();
            Porcentajeimpuesto = Porcentajeimpuesto?.Trim();

            if (string.IsNullOrWhiteSpace(TipoCompravena))
            {
                yield return new ValidationResult(
                    "Debe seleccionar si el registro es producto o servicio.",
                    new[] { nameof(TipoCompravena) });
            }
            else if (TipoCompravena != "PRODUCTO" && TipoCompravena != "SERVICIO")
            {
                yield return new ValidationResult(
                    "Debe elegir PRODUCTO o SERVICIO.",
                    new[] { nameof(TipoCompravena) });
            }

            if (!TipoProducto.HasValue)
            {
                yield return new ValidationResult(
                    "Debe seleccionar una categoría.",
                    new[] { nameof(TipoProducto) });
            }

            if (Idsubtipo.HasValue && !TipoProducto.HasValue)
            {
                yield return new ValidationResult(
                    "Debe seleccionar una categoría antes de elegir la subcategoría.",
                    new[] { nameof(Idsubtipo), nameof(TipoProducto) });
            }

            if (Precio2.HasValue && Precio2 < 0)
            {
                yield return new ValidationResult(
                    "El precio 2 no puede ser menor a 0.",
                    new[] { nameof(Precio2) });
            }

            if (Precio3.HasValue && Precio3 < 0)
            {
                yield return new ValidationResult(
                    "El precio 3 no puede ser menor a 0.",
                    new[] { nameof(Precio3) });
            }

            if (string.Equals(Codigoimpuesto, "2", StringComparison.OrdinalIgnoreCase) &&
                string.IsNullOrWhiteSpace(Porcentajeimpuesto))
            {
                yield return new ValidationResult(
                    "Debe seleccionar la tarifa IVA.",
                    new[] { nameof(Porcentajeimpuesto) });
            }
        }
    }

    // ===================== INICIALIZACIÓN =====================
    protected override async Task OnInitializedAsync()
    {
        InicializarModelos();
        EmisionControlService.Changed += OnEmisionChanged;
        isDemoMode = EsRutaDemoFactura();

        if (isDemoMode)
        {
            ConfigurarModoDemoFactura();
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaim = authState.User.FindFirst("IdUsuario")?.Value;
        currentUserId = int.TryParse(userClaim, out var id) ? id : 0;
        await CargarEstadoEmisionAsync();

        var lookupsTask = Http.GetFromJsonAsync<LookupsResponse>($"api/productos/lookups?userId={currentUserId}");
        var formasPagoTask = FacturacionService.ObtenerFormasPagoAsync();
        var emisoresTask = FacturacionService.GetEmisoresActivosAsync(currentUserId);
        var tiposClienteTask = FacturacionService.GetTiposClienteAsync();
        var paisesTask = FacturacionService.GetPaisesAsync();
        var identificacionesTask = IdentificacionService.GetAllActiveAsync();
        var cajaUsuarioTask = FacturacionService.GetCajaUsuarioAsync(currentUserId);
        var seriesFacturaTask = FacturacionService.GetSeriesFacturaHabilitadasAsync(currentUserId);
        var productosFrecuentesTask = FacturacionService.BuscarProductosFiltroAsync(currentUserId, string.Empty);

        await Task.WhenAll(
            formasPagoTask,
            emisoresTask,
            tiposClienteTask,
            paisesTask,
            identificacionesTask,
            cajaUsuarioTask,
            seriesFacturaTask,
            productosFrecuentesTask);

        formasPagoLista = await formasPagoTask;
        formaPagoSeleccionada = string.Empty;

        emisores = await emisoresTask;
        RestablecerEmisorSeleccionado();

        tiposCliente = await tiposClienteTask;
        listaPaises = await paisesTask;
        identificaciones = (await identificacionesTask)
            .Where(x =>
                !string.Equals((x.IdeCodigo ?? string.Empty).Trim(), "07", StringComparison.OrdinalIgnoreCase) &&
                !string.Equals((x.IdeDescripcion ?? string.Empty).Trim(), "CONSUMIDOR FINAL", StringComparison.OrdinalIgnoreCase))
            .ToList();

        codigoCedula = identificaciones
            .FirstOrDefault(x => (x.IdeDescripcion ?? "").Trim().ToUpper() == "CEDULA")
            ?.IdeCodigo ?? "05";

        codigoRuc = identificaciones
            .FirstOrDefault(x => (x.IdeDescripcion ?? "").Trim().ToUpper() == "RUC")
            ?.IdeCodigo ?? "04";

        cajaUsuario = await cajaUsuarioTask;
        seriesFactura = await seriesFacturaTask;
        sinCaja = !seriesFactura.Any();
        productosFrecuentesCatalogo = (await productosFrecuentesTask).Take(60).ToList();
        productosFrecuentesCliente = productosFrecuentesCatalogo.ToList();

        var lookups = await lookupsTask;
        if (lookups is not null)
        {
            modalIvas = lookups.Ivas ?? new();
        }

        if (!sinCaja)
        {
            var serieInicialRaw = await FacturacionService.GetSerieFacturaRawAsync(currentUserId);
            SeleccionarSerieFacturaPersistida(serieInicialRaw);
            await ActualizarNumeroFacturaParaSerieAsync();
