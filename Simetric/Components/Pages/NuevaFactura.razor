    private async Task AgregarDetalleDesdeLookup()
    {
        if (sinCaja)
        {
            await AlertService.ShowWarningAsync("Debes crear tu caja (serie) antes de facturar.");
            return;
        }

        msgDetalle = null;

        if (productoLookup == null)
        {
            await OnCodigoProductoBlur();
            if (productoLookup == null) return;
        }

        if (nuevoCantidad <= 0)
        {
            await AlertService.ShowWarningAsync("La cantidad debe ser mayor a 0.");
            return;
        }

        if (nuevoCantidad != decimal.Truncate(nuevoCantidad))
        {
            await AlertService.ShowWarningAsync("La cantidad debe ser un numero entero.");
            return;
        }

        if (nuevoPrecio <= 0)
        {
            await AlertService.ShowWarningAsync("El precio debe ser mayor a 0.");
            return;
        }

        if (nuevoPorcentajeDescuento < 0 || nuevoPorcentajeDescuento > 100)
        {
            await AlertService.ShowWarningAsync("El descuento debe estar entre 0 y 100.");
            return;
        }

        decimal subtotalBruto = nuevoCantidad * nuevoPrecio;
        decimal valorMonetarioDescuento = Math.Round(subtotalBruto * (nuevoPorcentajeDescuento / 100m), 2);

        var detalle = ObtenerFilaDisponibleParaProducto();
        CargarProductoEnDetalle(
            detalle,
            productoLookup,
            nuevoCantidad,
            nuevoPrecio,
            valorMonetarioDescuento,
            nuevoPorcentajeDescuento,
            ModoDescuento.Porcentaje);

        nuevoCodProducto = "";
        nuevoDescripcion = "";
        nuevoCantidad = 1;
        nuevoPrecio = 0;
        nuevoPorcentajeDescuento = 0;
        productoLookup = null;
        sugerenciasProductos = null;
        msgDetalle = null;
        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

    private void QuitarDetalle(int index)
    {
        if (index >= 0 && index < detallesDto.Count)
        {
            var detalle = detallesDto[index];
            detallesDto.RemoveAt(index);
            valoresTemporalesCantidad.Remove(detalle);
            valoresTemporalesPrecio.Remove(detalle);
            valoresTemporalesPorcentaje.Remove(detalle);
            valoresTemporalesDescuentoMoneda.Remove(detalle);
            modosDescuentoDetalle.Remove(detalle);
            AsegurarFilaVaciaDetalle();
            CalcularTotalesFactura();
            StateHasChanged();
        }
    }

