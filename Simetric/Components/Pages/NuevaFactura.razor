    private void AgregarCorreoOpcionalFactura()
    {
        NormalizarCorreosOpcionalesFactura();

        if (correosOpcionalesFactura.Count >= MaxCorreosOpcionalesFactura)
            return;

        correosOpcionalesFactura.Add(new CorreoOpcionalFacturaInput());
    }

    private void EliminarCorreoOpcionalFactura(int index)
    {
        if (index < 0 || index >= correosOpcionalesFactura.Count)
            return;

        var correoRemovido = correosOpcionalesFactura[index];
        correosOpcionalesFactura.RemoveAt(index);

        if (correoRemovido.EsPersistidoCliente)
        {
            correosPersistidosClienteFactura = correosPersistidosClienteFactura
                .Where(x =>
                    !string.Equals(
                        (x ?? string.Empty).Trim(),
                        (correoRemovido.CorreoOriginal ?? correoRemovido.Correo ?? string.Empty).Trim(),
                        StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void NormalizarCorreosOpcionalesFactura()
    {
        foreach (var correo in correosOpcionalesFactura)
            correo.Correo = (correo.Correo ?? string.Empty).Trim();
    }

    private List<FacturaCorreoDestinoDto> ObtenerCorreosOpcionalesFactura()
    {
        NormalizarCorreosOpcionalesFactura();

        return correosOpcionalesFactura
            .Where(x => !string.IsNullOrWhiteSpace(x.Correo))
            .Select(x => new FacturaCorreoDestinoDto
            {
                Correo = x.Correo,
                GuardarEnCliente = x.EsPersistidoCliente || x.GuardarEnCliente
            })
            .ToList();
    }

    private async Task CargarCorreosOpcionalesClienteAsync()
    {
        correosOpcionalesFactura = new();
        correosPersistidosClienteFactura = new();

        if (cliente.Codcliente <= 0)
            return;

        correosPersistidosClienteFactura = (await FacturacionService.GetCorreosAdicionalesClienteAsync(currentUserId, cliente.Codcliente))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(MaxCorreosOpcionalesFactura)
            .ToList();

        foreach (var correo in correosPersistidosClienteFactura)
        {
            correosOpcionalesFactura.Add(new CorreoOpcionalFacturaInput
            {
                Correo = correo,
                CorreoOriginal = correo,
                GuardarEnCliente = true,
                EsPersistidoCliente = true
            });
        }
    }

    private bool ClienteTieneDatosComplementarios()
    {
        return cliente.Codcliente > 0 ||
               cliente.TipoCliente.HasValue ||
               cliente.Pais.HasValue ||
               cliente.Provincia.HasValue ||
               cliente.Ciudad.HasValue ||
               !string.IsNullOrWhiteSpace(cliente.Nombres) ||
               !string.IsNullOrWhiteSpace(cliente.Apellidos) ||
               !string.IsNullOrWhiteSpace(cliente.Nombrerazonsocial) ||
               !string.IsNullOrWhiteSpace(cliente.Nombrecomercial) ||
               !string.IsNullOrWhiteSpace(cliente.Correo) ||
               !string.IsNullOrWhiteSpace(cliente.Celular) ||
               !string.IsNullOrWhiteSpace(cliente.Telefonoconvencional) ||
               !string.IsNullOrWhiteSpace(cliente.Direccion) ||
               !string.IsNullOrWhiteSpace(cliente.Observaciones) ||
               correosOpcionalesFactura.Any() ||
               correosPersistidosClienteFactura.Any();
    }

    private void LimpiarClienteFacturaParaNuevaBusqueda(string? identificacion = null)
    {
        var numero = new string((identificacion ?? string.Empty).Where(char.IsDigit).ToArray());

        cliente = new Simetric.Models.Cliente
        {
            Usuario = currentUserId,
            Estado = true,
            Numeroidentificacion = numero
        };

        if (numero.Length is 10 or 13)
        {
            cliente.Tipoidentificacion = InferirTipoIdentificacion(numero);
        }

        correosOpcionalesFactura = new();
        correosPersistidosClienteFactura = new();
        listaProvincias = new();
        listaCiudades = new();
        productosFrecuentesCliente = productosFrecuentesCatalogo.ToList();
        clienteDetectadoEnCatalogoFactura = false;
        continuarConClienteSinRegistro = false;
        facturaEsCredito = false;
        factura.Tiempocredito = null;
    }

    private async Task OnInputBusquedaIdentificacion(ChangeEventArgs e)
    {
        var identificacionAnterior = cliente.Numeroidentificacion;
        var val = e.Value?.ToString() ?? "";
        val = new string(val.Where(char.IsDigit).ToArray());

        if (!string.Equals(identificacionAnterior, val, StringComparison.Ordinal))
        {
            continuarConClienteSinRegistro = false;

            if (ClienteTieneDatosComplementarios())
            {
                LimpiarClienteFacturaParaNuevaBusqueda(val);
            }
        }

        if (cliente.Codcliente > 0 && !string.Equals(identificacionAnterior, val, StringComparison.Ordinal))
        {
            cliente.Codcliente = 0;
            correosOpcionalesFactura = new();
            correosPersistidosClienteFactura = new();
        }

        cliente.Numeroidentificacion = val;

        if (val.Length >= 1)
        {
            sugerenciasIdentificacion = await FacturacionService.BuscarClientesFiltroAsync(currentUserId, val);
            indiceSugerenciaIdentificacionActiva = ObtenerIndiceInicial(sugerenciasIdentificacion);
            clienteDetectadoEnCatalogoFactura = sugerenciasIdentificacion.Any(c =>
                string.Equals(c.Numeroidentificacion?.Trim(), val, StringComparison.Ordinal));
        }
        else
        {
            sugerenciasIdentificacion = null;
            indiceSugerenciaIdentificacionActiva = -1;
            clienteDetectadoEnCatalogoFactura = false;
        }
    }

    private async Task OnBlurIdentificacion()
    {
        await Task.Delay(200);

        if (seleccionandoClienteDesdeLista)
        {
            seleccionandoClienteDesdeLista = false;
            return;
        }

        sugerenciasIdentificacion = null;
        indiceSugerenciaIdentificacionActiva = -1;

        if (!string.IsNullOrWhiteSpace(cliente.Numeroidentificacion))
            cliente.Tipoidentificacion = InferirTipoIdentificacion(cliente.Numeroidentificacion);

        StateHasChanged();
    }

    private async Task OnInputBusqueda(ChangeEventArgs e)
    {
        var nuevoTextoBusqueda = e.Value?.ToString() ?? string.Empty;
        var digitosBusqueda = new string(nuevoTextoBusqueda.Where(char.IsDigit).ToArray());
        var identificacionClienteActual = cliente.Numeroidentificacion?.Trim() ?? string.Empty;
        var buscaOtroCliente = string.IsNullOrWhiteSpace(identificacionClienteActual) ||
                               string.IsNullOrWhiteSpace(digitosBusqueda) ||
                               !string.Equals(digitosBusqueda, identificacionClienteActual, StringComparison.Ordinal);

        if (!string.IsNullOrWhiteSpace(nuevoTextoBusqueda) && buscaOtroCliente && ClienteTieneDatosComplementarios())
        {
            LimpiarClienteFacturaParaNuevaBusqueda(digitosBusqueda);
        }

        textoBusqueda = nuevoTextoBusqueda;
        if (cliente.Codcliente > 0)
        {
            var textoClienteSeleccionado = $"{cliente.Numeroidentificacion} - {ObtenerNombreClienteVisual(cliente)}";
            if (!string.Equals(textoBusqueda.Trim(), textoClienteSeleccionado.Trim(), StringComparison.OrdinalIgnoreCase) &&
                !string.Equals(textoBusqueda.Trim(), (cliente.Numeroidentificacion ?? string.Empty).Trim(), StringComparison.OrdinalIgnoreCase))
            {
                LimpiarClienteFacturaParaNuevaBusqueda(digitosBusqueda);
            }
        }

        SincronizarClienteDesdeBusquedaUnificada(textoBusqueda);

        sugerencias = await FacturacionService.BuscarClientesFiltroAsync(currentUserId, textoBusqueda);
        indiceSugerenciaClienteActiva = ObtenerIndiceInicial(sugerencias);
        if (!string.IsNullOrWhiteSpace(cliente.Numeroidentificacion))
        {
            var identificacionActual = cliente.Numeroidentificacion.Trim();
            clienteDetectadoEnCatalogoFactura = sugerencias?.Any(c =>
                string.Equals(c.Numeroidentificacion?.Trim(), identificacionActual, StringComparison.Ordinal)) == true;
        }
    }

