                    <div class="n-summary-column">
                        <div class="n-summary-top-grid">
                            <div class="docs-total-card" data-tour="invoice.totals-section">
                                <div class="docs-total-card-header">
                                    <span>Resumen</span>
                                    <h6>Totales del comprobante</h6>
                                </div>

                            @{
                                var gruposPorTarifa = detallesDto
                                    .Where(x => !EsDetalleFacturaVacio(x))
                                    .GroupBy(x => GetTarifaEfectiva(x))
                                    .Select(g => new
                                    {
                                        Tarifa = g.Key,
                                        Bruto = g.Sum(x => GetSubtotalBrutoDetalle(x)),
                                        Descuento = g.Sum(x => GetDescuentoEfectivoDetalle(x)),
                                        Base = g.Sum(x => GetBaseImponibleDetalle(x)),
                                        Iva = g.Sum(x => GetIvaDetalle(x))
                                    })
                                    .ToList();

                                var totalDescuento = gruposPorTarifa.Sum(x => x.Descuento);
                                var totalBaseImponible = gruposPorTarifa.Sum(x => x.Base);
                                var totalIvaGlobal = gruposPorTarifa.Sum(x => x.Iva);
                                var granTotal = totalBaseImponible + totalIvaGlobal;
                                var subtotalBaseGravada = gruposPorTarifa.Where(x => x.Tarifa > 0).Sum(x => x.Base);
                                var subtotalBaseCero = gruposPorTarifa.Where(x => x.Tarifa == 0).Sum(x => x.Base);
                                var subtotalNoObjetoIva = 0m;
                                var subtotalExentoIva = 0m;
                                var valorIce = 0m;
                                var valorServicio = 0m;
                                var valorIrbpnr = 0m;
                                var tarifasIva = gruposPorTarifa
                                    .Where(x => x.Tarifa > 0 && x.Iva > 0)
                                    .OrderBy(x => x.Tarifa)
                                    .ToList();
                            }

                                <div class="docs-total-fiscal-list">
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL BASE GRAVADA</span>
                                    <strong>$ @subtotalBaseGravada.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL BASE 0%</span>
                                    <strong>$ @subtotalBaseCero.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL NO OBJETO IVA</span>
                                    <strong>$ @subtotalNoObjetoIva.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL EXENTO IVA</span>
                                    <strong>$ @subtotalExentoIva.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row docs-total-fiscal-discount">
                                    <span>DESCUENTO</span>
                                    <strong>$ @totalDescuento.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL CON DESCUENTO</span>
                                    <strong>$ @totalBaseImponible.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row">
                                    <span>ICE</span>
                                    <strong>$ @valorIce.ToString("N2")</strong>
                                </div>

                                @foreach (var item in tarifasIva)
                                {
                                    <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                        <span>IVA TARIFA @item.Tarifa.ToString("0.##", CultureInfo.InvariantCulture)%</span>
                                        <strong>$ @item.Iva.ToString("N2")</strong>
                                    </div>
                                }

                                <div class="docs-total-fiscal-row">
                                    <span>SERVICIO 10%</span>
                                    <strong>$ @valorServicio.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row">
                                    <span>IRBPNR</span>
                                    <strong>$ @valorIrbpnr.ToString("N2")</strong>
                                </div>
                                <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                    <span>TOTAL</span>
                                    <strong>$ @granTotal.ToString("N2")</strong>
                                </div>
                                </div>
                            </div>

                        </div>

                        <div class="n-detail-actions-row">
                            <button type="button" class="n-btn n-btn-secondary" @onclick="AbrirVistaPreviaPdfTemporalAsync">
                                <i class="bi bi-file-earmark-pdf me-2"></i> Previsualizar PDF
                            </button>

                            <button type="button" class="n-btn-link" @onclick="LimpiarFormulario">
                                Cancelar / Limpiar
                            </button>

                            <button type="submit"
                                    class="n-btn-primary @(mostrarPantallaCargaEmision ? "n-auto-loading" : null)"
                                    disabled="@(!PuedeIntentarGuardarFactura || mostrarPantallaCargaEmision)">
                                @if (!mostrarPantallaCargaEmision)
                                {
                                    <i class="bi bi-check2-circle fs-5 me-2"></i>
                                }
                                @(isDemoMode ? "Generar Factura (bloqueado)" : (mostrarPantallaCargaEmision ? "Generando Factura..." : "Generar Factura"))
                            </button>
                        </div>
                    </div>
                </div>
</div>
</div>
</EditForm>
</div>

@if (mostrarVistaPreviaPdfTemporal)
{
    <div class="n-product-modal-backdrop" @onclick="CerrarVistaPreviaPdfTemporalAsync"></div>
    <div class="n-product-modal-shell n-pdf-preview-shell" role="dialog" aria-modal="true" aria-labelledby="pdfPreviewTitulo">
        <div class="n-modal n-product-modal-content n-pdf-preview-modal">
            <div class="n-modal-header">
                <div class="n-modal-header-main n-modal-header-main-product">
                    <div class="n-modal-copy n-modal-copy-product">
                        <div class="n-modal-title-row">
                            <div id="pdfPreviewTitulo" class="n-modal-title">@tituloPreviewPdfFactura</div>
                            <span class="n-modal-head-chip">@etiquetaPreviewPdfFactura</span>
                        </div>
                        <p class="n-modal-subtitle n-product-create-subtitle">
                            Vista ampliada para revisar el PDF completo antes de emitir.
                        </p>
                    </div>
                </div>

                <div class="n-modal-header-side n-modal-header-side-product">
                    <button type="button" class="n-modal-close" @onclick="CerrarVistaPreviaPdfTemporalAsync" aria-label="Cerrar vista previa">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <div class="n-modal-body n-pdf-preview-body">
                @if (!string.IsNullOrWhiteSpace(urlPdfTemporal))
                {
                    <iframe class="n-pdf-preview-iframe" src="@urlPdfTemporal" title="Vista previa PDF temporal"></iframe>
                }
                else
                {
                    <div class="n-pdf-preview-empty">
                        <div class="spinner-border text-primary" role="status"></div>
                        <strong>Generando PDF...</strong>
                    </div>
                }
            </div>

