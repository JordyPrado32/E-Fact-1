    private void OnDetalleIvaSelectChanged(DetalleFacturaDto d, string? v)
    {
        if (!int.TryParse(v ?? "0", out var val))
            val = 0;

        if (val == -1)
        {
            d.TarifaPersonalizada = true;
            d.TarifaManual ??= d.Tarifa;
        }
        else
        {
            d.TarifaPersonalizada = false;
            d.Tarifa = Math.Max(0, val);
            d.TarifaManual = d.Tarifa;
        }

        AsegurarFilaVaciaDetalle();
        CalcularTotalesFactura();
        StateHasChanged();
    }

