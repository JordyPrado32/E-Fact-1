    private static string GetFormaPagoNombre(FormasPago fp)
    {
        if (fp == null) return "";
        var descSri = (fp.DescripcionSri ?? "").Trim();
        var desc = (fp.Descripcion ?? "").Trim();

        if (string.IsNullOrWhiteSpace(descSri)) return desc;
        if (string.IsNullOrWhiteSpace(desc)) return descSri;

        // Remove accents and compare
        var normSri = NormalizeString(descSri);
        var normDesc = NormalizeString(desc);

        if (normSri == normDesc)
        {
            return descSri;
        }

        return $"{descSri} ({desc})";
    }

    private static string NormalizeString(string value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        var normalized = value.Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder();
        foreach (var c in normalized)
        {
            var unicodeCategory = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c);
            if (unicodeCategory != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                sb.Append(c);
            }
        }
        return sb.ToString().ToUpperInvariant().Replace(" ", "").Replace("-", "");
    }

