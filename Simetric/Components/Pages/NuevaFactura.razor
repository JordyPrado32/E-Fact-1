    private async Task OnKeyDownConceptoDetalleAsync(DetalleFacturaDto detalle, KeyboardEventArgs e)
    {
        if (sinCaja || detalle.Codproducto > 0)
            return;

        if (e.Key == "ArrowDown")
        {
            if (!ReferenceEquals(filaBusquedaProductoActiva, detalle) || sugerenciasProductos == null || !sugerenciasProductos.Any())
            {
                await MostrarSugerenciasDetalleProductoAsync(detalle);
                indiceSugerenciaProductoActiva = ObtenerIndiceInicial(sugerenciasProductos);
                return;
            }

            indiceSugerenciaProductoActiva = MoverIndiceCircular(indiceSugerenciaProductoActiva, 1, sugerenciasProductos.Count);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            if (!ReferenceEquals(filaBusquedaProductoActiva, detalle) || sugerenciasProductos == null || !sugerenciasProductos.Any())
            {
                await MostrarSugerenciasDetalleProductoAsync(detalle);
                indiceSugerenciaProductoActiva = sugerenciasProductos?.Count > 0 ? sugerenciasProductos.Count - 1 : -1;
                return;
            }

            indiceSugerenciaProductoActiva = MoverIndiceCircular(indiceSugerenciaProductoActiva, -1, sugerenciasProductos.Count);
            return;
        }

        if (e.Key == "Escape")
        {
            filaBusquedaProductoActiva = null;
            sugerenciasProductos = null;
            indiceSugerenciaProductoActiva = -1;
            return;
        }

        if ((e.Key == "Enter" || e.Key == "Tab") &&
            ReferenceEquals(filaBusquedaProductoActiva, detalle) &&
            sugerenciasProductos != null &&
            sugerenciasProductos.Any())
        {
            var indice = indiceSugerenciaProductoActiva >= 0 &&
                         indiceSugerenciaProductoActiva < sugerenciasProductos.Count
                ? indiceSugerenciaProductoActiva
                : 0;
            await SeleccionarProductoEnFilaDesdeListaAsync(detalle, sugerenciasProductos[indice]);
        }
    }

