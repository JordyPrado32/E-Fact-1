    private async Task CargarProductosFrecuentesClienteAsync()
    {
        productosFrecuentesCliente = productosFrecuentesCatalogo.ToList();

        if (!PuedeConsultarHistorialCliente || currentUserId <= 0)
            return;

        try
        {
            var facturasCliente = await FacturacionService.ListarFacturasClienteUsuarioAsync(
                currentUserId,
                cliente.Numeroidentificacion!.Trim(),
                20);

            if (!facturasCliente.Any())
                return;

            var detallesHistorial = new List<Simetric.Models.Detallefactura>();

            foreach (var facturaHistorial in facturasCliente.Take(12))
            {
                var facturaCompleta = await FacturacionService.GetFacturaCompletaUsuarioAsync(facturaHistorial.Codfactura, currentUserId);
                if (facturaCompleta?.Detalles is { Count: > 0 })
                {
                    detallesHistorial.AddRange(facturaCompleta.Detalles);
                }
            }

            var frecuentes = detallesHistorial
                .Where(d => d.Codproducto > 0 || !string.IsNullOrWhiteSpace(d.Descripproducto))
                .GroupBy(d => d.Codproducto > 0
                    ? $"P:{d.Codproducto}"
                    : $"D:{(d.Descripproducto ?? string.Empty).Trim().ToUpperInvariant()}")
                .Select(g =>
                {
                    var item = g
                        .OrderByDescending(x => x.Codlinea)
                        .First();

                    return new
                    {
                        Item = item,
                        Veces = g.Count(),
                        Cantidad = g.Sum(x => x.Cantproducto)
                    };
                })
                .OrderByDescending(x => x.Veces)
                .ThenByDescending(x => x.Cantidad)
                .Take(4)
                .Select(x => new ProductoLookupDetalleDto
                {
                    Codproducto = x.Item.Codproducto,
                    Codprincipal = x.Item.Codprincipal,
                    Codauxiliar = x.Item.Codauxiliar,
                    Descripcion = x.Item.Descripproducto,
                    PrecioUnitario = x.Item.Precioproducto,
                    TarifaIva = x.Item.Tarifa
                })
                .ToList();

            if (frecuentes.Any())
            {
                productosFrecuentesCliente = frecuentes;
            }
        }
        catch
        {
            productosFrecuentesCliente = productosFrecuentesCatalogo.ToList();
        }
    }

