    private async Task GuardarProductoModal()
    {
        guardandoProductoModal = true;
        errorModalProducto = null;
        okModalProducto = null;

        try
        {
            productoModal.Nombre = (productoModal.Nombre ?? "").Trim();
            productoModal.CodigoPrincipal = (productoModal.CodigoPrincipal ?? "").Trim();
            productoModal.CodAuxiliar = string.IsNullOrWhiteSpace(productoModal.CodAuxiliar) ? null : productoModal.CodAuxiliar.Trim();
            productoModal.TipoCompravena = productoModal.TipoCompravena?.Trim().ToUpperInvariant();
            productoModal.Codigoimpuesto = string.IsNullOrWhiteSpace(productoModal.Codigoimpuesto) ? null : productoModal.Codigoimpuesto.Trim();
            productoModal.Porcentajeimpuesto = string.IsNullOrWhiteSpace(productoModal.Porcentajeimpuesto) ? null : productoModal.Porcentajeimpuesto.Trim();

            if (productoModal.Idsubtipo.HasValue && productoModal.Idsubtipo.Value <= 0)
                productoModal.Idsubtipo = null;

            if (string.IsNullOrWhiteSpace(productoModal.Porcentajeimpuesto))
            {
                productoModal.Codigoimpuesto = string.Empty;
                productoModal.Porcentajeimpuesto = string.Empty;
            }
            else
            {
                productoModal.Codigoimpuesto = "2";
            }

            var resp = await Http.PostAsJsonAsync($"api/productos?userId={currentUserId}", new
            {
                Codigo = 0,
                productoModal.Nombre,
                CodigoPrincipal = productoModal.CodigoPrincipal,
                productoModal.CodAuxiliar,
                ValorUnitario = productoModal.ValorUnitario,
                Precio2 = productoModal.Precio2,
                Precio3 = productoModal.Precio3,
                TipoCompravena = productoModal.TipoCompravena,
                TipoProducto = productoModal.TipoProducto,
                Idsubtipo = productoModal.Idsubtipo,
                productoModal.Codigoimpuesto,
                Porcentajeimpuesto = productoModal.Porcentajeimpuesto,
                Estado = true,
                Margen = (decimal?)null,
                Facturable = productoModal.Facturable
            });

            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                errorModalProducto = string.IsNullOrWhiteSpace(txt)
                    ? $"No se pudo guardar (HTTP {(int)resp.StatusCode})."
                    : txt;
                return;
            }

            await SetProductoModalVisibilityAsync(false);

            nuevoCodProducto = productoModal.CodigoPrincipal ?? "";
            productoLookup = null;
            sugerenciasProductos = null;
            msgDetalle = "Producto creado. Buscando y seleccionando...";

            await OnCodigoProductoBlur();

            if (productoLookup != null)
                msgDetalle = "Producto creado y seleccionado. Ahora presiona (+) para agregarlo.";
            else
                msgDetalle = "Producto creado, pero no se pudo cargar en el lookup. Escribe el código y presiona Enter.";

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            errorModalProducto = $"Error guardando producto: {ex.Message}";
        }
        finally
        {
            guardandoProductoModal = false;
        }
    }

