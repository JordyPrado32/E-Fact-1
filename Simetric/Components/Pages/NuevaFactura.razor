        ModoDescuento modoDescuento = ModoDescuento.Porcentaje,
        bool cargarDetalleAutomatico = true)
    {
        if (sinCaja) return;

        var detalle = ObtenerFilaDisponibleParaProducto();
        CargarProductoEnDetalle(detalle, producto, cantidad, precio, descuentoValor, descuentoPorcentaje, modoDescuento, cargarDetalleAutomatico);

        nuevoCodProducto = string.Empty;
        nuevoDescripcion = string.Empty;
        nuevoCantidad = 1;
