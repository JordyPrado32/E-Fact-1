        </div>

        @* =======================================================
            SECCIÓN FACTURACIÓN
        ======================================================= *@
        <div class="n-card n-invoice-data-card mb-3 d-none" data-tour="invoice.header-section">
            <div class="n-card-header n-header-dark">
                <div class="n-invoice-header-row">
                    <h5><i class="bi bi-receipt-cutoff me-2"></i> Datos de Factura</h5>

                </div>
            </div>

            <div class="n-card-body">
                <div class="row g-3 n-invoice-data-grid">
                    <div class="col-md-2">
                        <label class="n-label">Serie</label>
                        <input type="text" class="n-input text-center fw-bold bg-light border-0" @bind="serieVisual" readonly />
                    </div>

                    <div class="col-md-2">
                        <label class="n-label">Número de factura</label>
                        <input type="text" class="n-input text-center fw-bold bg-light border-0" @bind="factura.Numfactura" readonly />
                    </div>

                </div>

            </div>
        </div>

        @* =======================================================
            SECCIÓN DETALLE DE PRODUCTOS
        ======================================================= *@
        <div class="n-card n-invoice-detail-card mb-4" data-tour="invoice.detail-section">
            <div class="n-card-header n-header-dark">
                <div class="invoice-detail-head">
                    <h5 class="mb-0"><i class="bi bi-cart4 me-2"></i> Detalle de Factura</h5>
                </div>
            </div>

            <div class="n-card-body">
                @if (!string.IsNullOrWhiteSpace(msgDetalle))
                {
                    <div class="alert alert-info border-0 rounded-3 py-2 mb-3">
                        @msgDetalle
                    </div>
                }

                <div class="table-responsive n-table-container">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="n-table-header bg-light">
                            <tr>
                                <th style="width: 80px;">Cód.</th>
                                <th style="min-width: 180px;">Concepto</th>
                                <th style="min-width: 260px;">Detalle</th>
                                <th class="text-center" style="width: 80px;">Cant.</th>
                                <th class="text-end" style="width: 100px;">Precio</th>
                                <th class="text-center" style="width: 168px;">Descuento</th>
                                <th class="text-end" style="width: 96px;" title="Descuento aplicado">Desc. apl.</th>
                                <th class="text-end" style="width: 100px;">Base Imp.</th>
                                <th class="text-end" style="width: 120px;">IVA</th>
                                <th class="text-end" style="width: 110px;">Total</th>
                                <th class="text-center" style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < detallesDto.Count; i++)
                            {
                                var index = i;
                                var d = detallesDto[i];
                                var tarifaEfectiva = GetTarifaEfectiva(d);
                                var descuentoFila = GetDescuentoEfectivoDetalle(d);
                                var baseImp = GetBaseImponibleDetalle(d);
                                var ivaFila = GetIvaDetalle(d);
                                var totalFila = GetTotalDetalle(d);

                                <tr class="@(EsDetalleFacturaVacio(d) ? "n-detail-empty-row" : null)">
                                    <td>
                                        @if (d.Codproducto > 0)
                                        {
                                            <span class="text-muted small fw-bold">@GetCodigoVisualDetalle(d)</span>
                                        }
                                        else
                                        {
                                            <input type="text"
                                                   class="n-input-sm text-center fw-bold"
                                                   @bind="d.Codprincipal"
                                                   @bind:event="oninput"
                                                   @bind:after="AsegurarFilaVaciaDespuesDeEdicion"
                                                   maxlength="50"
                                                   placeholder="Codigo" />
                                        }
                                    </td>
                                    <td class="position-relative">
                                        <input type="text"
                                               class="n-input-sm n-detail-concept-input"
                                               @bind="d.Descripcion"
                                               @bind:event="oninput"
                                               @bind:after="@(() => OnConceptoDetalleEditadoAsync(d))"
                                               @onfocus="@(() => MostrarSugerenciasDetalleProductoAsync(d))"
                                               @onblur="@(() => OcultarSugerenciasDetalleProductoAsync(d))"
                                               @onkeydown="@((KeyboardEventArgs e) => OnKeyDownConceptoDetalleAsync(d, e))"
                                               maxlength="150"
                                               placeholder="@(EsDetalleFacturaVacio(d) ? "Buscar producto o servicio" : "Concepto o nombre manual")" />
                                        @if (ReferenceEquals(filaBusquedaProductoActiva, d) && sugerenciasProductos != null && sugerenciasProductos.Any())
                                        {
                                            <ul class="n-suggestions n-suggestions-inline n-detail-suggestions-floating">
                                                @for (var idx = 0; idx < sugerenciasProductos.Count; idx++)
                                                {
                                                    var p = sugerenciasProductos[idx];
                                                    <li @onmousedown="() => PrepararSeleccionProducto()"
                                                        class="@(indiceSugerenciaProductoActiva == idx ? "is-active" : null)"
                                                        @onclick="async () => await SeleccionarProductoEnFilaDesdeListaAsync(d, p)">
                                                        <strong>@p.Descripcion</strong><br />
                                                        <small>Cód: @p.Codprincipal | @ObtenerResumenProductoBusqueda(p) | PVP: $@p.PrecioUnitario</small>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </td>
                                    <td>
                                        <textarea class="n-input-sm n-detail-extra-input"
