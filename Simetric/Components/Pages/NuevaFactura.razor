    private async Task ActualizarNumeroFacturaParaSerieAsync()
    {
        if (sinCaja || factura.Codemisor is null or <= 0 || string.IsNullOrWhiteSpace(factura.Serie))
        {
            factura.Numfactura = string.Empty;
            return;
        }

        var debePreguntar = await FacturacionService.DebePreguntarSecuenciaInicialAsync(currentUserId, factura.Codemisor, factura.Serie);
        if (debePreguntar)
        {
            usuarioYaFacturoAntes = null;
            secuenciaAnteriorManual = string.Empty;
            errorSecuenciaInicial = null;
            seriePendienteModalRaw = factura.Serie;
            mostrarModalSecuenciaInicial = true;
            factura.Numfactura = "000000001";
            return;
        }

        seriePendienteModalRaw = null;
        serieConfirmadaRaw = factura.Serie;
        mostrarModalSecuenciaInicial = false;
        await FacturacionService.SavePreferredSeriesForAllDocumentsAsync(currentUserId, factura.Serie);
        factura.Numfactura = await FacturacionService.GetNextFacturaNumeroAsync(currentUserId, factura.Codemisor, factura.Serie);
    }

