    private static string? NormalizarUrlDocumentoGenerado(string? pdfUrl)
    {
        if (string.IsNullOrWhiteSpace(pdfUrl))
            return null;

        var separador = pdfUrl.Contains('?', StringComparison.Ordinal) ? "&" : "?";
        return $"{pdfUrl}{separador}v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
    }

    private void RestablecerEmisorSeleccionado(int? emisorPreferido = null)
    {
