@* ======================= MODAL CATALOGO DE PRODUCTOS ======================= *@
@if (mostrarCatalogoProductosFactura)
{
    <div class="n-product-modal-backdrop n-product-catalog-backdrop" @onclick="CerrarCatalogoProductosFactura"></div>
    <div class="n-product-modal-shell n-product-catalog-shell" role="dialog" aria-modal="true" aria-labelledby="catalogoProductosFacturaTitulo">
        <div class="n-modal n-product-modal-content n-product-catalog-modal">
            <div class="n-modal-header">
                <div class="n-modal-header-main n-modal-header-main-product">
                    <span class="n-product-create-icon">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </span>
                    <div class="n-modal-copy n-modal-copy-product">
                        <div class="n-modal-title-row">
                            <div id="catalogoProductosFacturaTitulo" class="n-modal-title">Catalogo de productos y servicios</div>
                            <span class="n-modal-head-chip n-modal-head-chip-accent">Usar</span>
                        </div>
                        <p class="n-modal-subtitle n-product-create-subtitle">
                            Selecciona uno o varios items y agregalos al detalle de la factura.
                        </p>
                    </div>
                </div>

                <div class="n-modal-header-side n-modal-header-side-product">
                    <button type="button" class="n-modal-close" @onclick="CerrarCatalogoProductosFactura" aria-label="Cerrar catalogo">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <div class="n-modal-body n-product-catalog-body">
                <div class="n-product-catalog-toolbar">
                    <div class="n-product-catalog-search">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               class="n-input"
                               @bind="filtroCatalogoProductosFactura"
                               @bind:event="oninput"
                               placeholder="Buscar por nombre, codigo, categoria o subcategoria" />
                    </div>

                    <div class="n-product-catalog-selection">
                        <span>@productosCatalogoSeleccionados.Count seleccionados</span>
                        <button type="button"
                                class="n-btn-link"
                                disabled="@(!productosCatalogoSeleccionados.Any())"
                                @onclick="LimpiarSeleccionCatalogoProductos">
                            Limpiar
                        </button>
                        <button type="button"
                                class="n-btn-primary"
                                disabled="@(!productosCatalogoSeleccionados.Any())"
                                @onclick="AgregarProductosSeleccionadosCatalogoFactura">
                            <i class="bi bi-plus-circle"></i>
                            Agregar seleccionados
                        </button>
                    </div>
                </div>

                @if (!productosFrecuentesCatalogo.Any())
                {
                    <div class="n-product-catalog-empty">
                        <i class="bi bi-box-seam"></i>
                        <strong>No hay productos registrados.</strong>
                        <small>Registra un producto nuevo para poder usarlo en la factura.</small>
                    </div>
                }
                else if (!ProductosCatalogoFacturaFiltrados.Any())
                {
                    <div class="n-product-catalog-empty">
                        <i class="bi bi-search"></i>
                        <strong>Sin coincidencias.</strong>
                        <small>Prueba con otro nombre, codigo o categoria.</small>
                    </div>
                }
                else
                {
                    <div class="n-product-catalog-grid">
                        @foreach (var producto in ProductosCatalogoFacturaFiltrados)
                        {
                            var seleccionadoCatalogo = ProductoCatalogoSeleccionado(producto);
                            <article class="n-product-catalog-card @(seleccionadoCatalogo ? "is-selected" : string.Empty)">
                                <button type="button"
                                        class="n-product-catalog-select"
                                        title="Seleccionar producto"
                                        aria-label="Seleccionar producto"
                                        @onclick="() => AlternarProductoCatalogoFactura(producto)">
                                    <i class="@GetIconoSeleccionCatalogo(seleccionadoCatalogo)"></i>
                                </button>
                                <span class="n-product-catalog-icon">
                                    <i class="bi bi-box-seam"></i>
                                </span>
                                <div>
                                    <strong>@(producto.Descripcion ?? "Producto")</strong>
                                    <small>@(string.IsNullOrWhiteSpace(producto.Codprincipal) ? "Sin codigo" : producto.Codprincipal)</small>
                                    <small>@(string.IsNullOrWhiteSpace(producto.Categoria) ? "Catalogo" : producto.Categoria) | IVA @producto.TarifaIva.ToString("0.##", CultureInfo.InvariantCulture)%</small>
                                </div>
                                <div class="n-product-catalog-side">
                                    <span>$ @producto.PrecioUnitario.ToString("N2")</span>
                                    <button type="button"
                                            class="n-product-catalog-use"
                                            @onclick="() => AgregarProductoCatalogoFactura(producto)">
                                        Agregar
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

