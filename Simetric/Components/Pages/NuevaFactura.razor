                                    </td>

                                    <td>
                                        <input type="text"
                                               class="n-input-sm text-end bg-white border-0 fw-medium"
                                               value="@GetPrecioVisual(d)"
                                               @oninput="@((ChangeEventArgs e) => OnPrecioDetalleInput(d, e.Value?.ToString()))" />
                                    </td>

                                    <td>
                                        <div class="n-discount-editor">
                                            <div class="n-discount-mode" role="group" aria-label="Modo de descuento del item">
                                                <button type="button"
                                                        class="@(GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje ? "is-active" : string.Empty)"
                                                        title="Descuento por porcentaje"
                                                        @onclick="() => CambiarModoDescuentoDetalle(d, ModoDescuento.Porcentaje)">
                                                    %
                                                </button>
                                                <button type="button"
                                                        class="@(GetModoDescuentoDetalle(d) == ModoDescuento.Moneda ? "is-active" : string.Empty)"
                                                        title="Descuento por valor"
                                                        @onclick="() => CambiarModoDescuentoDetalle(d, ModoDescuento.Moneda)">
                                                    $
                                                </button>
                                            </div>
                                            <div class="n-discount-input-wrap">
                                                <input type="number"
                                                       class="n-input-sm text-end"
                                                       step="0.01"
                                                       min="0"
                                                       max="@(GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje ? "100" : null)"
                                                       value="@GetDescuentoDetalleVisual(d)"
                                                       @oninput="@((ChangeEventArgs e) => OnDescuentoDetalleInput(d, e.Value?.ToString()))" />
                                                <span>@(GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje ? "%" : "$")</span>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-end text-danger small fw-medium">@descuentoFila.ToString("N2")</td>
                                    <td class="text-end fw-medium text-dark">@baseImp.ToString("N2")</td>

                                    <td>
                                        <div class="d-flex justify-content-center">
                                            <select class="form-select form-select-sm text-center fw-semibold border-0 bg-white shadow-sm"
                                                    style="min-width: 92px; max-width: 110px;"
                                                    @onchange="@((ChangeEventArgs e) => OnDetalleIvaSelectChanged(d, e.Value?.ToString()))">
                                                <option value="0" selected="@(tarifaEfectiva == 0)">0%</option>
                                                @foreach (var iva in modalIvas)
                                                {
                                                    var tarifaCatalogo = ObtenerTarifaIvaModal(iva);
                                                    if (tarifaCatalogo > 0)
                                                    {
                                                        <option value="@tarifaCatalogo" selected="@(tarifaEfectiva == tarifaCatalogo)">@($"{iva.Descripcion}")</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </td>

                                    <td class="text-end fw-bold" style="color: var(--n-blue);">@totalFila.ToString("N2")</td>

                                    <td class="text-center">
                                        <button type="button"
                                                class="n-btn-primary p-0 d-flex justify-content-center align-items-center mx-auto"
                                                style="height: 30px; width: 30px; border-radius: 6px;"
                                                @onclick="() => QuitarDetalle(index)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </td>
                                </tr>

                                @if (ReferenceEquals(filaBusquedaProductoActiva, d) && sugerenciasProductos != null && sugerenciasProductos.Any())
                                {
                                    <tr class="n-detail-suggestions-row">
                                        <td class="n-detail-suggestions-spacer"></td>
                                        <td class="n-detail-suggestions-cell" colspan="10">
                                            <ul class="n-suggestions n-suggestions-inline">
                                                @for (var idx = 0; idx < sugerenciasProductos.Count; idx++)
                                                {
                                                    var p = sugerenciasProductos[idx];
                                                    <li @onmousedown="() => PrepararSeleccionProducto()"
                                                        class="@(indiceSugerenciaProductoActiva == idx ? "is-active" : null)"
                                                        @onclick="async () => await SeleccionarProductoEnFilaDesdeListaAsync(d, p)">
                                                        <strong>@p.Descripcion</strong><br />
                                                        <small>Cód: @p.Codprincipal | @ObtenerResumenProductoBusqueda(p) | PVP: $@p.PrecioUnitario</small>
                                                    </li>
                                                }
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="n-detail-table-actions">
                    <button type="button"
                            class="n-table-add-product-btn"
                            @onclick="AbrirCatalogoProductosFacturaComun"
                            disabled="@sinCaja">
                        <i class="bi bi-plus-circle"></i>
                        <span>Seleccionar servicio o producto</span>
                    </button>
                    <button type="button"
                            class="n-btn-primary n-detail-product-trigger"
                            @onclick="AbrirModalProductoFacturaComun"
                            disabled="@sinCaja">
                        <i class="bi bi-plus-circle"></i>
                        <span>Registrar nuevo producto</span>
                    </button>
                </div>

                <div class="n-detail-bottom-layout">
                    <div class="n-detail-assist-column">
                        @*
                        <div class="n-global-discount-panel">
                            <span class="n-global-discount-icon">
