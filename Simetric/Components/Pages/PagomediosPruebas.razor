                query: new List<QueryParam>
                {
                    new("integration", "Integration", "true", "true"),
                    new("reference", "Referencia", string.Empty, "PM-000000"),
                    new("uuid", "UUID/token", string.Empty, "token de la solicitud"),
                    new("description", "Descripcion", string.Empty, "Pago de prueba"),
