    }

    private sealed class PagomediosEndpoint
    {
        public PagomediosEndpoint(
            string key,
            string group,
            string method,
            string path,
            string summary,
            string? bodyJson = null,
            List<QueryParam>? query = null,
            bool requiresConfirmation = false,
            string? pathTokenName = null,
            string? pathTokenLabel = null,
            string? pathTokenPlaceholder = null)
        {
            Key = key;
            Group = group;
            Method = method;
            Path = path;
            Summary = summary;
            BodyJson = bodyJson ?? string.Empty;
            Query = query ?? new List<QueryParam>();
            RequiresConfirmation = requiresConfirmation;
            PathTokenName = pathTokenName;
            PathTokenLabel = pathTokenLabel ?? pathTokenName ?? string.Empty;
            PathTokenPlaceholder = pathTokenPlaceholder ?? string.Empty;
        }

        public string Key { get; }
        public string Group { get; }
        public string Method { get; }
        public string Path { get; }
        public string Summary { get; }
        public string BodyJson { get; set; }
        public List<QueryParam> Query { get; }
        public bool RequiresConfirmation { get; }
        public bool Confirmed { get; set; }
        public string? PathTokenName { get; }
        public string PathTokenLabel { get; }
        public string PathTokenPlaceholder { get; }
        public string PathTokenValue { get; set; } = string.Empty;
        public bool HasBody => !string.IsNullOrWhiteSpace(BodyJson);
        public PagomediosApiResult? Result { get; set; }
    }

    private sealed class QueryParam
    {
        public QueryParam(string name, string label, string value, string placeholder)
        {
            Name = name;
            Label = label;
            Value = value;
            Placeholder = placeholder;
        }

        public string Name { get; }
        public string Label { get; }
        public string Value { get; set; }
        public string Placeholder { get; }
    }
}
