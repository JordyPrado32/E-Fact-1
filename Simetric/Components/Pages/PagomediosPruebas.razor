                    has_cards = 0,
                    has_de_una = 1,
                    has_paypal = 0,
                    has_safetypay = false,
                    custom_value = "simetric-link-test"
                })),
            new(
                "payment-links-get",
                "Links de pago",
                "GET",
                "/payment-links",
                "Consultar links de pago creados.",
                query: new List<QueryParam>
                {
                    new("integration", "Integration", "true", "true"),
