@page "/pagomedios/pruebas"
@using System.Text.Json
@using Simetric.Services
@inject PagoService PagoService
@inject IWebHostEnvironment Env

<div class="pagomedios-shell">
    @if (!Env.IsDevelopment())
    {
        <section class="pagomedios-hero">
            <div>
                <span class="pagomedios-kicker">Pagomedios V2</span>
                <h2>Pruebas deshabilitadas</h2>
                <p>Este panel de pruebas solo queda disponible en entorno de desarrollo para no afectar la operación de e-fact.</p>
            </div>
        </section>
    }
    else
    {
    <section class="pagomedios-hero">
        <div>
            <span class="pagomedios-kicker">Pagomedios V2</span>
            <h2>Comprobador de API</h2>
            <p>
                Usa el servidor oficial de consumo: <strong>@PagoService.BaseUrl</strong>.
                La ruta de <strong>services.abitmedia.cloud/pagomedios-v2</strong> es la documentacion Swagger.
            </p>
        </div>
        <a class="pagomedios-doc-link" href="https://services.abitmedia.cloud/pagomedios-v2" target="_blank" rel="noopener noreferrer">
            Abrir documentacion
        </a>
    </section>

    <section class="pagomedios-control">
        <div>
            <span>Autenticacion</span>
            <strong>@TokenStatus</strong>
        </div>
        <label>
            Token temporal
            <input type="password"
                   @bind="bearerTokenOverride"
                   @bind:event="oninput"
                   placeholder="Opcional: pega un Bearer token solo para esta prueba" />
        </label>
    </section>

    <div class="pagomedios-grid">
        @foreach (var endpoint in endpoints)
        {
            <article class="endpoint-panel">
                <header class="endpoint-header">
                    <div>
                        <span class="method-pill @GetMethodClass(endpoint.Method)">@endpoint.Method</span>
                        <strong>@endpoint.Path</strong>
                    </div>
                    <small>@endpoint.Group</small>
                </header>

                <p class="endpoint-summary">@endpoint.Summary</p>

                @if (!string.IsNullOrWhiteSpace(endpoint.PathTokenName))
                {
                    <label class="endpoint-field">
                        @endpoint.PathTokenLabel
                        <input @bind="endpoint.PathTokenValue"
                               @bind:event="oninput"
                               placeholder="@endpoint.PathTokenPlaceholder" />
                    </label>
                }

                @if (endpoint.Query.Any())
                {
                    <div class="endpoint-query-grid">
                        @foreach (var param in endpoint.Query)
                        {
                            <label class="endpoint-field">
                                @param.Label
                                <input @bind="param.Value"
                                       @bind:event="oninput"
                                       placeholder="@param.Placeholder" />
                            </label>
                        }
                    </div>
                }

                @if (endpoint.HasBody)
                {
                    <label class="endpoint-field">
                        JSON de envio
                        <textarea @bind="endpoint.BodyJson" @bind:event="oninput" spellcheck="false"></textarea>
                    </label>
                }

                @if (endpoint.RequiresConfirmation)
                {
                    <label class="endpoint-confirm">
                        <input type="checkbox" @bind="endpoint.Confirmed" />
                        Confirmo que quiero ejecutar este metodo sensible
                    </label>
                }

                <button type="button"
                        class="endpoint-run"
                        disabled="@(!CanExecute(endpoint))"
                        @onclick="() => Ejecutar(endpoint)">
                    @(IsRunning(endpoint) ? "Probando..." : "Probar endpoint")
                </button>

                @if (endpoint.Result is not null)
                {
                    <div class="endpoint-result @GetResultClass(endpoint.Result)">
                        <div class="endpoint-result-meta">
                            <strong>@GetResultTitle(endpoint.Result)</strong>
                            <span>@endpoint.Result.ElapsedMilliseconds ms</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(endpoint.Result.ErrorMessage))
                        {
                            <p>@endpoint.Result.ErrorMessage</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(endpoint.Result.RequestUrl))
                        {
                            <small>@endpoint.Result.RequestUrl</small>
                        }
                        <pre>@endpoint.Result.ResponseBody</pre>
                    </div>
                }
            </article>
        }
    </div>
    }
</div>

@code {
    private readonly List<PagomediosEndpoint> endpoints = BuildEndpoints();
    private string? bearerTokenOverride;
    private string? runningKey;

    private string TokenStatus =>
        string.IsNullOrWhiteSpace(PagoService.ConfiguredToken)
            ? "Falta token"
            : "Token listo en el servidor";

    private async Task Ejecutar(PagomediosEndpoint endpoint)
    {
        if (!CanExecute(endpoint))
        {
            return;
        }

        runningKey = endpoint.Key;
        endpoint.Result = null;

        try
        {
            var path = BuildPath(endpoint);
            var query = endpoint.Query.ToDictionary(item => item.Name, item => (string?)item.Value);
            endpoint.Result = await PagoService.SendRawAsync(
                endpoint.Method,
                path,
                endpoint.HasBody ? endpoint.BodyJson : null,
                query,
                bearerTokenOverride);
        }
        finally
        {
            runningKey = null;
        }
    }

    private bool CanExecute(PagomediosEndpoint endpoint)
    {
        if (runningKey is not null)
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(endpoint.PathTokenName) &&
            string.IsNullOrWhiteSpace(endpoint.PathTokenValue))
        {
            return false;
        }

        return !endpoint.RequiresConfirmation || endpoint.Confirmed;
    }

    private bool IsRunning(PagomediosEndpoint endpoint) => runningKey == endpoint.Key;

    private static string BuildPath(PagomediosEndpoint endpoint)
    {
        if (string.IsNullOrWhiteSpace(endpoint.PathTokenName))
        {
            return endpoint.Path;
        }

        return endpoint.Path.Replace(
            "{" + endpoint.PathTokenName + "}",
            Uri.EscapeDataString(endpoint.PathTokenValue.Trim()),
            StringComparison.OrdinalIgnoreCase);
    }

    private static string GetMethodClass(string method) => method switch
    {
        "GET" => "is-get",
        "POST" => "is-post",
        "DELETE" => "is-delete",
        _ => string.Empty
    };

    private static string GetResultClass(PagomediosApiResult result) =>
        result.IsSuccess ? "is-ok" : "is-error";

    private static string GetResultTitle(PagomediosApiResult result) =>
        result.StatusCode is null
            ? "Sin respuesta HTTP"
            : $"HTTP {result.StatusCode} {result.ReasonPhrase}";

    private static readonly JsonSerializerOptions EndpointJsonOptions = new()
    {
        PropertyNamingPolicy = null,
        WriteIndented = true
    };

    private static string ToJson(object value) =>
        JsonSerializer.Serialize(value, EndpointJsonOptions);

    private static List<PagomediosEndpoint> BuildEndpoints()
    {
        var thirdParty = new
