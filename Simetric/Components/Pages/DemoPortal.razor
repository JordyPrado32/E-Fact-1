@page "/demo"
@page "/demo/portal"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Simetric.Services
@inject DemoCatalogService DemoCatalog

@layout Simetric.Components.Layout.MainLayout

<PageTitle>Portal demo | Numerica e-fact</PageTitle>

<style>
    .guest-portal-shell {
        display: grid;
        gap: 1.5rem;
    }

    .guest-hero {
        padding: 1.5rem;
        border-radius: 28px;
        background: linear-gradient(135deg, #e8f4fb 0%, #f8fbfe 55%, #ffffff 100%);
        border: 1px solid #d7e8f4;
        box-shadow: 0 20px 46px rgba(16, 61, 98, 0.08);
    }

    .guest-hero h1 {
        margin: 0;
        font-size: clamp(1.9rem, 2.8vw, 2.7rem);
        font-weight: 800;
        color: #203a52;
    }

    .guest-hero p {
        margin: 0.55rem 0 0;
        max-width: 52rem;
        color: #607587;
        line-height: 1.55;
    }

    .guest-hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .guest-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.8rem;
        border-radius: 999px;
        background: #fff;
        border: 1px solid #d5e6f2;
        color: #35546d;
        font-weight: 700;
    }

    .guest-card-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .guest-card {
        border-radius: 24px;
        background: #fff;
        border: 1px solid #dcebf5;
        box-shadow: 0 18px 36px rgba(13, 74, 116, 0.08);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .guest-card-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        background: linear-gradient(135deg, #006bb5, #004a7c);
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
    }

    .guest-card h2 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 800;
        color: #22384b;
    }

    .guest-card p {
        margin: 0;
        color: #637789;
        line-height: 1.5;
    }

    .guest-card-footer {
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
    }

    .guest-card-label {
        padding: 0.35rem 0.58rem;
        border-radius: 999px;
        background: #edf7fd;
        border: 1px solid #cfe6f7;
        color: #0c5d97;
        font-size: 0.74rem;
        font-weight: 800;
    }

    .guest-card-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-weight: 800;
        color: #006bb5;
        text-decoration: none;
    }

    @@media (max-width: 980px) {
        .guest-card-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="guest-portal-shell">
    <section class="guest-hero">
        <h1>Recorrido guiado de e-fact</h1>
        <p>Esta vista usa la misma estructura general del sistema para que el invitado navegue como si estuviera dentro del producto real, pero con información demostrativa y acciones bloqueadas para no afectar nada.</p>

        <div class="guest-hero-badges">
            <span class="guest-chip"><i class="ri-eye-line"></i> Modo invitado</span>
            <span class="guest-chip"><i class="ri-lock-2-line"></i> Sin emisiones reales</span>
            <span class="guest-chip"><i class="ri-mail-forbid-line"></i> Sin correos reales</span>
            <span class="guest-chip"><i class="ri-database-2-line"></i> Sin cambios en BD</span>
        </div>
    </section>

    <section class="guest-card-grid">
        @foreach (var item in DemoCatalog.GetGuestServices())
        {
            <article class="guest-card">
                <span class="guest-card-icon">
                    <i class="@item.Icon"></i>
                </span>
                <div>
                    <h2>@item.Title</h2>
                    <p>@item.Description</p>
                </div>
                <div class="guest-card-footer">
                    <span class="guest-card-label">Solo lectura</span>
                    <a class="guest-card-link" href="@item.Route">
                        Abrir <i class="ri-arrow-right-line"></i>
                    </a>
                </div>
            </article>
        }
    </section>
</div>
