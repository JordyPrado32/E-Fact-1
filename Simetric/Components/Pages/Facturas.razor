                await AlertService.ShowSuccessAsync("Factura anulada internamente de forma correcta.");
                await Recargar();
            }
            else
            {
                await AlertService.ShowErrorAsync("No se pudo completar la anulación en la base de datos.");
            }
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"Error al intentar anular: {ex.Message}");
        }
        finally
        {
            procesandoAnulacion = false;
        }
    }
    // --- NUEVO MÉTODO ASÍNCRONO PARA LA CONFIRMACIÓN Y ANULACIÓN ---
   private async Task ConfirmarAnularFacturaAsync(FacturaListDto factura)
{
    if (procesandoAnulacion) return;

    // Usamos tu método de alerta para confirmar
        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"¿Está seguro de anular la factura N° {factura.NumeroCompleto}?\n\nEsta acción cambiará el estado a ANULADA en el sistema interno.");

    if (confirmado)
    {
        try
        {
            procesandoAnulacion = true;

            // Llamamos al método que acabamos de meter en tu servicio de facturación
            var exito = await FacturacionService.AnularFacturaDirectoAsync(factura.Codfactura);

            if (exito)
            {
                // Forzamos el cambio visual inmediato en la interfaz
                factura.Estado = false; 

                // Tu alerta de éxito
                await AlertService.ShowSuccessAsync("Factura anulada internamente de forma correcta.");
                
                // Recargamos el listado completo desde la base de datos
                await Recargar();
            }
            else
            {
                await AlertService.ShowErrorAsync("No se pudo completar la anulación en la base de datos.");
            }
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"Error al intentar anular: {ex.Message}");
        }
        finally
        {
            procesandoAnulacion = false;
        }
    }
}
