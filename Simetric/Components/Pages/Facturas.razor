    private async Task Recargar()
    {
        cargando = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaim = authState.User.FindFirst("IdUsuario")?.Value;
        currentUserId = int.TryParse(userClaim, out var id) ? id : 0;

        if (currentUserId <= 0)
        {
            NavManager.NavigateTo("/", true);
            return;
        }

        facturas.Clear();
        facturas.AddRange(await FacturacionService.ListarFacturasUsuarioAsync(currentUserId, 0));
        paginaActual = 1;
        cargando = false;
    }

    private bool CumpleFiltroFactura(FacturaListDto factura)
    {
        if (factura == null)
            return false;

        if (!string.IsNullOrWhiteSpace(Filtro))
        {
            var filtroActual = Filtro.Trim();
            var coincideTexto =
                (factura.Numfactura ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (factura.NumeroCompleto ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (factura.Cliente ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (factura.IdentificacionCliente ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (factura.NumeroAutorizacion ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (factura.EstadoSri ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase);

            if (!coincideTexto)
                return false;
        }

        var fechaFactura = factura.FechaEmision?.Date;

        if (FechaDesde.HasValue && (!fechaFactura.HasValue || fechaFactura.Value < FechaDesde.Value.Date))
            return false;

        if (FechaHasta.HasValue && (!fechaFactura.HasValue || fechaFactura.Value > FechaHasta.Value.Date))
            return false;

        return true;
    }

