    private async Task ConfirmarGenerarNotaCreditoAutomaticaAsync(FacturaListDto factura)
    {
        if (procesandoNotaCreditoAutomatica)
            return;

        if (factura.Estado != true)
        {
            await AlertService.ShowWarningAsync("La factura está anulada y ya no se puede hacer la nota de crédito automática.");
            return;
        }

        if (!DocumentoAutorizacionHelper.EstaAutorizado(factura.Autorizado, factura.EstadoSri))
        {
            await AlertService.ShowWarningAsync("La factura está pendiente de autorización y no puede generar una nota de crédito automática.");
            return;
        }

        if (!PuedeGenerarNotaCreditoAutomatica(factura))
            return;

        var confirmado = await MostrarConfirmacionNotaCreditoAutomaticaAsync(factura);

        if (!confirmado)
            return;

        try
        {
            procesandoNotaCreditoAutomatica = true;
            await MostrarProcesandoNotaCreditoAutomaticaAsync(factura);
            var resultado = await NotaCreditoService.EmitirNotaCreditoAutomaticaDesdeFacturaAsync(currentUserId, factura.Codfactura);
            await JS.InvokeVoidAsync("Swal.close");

            if (!resultado.Success)
            {
                await AlertService.ShowWarningAsync(resultado.Message, "No se pudo emitir la nota de crédito");
                return;
            }

            await Recargar();

            if (mostrarModal && facturaSeleccionada?.Factura?.Codfactura == factura.Codfactura)
                facturaSeleccionada = await FacturacionService.GetFacturaCompletaUsuarioAsync(factura.Codfactura, currentUserId);

            await MostrarResultadoNotaCreditoAutomaticaAsync(factura, resultado);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.close");
            await AlertService.ShowErrorAsync($"Ocurrió un error al generar la nota de crédito automática: {ex.Message}", "Error");
        }
        finally
        {
            procesandoNotaCreditoAutomatica = false;
        }
    }

