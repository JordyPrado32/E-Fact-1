    public async Task<mensajeSRI> EnviarXmlAApiFrameworkAsync(string rutaArchivoxml, string rutaFirma, string password)
    {
        try
        {
            string apiUrl = "http://localhost:8090/api/xml/process"; //produccion
            //string apiUrl = "https://localhost:44372/api/xml/process"; //pruebas

            if (!File.Exists(rutaArchivoxml))
            {
                throw new FileNotFoundException($"No se encontró el archivo XML en la ruta: {rutaArchivoxml}");
            }
            if (!File.Exists(rutaFirma))
            {
                throw new FileNotFoundException($"No se encontró el archivo de firma (.p12) en la ruta: {rutaFirma}");
            }

            rutaFirma = Path.Combine(Directory.GetCurrentDirectory(), "App_Data\\certs", "path\\" + Path.GetFileName(rutaFirma));
            var solicitudData = new
            {
                RutaXml = rutaArchivoxml,
                RutaFirma = rutaFirma,
                PasswordFirma = password
            };

            string jsonPayload = System.Text.Json.JsonSerializer.Serialize(solicitudData);
            var jsonContent = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

            var request = new HttpRequestMessage(HttpMethod.Post, apiUrl)
            {
                Content = jsonContent
            };

            request.Headers.Add("X-Api-Key", "E-factSimetricNumericaKey2026*#");
            request.Headers.UserAgent.ParseAdd("NumericaSoftwareClient/1.0");

            var handler = new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true
            };

            using (var client = new HttpClient(handler))
            {
                client.Timeout = TimeSpan.FromSeconds(80);
                HttpResponseMessage response = await client.SendAsync(request).ConfigureAwait(false);
                string xmlRespuesta = await response.Content.ReadAsStringAsync().ConfigureAwait(false);

                if (response.IsSuccessStatusCode)
                {
                    // 2. DESERIALIZAR la respuesta XML recibida al objeto mensajeSRI
                    var serializer = new System.Xml.Serialization.XmlSerializer(typeof(mensajeSRI));
                    using (var reader = new System.IO.StringReader(xmlRespuesta))
                    {
                        return (mensajeSRI)serializer.Deserialize(reader);
                    }
                }
                else
                {
                    // Si la API responde un error controlado (400, 404, 500)
                    throw new Exception($"Respuesta de error de la API: {xmlRespuesta}");
                }
            }
        }
        catch (Exception ex)
        {
            // 3. En caso de error, mapeamos la excepción a un objeto mensajeSRI de error
            // Reemplaza "xml" o las propiedades según cómo se llamen en tu clase real
            return new mensajeSRI
            {
                xml = $"<error><tipo>ExcepcionBlazor</tipo><mensaje>{ex.Message}</mensaje></error>"
                // Si tienes propiedades como 'estado' o 'mensaje', inicialízalas aquí
            };
        }
    }
    private List<FacturaCorreoDestinoDto> ObtenerCorreosOpcionalesFactura()
