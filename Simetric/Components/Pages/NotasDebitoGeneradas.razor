@page "/facturacion/notas-debito-generadas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.DTOs
@using Simetric.Services
@using System.Text.Json

@inject NotaDebitoService NotaDebitoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject SweetAlertService AlertService
@inject IJSRuntime JS
@inject ISimpleExcelExportService SimpleExcelExportService

<PageTitle>Notas de Debito Generadas</PageTitle>

@{
    var notasFiltradas = NotasFiltradas;
    var notasPaginaActual = NotasPaginaActual;
    var totalFiltrado = notasFiltradas.Sum(x => x.Total);
    var totalVisible = notasPaginaActual.Sum(x => x.Total);
    var notasAutorizadas = notasFiltradas.Count(x => EstaAutorizada(x));
    var notasNoAutorizadas = notasFiltradas.Count(x => ObtenerEstadoNotaTexto(x) == DocumentoAutorizacionHelper.EstadoNoAutorizado);
    var notasPendientes = notasFiltradas.Count - notasAutorizadas - notasNoAutorizadas;
}

<div class="facturas-shell" data-tour="ndgen.page">
    @if (idDocumentoMenuAbierto.HasValue)
    {
        <div class="row-menu-backdrop" @onclick="CerrarMenus"></div>
    }
    <section class="facturas-hero" data-tour="ndgen.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Cargos emitidos</span>
            <h2>Mis notas de débito con filtros, reporte y acciones unificadas</h2>
            <p>
                Filtra por cliente, documento modificado o motivo, exporta tu consulta y abre cada
                comprobante con el mismo patron visual del resto de documentos.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Notas filtradas</span>
                <strong>@notasFiltradas.Count</strong>
                <small>@ResumenRangoFechas</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Total filtrado</span>
                <strong>$ @totalFiltrado.ToString("N2")</strong>
                <small>Importe acumulado de las notas visibles en la consulta.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Autorizadas</span>
                <strong>@notasAutorizadas</strong>
                <small>Pendientes: @notasPendientes | No autorizadas: @notasNoAutorizadas</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="ndgen.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Busqueda y control</span>
            <h3>Notas de débito generadas</h3>
            <p>Combina texto y rango de fechas para ubicar cualquier cargo emitido en segundos.</p>
        </div>

        <div class="toolbar-actions toolbar-actions-expanded">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>

                <input class="search-input"
                       placeholder="Buscar por numero, factura, cliente o identificacion"
                       @bind="Filtro"
                       @bind:event="oninput" />

                @if (!string.IsNullOrWhiteSpace(Filtro))
                {
                    <button class="search-clear" type="button" @onclick="LimpiarTexto" aria-label="Limpiar busqueda">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>

            <label class="date-filter-box">
                <span>Estado SRI</span>
                <select class="date-filter-input" @bind="estadoFiltro">
                    <option value="@DocumentoEstadoFiltroHelper.Todos">Todos</option>
                    <option value="@DocumentoEstadoFiltroHelper.Pendientes">Pendientes</option>
                    <option value="@DocumentoEstadoFiltroHelper.Autorizados">Autorizados</option>
                    <option value="@DocumentoEstadoFiltroHelper.NoAutorizados">No autorizados</option>
                </select>
            </label>

            <div class="date-filter-group">
                <label class="date-filter-box">
                    <span>Desde</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaDesde" />
                </label>

                <label class="date-filter-box">
                    <span>Hasta</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaHasta" />
                </label>
            </div>

            <button class="report-btn" type="button" @onclick="DescargarReporteAsync">
                <i class="bi bi-file-earmark-spreadsheet"></i>
                <span>Descargar Excel</span>
            </button>

            <button class="refresh-btn" type="button" @onclick="Recargar">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refrescar</span>
            </button>

            @if (HayFiltrosActivos)
            {
                <button class="filter-reset-btn" type="button" @onclick="LimpiarFiltros">
                    <i class="bi bi-eraser"></i>
                    <span>Limpiar filtros</span>
                </button>
            }
        </div>
    </section>

    @if (cargando)
    {
        <section class="state-card">
            <div class="state-icon">
                <span class="spinner-border"></span>
            </div>
            <h3>Cargando notas de debito</h3>
            <p>Estamos organizando tu historial para dejar visibles los cargos mas recientes.</p>
        </section>
    }
    else if (notasFiltradas.Count == 0)
    {
        <section class="state-card state-card-empty">
            <div class="state-icon">
                <i class="bi bi-inbox"></i>
            </div>
            <h3>No hay resultados</h3>
            <p>
                @(HayFiltrosActivos
                    ? "No encontramos notas de debito con los filtros aplicados. Ajusta el texto o las fechas."
                    : "Todavia no existen notas de debito para mostrar en este panel.")
            </p>
        </section>
    }
    else
    {
        <section class="table-card" data-tour="ndgen.table">

            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado</span>
                    <h3>Notas de debito</h3>
                    <p>Consulta documento modificado, cliente, estado y total en una sola tabla.</p>
                </div>

                <div class="table-head-actions">
                    <label class="page-size-box" for="nd-page-size">
                        <span>Ver</span>
                        <select id="nd-page-size" class="page-size-select" @bind="RegistrosPorPagina">
                            @foreach (var opcion in pageSizeOptions)
                            {
                                <option value="@opcion">@opcion</option>
                            }
                        </select>
                        <span>registros</span>
                    </label>
                </div>
            </div>

            <div class="table-wrap list-table-wrap">

                <table class="table table-hover align-middle mb-0 facturas-table responsive-list-table">

                    <thead>
                        <tr>
                            <th style="width: 128px;">Fecha sustento</th>
                            <th style="width: 188px;">Numero de nota</th>
                            <th style="width: 176px;">Factura modificada</th>
                            <th>Cliente</th>
                            <th style="width: 148px;">Estado</th>
                            <th class="text-end" style="width: 132px;">Total</th>
                            <th class="text-end actions-header-otros">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var notaEntry in notasPaginaActual.Select((item, index) => new { Item = item, Index = index }))
                        {
                            var item = notaEntry.Item;
                            var openUp = notasPaginaActual.Count <= 2 || notaEntry.Index >= notasPaginaActual.Count - 2;
                            <tr>

                                <td data-label="Fecha sustento">
                                    <span class="invoice-date">
                                        @(item.FechaDocumentoModificado?.ToString("dd/MM/yyyy") ?? "-")
                                    </span>
                                </td>

                                <td data-label="Numero de nota">
                                    <span class="invoice-pill">
                                        @item.NumeroCompleto
                                    </span>
                                </td>

                                <td data-label="Factura modificada">
                                    <span class="invoice-id">
                                        @item.NumeroDocModificadoVisual
                                    </span>
                                </td>

                                <td data-label="Cliente">
                                    <div class="client-cell">
                                        <strong>@item.Cliente</strong>
                                        <span>@item.IdentificacionCliente</span>
                                    </div>
                                </td>

                                 <td data-label="Estado">
                                     <div class="client-cell">
                                         <span class="status-pill @ObtenerEstadoNotaClase(item)">
                                             @ObtenerEstadoNotaTexto(item)
                                         </span>
                                         <span class="authorization-number" title="@ObtenerNumeroAutorizacionTexto(item)">
                                             Autorizacion: @ObtenerNumeroAutorizacionTexto(item)
                                         </span>
                                     </div>
                                 </td>

                                <td class="text-end" data-label="Total">
                                    <span class="amount-pill">
                                        <span class="currency-symbol">$</span>
                                        <span class="currency-value">@item.Total.ToString("N2")</span>
                                    </span>
                                </td>

                                  <td class="text-end" data-label="Acciones">
                                      <!-- Desktop: Inline summarized compact icon buttons -->
                                      <div class="actions-desktop-inline gap-1 justify-content-end row-actions-inline-desktop">
                                           <button class="row-action-btn row-action-view"
                                                   type="button"
                                                   title="Ver"
                                                   @onclick="() => VerNotaAsync(item.Sec)">
                                               <i class="bi bi-eye"></i>
                                          </button>

                                          <button class="row-action-btn row-action-xml"
                                                  type="button"
                                                  title="Descargar XML"
                                                  @onclick="() => AbrirXmlAsync(item.Sec)">
                                              <i class="bi bi-filetype-xml"></i>
                                          </button>

                                           <button class="row-action-btn row-action-pdf"
                                                  type="button"
                                                  title="Descargar PDF"
                                                  @onclick="() => AbrirPdfAsync(item.Sec)">
                                               <i class="bi bi-file-earmark-pdf"></i>
                                           </button>

                                            @if (PuedeReenviarSri(item))
                                            {
                                                <button class="row-action-btn row-action-sri"
                                                        type="button"
                                                        title="Reenviar al SRI"
                                                        disabled="@AccionesBloqueadas"
                                                        @onclick="() => EmitirSriAsync(item.Sec)">
                                                    <i class="bi @(notaEmitiendoSri == item.Sec ? "bi-hourglass-split" : "bi-send")"></i>
                                                </button>
                                            }

                                           <button class="row-action-btn row-action-mail"
                                                   type="button"
                                                   title="Reenviar correo"
                                                   disabled="@AccionesBloqueadas"
                                                   @onclick="() => ReenviarCorreoAsync(item)">
                                               <i class="bi bi-envelope"></i>
                                           </button>

                                           <button class="row-action-btn row-action-danger"
                                                   type="button"
                                                   title="Anular nota de debito"
                                                   disabled="@AccionesBloqueadas"
                                                   @onclick="() => ConfirmarAnularNotaAsync(item)">
                                               <i class="bi bi-trash"></i>
                                           </button>
                                       </div>

                                      <!-- Mobile: Dropdown -->
                                      <div class="actions-mobile-dropdown row-actions-dropdown @(openUp ? "dropdown-open-up" : "")">
                                          <button class="row-actions-trigger" type="button" @onclick="() => ToggleMenu(item.Sec)" @onclick:stopPropagation>
                                              <i class="bi bi-three-dots"></i>
                                          </button>
                                          @if (idDocumentoMenuAbierto == item.Sec)
                                          {
                                              <div class="action-dropdown-menu">
                                                   <button class="action-dropdown-item item-view" type="button" @onclick="async () => { CerrarMenus(); await VerNotaAsync(item.Sec); }">
                                                      <i class="bi bi-eye"></i>
                                                      <span>Ver</span>
                                                  </button>
                                                   <button class="action-dropdown-item item-xml" type="button" @onclick="async () => { CerrarMenus(); await AbrirXmlAsync(item.Sec); }">
                                                      <i class="bi bi-filetype-xml"></i>
                                                      <span>Descargar XML</span>
                                                  </button>
                                                    <button class="action-dropdown-item item-pdf" type="button" @onclick="async () => { CerrarMenus(); await AbrirPdfAsync(item.Sec); }">
                                                      <i class="bi bi-file-earmark-pdf"></i>
                                                      <span>Descargar PDF</span>
                                                   </button>
                                                    @if (PuedeReenviarSri(item))
                                                    {
                                                        <button class="action-dropdown-item item-sri" type="button" disabled="@AccionesBloqueadas" @onclick="async () => { CerrarMenus(); await EmitirSriAsync(item.Sec); }">
                                                            <i class="bi bi-send-check"></i>
                                                            <span>Reenviar al SRI</span>
                                                        </button>
                                                    }
                                                   <button class="action-dropdown-item item-mail" type="button" disabled="@AccionesBloqueadas" @onclick="async () => { CerrarMenus(); await ReenviarCorreoAsync(item); }">
                                                       <i class="bi bi-envelope-arrow-up"></i>
                                                       <span>Reenviar correo</span>
                                                   </button>
                                                   <button class="action-dropdown-item item-cancel" type="button" disabled="@AccionesBloqueadas" @onclick="async () => { CerrarMenus(); await ConfirmarAnularNotaAsync(item); }">
                                                       <i class="bi bi-trash3"></i>
                                                       <span>Anular nota de debito</span>
                                                   </button>
                                               </div>
                                           }
                                       </div>
                                  </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <div class="table-footer">
                <div class="footer-metrics">
                    <div class="footer-metric">
                        <span class="footer-label">Resultados visibles</span>
                        <strong>@notasPaginaActual.Count</strong>
                    </div>

                    <div class="footer-metric">
                        <span class="footer-label">Resultados filtrados</span>
                        <strong>@notasFiltradas.Count</strong>
                    </div>

                    <div class="footer-metric footer-metric-highlight">
                        <span class="footer-label">Total visible</span>
                        <strong>$ @totalVisible.ToString("N2")</strong>
                    </div>
                </div>

                @if (TotalPaginas > 1)
                {
                    <nav class="pagination-nav" aria-label="Paginacion de notas de debito">
                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaAnterior"
                                disabled="@(PaginaActualSegura == 1)">
                            <i class="bi bi-chevron-left"></i>
                            <span>Anterior</span>
                        </button>

                        @foreach (var pagina in PaginasVisibles)
                        {
                            var paginaLocal = pagina;

                            <button class="pagination-btn @(paginaLocal == PaginaActualSegura ? "is-active" : null)"
                                    @onclick="() => IrAPagina(paginaLocal)">
                                @paginaLocal
                            </button>
                        }

                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaSiguiente"
                                disabled="@(PaginaActualSegura == TotalPaginas)">
                            <span>Siguiente</span>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </nav>
                }
            </div>

        </section>
    }

</div>

@if (mostrarModal && notaSeleccionada != null)
{
    <div class="factura-modal-backdrop" @onclick="CerrarModal"></div>

    <div class="modal fade show d-block factura-modal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable factura-modal-dialog">
            <div class="modal-content factura-modal-content">

                <div class="modal-header factura-modal-header">
                    <div>
                        <span class="modal-kicker">Comprobante generado</span>
                        <h5 class="modal-title mb-0">
                            Nota de Debito @notaSeleccionada.NotaDebito.NumNotaDebito
                        </h5>
                    </div>

                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>

                <div class="modal-body factura-modal-body">

                    <div class="nc-preview-shell">

                        <div class="nc-preview-top">
                            <div class="nc-company-card">
                                @if (!string.IsNullOrWhiteSpace(LogoEmisorNotaDetalle))
                                {
                                    <div style="display:flex; justify-content:center; margin-bottom:0.85rem;">
                                        <img src="@LogoEmisorNotaDetalle"
                                             alt="Logo del emisor"
                                             style="max-width:160px; max-height:78px; width:auto; height:auto; object-fit:contain; display:block;" />
                                    </div>
                                }
                                else
                                {
                                    <div style="display:flex; justify-content:center; margin-bottom:0.85rem;">
                                        <span style="font-size:1.9rem; font-weight:900; line-height:1; color:#dc2626; text-align:center;">NO TIENE LOGO</span>
                                    </div>
                                }
                                <h4>@(notaSeleccionada.Emisor?.RazonSocial ?? "EMISOR")</h4>
                                <div><strong>RUC:</strong> @(notaSeleccionada.Emisor?.Ruc ?? "")</div>
                                <div><strong>Direccion:</strong> @(notaSeleccionada.Emisor?.DireccionMatriz ?? "")</div>
                                <div><strong>Obligado contabilidad:</strong> @(notaSeleccionada.Emisor?.LlevaContabilidad ?? "NO")</div>
                            </div>

                            <div class="nc-doc-card">
                                <div class="nc-doc-title">NOTA DE DEBITO</div>
                                <div><strong>No.:</strong> @notaSeleccionada.NumeroCompleto</div>
                                <div><strong>Documento modificado:</strong> @notaSeleccionada.NumeroDocModificadoVisual</div>
                                <div><strong>Fecha sustento:</strong> @(notaSeleccionada.NotaDebito.FechaEmiDocModificado?.ToString("dd/MM/yyyy") ?? "")</div>
                                <div><strong>Fecha vence:</strong> @(notaSeleccionada.NotaDebito.FechaVence?.ToString("dd/MM/yyyy") ?? "")</div>
                                <div><strong>Estado SRI:</strong> @ObtenerEstadoNotaTexto(notaSeleccionada.NotaDebito.Autorizado)</div>
                                <div><strong>Numero de autorizacion:</strong> @ObtenerNumeroAutorizacionTexto(notaSeleccionada.NotaDebito.Autorizado, notaSeleccionada.NotaDebito.NumAutorizacion)</div>
                                @if (!DocumentoAutorizacionHelper.EstaAutorizado(notaSeleccionada.NotaDebito.Autorizado) &&
                                    !string.IsNullOrWhiteSpace(notaSeleccionada.NotaDebito.CodClave))
                                {
                                    <div><strong>Clave de acceso:</strong> @notaSeleccionada.NotaDebito.CodClave</div>
                                }
                            </div>
                        </div>

                        <div class="nc-section-card">
                            <div class="nc-section-title">Datos del cliente</div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <strong>Cliente:</strong><br />
                                    @NombreClienteDetalle
                                </div>

                                <div class="col-md-3">
                                    <strong>Identificacion:</strong><br />
                                    @(notaSeleccionada.Cliente?.Numeroidentificacion ?? "")
                                </div>

                                <div class="col-md-3">
                                    <strong>Tipo identificacion:</strong><br />
                                    @(@notaSeleccionada.TipoIdentificacionCliente ?? "")
                                </div>
                            </div>
                        </div>

                        <div class="nc-section-card">
                            <div class="nc-section-title">Motivo de la nota de debito</div>
                            <div class="nc-motivo-box">
                                @(notaSeleccionada.NotaDebito.Motivo ?? "")
                            </div>
                        </div>

                        <div class="nc-section-card">
                            <div class="nc-section-title">Detalle</div>

                            <div class="table-wrap">
                                <table class="table table-hover align-middle mb-0 facturas-table">
                                    <thead>
                                        <tr>
                                            <th>Codigo</th>
                                            <th>Descripcion</th>
                                            <th class="text-end">Cant.</th>
                                            <th class="text-end">P. Unit.</th>
                                            <th class="text-end">Desc.</th>
                                            <th class="text-end">Subtotal</th>
                                            <th class="text-end">IVA %</th>
                                            <th class="text-end">Valor IVA</th>
                                            <th class="text-end">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (notaSeleccionada.Detalles.Any())
                                        {
                                            @foreach (var d in notaSeleccionada.Detalles)
                                            {
                                                <tr>
                                                    <td>@d.CodigoInterno</td>
                                                    <td>@d.Descripcion</td>
                                                    <td class="text-end">@d.Cantidad.ToString("N2")</td>
                                                    <td class="text-end">@d.PrecioUnitario.ToString("N2")</td>
                                                    <td class="text-end">@d.Descuento.ToString("N2")</td>
                                                    <td class="text-end">@d.Subtotal.ToString("N2")</td>
                                                    <td class="text-end">@d.TarifaIva.ToString("N2")</td>
                                                    <td class="text-end">@d.ValorIva.ToString("N2")</td>
                                                    <td class="text-end">@d.Total.ToString("N2")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="9" class="text-center py-4">
                                                    No se encontraron detalles en la nota de debito.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="nc-totals-row">
                            <div class="nc-total-card">
                                <span>Subtotal</span>
                                <strong>$ @((notaSeleccionada.NotaDebito.Subtotal ?? 0m).ToString("N2"))</strong>
                            </div>

                            <div class="nc-total-card">
                                <span>IVA</span>
                                <strong>$ @((notaSeleccionada.NotaDebito.Iva ?? 0m).ToString("N2"))</strong>
                            </div>

                            <div class="nc-total-card nc-total-card-main">
                                <span>Total</span>
                                <strong>$ @((notaSeleccionada.NotaDebito.ValorTotal ?? 0m).ToString("N2"))</strong>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="modal-footer factura-modal-footer">
                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirXmlAsync(notaSeleccionada.NotaDebito.Sec)">
                        Abrir XML
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(notaSeleccionada.NotaDebito.Sec)">
                        Abrir PDF A4
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(notaSeleccionada.NotaDebito.Sec, FormatoImpresionDocumento.Termica80mm)">
                        Termica 80mm
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(notaSeleccionada.NotaDebito.Sec, FormatoImpresionDocumento.Termica50mm)">
                        Termica 50mm
                    </button>

                    <button class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal">
                        Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private int? idDocumentoMenuAbierto;

    private void ToggleMenu(int id)
    {
        if (idDocumentoMenuAbierto == id)
            idDocumentoMenuAbierto = null;
        else
            idDocumentoMenuAbierto = id;
    }

    private void CerrarMenus()
    {
        idDocumentoMenuAbierto = null;
    }
    private int currentUserId;
    private bool cargando = true;
    private int? notaEmitiendoSri;
    private bool procesandoCorreo;
    private bool procesandoAnulacion;
    private List<NotaDebitoListDto> notas = new();
    private readonly int[] pageSizeOptions = { 5, 10, 20, 50 };
    private int paginaActual = 1;
    private int registrosPorPagina = 10;
    private bool mostrarModal;
    private NotaDebitoDetalleViewDto? notaSeleccionada;
    private string? LogoEmisorNotaDetalle => ResolverLogoEmisorPreview(notaSeleccionada?.Emisor?.LogoImagen);
    private string filtro = string.Empty;
    private string estadoFiltro = DocumentoEstadoFiltroHelper.Todos;
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;

    private static string? ResolverLogoEmisorPreview(string? logoImagen)
    {
        if (string.IsNullOrWhiteSpace(logoImagen))
            return null;

        var logo = logoImagen.Trim();
        if (logo.StartsWith("data:image/", StringComparison.OrdinalIgnoreCase))
            return logo;

        if (logo.StartsWith("/", StringComparison.Ordinal))
            return logo;

        if (logo.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            logo.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return logo;

        return logo.StartsWith("images/", StringComparison.OrdinalIgnoreCase)
            ? $"/{logo}"
            : $"/{logo.TrimStart('/')}";
    }

