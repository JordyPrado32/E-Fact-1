    private async Task DescargarReporteAsync()
    {
        var notasFiltradas = NotasFiltradas;
        if (notasFiltradas.Count == 0)
        {
            await AlertService.ShowInfoAsync("No hay datos para exportar con los filtros actuales.");
            return;
        }

        var archivo = SimpleExcelExportService.Create(
            $"notas_debito_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx",
            new ExcelSheetData(
                "NotasDebito",
                new[]
                {
                    "Fecha sustento",
                    "Numero nota",
                    "Factura modificada",
                    "Cliente",
                    "Identificacion",
                    "Estado",
                    "Numero autorizacion",
                    "Subtotal",
                    "IVA",
                    "Total"
                },
                notasFiltradas
                    .Select(item => (IReadOnlyList<string>)new[]
                    {
                        item.FechaDocumentoModificado?.ToString("yyyy-MM-dd") ?? string.Empty,
                        item.NumeroCompleto ?? string.Empty,
                        item.NumeroDocModificadoVisual ?? string.Empty,
                        item.Cliente ?? string.Empty,
                        item.IdentificacionCliente ?? string.Empty,
                        ObtenerEstadoNotaTexto(item),
                        ObtenerNumeroAutorizacionTexto(item),
                        item.Subtotal.ToString("N2"),
                        item.Iva.ToString("N2"),
                        item.Total.ToString("N2")
                    })
                    .ToList()));

        await using var stream = new MemoryStream(archivo.Content);
        using var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("downloadFileFromStream", archivo.FileName, streamRef, archivo.ContentType);
    }

    private void LimpiarTexto() => Filtro = string.Empty;

    private void LimpiarFiltros()
    {
        Filtro = string.Empty;
        estadoFiltro = DocumentoEstadoFiltroHelper.Todos;
        FechaDesde = null;
        FechaHasta = null;
    }

    private void PaginaAnterior()
    {
        if (PaginaActualSegura > 1)
            paginaActual = PaginaActualSegura - 1;
    }

    private void PaginaSiguiente()
    {
        if (PaginaActualSegura < TotalPaginas)
            paginaActual = PaginaActualSegura + 1;
    }

    private void IrAPagina(int pagina)
    {
        paginaActual = Math.Clamp(pagina, 1, Math.Max(TotalPaginas, 1));
    }

    private static bool EstaAutorizada(NotaDebitoListDto nota) =>
        DocumentoAutorizacionHelper.EstaAutorizado(nota.Autorizado);

    private static bool PuedeReenviarSri(NotaDebitoListDto nota) =>
        nota.Estado && !EstaAutorizada(nota);

    private static string ObtenerEstadoNotaTexto(NotaDebitoListDto nota) =>
        DocumentoAutorizacionHelper.ObtenerEstadoVisual(
            nota.Autorizado,
            DocumentoAutorizacionHelper.EstaAutorizado(nota.Autorizado));

    private static string ObtenerEstadoNotaTexto(string? autorizado) =>
        DocumentoAutorizacionHelper.ObtenerEstadoVisual(
            autorizado,
            DocumentoAutorizacionHelper.EstaAutorizado(autorizado));

    private static string ObtenerNumeroAutorizacionTexto(NotaDebitoListDto nota) =>
        DocumentoAutorizacionHelper.ObtenerNumeroAutorizacionVisual(
            nota.Autorizado,
            DocumentoAutorizacionHelper.EstaAutorizado(nota.Autorizado),
            nota.NumeroAutorizacion);

    private static string ObtenerNumeroAutorizacionTexto(string? autorizado, string? numeroAutorizacion) =>
        DocumentoAutorizacionHelper.ObtenerNumeroAutorizacionVisual(
            autorizado,
            DocumentoAutorizacionHelper.EstaAutorizado(autorizado),
            numeroAutorizacion);

    private static string ObtenerEstadoNotaClase(NotaDebitoListDto nota)
    {
        var estado = ObtenerEstadoNotaTexto(nota);
        return estado == DocumentoAutorizacionHelper.EstadoAutorizado
            ? "status-pill-success"
            : estado == DocumentoAutorizacionHelper.EstadoNoAutorizado
                ? "status-pill-danger"
                : "status-pill-info";
    }

