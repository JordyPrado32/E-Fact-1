    private async Task EmitirSriAsync(int sec)
    {
        if (notaEmitiendoSri.HasValue)
            return;

        notaEmitiendoSri = sec;
        try
        {
            var respuesta = await NotaDebitoService.EmitirNotaDebitoSriAsync(sec, currentUserId);
            var autorizada = string.Equals(
                respuesta.estado,
                DocumentoAutorizacionHelper.EstadoAutorizado,
                StringComparison.OrdinalIgnoreCase) ||
                !string.IsNullOrWhiteSpace(respuesta.autorizacion);

            if (autorizada)
                await AlertService.ShowSuccessAsync($"Nota de debito autorizada por el SRI. Autorizacion: {respuesta.autorizacion}.", "Nota autorizada");
            else
                await AlertService.ShowWarningAsync($"El SRI respondio {respuesta.estado}: {respuesta.mensaje}", "Nota no autorizada");

            await Recargar();
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync(ex.Message, "No se pudo enviar la nota al SRI");
        }
        finally
        {
            notaEmitiendoSri = null;
        }
    }

