@page "/e-sign/soporte"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Services
@using Simetric.Services.ESign
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState

<PageTitle>Soporte | Numerica E-Sign</PageTitle>

<div class="support-shell">
    @if (cargando)
    {
        <div class="esign-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px; gap: 1rem; color: #1b5e20;">
            <span class="spinner-border" role="status" style="width: 3rem; height: 3rem;"></span>
            <h3 style="font-weight: 700; margin: 0;">Cargando Soporte</h3>
        </div>
    }
    else
    {
        <section class="support-hero">
            <div class="hero-copy">
                <span class="hero-eyebrow">Centro de ayuda</span>
                <h2>Soporte E-Sign</h2>
                <p>
                    Encuentra respuestas concretas sobre el uso de firmas electrónicas,
                    los procesos de firma de documentos y la gestión de tus solicitudes.
                </p>
            </div>

            <div class="hero-summary">
                <article class="summary-card summary-card-primary">
                    <span class="summary-label">Horario</span>
                    <strong>09:00</strong>
                    <small>Lunes a viernes hasta las 18:00.</small>
                </article>

                <article class="summary-card">
                    <span class="summary-label">Canales</span>
                    <strong>2</strong>
                    <small>WhatsApp y correo electrónico.</small>
                </article>

                <article class="summary-card">
                    <span class="summary-label">Guías</span>
                    <strong>@faqs.Count</strong>
                    <small>Preguntas frecuentes disponibles.</small>
                </article>
            </div>
        </section>

        <section class="toolbar-card">
            <div class="toolbar-copy">
                <span class="toolbar-kicker">Atención</span>
                <h3>Canales de soporte</h3>
                <p>Ten a mano tu cédula de identidad, RUC y una captura de pantalla del inconveniente.</p>
            </div>

            <div class="support-actions">
                <button type="button" class="primary-btn whatsapp-btn" @onclick="IrAWhatsApp">
                    <i class="bi bi-whatsapp"></i>
                    <span>WhatsApp</span>
                </button>
                <a href="mailto:soporte@numericasoftware.com?subject=Soporte%20E-Sign" class="secondary-btn">
                    <i class="bi bi-envelope"></i>
                    <span>Correo electrónico</span>
                </a>
            </div>
        </section>

        <section class="support-grid">
            <section class="table-card">
                <div class="table-card-head">
                    <div>
                        <span class="table-kicker">Preguntas frecuentes</span>
                        <h3>Respuestas rápidas</h3>
                    </div>
                    <span class="table-badge">@faqs.Count temas</span>
                </div>

                <div class="faq-list">
                    @foreach (var item in faqs)
                    {
                        var isActive = active == item.Id;
                        <article class="faq-item @(isActive ? "is-active" : string.Empty)">
                            <button type="button"
                                    class="faq-button"
                                    aria-expanded="@isActive"
                                    @onclick="() => Toggle(item.Id)">
                                <span class="faq-icon">
                                    <i class="@item.Icon"></i>
                                </span>
                                <span class="faq-question">@item.Pregunta</span>
                                <i class="bi @(isActive ? "bi-chevron-up" : "bi-chevron-down") faq-toggle"></i>
                            </button>

                            @if (isActive)
                            {
                                <div class="faq-answer">@item.Respuesta</div>
                            }
                        </article>
                    }
                </div>
            </section>

            <aside class="editor-card support-side-card">
                <div class="editor-head">
                    <div>
                        <span class="panel-kicker">Antes de escribir</span>
                        <h3>Datos útiles</h3>
                        <p>Con esta información soporte puede revisar tu firma o trámite con mayor rapidez.</p>
                    </div>
                </div>

                <div class="support-checklist">
                    <div class="support-check-item">
                        <i class="bi bi-person-badge"></i>
                        <span>Cédula, RUC y nombre del solicitante.</span>
                    </div>
                    <div class="support-check-item">
                        <i class="bi bi-key"></i>
                        <span>Tipo de firma (Archivo .p12 o en nube).</span>
                    </div>
                    <div class="support-check-item">
                        <i class="bi bi-window"></i>
                        <span>Pantalla o módulo donde aparece el problema.</span>
                    </div>
                    <div class="support-check-item">
                        <i class="bi bi-image"></i>
                        <span>Captura completa del error o comportamiento.</span>
                    </div>
                </div>
            </aside>
        </section>
    }
</div>

@code {
    private bool cargando = true;
    private int active = 1;

    private void Toggle(int id)
    {
        active = active == id ? 0 : id;
    }

    private void IrAWhatsApp()
    {
        var numero = "593995876753";
        var mensaje = Uri.EscapeDataString("Hola, necesito soporte en E-Sign.");
        NavManager.NavigateTo($"https://wa.me/{numero}?text={mensaje}", true);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!int.TryParse(user.FindFirst("IdUsuario")?.Value, out var userId) || userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, ESignRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(ESignRoutes.ServiceKey)}", forceLoad: true);
            return;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(ESignRoutes.ServiceKey);

        cargando = false;
    }

    private readonly List<FaqItem> faqs = new()
    {
        new()
        {
            Id = 1,
            Icon = "bi bi-info-circle",
            Pregunta = "¿Qué es una firma electrónica y para qué sirve?",
            Respuesta = "Es el equivalente digital de tu firma manuscrita. Permite firmar documentos (PDF, XML, etc.) garantizando la autoría, integridad y validez jurídica de la información."
        },
        new()
        {
            Id = 2,
            Icon = "bi bi-filetype-pdf",
            Pregunta = "¿Qué formatos de archivo de firma son compatibles con E-Sign?",
            Respuesta = "E-Sign trabaja de forma óptima con certificados emitidos por Uanataca y soporta archivos .p12 o .pfx, que son el estándar autorizado en el Ecuador."
        },
        new()
        {
            Id = 3,
            Icon = "bi bi-pen",
            Pregunta = "¿Cómo puedo firmar un documento PDF en el sistema?",
            Respuesta = "Dirígete a la sección 'Documentos firmados', carga tu archivo PDF, selecciona el archivo de tu firma .p12, ingresa la contraseña correspondiente y haz clic en 'Firmar'. El documento se descargará automáticamente firmado."
        },
        new()
        {
            Id = 4,
            Icon = "bi bi-check-circle",
            Pregunta = "¿Tiene la misma validez legal que una firma física en papel?",
            Respuesta = "Sí. De acuerdo con la Ley de Comercio Electrónico, Firmas y Mensajes de Datos del Ecuador, las firmas electrónicas tienen la misma validez legal e idénticos efectos que una firma física."
        },
        new()
        {
            Id = 5,
            Icon = "bi bi-key",
            Pregunta = "¿Qué debo hacer si olvido la contraseña de mi firma electrónica?",
            Respuesta = "Por seguridad y protección de tus datos, las contraseñas de las firmas electrónicas no se almacenan en nuestros servidores. Si la olvidas, deberás solicitar una revocación y posterior reemisión de tu certificado."
        },
        new()
        {
            Id = 6,
            Icon = "bi bi-cloud",
            Pregunta = "¿Puedo utilizar mi firma emitida aquí en otros portales gubernamentales?",
            Respuesta = "Sí, al ser emitida por una entidad de certificación autorizada en el Ecuador, puedes usar tu firma en el portal del SRI (facturación electrónica, trámites), Superintendencia de Compañías, Senae, Quipux y más."
        },
        new()
        {
            Id = 7,
            Icon = "bi bi-shield-check",
            Pregunta = "¿Cómo sé si un documento firmado electrónicamente por otro usuario es válido?",
            Respuesta = "Puedes verificar la validez de las firmas abriendo el PDF en programas oficiales como Adobe Acrobat Reader, o subiéndolo al validador oficial Firmatic del MINTEL."
        },
        new()
        {
            Id = 8,
            Icon = "bi bi-calendar-check",
            Pregunta = "¿Qué vigencia tiene mi firma electrónica y cuándo debo renovarla?",
            Respuesta = "La validez depende directamente del certificado digital emitido por la entidad certificadora. La API de precompra no gestiona renovaciones; ese proceso se coordina con la entidad emisora y con nuestro flujo operativo interno."
        }
    };

    private sealed class FaqItem
    {
        public int Id { get; set; }
        public string Icon { get; set; } = string.Empty;
        public string Pregunta { get; set; } = string.Empty;
        public string Respuesta { get; set; } = string.Empty;
    }
}
