    private async Task<bool> ConfirmarEliminacionAsync(string title, string text)
    {
        var resultado = await JS.InvokeAsync<System.Text.Json.JsonElement>("Swal.fire", new
        {
            icon = "warning",
            title,
            text,
            showCancelButton = true,
            confirmButtonText = "Si, eliminar",
            cancelButtonText = "Cancelar",
            reverseButtons = true,
            focusCancel = true,
            confirmButtonColor = "#c23b4b",
            cancelButtonColor = "#7a8da2"
        });

        return resultado.TryGetProperty("isConfirmed", out var confirmacion) && confirmacion.GetBoolean();
    }

    private async Task MostrarAlertaAsync(string title, string text, string icon)
    {
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon,
            title,
            text,
            confirmButtonText = "Aceptar",
            confirmButtonColor = icon == "success" ? "#006bb5" : "#c23b4b"
        });
    }

    private void CerrarDetalleMenu()
    {
        showModalMenuDetail = false;
        menuDetalle = null;
    }

    private void CerrarModalRol()
    {
        showModalRol = false;
        nuevoNombrePerfil = string.Empty;
        errorNuevoRol = null;
    }

    private void CerrarModalMenu()
    {
        showModalMenu = false;
        LimpiarErroresMenu();
    }

    private void PrepararValidacionMenu()
    {
        menuEditContext = new EditContext(menuModel);
        menuValidationStore = new ValidationMessageStore(menuEditContext);
    }

    private void LimpiarErroresMenu()
    {
        menuValidationStore?.Clear();
        menuEditContext?.NotifyValidationStateChanged();
    }

    private bool ValidarReglasMenu()
    {
        menuValidationStore?.Clear();

        menuModel.NombreMenu = (menuModel.NombreMenu ?? string.Empty).Trim();
        menuModel.IconoMenu = string.IsNullOrWhiteSpace(menuModel.IconoMenu) ? null : menuModel.IconoMenu.Trim();
        menuModel.RutaMenu = string.IsNullOrWhiteSpace(menuModel.RutaMenu) ? string.Empty : menuModel.RutaMenu.Trim();

        if (menuModel.NombreMenu.Length < 3)
        {
            menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.NombreMenu)), "El nombre debe tener al menos 3 caracteres.");
        }

        if (listaMaestraMenus.Any(m =>
                m.IdMenu != menuModel.IdMenu &&
                m.IdMenuPadre == menuModel.IdMenuPadre &&
                string.Equals((m.NombreMenu ?? string.Empty).Trim(), menuModel.NombreMenu, StringComparison.OrdinalIgnoreCase)))
        {
            menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.NombreMenu)), "Ya existe un ítem con ese nombre en el mismo nivel.");
        }

        if (!string.IsNullOrWhiteSpace(menuModel.IconoMenu))
        {
            if (menuModel.IconoMenu.Length > 50)
            {
                menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.IconoMenu)), "El icono no puede superar los 50 caracteres.");
            }
            else if (!menuModel.IconoMenu.All(ch => char.IsLetterOrDigit(ch) || ch == '-'))
            {
                menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.IconoMenu)), "El icono solo puede contener letras, números y guiones.");
            }
        }

        if (menuModel.IdMenuPadre != 0)
        {
            if (string.IsNullOrWhiteSpace(menuModel.RutaMenu))
            {
                menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.RutaMenu)), "La ruta es obligatoria para los ítems hijos.");
            }
            else
            {
                if (!menuModel.RutaMenu.StartsWith("/"))
                {
                    menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.RutaMenu)), "La ruta debe iniciar con '/'.");
                }

                if (menuModel.RutaMenu.Contains(' '))
                {
                    menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.RutaMenu)), "La ruta no puede contener espacios.");
                }

                if (listaMaestraMenus.Any(m =>
                        m.IdMenu != menuModel.IdMenu &&
                        !string.IsNullOrWhiteSpace(m.RutaMenu) &&
                        string.Equals(m.RutaMenu.Trim(), menuModel.RutaMenu, StringComparison.OrdinalIgnoreCase)))
                {
                    menuValidationStore?.Add(new FieldIdentifier(menuModel, nameof(menuModel.RutaMenu)), "Ya existe otro ítem con esa ruta.");
                }
            }
        }

        menuEditContext.NotifyValidationStateChanged();

        var tieneErrores = menuEditContext.GetValidationMessages().Any();
        if (tieneErrores)
            errorEstado = "Corrige los campos del menú antes de guardar.";

        return !tieneErrores;
    }

    private void LimpiarEstadoOperacion()
    {
        mensajeEstado = null;
        errorEstado = null;
    }

    private bool EsMenuProtegido(int idMenu) =>
        EsMenuProtegido(listaMaestraMenus.FirstOrDefault(m => m.IdMenu == idMenu));

    private static bool EsMenuProtegido(Menu? menu) =>
        EsModuloPrincipalAdministracionProtegido(menu) || EsSeccionRolesPermisosProtegida(menu);

    private static bool EsModuloPrincipalAdministracionProtegido(Menu? menu) =>
        menu is not null &&
        menu.IdMenuPadre == 0 &&
        CoincideNombreMenu(menu.NombreMenu, "Administracion");

    private static bool EsSeccionRolesPermisosProtegida(Menu? menu) =>
        menu is not null &&
        (!string.IsNullOrWhiteSpace(menu.RutaMenu) &&
         CoincideRutaMenu(menu.RutaMenu, "/configuracion/seguridad") ||
         CoincideNombreMenu(menu.NombreMenu, "Roles y permisos"));

    private string ObtenerMensajeProteccion(int idMenu, bool eliminacion = false) =>
        ObtenerMensajeProteccion(listaMaestraMenus.FirstOrDefault(m => m.IdMenu == idMenu), eliminacion);

    private static string ObtenerMensajeProteccion(Menu? menu, bool eliminacion = false)
    {
        if (EsModuloPrincipalAdministracionProtegido(menu))
        {
            return eliminacion
                ? "El modulo principal Administracion es estatico y no se puede eliminar ni desactivar."
                : "El modulo principal Administracion es estatico y no se puede modificar.";
        }

        return eliminacion
            ? "La seccion Roles y permisos es estatica y no se puede eliminar ni desactivar."
            : "La seccion Roles y permisos es estatica y no se puede modificar.";
    }

    private static bool CoincideRutaMenu(string? valorActual, string valorEsperado) =>
        !string.IsNullOrWhiteSpace(valorActual) &&
        string.Equals(valorActual.Trim(), valorEsperado, StringComparison.OrdinalIgnoreCase);

    private static bool CoincideNombreMenu(string? valorActual, string valorEsperado) =>
        !string.IsNullOrWhiteSpace(valorActual) &&
        CultureInfo.InvariantCulture.CompareInfo.Compare(
            valorActual.Trim(),
            valorEsperado,
            CompareOptions.IgnoreCase | CompareOptions.IgnoreNonSpace) == 0;

    private void AbrirModalOrdenar()
    {
        LimpiarEstadoOperacion();
        dragItem = null;
        isSavingOrder = false;
        
        // Find parents
        parentMenusParaOrden = listaMaestraMenus
            .Where(item => item.IdMenuPadre == 0)
            .OrderBy(item => item.OrdenMenu ?? 9999)
            .ThenBy(item => item.IdMenu)
            .ToList();

        // Copy current state orders to be modified locally
        for (int i = 0; i < parentMenusParaOrden.Count; i++)
        {
            parentMenusParaOrden[i].OrdenMenu = i + 1;
        }

        if (parentMenusParaOrden.Any())
        {
            selectedParentIdForChildOrder = parentMenusParaOrden.First().IdMenu;
        }
        else
        {
            selectedParentIdForChildOrder = 0;
        }

        CargarHijosParaOrden();
        showModalOrder = true;
    }

    private void CerrarModalOrder()
    {
        if (isSavingOrder) return;
        showModalOrder = false;
        dragItem = null;
    }

    private void CargarHijosParaOrden()
    {
        childMenusParaOrden = listaMaestraMenus
            .Where(item => item.IdMenuPadre == selectedParentIdForChildOrder)
            .OrderBy(item => item.OrdenMenu ?? 9999)
            .ThenBy(item => item.IdMenu)
            .ToList();

        for (int i = 0; i < childMenusParaOrden.Count; i++)
        {
            childMenusParaOrden[i].OrdenMenu = i + 1;
        }
    }

    private void ActualizarLocalDeHijos()
    {
        foreach (var item in childMenusParaOrden)
        {
            var masterItem = listaMaestraMenus.FirstOrDefault(m => m.IdMenu == item.IdMenu);
            if (masterItem != null)
            {
                masterItem.OrdenMenu = item.OrdenMenu;
            }
        }
    }

    private void MoverItem(List<Menu> list, Menu item, int direccion)
    {
        var index = list.IndexOf(item);
        if (index == -1) return;

        var nuevoIndex = index + direccion;
        if (nuevoIndex < 0 || nuevoIndex >= list.Count) return;

        list.RemoveAt(index);
        list.Insert(nuevoIndex, item);

        for (int i = 0; i < list.Count; i++)
        {
            list[i].OrdenMenu = i + 1;
        }
    }

    private void HandleDragStart(Menu item)
    {
        dragItem = item;
    }

    private void HandleDragOver(Menu item)
    {
        // Allowed
    }

    private void HandleDrop(Menu targetItem, bool isParentList)
    {
        if (dragItem == null || dragItem == targetItem) return;

        var list = isParentList ? parentMenusParaOrden : childMenusParaOrden;
        var indexDrag = list.IndexOf(dragItem);
        var indexTarget = list.IndexOf(targetItem);

        if (indexDrag != -1 && indexTarget != -1)
        {
            list.RemoveAt(indexDrag);
            list.Insert(indexTarget, dragItem);

            for (int i = 0; i < list.Count; i++)
            {
                list[i].OrdenMenu = i + 1;
            }
        }
    }

    private async Task GuardarOrdenMenus()
    {
        isSavingOrder = true;
        LimpiarEstadoOperacion();

        // 1. Sync current child order back
        ActualizarLocalDeHijos();

        // 2. Sync parent order back
        foreach (var item in parentMenusParaOrden)
        {
            var masterItem = listaMaestraMenus.FirstOrDefault(m => m.IdMenu == item.IdMenu);
            if (masterItem != null)
            {
                masterItem.OrdenMenu = item.OrdenMenu;
            }
        }

        // 3. Save to database using service
        try
        {
            var exito = await MenuService.ActualizarOrdenMenus(listaMaestraMenus);
            if (exito)
            {
                showModalOrder = false;
                await CargarDatos();
                mensajeEstado = "El orden de los menús se ha guardado correctamente.";
                MenuStateService.NotifyMenuChanged();
                await MostrarAlertaAsync("Orden guardado", "El orden de los menús se actualizó correctamente.", "success");
            }
            else
            {
                errorEstado = "No se pudo actualizar el orden de los menús en la base de datos.";
                await MostrarAlertaAsync("Error", errorEstado, "error");
            }
        }
        catch (Exception ex)
        {
            errorEstado = $"Error al guardar el orden: {ex.Message}";
            await MostrarAlertaAsync("Error", errorEstado, "error");
        }
        finally
        {
            isSavingOrder = false;
        }
    }
}
