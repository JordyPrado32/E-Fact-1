    private async Task CargarDatos()
    {
        isLoading = true;

        try
        {
            listaRoles = await MenuService.GetAllRoles();
            listaMaestraMenus = await MenuService.GetAllMenus();

            if (listaRoles.Any())
            {
                var rolInicial = listaRoles
                    .OrderBy(r => r.DescripcionRol)
                    .FirstOrDefault(r => rolSeleccionado is not null && r.IdRol == rolSeleccionado.IdRol)
                    ?? listaRoles.OrderBy(r => r.DescripcionRol).First();

                await SeleccionarRol(rolInicial);
            }
        }
        finally
        {
            isLoading = false;
