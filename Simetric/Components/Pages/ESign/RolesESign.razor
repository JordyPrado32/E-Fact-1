        {
            errorEstado = ObtenerMensajeProteccion(id, true);
            return;
        }

        var menu = listaMaestraMenus.FirstOrDefault(m => m.IdMenu == id);
        var nombreMenu = string.IsNullOrWhiteSpace(menu?.NombreMenu) ? "este item de menu" : $"el item de menu {menu.NombreMenu}";
        var confirmado = await ConfirmarEliminacionAsync("Eliminar item de menu", $"Se desactivara {nombreMenu} y dejara de mostrarse.");
        if (!confirmado)
        {
            return;
        }

        if (await MenuService.EliminarLogicoMenu(id))
        {
            var idRolSeleccionado = rolSeleccionado?.IdRol;
            await CargarDatos();

            if (idRolSeleccionado.HasValue)
            {
                var rolActualizado = listaRoles.FirstOrDefault(r => r.IdRol == idRolSeleccionado.Value);
                if (rolActualizado != null)
                {
                    await SeleccionarRol(rolActualizado);
                }
