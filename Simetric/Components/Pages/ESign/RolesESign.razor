@page "/e-sign/administracion/roles"
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.Services.ESign
@inject IESignMenuService MenuService
@inject TutorialRegistryService TutorialRegistry
@inject TutorialStateService TutorialStateService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@using Simetric.Models
@using Simetric.Services
@inject MenuStateService MenuStateService
@{
    var modulosPadre = GetMenusPadre();
}

<PageTitle>Roles y permisos | Numerica eRúbrica</PageTitle>
<style>

    .security-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1040;
        background: rgba(15, 23, 42, 0.55) !important;
        backdrop-filter: blur(4px);
    }

    .security-modal-content {
        background: #ffffff !important;
        border: none !important;
        border-radius: 24px !important;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4) !important;
        overflow: hidden;
    }

    /* --- CABECERA VERDE CON LETRAS BLANCAS (Para todos los modales) --- */
    .security-modal-header,
    .security-modal-header-dark,
    .security-modal-header-primary {
        background: linear-gradient(135deg, #2E7D32, #4CAF50) !important;
        padding: 1.5rem !important;
        border-bottom: none !important;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

        /* Forzar textos blancos en la cabecera */
        .security-modal-header h1,
        .security-modal-header h2,
        .security-modal-header h3,
        .security-modal-header .modal-kicker {
            color: #ffffff !important;
            margin: 0 !important;
        }

        .security-modal-header h3 {
            font-size: 1.4rem !important;
            font-weight: 800 !important;
            margin-top: 5px !important;
            text-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }

        .security-modal-header .modal-kicker {
            font-size: 0.75rem !important;
            font-weight: 800 !important;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: rgba(255, 255, 255, 0.9) !important;
        }

        /* Botón de cerrar blanco */
        .security-modal-header .modal-close {
            color: #ffffff !important;
            background: rgba(255, 255, 255, 0.2) !important;
            border: none !important;
            border-radius: 50% !important;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.2s;
        }

            .security-modal-header .modal-close:hover {
                background: rgba(255, 255, 255, 0.35) !important;
            }

    .security-modal-body {
        padding: 1.5rem !important;
        background: #ffffff !important;
    }

        .security-modal-body p,
        .security-modal-body span {
            color: #334155 !important;
        }

        .security-modal-body .field-label {
            color: #557089 !important;
            font-weight: 800 !important;
            text-transform: uppercase;
            font-size: 0.75rem !important;
        }

        /* Campos de formulario */
        .security-modal-body .field-input,
        .security-modal-body .form-control,
        .security-modal-body .form-select {
            background: #ffffff !important;
            border: 1px solid #d4e3ef !important;
            color: #0f172a !important;
            font-weight: 500;
        }

    /* --- FOOTER --- */
    .security-modal-footer {
        padding: 1.2rem 1.5rem !important;
        background: #f8fafc !important;
        border-top: 1px solid #e2e8f0 !important;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }
</style>

<div class="security-shell" data-tour="security.page">
    <section class="security-hero" data-tour="security.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Control de accesos</span>
            <h2>Panel de seguridad</h2>
        </div>

        <div class="hero-actions">
            <button type="button" class="secondary-btn secondary-btn-accent" data-tour="security.new-master-item" @onclick="AbrirModalMenu">
                <i class="ri-list-settings-line"></i>
                <span>Nuevo Menu</span>
            </button>

            <button type="button" class="secondary-btn secondary-btn-accent" @onclick="AbrirModalOrdenar">
                <i class="ri-drag-drop-line"></i>
                <span>Ordenar menus</span>
            </button>

            <button type="button" class="primary-btn" data-tour="security.new-role" @onclick="AbrirModalRol">
                <i class="ri-add-circle-line"></i>
                <span>Nuevo perfil</span>
            </button>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Perfiles registrados</span>
                <strong>@listaRoles.Count</strong>
                <small>Roles disponibles para asignar matrices de acceso.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Modulos principales</span>
                <strong>@modulosPadre.Count</strong>
                <small>Estructura padre del arbol de navegacion.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Items de menu</span>
                <strong>@ItemsMenu</strong>
                <small>Rutas e hijos configurados dentro del sistema.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Permisos seleccionados</span>
                <strong>@PermisosSeleccionados</strong>
                <small>@(rolSeleccionado is null ? "Seleccione un perfil para comenzar." : $"Asignacion actual de {rolSeleccionado.DescripcionRol}.")</small>
            </article>
        </div>
    </section>

    <section class="security-grid">
        <aside class="roles-panel" data-tour="security.roles-panel">
            <div class="panel-head" data-tour="security.roles-panel-header">
                <div>
                    <span class="panel-kicker">Perfiles disponibles</span>
                    <h3>Roles de acceso</h3>
                </div>
                <span class="panel-badge">@listaRoles.Count</span>
            </div>

            @if (isLoading)
            {
                <div class="state-card state-card-compact">
                    <div class="state-icon">
                        <i class="ri-loader-4-line"></i>
                    </div>
                    <h3>Cargando perfiles</h3>
                    <p>Recuperando roles y estructura de menus.</p>
                </div>
            }
            else if (!listaRoles.Any())
            {
                <div class="state-card state-card-compact state-card-empty">
                    <div class="state-icon">
                        <i class="ri-shield-user-line"></i>
                    </div>
                    <h3>No hay perfiles disponibles</h3>
                    <p>Cree el primer perfil para comenzar a asignar accesos.</p>
                </div>
            }
            else
            {
                <div class="roles-list">
                    @foreach (var roleEntry in listaRoles.OrderBy(r => r.DescripcionRol).Select((role, index) => new { Role = role, Index = index }))
                    {
                        var r = roleEntry.Role;
                        <article class="role-card @(rolSeleccionado?.IdRol == r.IdRol ? "role-card-active" : string.Empty)"
                                 data-tour="@(roleEntry.Index == 0 ? "security.first-role-card" : null)"
                                 @onclick="() => SeleccionarRol(r)">
                            <div class="role-menu-wrap" @onclick:stopPropagation="true">
                                <button type="button"
                                        class="role-menu-trigger"
                                        title="Mas opciones"
                                        @onclick="() => ToggleRolMenu(r.IdRol)">
                                    <i class="ri-more-2-fill"></i>
                                </button>

                                @if (rolMenuAbiertoId == r.IdRol)
                                {
                                    <div class="role-menu-dropdown" @onclick:stopPropagation="true">
                                        <button type="button"
                                                class="role-menu-item role-menu-item-danger"
                                                @onclick="() => EliminarRolDesdeMenu(r.IdRol)">
                                            <i class="ri-delete-bin-line"></i>
                                            <span>Eliminar</span>
                                        </button>
                                    </div>
                                }
                            </div>

                            <div class="role-copy">
                                <strong>@r.DescripcionRol</strong>
                                <span>@(r.EstadoRol == true ? "Perfil activo" : "Perfil inactivo")</span>
                            </div>
                            <div class="role-actions">
                                <span class="role-status @(r.EstadoRol == true ? "role-status-active" : "role-status-muted")">
                                    @(r.EstadoRol == true ? "Activo" : "Inactivo")
                                </span>
                                <button type="button"
                                        class="secondary-btn secondary-btn-quiet role-select-btn"
                                        data-tour="@(roleEntry.Index == 0 ? "security.first-role-select" : null)"
                                        title="Seleccionar perfil"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => SeleccionarRol(r)">
                                    <i class="ri-check-line"></i>
                                    <span>Seleccionar</span>
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </aside>

        <section class="permissions-panel" data-tour="security.permissions-panel">
            @if (rolSeleccionado != null)
            {
                <div class="panel-head panel-head-spread" data-tour="security.permissions-panel-header">
                    <div>
                        <span class="panel-kicker">Matriz de permisos</span>
                        <h3>@rolSeleccionado.DescripcionRol</h3>
                        <p>Seleccione modulos completos o items individuales para este perfil.</p>
                    </div>
                    <button type="button" class="primary-btn" data-tour="security.save-access" @onclick="GuardarAccesos" disabled="@guardandoAccesos">
                        @if (guardandoAccesos)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <i class="ri-save-3-line"></i>
                            <span>Guardar cambios</span>
                        }
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensajeEstado))
                {
                    <div class="status-banner status-banner-success">
                        <i class="ri-checkbox-circle-line"></i>
                        <span>@mensajeEstado</span>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorEstado))
                {
                    <div class="status-banner status-banner-error">
                        <i class="ri-error-warning-line"></i>
                        <span>@errorEstado</span>
                    </div>
                }

                @if (!modulosPadre.Any())
                {
                    <div class="state-card state-card-empty">
                        <div class="state-icon">
                            <i class="ri-list-check-3"></i>
                        </div>
                        <h3>No hay modulos configurados</h3>
                        <p>Agregue un item maestro para construir la jerarquia de accesos.</p>
                    </div>
                }
                else
                {
                    <div class="modules-list">
                        @foreach (var moduloEntry in modulosPadre.OrderBy(m => m.OrdenMenu ?? 9999).ThenBy(m => m.IdMenu).Select((menu, index) => new { Menu = menu, Index = index }))
                        {
                            var padre = moduloEntry.Menu;
                            var hijos = GetMenusHijo(padre.IdMenu);
                            var esModuloProtegido = EsMenuProtegido(padre);
                            <article class="module-card" data-tour="@(moduloEntry.Index == 0 ? "security.first-module-card" : null)">
                                <header class="module-head">
                                    <label class="module-selection">
                                        <input type="checkbox"
                                               class="permission-check"
                                               checked="@padre.IsSelected"
                                               @onchange="(e) => ToggleGrupo(padre, e)" />
                                        <span class="module-copy">
                                            <span class="module-kicker">Modulo principal</span>
                                            <span class="module-title">
                                                <i class="@ResolveIcono(padre.IconoMenu)"></i>
                                                @padre.NombreMenu
                                            </span>
                                            <span class="module-meta">
                                                <span class="module-badge">@hijos.Count items</span>
                                                @if (esModuloProtegido)
                                                {
                                                    <span class="route-chip route-chip-protected">
                                                        <i class="ri-lock-line"></i>
                                                        <span>Estatico</span>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="route-chip">Contenedor sin ruta</span>
                                                }
                                            </span>
                                        </span>
                                    </label>

                                    <div class="module-actions">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view" title="Ver detalle" @onclick="() => VerDetalleMenu(padre)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (!esModuloProtegido)
                                            {
                                                <button type="button" class="action-btn action-edit" title="Editar modulo" @onclick="() => EditarMenuMaestro(padre)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <button type="button" class="action-btn action-delete" title="Eliminar modulo" @onclick="() => EliminarMenuMaestro(padre.IdMenu)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="protected-flag" title="El modulo principal Administracion es fijo y no se puede modificar.">
                                                    <i class="ri-shield-keyhole-line"></i>
                                                    <span>Protegido</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </header>

                                @if (hijos.Any())
                                {
                                    <div class="module-children">
                                        @foreach (var hijo in hijos)
                                        {
                                            var esItemProtegido = EsMenuProtegido(hijo);
                                            <div class="child-row">
                                                <label class="child-main">
                                                    <input type="checkbox" class="permission-check" @bind="hijo.IsSelected" />
                                                    <span class="child-copy">
                                                        <strong>
                                                            <i class="@ResolveIcono(hijo.IconoMenu)"></i>
                                                            @hijo.NombreMenu
                                                        </strong>
                                                    </span>
                                                </label>
                                                <div class="child-actions">
                                                    <div class="action-group">
                                                        <button type="button" class="action-btn action-view" title="Ver detalle" @onclick="() => VerDetalleMenu(hijo)">
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                        @if (!esItemProtegido)
                                                        {
                                                            <button type="button" class="action-btn action-edit" title="Editar item" @onclick="() => EditarMenuMaestro(hijo)">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </button>
                                                            <button type="button" class="action-btn action-delete" title="Eliminar item" @onclick="() => EliminarMenuMaestro(hijo.IdMenu)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="protected-flag" title="@ObtenerMensajeProteccion(hijo)">
                                                                <i class="ri-shield-keyhole-line"></i>
                                                                <span>Protegido</span>
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="module-empty">
                                        <i class="ri-information-line"></i>
                                        <span>Este modulo aun no tiene items hijos.</span>
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }
            }
            else
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="ri-shield-flash-line"></i>
                    </div>
                    <h3>Seleccione un perfil</h3>
                    <p>Elija un rol desde la columna izquierda para administrar su matriz de accesos.</p>
                </div>
            }
        </section>
    </section>
</div>

@if (_tutorialSeguridad is not null)
{
    <AppTutorialOverlay Definition="_tutorialSeguridad"
                        Visible="_mostrarTutorialSeguridad"
                        OnClosed="HandleTutorialSeguridadClosedAsync" />
}

@if (showModalRol)
{
    <div class="security-modal-backdrop"></div>
    <div class="security-modal" role="dialog" aria-modal="true">
        <div class="security-modal-content security-modal-sm">
            <div class="security-modal-header security-modal-header-dark">
                <div>
                    <span class="modal-kicker">Nuevo perfil</span>
                    <h3>Crear rol de usuario</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarModalRol" aria-label="Cerrar">
                    <i class="ri-close-line"></i>
                </button>
            </div>

            <div class="security-modal-body">
                <div class="form-field">
                    <label class="field-label">Nombre del perfil</label>
                    <input @bind="nuevoNombrePerfil"
                           @bind:event="oninput"
                           class="form-control field-input"
                           placeholder="Ej: Administrador, Auditor, Supervisor..." />
                    @if (!string.IsNullOrWhiteSpace(errorNuevoRol))
                    {
                        <small class="text-danger d-block mt-2">@errorNuevoRol</small>
                    }
                </div>
            </div>

            <div class="security-modal-footer">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModalRol">
                    Cancelar
                </button>
                <button type="button"
                        class="primary-btn"
                        @onclick="ProcesarNuevoRol"
                        disabled="@(string.IsNullOrWhiteSpace(nuevoNombrePerfil))">
                    <i class="ri-add-circle-line"></i>
                    <span>Crear perfil</span>
                </button>
            </div>
        </div>
    </div>
}

@if (showModalMenu)
{
    <div class="security-modal-backdrop"></div>
    <div class="security-modal" role="dialog" aria-modal="true">
        <div class="security-modal-content security-modal-lg">
            <EditForm EditContext="menuEditContext" OnValidSubmit="GuardarMenuMaestro">
                <DataAnnotationsValidator />
                <div class="security-modal-header security-modal-header-primary">
                    <div>
                        <span class="modal-kicker">Configuracion de menu</span>
                        <h3>@(menuModel.IdMenu == 0 ? "Crear nuevo item" : "Editar item maestro")</h3>
                    </div>
                    <button type="button" class="modal-close" @onclick="CerrarModalMenu" aria-label="Cerrar">
                        <i class="ri-close-line"></i>
                    </button>
                </div>

                <div class="security-modal-body">
                    <div class="form-grid">
                        <div class="form-field form-field-wide">
                            <label class="field-label">Tipo de item o ubicacion</label>
                            <select class="form-select field-input" @bind="menuModel.IdMenuPadre">
                                <option value="0">Es un modulo principal</option>
                                @foreach (var p in GetMenusPadre().Where(m => m.IdMenu != menuModel.IdMenu).OrderBy(m => m.NombreMenu))
                                {
                                    <option value="@p.IdMenu">Hijo de: @p.NombreMenu</option>
                                }
                            </select>
                        </div>

                        <div class="form-field">
                            <label class="field-label">Nombre visible</label>
                            <InputText @bind-Value="menuModel.NombreMenu" class="form-control field-input" placeholder="Ej: Facturacion" />
                            <ValidationMessage For="@(() => menuModel.NombreMenu)" />
                        </div>

                        <div class="form-field">
                            <label class="field-label">Icono</label>
                            <div class="icon-input-wrap">
                                <span class="icon-preview">
                                    <i class="@ResolveIcono(menuModel.IconoMenu)"></i>
                                </span>
                                <InputText @bind-Value="menuModel.IconoMenu" class="form-control field-input" placeholder="ri-home-4-line" />
                            </div>
                            <ValidationMessage For="@(() => menuModel.IconoMenu)" />
                        </div>

                        @if (menuModel.IdMenuPadre != 0)
                        {
                            <div class="form-field form-field-wide">
                                <label class="field-label">Ruta de navegacion</label>
                                <InputText @bind-Value="menuModel.RutaMenu" class="form-control field-input field-input-accent" placeholder="/ventas/lista" />
                                <small class="field-help">Debe coincidir con el @@page definido en Blazor.</small>
                                <ValidationMessage For="@(() => menuModel.RutaMenu)" />
                            </div>
                        }
                        else
                        {
                            <div class="form-note form-field-wide">
                                <i class="ri-information-line"></i>
                                <span>Los modulos principales solo agrupan items y no necesitan ruta de navegacion.</span>
                            </div>
                        }

                        <div class="form-field form-field-wide">
                            <a href="https://remixicon.com/" target="_blank" rel="noreferrer" class="catalog-link">
                                Ver catalogo de iconos RemixIcon
                            </a>
                        </div>
                    </div>
                </div>

                <div class="security-modal-footer">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModalMenu">
                        Cerrar
                    </button>
                    <button type="submit" class="primary-btn">
                        <i class="@(menuModel.IdMenu == 0 ? "ri-add-line" : "ri-save-3-line")"></i>
                        <span>@(menuModel.IdMenu == 0 ? "Crear item" : "Actualizar")</span>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showModalMenuDetail && menuDetalle is not null)
{
    <div class="security-modal-backdrop"></div>
    <div class="security-modal" role="dialog" aria-modal="true">
        <div class="security-modal-content security-modal-sm">
            <div class="security-modal-header security-modal-header-primary">
                <div>
                    <span class="modal-kicker">Vista de detalle</span>
                    <h3>Detalle del item</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarDetalleMenu" aria-label="Cerrar">
                    <i class="ri-close-line"></i>
                </button>
            </div>

            <div class="security-modal-body">
                <div class="form-grid">
                    <div class="form-field form-field-wide">
                        <label class="field-label">Tipo de item</label>
                        <div class="detail-value">@GetTipoMenu(menuDetalle)</div>
                    </div>

                    <div class="form-field form-field-wide">
                        <label class="field-label">Nombre visible</label>
                        <div class="detail-value">@menuDetalle.NombreMenu</div>
                    </div>

                    <div class="form-field">
                        <label class="field-label">Icono</label>
                        <div class="detail-value detail-value-inline">
                            <i class="@ResolveIcono(menuDetalle.IconoMenu)"></i>
                            <span>@ResolveIcono(menuDetalle.IconoMenu)</span>
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="field-label">Estado</label>
                        <div class="detail-value">@(menuDetalle.EstadoMenu == true ? "Activo" : "Inactivo")</div>
                    </div>

                    <div class="form-field form-field-wide">
                        <label class="field-label">Padre</label>
                        <div class="detail-value">@GetPadreMenu(menuDetalle)</div>
                    </div>

                    <div class="form-field form-field-wide">
                        <label class="field-label">Ruta</label>
                        <div class="detail-value">@GetRutaTexto(menuDetalle)</div>
                    </div>
                </div>
            </div>

            <div class="security-modal-footer">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarDetalleMenu">
                    Cerrar
                </button>
            </div>
        </div>
    </div>
}

@if (showModalOrder)
{
    <div class="security-modal-backdrop"></div>
    <div class="security-modal" role="dialog" aria-modal="true" aria-labelledby="orderModalTitle">
        <div class="security-modal-content security-modal-lg">
            <div class="security-modal-header security-modal-header-primary">
                <div>
                    <span class="modal-kicker">Navegación del Portal</span>
                    <h3 id="orderModalTitle">Ordenar menú de servicios</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarModalOrder" disabled="@isSavingOrder" aria-label="Cerrar">
                    <i class="ri-close-line"></i>
                </button>
            </div>

            <div class="security-modal-body">
                <p class="order-desc">Arrastra los elementos o utiliza las flechas para ordenar los menús tal como quieres que aparezcan en el panel lateral.</p>

                <div class="order-grid">
                    <!-- Columna Módulos Principales -->
                    <div class="order-column">
                        <div class="column-header">
                            <h4>Módulos Principales</h4>
                            <span class="badge-count">@parentMenusParaOrden.Count</span>
                        </div>
                        
                        <div class="order-list">
                            @foreach (var parent in parentMenusParaOrden.Select((item, index) => new { Item = item, Index = index }))
                            {
                                var item = parent.Item;
                                var idx = parent.Index;
                                <div class="order-item @(dragItem == item ? "is-dragging" : "")"
                                     draggable="true"
                                     @ondragstart="() => HandleDragStart(item)"
                                     @ondragover:preventDefault
                                     @ondragover="() => HandleDragOver(item)"
                                     @ondrop="() => HandleDrop(item, true)"
                                     @key="@($"parent:{item.IdMenu}")">
                                    <div class="item-drag-handle">
                                        <i class="ri-drag-move-fill"></i>
                                    </div>
                                    <div class="item-icon">
                                        <i class="@ResolveIcono(item.IconoMenu)"></i>
                                    </div>
                                    <span class="item-name">@item.NombreMenu</span>
                                    <div class="item-actions">
                                        <button type="button" class="order-action-btn" title="Subir" 
                                                disabled="@(idx == 0)"
                                                @onclick="() => MoverItem(parentMenusParaOrden, item, -1)">
                                            <i class="ri-arrow-up-line"></i>
                                        </button>
                                        <button type="button" class="order-action-btn" title="Bajar" 
                                                disabled="@(idx == parentMenusParaOrden.Count - 1)"
                                                @onclick="() => MoverItem(parentMenusParaOrden, item, 1)">
                                            <i class="ri-arrow-down-line"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Columna Items Hijos -->
                    <div class="order-column">
                        <div class="column-header column-header-split">
                            <h4>Submenús de:</h4>
                            <select class="form-select field-input select-parent-order" @bind="SelectedParentIdForChildOrder">
                                @foreach (var parent in parentMenusParaOrden)
                                {
                                    <option value="@parent.IdMenu">@parent.NombreMenu</option>
                                }
                            </select>
                        </div>

                        <div class="order-list">
                            @if (!childMenusParaOrden.Any())
                            {
                                <div class="empty-order-state">
                                    <i class="ri-information-line"></i>
                                    <span>Este módulo no tiene submenús.</span>
                                </div>
                            }
                            else
                            {
                                @foreach (var child in childMenusParaOrden.Select((item, index) => new { Item = item, Index = index }))
                                {
                                    var item = child.Item;
                                    var idx = child.Index;
                                    <div class="order-item @(dragItem == item ? "is-dragging" : "")"
                                         draggable="true"
                                         @ondragstart="() => HandleDragStart(item)"
                                         @ondragover:preventDefault
                                         @ondragover="() => HandleDragOver(item)"
                                         @ondrop="() => HandleDrop(item, false)"
                                         @key="@($"child:{item.IdMenu}")">
                                        <div class="item-drag-handle">
                                            <i class="ri-drag-move-fill"></i>
                                        </div>
                                        <div class="item-icon">
                                            <i class="@ResolveIcono(item.IconoMenu)"></i>
                                        </div>
                                        <span class="item-name">@item.NombreMenu</span>
                                        <div class="item-actions">
                                            <button type="button" class="order-action-btn" title="Subir" 
                                                    disabled="@(idx == 0)"
                                                    @onclick="() => MoverItem(childMenusParaOrden, item, -1)">
                                                <i class="ri-arrow-up-line"></i>
                                            </button>
                                            <button type="button" class="order-action-btn" title="Bajar" 
                                                    disabled="@(idx == childMenusParaOrden.Count - 1)"
                                                    @onclick="() => MoverItem(childMenusParaOrden, item, 1)">
                                                <i class="ri-arrow-down-line"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="security-modal-footer">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModalOrder" disabled="@isSavingOrder">Cancelar</button>
                <button type="button" class="primary-btn" @onclick="GuardarOrdenMenus" disabled="@isSavingOrder">
                    @if (isSavingOrder)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span>Guardando orden...</span>
                    }
                    else
                    {
                        <i class="ri-save-3-line"></i>
                        <span>Guardar orden</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
