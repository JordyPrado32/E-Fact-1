        PrepararValidacionMenu();
        await CargarDatos();
    }

    protected override void OnParametersSet()
    {
        var firmaActual = $"{TutorialQuery}|{ForceTutorial}";

        if (!string.Equals(_firmaTutorialActual, firmaActual, StringComparison.Ordinal))
        {
            _firmaTutorialActual = firmaActual;
            _tutorialSeguridadEvaluado = false;
        }
