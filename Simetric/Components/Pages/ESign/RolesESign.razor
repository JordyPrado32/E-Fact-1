    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_tutorialSeguridadEvaluado || isLoading || _tutorialSeguridad is null)
            return;

        var lanzamientoForzado =
            ForceTutorial &&
            string.Equals(TutorialQuery, TutorialSeguridadId, StringComparison.OrdinalIgnoreCase);

        var debeAutoIniciar = lanzamientoForzado ||
                              await TutorialStateService.ShouldAutoStartAsync(TutorialSeguridadId);

        _tutorialSeguridadEvaluado = true;

        if (!debeAutoIniciar)
            return;

        _tutorialLanzadoDesdeCatalogo = lanzamientoForzado;
        await AsegurarContextoTutorialAsync();
        _mostrarTutorialSeguridad = true;
        await InvokeAsync(StateHasChanged);
