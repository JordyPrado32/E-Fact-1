@page "/politica-privacidad"
@page "/politica-privacidad/{IdUsuario:int}"
@attribute [AllowAnonymous]
@layout Simetric.Components.Layout.EmptyLayout

@using Simetric.Services
@using Simetric.Data
@using Simetric.Extensions
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Auth

@inject NavigationManager NavManager
@inject AuditService Auditoria
@inject IJSRuntime JS
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject SecurityService Security
@inject EmisorOnboardingService EmisorOnboardingService
@inject PendingLoginFlowService PendingLoginFlow
@inject LoginDestinationService LoginDestination
@inject SelectedAppServiceStateService SelectedAppServiceState

<PageTitle>Política de Privacidad | Numérica</PageTitle>

<div class="privacy-viewport notranslate" translate="no">
    
    <header class="privacy-hero">
        <div class="brand-logo-container">
            <img src="/images/LogoNumerica.svg" alt="Logo numerica" onerror="this.style.display='none'" />
        </div>
        <h1 class="hero-title">POLÍTICA DE PRIVACIDAD</h1>
        <div class="hero-subtitle">NUMÉRICA SOFTWARE S.A.S.</div>
    </header>

    <main class="privacy-container">
        <div class="privacy-card">
            
            <div class="text-center">
                <span class="update-badge"><i class="bi bi-calendar-check me-2"></i>Última actualización: mayo 2026</span>
            </div>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-building"></i> 1. ¿Quiénes Somos?</h3>
                <p><strong>Numérica Software S.A.S.</strong> (en adelante, “Numérica”) es una empresa ecuatoriana dedicada al desarrollo de soluciones tecnológicas, incluyendo plataformas como:</p>
                <ul class="custom-list">
                    <li><strong>e-fact</strong> (facturación electrónica)</li>
                    <li><strong>eRúbrica</strong> (firma electrónica)</li>
                    <li>Otros sistemas digitales</li>
                </ul>
                <div class="highlight-box">
                    <div class="contact-item">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span>Dirección: Eloy Alfaro N33-231 y Av. 6 de Diciembre, Quito – Ecuador</span>
                    </div>
                    <div class="contact-item mb-0">
                        <i class="bi bi-envelope-fill"></i>
                        <span>Correo: protecciondatos@numericasoftware.com</span>
                    </div>
                </div>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-clipboard-data"></i> 2. ¿Qué datos recopilamos?</h3>
                <p>Recopilamos datos personales cuando creas una cuenta en nuestras plataformas, utilizas nuestros servicios (ej: e-fact), llenas formularios en la web o te comunicas con nosotros.</p>
                <p><strong>Datos que podemos recopilar:</strong></p>
                <div class="row">
                    <div class="col-md-6">
                        <ul class="custom-list">
                            <li>Nombres y apellidos</li>
                            <li>Cédula o RUC</li>
                            <li>Dirección</li>
                            <li>Teléfono</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="custom-list">
                            <li>Correo electrónico</li>
                            <li>Información relacionada con facturación electrónica</li>
                            <li>Información de uso de la plataforma</li>
                        </ul>
                    </div>
                </div>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-gear-fill"></i> 3. ¿Para qué utilizamos tus datos?</h3>
                <p>Usamos tus datos para diferentes fines, agrupados de la siguiente manera:</p>
                
                <h5 class="fw-bold text-dark mt-4 mb-3">Prestación del servicio (Finalidad Principal)</h5>
                <ul class="custom-list">
                    <li>Crear y gestionar tu cuenta.</li>
                    <li>Permitir el uso de nuestras plataformas.</li>
                    <li>Generar documentos electrónicos.</li>
                    <li>Cumplir obligaciones legales (ej: interacción con el SRI).</li>
                </ul>

                <h5 class="fw-bold text-dark mt-4 mb-3">Mejora del servicio</h5>
                <ul class="custom-list">
                    <li>Analizar el uso de la plataforma.</li>
                    <li>Detectar errores o problemas técnicos.</li>
                    <li>Mejorar funcionalidades.</li>
                </ul>

                <h5 class="fw-bold text-dark mt-4 mb-3">Comunicaciones (con tu consentimiento)</h5>
                <ul class="custom-list">
                    <li>Enviar notificaciones del sistema.</li>
                    <li>Informarte sobre actualizaciones.</li>
                    <li>Enviarte promociones o novedades.</li>
                </ul>
                <p class="text-muted small mt-2"><em>* Puedes desactivar estas comunicaciones en cualquier momento.</em></p>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-file-earmark-text"></i> 4. Base Legal del Tratamiento</h3>
                <p>De conformidad con la Ley Orgánica de Protección de Datos Personales (LOPDP), el tratamiento de tus datos se basa en:</p>
                <ul class="custom-list">
                    <li>Tu consentimiento.</li>
                    <li>La ejecución de un contrato (uso de e-fact u otros sistemas).</li>
                    <li>Cumplimiento de obligaciones legales.</li>
                    <li>Interés legítimo de Numérica, cuando aplique.</li>
                </ul>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-share-fill"></i> 5. ¿Compartimos tus datos?</h3>
                <p>Podemos compartir tus datos únicamente cuando sea estrictamente necesario:</p>
                <ul class="custom-list">
                    <li>Con autoridades competentes (ej: SRI).</li>
                    <li>Con proveedores tecnológicos (hosting, firma electrónica, etc.).</li>
                    <li>Para cumplir obligaciones legales.</li>
                </ul>
                <p>En todos los casos, exigimos niveles adecuados de protección de datos.</p>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-globe"></i> 6. Transferencias Internacionales</h3>
                <p>Algunos proveedores tecnológicos pueden estar ubicados fuera de Ecuador. En estos casos, Numérica garantiza que:</p>
                <ul class="custom-list">
                    <li>Existan niveles adecuados de protección.</li>
                    <li>Se cumpla la normativa aplicable.</li>
                </ul>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-clock-history"></i> 7. ¿Cuánto tiempo conservamos tus datos?</h3>
                <p>Tus datos serán conservados:</p>
                <ul class="custom-list">
                    <li>Mientras exista una relación contractual.</li>
                    <li>Por el tiempo necesario para cumplir obligaciones legales.</li>
                    <li>Hasta un máximo referencial de 10 años, para fines de defensa legal.</li>
                </ul>
                <p>Posteriormente, podrán ser eliminados, anonimizados o bloqueados.</p>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-shield-lock-fill"></i> 8. Seguridad de la Información</h3>
                <p>Numérica implementa medidas técnicas y organizativas para proteger tus datos, incluyendo:</p>
                <div class="row">
                    <div class="col-md-6">
                        <ul class="custom-list">
                            <li>Control de accesos</li>
                            <li>Autenticación de usuarios</li>
                            <li>Copias de seguridad</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="custom-list">
                            <li>Registro de actividades</li>
                            <li>Protección contra accesos no autorizados</li>
                        </ul>
                    </div>
                </div>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-person-lines-fill"></i> 9. Tus Derechos</h3>
                <p>Como titular de datos, puedes ejercer los siguientes derechos y garantizar no ser objeto de decisiones automatizadas:</p>
                <div class="row">
                    <div class="col-md-4 col-6">
                        <ul class="custom-list">
                            <li>Acceso a tus datos</li>
                            <li>Rectificación</li>
                        </ul>
                    </div>
                    <div class="col-md-4 col-6">
                        <ul class="custom-list">
                            <li>Eliminación</li>
                            <li>Oposición</li>
                        </ul>
                    </div>
                    <div class="col-md-4 col-12">
                        <ul class="custom-list">
                            <li>Portabilidad</li>
                            <li>Suspensión del tratamiento</li>
                        </ul>
                    </div>
                </div>
            </section>

            <section class="policy-section">
                <h3 class="section-title"><i class="bi bi-envelope-paper-fill"></i> 10. ¿Cómo puedes ejercer tus derechos?</h3>
                <p>Puedes solicitar el ejercicio de tus derechos enviando un correo a <strong>protecciondatos@numericasoftware.com</strong> incluyendo:</p>
                <ul class="custom-list">
                    <li>Nombre completo</li>
                    <li>Documento de identidad</li>
                    <li>Descripción clara de tu solicitud</li>
                </ul>
                <div class="alert alert-info border-0 bg-light mt-3">
                    <i class="bi bi-info-circle-fill me-2"></i> Si no estás conforme con la respuesta, tienes derecho a acudir a la autoridad competente.
                </div>
            </section>

            <div class="row mt-5 pt-3 border-top">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold text-dark"><i class="bi bi-x-circle text-primary me-2"></i> 11. Revocación</h5>
                    <p class="small text-muted">Puedes retirar tu consentimiento en cualquier momento, sin afectar la legalidad del tratamiento previo.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold text-dark"><i class="bi bi-cookie text-primary me-2"></i> 12. Cookies</h5>
                    <p class="small text-muted">Utilizamos cookies para garantizar el funcionamiento, analizar el comportamiento y mejorar la experiencia. Puedes gestionarlo desde el banner web.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold text-dark"><i class="bi bi-arrow-repeat text-primary me-2"></i> 13. Cambios</h5>
                    <p class="small text-muted">Numérica podrá actualizar esta Política en cualquier momento. Se recomienda revisarla periódicamente.</p>
                </div>
            </div>
            <div class="accept-section mt-4">
                <div class="accept-head">
                    <span class="accept-kicker">Confirmacion obligatoria</span>
                    <h3>Confirma la lectura para continuar</h3>
                    <p>
                        Este paso es requerido antes de ingresar al sistema. Al aceptar podremos
                        continuar con tu ingreso de forma segura.
                    </p>
                </div>

                @if (cargandoDatos)
                {
                    <div class="accept-loading">
                        <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                        <span>Consultando registros...</span>
                    </div>
                }
                else if (completandoInicioPendiente)
                {
                    <div class="accept-loading">
                        <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                        <span>Ingresando al sistema...</span>
                    </div>
                }
                else if (yaAceptoPreviamente)
                {
                    <div class="accept-success">
                        <i class="bi bi-shield-fill-check"></i>
                        <div>
                            <strong>Politica aceptada</strong>
                            <p>Ya aceptaste esta politica anteriormente. Puedes continuar con tu ingreso.</p>
                        </div>
                    </div>

                    <div class="accept-actions">
                        <a href="@RutaRetorno" class="btn-n-primary text-decoration-none d-inline-flex align-items-center">
                            <i class="bi bi-arrow-left me-2"></i>@TextoRetorno
                        </a>
                    </div>
                }
                else if (!IdUsuario.HasValue)
                {
                    <div class="accept-warning">
                        <i class="bi bi-exclamation-circle"></i>
                        <div>
                            <strong>No pudimos identificar tu usuario.</strong>
                            <p>Vuelve al login y accede nuevamente para registrar la aceptacion de forma correcta.</p>
                        </div>
                    </div>

                    <div class="accept-actions">
                        <a href="/login" class="btn-n-secondary text-decoration-none d-inline-flex align-items-center">
                            <i class="bi bi-arrow-left me-2"></i>Ir al Login
                        </a>
                    </div>
                }
                else
                {
                    <div class="accept-check-card @(acuerdoAceptado ? "is-accepted" : null)" style="@EstiloTarjetaAceptacion">
                        <div class="accept-check-row">
                            <input class="accept-check-input" type="checkbox" id="checkAceptar" @bind="acuerdoAceptado" />
                            <label class="accept-check-label @(acuerdoAceptado ? "is-accepted" : null)" style="@EstiloTextoAceptacion" for="checkAceptar">
                                He leído, entiendo y acepto la Política de Privacidad de Numérica.
                            </label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(mensajeAceptacion))
                        {
                            <div class="accept-inline-error">
                                <i class="bi bi-exclamation-circle"></i>
                                <span>@mensajeAceptacion</span>
                            </div>
                        }
                    </div>

                    <div class="accept-actions">
                        <button @key="acuerdoAceptado"
                                class="btn-n-primary @(acuerdoAceptado ? "is-ready" : "is-pending")"
                                style="@EstiloBotonAceptacion"
                                disabled="@guardando"
                                @onclick="AceptarAcuerdo">
                            @if (guardando)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Confirmando aceptacion...</span>
                            }
                            else
                            {
                                <i class="bi bi-check2-circle me-2"></i><span>Aceptar e Ingresar</span>
                            }
                        </button>
                    </div>
                }
            </div>

        </div>
    </main>
</div>

@code {
    private const string TermsStoragePrefix = "numerica:privacy-accepted:";
    private const string PolicyAcceptanceAction = "Aceptación de Políticas de Privacidad";
    [Parameter] public int? IdUsuario { get; set; }
    [SupplyParameterFromQuery(Name = "loginToken")] public string? LoginToken { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
    private bool acuerdoAceptado = false;
    private bool guardando = false;
    private bool yaAceptoPreviamente = false;
    private bool cargandoDatos = true;
    private bool completandoInicioPendiente = false;
    private bool usuarioAutenticado = false;
    private string? mensajeAceptacion;
    private string EstiloTarjetaAceptacion =>
        acuerdoAceptado
            ? "background: rgba(232, 248, 238, 0.96); border-color: rgba(74, 179, 109, 0.68); box-shadow: 0 0 0 1px rgba(74, 179, 109, 0.12);"
            : string.Empty;
    private string EstiloTextoAceptacion =>
        acuerdoAceptado
            ? "color: #197a43;"
            : string.Empty;
    private string EstiloBotonAceptacion =>
        acuerdoAceptado
            ? "background: linear-gradient(135deg, #1f88ff, #165fc2); border-color: rgba(25, 102, 196, 0.65); color: #ffffff; box-shadow: 0 20px 34px rgba(22, 95, 194, 0.34); animation: privacy-ready-pulse 0.7s ease-out;"
            : "background: linear-gradient(135deg, #a8b9c8, #8ea3b7); border-color: rgba(120, 146, 171, 0.5); color: #f8fbff; box-shadow: 0 14px 24px rgba(82, 121, 153, 0.16);";
    private string RutaRetorno => ObtenerRutaRetorno();
    private string TextoRetorno =>
        !usuarioAutenticado ? "Ir al Login" :
        RutaRetorno.Contains("perfil", StringComparison.OrdinalIgnoreCase) ? "Volver a mi perfil" :
        "Volver a la vista anterior";

    private string? serviceKey;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            usuarioAutenticado = authState.User.Identity?.IsAuthenticated == true;

            serviceKey = await SelectedAppServiceState.GetCurrentServiceKeyAsync();

            if (!IdUsuario.HasValue)
            {
                var claimIdUsuario = authState.User.FindFirst("IdUsuario")?.Value;

                if (int.TryParse(claimIdUsuario, out int idSession))
                {
                    IdUsuario = idSession;
                }
            }

            if (IdUsuario.HasValue)
            {
                using var context = await DbFactory.CreateDbContextAsync();

                yaAceptoPreviamente = await context.Auditorias
                    .AnyAsync(a => a.IdUsuario == IdUsuario.Value && a.Accion == PolicyAcceptanceAction);

                if (yaAceptoPreviamente)
                {
                    await PersistTermsAcceptanceAsync(IdUsuario.Value, null);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al consultar BD: {ex.Message}");
            if (IdUsuario.HasValue)
            {
                yaAceptoPreviamente = await HasStoredTermsAcceptanceAsync(IdUsuario.Value, null);
            }
        }
        finally
        {
            cargandoDatos = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !yaAceptoPreviamente || string.IsNullOrWhiteSpace(LoginToken) || completandoInicioPendiente)
        {
            return;
        }

        await CompletarInicioPendienteAsync();
    }

    private async Task AceptarAcuerdo()
    {
        mensajeAceptacion = null;

        if (!acuerdoAceptado)
        {
            mensajeAceptacion = "Debes marcar la aceptacion para continuar.";
            return;
        }

        if (!IdUsuario.HasValue)
        {
            mensajeAceptacion = "No fue posible identificar tu usuario para registrar esta aceptacion.";
            return;
        }

        guardando = true;
        try
        {
            await Auditoria.RegistrarAuditoriaAsync(
                IdUsuario.Value,
                PolicyAcceptanceAction,
                new { EstadoPrevio = "Pendiente de lectura" },
                new { EstadoNuevo = "Aceptado y Firmado", Fecha = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") },
                new { Modulo = "Seguridad/Login", Mensaje = "El usuario confirmo obligatoriamente el acuerdo de confidencialidad." }
            );
            await EnsurePolicyAcceptanceStoredAsync(IdUsuario.Value);

            var usernameForStorage = string.Empty;
            if (!string.IsNullOrWhiteSpace(LoginToken) &&
                PendingLoginFlow.TryPeek(LoginToken, IdUsuario.Value, out var pendingLoginPreview) &&
                pendingLoginPreview is not null)
            {
                usernameForStorage = pendingLoginPreview.Username;
            }

            await PersistTermsAcceptanceAsync(IdUsuario.Value, usernameForStorage);

            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "success",
                title = "Politica aceptada",
                text = !string.IsNullOrWhiteSpace(LoginToken)
                    ? "Redirigiendo a tu cuenta..."
                    : usuarioAutenticado
                        ? "Regresando al sistema..."
                        : "Redirigiendo al login...",
                confirmButtonColor = "#5f8fb4",
                timer = 1200,
                showConfirmButton = false,
                showCloseButton = false,
                allowEscapeKey = false,
                allowOutsideClick = false
            });

            await Task.Delay(1200);
            if (!string.IsNullOrWhiteSpace(LoginToken))
            {
                await CompletarInicioPendienteAsync();
                return;
            }

            NavManager.NavigateTo(usuarioAutenticado ? RutaRetorno : "/login?status=politicas_aceptadas");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task CompletarInicioPendienteAsync()
    {
        if (!IdUsuario.HasValue || string.IsNullOrWhiteSpace(LoginToken))
        {
            NavManager.NavigateTo("/login?status=politicas_aceptadas", replace: true);
            return;
        }

        if (!PendingLoginFlow.TryConsume(LoginToken, IdUsuario.Value, out var pendingLogin) || pendingLogin is null)
        {
            await ShowFlowAlert("info", "Vuelve a ingresar", "Tu acceso pendiente vencio. Inicia sesion nuevamente para continuar.");
            NavManager.NavigateTo("/login?status=politicas_aceptadas", replace: true);
            return;
        }

        completandoInicioPendiente = true;
        mensajeAceptacion = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var userInDb = await context.Usuarios.FirstOrDefaultAsync(u => u.IdUsuario == IdUsuario.Value);

            if (userInDb == null)
            {
                await ShowFlowAlert("warning", "Usuario no disponible", "No pudimos recuperar tu sesion. Inicia sesion nuevamente.");
                NavManager.NavigateTo("/login", replace: true);
                return;
            }

            var authResponse = await JS.InvokeAsync<AuthCookieResponse>("authInterop.login", new
            {
                Username = pendingLogin.Username,
                Password = pendingLogin.Password,
                Recordarme = pendingLogin.Recordarme
            });

            if (!string.IsNullOrWhiteSpace(authResponse.Message))
            {
                await Security.RegistrarLogInicioSesionAsync(userInDb.IdUsuario, false, $"Login pendiente rechazado: {authResponse.Message}");
                await ShowFlowAlert("warning", "No pudimos completar el ingreso", authResponse.Message);
                NavManager.NavigateTo("/login", replace: true);
                return;
            }

            if (authResponse.RequiereCambioClave)
            {
                NavManager.NavigateTo($"/cambiar-clave/{authResponse.IdUsuario}", replace: true);
                return;
            }

            var authProvider = (CustomAuthStateProvider)AuthStateProvider;
            await authProvider.UpdateAuthenticationState(userInDb);
            await Security.RegistrarLogInicioSesionAsync(userInDb.IdUsuario, true, "Exito");
            var destination = await LoginDestination.PrepareDestinationAsync(userInDb.IdUsuario, userInDb.IdTipoUsuario);
            NavManager.NavigateToIfNeeded(destination, forceLoad: true);
        }
        catch (Exception ex) when (ex is not Microsoft.AspNetCore.Components.NavigationException)
        {
            await Security.RegistrarLogInicioSesionAsync(IdUsuario.Value, false, $"Error reanudando login: {ex.Message}");
            mensajeAceptacion = "Tu aceptacion fue guardada, pero no pudimos completar el ingreso automatico.";
            await ShowFlowAlert("error", "Ingreso pendiente", "La aceptacion se registro, pero debes iniciar sesion nuevamente.");
            NavManager.NavigateTo("/login?status=politicas_aceptadas", replace: true);
        }
        finally
        {
            completandoInicioPendiente = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShowFlowAlert(string icon, string title, string text)
    {
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = icon,
            title = title,
            text = text,
            confirmButtonColor = "#6f98b8"
        });
    }

    private async Task<bool> HasStoredTermsAcceptanceAsync(int userId, string? username)
    {
        foreach (var storageKey in BuildTermsStorageKeys(userId, username))
        {
            var storedValue = await JS.InvokeAsync<string?>("localStorage.getItem", storageKey);
            if (string.Equals(storedValue, "true", StringComparison.OrdinalIgnoreCase))
                return true;
        }

        return false;
    }

    private async Task PersistTermsAcceptanceAsync(int userId, string? username)
    {
        foreach (var storageKey in BuildTermsStorageKeys(userId, username))
            await JS.InvokeVoidAsync("localStorage.setItem", storageKey, "true");
    }

    private async Task EnsurePolicyAcceptanceStoredAsync(int userId)
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        var exists = await context.Auditorias
            .AnyAsync(a => a.IdUsuario == userId && a.Accion == PolicyAcceptanceAction);

        if (exists)
            return;

        context.Auditorias.Add(new Simetric.Models.Auditoria
        {
            IdUsuario = userId,
            Fecha = DateTime.Now,
            Accion = PolicyAcceptanceAction,
            ValoresPrevios = """{"EstadoPrevio":"Pendiente de lectura"}""",
            ValorNuevo = """{"EstadoNuevo":"Aceptado y Firmado"}""",
            Detalles = """{"Modulo":"Seguridad/Login","Mensaje":"Aceptacion persistente de politica de privacidad."}"""
        });

        await context.SaveChangesAsync();
    }

    private static IEnumerable<string> BuildTermsStorageKeys(int userId, string? username)
    {
        var keys = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            $"{TermsStoragePrefix}{userId}"
        };

        var normalized = username?.Trim().ToLowerInvariant();
        if (!string.IsNullOrWhiteSpace(normalized))
            keys.Add($"{TermsStoragePrefix}{normalized}");

        return keys;
    }

    private string ObtenerRutaRetorno()
    {
        var fallback = usuarioAutenticado ? "/dashboard" : "/login";
        if (usuarioAutenticado && !string.IsNullOrWhiteSpace(serviceKey))
        {
            fallback = serviceKey.ToLowerInvariant() switch
            {
                "e-sign" => "/e-sign",
                "e-contax" => "/e-contax",
                "e-declara" => "/e-declara",
                _ => "/dashboard"
            };
        }
        var route = ReturnUrl?.Trim();

        if (string.IsNullOrWhiteSpace(route) ||
            !route.StartsWith("/", StringComparison.Ordinal) ||
            route.StartsWith("//", StringComparison.Ordinal) ||
            route.StartsWith("/politica-privacidad", StringComparison.OrdinalIgnoreCase))
        {
            return fallback;
        }

        return route;
    }

    private sealed class AuthCookieResponse
    {
        public bool Success { get; set; }
        public bool RequiereCambioClave { get; set; }
        public int IdUsuario { get; set; }
        public string? Message { get; set; }
    }
}
