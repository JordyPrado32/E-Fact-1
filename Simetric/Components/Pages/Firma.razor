@code {
    private const long MaxCertificadoSize = 5 * 1024 * 1024;

    private readonly List<EmisorDto> emisores = new();
    private EmisorUpsertDto firmaModel = new();
    private bool cargando = true;
    private bool guardandoFirma;
    private bool esAsociado;
    private bool mostrarModalFirma;
    private bool bloquearAutocompletadoBusqueda = true;
    private bool mostrarPassword;
    private string filtro = string.Empty;
    private string? mensaje;
    private string? debugError;
    private EmisionEstado? emisionEstado;
    private string? nombrePathCertificadoSeleccionado;
    private bool emisorSeleccionadoTieneClaveCertificado;
    private bool MostrarVolverInicioOnboarding =>
        EmisorOnboardingService.RequiresInitialSetup || emisionEstado?.PuedeEmitir == false;

    private string tipoPassword => mostrarPassword ? "text" : "password";
    private bool FirmaDisponible => firmaModel.Codigo > 0;

    private void DesbloquearBusquedaFirma(FocusEventArgs _)
    {
        if (!bloquearAutocompletadoBusqueda)
        {
            return;
        }

        bloquearAutocompletadoBusqueda = false;
    }
    private string? NombrePathCertificadoActual => nombrePathCertificadoSeleccionado ?? ObtenerNombreArchivo(firmaModel.PathCertificado);
    private bool TieneClaveCertificadoActual =>
        !string.IsNullOrWhiteSpace(firmaModel.ClaveCertificado) ||
        emisorSeleccionadoTieneClaveCertificado;
    private bool FirmaConfiguradaActual =>
        !string.IsNullOrWhiteSpace(NombrePathCertificadoActual) &&
        TieneClaveCertificadoActual;

    private IEnumerable<EmisorDto> EmisoresFiltrados =>
        string.IsNullOrWhiteSpace(filtro)
            ? emisores
            : emisores.Where(e =>
                (e.RazonSocial ?? string.Empty).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (e.NomComercial ?? string.Empty).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (e.Ruc ?? string.Empty).Contains(filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        esAsociado =
            (bool.TryParse(user.FindFirst("EstadoAsociado")?.Value, out var estadoAsociado) && estadoAsociado) ||
            !string.IsNullOrWhiteSpace(user.FindFirst("IdJefe")?.Value);

        await CargarTodo();
    }

    private async Task CargarTodo()
    {
        cargando = true;
        debugError = null;

        try
        {
            var idUsuario = await ObtenerIdUsuarioLogueado();
            if (idUsuario is not > 0)
            {
                mensaje = "No se pudo obtener la sesion del usuario.";
                return;
            }

            var seleccionadoPrevio = firmaModel.Codigo;
            var data = await Http.GetFromJsonAsync<List<EmisorDto>>($"api/emisores?idUsuario={idUsuario.Value}") ?? new();

            emisores.Clear();
            emisores.AddRange(data);

            var seleccionado = seleccionadoPrevio > 0
                ? emisores.FirstOrDefault(e => e.Codigo == seleccionadoPrevio)
                : null;

            SeleccionarEmisorFirma(seleccionado ?? emisores.FirstOrDefault(e => e.Estado == true) ?? emisores.FirstOrDefault());
            await EmisorOnboardingService.RefreshRequirementAsync(idUsuario);
            emisionEstado = await EmisionControlService.ObtenerEstadoAsync(idUsuario);
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
        }
        finally
        {
            cargando = false;
        }
    }

    private void SeleccionarEmisorFirma(EmisorDto? emisor)
    {
        if (emisor is null)
        {
            firmaModel = new EmisorUpsertDto();
            nombrePathCertificadoSeleccionado = null;
            emisorSeleccionadoTieneClaveCertificado = false;
            return;
        }

        firmaModel = CrearModeloDesdeEmisor(emisor);
        nombrePathCertificadoSeleccionado = null;
        emisorSeleccionadoTieneClaveCertificado = emisor.TieneClaveCertificadoConfigurada;
    }

    private void AbrirModalFirma()
    {
        AbrirModalFirma(emisores.FirstOrDefault(e => e.Estado == true) ?? emisores.FirstOrDefault());
    }

    private void AbrirModalFirma(EmisorDto? emisor)
    {
        SeleccionarEmisorFirma(emisor);
        mostrarModalFirma = true;
    }

    private void CerrarModalFirma()
    {
        mostrarModalFirma = false;
    }

    private async Task GuardarFirma()
    {
        if (!FirmaDisponible || esAsociado || guardandoFirma)
        {
            return;
        }

        var idUsuario = await ObtenerIdUsuarioLogueado();
        if (idUsuario is not > 0)
        {
            mensaje = "No se pudo identificar al usuario para guardar la firma.";
            return;
        }

        guardandoFirma = true;
        mensaje = "Guardando configuracion de firma...";
        debugError = null;

        try
        {
            firmaModel.IdUsuario = idUsuario.Value;
            firmaModel.PathCertificado = firmaModel.PathCertificado?.Trim();
            firmaModel.ClaveCertificado = firmaModel.ClaveCertificado?.Trim();

            if (!string.IsNullOrWhiteSpace(firmaModel.ClaveCertificado))
            {
                firmaModel.EliminarClaveCertificado = false;
            }

            var response = await Http.PutAsJsonAsync($"api/emisores/{firmaModel.Codigo}", firmaModel);
            if (!response.IsSuccessStatusCode)
            {
                mensaje = "No se pudo guardar la firma electronica.";
                debugError = await LeerMensajeErrorHttpAsync(response, "No se pudo guardar la firma electronica.");
                return;
            }

            await CargarTodo();
            EmisionControlService.NotifyChanged();
            EmisorOnboardingService.NotifyChanged();
            mostrarModalFirma = false;
            mensaje = "Firma electronica guardada correctamente.";
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = "Error al guardar la firma.";
        }
        finally
        {
            guardandoFirma = false;
        }
    }

    private void QuitarPathCertificado()
    {
        firmaModel.PathCertificado = null;
        nombrePathCertificadoSeleccionado = null;
        mensaje = "Archivo de firma quitado del formulario. Guarda para confirmar el cambio.";
        debugError = null;
    }

    private void QuitarClaveCertificado()
    {
        firmaModel.ClaveCertificado = null;
        firmaModel.EliminarClaveCertificado = true;
        emisorSeleccionadoTieneClaveCertificado = false;
        mensaje = "Clave del certificado quitada del formulario. Guarda para confirmar el cambio.";
        debugError = null;
    }

    private Task SubirPathCertificado(InputFileChangeEventArgs e)
    {
        if (esAsociado)
        {
            mensaje = "Los usuarios asociados no pueden modificar la firma.";
            debugError = null;
            return Task.CompletedTask;
        }

        return SubirArchivoP12(e, "Archivo Firma", "path", relativePath =>
        {
            firmaModel.PathCertificado = relativePath;
            nombrePathCertificadoSeleccionado = e.File?.Name;
        });
    }

    private async Task SubirArchivoP12(InputFileChangeEventArgs e, string etiqueta, string subcarpeta, Action<string> asignarRuta)
    {
        try
        {
            if (e.FileCount > 1)
            {
                mensaje = $"Solo puedes subir un archivo .p12 para {etiqueta}.";
                debugError = null;
                return;
            }

            var file = e.File;
            if (file is null)
            {
                mensaje = $"No se selecciono ningun archivo para {etiqueta}.";
                return;
            }

            var extension = Path.GetExtension(file.Name)?.ToLowerInvariant();
            if (!string.Equals(extension, ".p12", StringComparison.OrdinalIgnoreCase))
            {
                mensaje = $"Solo se permiten archivos .p12 para {etiqueta}.";
                debugError = null;
                return;
            }

            var contentType = (file.ContentType ?? string.Empty).Trim().ToLowerInvariant();
            var tiposPermitidos = new[]
            {
                string.Empty,
                "application/x-pkcs12",
                "application/pkcs12",
                "application/x-pkcs-12",
                "application/octet-stream"
            };

            if (!tiposPermitidos.Contains(contentType))
            {
                mensaje = $"El archivo seleccionado para {etiqueta} no es un certificado .p12 valido.";
                debugError = null;
                return;
            }

            if (file.Size <= 0)
            {
                mensaje = $"El archivo seleccionado para {etiqueta} esta vacio.";
                debugError = null;
                return;
            }

            if (file.Size > MaxCertificadoSize)
            {
                mensaje = $"El archivo de {etiqueta} excede el tamano maximo de 5 MB.";
                debugError = null;
                return;
            }

            using var stream = file.OpenReadStream(MaxCertificadoSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var bytes = ms.ToArray();
            if (bytes.Length == 0)
            {
                mensaje = $"No se pudo leer el archivo seleccionado para {etiqueta}.";
                debugError = null;
                return;
            }

            var relativePath = await GuardarArchivoCertificadoAsync(bytes, subcarpeta);
            asignarRuta(relativePath);
            mensaje = $"{etiqueta} cargado correctamente. Guarda para confirmar el cambio.";
            debugError = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = $"Error al procesar el archivo de {etiqueta}.";
        }
    }

    private async Task<string> GuardarArchivoCertificadoAsync(byte[] bytes, string subcarpeta)
    {
        var relativePath = $"certs/{subcarpeta}/{Guid.NewGuid():N}.p12";
        var physicalPath = Path.Combine(
            HostEnvironment.ContentRootPath,
            "App_Data",
            relativePath.Replace('/', Path.DirectorySeparatorChar));

        var directory = Path.GetDirectoryName(physicalPath);
        if (!string.IsNullOrWhiteSpace(directory))
        {
            Directory.CreateDirectory(directory);
        }

        await File.WriteAllBytesAsync(physicalPath, bytes);
        return relativePath;
    }

    private async Task<int?> ObtenerIdUsuarioLogueado()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var idClaim = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(idClaim, out var id) ? id : null;
    }

