@page "/firma"

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.Services
@using System.IO
@using System.Security.Claims
@using System.Text.Json

@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IWebHostEnvironment HostEnvironment
@inject NavigationManager NavManager
@inject EmisorOnboardingService EmisorOnboardingService
@inject EmisionControlService EmisionControlService

@rendermode InteractiveServer

@{
    var filteredEmisores = EmisoresFiltrados.ToList();
    var totalConFirma = emisores.Count(TieneFirmaConfigurada);
    var totalPendientes = Math.Max(emisores.Count(e => e.Estado == true) - totalConFirma, 0);
}

<PageTitle>Firma electronica | Numerica e-fact</PageTitle>

<div class="entity-shell" data-tour="firma.page">
    @if (MostrarVolverInicioOnboarding)
    {
        <div class="breadcrumb-container">
            <button type="button" class="breadcrumb-home-btn" @onclick='() => NavManager.NavigateTo("/dashboard")'>
                <i class="bi bi-house-door"></i>
                <span>Volver al inicio</span>
            </button>
        </div>
    }

    <section class="entity-hero" data-tour="firma.hero" style="display:none;">
        <div class="hero-copy">
            <span class="hero-eyebrow">Configuración de seguridad</span>
            <h2>Firma electrónica</h2>
            <p>
                Carga y administra tu certificado de firma electrónica (.p12) para autorizar
                legalmente los comprobantes electrónicos ante el SRI.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Firmas configuradas</span>
                <strong>@totalConFirma</strong>
                <small>Certificados activos y listos para firmar.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Firmas pendientes</span>
                <strong>@totalPendientes</strong>
                <small>Emisores activos que requieren configuración de firma.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Emisores totales</span>
                <strong>@emisores.Count</strong>
                <small>Empresas registradas en tu cuenta.</small>
            </article>
        </div>
    </section>
    <section class="quick-action-bar" aria-label="Acciones rapidas de firma">
        <button type="button" class="quick-action-card quick-action-primary" @onclick="IrAEmisor">
            <span class="quick-action-icon"><i class="bi bi-building"></i></span>
            <span>
                <strong>Datos del emisor</strong>
                <small>Volver al registro fiscal</small>
            </span>
        </button>

        <button type="button" class="quick-action-card" @onclick="IrAComprarFirma">
            <span class="quick-action-icon quick-action-icon-green"><i class="bi bi-cart-check"></i></span>
            <span>
                <strong>Comprar firma</strong>
                <small>Continuar en eRúbrica</small>
            </span>
        </button>

        <div class="quick-action-search">
            <i class="bi bi-search"></i>
            <input type="search"
                   name="firma_busqueda_emisor"
                   placeholder="Buscar por razon social o RUC..."
                   @bind="filtro"
                   @bind:event="oninput"
                   @onfocus="DesbloquearBusquedaFirma"
                   autocomplete="new-password"
                   autocorrect="off"
                   autocapitalize="off"
                   spellcheck="false"
                   data-form-type="other"
                   data-lpignore="true"
                   readonly="@bloquearAutocompletadoBusqueda" />
        </div>
    </section>



    <section class="entity-grid">
        <section class="table-card" data-tour="firma.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado activo</span>
                    <h3>Firmas por emisor</h3>
                </div>
                <div class="table-head-actions">
                    <span class="table-badge">@totalConFirma configuradas</span>
                    <button type="button" class="primary-btn" @onclick="AbrirModalFirma" disabled="@(!emisores.Any())">
                        <i class="bi bi-plus-lg"></i>
                        <span>Agregar firma</span>
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(debugError))
            {
                <div class="status-banner status-banner-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@debugError</span>
                </div>
            }

            @if (cargando)
            {
                <div class="state-card">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando firmas</h3>
                    <p>Preparando los emisores disponibles para configurar certificado y clave.</p>
                </div>
            }
            else if (!filteredEmisores.Any())
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="bi bi-shield-x"></i>
                    </div>
                    <h3>No hay emisores para configurar</h3>
                    <p>Primero registra un emisor activo y luego vuelve para cargar su firma electronica.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table entity-table entity-table-firmas mb-0">
                        <thead>
                            <tr>
                                <th>Emisor</th>
                                <th>RUC</th>
                                <th>Firma</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in filteredEmisores)
                            {
                                var firmaConfigurada = TieneFirmaConfigurada(e);
                                <tr class="@(firmaModel.Codigo == e.Codigo ? "is-selected" : string.Empty)">
                                    <td>
                                        <div class="cell-main cell-main-stacked">
                                            <strong>@GetNombreEmisor(e)</strong>
                                            <span>@(string.IsNullOrWhiteSpace(e.NomComercial) ? "Sin nombre comercial" : e.NomComercial)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="code-pill">@(string.IsNullOrWhiteSpace(e.Ruc) ? "Sin RUC" : e.Ruc)</span>
                                    </td>
                                    <td>
                                        <span class="signature-status @(firmaConfigurada ? "is-ready" : "is-pending")">
                                            @(firmaConfigurada ? "Configurada" : "Pendiente")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-group">
                                            <button type="button"
                                                    class="action-btn action-edit"
                                                    title="Gestionar firma"
                                                    @onclick="() => AbrirModalFirma(e)">
                                                <i class="bi bi-shield-check"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="editor-card entity-editor-card" data-tour="firma.editor" style="display:none;">
            <div class="editor-head">
                <div>
                    <span class="panel-kicker">Configuracion de firma</span>
                    <h3>@(FirmaDisponible ? GetTituloEditor() : "Firma electronica")</h3>
                    <p>Actualiza el archivo .p12 y la clave que se usaran para emitir comprobantes.</p>
                </div>
                <span class="editor-badge @(FirmaConfiguradaActual ? "editor-badge-ready" : "editor-badge-new")">
                    @(FirmaConfiguradaActual ? "Configurada" : "Pendiente")
                </span>
            </div>

            @if (!FirmaDisponible)
            {
                <div class="editor-body">
                    <div class="signature-empty-state">
                        <i class="bi bi-building-check"></i>
                        <div>
                            <strong>Primero guarda los datos del emisor</strong>
                            <p>Cuando exista un emisor activo, aqui podras configurar o actualizar su firma.</p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="editor-body entity-form-legacy">
                    <div class="signature-emisor-summary">
                        <div>
                            <span>Emisor seleccionado</span>
                            <strong>@GetTituloEditor()</strong>
                        </div>
                        <small>@(string.IsNullOrWhiteSpace(firmaModel.Ruc) ? "RUC no disponible" : $"RUC {firmaModel.Ruc}")</small>
                    </div>

                    @if (esAsociado)
                    {
                        <div class="status-banner status-banner-info status-banner-inline">
                            <i class="bi bi-lock"></i>
                            <span>Los usuarios asociados pueden consultar la firma, pero no modificarla.</span>
                        </div>
                    }

                    <div class="signature-editor-body">
                        <div>
                            <label class="form-label small fw-bold">Archivo de firma</label>
                            <div class="signature-choice-grid">
                                <label class="signature-choice signature-choice-upload">
                                    <i class="bi bi-upload"></i>
                                    <span>
                                        <strong>Subir firma</strong>
                                        <small>Archivo .p12 de hasta 5 MB</small>
                                    </span>
                                    <InputFile accept=".p12" OnChange="SubirPathCertificado" disabled="@esAsociado" />
                                </label>

                                <button type="button" class="signature-choice signature-choice-buy" @onclick="IrAComprarFirma">
                                    <i class="bi bi-cart-check"></i>
                                    <span>
                                        <strong>Comprar firma</strong>
                                        <small>Continuar en eRúbrica</small>
                                    </span>
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(NombrePathCertificadoActual))
                            {
                                <div class="signature-current">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>@NombrePathCertificadoActual</span>
                                    @if (!esAsociado)
                                    {
                                        <button type="button" title="Quitar certificado" @onclick="QuitarPathCertificado">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <div>
                            <label class="form-label small fw-bold">Clave del certificado</label>
                            <div class="cert-password-shell">
                                <input type="@tipoPassword"
                                       class="form-control form-control-sm cert-password-input"
                                       placeholder="Ingresa la clave del archivo .p12"
                                       @bind="firmaModel.ClaveCertificado"
                                       autocomplete="off"
                                       disabled="@esAsociado" />
                                <button class="cert-password-eye" type="button" @onclick="TogglePasswordVisibility" title="Mostrar u ocultar clave">
                                    <i class="bi @(mostrarPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>

                            @if (TieneClaveCertificadoActual)
                            {
                                <div class="signature-current">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Clave configurada</span>
                                    @if (!esAsociado)
                                    {
                                        <button type="button" title="Quitar clave" @onclick="QuitarClaveCertificado">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="signature-editor-actions">
                    <button type="button"
                            class="secondary-btn"
                            @onclick="CargarTodo"
                            disabled="@guardandoFirma">
                        <i class="bi bi-arrow-clockwise"></i>
                        Refrescar
                    </button>

                    <button type="button"
                            class="primary-btn @(guardandoFirma ? "n-auto-loading" : null)"
                            @onclick="GuardarFirma"
                            disabled="@(esAsociado || guardandoFirma)">
                        @if (!guardandoFirma)
                        {
                            <i class="bi bi-shield-check"></i>
                        }
                        @(guardandoFirma ? "Guardando firma..." : "Guardar firma")
                    </button>
                </div>
            }
        </section>
    </section>
</div>

