    private static string? ResolveServiceLogo(string? clave) =>
        clave?.ToLower() switch
        {
            "efact" or "e-fact" => "/images/LogoPrincipal.svg",
            "econta" or "e-conta" or "econtax" or "e-contax" => "/images/econtax/LogoEContaxWord.png",
            "edeclara" or "e-declara" => "/images/edeclara/LogoEDeclara.png",
            "esign" or "e-sign" => "/images/esign/erubrica.png",
            _ => null
        };
 
    private static string GetServiceDescription(AppServiceCatalogItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.Descripcion))
        {
            return item.Descripcion;
        }
 
        return item.Clave.ToLower() switch
        {
            "efact" or "e-fact" => "Facturacion electronica con acceso libre para usuarios registrados.",
            "econta" or "e-conta" or "econtax" or "e-contax" => "Contabilidad y tributacion con herramientas habilitadas por suscripcion.",
            "edeclara" or "e-declara" => "Declaraciones tributarias y control fiscal segun tu plan activo.",
            "epeople" or "e-people" => "Gestion de talento humano y colaboradores bajo suscripcion.",
            "esign" or "e-sign" => "Firma electronica y certificado digital para firma de documentos en linea.",
            "backoffice" => "Acceso exclusivo para administradores y personal de backoffice.",
            _ => "Accede a las herramientas disponibles para tu cuenta."
        };
    }

    private string GetServicesListClass()
    {
        var count = Math.Clamp(servicios.Count, 1, 5);
        return $"services-list services-count-{count}";
    }

    private static string ResolveAvatarUrl(string? avatarUrl)
    {
        if (string.IsNullOrWhiteSpace(avatarUrl) ||
            avatarUrl.EndsWith("default.png", StringComparison.OrdinalIgnoreCase))
        {
            return DefaultAvatarUrl;
        }

        if (avatarUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase) ||
            avatarUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            avatarUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            avatarUrl.StartsWith("/", StringComparison.Ordinal))
        {
            return avatarUrl;
        }

        return avatarUrl.StartsWith("images/", StringComparison.OrdinalIgnoreCase)
            ? $"/{avatarUrl}"
            : avatarUrl;
    }

    private static string BuildDisplayName(ClaimsPrincipal user)
    {
        var nombres = user.Identity?.Name ?? string.Empty;
        var apellidos = user.FindFirst(ClaimTypes.Surname)?.Value ?? string.Empty;
        return string.Join(" ", new[] { nombres, apellidos }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
    }

