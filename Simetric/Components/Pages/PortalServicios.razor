            "econta" or "e-conta" or "econtax" or "e-contax" => ("#00A896", "#007C73", "rgba(0,168,150,0.25)"),
            "edeclara" or "e-declara" => ("#6e40c9", "#4e2d91", "rgba(110,64,201,0.25)"),
            "epeople" or "e-people" => ("#e06c1a", "#a84d11", "rgba(224,108,26,0.25)"),
            "esign" or "e-sign" => ("#2E7D32", "#1B5E20", "rgba(80, 200, 120, 0.25)"),
            "backoffice" => ("#0f172a", "#090d16", "rgba(15,23,42,0.25)"),
