    private List<AppServiceCatalogItem> servicios = new();
    private bool _cerrandoSesion;
    private string? fotoUrl;
    private const string DefaultAvatarUrl = "/images/avatars/Avatar-Boy.jpg";
    private bool cargando = true;
    private string? errorCarga;
    private string? nombreUsuario;
    private string? servicioSeleccionado;
    private string? procesandoClave;
    private int usuarioId;
    private bool esSuperAdmin;
    private bool isTestUser;
    private bool mostrarModalEDeclara;
    private bool procesandoPagoEDeclaraIndividual;
    private bool procesandoPagoEDeclaraAsesor;
    private bool procesandoPagoEDeclaraEmpresarial;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateToIfNeeded("/login", forceLoad: true);
            return;
        }

        if (!int.TryParse(user.FindFirst("IdUsuario")?.Value, out usuarioId) || usuarioId <= 0)
        {
            NavManager.NavigateToIfNeeded("/login", forceLoad: true);
            return;
        }

        esSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        if (!esSuperAdmin)
        {
            await SelectedAppServiceState.SetCurrentServiceKeyAsync(AppAccessService.FreeServiceKey);
            NavManager.NavigateToIfNeeded("/dashboard");
            return;
        }

        var emailClaim = user.FindFirst(ClaimTypes.Email)?.Value ?? user.FindFirst("Email")?.Value;
        var userEmail = emailClaim?.Trim().ToLowerInvariant();
        isTestUser = string.Equals(userEmail, "arianna.caceres.chicaiza@estudiantes.cordillera.edu.ec", StringComparison.OrdinalIgnoreCase) ||
                     string.Equals(userEmail, "caceresarianna12@gmail.com", StringComparison.OrdinalIgnoreCase) ||
                     string.Equals(userEmail, "caceres.ariana.ueld@gmail.com", StringComparison.OrdinalIgnoreCase);

        nombreUsuario = BuildDisplayName(user);

        // Avatar: primero el claim (rápido), si está vacío va a la BD (siempre actualizado)
        var avatarClaim = user.FindFirst("AvatarUrl")?.Value;
        if (!string.IsNullOrWhiteSpace(avatarClaim) &&
            !avatarClaim.EndsWith("default.png", StringComparison.OrdinalIgnoreCase))
        {
            fotoUrl = ResolveAvatarUrl(avatarClaim);
        }
        else
        {
            try
            {
                var userDb = await UsuarioService.ObtenerUsuarioPorId(usuarioId);
                fotoUrl = ResolveAvatarUrl(userDb?.AvatarUrl);
            }
            catch
            {
                fotoUrl = DefaultAvatarUrl;
            }
        }

        servicioSeleccionado = await SelectedAppServiceState.GetCurrentServiceKeyAsync();

        try
        {
            var allServices = (await AppAccessService.GetCatalogForUserAsync(usuarioId, esSuperAdmin))
                .ToList();
            if (esSuperAdmin)
            {
                servicios = allServices;
            }
            else
            {
                servicios = allServices
                    .Where(s =>
                        !string.Equals(s.Clave, "backoffice", StringComparison.OrdinalIgnoreCase) &&
                        (s.TieneAcceso || (isTestUser && (string.Equals(s.Clave, "edeclara", StringComparison.OrdinalIgnoreCase) || string.Equals(s.Clave, "e-declara", StringComparison.OrdinalIgnoreCase)))))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            errorCarga = $"No se pudo cargar el portal de servicios: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender) => Task.CompletedTask;

    private async Task IrAlServicioAsync(AppServiceCatalogItem item)
    {
        procesandoClave = item.Clave;
        try
        {
            await SelectedAppServiceState.SetCurrentServiceKeyAsync(item.Clave);

            if (!item.TieneAcceso)
            {
                if ((string.Equals(item.Clave, "edeclara", StringComparison.OrdinalIgnoreCase) || string.Equals(item.Clave, "e-declara", StringComparison.OrdinalIgnoreCase)) && isTestUser)
                {
                    mostrarModalEDeclara = true;
                    procesandoClave = null;
                    StateHasChanged();
                    return;
                }

                NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(item.Clave)}", forceLoad: true);
                return;
            }

            if (string.Equals(item.Clave, AppAccessService.FreeServiceKey, StringComparison.OrdinalIgnoreCase))
            {
                await EmisorOnboardingService.RefreshRequirementAsync(usuarioId);
                NavManager.NavigateToIfNeeded(item.RutaAcceso);
                return;
            }

            NavManager.NavigateToIfNeeded(item.RutaAcceso);
        }
        finally
        {
            procesandoClave = null;
        }
    }

    private async Task CerrarSesionAsync()
    {
        if (_cerrandoSesion)
            return;

        _cerrandoSesion = true;

        try
        {
            await JS.InvokeVoidAsync("numericaLogoutAndRedirect", "/login");
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }

