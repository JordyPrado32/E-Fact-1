<div class="portal-viewport">
    <div class="content-side">

        <div class="content-header">
            <div class="portal-header">
                <div class="portal-title-block">
                    <span class="portal-header-logo">
                        <img src="/images/LogoNumerica.svg" alt="Numerica" onerror="this.style.display='none'" />
                    </span>
                    <div class="portal-title-copy">
                        <h1>Servicios Disponibles</h1>
                        <p>Selecciona el modulo al que deseas ingresar</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(nombreUsuario))
                {
                    <div class="user-info-bar">
                        <div class="user-avatar-circle">
                            @if (!string.IsNullOrWhiteSpace(fotoUrl))
                            {
                                <img src="@fotoUrl" alt="Avatar del usuario"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <span class="avatar-initials" style="display:none;">
                                    @(string.Concat(nombreUsuario.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                        .Take(2).Select(w => w[0].ToString().ToUpper())))
                                </span>
                            }
                            else
                            {
                                <span class="avatar-initials">
                                    @(string.Concat(nombreUsuario.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                        .Take(2).Select(w => w[0].ToString().ToUpper())))
                                </span>
                            }
                        </div>
                        <div class="user-info-text">
                            <strong>@nombreUsuario</strong>
                            <span class="user-session-row">
                                <span class="user-session-dot"></span>
                                Sesion activa
                            </span>
                        </div>
                        <button type="button" class="btn-logout" @onclick="CerrarSesionAsync">
                            <i class="ri-logout-box-r-line"></i>
                            Salir
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="content-scroll">
            <section class="portal-welcome">
                <div class="portal-welcome-content">
                    <span class="portal-eyebrow">Numerica Software</span>
                    <h2>Bienvenido, @(string.IsNullOrWhiteSpace(nombreUsuario) ? "Usuario" : nombreUsuario)</h2>
                    <p>Tus servicios activos estan listos para usarse</p>
                </div>
                <div class="portal-welcome-badges" aria-label="Estado de servicios">
                    <span class="portal-chip"><i class="ri-checkbox-circle-line"></i>Disponible</span>
                    <span class="portal-chip"><i class="ri-pulse-line"></i>Actual</span>
                    <span class="portal-chip"><i class="ri-shield-check-line"></i>Suscripcion activa</span>
                </div>
            </section>

            <div class="portal-inner">

                @if (cargando)
                {
                    <div class="portal-state">Cargando tus servicios disponibles...</div>
                }
                else if (!string.IsNullOrWhiteSpace(errorCarga))
                {
                    <div class="portal-state">@errorCarga</div>
                }
                else
                {
                    <div class="@GetServicesListClass()">
                        @for (var index = 0; index < servicios.Count; index++)
                        {
                            var item = servicios[index];
                            var (cardColor, cardDark, cardGlow) = ResolveServiceColors(item.Clave);
                            var logoSource = ResolveServiceLogo(item.Clave);
                            var isCurrent = string.Equals(item.Clave, servicioSeleccionado, StringComparison.OrdinalIgnoreCase);

                            <article class="service-card"
                                     style="@($"--card-color:{cardColor};--card-dark:{cardDark};--card-glow:{cardGlow};")">
                                <div class="card-hero">
                                    <div class="service-logo-panel">
                                        @if (!string.IsNullOrWhiteSpace(logoSource))
                                        {
                                            <img class="service-logo service-logo-@item.Clave.ToLower()" src="@logoSource" alt="@item.Nombre" onerror="this.style.display='none'" />
                                        }
                                        else
                                        {
                                            <span class="service-logo-fallback">@item.Nombre</span>
                                        }
                                    </div>
                                </div>

                                <div class="card-body">
                                    <div class="card-divider"></div>
                                    <h2 class="card-name">@item.Nombre</h2>
                                    <p class="card-description">@GetServiceDescription(item)</p>

                                    <div class="service-badges">
                                        <span class="service-badge">@(item.TieneAcceso ? "Disponible" : "Plan requerido")</span>
                                        @if (isCurrent)
                                        {
                                            <span class="service-badge service-badge-current">Actual</span>
                                        }
                                        <span class="service-badge service-badge-soft">
                                            @(item.TieneAcceso ? "Suscripcion activa" : "Solicitar acceso")
                                        </span>
                                    </div>

                                    <div class="card-actions">
                                        <button type="button"
                                                class="btn-service-primary"
                                                @onclick="() => IrAlServicioAsync(item)"
                                                disabled="@(procesandoClave == item.Clave)">
                                            @(procesandoClave == item.Clave
                                                ? "Abriendo..."
                                                : item.TieneAcceso ? "Ingresar" : "Ver suscripcion")
                                        </button>

                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }

            </div>
        </div>
    </div>
</div>

