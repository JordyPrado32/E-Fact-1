@page "/portal-servicios"
@layout Simetric.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Simetric.Extensions
@using Simetric.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject IUsuarioService UsuarioService
@inject NavigationManager NavManager
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject EmisorOnboardingService EmisorOnboardingService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Portal de servicios | Numerica</PageTitle>

<style>
    @FontFaceCss

    :root {
        --n-blue: #006bb5;
        --n-blue-dark: #004a7c;
        --n-blue-light: #e6f0f8;
        --n-dark: #2c3e50;
        --white: #ffffff;
        --bg-color: #f4f7f6;
    }

    html, body {
        height: 100%;
        margin: 0;
        overflow: hidden;
        font-family: "Montserrat", sans-serif;
        background: #d7ecfb;
    }

    .portal-viewport {
        --portal-shell-padding: clamp(1rem, 2.4vw, 2rem);
        position: relative;
        isolation: isolate;
        height: 100dvh;
        max-height: 100dvh;
        width: 100%;
        overflow: hidden;
        padding: var(--portal-shell-padding);
        background:
            radial-gradient(ellipse at 16% 8%, rgba(0, 107, 181, 0.28), transparent 34rem),
            radial-gradient(ellipse at 92% 18%, rgba(55, 156, 219, 0.3), transparent 32rem),
            radial-gradient(ellipse at 72% 92%, rgba(0, 74, 124, 0.16), transparent 34rem),
            linear-gradient(140deg, #edf8ff 0%, #d2ebfb 44%, #a9d4ee 100%);
    }

        .portal-viewport::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: -2;
            pointer-events: none;
            opacity: 0.52;
            background-image:
                linear-gradient(rgba(0, 74, 124, 0.1) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 74, 124, 0.1) 1px, transparent 1px);
            background-size: 74px 74px;
            mask-image: linear-gradient(140deg, rgba(0,0,0,0.9), transparent 72%);
        }

        .portal-viewport::after {
            content: "";
            position: fixed;
            width: min(46vw, 34rem);
            aspect-ratio: 1;
            right: -11rem;
            bottom: -13rem;
            z-index: -1;
            border: 1.8rem solid rgba(0, 107, 181, 0.08);
            border-radius: 50%;
        }

    .brand-side {
        flex: 0 0 54%;
        background: linear-gradient(135deg, var(--n-blue) 0%, var(--n-blue-dark) 100%);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(2.5rem, 4vw, 5rem);
        position: relative;
        overflow: hidden;
    }

        .brand-side::before,
        .brand-side::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            z-index: 0;
        }

        .brand-side::before {
            width: 400px;
            height: 400px;
            top: -100px;
            left: -100px;
        }

        .brand-side::after {
            width: 600px;
            height: 600px;
            bottom: -200px;
            right: -150px;
        }

    .numeric-digits-layer {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
    }

    .numerica-digit {
        position: absolute;
        z-index: 1;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1;
        user-select: none;
        mix-blend-mode: screen;
        text-shadow: 0 0 20px rgba(255,255,255,0.34), 0 0 42px rgba(255,255,255,0.22), 0 0 64px rgba(184,220,255,0.1);
        font-variant-numeric: tabular-nums;
        will-change: transform, opacity;
    }

    @KeyframesDigitFloatCss

    .numeric-digits-layer::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        background: radial-gradient(circle at 18% 24%, rgba(255,255,255,0.14), transparent 34%), radial-gradient(circle at 74% 72%, rgba(255,255,255,0.11), transparent 30%);
        opacity: 0.78;
    }

    .glass-card {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 24px;
        padding: clamp(2rem, 2.8vw, 3rem);
        width: min(100%, 31rem);
        max-width: 31rem;
        min-height: clamp(29rem, 64vh, 31.5rem);
        aspect-ratio: 1 / 1;
        position: relative;
        z-index: 2;
        box-shadow: 0 25px 50px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        gap: 0.9rem;
    }

    .brand-logo-shell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        max-width: 100%;
        padding: 0.8rem 1.1rem;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0.08));
        border: 1px solid rgba(255,255,255,0.26);
        box-shadow: 0 16px 30px rgba(2,35,66,0.16), inset 0 1px 0 rgba(255,255,255,0.18);
        backdrop-filter: blur(10px);
    }

    .brand-logo {
        width: clamp(11rem, 26vw, 12.75rem);
        max-width: 100%;
        display: block;
        filter: drop-shadow(0 8px 18px rgba(1,21,40,0.24)) saturate(1.04) contrast(1.04);
    }

    .login-brand-heading {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-weight: 600;
        letter-spacing: 0.05em;
        line-height: 1;
        font-size: clamp(1.45rem, 2vw, 1.85rem);
    }

    .services-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: 0.5rem;
    }

    .service-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.38rem 0.85rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        border: 1px solid rgba(255,255,255,0.3);
        background: rgba(255,255,255,0.12);
        color: #fff;
        backdrop-filter: blur(4px);
    }

    .service-pill-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

    .product-signature {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.16);
        color: rgba(255,255,255,0.84);
        font-size: 0.9rem;
        letter-spacing: 0.01em;
        min-height: 56px;
    }

    .product-signature-badge {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.18);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: none;
        box-shadow: 0 14px 28px rgba(0,0,0,0.12);
    }

        .product-signature-badge img {
            width: 26px;
            height: 26px;
            display: block;
            object-fit: contain;
            transform: translateY(-1px);
        }

    /* ── CONTENT SIDE ── */
    .content-side {
        position: relative;
        width: min(100%, 1560px);
        height: calc(100dvh - var(--portal-shell-padding) * 2);
        max-height: 820px;
        margin: 0 auto;
        background:
            linear-gradient(180deg, rgba(246,252,255,0.82), rgba(219,237,249,0.84));
        border: 1px solid rgba(255,255,255,0.92);
        border-radius: 34px;
        box-shadow: 0 30px 70px rgba(14, 61, 102, 0.18), inset 0 1px 0 rgba(255,255,255,0.85);
        backdrop-filter: blur(18px);
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
    }

        .content-side::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(135deg, rgba(0,107,181,0.12), transparent 30%),
                radial-gradient(ellipse at 28% 6%, rgba(255,255,255,0.62), transparent 26rem),
                radial-gradient(ellipse at 96% 96%, rgba(0,107,181,0.1), transparent 28rem);
            opacity: 0.9;
        }

    .content-header {
        position: relative;
        z-index: 1;
        flex-shrink: 0;
        padding: clamp(1.35rem, 2.4vw, 2.35rem) clamp(1.25rem, 3vw, 2.5rem) 0;
    }

    .content-scroll {
        position: relative;
        z-index: 1;
        flex: 1 1 auto;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 1rem clamp(1.25rem, 3vw, 2.5rem) clamp(2rem, 3vw, 2.7rem);
    }

    .portal-inner {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        animation: slideUp 0.6s ease-out forwards;
    }

    @KeyframesSlideUpCss

    /* ── HEADER ── */
    .portal-header {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(20rem, 28rem);
        align-items: center;
        gap: clamp(1rem, 2.6vw, 2rem);
    }

        .portal-header h1 {
            font-size: clamp(2rem, 3.2vw, 3.05rem);
            font-weight: 800;
            color: #203a52;
            margin: 0;
            line-height: 1.05;
        }

    .portal-title-block {
        display: flex;
        align-items: center;
        gap: clamp(0.8rem, 1.5vw, 1.15rem);
        min-width: 0;
    }

    .portal-title-copy {
        min-width: 0;
    }

        .portal-title-copy p {
            margin: 0.45rem 0 0;
            color: #66798b;
            font-size: clamp(0.92rem, 1.3vw, 1.08rem);
            line-height: 1.4;
        }

    .portal-header-logo {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.9);
        border: 1px solid rgba(176,198,214,0.9);
        box-shadow: 0 16px 34px rgba(41,72,101,0.12);
        flex: 0 0 auto;
    }

        .portal-header-logo img {
            width: 34px;
            height: 34px;
            object-fit: contain;
            display: block;
        }

    .user-info-bar {
        justify-self: end;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        margin-top: 0;
        padding: 0.85rem 1rem;
        border-radius: 22px;
        background: rgba(238, 247, 255, 0.72);
        border: 1px solid rgba(0,107,181,0.18);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 16px 36px rgba(0,74,124,0.08);
        backdrop-filter: blur(12px);
        min-width: 0;
        width: min(100%, 28rem);
    }

    .user-avatar-circle {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--n-blue), var(--n-blue-dark));
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        flex-shrink: 0;
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 22px rgba(0,74,124,0.18);
    }

        .user-avatar-circle img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .user-avatar-circle img[src*="Bandera-"] {
            object-fit: contain !important;
        }

        .user-avatar-circle .avatar-initials {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
        }

    .user-info-text {
        flex: 1;
        min-width: 0;
    }

        .user-info-text strong {
            display: block;
            color: var(--n-dark);
            font-size: 0.95rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-session-row {
            display: inline-flex;
            align-items: center;
            gap: 0.38rem;
            margin-top: 0.12rem;
            font-size: 0.78rem;
            color: #7a8794;
        }

    .user-session-dot {
        width: 0.48rem;
        height: 0.48rem;
        border-radius: 50%;
        background: #19b47e;
        box-shadow: 0 0 0 0.24rem rgba(25,180,126,0.12);
    }

    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.48rem 0.8rem;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 700;
        background: rgba(255,255,255,0.58);
        color: #b91c1c;
        border: 1px solid rgba(220,38,38,0.18);
        cursor: pointer;
        transition: background 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

        .btn-logout:hover {
            background: rgba(220,38,38,0.1);
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(220,38,38,0.08);
        }

    .portal-welcome {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: clamp(1.1rem, 2.2vw, 1.75rem);
        padding: clamp(1rem, 2vw, 1.25rem);
        border-radius: 24px;
        background:
            linear-gradient(135deg, rgba(255,255,255,0.82), rgba(235,247,255,0.72)),
            radial-gradient(ellipse at 90% 10%, rgba(0,107,181,0.14), transparent 18rem);
        border: 1px solid rgba(184, 211, 230, 0.72);
        box-shadow: 0 18px 40px rgba(22, 70, 112, 0.08);
    }

        .portal-welcome::after {
            content: "";
            position: absolute;
            inset: auto -4rem -5rem auto;
            width: 18rem;
            aspect-ratio: 1;
            border: 1rem solid rgba(0,107,181,0.045);
            border-radius: 50%;
        }

    .portal-welcome-content {
        position: relative;
        z-index: 1;
        min-width: 0;
    }

    .portal-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 0.35rem;
        color: var(--n-blue-dark);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

        .portal-eyebrow::before {
            content: "";
            width: 0.5rem;
            height: 0.5rem;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--n-blue), #4cc9f0);
            box-shadow: 0 0 0 0.25rem rgba(0,107,181,0.12);
        }

    .portal-welcome h2 {
        margin: 0;
        color: #203a52;
        font-size: clamp(1.12rem, 1.9vw, 1.48rem);
        font-weight: 800;
        line-height: 1.15;
    }

    .portal-welcome p {
        margin: 0.35rem 0 0;
        color: #6b7d8e;
        font-size: 0.92rem;
        line-height: 1.45;
    }

    .portal-welcome-badges {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 0.55rem;
        min-width: min(100%, 20rem);
    }

    .portal-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        padding: 0.48rem 0.72rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.8);
        border: 1px solid rgba(0,107,181,0.13);
        color: #35546d;
        font-size: 0.76rem;
        font-weight: 800;
        box-shadow: 0 10px 22px rgba(0,74,124,0.06);
    }

        .portal-chip i {
            color: var(--n-blue);
            font-size: 0.95rem;
        }

    /* ── SERVICES CATALOG ── */
    .services-list {
        position: relative;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        align-items: stretch;
        justify-content: stretch;
        gap: clamp(1rem, 1.7vw, 1.35rem);
        margin-top: clamp(1.15rem, 2.4vw, 1.8rem);
    }

    .services-count-1 {
        grid-template-columns: minmax(min(100%, 18rem), 25rem);
        justify-content: center;
    }

    .services-count-2 {
        grid-template-columns: repeat(2, minmax(min(100%, 18rem), 25rem));
        justify-content: center;
    }

    .services-count-3 {
        grid-template-columns: repeat(3, minmax(min(100%, 18rem), 25rem));
        justify-content: center;
    }

    .services-count-4 {
        grid-template-columns: repeat(4, minmax(min(100%, 15rem), 22rem));
        justify-content: center;
    }

    .services-count-5 {
        grid-template-columns: repeat(5, minmax(min(100%, 14rem), 20rem));
        justify-content: center;
    }

    /* ── SERVICE CARD ── */
    .service-card {
        position: relative;
        isolation: isolate;
        border-radius: 24px;
        background: rgba(255,255,255,0.94);
        border: 1px solid rgba(255,255,255,0.96);
        padding: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        width: 100%;
        min-width: 0;
        height: 100%;
        min-height: 25.25rem;
        transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
        box-shadow: 0 18px 42px rgba(34,63,88,0.12);
    }

        .service-card::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            background: linear-gradient(180deg, color-mix(in srgb, var(--card-color) 10%, transparent), transparent 46%);
            opacity: 0;
            transition: opacity 0.24s ease;
        }

        .service-card:hover {
            transform: translateY(-7px);
            border-color: color-mix(in srgb, var(--card-color) 28%, white);
            box-shadow: 0 28px 52px var(--card-glow, rgba(0,0,0,0.13));
        }

        .service-card:hover::before {
            opacity: 1;
        }

    .card-hero {
        position: relative;
        min-height: 8.2rem;
        border-radius: 24px 24px 0 0;
        background:
            radial-gradient(ellipse at 22% 18%, rgba(255,255,255,0.28), transparent 10rem),
            linear-gradient(156deg, rgba(255,255,255,0.18) 0%, transparent 44%),
            linear-gradient(135deg, var(--card-color), var(--card-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.25rem 1rem 1rem;
        overflow: hidden;
    }

        .card-hero::after {
            content: "";
            position: absolute;
            inset: auto -18% -58% 10%;
            height: 11rem;
            border-radius: 999px;
            background: rgba(255,255,255,0.1);
            transform: rotate(-9deg);
        }

    .service-logo-panel {
        position: relative;
        z-index: 1;
        width: min(100%, 11.8rem);
        min-height: 4.05rem;
        border-radius: 18px;
        background: rgba(255,255,255,0.94);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.72rem 1rem;
        box-shadow: 0 16px 32px rgba(4,34,62,0.16), inset 0 1px 0 rgba(255,255,255,0.82);
    }

    .service-logo {
        display: block;
        max-width: 100%;
        max-height: 2.55rem;
        object-fit: contain;
    }

    .service-logo-e-fact {
        max-height: 2.2rem;
    }

    .service-logo-e-sign {
        max-height: 4rem;
    }

    .service-logo-e-conta {
        max-height: 2.15rem;
        transform: scale(1.08);
    }

    .service-logo-e-declara {
        max-height: 2.3rem;
    }

    .service-logo-fallback {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        color: var(--card-color);
        font-size: 1.18rem;
        letter-spacing: 0;
        line-height: 1;
        text-align: center;
    }

    .card-body {
        position: relative;
        padding: 1.2rem 1.15rem 1.2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.72rem;
        flex: 1;
        text-align: center;
        background:
            linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        border-radius: 0 0 24px 24px;
    }

    .card-divider {
        width: 3.4rem;
        height: 0.22rem;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--card-color), var(--card-dark));
    }

    .card-name {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-size: 1rem;
        color: var(--n-dark);
        margin: 0;
        letter-spacing: 0;
        line-height: 1.15;
    }

    .card-description {
        margin: 0;
        color: #6a7a89;
        font-size: 0.82rem;
        line-height: 1.48;
        min-height: 4.15rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .service-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.45rem;
        min-height: 2rem;
    }

    .service-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.34rem 0.58rem;
        border-radius: 999px;
        background: color-mix(in srgb, var(--card-color) 9%, white);
        color: var(--card-dark);
        border: 1px solid color-mix(in srgb, var(--card-color) 18%, white);
        font-size: 0.68rem;
        font-weight: 800;
        line-height: 1;
    }

    .service-badge-soft {
        background: #f8fbfe;
        color: #657789;
        border-color: #e7eef5;
    }

    .service-badge-current {
        background: linear-gradient(135deg, color-mix(in srgb, var(--card-color) 14%, white), #ffffff);
        color: var(--card-dark);
        border-color: color-mix(in srgb, var(--card-color) 28%, white);
        box-shadow: 0 10px 20px var(--card-glow, rgba(0,0,0,0.1));
    }

    .card-actions {
        width: 100%;
        margin-top: auto;
        padding-top: 0.8rem;
        border-top: 1px solid #e8edf3;
        display: flex;
        gap: 0.65rem;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
    }

    .btn-service-primary {
