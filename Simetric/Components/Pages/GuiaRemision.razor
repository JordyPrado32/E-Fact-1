    private async Task BuscarFacturaAsync()
    {
        errorCarga = null;

        if (string.IsNullOrWhiteSpace(numFacturaBuscar) || numFacturaBuscar.Trim().Length < 3)
        {
            estadoCarga = "Escribe al menos 3 digitos";
            return;
        }

        try
        {
            estadoCarga = "Buscando factura...";
            var dto = await FacturacionService.GetFacturaPorNumeroUsuarioAsync(numFacturaBuscar.Trim(), currentUserId);

            if (dto?.Factura == null)
            {
                estadoCarga = "No se encontro la factura.";
                LimpiarFacturaReferencia();
                return;
            }

            AplicarFacturaReferencia(dto);

            estadoCarga = string.IsNullOrWhiteSpace(dto.Factura.Guiaremision)
                ? "Factura cargada correctamente."
                : $"La factura ya registra la guia {dto.Factura.Guiaremision}.";
        }
        catch (Exception ex)
        {
            estadoCarga = "Error";
            errorCarga = ex.Message;
        }
    }

