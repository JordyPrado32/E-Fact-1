        if (e.Key == "Enter" && sugerenciasProductosDetalle.Any())
            await SeleccionarProductoDetalleAsync(detalle, sugerenciasProductosDetalle[0]);
    }

    private static void AplicarProductoAlDetalle(
        DetalleGuiaRemision detalle,
        ProductoLookupDetalleDto producto)
    {
        detalle.CodInterno = string.IsNullOrWhiteSpace(producto.Codprincipal)
            ? producto.Codproducto.ToString(CultureInfo.InvariantCulture)
            : producto.Codprincipal;
        detalle.CodAdicional = producto.Codauxiliar;
        detalle.Descripcion = producto.Descripcion;
        detalle.Cantidad = detalle.Cantidad.GetValueOrDefault() > 0 ? detalle.Cantidad : 1;
    }

    private async Task AbrirVistaPreviaPdfTemporalAsync()
    {
        if (previsualizandoPdf)
            return;

        var error = ValidarGuia(esPrevisualizacion: true);
        if (!string.IsNullOrWhiteSpace(error))
        {
            await AlertService.ShowWarningAsync(error);
            return;
        }

        previsualizandoPdf = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            guia.Fecha = DateTime.Today;
            var dto = new GuiaRemisionDetalleViewDto
            {
                Guia = new GuiaModel
                {
                    Serie = serieGuiaVisual.Replace("-", string.Empty).Trim(),
                    NumGuiaRemision = secuencialGuiaVisual,
                    Fecha = guia.Fecha,
                    FechaIniTransporte = guia.FechaIniTransporte,
                    FechaFinTransporte = guia.FechaFinTransporte,
                    Placa = string.IsNullOrWhiteSpace(guia.Placa) ? transportista.Placa : guia.Placa,
                    Mensaje = guia.Mensaje,
                    EstadoSRI = "PENDIENTE",
                    Ambiente = 2
                },
                Destinatario = destinatario,
                Transportista = transportista,
                Emisor = emisor != null ? new EmisorModel
                {
                    Ruc = emisor.Ruc,
                    RazonSocial = emisor.RazonSocial,
                    NomComercial = emisor.NomComercial,
                    DireccionMatriz = emisor.DireccionMatriz,
                    DirEstablecimiento = emisor.DirEstablecimiento,
                    Telefono = emisor.Telefono,
                    LogoImagen = emisor.LogoImagen
                } : null,
                Factura = facturaReferencia?.Factura,
                NumeroCompleto = $"{serieGuiaVisual}-{secuencialGuiaVisual}",
                NumeroDocumentoSustentoVisual =
                    string.IsNullOrWhiteSpace(destinatario.SerieDocSustento) &&
                    string.IsNullOrWhiteSpace(destinatario.NumDocSustento)
                        ? string.Empty
                        : $"{destinatario.SerieDocSustento}-{destinatario.NumDocSustento}".Trim('-'),
                Detalles = detallesGuia.Select(d => new GuiaRemisionDetalleLineaDto
                {
                    CodigoInterno = d.CodInterno ?? "",
                    CodigoAdicional = d.CodAdicional ?? "",
                    Descripcion = d.Descripcion ?? "",
                    Cantidad = d.Cantidad ?? 0
                }).ToList()
            };

            var rutaPdf = await GuiaRemisionPdfService.GenerarPdfGuiaRemisionAsync(dto);
            
            var webRoot = string.IsNullOrWhiteSpace(WebHostEnvironment.WebRootPath) 
                ? Path.Combine(Directory.GetCurrentDirectory(), "wwwroot") 
                : WebHostEnvironment.WebRootPath;
            
            var relativePath = Path.GetRelativePath(webRoot, rutaPdf).Replace(Path.DirectorySeparatorChar, '/');
            urlPdfTemporal = "/" + relativePath + "?v=" + DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            pdfVistaEsTemporal = true;
            mostrarVistaPreviaPdfTemporal = true;
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"No se pudo generar la vista previa del PDF: {ex.Message}", "Error");
        }
        finally
        {
            previsualizandoPdf = false;
            await InvokeAsync(StateHasChanged);
        }
    }

