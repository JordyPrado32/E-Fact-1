    private async Task GuardarGuiaAsync()
    {
        if (guardandoGuia)
            return;

        guardandoGuia = true;
        try
        {
            var error = ValidarGuia();
            if (!string.IsNullOrWhiteSpace(error))
            {
                await AlertService.ShowErrorAsync(error);
                return;
            }

            mensajeRapidoEmision = null;
            mensajeRapidoEsError = false;
            documentoGeneradoPdfUrl = null;
            await InvokeAsync(StateHasChanged);

            guia.Fecha = DateTime.Today;
            guia.Serie = serieGuiaVisual.Replace("-", string.Empty).Trim();
            guia.NumGuiaRemision = secuencialGuiaVisual;
            guia.Codfactura = facturaReferencia?.Factura?.Codfactura;
            guia.Placa = string.IsNullOrWhiteSpace(guia.Placa) ? transportista.Placa : guia.Placa;
            destinatario.CodDocSustento = facturaReferencia?.Factura != null ? "01" : null;

            var resultado = await GuiaRemisionService.GuardarGuiaRemisionCompletaAsync(
                currentUserId,
                facturaReferencia?.Factura?.Codfactura,
                emisor?.Codigo,
                transportista,
                guia,
                destinatario,
                detallesGuia);

            await InitialSequencePromptService.UpdateLastSequenceAsync(
                currentUserId,
                "guia-remision",
                resultado.Secuencial,
                serieGuiaRawActual);

            var respuestaSri = await GuiaRemisionService.EmitirGuiaRemisionSriAsync(
                resultado.SecGuiaRemision,
                currentUserId);
            var autorizadaSri = string.Equals(
                respuestaSri.estado,
                DocumentoAutorizacionHelper.EstadoAutorizado,
                StringComparison.OrdinalIgnoreCase) ||
                !string.IsNullOrWhiteSpace(respuestaSri.autorizacion);

            string? pdfUrl = null;
            string? pdfError = null;

            try
            {
                pdfUrl = await GuiaRemisionService.AsegurarPdfGuiaRemisionUsuarioAsync(resultado.SecGuiaRemision, currentUserId);
            }
            catch (Exception ex)
            {
                pdfError = ex.Message;
            }

            var hayObservaciones = !autorizadaSri || !string.IsNullOrWhiteSpace(pdfError);
            documentoGeneradoPdfUrl = autorizadaSri && !string.IsNullOrWhiteSpace(pdfUrl)
                ? $"{pdfUrl}?v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}"
                : null;
            mensajeRapidoEmision = autorizadaSri
                ? $"Guía {resultado.NumeroCompleto} emitida correctamente al SRI."
                : $"Guía guardada, pero no se pudo emitir al SRI. {respuestaSri.estado}: {respuestaSri.mensaje}";

            if (autorizadaSri && !string.IsNullOrWhiteSpace(pdfError))
                mensajeRapidoEmision += $" El PDF no se pudo generar: {pdfError}";

            mensajeRapidoEsError = hayObservaciones;
            await CargarEstadoEmisionAsync();
            EmisionControlService.NotifyChanged();
            await LimpiarFormularioAsync();
        }
        catch (Exception ex)
        {
            var mensaje = ex.GetBaseException().Message;
            mensajeRapidoEmision = mensaje;
            mensajeRapidoEsError = true;
            await AlertService.ShowErrorAsync(mensaje, "No se pudo guardar la guia");
        }
        finally
        {
            guardandoGuia = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LimpiarFormularioAsync()
    {
        ReiniciarModelos();
        numFacturaBuscar = string.Empty;
        listaFacturas.Clear();
        mostrarListaFacturas = false;
        seleccionandoFacturaDesdeLista = false;
        textoBusquedaTransportista = string.Empty;
        errorCarga = null;
        estadoCarga = sinCaja ? "Caja sin serie de guia" : "Sin cargar";
        await RecargarSecuencialAsync();
    }

    private string? ValidarGuia(bool esPrevisualizacion = false)
    {
        if (sinCaja)
            return "Debes configurar la serie de guia en tu caja antes de emitir este documento.";

        if (BloqueadoPorSaldoDocumentos)
            return MensajeBloqueoDocumentos;

        if (emisor == null || emisor.Codigo <= 0)
            return "Debes configurar un emisor activo antes de generar la guia.";

        if (!esPrevisualizacion &&
            facturaReferencia?.Factura != null &&
            !string.IsNullOrWhiteSpace(facturaReferencia.Factura.Guiaremision))
            return $"La factura ya tiene registrada la guia {facturaReferencia.Factura.Guiaremision}.";

        transportista.NumeroIdentificacion = (transportista.NumeroIdentificacion ?? string.Empty).Trim();
        transportista.TipoIdentificacion = ResolverTipoIdentificacionTransportista(
            transportista.TipoIdentificacion,
            transportista.NumeroIdentificacion);
        if (!EsIdentificacionValidaPorTipo(transportista.TipoIdentificacion, transportista.NumeroIdentificacion))
            return "La identificacion del transportista no tiene un formato válido para el tipo seleccionado.";

        transportista.RazonSocial = (transportista.RazonSocial ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(transportista.RazonSocial))
            return "Debes ingresar la razon social del transportista.";

        transportista.Placa = (transportista.Placa ?? string.Empty).Trim().ToUpperInvariant();
        if (!EsPlacaValida(transportista.Placa))
            return "Debes ingresar la placa del vehiculo.";

        if (guia.FechaIniTransporte == null || guia.FechaFinTransporte == null || guia.FechaFinTransporte < guia.FechaIniTransporte)
            return "Debes indicar un rango valido de fechas para el transporte.";

        if (guia.FechaIniTransporte.Value.Date < DateTime.Today)
            return "La fecha de inicio de traslado no puede ser de días pasados.";

        guia.DireccionPartida = (guia.DireccionPartida ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(guia.DireccionPartida))
            return "Debes ingresar la direccion de partida.";

        transportista.Correo = (transportista.Correo ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(transportista.Correo) && !EsCorreoValido(transportista.Correo))
            return "El correo del transportista no tiene un formato válido.";

        transportista.Telefono = (transportista.Telefono ?? string.Empty).Trim();

        destinatario.IdDestinatario = (destinatario.IdDestinatario ?? string.Empty).Trim();
        destinatario.RazonSocial = (destinatario.RazonSocial ?? string.Empty).Trim();
        destinatario.Direccion = (destinatario.Direccion ?? string.Empty).Trim();
        destinatario.MotivoTraslado = (destinatario.MotivoTraslado ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(destinatario.IdDestinatario) ||
            string.IsNullOrWhiteSpace(destinatario.RazonSocial) ||
            string.IsNullOrWhiteSpace(destinatario.Direccion) ||
            string.IsNullOrWhiteSpace(destinatario.MotivoTraslado))
            return "Completa los datos obligatorios del destinatario.";

        if (!EsIdentificacionGenericaValida(destinatario.IdDestinatario))
            return "La identificación del destinatario no tiene un formato válido.";

        if (!detallesGuia.Any())
            return "La guia debe tener al menos un detalle.";

        for (int i = 0; i < detallesGuia.Count; i++)
        {
            if (string.IsNullOrWhiteSpace(detallesGuia[i].Descripcion))
                return $"En la linea #{i + 1} la descripcion es obligatoria.";

            if ((detallesGuia[i].Cantidad ?? 0) <= 0)
                return $"En la linea #{i + 1} la cantidad debe ser mayor a cero.";
        }

        return null;
    }

    private async Task CargarEstadoEmisionAsync()
    {
        emisionEstado = await EmisionControlService.ObtenerEstadoAsync(currentUserId);
    }

    private static bool EsCorreoValido(string correo)
    {
        try
        {
            _ = new System.Net.Mail.MailAddress(correo);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool EsPlacaValida(string placa) =>
        !string.IsNullOrWhiteSpace(placa) &&
        placa.Length is >= 5 and <= 10 &&
        placa.All(ch => char.IsLetterOrDigit(ch) || ch == '-');

    private static bool EsIdentificacionValidaPorTipo(string tipo, string identificacion)
    {
        if (string.IsNullOrWhiteSpace(identificacion))
            return false;

        return tipo switch
        {
            "04" => identificacion.Length == 13 && identificacion.All(char.IsDigit),
            "05" => identificacion.Length == 10 && identificacion.All(char.IsDigit),
            "06" => identificacion.Length is >= 3 and <= 20 &&
                    identificacion.All(ch => char.IsLetterOrDigit(ch) || ch == '-'),
            _ => EsIdentificacionGenericaValida(identificacion)
        };
    }

    private static string ResolverTipoIdentificacionTransportista(string? tipo, string? identificacion)
    {
        var tipoLimpio = tipo?.Trim();
        if (tipoLimpio?.Length == 2 && tipoLimpio.All(char.IsDigit))
            return tipoLimpio;

        var identificacionLimpia = identificacion?.Trim() ?? string.Empty;
        return identificacionLimpia.All(char.IsDigit) switch
        {
            true when identificacionLimpia.Length == 13 => "04",
            true when identificacionLimpia.Length == 10 => "05",
            _ => "06"
        };
    }

    private static bool EsIdentificacionGenericaValida(string identificacion)
    {
        if (string.IsNullOrWhiteSpace(identificacion))
            return false;

        if (identificacion.All(char.IsDigit))
            return identificacion.Length is 10 or 13;

        return identificacion.Length is >= 3 and <= 20 &&
               identificacion.All(ch => char.IsLetterOrDigit(ch) || ch == '-');
    }

    private static string ObtenerNombreCliente(Cliente? cli)
    {
        if (cli == null)
            return string.Empty;

        if (!string.IsNullOrWhiteSpace(cli.Nombrerazonsocial))
            return cli.Nombrerazonsocial.Trim();

        return $"{cli.Nombres} {cli.Apellidos}".Trim();
    }

    private static string FormatearSerie(string? serie)
    {
        var limpia = (serie ?? string.Empty).Replace("-", string.Empty).Trim();
        if (limpia.Length != 6)
            return limpia;

        return $"{limpia[..3]}-{limpia[3..]}";
    }
}
