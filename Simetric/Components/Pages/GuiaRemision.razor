    private async Task AplicarConfiguracionSecuenciaInicialAsync()
    {
        var estado = await InitialSequencePromptService.GetStateAsync(currentUserId, "guia-remision", serieGuiaRawActual);

        if (!estado.Initialized)
        {
            mostrarModalSecuenciaInicial = true;
            secuencialGuiaVisual = string.Empty;
            return;
        }

        mostrarModalSecuenciaInicial = false;
        secuencialGuiaVisual = InitialSequencePromptService.ResolveNextSequence(secuencialGuiaAutomatico, estado);
    }

    private void OnCambioRespuestaSecuencia(bool? value)
    {
        usuarioYaEmitioAntes = value;
