    private async Task RecargarSecuencialAsync()
    {
        if (sinCaja)
            return;

        if (currentUserId <= 0)
        {
            estadoCarga = "Usuario no identificado";
            errorCarga = "No se pudo identificar al usuario actual para resolver la serie de guia.";
            return;
        }

        try
        {
            secuencialGuiaAutomatico = await GuiaRemisionService.GetNextGuiaRemisionNumeroAsync(currentUserId, serieGuiaRawActual);
            await AplicarConfiguracionSecuenciaInicialAsync();
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync(ex.Message, "No se pudo recalcular el secuencial");
        }
    }

    private async Task OnSerieDocumentoChangedAsync(ChangeEventArgs e)
    {
        var serieRaw = e.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(serieRaw) ||
            string.Equals(serieGuiaRawActual, serieRaw, StringComparison.Ordinal))
            return;

        await FacturacionService.SavePreferredSeriesForAllDocumentsAsync(currentUserId, serieRaw);
        serieGuiaRawActual = serieRaw;
        serieGuiaVisual = FormatearSerie(serieRaw);
        await RecargarSecuencialAsync();
