    private async Task ConfirmarSecuenciaInicialAsync()
    {
        errorSecuenciaInicial = null;

        if (usuarioYaEmitioAntes == null)
        {
            errorSecuenciaInicial = "Debes indicar si ya habias generado guias antes.";
            return;
        }

        var secuenciaNormalizada = string.Empty;

        if (usuarioYaEmitioAntes == true &&
            !InitialSequencePromptService.TryNormalizeSequence(secuenciaAnteriorManual, out secuenciaNormalizada))
        {
            errorSecuenciaInicial = "Ingresa una secuencia valida de hasta 9 digitos.";
            return;
        }

        var estado = new InitialSequencePromptState
        {
            Initialized = true,
            HadPreviousDocuments = usuarioYaEmitioAntes.Value,
            PreviousSequence = usuarioYaEmitioAntes.Value ? secuenciaNormalizada : string.Empty
        };

        await InitialSequencePromptService.SaveStateAsync(currentUserId, "guia-remision", serieGuiaRawActual, estado);

        secuenciaAnteriorManual = secuenciaNormalizada;
        mostrarModalSecuenciaInicial = false;
        secuencialGuiaVisual = usuarioYaEmitioAntes.Value
            ? InitialSequencePromptService.ResolveNextSequence(secuencialGuiaAutomatico, estado)
            : secuencialGuiaAutomatico;
    }

