@page "/validar-mfa/{IdUsuario:int}"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Auth
@using Simetric.Models
@using Simetric.Data
@using Simetric.Extensions
@using Simetric.Services
@using Microsoft.EntityFrameworkCore
@using OtpNet
@layout Simetric.Components.Layout.EmptyLayout
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EmisorOnboardingService EmisorOnboardingService
@inject LoginDestinationService LoginDestination
@rendermode InteractiveServer

<PageTitle>Verificacion MFA | Numerica e-fact</PageTitle>

<div class="mfa-shell">
    <div class="mfa-grid">
        <section class="mfa-story">
            <div class="mfa-story-backdrop"></div>
            <div class="mfa-story-card">
                <div class="mfa-brand">
                    <img src="images/logo.png" alt="Logo E-FACT" class="mfa-brand-logo" />
                    <span class="mfa-brand-chip">Autenticacion reforzada</span>
                </div>

                <div class="mfa-story-copy">
                    <span class="mfa-kicker">Doble factor activo</span>
                    <h1>Verificacion MFA</h1>
                    <p>
                        Confirma tu identidad con el codigo de 6 digitos generado por tu
                        aplicacion autenticadora para completar el ingreso seguro.
                    </p>
                </div>

                <div class="mfa-story-highlights">
                    <article class="mfa-highlight-card">
                        <strong>Codigo temporal</strong>
                        <span>Valido por ventana corta para proteger el acceso a la cuenta.</span>
                    </article>
                    <article class="mfa-highlight-card">
                        <strong>Seguridad extra</strong>
                        <span>La verificacion se ejecuta despues de validar usuario y contrasena.</span>
                    </article>
                    <article class="mfa-highlight-card">
                        <strong>Acceso inmediato</strong>
                        <span>Una vez validado, la sesion se habilita y continas al panel.</span>
                    </article>
                </div>

                <div class="mfa-story-points">
                    <div class="mfa-story-point">
                        <i class="ri-smartphone-line"></i>
                        <span>Abre tu aplicacion MFA y usa el codigo actual de 6 digitos.</span>
                    </div>
                    <div class="mfa-story-point">
                        <i class="ri-timer-line"></i>
                        <span>Si el codigo vence, espera el siguiente ciclo e intenta de nuevo.</span>
                    </div>
                    <div class="mfa-story-point">
                        <i class="ri-shield-check-line"></i>
                        <span>La validacion protege la cuenta incluso si la clave principal fue comprometida.</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="mfa-panel">
            <div class="mfa-card">
                <div class="mfa-head">
                    <div class="mfa-icon-wrap">
                        <i class="ri-shield-check-line"></i>
                    </div>
                    <span class="mfa-kicker mfa-kicker-blue">Paso final</span>
                    <h2>Verificacion MFA</h2>
                    <p>Introduce el codigo de 6 digitos generado por tu aplicacion autenticadora.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="status-banner status-banner-error">
                        <i class="ri-error-warning-line"></i>
                        <span>@errorMessage</span>
                    </div>
                }

                <div class="form-section">
                    <div class="form-section-head">
                        <span class="form-section-kicker">Codigo temporal</span>
                        <h3>Acceso protegido</h3>
                        <p>Ingresa el codigo actual tal como aparece en tu dispositivo.</p>
                    </div>

                    <div class="form-field">
                        <label class="field-label">Codigo de verificacion</label>
                        <div class="field-control">
                            <span class="field-icon">
                                <i class="ri-smartphone-line"></i>
                            </span>
                            <input type="text"
                                   @bind="codigoIngresado"
                                   @bind:event="oninput"
                                   class="field-input field-input-with-icon mfa-code-input"
                                   placeholder="000000"
                                   maxlength="6"
                                   inputmode="numeric"
                                   autocomplete="one-time-code" />
                        </div>
                    </div>

                    <div class="security-note">
                        <i class="ri-information-line"></i>
                        <span>Si el codigo no funciona, revisa que la hora del dispositivo este sincronizada.</span>
                    </div>
                </div>

                <button type="button" class="submit-btn" @onclick="ConfirmarCodigo" disabled="@cargando">
                    @if (cargando)
                    {
                        <span class="submit-spinner"></span>
                        <span>Validando...</span>
                    }
                    else
                    {
                        <i class="ri-login-box-line"></i>
                        <span>Verificar y acceder</span>
                    }
                </button>

                <div class="mfa-footer">
                    <a href="/login" class="inline-link">Volver al inicio</a>
                </div>
            </div>
        </section>
    </div>
</div>

@code {
    [Parameter] public int IdUsuario { get; set; }

    private string codigoIngresado = string.Empty;
    private string? errorMessage;
    private bool cargando;

    private async Task ConfirmarCodigo()
    {
        if (string.IsNullOrWhiteSpace(codigoIngresado) || codigoIngresado.Length < 6)
        {
            errorMessage = "El codigo debe tener 6 digitos.";
            return;
        }

        cargando = true;
        errorMessage = null;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var usuario = await context.Usuarios.FindAsync(IdUsuario);

            if (usuario != null && !string.IsNullOrEmpty(usuario.MfaSecretKey))
            {
                var secretBytes = Base32Encoding.ToBytes(usuario.MfaSecretKey);
                var totp = new Totp(secretBytes);
                bool isValid = totp.VerifyTotp(codigoIngresado, out _, new VerificationWindow(1, 1));

                if (isValid)
                {
                    var authResponse = await JS.InvokeAsync<MfaAuthResponse>("authInterop.mfaLogin", new
                    {
                        IdUsuario = usuario.IdUsuario
                    });

                    if (!authResponse.Success)
                    {
                        errorMessage = string.IsNullOrWhiteSpace(authResponse.Message)
                            ? "No fue posible completar el acceso MFA."
                            : authResponse.Message;
                        return;
                    }

                    var authProvider = (CustomAuthStateProvider)AuthStateProvider;
                    await authProvider.UpdateAuthenticationState(usuario);
                    var destination = await LoginDestination.PrepareDestinationAsync(usuario.IdUsuario, usuario.IdTipoUsuario);
                    Nav.NavigateToIfNeeded(destination, forceLoad: true);
                }
                else
                {
                    errorMessage = "Codigo incorrecto. Verifica tu aplicacion.";
                }
            }
        }
        catch (Exception ex) when (ex is not Microsoft.AspNetCore.Components.NavigationException)
        {
            errorMessage = "Error: " + ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private sealed class MfaAuthResponse
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
    }
}
