                        </div>
                        <div class="ret-preview-total-card is-main">
                            <span>Total retenido</span>
                            <strong>$ @((preview.Retenciones ?? new List<CompraRetValorDto>()).Where(EsRetencionSeleccionada).Sum(x => x.ValorRetenido ?? 0m).ToString("N2"))</strong>
