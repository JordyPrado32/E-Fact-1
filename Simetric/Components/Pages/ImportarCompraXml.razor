    private string FormatDate(DateTime? fecha)
        => fecha?.ToString("dd/MM/yyyy") ?? "";

    private static string FormatearSerieRetencion(string? serie)
    {
        var limpio = new string((serie ?? string.Empty).Where(char.IsDigit).ToArray());
        if (limpio.Length >= 6)
            return $"{limpio[..3]}-{limpio.Substring(3, 3)}";

        return string.IsNullOrWhiteSpace(serie) ? "001-001" : serie.Trim();
    }

    private static string FormatearSecuencialRetencion(string? numero)
    {
        var limpio = new string((numero ?? string.Empty).Where(char.IsDigit).ToArray());
        if (limpio.Length > 9)
            limpio = limpio[^9..];

        return string.IsNullOrWhiteSpace(limpio) ? "000000000" : limpio.PadLeft(9, '0');
    }

    private static string FormatearSegmentoSerie(string? valor)
    {
        var limpio = new string((valor ?? string.Empty).Where(char.IsDigit).ToArray());
        if (limpio.Length > 3)
            limpio = limpio[^3..];

        return string.IsNullOrWhiteSpace(limpio) ? "001" : limpio.PadLeft(3, '0');
    }
