    private static string NormalizarMensajeErrorGuardado(string? mensajeError)
    {
        if (string.IsNullOrWhiteSpace(mensajeError))
            return "No se pudo guardar la retención.";

        return mensajeError.Contains("La liquidación de compra ya fue registrada", StringComparison.OrdinalIgnoreCase) ||
               mensajeError.Contains("codFactura", StringComparison.OrdinalIgnoreCase)
            ? "La liquidación de compra ya tiene una retención registrada y no puede retenerse nuevamente."
            : mensajeError;
    }

    private static bool EsMensajeLiquidacionYaRegistrada(string? mensajeError) =>
        !string.IsNullOrWhiteSpace(mensajeError) &&
        (mensajeError.Contains("La liquidación de compra ya fue registrada", StringComparison.OrdinalIgnoreCase) ||
         mensajeError.Contains("La liquidación de compra ya tiene una retención registrada", StringComparison.OrdinalIgnoreCase) ||
         mensajeError.Contains("codFactura", StringComparison.OrdinalIgnoreCase));

    private static string? NormalizarUrlDocumentoRetencionGenerado(string? pdfUrl)
    {
        if (string.IsNullOrWhiteSpace(pdfUrl))
            return null;

        var separador = pdfUrl.Contains('?', StringComparison.Ordinal) ? "&" : "?";
        return $"{pdfUrl}{separador}v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
    }

