@page "/compras/importar-xml"
@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Components.Shared
@using Simetric.DTOs
@using Simetric.Models
@using Simetric.Services
@inject Simetric.Services.ComprobanteRetencionGenerator XmlGenerator
@inject AuthenticationStateProvider AuthStateProvider
@inject ComprasXmlService ComprasXmlService
@inject FacturacionService FacturacionService
@inject InitialSequencePromptService InitialSequencePromptService
@inject RetencionesService RetencionesService
@inject RetencionCorreoService RetencionCorreoService
@inject RetencionGeneradaService RetencionGeneradaService
@inject EmisionControlService EmisionControlService
@inject LiquidacionCompraService LiquidacionCompraService
@inject IRetencionPdfService RetencionPdfService
@inject NavigationManager NavManager

@if (!ModoIntegrado)
{
    <PageTitle>Retencion | Numerica e-fact</PageTitle>
}

<div class="container-fluid py-3 px-3 px-md-4 bg-light-modern compact-import-page docs-unified-page @(ModoIntegrado ? "retencion-integrada" : string.Empty)" data-tour="compras.page" @onclick="CerrarBuscadoresRetencion">
    @if (guardando)
    {
        <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
             style="background: rgba(15, 23, 42, 0.38); z-index: 2000; backdrop-filter: blur(2px);">
            <div class="bg-white rounded-4 shadow-lg px-4 py-4 text-center" style="width: min(92vw, 420px);">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <div class="fw-semibold fs-5">@textoGuardandoRetencion</div>
                <div class="text-muted small mt-2">Espera un momento mientras guardamos la retencion y consultamos su autorizacion en el SRI.</div>
            </div>
        </div>
    }

    <DocumentoEmisionToast Message="@mensajeRapidoRetencion"
                           IsError="@mensajeRapidoRetencionEsError"
                           PdfUrl="@retencionGeneradaPdfUrl"
                           OnOpenPdf="AbrirDocumentoRetencionGeneradoAsync">
        <AdditionalActions>
            @if (!ModoIntegrado && !mensajeRapidoRetencionEsError && retencionGeneradaSec is > 0)
            {
                <button type="button" class="documento-emision-accion" @onclick="NuevaRetencionDesdeAvisoAsync">Nueva retencion</button>
            }
        </AdditionalActions>
    </DocumentoEmisionToast>

    <InitialSequenceModal Visible="@mostrarModalSecuenciaInicial"
                          Title="Configuracion inicial de retencion"
                          Description="Antes de emitir tu primera retencion con esta serie, indicanos si ya habias emitido retenciones anteriormente."
                          QuestionLabel="Ya habias emitido retenciones antes?"
                          SequenceLabel="Ingresa la secuencia donde te quedaste"
                          SequencePlaceholder="Ej: 000000125"
                          SequenceHint="Si te quedaste en la 125, la siguiente sera la 126."
                          HadPreviousDocuments="usuarioYaEmitioAntes"
                          HadPreviousDocumentsChanged="OnCambioRespuestaSecuencia"
                          PreviousSequence="@secuenciaAnteriorManual"
                          PreviousSequenceChanged="OnSecuenciaAnteriorManualChanged"
                          ErrorMessage="@errorSecuenciaInicial"
                          OnDismiss="@(() => mostrarModalSecuenciaInicial = false)"
                          OnConfirm="ConfirmarSecuenciaInicialAsync" />

    <section class="docs-form-hero" data-tour="compras.hero">
        <div class="docs-form-hero-body">
            <div class="docs-form-hero-copy invoice-heading-card">
                <div class="invoice-heading-head">
                    <span class="invoice-heading-icon"><i class="bi bi-receipt-cutoff"></i></span>
                    <span class="docs-form-kicker">Documento de retención</span>
                </div>
                <h2 class="docs-form-title">@(ModoIntegrado ? "Retencion de la liquidacion" : "Nueva retencion")</h2>
                <p class="docs-form-text">
                    @(ModoIntegrado
                        ? "Completa la retencion de esta liquidacion autorizada y revisa el documento antes de emitirlo."
                        : "Importa el XML o registra manualmente el comprobante base para emitir la retencion y revisar su historial sin cambiar de pantalla.")
                </p>
                <div class="invoice-heading-meter"><span></span></div>
            </div>

            <div class="docs-form-toolbar">
                <div class="n-invoice-id-strip" aria-label="Identificadores de retencion">
                    <div class="n-invoice-id-pill">
                        <span>Serie</span>
                        @if (seriesDocumento.Any())
                        {
                            <select class="n-invoice-id-select"
                                    value="@(preview?.Serie ?? string.Empty)"
                                    @onchange="OnSerieDocumentoChangedAsync">
                                @foreach (var serie in seriesDocumento)
                                {
                                    <option value="@serie.SerieRaw">@serie.SerieVisual</option>
                                }
                            </select>
                        }
                        else
                        {
                            <strong>@FormatearSerieRetencion(preview?.Serie)</strong>
                        }
                    </div>
                    <div class="n-invoice-id-pill">
                        <span>Retención</span>
                        <strong>@FormatearSecuencialRetencion(preview?.NumeroRetencionGenerado)</strong>
                    </div>
                </div>

                <button type="button" class="n-btn n-btn-secondary" @onclick="AbrirHistorialRetencionesAsync">
                    <i class="bi bi-clock-history me-2"></i> Historial
                </button>

                <button type="button" class="n-btn n-btn-secondary" @onclick="LimpiarTodo">
                    <i class="bi bi-arrow-clockwise me-2"></i> Limpiar pantalla
                </button>
            </div>
        </div>
    </section>

    <section class="n-client-search-strip d-none" data-tour="compras.search">
        <div class="n-client-search-strip-copy">
            <span class="n-client-search-eyebrow">Buscador de liquidación de compra</span>
            <strong>Encuentra una liquidación de compra para emitir la retención</strong>
        </div>

        <div class="n-client-search-input position-relative" @onclick:stopPropagation="true">
            <div class="n-input-wrapper">
                <i class="bi bi-search n-input-icon"></i>
                <input class="n-input n-input-with-icon n-input-with-toggle"
                       placeholder="Buscar liquidación de compra por número o secuencial"
                       @bind="textoBusquedaSecuencial"
                       @bind:event="oninput"
                       @onfocus="MostrarLiquidacionesDropdown"
                       @onkeydown="OnBusquedaLiquidacionKeyDown" />
                <button type="button"
                        class="n-input-toggle-btn"
                        @onclick="ToggleLiquidacionesDropdown"
                        aria-label="Buscar liquidación de compra">
                    <i class="bi bi-chevron-down"></i>
                </button>
            </div>
            @if (mostrarLiquidacionesDropdown)
            {
                <ul class="n-suggestions ret-liquidation-dropdown">
                    @if (LiquidacionesDropdown.Any())
                    {
                        @foreach (var liquidacion in LiquidacionesDropdown)
                        {
                            <li class="ret-liquidation-option"
                                @onclick="() => SeleccionarLiquidacionAsync(liquidacion)">
                                <span>
                                    <strong>@liquidacion.NumeroDocumento</strong>
                                    <small>@liquidacion.Proveedor</small>
                                </span>
                                <span class="ret-liquidation-meta">
                                    @liquidacion.FechaEmision?.ToString("dd/MM/yyyy") | $ @liquidacion.ImporteTotal.ToString("N2")
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ret-liquidation-empty">No hay liquidaciones pendientes de retención.</li>
                    }
                </ul>
            }
        </div>
    </section>

    @if (!ModoIntegrado)
    {
    <section class="nc-issue-options" aria-label="Opciones para emitir retencion">
        <div class="nc-issue-options-copy">
            <span class="nc-section-kicker">Opciones de ingreso</span>
            <strong>Elige cómo quieres cargar la liquidación de compra base</strong>
        </div>

        <div class="nc-issue-options-grid">
            <div class="nc-issue-option nc-issue-option-file @(modoIngreso == "XML" ? "is-active" : string.Empty)"
                 @onclick='() => CambiarModo("XML")'>
                <span class="nc-issue-option-icon"><i class="bi bi-filetype-xml"></i></span>
                <div>
                    <strong>Desde XML</strong>
                    <small>Carga el XML de liquidación de compra y revisa la retención antes de guardar.</small>
                    <label class="nc-xml-picker" @onclick:stopPropagation="true">
                        <span>Seleccionar archivo XML</span>
                        <InputFile OnChange="OnXmlSelected" accept=".xml" />
                    </label>
                </div>
            </div>

            <button type="button"
                    class="nc-issue-option @(modoIngreso == "MANUAL" ? "is-active" : string.Empty)"
                    @onclick='() => CambiarModo("MANUAL")'>
                <span class="nc-issue-option-icon"><i class="bi bi-pencil-square"></i></span>
                <div>
                    <strong>Manual</strong>
                    <small>Completa proveedor, liquidacion, detalle y retenciones.</small>
                </div>
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(mensaje))
        {
            <div class="nc-mode-message @(esError ? "is-error" : "is-ok")">@mensaje</div>
        }
    </section>

    <section class="n-client-search-strip" data-tour="compras.search">
        <div class="n-client-search-strip-copy">
            <span class="n-client-search-eyebrow">Buscador de liquidacion de compra</span>
            <strong>Encuentra una liquidacion de compra para emitir la retencion</strong>
        </div>

        <div class="n-client-search-input position-relative" @onclick:stopPropagation="true">
            <div class="n-input-wrapper">
                <i class="bi bi-search n-input-icon"></i>
                <input class="n-input n-input-with-icon n-input-with-toggle"
                       placeholder="Buscar liquidacion de compra por numero o secuencial"
                       @bind="textoBusquedaSecuencial"
                       @bind:event="oninput"
                       @onfocus="MostrarLiquidacionesDropdown"
                       @onkeydown="OnBusquedaLiquidacionKeyDown" />
                <button type="button"
                        class="n-input-toggle-btn"
                        @onclick="ToggleLiquidacionesDropdown"
                        aria-label="Buscar liquidacion de compra">
                    <i class="bi @(mostrarLiquidacionesDropdown ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </button>
            </div>
            @if (mostrarLiquidacionesDropdown)
            {
                <ul class="n-suggestions ret-liquidation-dropdown">
                    @if (LiquidacionesDropdown.Any())
                    {
                        @foreach (var liquidacion in LiquidacionesDropdown)
                        {
                            <li class="ret-liquidation-option"
                                @onclick="() => SeleccionarLiquidacionAsync(liquidacion)">
                                <span>
                                    <strong>@liquidacion.NumeroDocumento</strong>
                                    <small>@liquidacion.Proveedor</small>
                                </span>
                                <span class="ret-liquidation-meta">
                                    @liquidacion.FechaEmision?.ToString("dd/MM/yyyy") | $ @liquidacion.ImporteTotal.ToString("N2")
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ret-liquidation-empty">No hay liquidaciones pendientes de retención.</li>
                    }
                </ul>
            }
        </div>
    </section>
    }

    <section class="n-client-search-strip d-none" data-tour="compras.search">
        <div class="n-client-search-strip-copy">
            <span class="n-client-search-eyebrow">Buscador de liquidación de compra</span>
            <strong>Encuentra una liquidación de compra para emitir la retención</strong>
        </div>

        <div class="n-client-search-input position-relative" @onclick:stopPropagation="true">
            <div class="n-input-wrapper">
                <i class="bi bi-search n-input-icon"></i>
                <input class="n-input n-input-with-icon n-input-with-toggle"
                       placeholder="Buscar liquidación de compra por número o secuencial"
                       @bind="textoBusquedaSecuencial"
                       @bind:event="oninput"
                       @onfocus="MostrarLiquidacionesDropdown"
                       @onkeydown="OnBusquedaLiquidacionKeyDown" />
                <button type="button"
                        class="n-input-toggle-btn"
                        @onclick="ToggleLiquidacionesDropdown"
                        aria-label="Buscar liquidación de compra">
                    <i class="bi @(mostrarLiquidacionesDropdown ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </button>
            </div>
            @if (mostrarLiquidacionesDropdown)
            {
                <ul class="n-suggestions ret-liquidation-dropdown">
                    @if (LiquidacionesDropdown.Any())
                    {
                        @foreach (var liquidacion in LiquidacionesDropdown)
                        {
                            <li class="ret-liquidation-option"
                                @onclick="() => SeleccionarLiquidacionAsync(liquidacion)">
                                <span>
                                    <strong>@liquidacion.NumeroDocumento</strong>
                                    <small>@liquidacion.Proveedor</small>
                                </span>
                                <span class="ret-liquidation-meta">
                                    @liquidacion.FechaEmision?.ToString("dd/MM/yyyy") | $ @liquidacion.ImporteTotal.ToString("N2")
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="ret-liquidation-empty">No hay liquidaciones pendientes de retención.</li>
                    }
                </ul>
            }
        </div>
    </section>

    @if (preview != null)
    {
        <div data-tour="compras.preview">

            <section class="ret-comprobante-strip">
                <div>
                    <span class="nc-section-kicker">@DatosComprobanteKickerVisual</span>
                    <strong>@DatosComprobanteDescripcionVisual</strong>
                </div>

                <div class="ret-comprobante-fields">
                    <label class="ret-comprobante-document-field">
                        <span>Número de liquidación</span>
                        <input type="text"
                               class="n-input"
                               value="@NumeroLiquidacionInputVisual"
                               @oninput="OnNumeroLiquidacionInput"
                               maxlength="17"
                               inputmode="numeric"
                               readonly="@CamposComprobanteBaseSoloLectura"
                               placeholder="001-001-001001" />
                    </label>

                    <label>
                        <span>Fecha emisión</span>
                        <InputDate class="n-input"
                                   @bind-Value="preview.FechaEmision"
                                   disabled="@CamposComprobanteBaseSoloLectura" />
                    </label>

                    <label class="ret-comprobante-auth-field">
                        <span>Número Autorización</span>
                        <input class="n-input font-monospace"
                               @bind="preview.NumeroAutorizacion"
                               @bind:event="oninput"
                               readonly="@CamposComprobanteBaseSoloLectura"
                               placeholder="Autorización de la liquidación" />
                    </label>

                </div>
            </section>

            @if (MostrarAvisoProveedorNoRegistrado)
            {
                <div class="ret-provider-alert @(continuarConProveedorSinRegistro ? "is-continued" : "")">
                    <span class="n-client-create-icon">
                        <i class="bi bi-person-plus"></i>
                    </span>
                    <div>
                        <strong>Proveedor no registrado</strong>
                        <span>@(continuarConProveedorSinRegistro
                            ? "Continuaras con los datos ingresados para esta retencion."
                            : "Puede registrarlo ahora o continuar; al guardar se creara con la informacion ingresada.")</span>
                    </div>
                    <div class="ret-provider-alert-actions">
                        <button type="button" class="n-client-create-check" @onclick="AbrirModalProveedorNuevo">
                            <i class="bi bi-person-plus"></i>
                            <span>Registrar proveedor</span>
                        </button>
                        <button type="button"
                                class="n-client-continue-check @(continuarConProveedorSinRegistro ? "is-active" : "")"
                                @onclick="ContinuarConProveedorIngresado">
                            <i class="bi @(continuarConProveedorSinRegistro ? "bi-x-circle" : "bi-arrow-right-circle")"></i>
                            <span>@(continuarConProveedorSinRegistro ? "Desmarcar" : "Continuar")</span>
                        </button>
                    </div>
                </div>
            }

            @if (!ModoIntegrado)
            {
            <div class="row g-3 preview-overview-row">
                <div class="col-12 preview-overview-col">
                    <div class="n-card compact-card overview-card provider-card import-info-card h-100">
                        <div class="n-card-header">
                            <h5><i class="bi bi-truck me-2"></i> Información del Proveedor</h5>
                            <small>Datos del XML o ingresados manualmente</small>
                        </div>

                        <div class="n-card-body compact-card-body">
                            <div class="compact-info-grid compact-info-grid-provider">
                                <div class="compact-field compact-field-span-2">
                                    <label class="n-label">RUC</label>
                                    <div class="n-client-search-input ret-provider-lookup-field" @onclick:stopPropagation="true">
                                        <div class="n-input-wrapper">
                                            <i class="bi bi-search n-input-icon"></i>
                                            <input class="n-input n-input-with-icon n-input-with-toggle"
                                               value="@preview.RucProveedor"
                                               @oninput="OnRucProveedorInput"
                                               @onfocus='() => MostrarProveedorDropdown("ruc")'
                                               placeholder="Buscar por RUC o cedula"
                                               autocomplete="off"
                                               disabled="@CamposFormularioBloqueados" />
                                            <button type="button"
                                                    class="n-input-toggle-btn"
                                                    @onclick='() => ToggleProveedorDropdown("ruc")'
                                                    disabled="@CamposFormularioBloqueados"
                                                    aria-label="Mostrar proveedores por RUC">
                                                <i class="bi @(campoProveedorActivo == "ruc" && sugerenciasProveedorBusqueda.Any() ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                            </button>
                                        </div>

                                        @if (campoProveedorActivo == "ruc" && sugerenciasProveedorBusqueda.Any())
                                        {
                                            <ul class="n-suggestions ret-provider-suggestions">
                                                @foreach (var proveedor in sugerenciasProveedorBusqueda)
                                                {
                                                    <li @onmousedown="() => SeleccionarProveedorSugeridoAsync(proveedor)"
                                                        @onmousedown:preventDefault>
                                                        <strong>@proveedor.Identificacion</strong>
                                                        <small>@proveedor.RazonSocial</small>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>

                                <div class="compact-field">
                                    <label class="n-label">Razón social</label>
                                    <div class="n-client-search-input ret-provider-lookup-field" @onclick:stopPropagation="true">
                                        <div class="n-input-wrapper">
                                            <i class="bi bi-search n-input-icon"></i>
                                            <input class="n-input n-input-with-icon n-input-with-toggle"
                                               value="@preview.RazonSocialProveedor"
                                               @oninput="OnRazonSocialProveedorInput"
                                               @onfocus='() => MostrarProveedorDropdown("razon")'
                                               placeholder="Buscar por razon social"
                                               autocomplete="off"
                                               disabled="@CamposFormularioBloqueados" />
                                            <button type="button"
                                                    class="n-input-toggle-btn"
                                                    @onclick='() => ToggleProveedorDropdown("razon")'
                                                    disabled="@CamposFormularioBloqueados"
                                                    aria-label="Mostrar proveedores por razon social">
                                                <i class="bi @(campoProveedorActivo == "razon" && sugerenciasProveedorBusqueda.Any() ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                            </button>
                                        </div>

                                        @if (campoProveedorActivo == "razon" && sugerenciasProveedorBusqueda.Any())
                                        {
                                            <ul class="n-suggestions ret-provider-suggestions">
                                                @foreach (var proveedor in sugerenciasProveedorBusqueda)
                                                {
                                                    <li @onmousedown="() => SeleccionarProveedorSugeridoAsync(proveedor)"
                                                        @onmousedown:preventDefault>
                                                        <strong>@proveedor.RazonSocial</strong>
                                                        <small>@proveedor.Identificacion</small>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>

                                <div class="compact-field compact-field-span-2">
                                    <label class="n-label">Proveedor dirección</label>
                                    <input class="n-input" @bind="preview.DireccionProveedor" disabled="@CamposFormularioBloqueados" />
                                </div>

                                <div class="compact-field">
                                    <label class="n-label">Número de teléfono</label>
                                    <input class="n-input" @bind="preview.TelefonoProveedor" placeholder="Opcional" disabled="@CamposFormularioBloqueados" />
                                </div>
                            </div>

                            <div class="provider-mail-inline">
                                <div class="n-email-main-field ret-mail-primary">
                                    <div class="n-email-main-head">
                                        <label class="n-label mb-0">Correo electrónico principal</label>
                                    </div>

                                    <div class="n-email-primary-row">
                                        <div class="n-input-wrapper">
                                            <i class="bi bi-envelope n-input-icon"></i>
                                            <input type="email"
                                                   class="n-input n-input-with-icon"
                                                   @bind="preview.EmailProveedor"
                                                   @bind:event="oninput"
                                                   placeholder="proveedor@ejemplo.com"
                                                   disabled="@CamposFormularioBloqueados" />
                                        </div>

                                        <button type="button"
                                                class="n-email-add-btn"
                                                title="Agregar correo adicional"
                                                @onclick="AgregarCorreoOpcionalRetencion"
                                                disabled="@(CamposFormularioBloqueados || correosOpcionalesRetencion.Count >= MaxCorreosOpcionalesRetencion)">
                                            <i class="bi bi-envelope-plus"></i>
                                            <span>Agregar correo</span>
                                        </button>
                                    </div>
                                </div>

                                @if (correosOpcionalesRetencion.Any())
                                {
                                    <div class="ret-mail-extra-section">
                                        <label class="n-label">Correos adicionales</label>
                                        <div class="ret-mail-list">
                                            @for (int i = 0; i < correosOpcionalesRetencion.Count; i++)
                                            {
                                                var index = i;
                                                <div class="ret-mail-row">
                                                    <div class="ret-mail-input-shell">
                                                        <input type="email"
                                                               class="n-input"
                                                               @bind="correosOpcionalesRetencion[index].Correo"
                                                               placeholder="correo@ejemplo.com" />
                                                        <button type="button"
                                                                class="ret-mail-remove"
                                                                title="Quitar correo adicional"
                                                                @onclick="() => EliminarCorreoOpcionalRetencion(index)">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </div>

                                                    @if (correosOpcionalesRetencion[index].EsPersistidoCliente)
                                                    {
                                                        <span class="ret-mail-pill">Guardado en proveedor</span>
                                                    }
                                                    else
                                                    {
                                                        <label class="ret-mail-check">
                                                            <input type="checkbox"
                                                                   @bind="correosOpcionalesRetencion[index].GuardarEnCliente" />
                                                            <span>Guardar</span>
                                                        </label>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            }

            @if (false && MostrarAvisoProveedorNoRegistrado)
            {
                <div class="ret-provider-alert">
                    <div>
                        <strong>Proveedor no registrado</strong>
                        <span>Puede registrarlo ahora o continuar; al guardar se creará con la información ingresada.</span>
                    </div>
                    <div class="ret-provider-alert-actions">
                        <button type="button" class="n-btn n-btn-primary" @onclick="AbrirModalProveedorNuevo">
                            Registrar proveedor
                        </button>
                        <button type="button" class="n-btn n-btn-secondary" @onclick="ContinuarConProveedorIngresado">
                            Continuar
                        </button>
                    </div>
                </div>
            }

            @if (ModoIntegrado)
            {
            <div class="ret-integrated-tables mb-4">
                <div class="ret-selected-summary ret-integrated-summary">
                        @if (preview.Detalles != null && preview.Detalles.Any())
                        {
                            <div class="ret-summary-block">
                                <div class="ret-summary-title">Retencion IVA</div>
                                <div class="ret-summary-table-wrap">
                                    <table class="table table-sm align-middle mb-0 ret-summary-table ret-integrated-summary-table">
                                        <thead>
                                            <tr>
                                                <th></th>
