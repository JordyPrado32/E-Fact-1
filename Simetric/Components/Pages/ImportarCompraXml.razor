    private void AgregarRetencion()
    {
        if (preview == null)
            return;

        preview.Retenciones ??= new List<CompraRetValorDto>();

        var cantidadRenta = preview.Retenciones.Count(x => (x.Tipo ?? "").Trim().ToUpperInvariant() == "RENTA");
        var cantidadIva = preview.Retenciones.Count(x => (x.Tipo ?? "").Trim().ToUpperInvariant() == "IVA");

        var tipoNuevo = cantidadRenta <= cantidadIva ? "RENTA" : "IVA";

        var nueva = new CompraRetValorDto
        {
            Sec = null,
            Estado = true,
            Serie = preview.Serie,
            Autorizacion = preview.NumeroAutorizacion,
            Tipo = tipoNuevo,
            DescripcionRet = "",
            Valor = 0m,
            PorcentajeRetencion = 0m,
            ValorRetenido = 0m,
            Base = 0m,
            BasesParciales = new List<BaseParcialRetencionDto>
            {
                new BaseParcialRetencionDto { Base = 0m, ValorRetenido = 0m }
            }
        };

        preview.Retenciones.Add(nueva);
        retencionEnEdicion = nueva;
        tipoPopup = tipoNuevo;
    }

    private async Task EliminarRetencion(int index)
    {
        if (preview?.Retenciones == null)
            return;

        if (index < 0 || index >= preview.Retenciones.Count)
            return;

        try
        {
            var item = preview.Retenciones[index];

            if (item.Sec.HasValue && item.Sec.Value > 0)
            {
                await ComprasXmlService.EliminarRetencionAsync(item.Sec.Value);
            }

            preview.Retenciones.RemoveAt(index);

            if (retencionEnEdicion == item)
            {
                retencionEnEdicion = preview.Retenciones.LastOrDefault();
                resultadosBusqueda.Clear();
            }

            mensaje = "Retención eliminada correctamente.";
            esError = false;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
            esError = true;
        }
    }

    private async Task BuscarRetencionesDinamico(CompraRetValorDto r, string? filtro)
    {
        retencionEnEdicion = r;

        if (string.IsNullOrWhiteSpace(r.Tipo))
        {
            resultadosBusqueda.Clear();
            return;
        }

        if (string.IsNullOrWhiteSpace(filtro) || filtro.Length < 2)
        {
            resultadosBusqueda.Clear();
            return;
        }

        try
        {
            if (!cacheRetenciones.ContainsKey(r.Tipo))
            {
                estaCargando = true;
                var data = await RetencionesService.ListarPorTipoAsync(r.Tipo);
                cacheRetenciones[r.Tipo] = data ?? new();
                estaCargando = false;
            }

            resultadosBusqueda = cacheRetenciones[r.Tipo]
                .Where(x => x.Descripcion.Contains(filtro, StringComparison.OrdinalIgnoreCase)
                         || x.Id.ToString().Contains(filtro))
                .Take(8)
                .ToList();
        }
        catch (Exception ex)
        {
            mensaje = $"Error al buscar: {ex.Message}";
            esError = true;
        }
        finally
        {
            estaCargando = false;
        }
    }

