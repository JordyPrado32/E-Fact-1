    private Task AgregarProductoRetencionDesdeCatalogo(ProductoLookupDetalleDto producto)
    {
        var detalle = ObtenerFilaDisponibleRetencion();
        CargarProductoEnDetalleRetencion(detalle, producto);
        return Task.CompletedTask;
    }

    private Task AgregarProductosRetencionDesdeCatalogo(IReadOnlyList<ProductoLookupDetalleDto> productos)
    {
        foreach (var producto in productos)
        {
            var detalle = ObtenerFilaDisponibleRetencion();
            CargarProductoEnDetalleRetencion(detalle, producto);
        }

        return Task.CompletedTask;
    }

    private CompraXmlDetalleDto ObtenerFilaDisponibleRetencion()
    {
        preview ??= new CompraXmlPreviewDto { Detalles = new List<CompraXmlDetalleDto>() };
        preview.Detalles ??= new List<CompraXmlDetalleDto>();

        var disponible = preview.Detalles.LastOrDefault(EsDetalleCompraVacio);
        if (disponible != null)
            return disponible;

        disponible = ComprasXmlService.CrearDetalleManualVacio();
        preview.Detalles.Add(disponible);
        return disponible;
    }

    private void CargarProductoEnDetalleRetencion(CompraXmlDetalleDto detalle, ProductoLookupDetalleDto producto)
    {
        detalle.CodPrincipal = !string.IsNullOrWhiteSpace(producto.Codprincipal)
            ? producto.Codprincipal.Trim()
            : producto.Codproducto.ToString(System.Globalization.CultureInfo.InvariantCulture);
        detalle.CodAuxiliar = producto.Codauxiliar ?? string.Empty;
        detalle.Descripcion = producto.Descripcion ?? string.Empty;
        detalle.Cantidad = detalle.Cantidad <= 0 ? 1m : detalle.Cantidad;
        detalle.PrecioUnitario = producto.PrecioUnitario;
        detalle.Descuento = 0m;
        detalle.CodImp = 2;
        detalle.Tarifa = producto.TarifaIva is 5 or 8 or 15 ? producto.TarifaIva : 0;

        filaBusquedaProductoRetencionActiva = null;
        seleccionandoProductoRetencionDesdeLista = false;
        sugerenciasProductosRetencion = null;
        indiceSugerenciaProductoRetencionActiva = -1;

        RecalcularDetalleEditado(detalle);
    }

    private void OnCodigoDetalleRetencionInput(CompraXmlDetalleDto item, string? value)
    {
        item.CodPrincipal = value ?? string.Empty;
        AsegurarFilaDetalleManualDisponible();
    }

    private async Task OnConceptoDetalleRetencionInputAsync(CompraXmlDetalleDto item, string? value)
    {
        item.Descripcion = value ?? string.Empty;
        AsegurarFilaDetalleManualDisponible();

        if (modoIngreso != "MANUAL")
            return;

        filaBusquedaProductoRetencionActiva = item;
        var filtro = (item.Descripcion ?? string.Empty).Trim();
        sugerenciasProductosRetencion = await FacturacionService.BuscarProductosFiltroAsync(usuarioActual ?? 0, filtro);
        indiceSugerenciaProductoRetencionActiva = ObtenerIndiceInicial(sugerenciasProductosRetencion);
        await InvokeAsync(StateHasChanged);
    }

    private async Task MostrarSugerenciasDetalleRetencionAsync(CompraXmlDetalleDto item)
    {
        if (modoIngreso != "MANUAL")
            return;

        filaBusquedaProductoRetencionActiva = item;
        var filtro = (item.Descripcion ?? string.Empty).Trim();
        sugerenciasProductosRetencion = await FacturacionService.BuscarProductosFiltroAsync(usuarioActual ?? 0, filtro);
        indiceSugerenciaProductoRetencionActiva = ObtenerIndiceInicial(sugerenciasProductosRetencion);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OcultarSugerenciasDetalleRetencionAsync(CompraXmlDetalleDto item)
    {
        await Task.Delay(150);

        if (seleccionandoProductoRetencionDesdeLista)
            return;

        if (ReferenceEquals(filaBusquedaProductoRetencionActiva, item))
        {
            filaBusquedaProductoRetencionActiva = null;
            sugerenciasProductosRetencion = null;
            indiceSugerenciaProductoRetencionActiva = -1;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnKeyDownConceptoDetalleRetencionAsync(CompraXmlDetalleDto item, KeyboardEventArgs e)
    {
        if (modoIngreso != "MANUAL")
            return;

        if (e.Key == "ArrowDown")
        {
            if (sugerenciasProductosRetencion == null || !sugerenciasProductosRetencion.Any())
                await MostrarSugerenciasDetalleRetencionAsync(item);

            indiceSugerenciaProductoRetencionActiva = MoverIndiceCircular(indiceSugerenciaProductoRetencionActiva, 1, sugerenciasProductosRetencion?.Count ?? 0);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            indiceSugerenciaProductoRetencionActiva = MoverIndiceCircular(indiceSugerenciaProductoRetencionActiva, -1, sugerenciasProductosRetencion?.Count ?? 0);
            return;
        }

        if (e.Key == "Escape")
        {
            filaBusquedaProductoRetencionActiva = null;
            sugerenciasProductosRetencion = null;
            indiceSugerenciaProductoRetencionActiva = -1;
            return;
        }

        if ((e.Key == "Enter" || e.Key == "Tab") && sugerenciasProductosRetencion?.Any() == true)
        {
            var indice = indiceSugerenciaProductoRetencionActiva >= 0 && indiceSugerenciaProductoRetencionActiva < sugerenciasProductosRetencion.Count
                ? indiceSugerenciaProductoRetencionActiva
                : 0;
            await SeleccionarProductoRetencionEnFilaAsync(item, sugerenciasProductosRetencion[indice]);
        }
    }

    private Task SeleccionarProductoRetencionEnFilaAsync(CompraXmlDetalleDto item, ProductoLookupDetalleDto producto)
    {
        CargarProductoEnDetalleRetencion(item, producto);
        return Task.CompletedTask;
    }

    private void PrepararSeleccionProductoRetencion()
    {
        seleccionandoProductoRetencionDesdeLista = true;
    }

    private static string ObtenerResumenProductoBusqueda(ProductoLookupDetalleDto producto)
    {
        var categoria = string.IsNullOrWhiteSpace(producto.Categoria) ? "Sin categoria" : producto.Categoria.Trim();
        return string.IsNullOrWhiteSpace(producto.Subcategoria)
            ? categoria
            : $"{categoria} / {producto.Subcategoria.Trim()}";
    }

    private static int ObtenerIndiceInicial<T>(ICollection<T>? items) =>
        items is { Count: > 0 } ? 0 : -1;

    private static int MoverIndiceCircular(int indiceActual, int desplazamiento, int total)
    {
        if (total <= 0)
            return -1;

        if (indiceActual < 0 || indiceActual >= total)
            return desplazamiento >= 0 ? 0 : total - 1;

        var siguiente = (indiceActual + desplazamiento) % total;
        return siguiente < 0 ? siguiente + total : siguiente;
    }

    private void AgregarDetalleManual()
    {
        if (preview == null)
            return;

        preview.Detalles ??= new List<CompraXmlDetalleDto>();
        preview.Detalles.Add(ComprasXmlService.CrearDetalleManualVacio());

        ComprasXmlService.RecalcularTotalesManualDesdeDetalles(preview);
        SincronizarRetencionesDesdeDetalles();
        AsegurarFilaDetalleManualDisponible();
        StateHasChanged();
    }

    private void EliminarDetalleManual(int index)
    {
        if (preview?.Detalles == null)
            return;

        if (index < 0 || index >= preview.Detalles.Count)
            return;

        var detalle = preview.Detalles[index];
        modosDescuentoDetalleRetencion.Remove(detalle);
        porcentajesDescuentoDetalleRetencion.Remove(detalle);
        preview.Detalles.RemoveAt(index);
        if (!preview.Detalles.Any() && modoIngreso == "MANUAL")
            preview.Detalles.Add(ComprasXmlService.CrearDetalleManualVacio());

        ComprasXmlService.RecalcularTotalesManualDesdeDetalles(preview);
        SincronizarRetencionesDesdeDetalles();
        AsegurarFilaDetalleManualDisponible();
        StateHasChanged();
    }

    private void RecalcularDetalleEditado(CompraXmlDetalleDto item)
    {
        if (preview == null || item == null)
            return;

        ComprasXmlService.RecalcularDetalleManual(item);
        ComprasXmlService.RecalcularTotalesManualDesdeDetalles(preview);
        SincronizarRetencionesDesdeDetalles();
        AsegurarFilaDetalleManualDisponible();
        StateHasChanged();
    }

