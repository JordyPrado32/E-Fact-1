    private async Task BuscarProveedorRapidoAsync(string? texto)
    {
        var filtro = (texto ?? string.Empty).Trim();
        if (usuarioActual is null or <= 0)
        {
            sugerenciasProveedorBusqueda = new();
            return;
        }

        sugerenciasProveedorBusqueda = await LiquidacionCompraService.BuscarProveedoresAsync(filtro, usuarioActual);
        proveedorRegistradoDetectado = ProveedorTieneCoincidenciaExacta;
    }

    private async Task SeleccionarProveedorExactoSiExisteAsync()
    {
        if (preview == null)
            return;

        var identificacion = SoloDigitos(preview.RucProveedor);
        var razon = (preview.RazonSocialProveedor ?? string.Empty).Trim();
        var proveedor = sugerenciasProveedorBusqueda.FirstOrDefault(x =>
            (ProveedorIdentificacionCompleta && SoloDigitos(x.Identificacion) == identificacion) ||
            (!string.IsNullOrWhiteSpace(razon) && string.Equals(x.RazonSocial?.Trim(), razon, StringComparison.OrdinalIgnoreCase)));

        if (proveedor != null)
            await SeleccionarProveedorSugeridoAsync(proveedor);
    }

    private async Task SeleccionarProveedorSugeridoAsync(LiquidacionProveedorLookupDto proveedor)
    {
        if (preview == null)
            return;

        preview.CodProveedor = proveedor.CodCliente;
        preview.RucProveedor = proveedor.Identificacion;
        preview.RazonSocialProveedor = proveedor.RazonSocial;
        preview.DireccionProveedor = proveedor.Direccion;
        preview.TelefonoFijoProveedor = proveedor.TelefonoFijo;
        preview.TelefonoProveedor = proveedor.TelefonoMovil;
        preview.EmailProveedor = proveedor.Correo;
        proveedorRegistradoDetectado = true;
        sugerenciasProveedorBusqueda = new();
        campoProveedorActivo = string.Empty;
        continuarConProveedorSinRegistro = false;
        proveedorNoRegistradoDescartado = false;

        await CargarCorreosOpcionalesProveedorAsync();
        await BuscarProductosSugeridosAsync();
    }

    private async Task DetectarProveedorActualAsync()
    {
        proveedorRegistradoDetectado = (preview?.CodProveedor ?? 0) > 0;

        if (preview == null || proveedorRegistradoDetectado)
            return;

        var filtro = !string.IsNullOrWhiteSpace(preview.RucProveedor)
            ? preview.RucProveedor
            : preview.RazonSocialProveedor;

        if (string.IsNullOrWhiteSpace(filtro) || filtro.Trim().Length < 2)
            return;

        await BuscarProveedorRapidoAsync(filtro);

        var identificacion = SoloDigitos(preview.RucProveedor);
        var razon = (preview.RazonSocialProveedor ?? string.Empty).Trim();
        var proveedor = sugerenciasProveedorBusqueda.FirstOrDefault(x =>
            (!string.IsNullOrWhiteSpace(identificacion) && SoloDigitos(x.Identificacion) == identificacion) ||
            (!string.IsNullOrWhiteSpace(razon) && string.Equals(x.RazonSocial?.Trim(), razon, StringComparison.OrdinalIgnoreCase)));

        if (proveedor != null)
        {
            await SeleccionarProveedorSugeridoAsync(proveedor);
            return;
        }

        proveedorRegistradoDetectado = false;
        sugerenciasProveedorBusqueda = new();
        campoProveedorActivo = string.Empty;
    }

    private async Task OnProveedorGuardadoDesdeCrudAsync(string? identificacionGuardada)
    {
        mostrarModalProveedorNuevo = false;
        continuarConProveedorSinRegistro = false;
        proveedorNoRegistradoDescartado = false;
        proveedorRegistradoDetectado = false;

        if (!string.IsNullOrWhiteSpace(identificacionGuardada))
        {
            await BuscarProveedorRapidoAsync(identificacionGuardada);
            var proveedor = sugerenciasProveedorBusqueda
                .FirstOrDefault(x => string.Equals(x.Identificacion, identificacionGuardada.Trim(), StringComparison.OrdinalIgnoreCase));

            if (proveedor != null)
                await SeleccionarProveedorSugeridoAsync(proveedor);
        }

        await InvokeAsync(StateHasChanged);
    }

    private static string InferirTipoIdentificacionProveedor(string? identificacion)
    {
        var digitos = SoloDigitos(identificacion);
        return digitos.Length == 13 ? "04" : "05";
    }

    private string? ValidarCorreosRetencion()
    {
        if (preview == null)
            return null;

        preview.EmailProveedor = (preview.EmailProveedor ?? string.Empty).Trim();
        NormalizarCorreosOpcionalesRetencion();

        var correosUsados = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(preview.EmailProveedor))
        {
            try
            {
                _ = new System.Net.Mail.MailAddress(preview.EmailProveedor);
            }
            catch
            {
                return "El correo principal del proveedor no tiene un formato válido.";
            }

            correosUsados.Add(preview.EmailProveedor);
        }

        for (int i = 0; i < correosOpcionalesRetencion.Count; i++)
        {
            var correoExtra = correosOpcionalesRetencion[i];

            if (string.IsNullOrWhiteSpace(correoExtra.Correo))
                continue;

            try
            {
                _ = new System.Net.Mail.MailAddress(correoExtra.Correo);
            }
            catch
            {
                return $"El correo adicional #{i + 1} no tiene un formato válido.";
            }

            if (!correosUsados.Add(correoExtra.Correo))
                return $"El correo {correoExtra.Correo} está repetido entre los destinatarios de la retención.";
        }

        return null;
    }

