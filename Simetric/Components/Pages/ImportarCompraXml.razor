            preview = await ComprasXmlService.LeerCompraDesdeXmlAsync(xml);
            preview.Usuario = usuarioActual;
            preview.RucEmisor ??= preview.IdentificacionComprador ?? "";
            preview.IdentificacionComprador = preview.RucEmisor;
            await ComprasXmlService.AplicarEmisorConfiguradoAsync(preview);
            if (!preview.YaImportado || string.IsNullOrWhiteSpace(preview.NumeroRetencionGenerado))
                await AplicarConfiguracionSecuenciaRetencionAsync();

            await DetectarProveedorActualAsync();
            _ = CargarCorreosOpcionalesProveedorEnSegundoPlanoAsync();
            preview.Retenciones ??= new List<CompraRetValorDto>();

            foreach (var ret in preview.Retenciones)
            {
                ret.BasesParciales ??= new List<BaseParcialRetencionDto>();

                if (ret.BasesParciales.Count == 0)
                {
                    var baseExistente = Redondear2(ret.Base ?? 0m);
                    var porcentaje = Redondear2(ret.PorcentajeRetencion ?? 0m);

                    ret.BasesParciales.Add(new BaseParcialRetencionDto
                    {
                        Base = baseExistente,
                        ValorRetenido = Redondear2(baseExistente * porcentaje / 100m)
                    });
                }

                AjustarCamposBaseParcial(ret, 0);
                RecalcularRetencionDesdeBases(ret);
            }

            mensaje = "XML de liquidación de compra cargado correctamente. Revisa la información antes de guardar.";
            esError = false;
        }
        catch (Exception ex)
        {
            await InicializarPreviewVacioAsync(false);
            liquidacionCargadaParaRetencion = false;
            mensaje = ex.Message;
            esError = true;
        }
    }

    private async Task CargarLiquidacionDesdeListadoAsync(int codFactura)
    {
        try
        {
            mensaje = null;
            esError = false;
            mostrarLiquidacionesDropdown = false;

            if (usuarioActual is not > 0)
                throw new Exception("No se pudo identificar el usuario actual para cargar la liquidación.");

            var detalle = await LiquidacionCompraService.GetLiquidacionDetalleUsuarioAsync(codFactura, usuarioActual.Value);
            if (detalle?.Preview == null)
                throw new Exception("No se pudo cargar la liquidación seleccionada.");

            var previewRetencion = MapearPreviewRetencionDesdeLiquidacion(detalle.Preview, detalle.CodFactura);
            await AplicarPreviewRetencionAsync(
                previewRetencion,
                $"Liquidación de compra encontrada con número {previewRetencion.Secuencial}.");
        }
        catch (Exception ex)
        {
            await InicializarPreviewVacioAsync(modoIngreso == "MANUAL");
            liquidacionCargadaParaRetencion = false;
            mensaje = ex.Message;
            esError = true;
        }
    }

    private async Task<CompraXmlPreviewDto?> BuscarPreviewLiquidacionDesdeListadoAsync(string criterio)
    {
        if (usuarioActual is not > 0 || liquidacionesDisponibles.Count == 0)
            return null;

        var liquidacion = liquidacionesDisponibles.FirstOrDefault(x => CoincideLiquidacionConBusqueda(x, criterio));
        if (liquidacion == null)
            return null;

        var detalle = await LiquidacionCompraService.GetLiquidacionDetalleUsuarioAsync(liquidacion.CodFactura, usuarioActual.Value);
        return detalle?.Preview == null
            ? null
            : MapearPreviewRetencionDesdeLiquidacion(detalle.Preview, detalle.CodFactura);
    }

    private async Task AplicarPreviewRetencionAsync(CompraXmlPreviewDto previewEncontrado, string mensajeExito)
    {
        preview = previewEncontrado;
        liquidacionCargadaParaRetencion = true;
        preview.Usuario = usuarioActual;
        preview.RucEmisor ??= preview.IdentificacionComprador ?? "";
        preview.IdentificacionComprador = preview.RucEmisor;
        if (!preview.YaImportado || string.IsNullOrWhiteSpace(preview.NumeroRetencionGenerado))
            await AplicarConfiguracionSecuenciaRetencionAsync();

        await DetectarProveedorActualAsync();
        _ = CargarCorreosOpcionalesProveedorEnSegundoPlanoAsync();
        preview.Retenciones ??= new List<CompraRetValorDto>();

        foreach (var ret in preview.Retenciones)
        {
            ret.BasesParciales ??= new List<BaseParcialRetencionDto>();

            if (ret.BasesParciales.Count == 0)
            {
                var baseExistente = Redondear2(ret.Base ?? 0m);
                var porcentaje = Redondear2(ret.PorcentajeRetencion ?? 0m);

                ret.BasesParciales.Add(new BaseParcialRetencionDto
                {
                    Base = baseExistente,
                    ValorRetenido = Redondear2(baseExistente * porcentaje / 100m)
                });
            }

            AjustarCamposBaseParcial(ret, 0);
            RecalcularRetencionDesdeBases(ret);
        }

        mensaje = mensajeExito;
        esError = false;
    }

    private static bool CoincideLiquidacionConBusqueda(LiquidacionCompraListDto liquidacion, string criterio)
    {
        criterio = (criterio ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(criterio))
            return false;

        var criterioNumerico = new string(criterio.Where(char.IsDigit).ToArray());
        var numeroDocumentoNumerico = new string((liquidacion.NumeroDocumento ?? string.Empty).Where(char.IsDigit).ToArray());
        var secuencialNumerico = new string((liquidacion.Secuencial ?? string.Empty).Where(char.IsDigit).ToArray());

        return string.Equals(liquidacion.NumeroDocumento, criterio, StringComparison.OrdinalIgnoreCase)
            || string.Equals(liquidacion.Secuencial, criterio, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrWhiteSpace(criterioNumerico) &&
                (string.Equals(numeroDocumentoNumerico, criterioNumerico, StringComparison.Ordinal)
                 || string.Equals(secuencialNumerico, criterioNumerico, StringComparison.Ordinal)));
    }

