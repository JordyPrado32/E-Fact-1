    private RetencionGeneradaDetalleViewDto ConstruirVistaPreviaPdfRetencion()
    {
        var previewActual = preview ?? throw new InvalidOperationException("No hay información suficiente para generar la vista previa.");
        var retencionesSeleccionadas = (previewActual.Retenciones ?? new List<CompraRetValorDto>())
            .Where(EsRetencionSeleccionada)
            .ToList();
        var baseTotal = retencionesSeleccionadas.Sum(x => x.Base ?? 0m);
        var totalRetenido = retencionesSeleccionadas.Sum(x => x.ValorRetenido ?? 0m);
        var claveRetencionPreview = ObtenerClaveAccesoRetencionPreview(previewActual);

        return new RetencionGeneradaDetalleViewDto
        {
            RetencionInfo = new RetencionInfo
            {
                NumRetencion = FormatearSecuencialRetencion(previewActual.NumeroRetencionGenerado),
                Fecha = DateTime.Today,
                PeriodoFiscal = DateTime.Today.ToString("MM/yyyy"),
                TipoIdentificacion = InferirTipoIdentificacionProveedor(previewActual.RucProveedor),
                IdCliente = previewActual.RucProveedor,
                NumAutorizacion = null,
                Clave = claveRetencionPreview,
                Serie = previewActual.Serie,
                Ambiente = previewActual.Ambiente
            },
            Compra = new ComprasFactura
            {
                FchAutorizacion = previewActual.FechaEmision,
                Serie = previewActual.Serie,
                NumFactura = previewActual.Secuencial,
                Subtotal = previewActual.TotalSinImpuestos,
                ValorTotal = previewActual.ImporteTotal
            },
            Proveedor = new Proveedor
            {
                ruc = previewActual.RucProveedor,
                nombre = previewActual.RazonSocialProveedor,
                nombreComercial = previewActual.RazonSocialProveedor,
                direccion = previewActual.DireccionProveedor,
                email = previewActual.EmailProveedor,
                telefono = previewActual.TelefonoFijoProveedor,
                telefonoMovil = previewActual.TelefonoProveedor,
                tipoIdentificacion = InferirTipoIdentificacionProveedor(previewActual.RucProveedor)
            },
            Emisor = new Simetric.Models.Emisor
            {
                RazonSocial = previewActual.NombreEmisorEncontrado,
                Ruc = previewActual.RucEmisor,
                DireccionMatriz = previewActual.DireccionMatriz,
                DirEstablecimiento = previewActual.DireccionEstablecimiento,
                LlevaContabilidad = previewActual.ObligadoContabilidad,
                CodEstablecimiento = previewActual.Estab,
                CodPuntoEmision = previewActual.PtoEmi
            },
            TipoIdentificacionProveedor = InferirTipoIdentificacionProveedor(previewActual.RucProveedor),
            NumeroCompleto = $"{FormatearSerieRetencion(previewActual.Serie)}-{FormatearSecuencialRetencion(previewActual.NumeroRetencionGenerado)}",
            DocumentoSustentoVisual = $"{FormatearSerieRetencion(previewActual.Serie)}-{FormatearSecuencialRetencion(previewActual.Secuencial)}",
            FechaEmisionDocumentoSustento = previewActual.FechaEmision,
            BaseTotal = baseTotal,
            TotalRetenido = totalRetenido,
            Retenciones = retencionesSeleccionadas.Select(ret => new RetencionGeneradaDetalleLineaDto
            {
                Tipo = (ret.Tipo ?? string.Empty).Trim().ToUpperInvariant(),
                CodigoRetencion = string.IsNullOrWhiteSpace(ret.CodigoRetencion) ? (ret.IdRet?.ToString() ?? string.Empty) : ret.CodigoRetencion,
                Descripcion = string.IsNullOrWhiteSpace(ret.DescripcionRet) ? ObtenerTituloRetencion(ret) : ret.DescripcionRet ?? string.Empty,
                BaseImponible = ret.Base ?? 0m,
                PorcentajeRetener = ret.PorcentajeRetencion ?? 0m,
                ValorRetenido = ret.ValorRetenido ?? 0m
            }).ToList()
        };
    }

    private string ObtenerClaveAccesoRetencionPreview(CompraXmlPreviewDto previewActual)
    {
        if (!string.IsNullOrWhiteSpace(previewActual.ClaveAccesoRetencion))
            return SoloDigitos(previewActual.ClaveAccesoRetencion);

        var rucEmisor = SoloDigitos(previewActual.RucEmisor);
        if (rucEmisor.Length != 13)
            return string.Empty;

        var fechaEmision = DateTime.Today;
        var serie = $"{FormatearSegmentoSerie(previewActual.Estab)}{FormatearSegmentoSerie(previewActual.PtoEmi)}";
        var secuencial = FormatearSecuencialRetencion(previewActual.NumeroRetencionGenerado);
        var clave = XmlGenerator.GenerarClaveAcceso(
            fechaEmision,
            "07",
            rucEmisor,
            previewActual.Ambiente.ToString(System.Globalization.CultureInfo.InvariantCulture),
            serie,
            secuencial,
            "12345678",
            "1");

        previewActual.ClaveAccesoRetencion = clave;
        return clave;
    }

    private string ObtenerSerieRetencionActual()
    {
        var serieActual = $"{preview?.Estab}{preview?.PtoEmi}";
        if (!string.IsNullOrWhiteSpace(serieActual))
            return serieActual;

        return preview?.Serie ?? string.Empty;
    }

    private decimal ObtenerMaximoPorTipo(string? tipo)
    {
        if (preview == null)
            return 0m;

        var tipoNormalizado = (tipo ?? "").Trim().ToUpperInvariant();

        return tipoNormalizado switch
        {
            "RENTA" => Redondear2(preview.TotalSinImpuestos),
            "IVA" => Redondear2(preview.Iva),
            _ => 0m
        };
    }

    private void RecalcularRetencionDesdeBases(CompraRetValorDto r)
    {
        r.BasesParciales ??= new List<BaseParcialRetencionDto>();

        decimal porcentaje = Redondear2(r.PorcentajeRetencion ?? 0m);

        foreach (var item in r.BasesParciales)
        {
            if (item.Base < 0m)
                item.Base = 0m;

            item.Base = Redondear2(item.Base);
            item.ValorRetenido = Redondear2(item.Base * porcentaje / 100m);
        }

        decimal sumaBases = Redondear2(r.BasesParciales.Sum(x => x.Base));
        decimal sumaRetenida = Redondear2(r.BasesParciales.Sum(x => x.ValorRetenido));

        r.Base = sumaBases;
        r.Valor = porcentaje;
        r.ValorRetenido = sumaRetenida;
    }

    private void AjustarCamposBaseParcial(CompraRetValorDto r, int indiceEditado = 0)
    {
        r.BasesParciales ??= new List<BaseParcialRetencionDto>();

        if (r.BasesParciales.Count == 0)
        {
            r.BasesParciales.Add(new BaseParcialRetencionDto
            {
                Base = 0m,
                ValorRetenido = 0m
            });
        }

        string tipo = (r.Tipo ?? "").Trim().ToUpperInvariant();
        decimal maximo = ObtenerMaximoPorTipo(tipo);
        decimal porcentaje = Redondear2(r.PorcentajeRetencion ?? 0m);

        foreach (var item in r.BasesParciales)
        {
            if (item.Base < 0m)
                item.Base = 0m;

            item.Base = Redondear2(item.Base);
        }

        if (indiceEditado < 0 || indiceEditado >= r.BasesParciales.Count)
            indiceEditado = 0;

        decimal valorEditado = Redondear2(r.BasesParciales[indiceEditado].Base);

        if (valorEditado > maximo)
            valorEditado = maximo;

        var nuevasBases = new List<BaseParcialRetencionDto>
        {
            new BaseParcialRetencionDto
            {
                Base = valorEditado,
                ValorRetenido = Redondear2(valorEditado * porcentaje / 100m)
            }
        };

        decimal restante = Redondear2(maximo - valorEditado);

        if (restante > 0m)
        {
            nuevasBases.Add(new BaseParcialRetencionDto
            {
                Base = restante,
                ValorRetenido = Redondear2(restante * porcentaje / 100m)
            });
        }

        r.BasesParciales = nuevasBases;
    }

    private void OnBaseParcialChanged(CompraRetValorDto r, int index, string? valorTexto)
    {
        if (r == null)
            return;

        r.BasesParciales ??= new List<BaseParcialRetencionDto>();

        if (index < 0 || index >= r.BasesParciales.Count)
            return;

        if (!decimal.TryParse(
                valorTexto,
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out var nuevoValor))
        {
            nuevoValor = 0m;
        }

        if (nuevoValor < 0m)
            nuevoValor = 0m;

        r.BasesParciales[index].Base = Redondear2(nuevoValor);

        AjustarCamposBaseParcial(r, index);
        RecalcularRetencionDesdeBases(r);

        StateHasChanged();
    }

    private async Task BuscarPorSecuencialAsync()
    {
        try
        {
            mensaje = null;
            esError = false;
            mostrarLiquidacionesDropdown = false;

            if (string.IsNullOrWhiteSpace(textoBusquedaSecuencial))
            {
                mensaje = "Ingrese un número de liquidación de compra para buscar.";
                esError = true;
                return;
            }

            var previewLiquidacion = await BuscarPreviewLiquidacionDesdeListadoAsync(textoBusquedaSecuencial.Trim());
            if (previewLiquidacion != null)
            {
                await AplicarPreviewRetencionAsync(
                    previewLiquidacion,
                    $"Liquidación de compra encontrada con número {previewLiquidacion.Secuencial}.");
                return;
            }

            var previewEncontrado = await ComprasXmlService.BuscarPreviewPorSecuencialAsync(textoBusquedaSecuencial.Trim());

            if (previewEncontrado == null)
            {
                await InicializarPreviewVacioAsync(modoIngreso == "MANUAL");
                liquidacionCargadaParaRetencion = false;
                mensaje = $"No existe una liquidación de compra con el número {textoBusquedaSecuencial}. Importe el XML de liquidación.";
                esError = true;
                MostrarAvisoRapidoRetencion(mensaje, true);
                return;
            }

            if (previewEncontrado.TieneRetencionGenerada)
            {
                await InicializarPreviewVacioAsync(modoIngreso == "MANUAL");
                liquidacionCargadaParaRetencion = false;
                mensaje = $"La liquidación de compra {textoBusquedaSecuencial} ya tiene una retención registrada y no puede retenerse nuevamente.";
                esError = true;
                MostrarAvisoRapidoRetencion(mensaje, true);
                return;
            }

            preview = previewEncontrado;
            liquidacionCargadaParaRetencion = true;
            preview.Usuario = usuarioActual;
            preview.RucEmisor ??= preview.IdentificacionComprador ?? "";
            preview.IdentificacionComprador = preview.RucEmisor;
            if (!preview.YaImportado || string.IsNullOrWhiteSpace(preview.NumeroRetencionGenerado))
                await AplicarConfiguracionSecuenciaRetencionAsync();

            await DetectarProveedorActualAsync();
            _ = CargarCorreosOpcionalesProveedorEnSegundoPlanoAsync();
            preview.Retenciones ??= new List<CompraRetValorDto>();

            foreach (var ret in preview.Retenciones)
            {
                ret.BasesParciales ??= new List<BaseParcialRetencionDto>();

                if (ret.BasesParciales.Count == 0)
                {
                    var baseExistente = Redondear2(ret.Base ?? 0m);
                    var porcentaje = Redondear2(ret.PorcentajeRetencion ?? 0m);

                    ret.BasesParciales.Add(new BaseParcialRetencionDto
                    {
                        Base = baseExistente,
                        ValorRetenido = Redondear2(baseExistente * porcentaje / 100m)
                    });
                }

                AjustarCamposBaseParcial(ret, 0);
                RecalcularRetencionDesdeBases(ret);
            }

            mensaje = $"Liquidación de compra encontrada con número {preview.Secuencial}.";
            esError = false;
        }
        catch (Exception ex)
        {
            await InicializarPreviewVacioAsync(modoIngreso == "MANUAL");
            liquidacionCargadaParaRetencion = false;
            mensaje = ex.Message;
            esError = true;
            MostrarAvisoRapidoRetencion(mensaje, true);
        }
    }

