@code {
    [Parameter] public int? LiquidacionInicialId { get; set; }
    [Parameter] public bool ModoIntegrado { get; set; }
    [Parameter] public EventCallback OnCancelarIntegrado { get; set; }

    private enum ModoDescuentoRetencion
    {
        Porcentaje,
        Moneda
    }

    private int? usuarioActual;
    private string? mensaje;
    private bool esError;
    private bool guardando;
    private EmisionEstado? emisionEstado;
    private CompraXmlPreviewDto? preview;
    private bool mostrarModalSecuenciaInicial;
    private bool mostrarPreviewPdfRetencion;
    private string? urlPreviewPdfRetencion;
    private string tituloPreviewPdfRetencion = "Vista previa PDF temporal";
    private bool? usuarioYaEmitioAntes;
    private string secuenciaAnteriorManual = string.Empty;
    private string? errorSecuenciaInicial;
    private string textoGuardandoRetencion = "Guardando retencion...";
    private string? mensajeRapidoRetencion;
    private bool mensajeRapidoRetencionEsError;
    private int? retencionGeneradaSec;
    private string? retencionGeneradaPdfUrl;

    private string textoBusquedaSecuencial = "";
    private string modoIngreso = "MANUAL";

    private List<RetencionesService.RetencionBusquedaDto> resultadosBusqueda = new();
    private List<RetencionesService.RetencionBusquedaDto> retencionesIvaCatalogo = new();
    private List<RetencionesService.RetencionBusquedaDto> retencionesRentaCatalogo = new();
    private Dictionary<string, List<RetencionesService.RetencionBusquedaDto>> cacheRetenciones = new();
    private CompraRetValorDto? retencionEnEdicion;
    private bool estaCargando = false;
    private List<CompraXmlDetalleDto> productosSugeridos = new();
    private List<ProductoLookupDetalleDto>? sugerenciasProductosRetencion;
    private CompraXmlDetalleDto? filaBusquedaProductoRetencionActiva;
    private bool seleccionandoProductoRetencionDesdeLista;
    private int indiceSugerenciaProductoRetencionActiva = -1;
    private bool mostrarCatalogoProductosRetencion;
    private bool mostrarModalProductoRetencion;
    private Dictionary<CompraXmlDetalleDto, ModoDescuentoRetencion> modosDescuentoDetalleRetencion = new();
    private Dictionary<CompraXmlDetalleDto, decimal> porcentajesDescuentoDetalleRetencion = new();
    private List<LiquidacionCompraListDto> liquidacionesDisponibles = new();
    private List<LiquidacionProveedorLookupDto> sugerenciasProveedorBusqueda = new();
    private bool mostrarLiquidacionesDropdown;
    private string campoProveedorActivo = "";
    private string retDetalleSeccion = "DETALLE";
    private bool liquidacionCargadaParaRetencion;

    private bool mostrarPopupCodigos = false;
    private string tipoPopup = "IVA";
    private List<RetencionesService.RetencionBusquedaDto> codigosPopup = new();
    private bool mostrarHistorialRetenciones;
    private bool mostrarEditorRetencionesSeparado => false;
    private const int MaxCorreosOpcionalesRetencion = 4;
    private List<CorreoOpcionalRetencionInput> correosOpcionalesRetencion = new();
    private bool mostrarModalProveedorNuevo;
    private bool proveedorNoRegistradoDescartado;
    private bool continuarConProveedorSinRegistro;
    private bool proveedorRegistradoDetectado;
    private bool disposed;

    private sealed record RetencionResumenGrupo(
        string Titulo,
        List<CompraRetValorDto> Retenciones,
        decimal TotalBase,
        decimal TotalRetenido);
    private List<string> correosPersistidosProveedorRetencion = new();
    private List<CajaSerieResolucion> seriesDocumento = new();
    private readonly System.Threading.SemaphoreSlim previewInitLock = new(1, 1);

    private class CorreoOpcionalRetencionInput
    {
        public string Correo { get; set; } = string.Empty;
        public bool GuardarEnCliente { get; set; }
        public bool EsPersistidoCliente { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        PrepararPreviewVisualInicial();
        EmisionControlService.Changed += OnEmisionChanged;
        await CargarUsuarioActualAsync();
        await CargarEstadoEmisionAsync();
        seriesDocumento = await FacturacionService.GetSeriesFacturaHabilitadasAsync(usuarioActual ?? 0);

        if (LiquidacionInicialId is > 0)
        {
            await CargarLiquidacionDesdeListadoAsync(LiquidacionInicialId.Value);
            _ = CargarDatosRetencionEnSegundoPlanoAsync(cargarLiquidaciones: true, cargarCatalogos: true);
            if (!esError)
            {
                mensaje = $"Liquidacion de compra #{LiquidacionInicialId.Value} autorizada. Ya puedes completar y emitir la retencion.";
                MostrarAvisoRapidoRetencion(mensaje);
            }
            return;
        }

        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        var vieneDeLiquidacionGuardada = query.TryGetValue("liquidacionGuardada", out var liquidacionGuardadaVal) &&
            string.Equals(liquidacionGuardadaVal.ToString(), "1", StringComparison.OrdinalIgnoreCase);

        if (query.TryGetValue("liquidacion", out var liqVal) && !string.IsNullOrWhiteSpace(liqVal))
        {
            textoBusquedaSecuencial = liqVal.ToString();
            await BuscarPorSecuencialAsync();
            _ = CargarDatosRetencionEnSegundoPlanoAsync(cargarLiquidaciones: true, cargarCatalogos: true);
            if (vieneDeLiquidacionGuardada && !esError)
            {
                mensaje = $"Liquidacion de compra #{textoBusquedaSecuencial} guardada. Ya puedes emitir la retencion.";
                MostrarAvisoRapidoRetencion(mensaje);
            }
            return;
        }

        await InicializarPreviewVacioAsync(true);
        _ = CargarDatosRetencionEnSegundoPlanoAsync(cargarLiquidaciones: true, cargarCatalogos: true);
    }

    private async Task InicializarPreviewVacioAsync(bool manual)
    {
        if (disposed)
            return;

        await previewInitLock.WaitAsync();
        try
        {
            if (disposed)
                return;

            preview = await ComprasXmlService.CrearPreviewManualAsync();
            preview.Usuario = usuarioActual;
            preview.EsManual = manual;
            preview.Retenciones ??= new List<CompraRetValorDto>();
            preview.Detalles ??= new List<CompraXmlDetalleDto>();
            proveedorRegistradoDetectado = false;
            if (!preview.Detalles.Any())
                preview.Detalles.Add(ComprasXmlService.CrearDetalleManualVacio());

            if (manual)
                AsegurarFilaDetalleManualDisponible();

            preview.RucEmisor ??= string.Empty;
            preview.IdentificacionComprador = preview.RucEmisor;

            await AplicarSeriePreferidaManualAsync();
            await AplicarConfiguracionSecuenciaRetencionAsync();
            _ = CargarCorreosOpcionalesProveedorEnSegundoPlanoAsync();
        }
        finally
        {
            previewInitLock.Release();
        }
    }

    private Task AbrirHistorialRetencionesAsync()
    {
        mostrarHistorialRetenciones = true;
        return InvokeAsync(StateHasChanged);
    }

    private Task CerrarHistorialRetencionesAsync()
    {
        mostrarHistorialRetenciones = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task CargarLiquidacionesDisponiblesAsync()
    {
        if (usuarioActual is > 0)
        {
            var liquidaciones = await LiquidacionCompraService.ListarLiquidacionesUsuarioAsync(usuarioActual.Value);
            liquidacionesDisponibles = liquidaciones
                .Where(x => !x.TieneRetencion)
                .ToList();
        }
        else
        {
            liquidacionesDisponibles = new List<LiquidacionCompraListDto>();
        }
    }

    private IEnumerable<LiquidacionCompraListDto> LiquidacionesDropdown
    {
        get
        {
            var filtro = (textoBusquedaSecuencial ?? string.Empty).Trim();
            var query = liquidacionesDisponibles
                .Where(x => !x.TieneRetencion)
                .AsEnumerable();

            if (!string.IsNullOrWhiteSpace(filtro))
            {
                query = query.Where(x =>
                    x.NumeroDocumento.Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    x.Secuencial.Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    x.Proveedor.Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    x.IdentificacionProveedor.Contains(filtro, StringComparison.OrdinalIgnoreCase));
            }

            return query.Take(12);
        }
    }

    private void MostrarLiquidacionesDropdown()
    {
        mostrarLiquidacionesDropdown = true;
    }

    private void ToggleLiquidacionesDropdown()
    {
        mostrarLiquidacionesDropdown = !mostrarLiquidacionesDropdown;
    }

    private async Task SeleccionarLiquidacionAsync(LiquidacionCompraListDto liquidacion)
    {
        if (liquidacion.TieneRetencion)
        {
            mensaje = $"La liquidación {liquidacion.NumeroDocumento} ya tiene una retención registrada.";
            esError = true;
            mostrarLiquidacionesDropdown = false;
            return;
        }

        textoBusquedaSecuencial = liquidacion.NumeroDocumento;
        mostrarLiquidacionesDropdown = false;
        await CargarLiquidacionDesdeListadoAsync(liquidacion.CodFactura);
    }

    public void Dispose()
    {
        disposed = true;
        EmisionControlService.Changed -= OnEmisionChanged;
    }

    private void OnEmisionChanged()
    {
        if (disposed)
            return;

        _ = InvokeAsync(async () =>
        {
            await CargarEstadoEmisionAsync();
            if (disposed)
                return;

            StateHasChanged();
        });
    }

    private async Task BuscarProductosSugeridosAsync()
    {
        if (preview == null)
            return;

        productosSugeridos = await ComprasXmlService
            .ObtenerProductosSugeridosPorProveedorAsync(preview.RucProveedor ?? "");

        StateHasChanged();
    }

    private bool PuedeGuardar =>
        preview != null &&
        string.IsNullOrWhiteSpace(ObtenerErrorValidacionCompra());

    private bool PuedeIntentarGuardar =>
        preview != null &&
        PuedeEditarFormularioRetencion &&
        !BloqueadoPorSaldoDocumentosRetencion;

    private bool BloqueadoPorSaldoDocumentosRetencion =>
        emisionEstado?.RequiereCompraDocumentos == true &&
        preview?.Retenciones?.Any() == true;

    private string MensajeBloqueoDocumentos => emisionEstado?.Mensaje ?? EmisionControlService.MensajeSaldoAgotado;
    private bool ModoIngresoSeleccionado => modoIngreso is "XML" or "MANUAL";
    private bool PuedeEditarFormularioRetencion => ModoIngresoSeleccionado || liquidacionCargadaParaRetencion;
    private bool CamposFormularioBloqueados => !PuedeEditarFormularioRetencion || modoIngreso == "XML";
    private bool CamposComprobanteBaseSoloLectura => ModoIntegrado || CamposFormularioBloqueados || modoIngreso == "XML";
    private string DatosComprobanteKickerVisual => ModoIntegrado ? "LIQUIDACION AUTORIZADA" : DatosComprobanteKicker;
    private string DatosComprobanteDescripcionVisual => ModoIntegrado ? "Datos cargados desde la liquidacion de compra base." : DatosComprobanteDescripcion;
    private string DatosComprobanteKicker => modoIngreso == "MANUAL" ? "CAPTURA MANUAL" : modoIngreso == "XML" ? "DESDE XML" : "PENDIENTE";
    private string DatosComprobanteDescripcion => modoIngreso == "MANUAL"
        ? "Ingresa los datos de la liquidación de compra base."
        : modoIngreso == "XML"
            ? "Datos de la liquidación de compra base cargada desde XML."
            : "Selecciona XML, manual o una liquidacion para habilitar la edicion.";

    private void AgregarCorreoOpcionalRetencion()
    {
        if (correosOpcionalesRetencion.Count >= MaxCorreosOpcionalesRetencion)
            return;

        var correoPersistidoPendiente = correosPersistidosProveedorRetencion
            .FirstOrDefault(correoGuardado =>
                !correosOpcionalesRetencion.Any(x =>
                    string.Equals((x.Correo ?? string.Empty).Trim(), correoGuardado, StringComparison.OrdinalIgnoreCase)));

        if (!string.IsNullOrWhiteSpace(correoPersistidoPendiente))
        {
            correosOpcionalesRetencion.Add(new CorreoOpcionalRetencionInput
            {
                Correo = correoPersistidoPendiente,
                GuardarEnCliente = true,
                EsPersistidoCliente = true
            });
            return;
        }

        correosOpcionalesRetencion.Add(new CorreoOpcionalRetencionInput());
    }

    private void EliminarCorreoOpcionalRetencion(int index)
    {
        if (index < 0 || index >= correosOpcionalesRetencion.Count)
            return;

        correosOpcionalesRetencion.RemoveAt(index);
    }

    private void NormalizarCorreosOpcionalesRetencion()
    {
        foreach (var correo in correosOpcionalesRetencion)
            correo.Correo = (correo.Correo ?? string.Empty).Trim();
    }

    private List<FacturaCorreoDestinoDto> ObtenerCorreosOpcionalesRetencion()
    {
        NormalizarCorreosOpcionalesRetencion();

        return correosOpcionalesRetencion
            .Where(x => !string.IsNullOrWhiteSpace(x.Correo))
            .Select(x => new FacturaCorreoDestinoDto
            {
                Correo = x.Correo,
                GuardarEnCliente = x.EsPersistidoCliente ? false : x.GuardarEnCliente
            })
            .ToList();
    }

    private async Task CargarCorreosOpcionalesProveedorAsync()
    {
        correosOpcionalesRetencion = new();
        correosPersistidosProveedorRetencion = new();

        if (preview?.CodProveedor is null || preview.CodProveedor <= 0)
            return;

        correosPersistidosProveedorRetencion = (await ComprasXmlService.GetCorreosAdicionalesProveedorAsync(preview.CodProveedor.Value))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(MaxCorreosOpcionalesRetencion)
            .ToList();

        foreach (var correo in correosPersistidosProveedorRetencion)
        {
            correosOpcionalesRetencion.Add(new CorreoOpcionalRetencionInput
            {
                Correo = correo,
                GuardarEnCliente = true,
                EsPersistidoCliente = true
            });
        }
    }

    private async Task CargarCatalogosRetencionDetalleAsync()
    {
        retencionesIvaCatalogo = await RetencionesService.ListarPorTipoAsync("IVA") ?? new();
        retencionesRentaCatalogo = await RetencionesService.ListarPorTipoAsync("RENTA") ?? new();
    }

    private async Task CargarDatosRetencionEnSegundoPlanoAsync(bool cargarLiquidaciones, bool cargarCatalogos)
    {
        try
        {
            if (cargarLiquidaciones)
                await CargarLiquidacionesDisponiblesAsync();

            if (cargarCatalogos)
                await CargarCatalogosRetencionDetalleAsync();

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"No se pudieron cargar datos secundarios de retencion: {ex.Message}");
        }
    }

    private async Task CargarCorreosOpcionalesProveedorEnSegundoPlanoAsync()
    {
        try
        {
            await CargarCorreosOpcionalesProveedorAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"No se pudieron cargar correos opcionales de retencion: {ex.Message}");
        }
    }

    private bool MostrarAvisoProveedorNoRegistrado =>
        preview != null &&
        modoIngreso == "MANUAL" &&
        !ProveedorRegistradoActual &&
        (ProveedorIdentificacionCompleta || (campoProveedorActivo != "ruc" && ProveedorRazonSocialSinCoincidencias));

    private bool ProveedorRegistradoActual =>
        (preview?.CodProveedor ?? 0) > 0 || proveedorRegistradoDetectado;

    private bool ProveedorIdentificacionCompleta
    {
        get
        {
            var identificacion = SoloDigitos(preview?.RucProveedor);
            return identificacion.Length is 10 or 13;
        }
    }

