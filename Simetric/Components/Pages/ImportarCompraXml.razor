    private decimal Redondear2(decimal valor)
    {
        return Math.Round(valor, 2, MidpointRounding.AwayFromZero);
    }

    private decimal ObtenerIva15()
    {
        if (preview == null)
            return 0m;

        var iva15 = preview.Iva - preview.Iva5 - preview.Iva8;
        return Math.Round(iva15, 2, MidpointRounding.AwayFromZero);
    }

    private decimal ObtenerTotalRetencionTipo(string tipo)
    {
        return Redondear2((preview?.Retenciones ?? new List<CompraRetValorDto>())
            .Where(x => string.Equals((x.Tipo ?? "").Trim(), tipo, StringComparison.OrdinalIgnoreCase))
            .Sum(x => x.ValorRetenido ?? 0m));
    }

    private static bool EsDetalleCompraVacio(CompraXmlDetalleDto item)
    {
        return string.IsNullOrWhiteSpace(item.CodPrincipal) &&
               string.IsNullOrWhiteSpace(item.Descripcion) &&
               item.PrecioUnitario == 0m &&
               item.Descuento == 0m &&
               item.ValorTotal == 0m;
    }

    private void AsegurarFilaDetalleManualDisponible()
    {
        if (preview?.Detalles == null || modoIngreso != "MANUAL")
            return;

        if (!preview.Detalles.Any() || !EsDetalleCompraVacio(preview.Detalles.Last()))
            preview.Detalles.Add(ComprasXmlService.CrearDetalleManualVacio());
    }

    private void OnDecimalChanged(Action<decimal> setter, string? texto)
    {
        if (preview == null)
            return;

        if (!decimal.TryParse(
                texto,
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out var valor))
        {
            valor = 0m;
        }

        setter(valor);

        if (preview.EsManual)
        {
            ComprasXmlService.RecalcularTotalesManual(preview);
        }

        StateHasChanged();
    }

    private async Task AplicarConfiguracionSecuenciaRetencionAsync()
    {
        if (preview == null || usuarioActual is not > 0)
            return;

        var estado = await InitialSequencePromptService.GetStateAsync(
            usuarioActual.Value,
            "retencion",
            ObtenerSerieRetencionActual());
        if (!estado.Initialized)
        {
            mostrarModalSecuenciaInicial = true;
            preview.NumeroRetencionGenerado = "000000001";
            return;
        }

        mostrarModalSecuenciaInicial = false;
        preview.NumeroRetencionGenerado = estado.HadPreviousDocuments
            ? InitialSequencePromptService.GetNextSequenceFromPrevious(estado.PreviousSequence)
            : "000000001";
    }

    private void OnCambioRespuestaSecuencia(bool? value)
    {
        usuarioYaEmitioAntes = value;
        errorSecuenciaInicial = null;

        if (value != true)
            secuenciaAnteriorManual = string.Empty;
    }

    private void OnSecuenciaAnteriorManualChanged(string value)
    {
        secuenciaAnteriorManual = value ?? string.Empty;
        errorSecuenciaInicial = null;
    }

    private async Task ConfirmarSecuenciaInicialAsync()
    {
        errorSecuenciaInicial = null;

        if (preview == null || usuarioActual is not > 0)
            return;

        if (usuarioYaEmitioAntes == null)
        {
            errorSecuenciaInicial = "Debes indicar si ya habias registrado compras manuales antes.";
            return;
        }

        var secuenciaNormalizada = string.Empty;

        if (usuarioYaEmitioAntes == true &&
            !InitialSequencePromptService.TryNormalizeSequence(secuenciaAnteriorManual, out secuenciaNormalizada))
        {
            errorSecuenciaInicial = "Ingresa una secuencia valida de hasta 9 digitos.";
            return;
        }

        var estado = new InitialSequencePromptState
        {
            Initialized = true,
            HadPreviousDocuments = usuarioYaEmitioAntes.Value,
            PreviousSequence = usuarioYaEmitioAntes.Value ? secuenciaNormalizada : string.Empty
        };

        await InitialSequencePromptService.SaveStateAsync(
            usuarioActual.Value,
            "retencion",
            ObtenerSerieRetencionActual(),
            estado);

        secuenciaAnteriorManual = secuenciaNormalizada;
        mostrarModalSecuenciaInicial = false;
        preview.NumeroRetencionGenerado = usuarioYaEmitioAntes.Value
            ? InitialSequencePromptService.GetNextSequenceFromPrevious(secuenciaNormalizada)
            : "000000001";
    }

    private async Task AbrirPreviewPdfRetencion()
    {
        if (preview == null || !TieneRetencionesSeleccionadas())
            return;

        mensaje = null;
        esError = false;
        tituloPreviewPdfRetencion = "Vista previa PDF temporal";
        mostrarPreviewPdfRetencion = true;
        urlPreviewPdfRetencion = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var rutaTemporal = await RetencionPdfService.GenerarPdfRetencionTemporalAsync(ConstruirVistaPreviaPdfRetencion());
            urlPreviewPdfRetencion = $"{rutaTemporal}?v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";
        }
        catch (Exception ex)
        {
            urlPreviewPdfRetencion = null;
            mostrarPreviewPdfRetencion = false;
            mensaje = $"No se pudo abrir la vista previa del PDF: {ex.Message}";
            esError = true;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

