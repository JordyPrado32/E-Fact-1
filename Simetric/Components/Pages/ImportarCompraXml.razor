    private void SeleccionarRetencion(CompraRetValorDto r, RetencionesService.RetencionBusquedaDto seleccion)
    {
        if (preview == null)
            return;

        string tipo = (r.Tipo ?? "").Trim().ToUpperInvariant();
        decimal porcentaje = seleccion.Valor ?? 0m;
        decimal maximo = ObtenerMaximoPorTipo(tipo);

        r.PorcentajeRetencion = porcentaje;
        r.Valor = porcentaje;
        r.DescripcionRet = seleccion.Descripcion;

        r.CodigoRetencion = seleccion.Id ?? string.Empty;

        if (int.TryParse(new string(seleccion.Id.Where(char.IsDigit).ToArray()), out var idNum))
            r.IdRet = idNum;

        r.BasesParciales = new List<BaseParcialRetencionDto>
        {
            new BaseParcialRetencionDto
            {
                Base = maximo,
                ValorRetenido = Redondear2(maximo * porcentaje / 100m)
            }
        };

        RecalcularRetencionDesdeBases(r);

        resultadosBusqueda.Clear();
        retencionEnEdicion = r;
        StateHasChanged();
    }

    private void OnRetencionDetalleChanged(CompraXmlDetalleDto item, string tipo, string? codigo)
    {
        if (item == null)
            return;

        var catalogo = string.Equals(tipo, "IVA", StringComparison.OrdinalIgnoreCase)
            ? retencionesIvaCatalogo
            : retencionesRentaCatalogo;
        var seleccion = catalogo.FirstOrDefault(x => string.Equals(x.Id, codigo, StringComparison.Ordinal));
        var valorRetencion = ObtenerValorRetencionSeleccionada(tipo, seleccion);

        if (string.Equals(tipo, "IVA", StringComparison.OrdinalIgnoreCase))
        {
            item.RetencionIvaCodigo = seleccion?.Id ?? string.Empty;
            item.RetencionIvaDescripcion = seleccion?.Descripcion ?? string.Empty;
            item.RetencionIvaPorcentaje = valorRetencion;
        }
        else
        {
            item.RetencionRentaCodigo = seleccion?.Id ?? string.Empty;
            item.RetencionRentaDescripcion = seleccion?.Descripcion ?? string.Empty;
            item.RetencionRentaPorcentaje = valorRetencion;
        }

        SincronizarRetencionesDesdeDetalles();
    }

    private void SincronizarRetencionesDesdeDetalles()
    {
        if (preview?.Detalles == null)
            return;

        foreach (var item in preview.Detalles)
        {
            item.RetencionIvaValor = Redondear2(ObtenerBaseRetencionDetalle(item, "IVA") * item.RetencionIvaPorcentaje / 100m);
            item.RetencionRentaValor = Redondear2(ObtenerBaseRetencionDetalle(item, "RENTA") * item.RetencionRentaPorcentaje / 100m);
        }

        var retenciones = new List<CompraRetValorDto>();
        retenciones.AddRange(CrearRetencionesDetalle("IVA"));
        retenciones.AddRange(CrearRetencionesDetalle("RENTA"));
        preview.Retenciones = retenciones;
        StateHasChanged();
    }

    private IEnumerable<CompraRetValorDto> CrearRetencionesDetalle(string tipo)
    {
        if (preview?.Detalles == null)
            return Enumerable.Empty<CompraRetValorDto>();

        return preview.Detalles
            .Select(item => new
            {
                Codigo = tipo == "IVA" ? item.RetencionIvaCodigo : item.RetencionRentaCodigo,
                Descripcion = tipo == "IVA" ? item.RetencionIvaDescripcion : item.RetencionRentaDescripcion,
                Porcentaje = tipo == "IVA" ? item.RetencionIvaPorcentaje : item.RetencionRentaPorcentaje,
                Base = ObtenerBaseRetencionDetalle(item, tipo),
                Valor = tipo == "IVA" ? item.RetencionIvaValor : item.RetencionRentaValor
            })
            .Where(x => !string.IsNullOrWhiteSpace(x.Codigo))
            .GroupBy(x => new { x.Codigo, x.Descripcion, x.Porcentaje })
            .Select(g =>
            {
                var baseTotal = Redondear2(g.Sum(x => x.Base));
                var valorTotal = Redondear2(g.Sum(x => x.Valor));
                return new CompraRetValorDto
                {
                    Tipo = tipo,
                    IdRet = int.TryParse(new string(g.Key.Codigo.Where(char.IsDigit).ToArray()), out var id) ? id : (int?)null,
                    CodigoRetencion = g.Key.Codigo,
                    DescripcionRet = g.Key.Descripcion,
                    Valor = g.Key.Porcentaje,
                    PorcentajeRetencion = g.Key.Porcentaje,
                    Base = baseTotal,
                    ValorRetenido = valorTotal,
                    BasesParciales = new List<BaseParcialRetencionDto>
                    {
                        new() { Base = baseTotal, ValorRetenido = valorTotal }
                    }
                };
            })
            .ToList();
    }

