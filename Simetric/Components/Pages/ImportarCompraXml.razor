        await LimpiarTodo();
    }

    private string? ObtenerErrorValidacionCompra()
    {
        if (preview == null)
            return "No hay una compra cargada para guardar.";

        if (BloqueadoPorSaldoDocumentosRetencion)
            return MensajeBloqueoDocumentos;

        if (!preview.ExisteEmisor)
            return "No se encontró un emisor activo en el sistema para esta compra.";

        preview.Estab = SoloDigitos(preview.Estab);
        if (preview.Estab.Length != 3)
            return "El establecimiento debe tener exactamente 3 dígitos.";

        preview.PtoEmi = SoloDigitos(preview.PtoEmi);
        if (preview.PtoEmi.Length != 3)
            return "El punto de emisión debe tener exactamente 3 dígitos.";

        preview.Secuencial = SoloDigitos(preview.Secuencial);
        if (string.IsNullOrWhiteSpace(preview.Secuencial) || preview.Secuencial.Length > 9)
            return "El numero de compra debe contener entre 1 y 9 digitos.";

        if (preview.FechaEmision == null)
            return "Debes seleccionar la fecha de emisión.";

        if (preview.FechaEmision.Value.Date > DateTime.Today)
            return "La fecha de emisión no puede ser futura.";

        preview.RucProveedor = SoloDigitos(preview.RucProveedor);
        if (preview.RucProveedor.Length is < 10 or > 13)
            return "La identificación del proveedor debe tener entre 10 y 13 dígitos.";

        preview.RazonSocialProveedor = (preview.RazonSocialProveedor ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(preview.RazonSocialProveedor))
            return "Debes ingresar la razón social del proveedor.";

        preview.DireccionProveedor = (preview.DireccionProveedor ?? string.Empty).Trim();
        if (preview.EsManual && string.IsNullOrWhiteSpace(preview.DireccionProveedor))
            return "Debes ingresar la dirección del proveedor.";

        preview.TelefonoFijoProveedor = (preview.TelefonoFijoProveedor ?? string.Empty).Trim();

        preview.TelefonoProveedor = (preview.TelefonoProveedor ?? string.Empty).Trim();

        preview.EmailProveedor = (preview.EmailProveedor ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(preview.EmailProveedor) &&
            !EsCorreoValido(preview.EmailProveedor))
            return "El correo del proveedor no tiene un formato válido.";

        preview.RucEmisor = SoloDigitos(preview.RucEmisor);
        if (preview.RucEmisor.Length != 13)
            return "El RUC del emisor debe tener 13 dígitos.";

        preview.TipoIdentificacionComprador = string.IsNullOrWhiteSpace(preview.TipoIdentificacionComprador)
            ? "04"
            : preview.TipoIdentificacionComprador.Trim();

        preview.FormaPago = string.IsNullOrWhiteSpace(preview.FormaPago)
            ? "20"
            : preview.FormaPago.Trim();

        if (preview.ObligadoContabilidad is not ("SI" or "NO"))
            return "Debes indicar si el emisor está obligado a llevar contabilidad.";

        preview.NumeroAutorizacion = string.IsNullOrWhiteSpace(preview.NumeroAutorizacion)
            ? (preview.ClaveAcceso ?? string.Empty).Trim()
            : preview.NumeroAutorizacion.Trim();
        if (string.IsNullOrWhiteSpace(preview.NumeroAutorizacion))
            return "No se pudo resolver automaticamente la autorizacion de la compra.";

        if (!preview.NumeroAutorizacion.All(char.IsDigit))
            return "La autorizacion de la compra debe contener solo numeros.";

        if (preview.NumeroAutorizacion.Length is < 10 or > 49)
            return "La autorizacion de la compra debe tener entre 10 y 49 digitos.";

        preview.FechaAutorizacionSri = string.IsNullOrWhiteSpace(preview.FechaAutorizacionSri)
            ? (preview.FechaEmision ?? DateTime.Today).ToString("dd/MM/yyyy")
            : preview.FechaAutorizacionSri.Trim();
        if (string.IsNullOrWhiteSpace(preview.FechaAutorizacionSri))
            return "No se pudo resolver automaticamente la fecha de autorizacion del SRI.";

        if (!EsFechaValida(preview.FechaAutorizacionSri))
            return "La fecha de autorizacion del SRI no tiene un formato valido.";

        var detalles = (preview.Detalles ?? new List<CompraXmlDetalleDto>())
            .Where(x => !EsDetalleCompraVacio(x))
            .ToList();
        if (!detalles.Any())
            return "Debes agregar al menos un detalle en la compra.";

        for (int i = 0; i < detalles.Count; i++)
        {
            var item = detalles[i];
            item.CodPrincipal = (item.CodPrincipal ?? string.Empty).Trim();
            item.CodAuxiliar = (item.CodAuxiliar ?? string.Empty).Trim();
            item.Descripcion = (item.Descripcion ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(item.Descripcion))
                return $"En el detalle #{i + 1} la descripción es obligatoria.";

            if (item.Cantidad <= 0m)
                return $"En el detalle #{i + 1} la cantidad debe ser mayor a cero.";

            if (item.PrecioUnitario <= 0m)
                return $"En el detalle #{i + 1} el precio unitario debe ser mayor a cero.";

            if (item.Descuento < 0m)
                return $"En el detalle #{i + 1} el descuento no puede ser negativo.";

            var subtotalBruto = item.Cantidad * item.PrecioUnitario;
            if (item.Descuento > subtotalBruto)
                return $"En el detalle #{i + 1} el descuento no puede ser mayor al subtotal.";

            if (preview.EsManual && item.Tarifa is not (0 or 5 or 8 or 15))
                return $"En el detalle #{i + 1} debes seleccionar una tarifa de IVA válida.";
        }

        return null;
    }

    private static string SoloDigitos(string? valor) =>
        new string((valor ?? string.Empty).Where(char.IsDigit).ToArray());

    private string NumeroLiquidacionInputVisual =>
        FormatearNumeroLiquidacionInput(string.Concat(preview?.Estab, preview?.PtoEmi, preview?.Secuencial));

    private async Task OnNumeroLiquidacionInput(ChangeEventArgs e)
    {
        if (preview == null)
            return;

        var digitos = SoloDigitos(e.Value?.ToString());
        if (digitos.Length > 15)
            digitos = digitos[..15];

        preview.Estab = digitos.Length >= 3 ? digitos[..3] : digitos;
        preview.PtoEmi = digitos.Length > 3 ? digitos.Substring(3, Math.Min(3, digitos.Length - 3)) : string.Empty;
        preview.Secuencial = digitos.Length > 6 ? digitos[6..] : string.Empty;
        await AplicarConfiguracionSecuenciaRetencionAsync();
    }

    private void OnRucEmisorInput(ChangeEventArgs e)
    {
        if (preview == null)
            return;

        var valor = e.Value?.ToString() ?? string.Empty;
        preview.RucEmisor = valor;
        preview.IdentificacionComprador = valor;
    }

    private static string FormatearNumeroLiquidacionInput(string? valor)
    {
        var digitos = SoloDigitos(valor);
        if (digitos.Length <= 3)
            return digitos;

        if (digitos.Length <= 6)
            return $"{digitos[..3]}-{digitos[3..]}";

        return $"{digitos[..3]}-{digitos.Substring(3, 3)}-{digitos[6..]}";
    }

    private static bool EsCorreoValido(string correo)
    {
        try
        {
            _ = new System.Net.Mail.MailAddress(correo);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool EsFechaValida(string valor)
    {
        var formatos = new[] { "dd/MM/yyyy", "dd-MM-yyyy", "yyyy-MM-dd", "MM/dd/yyyy" };
        return DateTime.TryParseExact(
                   valor,
                   formatos,
                   System.Globalization.CultureInfo.InvariantCulture,
                   System.Globalization.DateTimeStyles.None,
                   out _) ||
               DateTime.TryParse(
                   valor,
                   new System.Globalization.CultureInfo("es-EC"),
                   System.Globalization.DateTimeStyles.None,
                   out _);
    }

