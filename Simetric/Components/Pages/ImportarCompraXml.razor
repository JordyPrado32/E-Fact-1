                            <small class="ret-header-note">Ingreso manual o selección desde catálogo</small>
                        </div>

                        <div class="ret-toolbar-actions">
                            <span class="import-count-chip import-count-chip-soft">@preview.Retenciones.Count retención(es)</span>

                            <button type="button" class="n-btn-link ret-toolbar-btn ret-toolbar-btn-outline" @onclick="AbrirPopupCodigos">
                                <i class="bi bi-list-ul"></i>
                                <span>Ver códigos</span>
                            </button>

                            <button type="button" class="n-btn-primary ret-toolbar-btn" @onclick="AgregarRetencion">
                                <i class="bi bi-plus-circle"></i>
                                <span>Agregar</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="n-card-body ret-card-body compact-card-body">
                    @if (preview.Retenciones.Count > 0)
                    {
                        <div class="ret-selected-summary">
                            @if (TieneRetencionesSeleccionadas())
                            {
                                @foreach (var grupoResumen in ObtenerGruposResumenRetencion())
                                {
                                    <div class="ret-summary-block">
                                        <div class="ret-summary-title">@grupoResumen.Titulo</div>
                                        <div class="ret-summary-table-wrap">
                                            <table class="table table-sm align-middle mb-0 ret-summary-table">
                                                <thead>
                                                    <tr>
                                                        <th>Retención</th>
                                                        <th class="text-end">Porcentaje</th>
                                                        <th class="text-end">Base Imponible</th>
                                                        <th class="text-end">Valor Retención</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var retResumen in grupoResumen.Retenciones)
                                                    {
                                                        <tr>
                                                            <td>@retResumen.DescripcionRet</td>
                                                            <td class="text-end">@((retResumen.PorcentajeRetencion ?? 0m).ToString("N2"))%</td>
                                                            <td class="text-end">@((retResumen.Base ?? 0m).ToString("N2"))</td>
                                                            <td class="text-end fw-bold">@((retResumen.ValorRetenido ?? 0m).ToString("N2"))</td>
                                                        </tr>
                                                    }
                                                    <tr class="ret-summary-total-row">
                                                        <td colspan="2" class="text-end">TOTAL:</td>
                                                        <td class="text-end">@grupoResumen.TotalBase.ToString("N2")</td>
                                                        <td class="text-end">@grupoResumen.TotalRetenido.ToString("N2")</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="ret-summary-empty">Aún no has seleccionado retenciones para IVA o renta.</div>
                            }
                        </div>

                        <div class="ret-grid">
                            @for (int i = 0; i < preview.Retenciones.Count; i++)
                            {
                                var r = preview.Retenciones[i];
                                var indexActual = i;

                                <div class="ret-item-card" @onclick="() => retencionEnEdicion = r">
                                    <div class="ret-item-top">
                                        <div class="ret-item-title">
                                            <i class="bi bi-receipt me-2"></i>
                                            @ObtenerTituloRetencion(r)
                                        </div>

                                        <button type="button"
                                                class="btn-delete-ret"
                                                title="Eliminar retención"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => EliminarRetencion(indexActual)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    <div class="ret-form-grid">
                                        <div class="ret-field ret-field-span-3">
                                            <label class="ret-label">Tipo</label>
                                            <InputSelect Value="@(r.Tipo ?? "")"
                                                         ValueChanged="@(async (string v) => await OnTipoChanged(r, v))"
                                                         ValueExpression="() => r.Tipo"
                                                         class="ret-input"
                                                         @onclick:stopPropagation="true">
                                                <option value="">Seleccione</option>
                                                <option value="IVA">IVA</option>
                                                <option value="RENTA">RENTA</option>
                                            </InputSelect>
                                        </div>

                                        <div class="ret-field ret-field-span-9">
                                            <label class="ret-label">Buscar código o descripción</label>
                                            <div class="ret-search-box">
                                                <i class="bi bi-search ret-search-glyph"></i>
                                                <input type="text"
                                                       class="ret-input ret-search-input"
                                                       placeholder="Escribe código o nombre..."
                                                       disabled="@string.IsNullOrWhiteSpace(r.Tipo)"
                                                       @onclick:stopPropagation="true"
                                                       @onfocus="@(() => retencionEnEdicion = r)"
                                                       @oninput="(e) => BuscarRetencionesDinamico(r, e.Value?.ToString())" />

                                                @if (resultadosBusqueda.Any() && retencionEnEdicion == r)
                                                {
                                                    <div class="search-results-overlay">
                                                        @foreach (var sugerencia in resultadosBusqueda)
                                                        {
                                                            <div class="search-item" @onclick="() => SeleccionarRetencion(r, sugerencia)">
                                                                <span class="badge @(r.Tipo == "IVA" ? "bg-info" : "bg-primary") me-2">
                                                                    @sugerencia.Id
                                                                </span>
                                                                <span class="text-dark">@sugerencia.Descripcion</span>
                                                                <small class="text-muted ms-auto">@((sugerencia.Valor ?? 0m).ToString("N2"))%</small>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="ret-field ret-field-span-6">
                                            <label class="ret-label">Nombre de retención</label>
                                            <InputText @bind-Value="r.DescripcionRet" class="ret-input" readonly />
                                        </div>

                                        <div class="ret-field ret-field-span-3">
                                            <label class="ret-label">Porcentaje (%)</label>
                                            <input class="ret-input text-end"
                                                   value="@((r.PorcentajeRetencion ?? 0m).ToString("N2"))"
                                                   readonly />
                                        </div>

                                        <div class="ret-field ret-field-span-3">
                                            <label class="ret-label">Valor retenido</label>
                                            <input class="ret-input text-end fw-bold"
                                                   value="@((r.ValorRetenido ?? 0m).ToString("N2"))"
                                                   readonly />
                                        </div>

                                        <div class="ret-field ret-field-span-12">
                                            <label class="ret-label">Base imponible / parciales</label>

                                            @if (r.BasesParciales != null && r.BasesParciales.Count > 0)
                                            {
                                                <div class="ret-partials-grid">
                                                    @for (int j = 0; j < r.BasesParciales.Count; j++)
                                                    {
                                                        var idxBase = j;

                                                        <div class="ret-partial-card">
                                                            <span class="ret-partial-caption">Parcial @(idxBase + 1)</span>

                                                            <div class="ret-partial-row">
                                                                <div class="ret-partial-field">
                                                                    <span class="ret-mini-label">Base</span>
                                                                    <input type="number"
                                                                           step="0.01"
                                                                           min="0"
                                                                           class="ret-input text-end"
                                                                           value="@r.BasesParciales[idxBase].Base.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                                           @onclick:stopPropagation="true"
                                                                           @oninput="(e) => OnBaseParcialChanged(r, idxBase, e.Value?.ToString())" />
                                                                </div>

                                                                <div class="ret-partial-field">
                                                                    <span class="ret-mini-label">Retenido</span>
                                                                    <input class="ret-input text-end fw-bold"
                                                                           value="@r.BasesParciales[idxBase].ValorRetenido.ToString("N2")"
                                                                           readonly />
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            <small class="ret-summary-note">
                                                Base total: @((r.Base ?? 0m).ToString("N2"))
                                            </small>
                                        </div>

                                        @if (TieneErrorRetencion(r))
                                        {
                                            <div class="ret-field ret-field-span-12">
                                                <div class="ret-error">
                                                    @ObtenerErrorRetencion(r)
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="ret-empty">
                            <div class="ret-empty-icon">
                                <i class="bi bi-percent"></i>
                            </div>
                            <div class="ret-empty-title">No hay retenciones agregadas</div>
                            <div class="ret-empty-text">Presiona “Agregar” para registrar una nueva retención.</div>
                        </div>
                    }
                </div>
            </div>
            }

            @{
                var subtotalBrutoCompra = preview.TotalSinImpuestos + preview.TotalDescuento;
                var iva15Compra = ObtenerIva15();
                var retencionIvaTotal = ObtenerTotalRetencionTipo("IVA");
                var retencionRentaTotal = ObtenerTotalRetencionTipo("RENTA");
                var totalRetenidoCompra = retencionIvaTotal + retencionRentaTotal;
            }

            @if (!ModoIntegrado)
            {
            <div class="row mt-3 justify-content-end ret-integrated-total-row">
                <div class="col-lg-4 col-xl-4">
                    <div class="docs-total-card ret-total-card">
                        <div class="docs-total-card-header">
                            <span>Resumen</span>
                            <h6></h6>
                        </div>

                        <div class="docs-total-fiscal-list ret-total-fiscal-list @(ModoIntegrado ? "d-none" : string.Empty)">
                            <div class="docs-total-fiscal-row">
                                <span>SUBTOTAL:</span>
                                <strong>$ @subtotalBrutoCompra.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-discount">
                                <span>DESCUENTO:</span>
                                <strong>$ @preview.TotalDescuento.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row">
                                <span>ICE:</span>
                                <strong>$ @preview.Detalles.Sum(x => x.ValorICE).ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                <span>IVA:</span>
                                <strong>$ @preview.Iva.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row">
                                <span>IVA 0%:</span>
                                <strong>$ @(0m.ToString("N2"))</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                <span>TOTAL:</span>
                                <strong>$ @preview.ImporteTotal.ToString("N2")</strong>
                            </div>
                        </div>

                        <div class="docs-total-fiscal-list ret-total-fiscal-list @(ModoIntegrado ? string.Empty : "d-none")">
                            <div class="docs-total-fiscal-row">
                                <span>SUBTOTAL BRUTO</span>
                                <strong>$ @subtotalBrutoCompra.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-discount">
                                <span>DESCUENTO TOTAL</span>
                                <strong>$ @preview.TotalDescuento.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row">
                                <span>BASE IMPONIBLE</span>
                                <strong>$ @preview.TotalSinImpuestos.ToString("N2")</strong>
                            </div>

                            @if (preview.Subtotal0 > 0m)
                            {
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL 0%</span>
                                    <strong>$ @preview.Subtotal0.ToString("N2")</strong>
                                </div>
                            }

                            @if (preview.Subtotal5 > 0m)
                            {
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL 5%</span>
                                    <strong>$ @preview.Subtotal5.ToString("N2")</strong>
                                </div>
                            }

                            @if (preview.Subtotal8 > 0m)
                            {
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL 8%</span>
                                    <strong>$ @preview.Subtotal8.ToString("N2")</strong>
                                </div>
                            }

                            @if (preview.Subtotal12 > 0m)
                            {
                                <div class="docs-total-fiscal-row">
                                    <span>SUBTOTAL 15%</span>
                                    <strong>$ @preview.Subtotal12.ToString("N2")</strong>
                                </div>
                            }

                            @if (preview.Iva5 > 0m)
                            {
                                <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                    <span>IVA 5%</span>
                                    <strong>$ @preview.Iva5.ToString("N2")</strong>
                                </div>
                            }

                            @if (preview.Iva8 > 0m)
                            {
                                <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                    <span>IVA 8%</span>
                                    <strong>$ @preview.Iva8.ToString("N2")</strong>
                                </div>
                            }

                            @if (iva15Compra > 0m)
                            {
                                <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                    <span>IVA 15%</span>
                                    <strong>$ @iva15Compra.ToString("N2")</strong>
                                </div>
                            }

                            <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                <span>IVA</span>
                                <strong>$ @preview.Iva.ToString("N2")</strong>
                            </div>
                            <div class="docs-total-fiscal-row docs-total-fiscal-ret">
                                <span>RETENCIÓN IVA</span>
                                <strong>$ @retencionIvaTotal.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-ret">
                                <span>RETENCIÓN RENTA</span>
                                <strong>$ @retencionRentaTotal.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                <span>TOTAL RETENCION</span>
                                <strong>$ @totalRetenidoCompra.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                <span>TOTAL</span>
                                <strong>$ @preview.ImporteTotal.ToString("N2")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            }

            @if (ModoIntegrado)
            {
            <div class="row mt-4">
                <div class="col-lg-7 mb-3"></div>

                <div class="col-lg-5">
                    <div class="docs-total-card ret-total-card">
                        <div class="docs-total-card-header">
                            <span>Resumen total</span>
                            <h6></h6>
                        </div>

                        <div class="docs-total-fiscal-list ret-total-fiscal-list">
                            <div class="docs-total-fiscal-row">
                                <span>SUBTOTAL</span>
                                <strong>$ @subtotalBrutoCompra.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-discount">
                                <span>DESCUENTO</span>
                                <strong>$ @preview.TotalDescuento.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row">
                                <span>BASE IMPONIBLE</span>
                                <strong>$ @preview.TotalSinImpuestos.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                <span>IVA</span>
                                <strong>$ @preview.Iva.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                <span>TOTAL LIQUIDACION</span>
                                <strong>$ @preview.ImporteTotal.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-ret">
                                <span>RETENCION IVA</span>
                                <strong>$ @retencionIvaTotal.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-ret">
                                <span>RETENCION RENTA</span>
                                <strong>$ @retencionRentaTotal.ToString("N2")</strong>
                            </div>

                            <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                <span>TOTAL RETENCION</span>
                                <strong>$ @totalRetenidoCompra.ToString("N2")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            }

            <div class="d-flex justify-content-end gap-2 pb-3 compact-footer-actions">
                <button type="button" class="n-btn n-btn-secondary" @onclick="CancelarRetencionAsync">
                    <i class="bi bi-x-circle me-2"></i> Cancelar
                </button>

                <button type="button"
                        class="n-btn n-btn-secondary"
                        @onclick="AbrirPreviewPdfRetencion"
                        disabled="@(preview == null || !TieneRetencionesSeleccionadas())">
                    <i class="bi bi-eye me-2"></i> Previsualizar PDF
                </button>

                <button type="button"
                        class="n-btn n-btn-primary"
                        data-tour="compras.save"
                        @onclick="GuardarCompraAsync"
                        disabled="@(!PuedeIntentarGuardar || guardando)">
                    <i class="bi bi-save me-2"></i>
                    @(guardando ? "Guardando..." : "Generar Retención")
                </button>
            </div>

        </div>
    }
</div>

@if (mostrarPreviewPdfRetencion && preview != null)
{
    <div class="n-product-modal-backdrop" @onclick="CerrarPreviewPdfRetencionAsync"></div>
    <div class="n-product-modal-shell n-pdf-preview-shell" role="dialog" aria-modal="true" aria-labelledby="pdfPreviewRetencionTitulo">
        <div class="n-modal n-product-modal-content n-pdf-preview-modal" style="width: min(96vw, 1280px); height: min(94vh, 920px); max-width: 96vw; max-height: 94vh; display: flex; flex-direction: column;">
            <div class="n-modal-header">
                <div class="n-modal-header-main n-modal-header-main-product">
                    <div class="n-modal-copy n-modal-copy-product">
                        <div class="n-modal-title-row">
                            <div id="pdfPreviewRetencionTitulo" class="n-modal-title">@tituloPreviewPdfRetencion</div>
                            <span class="n-modal-head-chip">Retención</span>
                        </div>
                        <p class="n-modal-subtitle n-product-create-subtitle">
                            Vista ampliada del comprobante de retención antes de emitir.
                        </p>
                    </div>
                </div>

                <div class="n-modal-header-side n-modal-header-side-product">
                    <button type="button" class="n-modal-close" @onclick="CerrarPreviewPdfRetencionAsync" aria-label="Cerrar vista previa">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <div class="n-modal-body n-pdf-preview-body" style="flex: 1 1 auto; min-height: 0;">
                @if (!string.IsNullOrWhiteSpace(urlPreviewPdfRetencion))
                {
                    <iframe class="n-pdf-preview-iframe" src="@urlPreviewPdfRetencion" title="Vista previa PDF temporal de retención"></iframe>
                }
                else
                {
                    <div class="n-pdf-preview-empty">
                        <div class="spinner-border text-primary" role="status"></div>
                        <strong>Generando PDF...</strong>
                    </div>
                }
            </div>

            <div class="n-modal-footer">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarPreviewPdfRetencionAsync">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (false && mostrarPreviewPdfRetencion && preview != null)
{
    <div class="ret-preview-backdrop" @onclick="CerrarPreviewPdfRetencion"></div>
    <div class="ret-preview-modal" role="dialog" aria-modal="true" aria-label="Previsualización PDF de retención">
        <div class="ret-preview-dialog">
            <div class="ret-preview-header">
                <div>
                    <span class="ret-preview-kicker">Previsualización PDF</span>
                    <h5>Comprobante de retención @FormatearSerieRetencion(preview.Serie)-@FormatearSecuencialRetencion(preview.NumeroRetencionGenerado)</h5>
                </div>
                <button type="button" class="ret-preview-close" @onclick="CerrarPreviewPdfRetencion" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="ret-preview-body">
                <div class="ret-preview-paper">
                    <div class="ret-preview-top">
                        <section class="ret-preview-company">
                            <div class="ret-preview-title">EMISOR</div>
                            <h4>@(string.IsNullOrWhiteSpace(preview.NombreEmisorEncontrado) ? "EMISOR" : preview.NombreEmisorEncontrado)</h4>
                            <div><strong>RUC:</strong> @(preview.RucEmisor ?? "")</div>
                            <div><strong>Dirección:</strong> @(preview.DireccionEstablecimiento ?? preview.DireccionMatriz ?? "")</div>
                            <div><strong>Obligado contabilidad:</strong> @(preview.ObligadoContabilidad ?? "NO")</div>
                        </section>

                        <section class="ret-preview-doc">
                            <div class="ret-preview-title">COMPROBANTE DE RETENCIÓN</div>
                            <div><strong>No.:</strong> @FormatearSerieRetencion(preview.Serie)-@FormatearSecuencialRetencion(preview.NumeroRetencionGenerado)</div>
                            <div><strong>Fecha emisión:</strong> @(preview.FechaEmision?.ToString("dd/MM/yyyy") ?? "")</div>
                            <div><strong>Periodo fiscal:</strong> @(preview.FechaEmision?.ToString("MM/yyyy") ?? "")</div>
                            <div><strong>Autorización:</strong> @(preview.NumeroAutorizacion ?? preview.ClaveAcceso ?? "Pendiente")</div>
                        </section>
                    </div>

                    <section class="ret-preview-card">
                        <div class="ret-preview-section-title">Datos del proveedor</div>
                        <div class="ret-preview-grid">
                            <div>
                                <strong>Proveedor:</strong>
                                <span>@(preview.RazonSocialProveedor ?? "")</span>
                            </div>
                            <div>
                                <strong>Identificación:</strong>
                                <span>@(preview.RucProveedor ?? "")</span>
                            </div>
                            <div>
                                <strong>Tipo identificación:</strong>
                                <span>04</span>
                            </div>
                        </div>
                    </section>

                    <section class="ret-preview-card">
                        <div class="ret-preview-section-title">Documento sustento</div>
                        <div class="ret-preview-grid">
                            <div>
                                <strong>Documento:</strong>
                                <span>@FormatearSerieRetencion(preview.Serie)-@FormatearSecuencialRetencion(preview.Secuencial)</span>
                            </div>
                            <div>
                                <strong>Total sin impuestos:</strong>
                                <span>$ @preview.TotalSinImpuestos.ToString("N2")</span>
                            </div>
                            <div>
                                <strong>Total documento:</strong>
                                <span>$ @preview.ImporteTotal.ToString("N2")</span>
                            </div>
                        </div>
                    </section>

                    <section class="ret-preview-card">
                        <div class="ret-preview-section-title">Detalle de retenciones</div>
                        <div class="ret-preview-table-wrap">
                            <table class="ret-preview-table">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Código</th>
                                        <th>Descripción</th>
                                        <th class="text-end">Base</th>
                                        <th class="text-end">% Ret.</th>
                                        <th class="text-end">Valor retenido</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ret in (preview.Retenciones ?? new List<CompraRetValorDto>()).Where(EsRetencionSeleccionada))
                                    {
                                        <tr>
                                            <td>@ret.Tipo</td>
                                            <td>@ret.IdRet</td>
                                            <td>@ret.DescripcionRet</td>
