    private ModoDescuentoRetencion GetModoDescuentoDetalleRetencion(CompraXmlDetalleDto item)
    {
        if (modosDescuentoDetalleRetencion.TryGetValue(item, out var modo))
            return modo;

        return ModoDescuentoRetencion.Porcentaje;
    }

    private string GetDescuentoDetalleRetencionVisual(CompraXmlDetalleDto item)
    {
        if (GetModoDescuentoDetalleRetencion(item) == ModoDescuentoRetencion.Moneda)
            return item.Descuento.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

        if (porcentajesDescuentoDetalleRetencion.TryGetValue(item, out var porcentaje))
            return NormalizarPorcentajeEntero(porcentaje).ToString("0", System.Globalization.CultureInfo.InvariantCulture);

        return "0";
    }

    private void CambiarModoDescuentoDetalleRetencion(CompraXmlDetalleDto item, ModoDescuentoRetencion modo)
    {
        modosDescuentoDetalleRetencion[item] = modo;

        if (modo == ModoDescuentoRetencion.Porcentaje)
        {
            var bruto = Math.Max(0m, item.Cantidad * item.PrecioUnitario);
            porcentajesDescuentoDetalleRetencion[item] = bruto > 0m
                ? NormalizarPorcentajeEntero(item.Descuento / bruto * 100m)
                : 0m;
        }

        ReaplicarDescuentoDetalleRetencion(item);
        RecalcularDetalleEditado(item);
    }

    private void ReaplicarDescuentoDetalleRetencion(CompraXmlDetalleDto item)
    {
        if (GetModoDescuentoDetalleRetencion(item) != ModoDescuentoRetencion.Porcentaje)
            return;

        var porcentaje = porcentajesDescuentoDetalleRetencion.TryGetValue(item, out var valor) ? valor : 0m;
        var bruto = Math.Max(0m, item.Cantidad * item.PrecioUnitario);
        item.Descuento = Math.Round(bruto * Math.Clamp(porcentaje, 0m, 100m) / 100m, 2);
    }

    private void OnDescuentoDetalleChanged(CompraXmlDetalleDto item, string? valorTexto)
    {
        if (item == null)
            return;

        if (!decimal.TryParse(
                valorTexto,
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture,
                out var valor))
        {
            valor = 0m;
        }

        if (valor < 0m)
            valor = 0m;

        if (GetModoDescuentoDetalleRetencion(item) == ModoDescuentoRetencion.Porcentaje)
        {
            var porcentaje = NormalizarPorcentajeEntero(valor);
            porcentajesDescuentoDetalleRetencion[item] = porcentaje;
            var bruto = Math.Max(0m, item.Cantidad * item.PrecioUnitario);
            item.Descuento = Math.Round(bruto * porcentaje / 100m, 2);
        }
        else
        {
            var bruto = Math.Max(0m, item.Cantidad * item.PrecioUnitario);
            item.Descuento = Math.Min(valor, bruto);
        }

        RecalcularDetalleEditado(item);
    }

    private static decimal NormalizarPorcentajeEntero(decimal valor) =>
        Math.Clamp(Math.Round(valor, 0, MidpointRounding.AwayFromZero), 0m, 100m);

    private string ObtenerErrorRetencion(CompraRetValorDto r)
    {
        if (preview == null)
            return string.Empty;

        string tipo = (r.Tipo ?? "").Trim().ToUpperInvariant();
        decimal maximo = ObtenerMaximoPorTipo(tipo);
        decimal totalBase = Redondear2((r.BasesParciales ?? new List<BaseParcialRetencionDto>()).Sum(x => x.Base));
        decimal valorRetenido = Redondear2(r.ValorRetenido ?? 0m);

        if (string.IsNullOrWhiteSpace(tipo))
            return string.Empty;

        if (totalBase < 0m)
            return "La base imponible no puede ser negativa.";

        if (valorRetenido < 0m)
            return "El valor retenido no puede ser negativo.";

        if (valorRetenido > totalBase)
        {
            return tipo == "RENTA"
                ? "El valor retenido de renta no puede ser mayor a la base imponible de renta."
                : tipo == "IVA"
                    ? "El valor retenido de IVA no puede ser mayor a la base imponible de IVA."
                    : "El valor retenido no puede ser mayor a la base imponible.";
        }

        if (totalBase > maximo)
        {
            return tipo == "RENTA"
                ? $"La base imponible de renta no puede superar {maximo:N2}."
                : tipo == "IVA"
                    ? $"La base imponible de IVA no puede superar {maximo:N2}."
                    : "La base imponible no puede superar el máximo permitido.";
        }

        return string.Empty;
    }

    private async Task CargarUsuarioActualAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity?.IsAuthenticated == true)
        {
            var idClaim =
                user.FindFirst("IdUsuario")?.Value ??
                user.FindFirst("idUsuario")?.Value ??
                user.FindFirst("usuario")?.Value ??
                user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (int.TryParse(idClaim, out var id))
                usuarioActual = id;
        }
    }

    private async Task GuardarCompraAsync()
    {
        if (preview == null)
            return;

        mensaje = null;
        esError = false;
        mensajeRapidoRetencion = null;
        mensajeRapidoRetencionEsError = false;
        guardando = true;
        textoGuardandoRetencion = "Guardando retencion...";
        retencionGeneradaSec = null;
        retencionGeneradaPdfUrl = null;

        try
        {
            preview.Usuario = usuarioActual;
            preview.Retenciones ??= new List<CompraRetValorDto>();
            preview.IdentificacionComprador = preview.RucEmisor ?? preview.IdentificacionComprador ?? "";

            var validacionCorreos = ValidarCorreosRetencion();
            if (!string.IsNullOrWhiteSpace(validacionCorreos))
                throw new Exception(validacionCorreos);

            if (preview.EsManual)
            {
                await ComprasXmlService.ResolverDatosManualAsync(preview);

                if (preview.Detalles != null && preview.Detalles.Count > 0)
                    ComprasXmlService.RecalcularTotalesManualDesdeDetalles(preview);
                else
                    ComprasXmlService.RecalcularTotalesManual(preview);
            }

            SincronizarRetencionesDesdeDetalles();
            if (preview.EsManual && preview.Detalles != null)
                preview.Detalles = preview.Detalles.Where(x => !EsDetalleCompraVacio(x)).ToList();

            var errorValidacion = ObtenerErrorValidacionCompra();
            if (!string.IsNullOrWhiteSpace(errorValidacion))
                throw new Exception(errorValidacion);

            preview.Retenciones = preview.Retenciones
                .Where(x =>
                    !string.IsNullOrWhiteSpace(x.Tipo) &&
                    (!string.IsNullOrWhiteSpace(x.DescripcionRet) || (x.IdRet ?? 0) > 0))
                .ToList();

            foreach (var ret in preview.Retenciones)
            {
                ret.BasesParciales ??= new List<BaseParcialRetencionDto>();

                if (ret.BasesParciales.Count == 0)
                {
                    var baseExistente = Redondear2(ret.Base ?? 0m);
                    var porcentaje = Redondear2(ret.PorcentajeRetencion ?? 0m);

                    ret.BasesParciales.Add(new BaseParcialRetencionDto
                    {
                        Base = baseExistente,
                        ValorRetenido = Redondear2(baseExistente * porcentaje / 100m)
                    });
                }

                RecalcularRetencionDesdeBases(ret);

                ret.Estado = true;
                ret.Serie = preview.Serie;
                ret.Autorizacion = string.IsNullOrWhiteSpace(ret.Autorizacion)
                    ? preview.NumeroAutorizacion
                    : ret.Autorizacion;

                ret.Tipo = ret.Tipo?.Trim().ToUpperInvariant();

                if (string.IsNullOrWhiteSpace(ret.Tipo))
                    throw new Exception("Debes seleccionar el tipo en cada retención.");

                if (string.Equals(ret.Tipo, "RENTA", StringComparison.OrdinalIgnoreCase))
                {
                    if (string.IsNullOrWhiteSpace(ret.CodigoRetencion))
                        throw new Exception("Debes seleccionar una retención válida desde la búsqueda o el popup.");
                }
                else if (ret.IdRet == null || ret.IdRet <= 0)
                    throw new Exception("Debes seleccionar una retención válida desde la búsqueda o el popup.");

                var error = ObtenerErrorRetencion(ret);
                if (!string.IsNullOrWhiteSpace(error))
                    throw new Exception(error);
            }

            int codFactura = await ComprasXmlService.GuardarCompraDesdePreviewAsync(preview);

            if (preview.EsManual)
            {
                await InitialSequencePromptService.UpdateLastSequenceAsync(
                    usuarioActual ?? 0,
                    "compra-manual",
                    preview.Secuencial,
                    preview.Serie);
            }

            if (preview.Retenciones.Any())
            {
                await InitialSequencePromptService.UpdateLastSequenceAsync(
                    usuarioActual ?? 0,
                    "retencion",
                    preview.NumeroRetencionGenerado,
                    preview.Serie);
            }

            string mensajeResultado;
            bool esErrorResultado = false;

            if (preview.Retenciones.Any())
            {
                var correosRetencion = ObtenerCorreosOpcionalesRetencion();
                retencionGeneradaSec = await RetencionCorreoService.RegistrarDestinatariosRetencionPorCompraAsync(
                    codFactura,
                    preview.EmailProveedor,
                    correosRetencion);

                if (retencionGeneradaSec is > 0)
                {
                    textoGuardandoRetencion = "Emitiendo en el SRI...";
                    await InvokeAsync(StateHasChanged);

                    var respuestaSri = await RetencionGeneradaService.EmitirRetencionSriAsync(
                        retencionGeneradaSec.Value,
                        usuarioActual,
                        intentarEnviarCorreo: true);

                    var pdfAutorizadoUrl = usuarioActual is > 0
                        ? await RetencionGeneradaService.AsegurarPdfRetencionUsuarioAsync(retencionGeneradaSec.Value, usuarioActual.Value)
                        : await RetencionGeneradaService.AsegurarPdfRetencionAsync(retencionGeneradaSec.Value);

                    retencionGeneradaPdfUrl = NormalizarUrlDocumentoRetencionGenerado(pdfAutorizadoUrl);

                    var estadoSri = (respuestaSri?.estado ?? string.Empty).Trim();
                    var mensajeSri = (respuestaSri?.mensaje ?? string.Empty).Trim();
                    var autorizada = string.Equals(estadoSri, DocumentoAutorizacionHelper.EstadoAutorizado, StringComparison.OrdinalIgnoreCase)
                        || !string.IsNullOrWhiteSpace(respuestaSri?.autorizacion);

                    if (autorizada)
                    {
                        mensajeResultado = $"Retención {FormatearSecuencialRetencion(preview.NumeroRetencionGenerado)} emitida correctamente al SRI.";
                    }
                    else if (string.Equals(estadoSri, "ERROR", StringComparison.OrdinalIgnoreCase))
                    {
                        mensajeResultado = $"Retención guardada, pero no se pudo emitir al SRI. {mensajeSri}";
                        esErrorResultado = true;
                    }
                    else
                    {
                        mensajeResultado = $"Retención guardada y enviada al SRI con estado {estadoSri}.";
                        if (!string.IsNullOrWhiteSpace(mensajeSri))
                            mensajeResultado += $" {mensajeSri}";
                    }
                }
                else
                {
                    mensajeResultado = "La compra se guardó, pero no se encontró la retención generada para enviarla al SRI.";
                    esErrorResultado = true;
                }
            }
            else
            {
                mensajeResultado = $"Compra #{codFactura} guardada correctamente.";
            }

            mensaje = preview.Retenciones.Any()
                ? $"Compra #{codFactura} guardada correctamente. La retención manual quedó generada con XML y PDF."
                : $"Compra #{codFactura} guardada correctamente.";

            mensaje = mensajeResultado;
            esError = esErrorResultado;
            MostrarAvisoRapidoRetencion(mensajeResultado, esErrorResultado);
            await CargarEstadoEmisionAsync();
            if (preview.Retenciones?.Any() == true)
            {
                EmisionControlService.NotifyChanged();
            }
            preview.YaImportado = true;
            preview.CodFacturaExistente = codFactura;
        }
        catch (Exception ex)
        {
            mensaje = NormalizarMensajeErrorGuardado(ex.Message);
            esError = true;
            MostrarAvisoRapidoRetencion(mensaje, true);
        }
        finally
        {
            guardando = false;
            textoGuardandoRetencion = "Guardando retencion...";
        }
    }

    private Task AbrirDocumentoRetencionGeneradoAsync()
    {
        if (string.IsNullOrWhiteSpace(retencionGeneradaPdfUrl))
            return Task.CompletedTask;

        tituloPreviewPdfRetencion = "PDF autorizado de retencion";
        urlPreviewPdfRetencion = retencionGeneradaPdfUrl;
        mostrarPreviewPdfRetencion = true;
        return InvokeAsync(StateHasChanged);
    }

