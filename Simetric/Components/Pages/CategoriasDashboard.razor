@page "/configuracion/categorias"
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Models
@using Simetric.Services
@inject ProductCategoryService CategoryService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Categorias | Numerica e-fact</PageTitle>

<div class="cat-shell" data-tour="categorias.page">
    <section class="tabs-shell" aria-label="Secciones de categorias" data-tour="categorias.tabs">
        <button type="button"
                class="tab-pill @(activeTab == "tipos" ? "is-active" : string.Empty)"
                @onclick='() => SwitchTab("tipos")'>
            <i class="bi bi-grid-fill"></i>
            <span>Categorias</span>
        </button>

        <button type="button"
                class="tab-pill @(activeTab == "subcategorias" ? "is-active" : string.Empty)"
                @onclick='() => SwitchTab("subcategorias")'>
            <i class="bi bi-diagram-3"></i>
            <span>Subcategorias</span>
        </button>
    </section>

    <section class="toolbar-card" data-tour="categorias.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Operacion</span>
            <h3>@ActiveSectionTitle</h3>
        </div>

        <div class="toolbar-actions">
            <button type="button" class="primary-btn" @onclick="() => AbrirModal()">
                <i class="bi bi-plus-lg"></i>
                <span>Nuevo</span>
            </button>
        </div>
    </section>

    <section class="table-card" data-tour="categorias.table">
        <div class="table-card-head">
            <div>
                <span class="table-kicker">Listado activo</span>
                <h3>@ActiveTableTitle</h3>
            </div>

            <span class="table-badge">@VisibleItems registros</span>
        </div>

        <div class="cat-filters-toolbar">
            <div class="cat-search-box">
                <i class="bi bi-search"></i>
                <input type="search"
                       class="cat-search-input"
                       placeholder="@GetSearchPlaceholder()"
                       @bind="SearchTerm"
                       @bind:event="oninput" />
            </div>

            @if (activeTab == "subcategorias")
            {
                <select class="cat-filter-select" @bind="FiltroCategoriaSubcategoria">
                    <option value="">Todas las categorias</option>
                    @foreach (var categoria in CategoriasDisponibles)
                    {
                        <option value="@categoria.Idtipoproducto">@categoria.Descripcion</option>
                    }
                </select>
            }

            <select class="cat-filter-select cat-filter-select-small" @bind="CurrentPageSize">
                <option value="5">5 registros</option>
                <option value="10">10 registros</option>
                <option value="20">20 registros</option>
            </select>
        </div>

        @if (!HasVisibleItems)
        {
            <div class="state-card state-card-empty">
                <div class="state-icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h3>No se encontraron registros</h3>
                <p>@EmptyStateMessage</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="table table-hover align-middle mb-0 cat-table">
                    <thead>
                        <tr>
                            <th class="ps-4" style="width: 30%;">Descripcion</th>
                            @if (activeTab == "subcategorias")
                            {
                                <th style="width: 30%;">Categoria</th>
                            }
                            <th style="width: 12%;">Estado</th>
                            <th class="text-center pe-4" style="width: 15%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (activeTab == "tipos")
                        {
                            @foreach (var item in TiposPaginados)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="cell-main">
                                            <strong>@item.Descripcion</strong>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-success-subtle text-success status-pill">
                                            @(item.Estado == true ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view" title="Ver" @onclick="() => VerDetalle(t: item)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button type="button" class="action-btn action-edit" title="Editar" @onclick="() => AbrirModal(t: item)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button type="button" class="action-btn action-delete" title="Dar de baja" @onclick="() => ConfirmDelete(item.Idtipoproducto)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            @foreach (var item in SubcategoriasPaginadas)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="cell-main">
                                            <strong>@item.Descripcion</strong>
                                        </div>
                                    </td>
                                    <td>@(item.IdtipoproductoNavigation?.Descripcion ?? "Sin categoria")</td>
                                    <td>
                                        <span class="badge rounded-pill bg-success-subtle text-success status-pill">
                                            @(item.Estado == "A" ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view" title="Ver" @onclick="() => VerDetalle(s: item)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button type="button" class="action-btn action-edit" title="Editar" @onclick="() => AbrirModal(s: item)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button type="button" class="action-btn action-delete" title="Dar de baja" @onclick="() => ConfirmDelete(item.Idsubtipo)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="cat-pagination">
            <span class="cat-pagination-meta">
                Mostrando @CurrentPageStart - @CurrentPageEnd de @CurrentTotalRecords registros
            </span>

            <div class="cat-pagination-actions">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaAnterior" disabled="@(CurrentPage <= 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="cat-page-indicator">Pagina @CurrentPage de @CurrentTotalPages</span>
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaSiguiente" disabled="@(CurrentPage >= CurrentTotalPages)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </section>
</div>

@if (showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-success text-white" style="border-radius: 8px 8px 0 0;">
                    <h5 class="modal-title fw-bold">@(tempId == 0 ? "Nuevo" : "Editar") @(activeTab == "tipos" ? "categoria" : "subcategoria")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Descripcion</label>
                        <input type="text" class="form-control" @bind="tempDesc" placeholder="Ej: Lacteos, Limpieza..." />
                    </div>

                    @if (activeTab == "subcategorias")
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Categoria</label>
                            <select class="form-select" @bind="tempPadreId">
                                <option value="0">-- Seleccione --</option>
                                @foreach (var categoria in CategoriasDisponibles)
                                {
                                    <option value="@categoria.Idtipoproducto">@categoria.Descripcion</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light" style="border-radius: 0 0 8px 8px;">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="primary-btn" @onclick="Guardar">
                        <i class="bi bi-save me-2"></i>Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDetailModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 8px;">
                <div class="modal-header text-white" style="background-color: #006bb5; border-radius: 8px 8px 0 0;">
                    <h5 class="modal-title fw-bold">Detalles del registro</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarDetalle"></button>
                </div>
                <div class="modal-body p-4">
                    @if (tipoSeleccionado != null)
                    {
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Seccion:</div>
                            <div class="col-7 text-dark fw-medium">Categoria</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Descripcion:</div>
                            <div class="col-7 text-dark fw-bold">@tipoSeleccionado.Descripcion</div>
                        </div>
                        <hr class="text-muted opacity-25 my-2" />
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Estado:</div>
                            <div class="col-7">
                                <span class="badge rounded-pill bg-success-subtle text-success">@(tipoSeleccionado.Estado == true ? "Activo" : "Inactivo")</span>
                            </div>
                        </div>
                    }
                    else if (subtipoSeleccionado != null)
                    {
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Seccion:</div>
                            <div class="col-7 text-dark fw-medium">Subcategoria</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Descripcion:</div>
                            <div class="col-7 text-dark fw-bold">@subtipoSeleccionado.Descripcion</div>
                        </div>
                        <hr class="text-muted opacity-25 my-2" />
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Categoria:</div>
                            <div class="col-7 text-dark">
                                @(subtipoSeleccionado.IdtipoproductoNavigation?.Descripcion ?? "Sin categoria")
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-5 text-muted fw-bold small">Estado:</div>
                            <div class="col-7">
                                <span class="badge rounded-pill bg-success-subtle text-success">@(subtipoSeleccionado.Estado == "A" ? "Activo" : "Inactivo")</span>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light" style="border-radius: 0 0 8px 8px; border-top: 1px solid #dee2e6;">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarDetalle">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int idUsuarioLogueado = 0;
    private string activeTab = "tipos";

    private bool showModal;
    private bool showDetailModal;

    private List<Productotipo> tiposList = new();
    private List<Productosubtipo> subtiposList = new();

    private Productotipo? tipoSeleccionado;
    private Productosubtipo? subtipoSeleccionado;

    private int tempId;
    private string tempDesc = string.Empty;
    private int tempPadreId;
    private string searchTipos = string.Empty;
    private string searchSubcategorias = string.Empty;
    private int? filtroCategoriaSubcategoria;
    private int pageSizeTipos = 10;
    private int pageSizeSubcategorias = 10;
    private int currentPageTipos = 1;
    private int currentPageSubcategorias = 1;

    [Parameter]
    [SupplyParameterFromQuery(Name = "openNew")]
    public bool OpenNewFromQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string ActiveSectionTitle => activeTab == "tipos" ? "Categorias" : "Subcategorias";
    private string ActiveTableTitle => activeTab == "tipos" ? "Categorias registradas" : "Subcategorias registradas";
    private string EmptyStateMessage => activeTab == "tipos"
        ? "No encontramos categorias activas con los filtros actuales."
        : "No encontramos subcategorias activas con los filtros actuales.";
    private int VisibleItems => CurrentTotalRecords;
    private bool HasVisibleItems => VisibleItems > 0;
    private IEnumerable<Productotipo> CategoriasDisponibles =>
        tiposList
            .Where(x => x.Estado == true)
            .OrderBy(x => x.Descripcion ?? string.Empty, StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!(user.Identity?.IsAuthenticated ?? false))
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        var idClaim = user.FindFirst("IdUsuario")?.Value;
        idUsuarioLogueado = int.TryParse(idClaim, out var uid) ? uid : 0;

        if (idUsuarioLogueado == 0)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        await LoadData();

        if (OpenNewFromQuery)
        {
            activeTab = "tipos";
            AbrirModal();
        }
    }

    private async Task LoadData()
    {
        tiposList = await CategoryService.GetTiposAsync(idUsuarioLogueado);
        subtiposList = await CategoryService.GetSubtiposAsync(idUsuarioLogueado);

        if (filtroCategoriaSubcategoria.HasValue &&
            !tiposList.Any(x => x.Estado == true && x.Idtipoproducto == filtroCategoriaSubcategoria.Value))
        {
            filtroCategoriaSubcategoria = null;
        }

        AjustarPaginaActual();
        StateHasChanged();
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        await LoadData();
    }

    private string SearchTerm
    {
        get => activeTab == "tipos" ? searchTipos : searchSubcategorias;
        set
        {
            if (activeTab == "tipos")
            {
                searchTipos = value;
                currentPageTipos = 1;
            }
            else
            {
                searchSubcategorias = value;
                currentPageSubcategorias = 1;
            }
        }
    }

    private int? FiltroCategoriaSubcategoria
    {
        get => filtroCategoriaSubcategoria;
        set
        {
            filtroCategoriaSubcategoria = value;
            currentPageSubcategorias = 1;
        }
    }

    private int CurrentPageSize
    {
        get => activeTab == "tipos" ? pageSizeTipos : pageSizeSubcategorias;
        set
        {
            if (activeTab == "tipos")
            {
                pageSizeTipos = value;
                currentPageTipos = 1;
            }
            else
            {
                pageSizeSubcategorias = value;
                currentPageSubcategorias = 1;
            }

            AjustarPaginaActual();
        }
    }

    private int CurrentPage => activeTab == "tipos" ? currentPageTipos : currentPageSubcategorias;

    private IEnumerable<Productotipo> TiposFiltrados =>
        tiposList
            .Where(x => x.Estado == true)
            .Where(x => CoincideTexto(x.Descripcion, searchTipos))
            .OrderBy(x => x.Descripcion ?? string.Empty, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<Productosubtipo> SubcategoriasFiltradas =>
        subtiposList
            .Where(x => x.Estado == "A")
            .Where(x => CoincideTexto(x.Descripcion, searchSubcategorias)
                || CoincideTexto(x.IdtipoproductoNavigation?.Descripcion, searchSubcategorias))
            .Where(x => !filtroCategoriaSubcategoria.HasValue || x.Idtipoproducto == filtroCategoriaSubcategoria.Value)
            .OrderBy(x => x.IdtipoproductoNavigation?.Descripcion ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.Descripcion ?? string.Empty, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<Productotipo> TiposPaginados =>
        TiposFiltrados
            .Skip((currentPageTipos - 1) * pageSizeTipos)
            .Take(pageSizeTipos);

    private IEnumerable<Productosubtipo> SubcategoriasPaginadas =>
        SubcategoriasFiltradas
            .Skip((currentPageSubcategorias - 1) * pageSizeSubcategorias)
            .Take(pageSizeSubcategorias);

    private int CurrentTotalRecords => activeTab == "tipos" ? TiposFiltrados.Count() : SubcategoriasFiltradas.Count();
    private int CurrentTotalPages => Math.Max(1, (int)Math.Ceiling(CurrentTotalRecords / (double)CurrentPageSize));
    private int CurrentPageStart => CurrentTotalRecords == 0 ? 0 : ((CurrentPage - 1) * CurrentPageSize) + 1;
    private int CurrentPageEnd => CurrentTotalRecords == 0 ? 0 : Math.Min(CurrentTotalRecords, CurrentPage * CurrentPageSize);

    private string GetSearchPlaceholder() =>
        activeTab == "tipos"
            ? "Buscar por descripcion"
            : "Buscar por subcategoria o categoria";

    private static bool CoincideTexto(string? valor, string termino)
    {
        if (string.IsNullOrWhiteSpace(termino))
        {
            return true;
        }

        return (valor ?? string.Empty).Contains(termino.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private void AjustarPaginaActual()
    {
        if (activeTab == "tipos")
        {
            currentPageTipos = Math.Min(Math.Max(1, currentPageTipos), Math.Max(1, (int)Math.Ceiling(TiposFiltrados.Count() / (double)pageSizeTipos)));
        }
        else
        {
            currentPageSubcategorias = Math.Min(Math.Max(1, currentPageSubcategorias), Math.Max(1, (int)Math.Ceiling(SubcategoriasFiltradas.Count() / (double)pageSizeSubcategorias)));
        }
    }

    private void PaginaAnterior()
    {
        if (activeTab == "tipos" && currentPageTipos > 1)
        {
            currentPageTipos--;
        }
        else if (activeTab == "subcategorias" && currentPageSubcategorias > 1)
        {
            currentPageSubcategorias--;
        }
    }

    private void PaginaSiguiente()
    {
        if (activeTab == "tipos" && currentPageTipos < CurrentTotalPages)
        {
            currentPageTipos++;
        }
        else if (activeTab == "subcategorias" && currentPageSubcategorias < CurrentTotalPages)
        {
            currentPageSubcategorias++;
        }
    }

    private void AbrirModal(Productotipo? t = null, Productosubtipo? s = null)
    {
        showModal = true;

        if (t != null)
        {
            tempId = t.Idtipoproducto;
            tempDesc = t.Descripcion ?? string.Empty;
            tempPadreId = 0;
        }
        else if (s != null)
        {
            tempId = s.Idsubtipo;
            tempDesc = s.Descripcion ?? string.Empty;
            tempPadreId = s.Idtipoproducto;
        }
        else
        {
            tempId = 0;
            tempDesc = string.Empty;
            tempPadreId = 0;
        }
    }

    private void CerrarModal() => showModal = false;

    private async Task Guardar()
    {
        tempDesc = (tempDesc ?? string.Empty).Trim();
        var volverDespuesDeGuardar = activeTab == "tipos" && tempId == 0 && EsReturnUrlSeguro(ReturnUrl);

        var errorValidacion = ValidarFormularioCategoria();
        if (!string.IsNullOrWhiteSpace(errorValidacion))
        {
            await JS.ShowAlertAsync("Revisa la informacion", errorValidacion, "warning");
            return;
        }

        try
        {
            if (activeTab == "tipos")
            {
                await CategoryService.SaveTipoAsync(new Productotipo
                {
                    Idtipoproducto = tempId,
                    Descripcion = tempDesc,
                    Estado = true
                }, idUsuarioLogueado);
            }
            else
            {
                await CategoryService.SaveSubtipoAsync(new Productosubtipo
                {
                    Idsubtipo = tempId,
                    Descripcion = tempDesc,
                    Idtipoproducto = tempPadreId,
                    Estado = "A"
                }, idUsuarioLogueado);
            }

            showModal = false;
            await LoadData();
            await JS.ShowToastAsync(activeTab == "tipos" ? "Categoria guardada" : "Subcategoria guardada");

            if (volverDespuesDeGuardar)
            {
                Nav.NavigateTo(ReturnUrl!);
            }
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync("No se pudo guardar", ex.Message, "error");
        }
    }

    private static bool EsReturnUrlSeguro(string? returnUrl) =>
        !string.IsNullOrWhiteSpace(returnUrl) &&
        returnUrl.StartsWith("/", StringComparison.Ordinal) &&
        !returnUrl.StartsWith("//", StringComparison.Ordinal) &&
        !returnUrl.Contains("://", StringComparison.Ordinal);

    private string? ValidarFormularioCategoria()
    {
        if (string.IsNullOrWhiteSpace(tempDesc) || tempDesc.Length < 3)
        {
            return "La descripcion es obligatoria y debe tener al menos 3 caracteres.";
        }

        if (activeTab == "tipos")
        {
            if (tiposList.Any(x =>
                    x.Idtipoproducto != tempId &&
                    string.Equals((x.Descripcion ?? string.Empty).Trim(), tempDesc, StringComparison.OrdinalIgnoreCase)))
            {
                return "Ya existe una categoria con esa descripcion.";
            }
        }
        else
        {
            if (tempPadreId == 0)
            {
                return "Debe seleccionar una categoria.";
            }

            if (subtiposList.Any(x =>
                    x.Idsubtipo != tempId &&
                    string.Equals((x.Descripcion ?? string.Empty).Trim(), tempDesc, StringComparison.OrdinalIgnoreCase) &&
                    x.Idtipoproducto == tempPadreId))
            {
                return "Ya existe una subcategoria con esa descripcion para la categoria seleccionada.";
            }
        }

        return null;
    }

    private async Task ConfirmDelete(int id)
    {
        var nombreSeccion = activeTab == "tipos" ? "categoria" : "subcategoria";

        if (!await JS.ConfirmDeleteAsync($"Dar de baja {nombreSeccion}", $"Se dara de baja la {nombreSeccion} seleccionada.", "Si, dar de baja"))
        {
            return;
        }

        try
        {
            if (activeTab == "tipos")
            {
                await CategoryService.SoftDeleteTipoAsync(id, idUsuarioLogueado);
            }
            else
            {
                await CategoryService.SoftDeleteSubtipoAsync(id, idUsuarioLogueado);
            }

            await LoadData();
            await JS.ShowToastAsync("Registro dado de baja");
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync("No se pudo eliminar", ex.Message, "error");
        }
    }

    private void VerDetalle(Productotipo? t = null, Productosubtipo? s = null)
    {
        tipoSeleccionado = t;
        subtipoSeleccionado = s;
        showDetailModal = true;
    }

    private void CerrarDetalle()
    {
        showDetailModal = false;
        tipoSeleccionado = null;
        subtipoSeleccionado = null;
    }
}
