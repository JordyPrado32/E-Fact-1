@page "/soporte/solicitud/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.DTOs
@using Simetric.Models
@using Simetric.Services
@using System.Security.Claims
@inject SolicitudService SolicitudService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="solicitud-detalle-shell">
    <button type="button" class="solicitud-back" @onclick="Volver">
        <i class="bi bi-arrow-left"></i>
        Volver a solicitudes
    </button>

    @if (!string.IsNullOrWhiteSpace(errorCarga))
    {
        <section class="solicitud-detalle-state is-error">
            <i class="bi bi-exclamation-triangle"></i>
            <h3>No se pudo cargar la solicitud</h3>
            <p>@errorCarga</p>
        </section>
    }
    else if (solicitud is null)
    {
        <section class="solicitud-detalle-state">
            <div class="solicitud-detalle-loader" aria-hidden="true"></div>
            <h3>Cargando solicitud</h3>
            <p>Estamos consultando los datos registrados.</p>
        </section>
    }
    else
    {
        <section class="solicitud-detalle-header">
            <div>
                <span class="solicitud-kicker">Solicitud @solicitud.SolId</span>
                <h3>@GetNombreCompleto(solicitud)</h3>
                <p>@solicitud.SolIdentificacion - @solicitud.SolTipoIdentificacion</p>
            </div>

            <div class="solicitud-detalle-statuses">
                <span class="solicitud-chip @GetEstadoClass(solicitud.SolIdEstadoNumerica)">
                    @GetNombreEstado(solicitud)
                </span>
                <span class="solicitud-chip @GetPagoClass(solicitud)">
                    @GetEstadoPago(solicitud)
                </span>
            </div>
        </section>

        <div class="solicitud-detalle-grid">
            <section class="solicitud-detalle-panel solicitud-detalle-panel-wide">
                <h4>Datos del solicitante</h4>
                <dl class="solicitud-info-list">
                    <div>
                        <dt>Tipo persona</dt>
                        <dd>@GetTipoPersonaLabel(solicitud.SolTipoPersona)</dd>
                    </div>
                    <div>
                        <dt>Tipo documento</dt>
                        <dd>@GetTipoIdentificacionLabel(solicitud.SolTipoIdentificacion)</dd>
                    </div>
                    <div>
                        <dt>Identificacion</dt>
                        <dd>@Valor(solicitud.SolIdentificacion)</dd>
                    </div>
                    @if (EsCedula(solicitud))
                    {
                        <div>
                            <dt>Codigo dactilar</dt>
                            <dd>@Valor(solicitud.SolCodigoDactilar)</dd>
                        </div>
                    }
                    <div>
                        <dt>Nombres</dt>
                        <dd>@Valor(solicitud.SolNombres)</dd>
                    </div>
                    <div>
                        <dt>Primer apellido</dt>
                        <dd>@Valor(solicitud.SolPrimerApellido)</dd>
                    </div>
                    <div>
                        <dt>Segundo apellido</dt>
                        <dd>@Valor(solicitud.SolSegundoApellido)</dd>
                    </div>
                    <div>
                        <dt>Fecha nacimiento</dt>
                        <dd>@GetFecha(solicitud.SolFechaNacimiento)</dd>
                    </div>
                    <div>
                        <dt>Sexo</dt>
                        <dd>@GetSexoLabel(solicitud.SolSexo)</dd>
                    </div>
                    <div>
                        <dt>Nacionalidad</dt>
                        <dd>@Valor(solicitud.SolNacionalidad)</dd>
                    </div>
                    <div>
                        <dt>Mayor de 65</dt>
                        <dd>@SiNo(solicitud.SolEsMayor65)</dd>
                    </div>
                    <div>
                        <dt>Requiere validacion</dt>
                        <dd>@SiNo(solicitud.SolRequiereValidacion)</dd>
                    </div>
                    <div>
                        <dt>Tiene RUC</dt>
                        <dd>@SiNo(solicitud.SolTieneRuc)</dd>
                    </div>
                    <div>
                        <dt>RUC</dt>
                        <dd>@Valor(solicitud.SolNroRuc)</dd>
                    </div>
                    @if (string.Equals(solicitud.SolTipoPersona, "JURIDICA", StringComparison.OrdinalIgnoreCase))
                    {
                        <div>
                            <dt>Razón social de la empresa</dt>
                            <dd>@Valor(solicitud.SolCompanyName)</dd>
                        </div>
                        <div>
                            <dt>Departamento de la empresa</dt>
                            <dd>@Valor(solicitud.SolDepartment)</dd>
                        </div>
                        <div>
                            <dt>Cargo del titular</dt>
                            <dd>@Valor(solicitud.SolPosition)</dd>
                        </div>
                        <div>
                            <dt>Motivo de la firma</dt>
                            <dd>@Valor(solicitud.SolReason)</dd>
                        </div>
                        <div>
                            <dt>Tipo doc. del representante</dt>
                            <dd>@GetTipoIdentificacionLabel(solicitud.SolIdentificationTypeManager)</dd>
                        </div>
                        <div>
                            <dt>Identificación del representante</dt>
                            <dd>@Valor(solicitud.SolIdentificationManager)</dd>
                        </div>
                        <div>
                            <dt>Nombres del representante</dt>
                            <dd>@Valor(solicitud.SolNamesManager)</dd>
                        </div>
                        <div>
                            <dt>Apellidos del representante</dt>
                            <dd>@Valor(solicitud.SolLastNameManager)</dd>
                        </div>
                    }
                    <div>
                        <dt>Celular</dt>
                        <dd>@Valor(solicitud.SolTelefono1)</dd>
                    </div>
                    <div>
                        <dt>Telefono secundario</dt>
                        <dd>@Valor(solicitud.SolTelefono2)</dd>
                    </div>
                    <div>
                        <dt>Correo principal</dt>
                        <dd>@Valor(solicitud.SolCorreo1)</dd>
                    </div>
                    <div>
                        <dt>Correo secundario</dt>
                        <dd>@Valor(solicitud.SolCorreo2)</dd>
                    </div>
                    <div>
                        <dt>Provincia</dt>
                        <dd>@Valor(solicitud.SolProvincia)</dd>
                    </div>
                    <div>
                        <dt>Canton</dt>
                        <dd>@Valor(solicitud.SolCanton)</dd>
                    </div>
                    <div>
                        <dt>Direccion</dt>
                        <dd>@Valor(solicitud.SolDireccion)</dd>
                    </div>
                    <div>
                        <dt>Observacion general</dt>
                        <dd>@Valor(solicitud.SolObservacionGeneral)</dd>
                    </div>
                    <div>
                        <dt>Ultima actualizacion</dt>
                        <dd>@(solicitud.SolFechaActualizacion is null ? "No registrado" : solicitud.SolFechaActualizacion.Value.ToString("dd/MM/yyyy HH:mm"))</dd>
                    </div>
                </dl>
            </section>

            <section class="solicitud-detalle-panel">
                <h4>Firma solicitada</h4>
                <dl>
                    <div>
                        <dt>Formato</dt>
                        <dd>@GetFormatoFirma(solicitud.SolFormatoFirma)</dd>
                    </div>
                    <div>
                        <dt>Vigencia</dt>
                        <dd>@Valor(solicitud.SolVigencia)</dd>
                    </div>
                    <div>
                        <dt>Fecha solicitud</dt>
                        <dd>@solicitud.SolFechaSolicitud.ToString("dd/MM/yyyy HH:mm")</dd>
                    </div>
                    <div>
                        <dt>Monto</dt>
                        <dd>@GetMonto(solicitud)</dd>
                    </div>
                </dl>
            </section>

            <section class="solicitud-detalle-panel">
                <h4>Resultado de pago</h4>
                <dl>
                    <div>
                        <dt>Estado</dt>
                        <dd>@GetEstadoPago(solicitud)</dd>
                    </div>
                    <div>
                        <dt>Referencia</dt>
                        <dd>@Valor(solicitud.SolIdTransaccionPago)</dd>
                    </div>
                    <div>
                        <dt>Fecha pago</dt>
                        <dd>@(solicitud.SolFechaPago is null ? "Sin fecha" : solicitud.SolFechaPago.Value.ToString("dd/MM/yyyy HH:mm"))</dd>
                    </div>
                </dl>
            </section>

            <section class="solicitud-detalle-panel solicitud-detalle-panel-wide solicitud-correccion-panel">
                <div class="solicitud-correccion-hero">
                    <div>
                        <span class="solicitud-correccion-kicker">Revision guiada</span>
                        <h4>Campos mal ingresados</h4>
                        <p class="solicitud-panel-help">
                            Marca los datos que el usuario debe corregir y redacta una sola instruccion clara para enviarla como notificacion.
                        </p>
                    </div>

                    <div class="solicitud-correccion-stats">
                        <article class="solicitud-correccion-stat">
                            <strong>@TotalCamposCorregibles</strong>
                            <span>Campos visibles</span>
                        </article>
                        <article class="solicitud-correccion-stat">
                            <strong>@TotalCamposSeleccionados</strong>
                            <span>Marcados</span>
                        </article>
                        <article class="solicitud-correccion-stat">
                            <strong>@TotalGruposSeleccionados/@TotalGruposCorregibles</strong>
                            <span>Secciones revisadas</span>
                        </article>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensajeSolicitudUsuario))
                {
                    <div class="solicitud-status-message is-success">
                        <i class="bi bi-check-circle"></i>
                        <span>@mensajeSolicitudUsuario</span>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorSolicitudUsuario))
                {
                    <div class="solicitud-status-message is-error">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>@errorSolicitudUsuario</span>
                    </div>
                }

                @if (TieneSolicitudPendiente)
                {
                    <div class="solicitud-status-message is-warning">
                        <i class="bi bi-clock-history"></i>
                        <span>Esta solicitud ya tiene una peticion pendiente. Espera la respuesta del usuario antes de enviar una nueva correccion.</span>
                    </div>
                }

                <div class="solicitud-correccion-layout">
                    <div class="solicitud-field-section-list">
                        @foreach (var grupo in GruposCamposCorregibles)
                        {
                            var cantidadSeleccionadosGrupo = grupo.Campos.Count(campo => camposSeleccionados.Contains(campo.Campo));
                            var grupoCompletoSeleccionado = cantidadSeleccionadosGrupo == grupo.Campos.Count;

                            <section class="solicitud-field-section @(cantidadSeleccionadosGrupo > 0 ? "has-selection" : string.Empty)">
                                <div class="solicitud-field-section-head">
                                    <div class="solicitud-field-section-heading">
                                        <div class="solicitud-field-section-title-row">
                                            <h5>@grupo.Nombre</h5>
                                            <span class="solicitud-field-section-badge">@cantidadSeleccionadosGrupo/@grupo.Campos.Count seleccionados</span>
                                        </div>
                                        <p>@grupo.Ayuda</p>
                                    </div>

                                    <button type="button"
                                            class="solicitud-field-section-action"
                                            disabled="@(guardandoCorreccion || TieneSolicitudPendiente)"
                                            @onclick="@(() => AlternarGrupoCampos(grupo.Campos))">
                                        @(grupoCompletoSeleccionado ? "Limpiar grupo" : "Seleccionar grupo")
                                    </button>
                                </div>

                                <div class="solicitud-field-check-grid">
                                    @foreach (var campo in grupo.Campos)
                                    {
                                        var seleccionado = camposSeleccionados.Contains(campo.Campo);

                                        <label class="solicitud-field-check @(seleccionado ? "is-selected" : string.Empty)">
                                            <input type="checkbox"
                                                   checked="@seleccionado"
                                                   disabled="@(guardandoCorreccion || TieneSolicitudPendiente)"
                                                   @onchange="(e) => ToggleCampoCorregible(campo.Campo, e)" />
                                            <span class="solicitud-field-check-content">
                                                <span class="solicitud-field-check-type">@GetTipoCampoCorregible(campo.Campo)</span>
                                                <strong>@GetEtiquetaCampo(campo, solicitud)</strong>
                                                <small>@GetDetalleGrupoCampo(campo, solicitud)</small>
                                            </span>
                                            <span class="solicitud-field-check-mark">
                                                <i class="bi bi-check2"></i>
                                            </span>
                                        </label>
                                    }
                                </div>
                            </section>
                        }
                    </div>

                    <aside class="solicitud-correccion-summary">
                        <section class="solicitud-correccion-card">
                            <span class="solicitud-correccion-step">Paso 1</span>
                            <h5>Resumen de seleccion</h5>
                            <p>Confirma aqui los campos que se incluiran en la solicitud antes de enviarla.</p>

                            @if (!CamposSeleccionadosResumen.Any())
                            {
                                <div class="solicitud-selection-empty">
                                    Aun no has marcado campos. Selecciona uno o varios elementos desde los bloques de la izquierda.
                                </div>
                            }
                            else
                            {
                                <div class="solicitud-selection-chip-list">
                                    @foreach (var campo in CamposSeleccionadosResumen)
                                    {
                                        <span class="solicitud-selection-chip">@GetEtiquetaCampo(campo, solicitud)</span>
                                    }
                                </div>
                            }

                            <button type="button"
                                    class="solicitud-selection-clear"
                                    disabled="@(guardandoCorreccion || TieneSolicitudPendiente || !CamposSeleccionadosResumen.Any())"
                                    @onclick="LimpiarCamposSeleccionados">
                                Limpiar seleccion
                            </button>
                        </section>

                        <section class="solicitud-correccion-card solicitud-correccion-card-accent">
                            <span class="solicitud-correccion-step">Paso 2</span>
                            <h5>Mensaje para el usuario</h5>
                            <p>Escribe una instruccion breve y accionable para que el cliente sepa exactamente que debe corregir.</p>

                            <div class="solicitud-state-form solicitud-correccion-form">
                                <label>
                                    <span>Instruccion para el usuario</span>
                                    <textarea @bind="detalleCorreccion"
                                              rows="5"
                                              maxlength="500"
                                              disabled="@(guardandoCorreccion || TieneSolicitudPendiente)"
                                              placeholder="Ej: Revisa los campos marcados y vuelve a ingresarlos sin abreviaturas ni errores."></textarea>
                                </label>

                                <button type="button"
                                        class="solicitud-save-state solicitud-save-state-block"
                                        disabled="@(guardandoCorreccion || TieneSolicitudPendiente || !CamposSeleccionadosResumen.Any())"
                                        @onclick="EnviarCorreccionCamposAsync">
                                    @if (guardandoCorreccion)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                        <span>Enviando</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-ui-checks"></i>
                                        <span>Solicitar correccion</span>
                                    }
                                </button>
                            </div>
                        </section>
                    </aside>
                </div>
            </section>

            <section class="solicitud-detalle-panel solicitud-detalle-panel-wide">
                <h4>Notificaciones enviadas al usuario</h4>

                @if (!ObservacionesActivas.Any())
                {
                    <p class="solicitud-empty">Todavia no se han enviado solicitudes de codigo o correccion.</p>
                }
                else
                {
                    <div class="solicitud-observacion-list">
                        @foreach (var observacion in ObservacionesActivas)
                        {
                            <article class="solicitud-observacion">
                                <span class="solicitud-observacion-type @GetObservacionClass(observacion.ObsTipo)">
                                    @GetObservacionTipo(observacion.ObsTipo)
                                </span>
                                <div>
                                    <strong>@GetCampoObservadoLabel(observacion.ObsCampoObservedo)</strong>
                                    <p>@Valor(observacion.ObsDetalle)</p>
                                    @if (!string.IsNullOrWhiteSpace(observacion.ObsRespuestaUsuario))
                                    {
                                        <p class="solicitud-observacion-response">
                                            <span>Respuesta del usuario:</span> @observacion.ObsRespuestaUsuario
                                        </p>
                                    }
                                    <small>
                                        @observacion.ObsEstado -
                                        @observacion.ObsFechaObservacion.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="solicitud-detalle-panel">
                <h4>Documentos adjuntos</h4>
                @if (!solicitud.Documentos.Any())
                {
                    <p class="solicitud-empty">No hay documentos vigentes adjuntos.</p>
                }
                else
                {
                    <div class="solicitud-doc-list">
                        @foreach (var doc in solicitud.Documentos.OrderBy(item => item.DocTipo))
                        {
                            <a class="solicitud-doc" href="@doc.DocRutaArchivo" download="@doc.DocNombreArchivo">
                                <span>
                                    <strong>@GetDocumentoTipoLabel(doc.DocTipo, solicitud)</strong>
                                    <small>@Valor(doc.DocNombreArchivo)</small>
                                    @if (EsDocumentoActualizado(doc))
                                    {
                                        <small class="solicitud-doc-updated">@GetDocumentoActualizadoLabel(doc)</small>
                                    }
                                </span>
                                <span class="solicitud-doc-download">
                                    <i class="bi bi-download"></i>
                                    Descargar
                                </span>
                            </a>
                        }
                    </div>
                }
            </section>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private UsuSolicitudFirma? solicitud;
    private string? errorCarga;
    private string? mensajeSolicitudUsuario;
    private string? errorSolicitudUsuario;
    private string detalleCorreccion = "Por favor revisa los datos marcados y vuelve a ingresarlos correctamente.";
    private bool guardandoCorreccion;
    private readonly HashSet<string> camposSeleccionados = new(StringComparer.OrdinalIgnoreCase);

    private IEnumerable<CampoCorregible> CamposCorregibles =>
        solicitud is null
            ? Enumerable.Empty<CampoCorregible>()
            : CamposSolicitud.Where(campo => CampoEsVisible(campo, solicitud));

    private IEnumerable<UsuSolicitudObservacion> ObservacionesActivas =>
        solicitud?.Observaciones
            .Where(observacion => observacion.ObsActivo)
            .OrderByDescending(observacion => observacion.ObsFechaObservacion)
        ?? Enumerable.Empty<UsuSolicitudObservacion>();

    private bool TieneSolicitudPendiente =>
        ObservacionesActivas.Any(observacion =>
            string.Equals(observacion.ObsEstado, "PENDIENTE", StringComparison.OrdinalIgnoreCase) &&
            (string.Equals(observacion.ObsTipo, "CODIGO", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(observacion.ObsTipo, "CAMPO", StringComparison.OrdinalIgnoreCase)));

    private IReadOnlyList<GrupoCampoCorregible> GruposCamposCorregibles =>
        solicitud is null
            ? Array.Empty<GrupoCampoCorregible>()
            : CamposCorregibles
                .GroupBy(campo => GetGrupoCampo(campo, solicitud))
                .OrderBy(grupo => GetOrdenGrupoCampo(grupo.Key))
                .Select(grupo => new GrupoCampoCorregible(
                    grupo.Key,
                    GetAyudaGrupoCampo(grupo.Key),
                    grupo.OrderBy(campo => GetEtiquetaCampo(campo, solicitud)).ToArray()))
                .ToArray();

    private IReadOnlyList<CampoCorregible> CamposSeleccionadosResumen =>
        solicitud is null
            ? Array.Empty<CampoCorregible>()
            : CamposCorregibles
                .Where(campo => camposSeleccionados.Contains(campo.Campo))
                .OrderBy(campo => GetOrdenGrupoCampo(GetGrupoCampo(campo, solicitud)))
                .ThenBy(campo => GetEtiquetaCampo(campo, solicitud))
                .ToArray();

    private int TotalCamposCorregibles => CamposCorregibles.Count();

    private int TotalCamposSeleccionados => CamposSeleccionadosResumen.Count;

    private int TotalGruposCorregibles => GruposCamposCorregibles.Count;

    private int TotalGruposSeleccionados =>
        GruposCamposCorregibles.Count(grupo => grupo.Campos.Any(campo => camposSeleccionados.Contains(campo.Campo)));

    private static readonly CampoCorregible[] CamposSolicitud =
    [
        new("SOL_TIPO_PERSONA", "Tipo de persona", "Titular"),
        new("SOL_TIPO_IDENTIFICACION", "Tipo de documento", "Identidad"),
        new("SOL_IDENTIFICACION", "Identificacion", "Documento"),
        new("SOL_CODIGO_DACTILAR", "Codigo dactilar", "Cedula", SoloCedula: true),
        new("SOL_NOMBRES", "Nombres", "Datos personales"),
        new("SOL_PRIMER_APELLIDO", "Primer apellido", "Datos personales"),
        new("SOL_SEGUNDO_APELLIDO", "Segundo apellido", "Datos personales"),
        new("SOL_FECHA_NACIMIENTO", "Fecha de nacimiento", "Datos personales"),
        new("SOL_SEXO", "Sexo", "Perfil"),
        new("SOL_NACIONALIDAD", "Nacionalidad", "Perfil"),
        new("SOL_TIENE_RUC", "Posee RUC", "RUC"),
        new("SOL_NRO_RUC", "Numero de RUC", "RUC", SoloRuc: true),
        new("SOL_TELEFONO_1", "Celular", "Contacto"),
        new("SOL_TELEFONO_2", "Telefono secundario", "Contacto"),
        new("SOL_CORREO_1", "Correo principal", "Contacto"),
        new("SOL_CORREO_2", "Correo secundario", "Contacto"),
        new("SOL_PROVINCIA", "Provincia", "Domicilio"),
        new("SOL_CANTON", "Canton", "Domicilio"),
        new("SOL_DIRECCION", "Direccion", "Domicilio"),
        new("DOC_CEDULA_FRONTAL", "Documento de identificación frontal", "Documentos adjuntos"),
        new("DOC_CEDULA_POSTERIOR", "Documento de identificación posterior", "Documentos adjuntos"),
        new("DOC_SELFIE_CEDULA", "Selfie sosteniendo su documento de identificación", "Documentos adjuntos"),
        new("DOC_VIDEO_ACEPTACION", "Video corto de aceptacion", "Documentos adjuntos", SoloMayor65: true),
        new("SOL_COMPANY_NAME", "Razón social de la empresa", "Datos de la empresa", SoloJuridica: true),
        new("SOL_DEPARTMENT", "Departamento de la empresa", "Datos de la empresa", SoloJuridica: true),
        new("SOL_POSITION", "Cargo del titular", "Datos de la empresa", SoloJuridica: true),
        new("SOL_REASON", "Motivo de la firma", "Datos de la empresa", SoloJuridica: true),
        new("SOL_IDENTIFICATION_TYPE_MANAGER", "Tipo doc. del representante", "Datos del representante", SoloJuridica: true),
        new("SOL_IDENTIFICATION_MANAGER", "Identificación del representante", "Datos del representante", SoloJuridica: true),
        new("SOL_NAMES_MANAGER", "Nombres del representante", "Datos del representante", SoloJuridica: true),
        new("SOL_LAST_NAME_MANAGER", "Apellidos del representante", "Datos del representante", SoloJuridica: true)
    ];

    protected override async Task OnParametersSetAsync()
    {
        solicitud = null;
        errorCarga = null;

        try
        {
            solicitud = await SolicitudService.ObtenerDetalleSolicitudAsync(Id);
            if (solicitud is null)
            {
                errorCarga = "No se encontro una solicitud con ese identificador.";
            }
        }
        catch (Exception ex)
        {
            errorCarga = "Ocurrio un problema al consultar el detalle. Revisa la conexion e intenta nuevamente.";
            Console.WriteLine($"Error al cargar detalle de solicitud {Id}: {ex.Message}");
        }
    }

    private void Volver() => Navigation.NavigateTo("/soporte/solicitudes");

    private async Task EnviarCorreccionCamposAsync()
    {
        if (solicitud is null)
        {
            return;
        }

        LimpiarMensajesSolicitudUsuario();

        var campos = CamposCorregibles
            .Where(campo => camposSeleccionados.Contains(campo.Campo))
            .Select(campo => new SolicitudCampoObservadoDto
            {
                Campo = campo.Campo,
                Etiqueta = GetEtiquetaCampo(campo, solicitud),
                Detalle = detalleCorreccion
            })
            .ToList();

        if (!campos.Any())
        {
            errorSolicitudUsuario = "Marca al menos un campo para solicitar correccion.";
            return;
        }

        var usuarioSoporteId = await ObtenerUsuarioSoporteIdAsync();
        if (usuarioSoporteId <= 0)
        {
            errorSolicitudUsuario = "No se pudo identificar al usuario de soporte. Cierra sesion e ingresa nuevamente.";
            return;
        }

        guardandoCorreccion = true;

        try
        {
            var ok = await SolicitudService.SolicitarCorreccionCamposAsync(
                solicitud.SolId,
                campos,
                detalleCorreccion,
                usuarioSoporteId);

            if (!ok)
            {
                errorSolicitudUsuario = "No se pudo enviar la solicitud de correccion. Revisa si ya existe una peticion pendiente para este usuario.";
                return;
            }

            camposSeleccionados.Clear();
            mensajeSolicitudUsuario = "Solicitud de correccion enviada como notificacion al usuario.";
            await RecargarSolicitudAsync();
        }
        catch (Exception ex)
        {
            errorSolicitudUsuario = "Ocurrio un problema al enviar la solicitud de correccion.";
            Console.WriteLine($"Error al solicitar correccion de solicitud {Id}: {ex.Message}");
        }
        finally
        {
            guardandoCorreccion = false;
        }
    }

    private void ToggleCampoCorregible(string campo, ChangeEventArgs e)
    {
        var seleccionado = e.Value is bool value && value;

        if (seleccionado)
        {
            camposSeleccionados.Add(campo);
            return;
        }

        camposSeleccionados.Remove(campo);
    }

    private void AlternarGrupoCampos(IReadOnlyList<CampoCorregible> camposGrupo)
    {
        if (!camposGrupo.Any())
        {
            return;
        }

        var todosSeleccionados = camposGrupo.All(campo => camposSeleccionados.Contains(campo.Campo));
        foreach (var campo in camposGrupo)
        {
            if (todosSeleccionados)
            {
                camposSeleccionados.Remove(campo.Campo);
            }
            else
            {
                camposSeleccionados.Add(campo.Campo);
            }
        }
    }

    private void LimpiarCamposSeleccionados() => camposSeleccionados.Clear();

    private async Task<int> ObtenerUsuarioSoporteIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst("IdUsuario")?.Value
            ?? authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(idClaim, out var usuarioSoporteId) ? usuarioSoporteId : 0;
    }

    private async Task RecargarSolicitudAsync()
    {
        solicitud = await SolicitudService.ObtenerDetalleSolicitudAsync(Id);
    }

    private void LimpiarMensajesSolicitudUsuario()
    {
        mensajeSolicitudUsuario = null;
        errorSolicitudUsuario = null;
    }

    private static string GetNombreCompleto(UsuSolicitudFirma sol)
    {
        var partes = new[] { sol.SolPrimerApellido, sol.SolSegundoApellido, sol.SolNombres };
        var nombre = string.Join(" ", partes.Where(parte => !string.IsNullOrWhiteSpace(parte)));

        return string.IsNullOrWhiteSpace(nombre) ? "Solicitante sin nombre" : nombre;
    }

    private static string GetNombreEstado(UsuSolicitudFirma sol) =>
        (sol.EstadoNumerica?.EstNombre ?? "Sin estado").ToUpperInvariant();

    private static string GetEstadoClass(int estadoId) => estadoId switch
    {
        1 => "is-pending",
        2 => "is-review",
        3 => "is-approved",
        4 => "is-rejected",
        _ => "is-neutral"
    };

    private static string GetPagoClass(UsuSolicitudFirma sol) =>
        sol.SolPagoExitoso == true ? "is-approved" : "is-pending";

    private static string GetEstadoPago(UsuSolicitudFirma sol) =>
        sol.SolPagoExitoso == true ? "Pago aprobado" : "Pago pendiente";

    private static string GetFormatoFirma(string? formatoFirma)
    {
        return (formatoFirma ?? string.Empty).Trim().ToUpperInvariant() switch
        {
            "ARCHIVO_P12" => "Archivo .P12",
            "NUBE" => "Firma en la nube",
            _ => string.IsNullOrWhiteSpace(formatoFirma) ? "No definido" : formatoFirma
        };
    }

    private static string GetMonto(UsuSolicitudFirma sol)
    {
        if (sol.SolMontoPago is null)
        {
            return "Sin monto";
        }

        var subtotal = Math.Round(sol.SolMontoPago.Value, 2);
        var total = Math.Round(subtotal + (subtotal * 0.15m), 2);
        return $"${total:0.00}";
    }

    private static string Valor(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "No registrado" : value;

    private static string GetFecha(DateTime fecha) =>
        fecha == default ? "No registrado" : fecha.ToString("dd/MM/yyyy");

    private static string SiNo(bool value) => value ? "Si" : "No";

    private static bool EsCedula(UsuSolicitudFirma sol) =>
        string.Equals(sol.SolTipoIdentificacion, "CEDULA", StringComparison.OrdinalIgnoreCase);

    private static string GetTipoPersonaLabel(string? tipoPersona)
    {
        return (tipoPersona ?? string.Empty).Trim().ToUpperInvariant() switch
        {
            "NATURAL" => "Persona natural",
            "JURIDICA" => "Persona juridica",
            _ => Valor(tipoPersona)
        };
    }

    private static string GetTipoIdentificacionLabel(string? tipoIdentificacion)
    {
        return (tipoIdentificacion ?? string.Empty).Trim().ToUpperInvariant() switch
        {
            "CEDULA" => "Cedula",
            "PASAPORTE" => "Pasaporte",
            _ => Valor(tipoIdentificacion)
        };
    }

    private static string GetSexoLabel(string? sexo)
    {
        return (sexo ?? string.Empty).Trim().ToUpperInvariant() switch
        {
            "M" => "Hombre",
            "F" => "Mujer",
            _ => Valor(sexo)
        };
    }

    private static string GetDocumentoTipoLabel(string? tipoDocumento, UsuSolicitudFirma sol)
    {
        var documento = GetDocumentoIdentidadLabel(sol);

        return (tipoDocumento ?? string.Empty).Trim().ToUpperInvariant() switch
        {
            "CEDULA_FRONTAL" => $"{documento} frontal",
            "CEDULA_POSTERIOR" => $"{documento} posterior",
            "SELFIE_CEDULA" => $"Selfie con {documento.ToLowerInvariant()}",
            "VIDEO_ACEPTACION" => "Video de aceptacion",
            _ => Valor(tipoDocumento)
        };
    }

    private static bool EsDocumentoActualizado(UsuSolicitudDocumento doc) =>
        !string.IsNullOrWhiteSpace(doc.DocObservacion) &&
        doc.DocObservacion.Contains("correccion", StringComparison.OrdinalIgnoreCase);

    private static string GetDocumentoActualizadoLabel(UsuSolicitudDocumento doc) =>
        $"Actualizado por correccion el {doc.DocFechaCarga:dd/MM/yyyy HH:mm}";

    private static bool CampoEsVisible(CampoCorregible campo, UsuSolicitudFirma sol)
    {
        if (campo.SoloCedula &&
            !string.Equals(sol.SolTipoIdentificacion, "CEDULA", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (campo.SoloRuc && !sol.SolTieneRuc &&
            !string.Equals(sol.SolTipoPersona, "JURIDICA", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (campo.SoloMayor65 && !sol.SolEsMayor65)
        {
            return false;
        }

        if (campo.SoloJuridica &&
            !string.Equals(sol.SolTipoPersona, "JURIDICA", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return true;
    }

    private static string GetEtiquetaCampo(CampoCorregible campo, UsuSolicitudFirma sol)
    {
        var documento = GetDocumentoIdentidadLabel(sol);

        return campo.Campo switch
        {
            "SOL_IDENTIFICACION" => documento,
            "DOC_CEDULA_FRONTAL" => $"{documento} frontal",
            "DOC_CEDULA_POSTERIOR" => $"{documento} posterior",
            "DOC_SELFIE_CEDULA" => $"Selfie con {documento.ToLowerInvariant()}",
            _ => campo.Etiqueta
        };
    }

    private static string GetGrupoCampo(CampoCorregible campo, UsuSolicitudFirma sol)
    {
        if (EsCampoDocumentoIdentidad(campo.Campo))
        {
            return GetDocumentoIdentidadLabel(sol);
        }

        if (EsCampoDocumentoAdjunto(campo.Campo))
        {
            return $"Documentos de {GetDocumentoIdentidadLabel(sol).ToLowerInvariant()}";
        }

        return campo.Grupo;
    }

    private static string GetDetalleGrupoCampo(CampoCorregible campo, UsuSolicitudFirma sol)
    {
        if (EsCampoDocumentoAdjunto(campo.Campo))
        {
            return "Adjunto";
        }

        if (EsCampoDocumentoIdentidad(campo.Campo))
        {
            return GetDocumentoIdentidadLabel(sol);
        }

        return campo.Grupo;
    }

    private static string GetTipoCampoCorregible(string campo)
    {
        if (EsCampoDocumentoAdjunto(campo))
        {
            return "Documento adjunto";
        }

        if (EsCampoDocumentoIdentidad(campo))
        {
            return "Documento";
        }

        return "Campo del formulario";
    }

    private static string GetAyudaGrupoCampo(string grupo)
    {
        if (grupo.Contains("Cedula", StringComparison.OrdinalIgnoreCase) ||
            grupo.Contains("Pasaporte", StringComparison.OrdinalIgnoreCase))
        {
            return "Campos y adjuntos del documento de identidad.";
        }

        return "Datos de esta seccion que el usuario puede corregir.";
    }

    private static int GetOrdenGrupoCampo(string grupo)
    {
        if (grupo.Contains("Cedula", StringComparison.OrdinalIgnoreCase) ||
            grupo.Contains("Pasaporte", StringComparison.OrdinalIgnoreCase))
        {
            return 1;
        }

        return grupo switch
        {
            "Titular" => 0,
            "Datos personales" => 2,
            "Perfil" => 3,
            "RUC" => 4,
            "Contacto" => 5,
            "Domicilio" => 6,
            _ => 9
        };
    }

    private static string GetDocumentoIdentidadLabel(UsuSolicitudFirma sol) =>
        string.Equals(sol.SolTipoIdentificacion, "PASAPORTE", StringComparison.OrdinalIgnoreCase)
            ? "Pasaporte"
            : "Cedula";

    private static bool EsCampoDocumentoIdentidad(string campo) =>
        string.Equals(campo, "SOL_TIPO_IDENTIFICACION", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(campo, "SOL_IDENTIFICACION", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(campo, "SOL_CODIGO_DACTILAR", StringComparison.OrdinalIgnoreCase);

    private static bool EsCampoDocumentoAdjunto(string campo) =>
        campo.StartsWith("DOC_", StringComparison.OrdinalIgnoreCase);

    private static string GetCampoObservadoLabel(string? campo)
    {
        if (string.IsNullOrWhiteSpace(campo))
        {
            return "Dato solicitado";
        }

        return CamposSolicitud.FirstOrDefault(item => string.Equals(item.Campo, campo, StringComparison.OrdinalIgnoreCase))?.Etiqueta
            ?? (string.Equals(campo, "DOC_CEDULA_FRONTAL", StringComparison.OrdinalIgnoreCase) ? "Documento de identificación frontal" : null)
            ?? (string.Equals(campo, "DOC_CEDULA_POSTERIOR", StringComparison.OrdinalIgnoreCase) ? "Documento de identificación posterior" : null)
            ?? (string.Equals(campo, "DOC_SELFIE_CEDULA", StringComparison.OrdinalIgnoreCase) ? "Selfie con documento de identificación" : null)
            ?? (string.Equals(campo, "DOC_VIDEO_ACEPTACION", StringComparison.OrdinalIgnoreCase) ? "Video de aceptacion" : null)
            ?? (string.Equals(campo, "SOL_ARCHIVO_P12", StringComparison.OrdinalIgnoreCase) ? "Firma .P12" : null)
            ?? campo;
    }

    private static string GetObservacionTipo(string? tipo)
    {
        if (string.Equals(tipo, "CODIGO", StringComparison.OrdinalIgnoreCase))
        {
            return "Codigo";
        }

        if (string.Equals(tipo, "FIRMA_P12", StringComparison.OrdinalIgnoreCase))
        {
            return "Entrega";
        }

        return "Correccion";
    }

    private static string GetObservacionClass(string? tipo)
    {
        if (string.Equals(tipo, "CODIGO", StringComparison.OrdinalIgnoreCase))
        {
            return "is-code";
        }

        if (string.Equals(tipo, "FIRMA_P12", StringComparison.OrdinalIgnoreCase))
        {
            return "is-firma";
        }

        return "is-field";
    }

    private sealed record CampoCorregible(
        string Campo,
        string Etiqueta,
        string Grupo,
        bool SoloCedula = false,
        bool SoloRuc = false,
        bool SoloMayor65 = false,
        bool SoloJuridica = false);

    private sealed record GrupoCampoCorregible(
        string Nombre,
        string Ayuda,
        IReadOnlyList<CampoCorregible> Campos);
}
