@page "/configuracion/tipos-cliente"
@using Simetric.Models
@using Simetric.Services
@inject TipoClienteService TipoClienteService
@inject IJSRuntime JS

<PageTitle>Tipos de Cliente | Numerica e-fact</PageTitle>

<div class="types-shell" data-tour="tipos.page">
    <section class="types-hero" data-tour="tipos.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Clasificacion comercial</span>
            <h2>Tipos de cliente</h2>
            <p>
                Mantén organizado el catalogo de perfiles comerciales y define rapidamente los tipos
                usados en clientes, ventas y segmentacion interna.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Registros</span>
                <strong>@listaTipos.Count</strong>
                <small>Tipos de cliente disponibles en el sistema.</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="tipos.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Mantenimiento</span>
            <h3>Administra el catalogo de tipos</h3>
            <p>Crea, actualiza o elimina tipos de cliente desde una vista simple y directa.</p>
        </div>

        <button class="primary-btn" @onclick="() => AbrirModal()">
            <i class="bi bi-plus-circle-fill"></i>
            <span>Nuevo tipo</span>
        </button>
    </section>

    <section class="table-card" data-tour="tipos.table">
        <div class="table-card-head">
            <div>
                <span class="table-kicker">Listado activo</span>
                <h3>Tipos registrados</h3>
            </div>

            <span class="table-badge">@listaTipos.Count registros</span>
        </div>

        @if (isLoading)
        {
            <div class="state-card">
                <div class="state-icon">
                    <span class="spinner-border text-primary" role="status"></span>
                </div>
                <h3>Cargando tipos de cliente</h3>
                <p>Estamos consultando el catalogo para dejar la tabla lista.</p>
            </div>
        }
        else if (!listaTipos.Any())
        {
            <div class="state-card state-card-empty">
                <div class="state-icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h3>No hay registros</h3>
                <p>Todavia no existen tipos de cliente configurados en esta vista.</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="table table-hover align-middle mb-0 types-table">
                    <thead>
                        <tr>
                            <th class="ps-4" style="width: 170px;">Codigo</th>
                            <th>Descripcion</th>
                            <th class="text-center" style="width: 150px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in listaTipos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="code-pill">#@t.TclCodigo</span>
                                </td>
                                <td>
                                    <div class="cell-main">
                                        <strong>@t.TclDescripcion</strong>
                                        <span>Clasificacion disponible para asignacion comercial.</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="action-group">
                                        <button class="action-btn action-view" @onclick="() => AbrirDetalle(t)" title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="action-btn action-edit" @onclick="() => AbrirModal(t)" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="action-btn action-delete" @onclick="() => Eliminar(t.TclSec)" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@if (showModal)
{
    <div class="types-modal-backdrop"></div>
    <div class="modal fade show d-block types-modal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content types-modal-content">
                <div class="modal-header types-modal-header">
                    <div>
                        <span class="modal-kicker">Mantenimiento</span>
                        <h5 class="modal-title fw-bold">@(tempTipo.TclSec == 0 ? "Nuevo tipo de cliente" : "Editar tipo")</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body types-modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="field-label">Codigo numerico</label>
                            <input type="number" @bind="tempTipo.TclCodigo" class="form-control field-input" placeholder="Ej: 101" />
                        </div>
                        <div class="col-12">
                            <label class="field-label">Descripcion</label>
                            <input @bind="tempTipo.TclDescripcion" class="form-control field-input" placeholder="Ej: Cliente Mayorista" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer types-modal-footer">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="primary-btn" @onclick="Guardar">
                        <i class="bi bi-save me-2"></i>Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDetailModal && detalleTipo is not null)
{
    <div class="types-modal-backdrop"></div>
    <div class="modal fade show d-block types-modal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content types-modal-content">
                <div class="modal-header types-modal-header">
                    <div>
                        <span class="modal-kicker">Detalle</span>
                        <h5 class="modal-title fw-bold">Tipo de cliente</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarDetalle"></button>
                </div>
                <div class="modal-body types-modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="field-label">Codigo numerico</label>
                            <div class="detail-value">#@detalleTipo.TclCodigo</div>
                        </div>
                        <div class="col-12">
                            <label class="field-label">Descripcion</label>
                            <div class="detail-value">@(string.IsNullOrWhiteSpace(detalleTipo.TclDescripcion) ? "Sin descripcion" : detalleTipo.TclDescripcion)</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer types-modal-footer">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarDetalle">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Tipocliente> listaTipos = new();
    private Tipocliente tempTipo = new();
    private bool showModal;
    private bool showDetailModal;
    private bool isLoading = true;
    private Tipocliente? detalleTipo;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        isLoading = true;
        listaTipos = await TipoClienteService.GetTiposClienteAsync();
        isLoading = false;
    }

    private void AbrirModal(Tipocliente? t = null)
    {
        if (t != null)
        {
            tempTipo = new Tipocliente
            {
                TclSec = t.TclSec,
                TclCodigo = t.TclCodigo,
                TclDescripcion = t.TclDescripcion
            };
        }
        else
        {
            tempTipo = new Tipocliente();
        }
        showModal = true;
    }

    private void CerrarModal() => showModal = false;

    private void AbrirDetalle(Tipocliente t)
    {
        detalleTipo = new Tipocliente
        {
            TclSec = t.TclSec,
            TclCodigo = t.TclCodigo,
            TclDescripcion = t.TclDescripcion
        };
        showDetailModal = true;
    }

    private void CerrarDetalle()
    {
        showDetailModal = false;
        detalleTipo = null;
    }

    private async Task Guardar()
    {
        tempTipo.TclDescripcion = (tempTipo.TclDescripcion ?? string.Empty).Trim();

        var errorValidacion = ValidarFormularioTipoCliente();
        if (!string.IsNullOrWhiteSpace(errorValidacion))
        {
            await JS.InvokeVoidAsync("alert", errorValidacion);
            return;
        }

        await TipoClienteService.SaveTipoClienteAsync(tempTipo);
        showModal = false;
        await CargarDatos();
    }

    private string? ValidarFormularioTipoCliente()
    {
        if (tempTipo.TclCodigo <= 0)
            return "El código numérico debe ser mayor a cero.";

        if (string.IsNullOrWhiteSpace(tempTipo.TclDescripcion) || tempTipo.TclDescripcion.Length < 3)
            return "La descripción debe tener al menos 3 caracteres.";

        if (listaTipos.Any(x => x.TclSec != tempTipo.TclSec && x.TclCodigo == tempTipo.TclCodigo))
            return "Ya existe un tipo de cliente con ese código.";

        if (listaTipos.Any(x =>
                x.TclSec != tempTipo.TclSec &&
                string.Equals((x.TclDescripcion ?? string.Empty).Trim(), tempTipo.TclDescripcion, StringComparison.OrdinalIgnoreCase)))
            return "Ya existe un tipo de cliente con esa descripción.";

        return null;
    }

    private async Task Eliminar(int id)
    {
        if (!await JS.ConfirmDeleteAsync("Eliminar tipo de cliente", "Se eliminara este tipo de cliente del catalogo."))
        {
            return;
        }

        try
        {
            await TipoClienteService.DeleteTipoClienteAsync(id);
            await CargarDatos();
            await JS.ShowToastAsync("Tipo de cliente eliminado");
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync("No se pudo eliminar", ex.Message, "error");
        }
    }
}
