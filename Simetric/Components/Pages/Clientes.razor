    private async Task SincronizarProveedorDesdeClienteAsync()
    {
        if (!model.EsProveedor)
            return;

        AsegurarDatosProveedorPorDefecto();

        var identificacion = model.Numeroidentificacion?.Trim();
        if (string.IsNullOrWhiteSpace(identificacion))
            return;

        await using var context = await DbFactory.CreateDbContextAsync();
        var proveedor = await context.Proveedores
            .FirstOrDefaultAsync(x => x.ruc == identificacion);

        if (proveedor is null)
        {
            proveedor = new Proveedor
            {
                ruc = identificacion,
                estado = true
            };
            context.Proveedores.Add(proveedor);
        }

        var nombres = SepararPartes(model.Nombres);
        var apellidos = SepararPartes(model.Apellidos);

        proveedor.tipoIdentificacion = ObtenerCodigoTipoIdentificacionProveedor();
        proveedor.personaNatural = EsPersonaSeleccionada ? 'S' : 'N';
        proveedor.primerNombre = EsPersonaSeleccionada ? nombres.ElementAtOrDefault(0) : null;
        proveedor.segundoNombre = EsPersonaSeleccionada ? nombres.ElementAtOrDefault(1) : null;
        proveedor.primerApellido = EsPersonaSeleccionada ? apellidos.ElementAtOrDefault(0) : null;
        proveedor.segundoApellido = EsPersonaSeleccionada ? apellidos.ElementAtOrDefault(1) : null;
        proveedor.nombreComercial = model.Nombrecomercial;
        proveedor.nombre = ObtenerNombreProveedorDesdeFormulario();
        proveedor.direccion = model.Direccion;
        proveedor.telefono = model.Telefonoconvencional;
        proveedor.telefonoMovil = model.Celular;
        proveedor.email = model.Correo;
        proveedor.obligado = string.Equals(model.Oblgconta, "SI", StringComparison.OrdinalIgnoreCase) ? 'S' : 'N';
        proveedor.cuentaContable = model.CuentaContableProveedor?.Trim();
        proveedor.retIva1 = model.CreditoTributarioProveedor?.Trim();
        proveedor.llevaRetencion = model.EsSujetoRetencionProveedor;
        proveedor.detalle = model.CodigoProveedor?.Trim();
        proveedor.tipoCuenta = model.RegistraInformacionBancariaProveedor ? model.TipoCuentaProveedor?.Trim() : null;
        proveedor.numeroCuenta = model.RegistraInformacionBancariaProveedor ? model.NumeroCuentaProveedor?.Trim() : null;
        proveedor.institucionFin = model.RegistraInformacionBancariaProveedor && int.TryParse(model.BancoProveedor?.Trim(), out var bancoCodigo)
            ? bancoCodigo
            : null;
        proveedor.fechaActualizacion = DateTime.Now;

        await context.SaveChangesAsync();
    }

