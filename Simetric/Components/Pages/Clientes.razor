    private async Task Editar(int id)
    {
        if (isDemoMode)
        {
            var itemDemo = clientes.FirstOrDefault(c => c.Codcliente == id);
            if (itemDemo is null)
                return;

            model = new ClienteUpsertDto
            {
                Parent = this,
                Codcliente = itemDemo.Codcliente,
                Apellidos = itemDemo.Apellidos,
                Nombres = itemDemo.Nombres,
                Nombrecomercial = itemDemo.Nombrecomercial,
                Nombrerazonsocial = itemDemo.Nombrerazonsocial,
                Tipoidentificacion = itemDemo.Tipoidentificacion,
                Numeroidentificacion = itemDemo.Numeroidentificacion,
                Direccion = itemDemo.Direccion,
                Telefonoconvencional = itemDemo.Telefonoconvencional,
                Celular = itemDemo.Celular,
                Correo = itemDemo.Correo,
                DiasCredito = itemDemo.DiasCredito,
                CorreosAdicionales = itemDemo.CorreosAdicionales.ToList(),
                Oblgconta = NormalizarObligadoContabilidad(itemDemo.Oblgconta),
                TipoCliente = itemDemo.TipoCliente,
                Estado = itemDemo.Estado,
                Observaciones = itemDemo.Observaciones,
                Pais = itemDemo.Pais,
                Provincia = itemDemo.Provincia,
                Ciudad = itemDemo.Ciudad,
                EsTipoEmpresa = EsTipoClienteEmpresa(itemDemo.TipoCliente)
            };

            editando = true;
            PrepararTipoContactoTelefonico();
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            ultimaCedulaConsultada = null;
            mensaje = "Cliente demo cargado en el formulario.";
            formKey = Guid.NewGuid();
            mostrarModalFormularioCliente = true;
            StateHasChanged();
            return;
        }

        mensaje = "Cargando cliente...";
        debugError = null;
        clienteEnVista = null;

        try
        {
            if (paises.Count == 0) await CargarPaises();
            if (tiposCliente.Count == 0 || identificaciones.Count == 0) await CargarLookupsClientes();
            await CargarUbicacionEcuador();

            var resp = await Http.GetAsync($"api/clientes/{id}?userId={usuarioLogueadoId}");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                mensaje = $"No se pudo cargar el cliente (HTTP {(int)resp.StatusCode}).";
                debugError = body;
                return;
            }

            var item = System.Text.Json.JsonSerializer.Deserialize<ClienteDto>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (item is null)
            {
                mensaje = "Respuesta vacía al cargar cliente.";
                debugError = body;
                return;
            }

            // Mapeo al modelo de edición
            model = new ClienteUpsertDto
            {
                Parent = this,
                Codcliente = item.Codcliente,
                Apellidos = item.Apellidos,
                Nombres = item.Nombres,
                Nombrecomercial = item.Nombrecomercial,
                Nombrerazonsocial = item.Nombrerazonsocial,
                Tipoidentificacion = item.Tipoidentificacion,
                Numeroidentificacion = item.Numeroidentificacion,
                Direccion = item.Direccion,
                Telefonoconvencional = item.Telefonoconvencional,
                Celular = item.Celular,
                Correo = item.Correo, // Principal
                DiasCredito = item.DiasCredito,

                CorreosAdicionales = item.CorreosAdicionales != null
                    ? item.CorreosAdicionales.Where(correo => !string.IsNullOrWhiteSpace(correo)).ToList()
                    : new List<string>(),

                Oblgconta = NormalizarObligadoContabilidad(item.Oblgconta),
                TipoCliente = item.TipoCliente,
                Estado = item.Estado,
                Observaciones = item.Observaciones,
                Pais = item.Pais is > 0 ? item.Pais : ecuadorPaisId,
                Provincia = item.Provincia is > 0 ? item.Provincia : null,
                Ciudad = item.Ciudad is > 0 ? item.Ciudad : null,
                EsTipoEmpresa = EsTipoClienteEmpresa(item.TipoCliente)
            };

            await PrepararLookupsUbicacionFormularioAsync();
            ActualizarTipoClienteForm();
            PrepararTipoContactoTelefonico();
            await CargarProveedorEnFormularioAsync(model.Numeroidentificacion);

            estadoAux = model.Estado ?? true;
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            ultimaCedulaConsultada = null;
            editando = true;
            formKey = Guid.NewGuid();
            mensaje = "Cliente cargado para edición.";
            mostrarModalFormularioCliente = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            debugError = $"{ex.Message} | INNER: {ex.InnerException?.Message}";
            mensaje = "Error al cargar cliente.";
        }
    }

    private async Task CargarProveedorEnFormularioAsync(string? identificacion)
    {
        if (string.IsNullOrWhiteSpace(identificacion))
            return;

        await using var context = await DbFactory.CreateDbContextAsync();
        var proveedor = await context.Proveedores
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.ruc == identificacion.Trim());

        if (proveedor is null)
            return;

        model.EsProveedor = true;
        model.CuentaContableProveedor = string.IsNullOrWhiteSpace(proveedor.cuentaContable)
            ? "21311 - Proveedores"
            : proveedor.cuentaContable;
        model.CreditoTributarioProveedor = proveedor.retIva1;
        model.CodigoProveedor = proveedor.detalle;
        model.EsSujetoRetencionProveedor = proveedor.llevaRetencion == true;
        model.TipoCuentaProveedor = proveedor.tipoCuenta;
        model.NumeroCuentaProveedor = proveedor.numeroCuenta;
        model.BancoProveedor = proveedor.institucionFin?.ToString();
        model.RegistraInformacionBancariaProveedor =
            !string.IsNullOrWhiteSpace(model.TipoCuentaProveedor) ||
            !string.IsNullOrWhiteSpace(model.NumeroCuentaProveedor) ||
            !string.IsNullOrWhiteSpace(model.BancoProveedor);
    }

