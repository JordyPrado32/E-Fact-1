    private async Task ImportarClientesAsync(InputFileChangeEventArgs e)
    {
        if (isDemoMode)
        {
            mensajeImportacion = "La importación está bloqueada en modo demo.";
            erroresImportacion = 1;
            await JS.ShowAlertAsync("Acción bloqueada", "La importación está bloqueada en modo demo.", "warning");
            return;
        }

        var archivo = e.File;
        if (archivo is null)
            return;

        var extension = Path.GetExtension(archivo.Name).ToLowerInvariant();
        if (extension != ".csv" && extension != ".xlsx")
        {
            mensajeImportacion = "Por favor, selecciona un archivo en formato .xlsx o .csv.";
            erroresImportacion = 1;
            await JS.ShowAlertAsync("Formato no válido", "Por favor, selecciona un archivo en formato .xlsx o .csv.", "warning");
            return;
        }

        const long maxSize = 4 * 1024 * 1024;
        if (archivo.Size > maxSize)
        {
            mensajeImportacion = "El archivo supera el máximo permitido de 4 MB.";
            erroresImportacion = 1;
            await JS.ShowAlertAsync("Archivo muy grande", "El archivo supera el máximo permitido de 4 MB.", "warning");
            return;
        }

        importandoClientes = true;
        erroresImportacion = 0;
        mensajeImportacion = "Procesando archivo...";
        StateHasChanged();

        try
        {
            var dtoList = new List<ClienteUpsertDto>();
            var errores = new List<string>();
            var filaOffset = 2; // Fila real en Excel

            if (extension == ".xlsx")
            {
                using var stream = archivo.OpenReadStream(maxSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                ms.Position = 0;

                var rows = MiniExcelLibs.MiniExcel.Query(ms, useHeaderRow: false).Cast<IDictionary<string, object>>().ToList();

                if (rows.Count < 2)
                {
                    mensajeImportacion = "El archivo no contiene clientes para importar.";
                    erroresImportacion = 1;
                    importandoClientes = false;
                    await JS.ShowAlertAsync("Archivo vacío", "El archivo no contiene clientes para importar.", "warning");
                    return;
                }

                for (int index = 1; index < rows.Count; index++)
                {
                    var row = rows[index];
                    if (row == null || row.Values.All(v => v == null || string.IsNullOrWhiteSpace(v.ToString())))
                        continue;

                    var fila = index + 1; // Fila real en Excel

                    // Columns: A=0, B=1, C=2, D=3, E=4, F=5, G=6, H=7, I=8, J=9, K=10, L=11, M=12, N=13, O=14, P=15, Q=16
                    var tipoClienteText = ExcelCampo(row, "A");
                    var tipoIdentificacionText = ExcelCampo(row, "B");
                    var identificacion = ExcelCampo(row, "C");
                    var razonSocial = ExcelCampo(row, "D");
                    var nombreComercial = ExcelCampo(row, "E");
                    var apellidos = ExcelCampo(row, "F");
                    var nombres = ExcelCampo(row, "G");
                    var correo = ExcelCampo(row, "H");
                    var celular = ExcelCampo(row, "I");
                    var telefono = ExcelCampo(row, "J");
                    var direccion = ExcelCampo(row, "K");
                    var oblgConta = ExcelCampo(row, "L").Trim().ToUpperInvariant();
                    if (string.IsNullOrWhiteSpace(oblgConta) || oblgConta == "0" || oblgConta == "NO")
                    {
                        oblgConta = "NO";
                    }
                    else if (oblgConta == "1" || oblgConta == "SI" || oblgConta == "S")
                    {
                        oblgConta = "SI";
                    }
                    else
                    {
                        oblgConta = "NO";
                    }

                    // Validaciones iniciales
                    if (string.IsNullOrWhiteSpace(tipoClienteText) || 
                        string.IsNullOrWhiteSpace(tipoIdentificacionText) ||
                        string.IsNullOrWhiteSpace(identificacion) ||
                        string.IsNullOrWhiteSpace(correo) ||
                        string.IsNullOrWhiteSpace(oblgConta))
                    {
                        errores.Add($"Fila {fila}: Faltan campos obligatorios (Tipo de cliente, Tipo de identificación, Identificación, Correo, o Llevar contabilidad) en las columnas del registro.");
                        continue;
                    }

                    // Map TipoCliente (Natural o Jurídica)
                    int tipoClienteId = 0;
                    var tcTextLower = RemoveAccents(tipoClienteText).ToLowerInvariant();
                    if (tcTextLower.Contains("jurid") || tcTextLower.Contains("empresa"))
                    {
                        tipoClienteId = tiposCliente.FirstOrDefault(x => TipoClienteClasificacion.EsJuridica(x.Descripcion))?.TclCodigo ?? 2;
                    }
                    else if (tcTextLower.Contains("natur") || tcTextLower.Contains("person"))
                    {
                        tipoClienteId = tiposCliente.FirstOrDefault(x => !TipoClienteClasificacion.EsJuridica(x.Descripcion))?.TclCodigo ?? 1;
                    }

                    if (tipoClienteId <= 0)
                    {
                        errores.Add($"Fila {fila}: Tipo de cliente '{tipoClienteText}' no válido (debe ser Natural o Juridica).");
                        continue;
                    }

                    // Map TipoIdentificacion
                    var tidTextLower = RemoveAccents(tipoIdentificacionText).ToLowerInvariant();
                    int? tipoIdentificacionId = null;
                    var matchTid = identificaciones.FirstOrDefault(x => 
                        RemoveAccents(x.Descripcion).Contains(tidTextLower, StringComparison.OrdinalIgnoreCase) || 
                        x.Codigo.Contains(tidTextLower, StringComparison.OrdinalIgnoreCase)
                    );
                    if (matchTid != null)
                    {
                        tipoIdentificacionId = matchTid.Id;
                    }
                    else
                    {
                        matchTid = identificaciones.FirstOrDefault(x => 
                            tidTextLower.Contains(RemoveAccents(x.Descripcion).ToLowerInvariant()) || 
                            tidTextLower.Contains(x.Codigo.ToLowerInvariant())
                        );
                        if (matchTid != null)
                        {
                            tipoIdentificacionId = matchTid.Id;
                        }
                    }

                    if (!tipoIdentificacionId.HasValue)
                    {
                        errores.Add($"Fila {fila}: Tipo de identificación '{tipoIdentificacionText}' no válido (debe ser Cedula o RUC).");
                        continue;
                    }

                    // Map OblgConta (SI/NO)
                    if (oblgConta != "SI" && oblgConta != "NO")
                    {
                        errores.Add($"Fila {fila}: Llevar contabilidad '{oblgConta}' no válido (debe ser SI o NO).");
                        continue;
                    }

                    // Map Ubicación (País, Provincia, Ciudad)
                    var paisText = ExcelCampo(row, "N");
                    var provinciaText = ExcelCampo(row, "O");
                    var ciudadText = ExcelCampo(row, "P");

                    int? paisId = ecuadorPaisId;
                    if (!string.IsNullOrWhiteSpace(paisText))
                    {
                        var matchPais = paises.FirstOrDefault(x => CompararSinTildesNiCaja(x.Descripcion, paisText));
                        if (matchPais != null) paisId = matchPais.IdPais;
                    }

                    int? provinciaId = null;
                    if (!string.IsNullOrWhiteSpace(provinciaText) && paisId == ecuadorPaisId)
                    {
                        var matchProv = provincias.FirstOrDefault(x => CompararSinTildesNiCaja(x.Descripcion, provinciaText));
                        if (matchProv != null) provinciaId = matchProv.IdProvincia;
                    }

                    int? ciudadId = null;
                    if (!string.IsNullOrWhiteSpace(ciudadText) && provinciaId.HasValue)
                    {
                        var matchCiudad = ciudades.FirstOrDefault(x => x.IdProvincia == provinciaId.Value && CompararSinTildesNiCaja(x.Descripcion, ciudadText));
                        if (matchCiudad != null) ciudadId = matchCiudad.IdCiudad;
                    }

                    var diasCreditoStr = ExcelCampo(row, "M");
                    int? diasCredito = null;
                    if (!string.IsNullOrWhiteSpace(diasCreditoStr) && int.TryParse(diasCreditoStr, out var dcVal))
                    {
                        diasCredito = dcVal;
                    }

                    var obs = ExcelCampo(row, "Q");

                    var dto = new ClienteUpsertDto
                    {
                        TipoCliente = tipoClienteId,
                        Tipoidentificacion = tipoIdentificacionId,
                        Numeroidentificacion = identificacion,
                        Nombrerazonsocial = razonSocial,
                        Nombrecomercial = nombreComercial,
                        Apellidos = apellidos,
                        Nombres = nombres,
                        Correo = correo,
                        Celular = celular,
                        Telefonoconvencional = telefono,
                        Direccion = direccion,
                        Oblgconta = oblgConta,
                        DiasCredito = diasCredito,
                        Pais = paisId,
                        Provincia = provinciaId,
                        Ciudad = ciudadId,
                        Observaciones = obs,
                        Estado = true
                    };

                    dtoList.Add(dto);
                }
            }
            else // CSV
            {
                using var stream = archivo.OpenReadStream(maxSize);
                using var reader = new StreamReader(stream, Encoding.UTF8, true);
                var contenido = await reader.ReadToEndAsync();
                var lineas = contenido.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n', StringSplitOptions.RemoveEmptyEntries);

                if (lineas.Length < 2)
                {
                    mensajeImportacion = "El archivo no contiene clientes para importar.";
                    erroresImportacion = 1;
                    importandoClientes = false;
                    await JS.ShowAlertAsync("Archivo vacío", "El archivo no contiene clientes para importar.", "warning");
                    return;
                }

                for (int index = 1; index < lineas.Length; index++)
                {
                    var campos = SepararCsv(lineas[index]);
                    if (campos.All(string.IsNullOrWhiteSpace))
                        continue;

                    var fila = index - 1 + filaOffset;

                    if (campos.Count < 12)
                    {
                        errores.Add($"Fila {fila}: faltan columnas obligatorias. Debe tener al menos TipoCliente, TipoIdentificacion, Identificacion, Celular, Telefono, Direccion, Correo y ObligadoContabilidad.");
                        continue;
                    }

                    var tipoClienteText = Campo(campos, 0).Trim();
                    var tipoIdentificacionText = Campo(campos, 1).Trim();
                    var identificacion = Campo(campos, 2).Trim();
                    var razonSocial = Campo(campos, 3).Trim();
                    var nombreComercial = Campo(campos, 4).Trim();
                    var apellidos = Campo(campos, 5).Trim();
                    var nombres = Campo(campos, 6).Trim();
                    var correo = Campo(campos, 7).Trim();
                    var celular = Campo(campos, 8).Trim();
                    var telefono = Campo(campos, 9).Trim();
                    var direccion = Campo(campos, 10).Trim();
                    var oblgConta = Campo(campos, 11).Trim().ToUpperInvariant();
                    if (string.IsNullOrWhiteSpace(oblgConta) || oblgConta == "0" || oblgConta == "NO")
                    {
                        oblgConta = "NO";
                    }
                    else if (oblgConta == "1" || oblgConta == "SI" || oblgConta == "S")
                    {
                        oblgConta = "SI";
                    }
                    else
                    {
                        oblgConta = "NO";
                    }

                    // Validaciones iniciales
                    if (string.IsNullOrWhiteSpace(tipoClienteText) || 
                        string.IsNullOrWhiteSpace(tipoIdentificacionText) ||
                        string.IsNullOrWhiteSpace(identificacion) ||
                        string.IsNullOrWhiteSpace(correo) ||
                        string.IsNullOrWhiteSpace(oblgConta))
                    {
                        errores.Add($"Fila {fila}: Faltan campos obligatorios (Tipo de cliente, Tipo de identificación, Identificación, Correo, o Llevar contabilidad) en las columnas del registro.");
                        continue;
                    }

                    // Map TipoCliente (Natural o Jurídica)
                    int tipoClienteId = 0;
                    var tcTextLower = RemoveAccents(tipoClienteText).ToLowerInvariant();
                    if (tcTextLower.Contains("jurid") || tcTextLower.Contains("empresa"))
                    {
                        tipoClienteId = tiposCliente.FirstOrDefault(x => TipoClienteClasificacion.EsJuridica(x.Descripcion))?.TclCodigo ?? 2;
                    }
                    else if (tcTextLower.Contains("natur") || tcTextLower.Contains("person"))
                    {
                        tipoClienteId = tiposCliente.FirstOrDefault(x => !TipoClienteClasificacion.EsJuridica(x.Descripcion))?.TclCodigo ?? 1;
                    }

                    if (tipoClienteId <= 0)
                    {
                        errores.Add($"Fila {fila}: Tipo de cliente '{tipoClienteText}' no válido (debe ser Natural o Juridica).");
                        continue;
                    }

                    // Map TipoIdentificacion
                    var tidTextLower = RemoveAccents(tipoIdentificacionText).ToLowerInvariant();
                    int? tipoIdentificacionId = null;
                    var matchTid = identificaciones.FirstOrDefault(x => 
                        RemoveAccents(x.Descripcion).Contains(tidTextLower, StringComparison.OrdinalIgnoreCase) || 
                        x.Codigo.Contains(tidTextLower, StringComparison.OrdinalIgnoreCase)
                    );
                    if (matchTid != null)
                    {
                        tipoIdentificacionId = matchTid.Id;
                    }
                    else
                    {
                        matchTid = identificaciones.FirstOrDefault(x => 
                            tidTextLower.Contains(RemoveAccents(x.Descripcion).ToLowerInvariant()) || 
                            tidTextLower.Contains(x.Codigo.ToLowerInvariant())
                        );
                        if (matchTid != null)
                        {
                            tipoIdentificacionId = matchTid.Id;
                        }
                    }

                    if (!tipoIdentificacionId.HasValue)
                    {
                        errores.Add($"Fila {fila}: Tipo de identificación '{tipoIdentificacionText}' no válido (debe ser Cedula o RUC).");
                        continue;
                    }

                    // Map OblgConta (SI/NO)
                    if (oblgConta != "SI" && oblgConta != "NO")
                    {
                        errores.Add($"Fila {fila}: Llevar contabilidad '{oblgConta}' no válido (debe ser SI o NO).");
                        continue;
                    }

                    // Map Ubicación (País, Provincia, Ciudad)
                    var paisText = Campo(campos, 13).Trim();
                    var provinciaText = Campo(campos, 14).Trim();
                    var ciudadText = Campo(campos, 15).Trim();

                    int? paisId = ecuadorPaisId;
                    if (!string.IsNullOrWhiteSpace(paisText))
                    {
                        var matchPais = paises.FirstOrDefault(x => CompararSinTildesNiCaja(x.Descripcion, paisText));
                        if (matchPais != null) paisId = matchPais.IdPais;
                    }

                    int? provinciaId = null;
                    if (!string.IsNullOrWhiteSpace(provinciaText) && paisId == ecuadorPaisId)
                    {
                        var matchProv = provincias.FirstOrDefault(x => CompararSinTildesNiCaja(x.Descripcion, provinciaText));
                        if (matchProv != null) provinciaId = matchProv.IdProvincia;
                    }

                    int? ciudadId = null;
                    if (!string.IsNullOrWhiteSpace(ciudadText) && provinciaId.HasValue)
                    {
                        var matchCiudad = ciudades.FirstOrDefault(x => x.IdProvincia == provinciaId.Value && CompararSinTildesNiCaja(x.Descripcion, ciudadText));
                        if (matchCiudad != null) ciudadId = matchCiudad.IdCiudad;
                    }

                    var diasCreditoStr = Campo(campos, 12).Trim();
                    int? diasCredito = null;
                    if (!string.IsNullOrWhiteSpace(diasCreditoStr) && int.TryParse(diasCreditoStr, out var dcVal))
                    {
                        diasCredito = dcVal;
                    }

                    var obs = Campo(campos, 16).Trim();

                    var dto = new ClienteUpsertDto
                    {
                        TipoCliente = tipoClienteId,
                        Tipoidentificacion = tipoIdentificacionId,
                        Numeroidentificacion = identificacion,
                        Nombrerazonsocial = razonSocial,
                        Nombrecomercial = nombreComercial,
                        Apellidos = apellidos,
                        Nombres = nombres,
                        Correo = correo,
                        Celular = celular,
                        Telefonoconvencional = telefono,
                        Direccion = direccion,
                        Oblgconta = oblgConta,
                        DiasCredito = diasCredito,
                        Pais = paisId,
                        Provincia = provinciaId,
                        Ciudad = ciudadId,
                        Observaciones = obs,
                        Estado = true
                    };

                    dtoList.Add(dto);
                }
            }

            var creados = 0;
            if (dtoList.Any())
            {
                using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromMinutes(5));
                var respuesta = await Http.PostAsJsonAsync($"api/clientes/bulk?userId={usuarioLogueadoId}", dtoList, cts.Token);
                if (respuesta.IsSuccessStatusCode)
                {
                    var result = await respuesta.Content.ReadFromJsonAsync<BulkImportResult>(cancellationToken: cts.Token);
                    if (result != null)
                    {
                        creados = result.Creados;
                        errores.AddRange(result.Errores);
                    }
                }
                else
                {
                    errores.Add($"Error en la carga masiva: {await respuesta.Content.ReadAsStringAsync()}");
                }
            }

            erroresImportacion = errores.Count;
            listaErroresImportacion = errores;
            mensajeImportacion = errores.Count == 0
                ? $"Importación completada: {creados} clientes creados."
                : $"Se crearon {creados} clientes. {errores.Count} filas presentaron errores.";

            if (errores.Count == 0)
            {
                await CargarTodo();
                EmisionControlService.NotifyChanged();
            }
            else if (creados > 0)
            {
                await CargarTodo();
                EmisionControlService.NotifyChanged();
            }
        }
        catch (Exception ex)
        {
            erroresImportacion = 1;
            mensajeImportacion = $"No se pudo importar el archivo: {ex.Message}";
        }
        finally
        {
            importandoClientes = false;
            StateHasChanged();
        }
    }

    private static string CleanImportedExcelField(object? value)
    {
        if (value == null) return string.Empty;
        if (value is double d)
        {
            return d.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
        }
        if (value is decimal de)
        {
            return de.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
        }
        if (value is float f)
        {
            return f.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
        }
        
        var str = value.ToString() ?? string.Empty;
        str = str.Trim();

        // 1. If it's in scientific notation (e.g. 1.79E+12 or 1,79E+12)
        if (str.Contains('E', StringComparison.OrdinalIgnoreCase))
        {
            var normalizedStr = str.Replace(',', '.');
            if (double.TryParse(normalizedStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedDouble))
            {
                return parsedDouble.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
            }
        }
        
        // 2. If it's a decimal number string (e.g. 1701042960.0 or 1701042960,0)
        var normalizedDecimal = str.Replace(',', '.');
        if (double.TryParse(normalizedDecimal, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedNum))
        {
            if (parsedNum % 1 == 0)
            {
                return parsedNum.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);
            }
        }

        return str;
    }

    private static string ExcelCampo(IDictionary<string, object> row, string columnLetter)
    {
        if (row != null && row.TryGetValue(columnLetter, out var val))
        {
            return CleanImportedExcelField(val);
        }
        return string.Empty;
    }

    private static string RemoveAccents(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        var normalizedString = text.Normalize(NormalizationForm.FormD);
        var stringBuilder = new StringBuilder();

        foreach (var c in normalizedString)
        {
            var unicodeCategory = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c);
            if (unicodeCategory != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                stringBuilder.Append(c);
            }
        }

        return stringBuilder.ToString().Normalize(NormalizationForm.FormC);
    }

    private static bool CompararSinTildesNiCaja(string? a, string? b)
    {
        if (a == null && b == null) return true;
        if (a == null || b == null) return false;
        var normA = RemoveAccents(a).Trim().ToLowerInvariant();
        var normB = RemoveAccents(b).Trim().ToLowerInvariant();
        return string.Equals(normA, normB);
    }

    private static List<string> SepararCsv(string linea)
    {
        var resultado = new List<string>();
        var actual = new StringBuilder();
        var entreComillas = false;

        for (var i = 0; i < linea.Length; i++)
        {
            var caracter = linea[i];
            if (caracter == '"')
            {
                if (entreComillas && i + 1 < linea.Length && linea[i + 1] == '"')
                {
                    actual.Append('"');
                    i++;
                }
                else
                {
                    entreComillas = !entreComillas;
                }
            }
            else if (caracter == ';' && !entreComillas)
            {
                resultado.Add(actual.ToString());
                actual.Clear();
            }
            else
            {
                actual.Append(caracter);
            }
        }

        resultado.Add(actual.ToString());
        return resultado;
    }

    private static string CleanImportedField(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        var trimmed = value.Trim();
        if (trimmed.StartsWith("=\"") && trimmed.EndsWith("\""))
        {
            trimmed = trimmed.Substring(2, trimmed.Length - 3);
        }
        else if (trimmed.StartsWith("=") && !trimmed.Contains(";"))
        {
            trimmed = trimmed.Substring(1);
            if (trimmed.StartsWith("\"") && trimmed.EndsWith("\""))
            {
                trimmed = trimmed.Substring(1, trimmed.Length - 2);
            }
        }
        else if (trimmed.StartsWith("\"") && trimmed.EndsWith("\""))
        {
            trimmed = trimmed.Substring(1, trimmed.Length - 2);
        }
        return trimmed.Trim();
    }

    private static string Campo(IReadOnlyList<string> campos, int indice) =>
        indice < campos.Count ? CleanImportedField(campos[indice]) : string.Empty;

