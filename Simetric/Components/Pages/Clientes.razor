    private async Task Guardar()
    {
        if (guardandoCliente)
            return;

        if (isDemoMode)
        {
            SetMensajeFormularioOListado("Modo demo: guardar clientes esta bloqueado.", esError: true);
            return;
        }

        guardandoCliente = true;
        SetMensajeFormularioOListado("Guardando...");
        model.Estado = estadoAux;
        ActualizarTipoClienteForm();

        model.Apellidos = model.Apellidos?.Trim();
        model.Nombres = model.Nombres?.Trim();
        model.Nombrecomercial = model.Nombrecomercial?.Trim();
        model.Nombrerazonsocial = model.Nombrerazonsocial?.Trim();
        model.Numeroidentificacion = model.Numeroidentificacion?.Trim();
        model.Direccion = model.Direccion?.Trim();
        model.Telefonoconvencional = model.Telefonoconvencional?.Trim();
        model.Celular = model.Celular?.Trim();
        NormalizarTelefonosPorTipoContacto();
        model.Correo = model.Correo?.Trim();
        model.CorreosAdicionales = model.CorreosAdicionales
            .Select(correo => correo?.Trim() ?? string.Empty)
            .Where(correo => !string.IsNullOrWhiteSpace(correo))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        model.Oblgconta = model.Oblgconta?.Trim().ToUpperInvariant();
        model.Observaciones = model.Observaciones?.Trim();

        var errorProveedor = ValidarDatosProveedorFormulario();
        if (!string.IsNullOrWhiteSpace(errorProveedor))
        {
            SetMensajeFormularioOListado(errorProveedor, esError: true);
            return;
        }

        if (EsEmpresaSeleccionada)
        {
            model.Apellidos = null;
            model.Nombres = null;
        }
        else
        {
            model.Nombrecomercial = null;
            model.Nombrerazonsocial = null;
        }

        try
        {
            var identificacionGuardada = model.Numeroidentificacion?.Trim() ?? string.Empty;
            var estabaEditando = editando;
            HttpResponseMessage resp = !editando
                ? await Http.PostAsJsonAsync($"api/clientes?userId={usuarioLogueadoId}", model)
                : await Http.PutAsJsonAsync($"api/clientes/{model.Codcliente}?userId={usuarioLogueadoId}", model);

            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                SetMensajeFormularioOListado($"Error API: {(int)resp.StatusCode}", body, esError: true);
                return;
            }

            await SincronizarProveedorDesdeClienteAsync();

            LimpiarMensajesFormularioOListado();

            await CargarTodo();
            EmisionControlService.NotifyChanged();

            if (OnClienteGuardado.HasDelegate && !string.IsNullOrWhiteSpace(identificacionGuardada))
            {
                await OnClienteGuardado.InvokeAsync(identificacionGuardada);
                return;
            }

            mostrarModalFormularioCliente = false;
            Nuevo();
            mensaje = estabaEditando ? "Cliente actualizado correctamente." : "Cliente creado correctamente.";
        }
        catch (Exception ex)
        {
            SetMensajeFormularioOListado("Error al guardar cliente.", $"{ex.Message} | INNER: {ex.InnerException?.Message}", esError: true);
        }
        finally
        {
            guardandoCliente = false;
        }
    }

    private bool TieneTipoClienteSeleccionado => model.TipoCliente > 0;
    private bool UsaDiasCreditoPersonalizado =>
        model.DiasCredito.HasValue && !diasCreditoOpciones.Contains(model.DiasCredito.Value);
    private bool UsaTelefonoConvencional =>
        string.Equals(model.TipoContactoTelefonico, ContactoTelefonoConvencional, StringComparison.OrdinalIgnoreCase);

    private bool EsPersonaSeleccionada =>
        TieneTipoClienteSeleccionado &&
        EsDescripcionPersonaNatural(tiposCliente.FirstOrDefault(t => t.TclCodigo == model.TipoCliente)?.Descripcion);

    private bool EsEmpresaSeleccionada => TieneTipoClienteSeleccionado && EsTipoClienteEmpresa(model.TipoCliente);

    private IEnumerable<IdentificacionDto> IdentificacionesDisponibles =>
        identificaciones.Where(EsIdentificacionPermitidaPorTipoCliente);

    private bool DebeMostrarObligadoContabilidad =>
        EsEmpresaSeleccionada || EsIdentificacionRucSeleccionada;

    private bool EsIdentificacionRucSeleccionada =>
        model.Tipoidentificacion.HasValue &&
        EsIdentificacionRuc(identificaciones.FirstOrDefault(x => x.Id == model.Tipoidentificacion.Value));

    private bool EsIdentificacionPasaporteSeleccionada =>
        model.Tipoidentificacion.HasValue &&
        EsIdentificacionPasaporte(identificaciones.FirstOrDefault(x => x.Id == model.Tipoidentificacion.Value));

    private bool EsTipoIdentificacionConsultaExternaSeleccionado
    {
        get
        {
            if (!model.Tipoidentificacion.HasValue)
                return false;

            var identificacion = identificaciones.FirstOrDefault(x => x.Id == model.Tipoidentificacion.Value);
            if (identificacion is null)
                return false;

            return string.Equals(identificacion.Codigo, "05", StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(identificacion.Codigo, "04", StringComparison.OrdinalIgnoreCase) ||
                   identificacion.Descripcion.Contains("cédula", StringComparison.OrdinalIgnoreCase) ||
                   identificacion.Descripcion.Contains("cedula", StringComparison.OrdinalIgnoreCase) ||
                   identificacion.Descripcion.Contains("RUC", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool EsTipoClienteEmpresa(int tipoCliente)
    {
        if (tipoCliente <= 0)
            return false;

        var desc = tiposCliente.FirstOrDefault(t => t.TclCodigo == tipoCliente)?.Descripcion;
        return EsDescripcionEmpresa(desc);
    }

    private static bool EsDescripcionPersonaNatural(string? descripcion) =>
        TipoClienteClasificacion.EsNatural(descripcion);

    private static bool EsDescripcionEmpresa(string? descripcion) =>
        TipoClienteClasificacion.EsJuridica(descripcion);

