    {
        var normalizado = (valor ?? string.Empty).Trim().ToUpperInvariant();
        return normalizado is "SI" or "NO" ? normalizado : string.Empty;
    }

    private void AsegurarTipoIdentificacionCompatible()
    {
        if (model.Tipoidentificacion.HasValue &&
            !IdentificacionesDisponibles.Any(x => x.Id == model.Tipoidentificacion.Value))
        {
            model.Tipoidentificacion = null;
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            ultimaCedulaConsultada = null;
        }
    }

    private bool EsIdentificacionPermitidaPorTipoCliente(IdentificacionDto identificacion)
    {
        if (!TieneTipoClienteSeleccionado)
            return true;

        if (EsEmpresaSeleccionada)
            return EsIdentificacionRuc(identificacion);

        return EsIdentificacionCedula(identificacion) ||
               EsIdentificacionRuc(identificacion) ||
               EsIdentificacionPasaporte(identificacion);
    }

    private static bool EsIdentificacionCedula(IdentificacionDto? identificacion)
    {
        if (identificacion is null)
            return false;

        return string.Equals(identificacion.Codigo, "05", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("cédula", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("cedula", StringComparison.OrdinalIgnoreCase);
    }

    private static bool EsIdentificacionRuc(IdentificacionDto? identificacion)
    {
        if (identificacion is null)
            return false;

        return string.Equals(identificacion.Codigo, "04", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("RUC", StringComparison.OrdinalIgnoreCase);
    }

    private static bool EsIdentificacionPasaporte(IdentificacionDto? identificacion)
    {
        if (identificacion is null)
            return false;

        return string.Equals(identificacion.Codigo, "06", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("pasaporte", StringComparison.OrdinalIgnoreCase);
    }

    private string NormalizarNumeroIdentificacionEntrada(string? valor)
    {
        var limpio = (valor ?? string.Empty).Trim();

        if (EsIdentificacionPasaporteSeleccionada)
            return new string(limpio.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();

        return new string(limpio.Where(char.IsDigit).ToArray());
    }

    private static string? NormalizarLugarNacimiento(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return null;

        return valor
            .Replace("/", ", ", StringComparison.Ordinal)
            .Trim();
    }

