                                    <circle cx="26" cy="26" r="25" stroke="#ef4444" stroke-width="2" fill="#fee2e2" />
                                    <line class="import-x-path" x1="17" y1="17" x2="35" y2="35" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
                                    <line class="import-x-path2" x1="35" y1="17" x2="17" y2="35" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
                                </svg>
                            </div>
                            <div>
                                <strong style="color: #991b1b; font-size: 1rem; font-weight: 800; display: block; margin-bottom: 0.4rem;">@mensajeImportacion</strong>
                                @if (listaErroresImportacion != null && listaErroresImportacion.Any())
                                {
                                    <div style="max-height: 140px; overflow-y: auto; border: 1px solid #fca5a5; background: #fff; border-radius: 10px; padding: 0.65rem 0.85rem; text-align: left; margin-top: 0.5rem;">
                                        <ul style="margin: 0; padding-left: 1.1rem; font-size: 0.74rem; color: #991b1b; display: flex; flex-direction: column; gap: 0.2rem;">
                                            @foreach (var error in listaErroresImportacion)
                                            {
                                                <li>@error</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

