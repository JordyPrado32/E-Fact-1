@page "/clientes"

@page "/demo/clientes"
@using System.Net.Http.Json
@using System.Text
@inject HttpClient Http
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.ComponentModel.DataAnnotations
@using System.Text.Json.Serialization
@using Microsoft.JSInterop
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using Simetric.Models
@using Simetric.Services
@using MiniExcelLibs
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject EmisionControlService EmisionControlService
@inject EmisorOnboardingService EmisorOnboardingService
@inject IDbContextFactory<AppDbContext> DbFactory
@attribute [AllowAnonymous]

@{
    var filteredClientes = ClientesFiltrados.ToList();
    var clientesPaginados = ClientesPaginados.ToList();
    var clientesReales = clientes.Where(c => !EsConsumidorFinal(c)).ToList();
    var totalActivos = clientesReales.Count(c => c.Estado == true);
    var totalConCorreo = clientesReales.Count(c => !string.IsNullOrWhiteSpace(c.Correo));
    var totalTipos = tiposCliente.Count;
    var paginaActualVista = PaginaActualNormalizada;
    var totalPaginasVista = TotalPaginasClientes;
    var primerRegistroVista = TotalRegistrosFiltrados == 0 ? 0 : ((paginaActualVista - 1) * registrosPorPagina) + 1;
    var ultimoRegistroVista = Math.Min(paginaActualVista * registrosPorPagina, TotalRegistrosFiltrados);
}

<PageTitle>Clientes / Proveedores | @PageBrandTitle</PageTitle>

<div class="entity-shell @(EsModoCrudEmbebido ? "entity-shell-embedded-form" : null)" data-tour="clientes.page">
    @if (MostrarVolverInicioOnboarding)
    {
        <div class="breadcrumb-container">
            <button type="button" class="breadcrumb-home-btn" @onclick='() => NavManager.NavigateTo("/dashboard")'>
                <i class="bi bi-house-door"></i>
                <span>Volver al inicio</span>
            </button>
        </div>
    }
    <section class="entity-hero" data-tour="clientes.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Catálogo comercial</span>
            <h2>Gestión de clientes / proveedores</h2>
            <p>
                Centraliza la cartera comercial y mantén el registro de clientes alineado
                con el mismo patrón visual y operativo de Productos.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Clientes activos</span>
                <strong>@totalActivos</strong>
                <small>Registros disponibles para facturación y operación diaria.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Tipos disponibles</span>
                <strong>@totalTipos</strong>
                <small>Clasificaciones activas para segmentar la cartera comercial.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Con correo</span>
                <strong>@totalConCorreo</strong>
                <small>Clientes listos para notificaciones y documentos electrónicos.</small>
            </article>
        </div>
    </section>

    <section class="quick-action-bar" aria-label="Acciones rápidas de clientes">
        <button type="button" class="quick-action-card quick-action-primary" @onclick="AbrirBotAsync">
            <span class="quick-action-icon"><i class="bi bi-stars"></i></span>
            <span>
                <strong>Crear cliente / proveedor con IA</strong>
                <small>Abre el bot para asistirte</small>
            </span>
        </button>

        <button type="button" class="quick-action-card" @onclick="AbrirImportacion">
            <span class="quick-action-icon quick-action-icon-green"><i class="bi bi-file-earmark-spreadsheet"></i></span>
            <span>
                <strong>Importar desde Excel</strong>
                <small>Carga masiva de clientes</small>
            </span>
        </button>



        <button type="button" class="quick-action-card quick-action-export" @onclick="ExportarClientesExcelAsync">
            <span class="quick-action-icon quick-action-icon-blue"><i class="bi bi-download"></i></span>
            <span>
                <strong>Exportar todos</strong>
                <small>Descargar Excel</small>
            </span>
        </button>


        <button type="button" class="quick-action-card" @onclick='() => NavManager.NavigateTo("/configuracion/tipos-cliente")'>
            <span class="quick-action-icon quick-action-icon-violet"><i class="bi bi-people"></i></span>
            <span>
                <strong>Tipos de cliente</strong>
                <small>Gestionar clasificaciones</small>
            </span>
        </button>

        <div class="quick-action-search">
            <i class="bi bi-search"></i>
            <input placeholder="Buscar por nombre, identificación o correo..."
                   value="@filtro"
                   @oninput="OnFiltroChanged" />
        </div>

        <button type="button" class="filter-toggle-btn @(mostrarPanelFiltros ? "active" : "")" @onclick="AlternarPanelFiltros">
            <i class="bi bi-funnel"></i>
            <span>Filtros</span>
            @if (filtroTipoCliente > 0 || !string.IsNullOrWhiteSpace(filtro) || registrosPorPagina != 10)
            {
                <b></b>
            }
        </button>
    </section>



    <section class="toolbar-card @(mostrarPanelFiltros ? "filters-visible" : "")" data-tour="clientes.toolbar">
        @if (isDemoMode)
        {
            <div class="status-banner status-banner-info mb-3">
                <i class="bi bi-eye"></i>
                <span>Modo demo: puedes revisar clientes y cargar datos al formulario, pero guardar y eliminar están bloqueados.</span>
            </div>
        }

        <div class="toolbar-copy">
            <span class="toolbar-kicker">Búsqueda y control</span>
            <h3>Consulta los datos y administra tus clientes / proveedores</h3>
            <p>Aqui tienes una lista de tus clientes, donde puedes administrar tu negocio </p>
        </div>

        <div class="toolbar-actions">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>
                <input class="search-input"
                       placeholder="Buscar por nombre o identificación"
                       value="@filtro"
                       @oninput="OnFiltroChanged" />
            </div>

            <div class="toolbar-secondary-actions">
                <div class="filter-box">
                    <label class="filter-label" for="clienteTipoFiltro">Tipo</label>
                    <select id="clienteTipoFiltro" class="filter-select" value="@filtroTipoCliente" @onchange="OnTipoFiltroChanged">
                        <option value="0">Todos</option>
                        @foreach (var tipo in tiposCliente)
                        {
                            <option value="@tipo.TclCodigo">@GetTipoClienteEtiqueta(tipo)</option>
                        }
                    </select>
                </div>

                <div class="filter-box">
                    <label class="filter-label" for="clientesRegistrosFiltro">Registros</label>
                    <select id="clientesRegistrosFiltro" class="filter-select" value="@registrosPorPagina" @onchange="OnRegistrosPorPaginaChanged">
                        @foreach (var opcion in opcionesRegistrosPorPagina)
                        {
                            <option value="@opcion">@opcion</option>
                        }
                    </select>
                </div>

                <button type="button" class="secondary-btn toolbar-secondary-btn filter-refresh-btn" @onclick="() => CargarTodo(true)">
                    <i class="bi bi-arrow-clockwise"></i>
                    <span>Refrescar</span>
                </button>
                <button type="button" class="secondary-btn toolbar-secondary-btn filter-reset-btn" @onclick="LimpiarFiltros">
                    <i class="bi bi-eraser"></i>
                    <span>Limpiar filtros</span>
                </button>
            </div>
        </div>
    </section>

    <section class="entity-grid">
        <section class="table-card" data-tour="clientes.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado activo</span>
                    <h3>Clientes / proveedores registrados</h3>
                </div>
                <div class="table-head-actions">
                    <span class="table-badge">@filteredClientes.Count registros</span>
                <button type="button" class="primary-btn" data-no-auto-loading="true" @onclick="AbrirNuevoClienteModal">
                        <i class="bi bi-plus-lg"></i>
                        <span>Nuevo cliente / proveedor</span>
                    </button>
                </div>
            </div>

            @if (!mostrarModalFormularioCliente && !string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            @if (!mostrarModalFormularioCliente && !string.IsNullOrWhiteSpace(debugError))
            {
                <div class="status-banner status-banner-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@debugError</span>
                </div>
            }

            @if (cargando)
            {
                <div class="state-card">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando clientes</h3>
                    <p>Preparando la cartera comercial y sus datos de identificación.</p>
                </div>
            }
            else if (!filteredClientes.Any())
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3>No hay clientes para mostrar</h3>
                    <p>Ajusta la búsqueda, cambia el tipo o registra un nuevo cliente.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table entity-table entity-table-clients mb-0">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th class="list-extra-col">Contacto</th>
                                <th>Identificación</th>
                                <th class="text-end">Facturas emitidas</th>
                                <th class="text-end">Saldo pendiente</th>
                                <th class="list-status-col">Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in clientesPaginados)
                            {
                                <tr>
                                    <td>
                                        <div class="cell-main cell-main-stacked">
                                            <strong>@GetNombreCompletoCliente(c)</strong>
                                            @if (!string.IsNullOrWhiteSpace(ObtenerNombreSecundarioCliente(c)))
                                            {
                                                <span class="meta-line">
                                                    <i class="bi bi-building"></i>
                                                    <span>@ObtenerNombreSecundarioCliente(c)</span>
                                                </span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(c.Correo))
                                            {
                                                <span class="meta-line">
                                                    <i class="bi bi-envelope"></i>
                                                    <span>@c.Correo</span>
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td class="list-extra-col">
                                        <div class="compact-detail">
                                            <span><i class="bi bi-telephone"></i> @(string.IsNullOrWhiteSpace(c.Celular) ? (string.IsNullOrWhiteSpace(c.Telefonoconvencional) ? "Sin teléfono" : c.Telefonoconvencional) : c.Celular)</span>
                                            <span><i class="bi bi-geo-alt"></i> @(string.IsNullOrWhiteSpace(GetCiudadNombre(c.Ciudad)) ? "Sin ubicación" : GetCiudadNombre(c.Ciudad))</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="code-pill">@(string.IsNullOrWhiteSpace(c.Numeroidentificacion) ? "Sin ID" : c.Numeroidentificacion)</span>
                                    </td>
                                    <td class="text-end">
                                        <strong>@c.FacturasEmitidas</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong>@($"${c.SaldoPendiente:N2}")</strong>
                                    </td>
                                    <td class="list-status-col">
                                        <div class="status-stack">
                                            <span class="status-pill @(c.Estado == true ? "status-pill-active" : "status-pill-inactive")">
                                                @(c.Estado == true ? "Activo" : "Inactivo")
                                            </span>
                                            <small>
                                                <i class="bi bi-receipt"></i>
                                                @(c.UltimaFactura.HasValue ? $"Última factura: {c.UltimaFactura:dd/MM/yyyy}" : "Sin facturas")
                                            </small>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        @if (EsConsumidorFinal(c))
                                        {
                                            <span class="action-empty">Sin acciones</span>
                                        }
                                        else
                                        {
                                            <div class="action-group">
                                                <button type="button" class="action-btn action-view" title="Ver"
                                                        @onclick="() => VerCliente(c)">
                                                    <i class="bi bi-eye"></i>
                                                </button>

                                                <button type="button" class="action-btn action-edit" title="Editar"
                                                        @onclick="() => Editar(c.Codcliente)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>

                                                <button type="button" class="action-btn action-delete" title="Eliminar"
                                                        @onclick="() => ConfirmarEliminar(c)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-pagination">
                    <span>Mostrando @primerRegistroVista-@ultimoRegistroVista de @TotalRegistrosFiltrados registros</span>
                    <div class="pagination-actions">
                        <button type="button"
                                class="pagination-btn"
                                disabled="@(paginaActualVista <= 1)"
                                @onclick="() => CambiarPagina(paginaActualVista - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <strong>@paginaActualVista / @totalPaginasVista</strong>
                        <button type="button"
                                class="pagination-btn"
                                disabled="@(paginaActualVista >= totalPaginasVista)"
                                @onclick="() => CambiarPagina(paginaActualVista + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>

            }

            @if (mostrarConfirmacion && clienteAEliminar is not null)
            {
                <div class="confirm-card">
                    <div class="confirm-copy">
                        <strong>Eliminar el cliente seleccionado</strong>
                        <p>@GetNombreCompletoCliente(clienteAEliminar)</p>
                    </div>

                    <div class="confirm-actions">
                        <button type="button" class="secondary-btn" @onclick="CancelarEliminar">Cancelar</button>
                        <button type="button" class="danger-btn" @onclick="EliminarConfirmado">Sí, eliminar</button>
                    </div>
                </div>
            }

            @if (clienteEnVista is not null)
            {
                <div class="detail-modal-backdrop" data-no-backdrop-dismiss="true" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onpointerdown:stopPropagation="true"></div>
                <div class="detail-modal" data-no-backdrop-dismiss="true" role="dialog" aria-modal="true" aria-labelledby="clienteDetalleTitulo" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onpointerdown:stopPropagation="true">
                    <div class="detail-modal-content" @onclick:stopPropagation="true">
                        <div class="detail-modal-header">
                            <div>
                                <span class="detail-kicker">Vista de cliente</span>
                                <h3 id="clienteDetalleTitulo">@GetNombreCompletoCliente(clienteEnVista)</h3>
                                <p>@GetTipoClienteDescripcion(clienteEnVista.TipoCliente) - @GetTipoIdentificacionDescripcion(clienteEnVista.Tipoidentificacion)</p>
                            </div>

                            <button type="button" class="detail-close" @onclick="CerrarVistaCliente" aria-label="Cerrar detalle" title="Cerrar">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>

                        <div class="detail-modal-body">
                            <div class="detail-sections">
                                <section class="detail-section">
                                    <h4 class="detail-section-title">Datos principales</h4>
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <span>Identificación</span>
                                            <strong>@(string.IsNullOrWhiteSpace(clienteEnVista.Numeroidentificacion) ? "Sin identificación" : clienteEnVista.Numeroidentificacion)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Estado</span>
                                            <strong>@GetEstadoDescripcion(clienteEnVista.Estado)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Correo principal</span>
                                            <strong>@(string.IsNullOrWhiteSpace(clienteEnVista.Correo) ? "Sin correo" : clienteEnVista.Correo)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Obligado a contabilidad</span>
                                            <strong>@GetObligadoContabilidadDescripcion(clienteEnVista.Oblgconta)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Nombre comercial</span>
                                            <strong>@(string.IsNullOrWhiteSpace(ObtenerNombreComercialCliente(clienteEnVista)) ? "Sin nombre comercial" : ObtenerNombreComercialCliente(clienteEnVista))</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Razón social</span>
                                            <strong>@(string.IsNullOrWhiteSpace(clienteEnVista.Nombrerazonsocial) ? "Sin razón social" : clienteEnVista.Nombrerazonsocial)</strong>
                                        </div>
                                    </div>
                                </section>

                                <section class="detail-section">
                                    <h4 class="detail-section-title">Contacto y ubicación</h4>
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <span>Teléfono</span>
                                            <strong>@(string.IsNullOrWhiteSpace(clienteEnVista.Telefonoconvencional) ? "Sin teléfono" : clienteEnVista.Telefonoconvencional)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Celular</span>
                                            <strong>@(string.IsNullOrWhiteSpace(clienteEnVista.Celular) ? "Sin celular" : clienteEnVista.Celular)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>País</span>
                                            <strong>@(string.IsNullOrWhiteSpace(GetPaisNombre(clienteEnVista.Pais)) ? "Sin país" : GetPaisNombre(clienteEnVista.Pais))</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Provincia</span>
                                            <strong>@(string.IsNullOrWhiteSpace(GetProvinciaNombre(clienteEnVista.Provincia)) ? "Sin provincia" : GetProvinciaNombre(clienteEnVista.Provincia))</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Cantón</span>
                                            <strong>@(string.IsNullOrWhiteSpace(GetCiudadNombre(clienteEnVista.Ciudad)) ? "Sin cantón" : GetCiudadNombre(clienteEnVista.Ciudad))</strong>
                                        </div>

                                        <div class="detail-item detail-item-full">
                                            <span>Dirección</span>
                                            <strong>@(string.IsNullOrWhiteSpace(clienteEnVista.Direccion) ? "Sin dirección" : clienteEnVista.Direccion)</strong>
                                        </div>
                                    </div>
                                </section>

                                @if (!string.IsNullOrWhiteSpace(GetCorreosAdicionalesTexto(clienteEnVista)))
                                {
                                    <div class="detail-note">
                                        <span>Correos adicionales</span>
                                        <strong>@GetCorreosAdicionalesTexto(clienteEnVista)</strong>
                                    </div>
                                }

                                        @if (!string.IsNullOrWhiteSpace(clienteEnVista.Observaciones))
                                        {
                                            <div class="detail-note">
                                                <span>Observaciones</span>
                                                <strong>@clienteEnVista.Observaciones</strong>
                                            </div>
                                        }

                                        <div class="detail-note">
                                            <span>Días de crédito</span>
                                            <strong>@(clienteEnVista.DiasCredito.HasValue ? $"{clienteEnVista.DiasCredito} días" : "Sin definir")</strong>
                                        </div>
                                    </div>
                                </div>

                        <div class="detail-modal-footer">
                            <button type="button" class="secondary-btn" @onclick="CerrarVistaCliente">Cerrar</button>
                        </div>
                    </div>
                </div>
            }
        </section>

        @if (EsModoCrudEmbebido)
        {
        <section class="editor-card entity-editor-card" data-tour="clientes.editor">
            <div class="editor-head">
                <div>
                    
                    <h3>@(editando ? "Editar cliente" : "Registrar cliente")</h3>
                    <p>Complete los datos comerciales, de contacto y ubicación del cliente.</p>
                </div>
                
            </div>

            <div class="editor-body entity-form-legacy">
                <EditForm Model="@model" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />

                    <div @key="formKey">
                            <details class="form-accordion" open>
                            <summary class="form-section-heading">
                                <span>1</span>
                                <strong>Información básica</strong>
                                <i class="bi bi-chevron-down"></i>
                            </summary>
                            <div class="form-accordion-body">

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small fw-bold">Tipo de Cliente *</label>
                                    <InputSelect class="form-select form-select-sm"
                                                 @bind-Value="model.TipoCliente"
                                                 @bind-Value:after="OnTipoClienteChanged">
                                        <option value="0">-- Seleccione Tipo --</option>
                                        @foreach (var t in tiposCliente)
                                        {
                                            <option value="@t.TclCodigo">@GetTipoClienteEtiqueta(t)</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => model.TipoCliente)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label small fw-bold">Tipo Identificación *</label>
                                    <InputSelect class="form-select form-select-sm"
                                                 @bind-Value="model.Tipoidentificacion"
                                                 @bind-Value:after="OnTipoIdentificacionChangedAsync">
                                        <option value="">-- Seleccione --</option>
                                        @foreach (var id in IdentificacionesDisponibles)
                                        {
                                            <option value="@id.Id">@id.Descripcion</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => model.Tipoidentificacion)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small fw-bold">Número Identificación *</label>
                                     <input class="form-control form-control-sm"
                                            value="@model.Numeroidentificacion"
                                            @oninput="OnNumeroIdentificacionChangedAsync"
                                            @onblur="OnNumeroIdentificacionBlurAsync" />
                                     <ValidationMessage For="@(() => model.Numeroidentificacion)" class="text-danger small" />
                                     @if (consultandoCedula)
                                     {
                                         <div class="status-banner status-banner-info mt-2">
                                             <i class="bi bi-search"></i>
                                             <span>Buscando datos de la identificación...</span>
                                         </div>
                                     }
                                     else if (!string.IsNullOrWhiteSpace(mensajeConsultaCedula))
                                     {
                                         <div class="small mt-1 @(consultaCedulaEsError ? "text-danger" : "text-success")">@mensajeConsultaCedula</div>
                                     }
                                 </div>
                             </div>

                            @if (!TieneTipoClienteSeleccionado)
                            {
                                <div class="status-banner status-banner-info mb-2">
                                    <i class="bi bi-info-circle"></i>
                                    <span>Selecciona primero el tipo de cliente</span>
                                </div>
                            }

                            @if (EsPersonaSeleccionada)
                            {
                                <div class="row mb-2">
                                    <div class="col">
                                        <label class="form-label small fw-bold">Apellidos *</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="model.Apellidos" />
                                        <ValidationMessage For="@(() => model.Apellidos)" class="text-danger small" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label small fw-bold">Nombres *</label>
