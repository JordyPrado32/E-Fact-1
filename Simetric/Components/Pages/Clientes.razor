    private async Task CargarLookupsClientes()
    {
        try
        {
            var respLook = await Http.GetAsync("api/clientes/lookups");
            var bodyLook = await respLook.Content.ReadAsStringAsync();

            if (!respLook.IsSuccessStatusCode)
                throw new Exception($"LOOKUPS -> HTTP {(int)respLook.StatusCode}: {bodyLook}");

            using var doc = System.Text.Json.JsonDocument.Parse(bodyLook);

            tiposCliente = new();
            if (doc.RootElement.TryGetProperty("tipos", out var tiposElem) &&
                tiposElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var t in tiposElem.EnumerateArray())
                {
                    var codigo = t.TryGetProperty("tclCodigo", out var c) ? c.GetInt32() : 0;
                    var desc = t.TryGetProperty("descripcion", out var d) ? d.GetString() ?? "" : "";
                    tiposCliente.Add(new TipoClienteDto { TclCodigo = codigo, Descripcion = desc });
                }
            }

            tiposCliente = tiposCliente
                .Where(tipo => EsDescripcionPersonaNatural(tipo.Descripcion) || EsDescripcionEmpresa(tipo.Descripcion))
                .GroupBy(GetTipoClienteEtiqueta, StringComparer.OrdinalIgnoreCase)
                .Select(grupo => grupo.First())
                .OrderBy(tipo => EsDescripcionEmpresa(tipo.Descripcion) ? 2 : 1)
                .ToList();

            paises = new();
            if (doc.RootElement.TryGetProperty("paises", out var paisesElem) &&
                paisesElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var p in paisesElem.EnumerateArray())
                {
                    var idPais = p.TryGetProperty("idPais", out var pid) ? pid.GetInt32() : 0;
                    var desc = p.TryGetProperty("descripcion", out var pd) ? pd.GetString() ?? "" : "";
                    paises.Add(new PaisLookupDto { IdPais = idPais, Descripcion = desc });
                }
            }

            ActualizarPaisEcuadorId();

            identificaciones = new();
            if (doc.RootElement.TryGetProperty("identificaciones", out var idElem) &&
                idElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var i in idElem.EnumerateArray())
                {
                    var ideSec = i.TryGetProperty("ideSec", out var sid) ? sid.GetInt32() : 0;
                    var ideCodigo = i.TryGetProperty("ideCodigo", out var scod) ? scod.GetString() ?? "" : "";
                    var ideDescripcion = i.TryGetProperty("ideDescripcion", out var sdesc) ? sdesc.GetString() ?? "" : "";
                    identificaciones.Add(new IdentificacionDto
                    {
                        Id = ideSec,
                        Codigo = ideCodigo,
                        Descripcion = ideDescripcion
                    });
                }
            }
        }
        catch (Exception exLook)
        {
            debugError = (debugError is null) ? exLook.Message : debugError + " || " + exLook.Message;
        }
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private async Task CargarPaises()
    {
        try
        {
            if (paises.Any())
            {
                ActualizarPaisEcuadorId();
                return;
            }

            var resp = await Http.GetAsync("api/clientes/lookups");
            var body = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
                throw new Exception($"PAISES -> HTTP {(int)resp.StatusCode}: {body}");

            using var doc = System.Text.Json.JsonDocument.Parse(body);
            paises = new();

            if (doc.RootElement.TryGetProperty("paises", out var paisesElem) &&
                paisesElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var p in paisesElem.EnumerateArray())
                {
                    var idPais = p.TryGetProperty("idPais", out var pid) ? pid.GetInt32() : 0;
                    var desc = p.TryGetProperty("descripcion", out var pd) ? pd.GetString() ?? "" : "";
                    paises.Add(new PaisLookupDto { IdPais = idPais, Descripcion = desc });
                }
            }

            ecuadorPaisId = paises
                .FirstOrDefault(p => string.Equals(p.Descripcion?.Trim(), "ECUADOR", StringComparison.OrdinalIgnoreCase))
                ?.IdPais;
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private void ActualizarPaisEcuadorId()
