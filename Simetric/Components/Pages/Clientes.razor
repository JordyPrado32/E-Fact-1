            ?.IdPais;
    }

    private async Task CargarUbicacionEcuador()
    {
        try
        {
            if (ecuadorPaisId is null || ecuadorPaisId <= 0)
                return;

            var resp = await Http.GetAsync("api/clientes/ubicacion-ecuador");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
                throw new Exception($"UBICACION ECUADOR -> HTTP {(int)resp.StatusCode}: {body}");

            using var doc = System.Text.Json.JsonDocument.Parse(body);

            if (doc.RootElement.TryGetProperty("provincias", out var provinciasElem) &&
                provinciasElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in provinciasElem.EnumerateArray())
                {
                    var idProvincia = item.TryGetProperty("idProvincia", out var idProp) ? idProp.GetInt32() : 0;
                    if (idProvincia <= 0 || provincias.Any(p => p.IdProvincia == idProvincia))
                        continue;

                    provincias.Add(new ProvinciaLookupDto
                    {
                        IdProvincia = idProvincia,
                        Descripcion = item.TryGetProperty("descripcion", out var descProp) ? descProp.GetString() ?? "" : "",
                        IdPais = item.TryGetProperty("idPais", out var paisProp) ? paisProp.GetInt32() : ecuadorPaisId
                    });
                }
            }

            OrdenarProvinciasEcuador();

            if (doc.RootElement.TryGetProperty("ciudades", out var ciudadesElem) &&
                ciudadesElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in ciudadesElem.EnumerateArray())
                {
                    var idCiudad = item.TryGetProperty("idCiudad", out var idProp) ? idProp.GetInt32() : 0;
                    if (idCiudad <= 0 || ciudades.Any(c => c.IdCiudad == idCiudad))
                        continue;

                    ciudades.Add(new CiudadLookupDto
                    {
                        IdCiudad = idCiudad,
                        Descripcion = item.TryGetProperty("descripcion", out var descProp) ? descProp.GetString() ?? "" : "",
                        IdProvincia = item.TryGetProperty("idProvincia", out var provProp) ? provProp.GetInt32() : null
                    });
                }
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private void OrdenarProvinciasEcuador()
    {
        if (ecuadorPaisId is null || ecuadorPaisId <= 0)
            return;

        var ordenCatalogo = CatalogoUbicacionEcuador.Provincias
            .Select((provincia, index) => new { provincia.Nombre, index })
            .ToDictionary(x => NormalizarClaveUbicacion(x.Nombre), x => x.index);

        provincias = provincias
            .OrderBy(p =>
            {
                if (p.IdPais != ecuadorPaisId)
                    return int.MaxValue - 1;

                var clave = NormalizarClaveUbicacion(p.Descripcion);
                return ordenCatalogo.TryGetValue(clave, out var orden) ? orden : int.MaxValue;
            })
            .ThenBy(p => p.Descripcion)
            .ToList();
    }

    private int GetOrdenProvincia(ProvinciaLookupDto provincia)
    {
        if (provincia.IdPais != ecuadorPaisId)
            return int.MaxValue;

        var clave = NormalizarClaveUbicacion(provincia.Descripcion);
        var indice = 0;
        foreach (var item in CatalogoUbicacionEcuador.Provincias)
        {
            if (NormalizarClaveUbicacion(item.Nombre) == clave)
                return indice;

            indice++;
        }

        return int.MaxValue;
    }

    private static string NormalizarClaveUbicacion(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return string.Empty;

        var normalizado = valor.Trim().Normalize(System.Text.NormalizationForm.FormD);
        var builder = new System.Text.StringBuilder(normalizado.Length);

        foreach (var caracter in normalizado)
        {
            if (System.Globalization.CharUnicodeInfo.GetUnicodeCategory(caracter) != System.Globalization.UnicodeCategory.NonSpacingMark)
                builder.Append(char.ToUpperInvariant(caracter));
        }

        return builder.ToString();
    }

    private async Task CargarProvincias(int paisId)
    {
        try
        {
            if (provincias.Any(p => p.IdPais == paisId))
                return;

            var resp = await Http.GetAsync($"api/clientes/provincias?paisId={paisId}");
            var body = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
                throw new Exception($"PROVINCIAS -> HTTP {(int)resp.StatusCode}: {body}");

            var data = System.Text.Json.JsonSerializer.Deserialize<List<ProvinciaLookupDto>>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            var nuevas = data ?? new();
            foreach (var x in nuevas)
            {
                x.IdPais = paisId;
                if (!provincias.Any(p => p.IdProvincia == x.IdProvincia))
                    provincias.Add(x);
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

