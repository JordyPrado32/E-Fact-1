    private async Task CargarTodo(bool esRefresco = false)
    {
        if (isDemoMode)
        {
            CargarDemoClientes();
            if (esRefresco)
                mensaje = "Datos demo recargados correctamente.";
            StateHasChanged();
            return;
        }

        cargando = true;
        mensaje = null;
        debugError = null;

        try
        {
            await CargarLookupsClientes();
            await CargarPaises();
            await CargarUbicacionEcuador();

            if (!model.Pais.HasValue && ecuadorPaisId.HasValue)
                model.Pais = ecuadorPaisId;

            var resp = await Http.GetAsync($"api/clientes?userId={usuarioLogueadoId}");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
                throw new Exception($"CLIENTES -> HTTP {(int)resp.StatusCode}: {body}");

            var data = System.Text.Json.JsonSerializer.Deserialize<List<ClienteDto>>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            clientes = data ?? new();

            await CargarUltimasFacturasClientes();
            await PrepararLookupsUbicacionParaListado();
            await EmisorOnboardingService.RefreshRequirementAsync(usuarioLogueadoId);
            emisionEstado = await EmisionControlService.ObtenerEstadoAsync(usuarioLogueadoId);

            if (esRefresco) mensaje = "Datos actualizados correctamente.";
            dbName = $"API ({Http.BaseAddress})";
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
            mensaje = "Falló la carga de datos.";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarUltimasFacturasClientes()
    {
        var ids = clientes.Select(c => c.Codcliente).Where(id => id > 0).Distinct().ToList();
        if (ids.Count == 0 || usuarioLogueadoId <= 0)
            return;

        await using var context = await DbFactory.CreateDbContextAsync();
        var fechas = await context.Facturas
            .AsNoTracking()
            .Where(f => f.Idusuario == usuarioLogueadoId &&
                        f.Codclientes.HasValue &&
                        ids.Contains(f.Codclientes.Value))
            .Select(f => new
            {
                ClienteId = f.Codclientes!.Value,
                Fecha = f.Fchautorizacion ?? f.Fechaentrega
            })
            .ToListAsync();

        var ultimas = fechas
            .Where(x => x.Fecha.HasValue)
            .GroupBy(x => x.ClienteId)
            .ToDictionary(g => g.Key, g => g.Max(x => x.Fecha));

        foreach (var cliente in clientes)
            cliente.UltimaFactura = ultimas.GetValueOrDefault(cliente.Codcliente);

        var facturasEmitidas = await context.Facturas
            .AsNoTracking()
            .Where(f => f.Idusuario == usuarioLogueadoId &&
                        f.Codclientes.HasValue &&
                        ids.Contains(f.Codclientes.Value))
            .GroupBy(f => f.Codclientes!.Value)
            .Select(g => new { ClienteId = g.Key, Total = g.Count() })
            .ToDictionaryAsync(x => x.ClienteId, x => x.Total);

        var saldosPendientes = await context.Facturas
            .AsNoTracking()
            .Where(f => f.Idusuario == usuarioLogueadoId &&
                        f.Codclientes.HasValue &&
                        ids.Contains(f.Codclientes.Value) &&
                        f.Tipopago == "19")
            .Select(f => new
            {
                ClienteId = f.Codclientes!.Value,
                SaldoPendiente = (f.Valortotal ?? 0m) - (
                    context.Abonos
                        .Where(a => a.codFactura == f.Codfactura && a.estado == true)
                        .Sum(a => (decimal?)a.abono) ?? 0m)
            })
            .ToListAsync();

        var saldoPorCliente = saldosPendientes
            .GroupBy(x => x.ClienteId)
            .ToDictionary(g => g.Key, g => Math.Round(g.Sum(x => Math.Max(x.SaldoPendiente, 0m)), 2));

        foreach (var cliente in clientes)
        {
            cliente.FacturasEmitidas = facturasEmitidas.GetValueOrDefault(cliente.Codcliente);
            cliente.SaldoPendiente = saldoPorCliente.GetValueOrDefault(cliente.Codcliente);
        }
    }

    private async Task PrepararLookupsUbicacionParaListado()
    {
        var paisIds = clientes.Where(x => x.Pais.HasValue).Select(x => x.Pais!.Value).Distinct().ToList();
        foreach (var pid in paisIds)
        {
            if (!provincias.Any(p => p.IdPais == pid))
                await CargarProvincias(pid);
        }

        var provIds = clientes.Where(x => x.Provincia.HasValue).Select(x => x.Provincia!.Value).Distinct().ToList();
        foreach (var prId in provIds)
        {
            if (!ciudades.Any(c => c.IdProvincia == prId))
                await CargarCiudades(prId);
        }
    }

