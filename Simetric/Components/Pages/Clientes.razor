        [StringLength(250, ErrorMessage = "Máximo 250 caracteres")]
        public string? Direccion { get; set; }

        public string? Telefonoconvencional { get; set; }

        public string? Celular { get; set; }

        [JsonIgnore]
        public string TipoContactoTelefonico { get; set; } = "CELULAR";

        [Required(ErrorMessage = "El correo electrónico es obligatorio")]
        [EmailAddress(ErrorMessage = "Correo electrónico no válido")]
        [StringLength(150, ErrorMessage = "Máximo 150 caracteres")]
        public string? Correo { get; set; }
        public int? DiasCredito { get; set; }

        [Required(ErrorMessage = "Debe indicar si lleva contabilidad")]
        [RegularExpression(@"^(SI|NO)$", ErrorMessage = "Solo se permite SI o NO")]
        public string? Oblgconta { get; set; }

        [Range(1, int.MaxValue, ErrorMessage = "Debe seleccionar el tipo de cliente")]
        public int TipoCliente { get; set; }

        [JsonIgnore]
        public bool EsTipoEmpresa { get; set; }

        public bool? Estado { get; set; } = true;

        [StringLength(300, ErrorMessage = "Máximo 300 caracteres")]
        public string? Observaciones { get; set; }

        public int? Pais { get; set; }

        public int? Provincia { get; set; }

        public int? Ciudad { get; set; }

        [JsonIgnore]
        public bool EsCliente { get; set; } = true;

        [JsonIgnore]
        public bool EsProveedor { get; set; }

        [JsonIgnore]
        public string? CuentaContableProveedor { get; set; } = "21311 - Proveedores";

        [JsonIgnore]
        public string? CreditoTributarioProveedor { get; set; }

        [JsonIgnore]
        public string? CodigoProveedor { get; set; }

        [JsonIgnore]
        public bool EsSujetoRetencionProveedor { get; set; }

        [JsonIgnore]
        public bool RegistraInformacionBancariaProveedor { get; set; }

        [JsonIgnore]
        public string? BancoProveedor { get; set; }

        [JsonIgnore]
        public string? TipoCuentaProveedor { get; set; }

        [JsonIgnore]
        public string? NumeroCuentaProveedor { get; set; }

        private static string? SanitizarTelefono(string? valor, bool esCelular)
        {
            if (string.IsNullOrWhiteSpace(valor)) return null;
            var digitos = new string(valor.Where(char.IsDigit).ToArray());
            if (string.IsNullOrEmpty(digitos)) return null;
            if (esCelular && digitos.Length == 9 && digitos.StartsWith('9'))
            {
                digitos = "0" + digitos;
            }
            return digitos;
        }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            Numeroidentificacion = Numeroidentificacion?.Trim();
            Apellidos = Apellidos?.Trim();
            Nombres = Nombres?.Trim();
            Nombrecomercial = Nombrecomercial?.Trim();
            Nombrerazonsocial = Nombrerazonsocial?.Trim();
            Direccion = Direccion?.Trim();
            Correo = Correo?.Trim();
            Telefonoconvencional = SanitizarTelefono(Telefonoconvencional, esCelular: false);
            Celular = SanitizarTelefono(Celular, esCelular: true);
            Observaciones = Observaciones?.Trim();
            Oblgconta = Oblgconta?.Trim().ToUpperInvariant();

            if (TipoCliente <= 0)
                yield break;

            bool esPasaporte = false;
            bool esCedula = false;
            bool esRuc = false;
            if (Parent != null && Tipoidentificacion.HasValue)
            {
                var match = Parent.identificaciones.FirstOrDefault(x => x.Id == Tipoidentificacion.Value);
                if (match != null)
                {
                    esPasaporte = string.Equals(match.Codigo, "06", StringComparison.OrdinalIgnoreCase) ||
                                  match.Descripcion.Contains("pasaporte", StringComparison.OrdinalIgnoreCase);
                    esCedula = string.Equals(match.Codigo, "05", StringComparison.OrdinalIgnoreCase) ||
                               match.Descripcion.Contains("cedula", StringComparison.OrdinalIgnoreCase) ||
                               match.Descripcion.Contains("cédula", StringComparison.OrdinalIgnoreCase);
                    esRuc = string.Equals(match.Codigo, "04", StringComparison.OrdinalIgnoreCase) ||
                            match.Descripcion.Contains("RUC", StringComparison.OrdinalIgnoreCase);
                }
            }

            if (!string.IsNullOrWhiteSpace(Numeroidentificacion) && Numeroidentificacion.All(char.IsDigit))
            {
                if (esCedula && Numeroidentificacion.Length == 9)
                {
                    Numeroidentificacion = "0" + Numeroidentificacion;
                }
                else if (esRuc && Numeroidentificacion.Length == 12)
                {
                    Numeroidentificacion = "0" + Numeroidentificacion;
                }
            }

            if (string.IsNullOrWhiteSpace(Numeroidentificacion))
            {
                yield return new ValidationResult(
                    "El número de identificación es obligatorio.",
                    new[] { nameof(Numeroidentificacion) });
            }
            else
            {
                if (esPasaporte)
                {
                    if (!Numeroidentificacion.All(char.IsLetterOrDigit))
                    {
                        yield return new ValidationResult(
                            "El pasaporte solo puede contener letras y números.",
                            new[] { nameof(Numeroidentificacion) });
                    }
                    if (Numeroidentificacion.Length < 3 || Numeroidentificacion.Length > 20)
                    {
                        yield return new ValidationResult(
                            "El pasaporte debe tener entre 3 y 20 caracteres.",
                            new[] { nameof(Numeroidentificacion) });
                    }
                }
                else
                {
                    if (!Numeroidentificacion.All(char.IsDigit))
                    {
                        yield return new ValidationResult(
                            "La identificación solo debe contener números.",
                            new[] { nameof(Numeroidentificacion) });
                    }
                    if (Numeroidentificacion.Length < 10 || Numeroidentificacion.Length > 13)
                    {
                        yield return new ValidationResult(
                            "La identificación debe tener entre 10 y 13 dígitos.",
                            new[] { nameof(Numeroidentificacion) });
                    }
                }
            }

            foreach (var correoAdicional in CorreosAdicionales.Where(correo => !string.IsNullOrWhiteSpace(correo)))
            {
                if (!EsCorreoValido(correoAdicional))
                {
                    yield return new ValidationResult(
                        "El correo secundario no es válido.",
                        new[] { nameof(CorreosAdicionales) });
                }
            }

            var correoPrincipalNormalizado = NormalizarCorreo(Correo);
            var correosSecundariosNormalizados = CorreosAdicionales
                .Select(NormalizarCorreo)
                .Where(correo => !string.IsNullOrWhiteSpace(correo))
                .ToList();

            if (!string.IsNullOrWhiteSpace(correoPrincipalNormalizado) &&
                correosSecundariosNormalizados.Contains(correoPrincipalNormalizado, StringComparer.OrdinalIgnoreCase))
            {
                yield return new ValidationResult(
                    "El correo secundario no puede ser igual al correo principal.",
                    new[] { nameof(Correo), nameof(CorreosAdicionales) });
            }

            if (correosSecundariosNormalizados.Count != correosSecundariosNormalizados.Distinct(StringComparer.OrdinalIgnoreCase).Count())
            {
                yield return new ValidationResult(
                    "No se permiten correos secundarios repetidos.",
                    new[] { nameof(CorreosAdicionales) });
            }

            if (EsTextoPersona())
            {
                if (string.IsNullOrWhiteSpace(Apellidos))
                {
                    yield return new ValidationResult(
                        "Los apellidos son obligatorios.",
                        new[] { nameof(Apellidos) });
                }
                else if (!TieneDosPalabras(Apellidos))
                {
                    yield return new ValidationResult(
                        "Debe ingresar al menos un apellido.",
                        new[] { nameof(Apellidos) });
                }

                if (string.IsNullOrWhiteSpace(Nombres))
                {
                    yield return new ValidationResult(
                        "Los nombres son obligatorios.",
                        new[] { nameof(Nombres) });
                }
                else if (!TieneDosPalabras(Nombres))
                {
                    yield return new ValidationResult(
                        "Debe ingresar al menos un nombre.",
                        new[] { nameof(Nombres) });
                }
            }
            else
            {
                if (string.IsNullOrWhiteSpace(Nombrerazonsocial))
                {
                    yield return new ValidationResult(
                        "La razón social es obligatoria para persona jurídica.",
                        new[] { nameof(Nombrerazonsocial) });
                }

            }

        }

        private bool EsTextoPersona()
        {
            return !EsTipoEmpresa;
        }

        private static bool EsCorreoValido(string valor)
        {
            try
            {
                _ = new System.Net.Mail.MailAddress(valor);
                return true;
            }
            catch
            {
                return false;
            }
        }

        private static string NormalizarCorreo(string? valor) =>
            (valor ?? string.Empty).Trim().ToLowerInvariant();

        private static bool TieneMinimoDosPalabras(string? texto)
        {
            if (string.IsNullOrWhiteSpace(texto))
                return false;

            var partes = texto
                .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            return partes.Length >= 2;
        }
    }

    private static bool TieneDosPalabras(string texto) =>
        !string.IsNullOrWhiteSpace(texto);

