    private static bool EsConsumidorFinal(ClienteDto cliente)
    {
        var identificacion = (cliente.Numeroidentificacion ?? string.Empty).Trim();
        if (identificacion == "9999999999999")
        {
            return true;
        }

        var nombres = (cliente.Nombres ?? string.Empty).Trim();
        var apellidos = (cliente.Apellidos ?? string.Empty).Trim();
        var correo = (cliente.Correo ?? string.Empty).Trim();

        return string.Equals(nombres, "Consumidor", StringComparison.OrdinalIgnoreCase)
            && string.Equals(apellidos, "Final", StringComparison.OrdinalIgnoreCase)
            && string.Equals(correo, "consumidorfinal@numerica", StringComparison.OrdinalIgnoreCase);
    }

