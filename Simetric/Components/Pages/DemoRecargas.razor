@page "/demo/recargas"
@layout Simetric.Components.Layout.MainLayout
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Simetric.Models
@using System.Globalization

<PageTitle>Compra de documentos demo | Numerica e-fact</PageTitle>

<div class="recargas-shell">
    <section class="recargas-header">
        <div class="recargas-title-wrap">
            <span class="page-kicker">1. Recarga tu cuenta</span>
            <h1>Compra documentos por recarga</h1>
            <p>Elige la cantidad de documentos que necesitas. En una cuenta real, el saldo se acredita al aprobarse el pago.</p>
        </div>
        <div class="header-stats">
            <article class="header-stat"><span>Saldo demo</span><strong>5 documentos</strong><small>Datos de ejemplo</small></article>
            <article class="header-stat"><span>Última recarga</span><strong>Sin movimientos</strong><small>Recorrido seguro</small></article>
        </div>
    </section>

    <section class="demo-notice"><i class="bi bi-info-circle"></i><span><strong>Modo demo.</strong> La calculadora funciona con las tarifas vigentes, pero no se procesará ningún pago.</span></section>

    <section class="commerce-grid recharge-commerce">
        <div class="plans-panel">
            <div class="custom-recharge custom-recharge-top">
                <div class="custom-recharge-copy">
                    <span class="section-kicker">Recarga personalizada</span>
                    <strong>Compra por documentos o por dinero</strong>
                    <small>Edita cualquiera de los dos valores y la calculadora actualiza automáticamente el otro.</small>
                </div>

                <label class="recharge-field">
                    <span>¿Cuántos documentos deseas comprar?</span>
                    <input type="number" min="@EFactDocumentPricing.DocumentosMinimosPersonalizados" max="@MaxDocumentos" class="recharge-input"
                           @bind="cantidadDocumentos" @bind:event="oninput" @bind:after="ActualizarDesdeCantidad" />
                    <small>Mínimo @EFactDocumentPricing.DocumentosMinimosPersonalizados documentos (equivalente a $5,00)</small>
                </label>

                <label class="recharge-field">
                    <span>Valor de la recarga</span>
                    <span class="custom-money-field">
                        <span class="money-prefix">$</span>
                        <input type="number" min="5" max="1000" step="0.01" class="custom-input" @bind="montoRecarga" @bind:event="oninput" @bind:after="ActualizarDesdeMonto" />
                        <span class="money-code">USD</span>
                    </span>
                    <small>Monto mínimo de recarga: $5,00</small>
                </label>
            </div>

            <div class="panel-head recommended-head">
                <div><span class="section-kicker">Opciones recomendadas</span><h2>Elige una recarga rápida</h2></div>
                <span class="panel-hint">Precios finales con IVA incluido</span>
            </div>

            <div class="plans-grid">
                @foreach (var plan in Planes)
                {
                    var seleccionado = plan.CantidadDocs < 0 ? esPlanIlimitado : !esPlanIlimitado && cantidadDocumentos == plan.CantidadDocs;
                    var clase = plan.CantidadDocs < 0 ? "plan-card-annual" : plan.EsRecomendado ? "plan-card-featured" : string.Empty;
                    <button type="button" class="plan-card @clase @(seleccionado ? "is-selected" : string.Empty)" @onclick="() => SeleccionarPlan(plan)">
                        <span class="plan-card-head">
                            <span class="plan-symbol plan-symbol-@plan.ColorClase"><i class="bi @plan.Icono"></i></span>
                            @if (plan.CantidadDocs < 0)
                            {
                                <span class="plan-highlight is-green">Mayor ahorro</span>
                            }
                            else if (plan.EsRecomendado)
                            {
                                <span class="plan-highlight">Recomendado</span>
                            }
                            <span class="plan-selected-check"><i class="bi bi-check-lg"></i></span>
                        </span>
                        <span class="plan-main">
                            <span class="plan-copy">
                                @if (plan.CantidadDocs < 0)
                                {<strong class="plan-docs plan-docs-unlimited">Ilimitados</strong><span class="plan-docs-label">durante 1 año</span>}
                                else
                                {<strong class="plan-docs">@plan.CantidadDocs</strong><span class="plan-docs-label">documentos</span>}
                            </span>
                            <span class="plan-price"><small>USD</small> $@plan.Precio.ToString("F2", CultureInfo.InvariantCulture)</span>
                        </span>
                        <span class="plan-description">@plan.Descripcion</span>
                        <span class="plan-cta"><span>Elegir plan</span><i class="bi bi-arrow-right"></i></span>
                    </button>
                }
            </div>

            @if (!CalculoValido)
            {
                <div class="custom-warning">La recarga debe estar entre $5,00 y $1.000,00 y respetar la cantidad mínima permitida.</div>
            }
        </div>

        <aside class="checkout-panel">
            <div class="checkout-card">
                <div class="panel-head panel-head-compact"><span class="section-kicker">Resumen de compra</span><h2>@(esPlanIlimitado ? "Plan ilimitado" : "Recarga de documentos")</h2></div>
                <div class="summary-box">
                    <div class="summary-row summary-documents"><span>Documentos</span><strong>@(esPlanIlimitado ? "Ilimitados" : cantidadDocumentos.ToString("N0", Cultura))</strong></div>
                    @if (esPlanIlimitado)
                    {
                        <div class="summary-row"><span>Vigencia</span><strong>1 año</strong></div>
                    }
                    <div class="summary-row"><span>Subtotal</span><strong>$@Subtotal.ToString("F2", CultureInfo.InvariantCulture)</strong></div>
                    <div class="summary-row"><span>IVA 15%</span><strong>$@Iva.ToString("F2", CultureInfo.InvariantCulture)</strong></div>
                    <div class="summary-row summary-row-total"><span>Total a pagar</span><strong><small>USD</small> $@Total.ToString("F2", CultureInfo.InvariantCulture)</strong></div>
                </div>
                <button type="button" class="btn-buy" disabled>Confirmar recarga</button>
                <div class="checkout-footnote"><i class="bi bi-shield-lock"></i><span><strong>Compra bloqueada en demo.</strong> Regístrate para procesar una recarga real.</span></div>
            </div>
        </aside>
    </section>

    <section class="recharge-benefits">
        <article><i class="bi bi-person"></i><span><strong>Recargas para 1 usuario</strong><small>Los documentos aplican al usuario que compra.</small></span></article>
        <article><i class="bi bi-lightning-charge"></i><span><strong>Acreditación automática</strong><small>Se aplica cuando el pago queda aprobado.</small></span></article>
        <article><i class="bi bi-calendar2-check"></i><span><strong>Sin vencimientos</strong><small>Utiliza tus documentos cuando los necesites.</small></span></article>
    </section>
</div>

@code {
    private static readonly CultureInfo Cultura = CultureInfo.GetCultureInfo("es-EC");
    private static readonly IReadOnlyList<EFactPlanDto> Planes = EFactBillingConfig.EFactPlans.Where(p => p.CantidadDocs != 0).ToList();
    private int cantidadDocumentos = EFactDocumentPricing.DocumentosMinimosPersonalizados;
    private decimal montoRecarga = EFactDocumentPricing.MontoMinimoPersonalizado;
    private bool esPlanIlimitado;
    private static int MaxDocumentos => decimal.ToInt32(decimal.Floor(EFactDocumentPricing.MontoMaximoPersonalizado / EFactDocumentPricing.PrecioRecargaAlta));
    private decimal Total => esPlanIlimitado ? EFactDocumentPricing.PrecioPlanIlimitado : Math.Max(0m, montoRecarga);
    private decimal Subtotal => EFactDocumentPricing.CalcularSubtotalDesdeTotal(Total);
    private decimal Iva => EFactDocumentPricing.CalcularIvaDesdeTotal(Total);
    private bool CalculoValido => esPlanIlimitado || (cantidadDocumentos >= EFactDocumentPricing.DocumentosMinimosPersonalizados && cantidadDocumentos <= MaxDocumentos && montoRecarga >= EFactDocumentPricing.MontoMinimoPersonalizado && montoRecarga <= EFactDocumentPricing.MontoMaximoPersonalizado);
    private void ActualizarDesdeCantidad() { esPlanIlimitado = false; montoRecarga = cantidadDocumentos > 0 ? EFactDocumentPricing.CalcularTotalPorCantidad(cantidadDocumentos) : 0m; }
    private void ActualizarDesdeMonto() { esPlanIlimitado = false; var precio = EFactDocumentPricing.ObtenerPrecioPorDocumentoSegunMonto(montoRecarga); cantidadDocumentos = EFactDocumentPricing.CalcularDocumentosPorMonto(montoRecarga, precio); }
    private void SeleccionarPlan(EFactPlanDto plan) { esPlanIlimitado = plan.CantidadDocs < 0; montoRecarga = plan.Precio; if (!esPlanIlimitado) cantidadDocumentos = plan.CantidadDocs; }
}
