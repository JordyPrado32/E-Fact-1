@page "/e-contax/administracion/formas-pago"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.Text.Json
@using Simetric.Models
@using Simetric.Services
@using Simetric.Services.EContax
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject EContaxAdministracionService AdministracionService
@rendermode InteractiveServer

@{
    var pagosPaginados = PagosPaginados.ToList();
}

<PageTitle>Formas de pago | Numerica E-Contax</PageTitle>

<div class="econtax-admin-shell" data-tour="econtax.formas-pago.page">
    <section class="admin-table-card">
        <div class="admin-table-head">
            <div>
                <span class="admin-kicker">Catalogo transaccional</span>
                <h3>Listado de formas de pago</h3>
            </div>

            <button type="button" class="primary-btn admin-primary-btn" @onclick="AbrirModalNueva">
                <i class="bi bi-plus-circle"></i>
                <span>Nueva</span>
            </button>
        </div>

        <div class="admin-filters">
            <label class="admin-search">
                <i class="bi bi-search"></i>
                <input type="search"
                       placeholder="Buscar por codigo, descripcion o SRI"
                       @bind="SearchTerm"
                       @bind:event="oninput" />
            </label>

            <select class="admin-filter" @bind="FiltroUso">
                <option value="todos">Todos</option>
                <option value="venta">Solo ventas</option>
                <option value="compra">Solo compras</option>
            </select>

            <select class="admin-filter admin-filter-small" @bind="PageSize">
                <option value="5">5 registros</option>
                <option value="10">10 registros</option>
                <option value="20">20 registros</option>
            </select>

            <button type="button" class="secondary-btn admin-refresh-btn" @onclick="CargarDatos">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refrescar</span>
            </button>
        </div>

        @if (isLoading)
        {
            <div class="admin-state">
                <div class="admin-state-icon">
                    <span class="spinner-border text-primary" role="status"></span>
                </div>
                <h3>Cargando formas de pago</h3>
                <p>Estamos preparando el catalogo de E-Contax.</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(pageErrorMessage))
        {
            <div class="admin-state admin-state-error">
                <div class="admin-state-icon">
                    <i class="bi bi-exclamation-octagon"></i>
                </div>
                <h3>No se pudo cargar la informacion</h3>
                <p>@pageErrorMessage</p>
            </div>
        }
        else if (!pagosPaginados.Any())
        {
            <div class="admin-state">
                <div class="admin-state-icon">
                    <i class="bi bi-search"></i>
                </div>
                <h3>Sin resultados</h3>
                <p>No encontramos formas de pago con los filtros actuales.</p>
            </div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>Codigo</th>
                            <th>Descripcion</th>
                            <th>SRI</th>
                            <th class="text-center">Uso</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in pagosPaginados)
                        {
                            <tr @key="item.Id">
                                <td>
                                    <span class="code-pill">@item.Codigo</span>
                                </td>
                                <td>
                                    <div class="cell-main">
                                        <strong>@item.Descripcion</strong>
                                    </div>
                                </td>
                                <td class="admin-muted">@item.DescripcionSri</td>
                                <td class="text-center">
                                    <div class="badge-group">
                                        <span class="soft-badge @(item.TipoVenta == true ? "soft-badge-success" : "soft-badge-muted")">Venta</span>
                                        <span class="soft-badge @(item.TipoCompra == true ? "soft-badge-info" : "soft-badge-muted")">Compra</span>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <div class="action-group">
                                        <button type="button" class="action-btn action-view" title="Ver" @onclick="() => VerDetalle(item.Id)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button" class="action-btn action-edit" title="Editar" @onclick="() => AbrirModal(item)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button type="button" class="action-btn action-delete" title="Eliminar" @onclick="() => ConfirmarEliminar(item)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="admin-pagination">
                <span>Mostrando @CurrentPageStart - @CurrentPageEnd de @CurrentTotalRecords registros</span>
                <div class="admin-pagination-actions">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaAnterior" disabled="@(currentPage <= 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <strong>@currentPage / @CurrentTotalPages</strong>
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaSiguiente" disabled="@(currentPage >= CurrentTotalPages)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </section>
</div>

@if (showModal)
{
    <div class="admin-modal-backdrop"></div>
    <div class="admin-modal" role="dialog" aria-modal="true" aria-labelledby="formaPagoModalTitle">
        <div class="admin-modal-content">
            <header class="admin-modal-header @(isReadOnly ? "is-readonly" : "is-editable")">
                <div>
                    <span class="admin-kicker">Forma de pago</span>
                    <h3 id="formaPagoModalTitle">@(isReadOnly ? "Vista de detalle" : (EsNuevoRegistro ? "Nueva forma de pago" : "Editar forma de pago"))</h3>
                </div>
                <button type="button" class="admin-modal-close" @onclick="CerrarModal" disabled="@isSaving" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="admin-modal-body">
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="admin-alert">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                        <span>@errorMessage</span>
                    </div>
                }

                <div class="admin-form-grid">
                    <label class="admin-field admin-field-short">
                        <span>Codigo</span>
                        <input type="text"
                               value="@temp.Codigo"
                               @oninput="OnCodigoChanged"
                               class="@GetInputClass(nameof(temp.Codigo))"
                               readonly="@isReadOnly"
                               maxlength="2" />
                        @if (errors.ContainsKey(nameof(temp.Codigo)))
                        {
                            <small>@errors[nameof(temp.Codigo)]</small>
                        }
                    </label>

                    <label class="admin-field">
                        <span>Descripcion</span>
                        <input type="text"
                               value="@temp.Descripcion"
                               @oninput="OnDescripcionChanged"
                               class="@GetInputClass(nameof(temp.Descripcion))"
                               readonly="@isReadOnly"
                               maxlength="150" />
                        @if (errors.ContainsKey(nameof(temp.Descripcion)))
                        {
                            <small>@errors[nameof(temp.Descripcion)]</small>
                        }
                    </label>

                    <label class="admin-field admin-field-full">
                        <span>Descripcion SRI</span>
                        <input type="text"
                               value="@temp.DescripcionSri"
                               @oninput="OnDescripcionSriChanged"
                               class="@GetInputClass(nameof(temp.DescripcionSri))"
                               readonly="@isReadOnly"
                               maxlength="150" />
                        @if (errors.ContainsKey(nameof(temp.DescripcionSri)))
                        {
                            <small>@errors[nameof(temp.DescripcionSri)]</small>
                        }
                    </label>

                    <div class="admin-switch">
                        <input id="tipoVenta" type="checkbox" checked="@(temp.TipoVenta == true)" @onchange="OnTipoVentaChanged" disabled="@isReadOnly" />
                        <label for="tipoVenta">Aplica para ventas</label>
                    </div>

                    <div class="admin-switch">
                        <input id="tipoCompra" type="checkbox" checked="@(temp.TipoCompra == true)" @onchange="OnTipoCompraChanged" disabled="@isReadOnly" />
                        <label for="tipoCompra">Aplica para compras</label>
                    </div>

                    @if (errors.ContainsKey("TipoUso"))
                    {
                        <small class="admin-form-error admin-field-full">@errors["TipoUso"]</small>
                    }
                </div>
            </div>

            <footer class="admin-modal-footer">
                <button type="button" class="secondary-btn" @onclick="CerrarModal" disabled="@isSaving">Cerrar</button>
                @if (!isReadOnly)
                {
                    <button type="button" class="primary-btn" @onclick="Guardar" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span>Procesando...</span>
                        }
                        else
                        {
                            <i class="bi bi-save"></i>
                            <span>@(EsNuevoRegistro ? "Crear registro" : "Guardar cambios")</span>
                        }
                    </button>
                }
            </footer>
        </div>
    </div>
}

@code {
    private const string PageBrandTitle = "Numerica E-Contax";
    private List<Simetric.Models.FormasPago> formasPago = new();
    private Simetric.Models.FormasPago temp = new();
    private readonly Dictionary<string, string> errors = new();
    private bool isLoading = true;
    private bool showModal;
    private bool isReadOnly;
    private bool isSaving;
    private string? pageErrorMessage;
    private string? errorMessage;
    private string searchTerm = string.Empty;
    private string filtroUso = "todos";
    private int pageSize = 10;
    private int currentPage = 1;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!await ValidarAccesoEContaxAsync(authState.User))
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await CargarDatos();
        await InvokeAsync(StateHasChanged);
    }

    private string SearchTerm
    {
        get => searchTerm;
        set
        {
            searchTerm = value;
            currentPage = 1;
        }
    }

    private string FiltroUso
    {
        get => filtroUso;
        set
        {
            filtroUso = value;
            currentPage = 1;
        }
    }

    private int PageSize
    {
        get => pageSize;
        set
        {
            pageSize = value;
            currentPage = 1;
            AjustarPaginaActual();
        }
    }

    private bool EsNuevoRegistro => temp.Id == 0;

    private IEnumerable<Simetric.Models.FormasPago> PagosFiltrados
    {
        get
        {
            var query = formasPago.AsEnumerable();

            query = FiltroUso switch
            {
                "venta" => query.Where(item => item.TipoVenta == true),
                "compra" => query.Where(item => item.TipoCompra == true),
                _ => query
            };

            if (string.IsNullOrWhiteSpace(SearchTerm))
            {
                return query;
            }

            var filtro = SearchTerm.Trim();
            return query.Where(item =>
                (item.Codigo ?? string.Empty).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (item.Descripcion ?? string.Empty).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (item.DescripcionSri ?? string.Empty).Contains(filtro, StringComparison.OrdinalIgnoreCase));
        }
    }

    private IEnumerable<Simetric.Models.FormasPago> PagosPaginados =>
        PagosFiltrados
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize);

    private int CurrentTotalRecords => PagosFiltrados.Count();
    private int CurrentTotalPages => Math.Max(1, (int)Math.Ceiling(CurrentTotalRecords / (double)PageSize));
    private int CurrentPageStart => CurrentTotalRecords == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int CurrentPageEnd => CurrentTotalRecords == 0 ? 0 : Math.Min(CurrentTotalRecords, currentPage * PageSize);

    private async Task CargarDatos()
    {
        isLoading = true;
        pageErrorMessage = null;

        try
        {
            formasPago = await AdministracionService.GetFormasPagoActivasAsync();
            AjustarPaginaActual();
        }
        catch (Exception ex)
        {
            formasPago = new List<Simetric.Models.FormasPago>();
            pageErrorMessage = $"Error al cargar formas de pago: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AbrirModalNueva() => AbrirModal();

    private void AbrirModal(Simetric.Models.FormasPago? item = null)
    {
        isReadOnly = false;
        isSaving = false;
        errorMessage = null;
        errors.Clear();

        temp = item is null
            ? new Simetric.Models.FormasPago { Estado = true, TipoVenta = true, TipoCompra = false }
            : new Simetric.Models.FormasPago
            {
                Id = item.Id,
                Codigo = item.Codigo,
                Descripcion = item.Descripcion,
                DescripcionSri = item.DescripcionSri,
                TipoVenta = item.TipoVenta,
                TipoCompra = item.TipoCompra,
                Estado = item.Estado
            };

        showModal = true;
    }

    private async Task VerDetalle(int id)
    {
        var item = await AdministracionService.GetFormaPagoAsync(id);
        if (item is null)
        {
            await MostrarAlertaAsync("Registro no disponible", "No fue posible cargar la forma de pago seleccionada.", "warning");
            return;
        }

        AbrirModal(item);
        isReadOnly = true;
    }

    private void CerrarModal()
    {
        if (isSaving)
        {
            return;
        }

        showModal = false;
        isReadOnly = false;
        errorMessage = null;
        errors.Clear();
    }

    private void OnCodigoChanged(ChangeEventArgs e)
    {
        var valor = new string((e.Value?.ToString() ?? string.Empty).Where(char.IsDigit).Take(2).ToArray());
        temp.Codigo = valor;
        ValidarCodigo();
    }

    private void OnDescripcionChanged(ChangeEventArgs e)
    {
        temp.Descripcion = LimitarTexto(e.Value?.ToString(), 150);
        ValidarDescripcion();
    }

    private void OnDescripcionSriChanged(ChangeEventArgs e)
    {
        temp.DescripcionSri = LimitarTexto(e.Value?.ToString(), 150);
        ValidarDescripcionSri();
    }

    private void OnTipoVentaChanged(ChangeEventArgs e)
    {
        temp.TipoVenta = ParseCheckboxValue(e.Value);
        ValidarTipoUso();
    }

    private void OnTipoCompraChanged(ChangeEventArgs e)
    {
        temp.TipoCompra = ParseCheckboxValue(e.Value);
        ValidarTipoUso();
    }

    private string GetInputClass(string field) =>
        errors.ContainsKey(field) ? "admin-input input-error" : "admin-input";

    private bool ValidarFormulario()
    {
        errors.Clear();
        ValidarCodigo();
        ValidarDescripcion();
        ValidarDescripcionSri();
        ValidarTipoUso();
        return errors.Count == 0;
    }

    private void ValidarCodigo()
    {
        errors.Remove(nameof(temp.Codigo));
        var codigo = (temp.Codigo ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(codigo))
        {
            errors[nameof(temp.Codigo)] = "El codigo es obligatorio.";
        }
        else if (!codigo.All(char.IsDigit))
        {
            errors[nameof(temp.Codigo)] = "El codigo solo permite numeros.";
        }
        else if (formasPago.Any(item => item.Id != temp.Id && string.Equals(item.Codigo, codigo, StringComparison.OrdinalIgnoreCase)))
        {
            errors[nameof(temp.Codigo)] = "Ya existe una forma de pago con ese codigo.";
        }
    }

    private void ValidarDescripcion()
    {
        errors.Remove(nameof(temp.Descripcion));
        var descripcion = (temp.Descripcion ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(descripcion))
        {
            errors[nameof(temp.Descripcion)] = "La descripcion es obligatoria.";
        }
    }

    private void ValidarDescripcionSri()
    {
        errors.Remove(nameof(temp.DescripcionSri));
        var descripcion = (temp.DescripcionSri ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(descripcion))
        {
            errors[nameof(temp.DescripcionSri)] = "La descripcion SRI es obligatoria.";
        }
    }

    private void ValidarTipoUso()
    {
        errors.Remove("TipoUso");

        if (temp.TipoVenta != true && temp.TipoCompra != true)
        {
            errors["TipoUso"] = "Debes marcar venta o compra.";
        }
    }

    private async Task Guardar()
    {
        if (isSaving)
        {
            return;
        }

        errorMessage = null;
        temp.Codigo = (temp.Codigo ?? string.Empty).Trim();
        temp.Descripcion = (temp.Descripcion ?? string.Empty).Trim();
        temp.DescripcionSri = (temp.DescripcionSri ?? string.Empty).Trim();

        if (!ValidarFormulario())
        {
            errorMessage = "Corrige los campos marcados antes de guardar.";
            return;
        }

        isSaving = true;
        try
        {
            var exito = await AdministracionService.GuardarFormaPagoAsync(temp);
            if (!exito)
            {
                errorMessage = "No se pudo guardar. Verifica si el codigo o la descripcion ya existen.";
                return;
            }

            CerrarModal();
            await CargarDatos();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmarEliminar(Simetric.Models.FormasPago item)
    {
        var confirmado = await ConfirmarAsync(
            "Dar de baja forma de pago",
            $"Se desactivara {item.Codigo} - {item.Descripcion}.");

        if (!confirmado)
        {
            return;
        }

        var eliminado = await AdministracionService.DesactivarFormaPagoAsync(item.Id);
        if (!eliminado)
        {
            await MostrarAlertaAsync("No se pudo eliminar", "Intenta nuevamente en unos segundos.", "error");
            return;
        }

        await CargarDatos();
        await MostrarAlertaAsync("Registro eliminado", "La forma de pago fue dada de baja correctamente.", "success");
    }

    private void PaginaAnterior()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void PaginaSiguiente()
    {
        if (currentPage < CurrentTotalPages)
        {
            currentPage++;
        }
    }

    private void AjustarPaginaActual()
    {
        currentPage = Math.Min(Math.Max(1, currentPage), CurrentTotalPages);
    }

    private async Task<bool> ConfirmarAsync(string titulo, string mensaje)
    {
        var resultado = await JS.InvokeAsync<JsonElement>("Swal.fire", new
        {
            icon = "warning",
            title = titulo,
            text = mensaje,
            showCancelButton = true,
            confirmButtonText = "Si, eliminar",
            cancelButtonText = "Cancelar",
            reverseButtons = true,
            focusCancel = true,
            confirmButtonColor = "#c23b4b",
            cancelButtonColor = "#7a8da2"
        });

        return resultado.TryGetProperty("isConfirmed", out var confirmacion) && confirmacion.GetBoolean();
    }

    private async Task MostrarAlertaAsync(string titulo, string mensaje, string icono)
    {
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = icono,
            title = titulo,
            text = mensaje,
            confirmButtonText = "Aceptar",
            timer = icono == "success" ? 1800 : (int?)null,
            showConfirmButton = icono != "success"
        });
    }

    private async Task<bool> ValidarAccesoEContaxAsync(ClaimsPrincipal user)
    {
        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var userId = ObtenerIdUsuario(user);
        if (userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private static bool ParseCheckboxValue(object? value) =>
        value is bool boolValue
            ? boolValue
            : value is string text && bool.TryParse(text, out var parsed) && parsed;

    private static string LimitarTexto(string? valor, int maxLength)
    {
        var texto = valor ?? string.Empty;
        return texto.Length > maxLength ? texto[..maxLength] : texto;
    }
}
