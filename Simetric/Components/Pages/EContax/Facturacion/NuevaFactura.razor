    private bool EsEmpresaPorTipoCliente()
    {
        if (cliente.TipoCliente == null)
            return false;

        var descripcion = tiposCliente.FirstOrDefault(x => x.TclCodigo == cliente.TipoCliente.Value)?.TclDescripcion ?? string.Empty;
        return EsTipoClienteJuridico(descripcion);
    }

    private bool EsPersonaPorTipoCliente()
    {
        if (cliente.TipoCliente == null)
            return false;

        var descripcion = tiposCliente.FirstOrDefault(x => x.TclCodigo == cliente.TipoCliente.Value)?.TclDescripcion ?? string.Empty;
        return EsTipoClienteNatural(descripcion);
    }

    private static string GetTipoClienteEtiqueta(string? descripcion)
        => string.IsNullOrWhiteSpace(descripcion)
            ? "-- Seleccione --"
            : TipoClienteClasificacion.ObtenerEtiqueta(descripcion);

    private static bool EsTipoClienteJuridico(string? descripcion) =>
        TipoClienteClasificacion.EsJuridica(descripcion);

    private static bool EsTipoClienteNatural(string? descripcion) =>
        TipoClienteClasificacion.EsNatural(descripcion);

    private int ContarPalabras(string? texto)
        => string.IsNullOrWhiteSpace(texto)
            ? 0
            : texto.Split(new[] { ' ', '\r', '\n', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;

    private string InferirTipoIdentificacion(string numero)
    {
        numero = (numero ?? string.Empty).Trim();
        if (numero.Length == 13)
            return identificaciones.FirstOrDefault(x => x.IdeCodigo == "04")?.IdeCodigo ?? "04";

        return identificaciones.FirstOrDefault(x => x.IdeCodigo == "05")?.IdeCodigo ?? "05";
    }

    private async Task BuscarYAplicarClienteExternoAsync(string? valor)
    {
        var identificacion = new string((valor ?? string.Empty).Where(char.IsDigit).ToArray());
        if (identificacion.Length is not (10 or 13))
            return;

        if (cliente.Codcliente > 0 &&
            string.Equals((cliente.Numeroidentificacion ?? string.Empty).Trim(), identificacion, StringComparison.Ordinal))
        {
            return;
        }

        var clienteLocal = await EContaxFacturacionService.GetClienteByIdentificacionAsync(currentUserId, identificacion);
        if (clienteLocal is not null)
        {
            await SeleccionarClienteAsync(clienteLocal);
            return;
        }

        var lookup = await CedulaLookupService.ConsultarAsync(identificacion);
        if (!lookup.Success || !lookup.Found)
            return;

        var clienteExterno = CrearClienteDesdeLookup(lookup, identificacion);
        var clientePersistido = await EContaxFacturacionService.UpsertClienteAsync(currentUserId, clienteExterno);
        await SeleccionarClienteAsync(clientePersistido);
    }

    private Cliente CrearClienteDesdeLookup(CedulaLookupResult lookup, string identificacion)
    {
        var clienteLookup = new Cliente
        {
            Numeroidentificacion = identificacion,
            Tipoidentificacion = InferirTipoIdentificacion(identificacion),
            Oblgconta = NormalizarObligadoContabilidad(lookup.ObligadoLlevarContabilidad),
            Estado = true,
            Usuario = currentUserId
        };

        if (string.Equals(lookup.Tipo, "ruc", StringComparison.OrdinalIgnoreCase))
        {
            var esNatural = (lookup.TipoContribuyente ?? string.Empty)
                .Contains("NATURAL", StringComparison.OrdinalIgnoreCase);

            clienteLookup.TipoCliente = ObtenerTipoClienteDesdeClasificacion(esNatural);

            if (esNatural)
            {
                var (apellidos, nombres) = SepararNombreCompleto(lookup.NombreCompleto);
                clienteLookup.Apellidos = apellidos;
                clienteLookup.Nombres = nombres;
            }
            else
            {
                var razonSocial = lookup.RazonSocial?.Trim() ?? lookup.NombreCompleto?.Trim();
                clienteLookup.Nombrerazonsocial = razonSocial;
                clienteLookup.Nombrecomercial = razonSocial;
            }

            return clienteLookup;
        }

        clienteLookup.TipoCliente = ObtenerTipoClienteDesdeClasificacion(true);
        var (apellidosCedula, nombresCedula) = SepararNombreCompleto(lookup.NombreCompleto);
        clienteLookup.Apellidos = apellidosCedula;
        clienteLookup.Nombres = nombresCedula;
        return clienteLookup;
    }

    private int? ObtenerTipoClienteDesdeClasificacion(bool esNatural)
    {
        return tiposCliente.FirstOrDefault(x =>
            esNatural
                ? EsTipoClienteNatural(x.TclDescripcion)
                : EsTipoClienteJuridico(x.TclDescripcion))?.TclCodigo;
    }

    private static (string? Apellidos, string? Nombres) SepararNombreCompleto(string? nombreCompleto)
    {
        var partes = (nombreCompleto ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (partes.Length == 2)
            return (partes[0], partes[1]);

        if (partes.Length == 3)
            return (string.Join(" ", partes.Take(2)), partes[2]);

        if (partes.Length >= 4)
            return (string.Join(" ", partes.Take(2)), string.Join(" ", partes.Skip(2)));

        if (partes.Length == 1)
            return (partes[0], null);

        return (null, null);
    }

    private static string NormalizarObligadoContabilidad(string? valor)
    {
        var normalizado = (valor ?? string.Empty).Trim().ToUpperInvariant();
        return normalizado is "SI" or "NO" ? normalizado : "NO";
    }

    private void SincronizarNombres()
    {
        var nombreCompleto = $"{cliente.Nombres} {cliente.Apellidos}".Trim();
        if (string.IsNullOrWhiteSpace(nombreCompleto))
            return;

        textoBusquedaCliente = nombreCompleto;
    }

    private void OnTipoClienteFacturaChanged()
    {
        if (EsEmpresaPorTipoCliente())
        {
            cliente.Nombres = null;
            cliente.Apellidos = null;
        }
        else
        {
            cliente.Nombrecomercial = null;
            cliente.Nombrerazonsocial = null;
            SincronizarNombres();
        }
    }

    private string ObtenerNombreClienteVisual(Cliente? clienteActual, string? fallback = null)
    {
        if (clienteActual is null)
            return string.IsNullOrWhiteSpace(fallback) ? "Cliente seleccionado" : fallback.Trim();

        var nombrePersona = $"{clienteActual.Nombres} {clienteActual.Apellidos}".Trim();
        var esJuridica = clienteActual.TipoCliente.HasValue &&
            tiposCliente.Any(x =>
                x.TclCodigo == clienteActual.TipoCliente.Value &&
                TipoClienteClasificacion.EsJuridica(x.TclDescripcion));

        if (!esJuridica && !string.IsNullOrWhiteSpace(nombrePersona))
            return nombrePersona;

        if (!string.IsNullOrWhiteSpace(clienteActual.Nombrerazonsocial))
            return clienteActual.Nombrerazonsocial.Trim();

        if (!string.IsNullOrWhiteSpace(clienteActual.Nombrecomercial))
            return clienteActual.Nombrecomercial.Trim();

        if (!string.IsNullOrWhiteSpace(nombrePersona))
            return nombrePersona;

        if (!string.IsNullOrWhiteSpace(clienteActual.Numeroidentificacion))
            return $"Cliente {clienteActual.Numeroidentificacion.Trim()}";

        return string.IsNullOrWhiteSpace(fallback) ? "Cliente seleccionado" : fallback.Trim();
    }

