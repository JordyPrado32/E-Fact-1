    private static string FormatearSerie(string? serie)
    {
        var digits = new string((serie ?? string.Empty).Where(char.IsDigit).ToArray());
        if (digits.Length >= 6)
            return $"{digits[..3]}-{digits.Substring(3, 3)}";

        return "001-001";
    }

    private static string GetEmisorNombre(Emisor emisor)
    {
        var nombre = string.IsNullOrWhiteSpace(emisor.NomComercial)
            ? emisor.RazonSocial
            : emisor.NomComercial;

        return $"{nombre} - {emisor.Ruc}".Trim(' ', '-');
    }

