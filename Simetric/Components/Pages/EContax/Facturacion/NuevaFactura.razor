    private sealed class EContaxFacturaLinea
    {
        private decimal cantidad = 1m;
        private decimal precio;
        private decimal porcentajeDescuento;
        private int tarifa = 15;

        public int Codproducto { get; init; }
        public string? Codprincipal { get; init; }
        public string? Codauxiliar { get; init; }
        public string? Descripcion { get; init; }

        public decimal Cantidad
        {
            get => cantidad;
            set => cantidad = value <= 0m ? 1m : value;
        }

        public decimal Precio
        {
            get => precio;
            set => precio = Math.Max(0m, value);
        }

        public decimal PorcentajeDescuento
        {
            get => porcentajeDescuento;
            set => porcentajeDescuento = Math.Clamp(value, 0m, 100m);
        }

        public int Tarifa
        {
            get => tarifa;
            set => tarifa = Math.Max(0, value);
        }

        public decimal SubtotalBruto => Math.Round(Cantidad * Precio, 2);
        public decimal Descuento => Math.Round(SubtotalBruto * (PorcentajeDescuento / 100m), 2);
        public decimal BaseImponible => Math.Round(Math.Max(0m, SubtotalBruto - Descuento), 2);
        public decimal Iva => Math.Round(BaseImponible * (Tarifa / 100m), 2);
        public decimal Total => Math.Round(BaseImponible + Iva, 2);

        public decimal GetIvaConDescuentoGlobal(decimal porcentajeGlobal)
        {
            var pct = Math.Clamp(porcentajeGlobal, 0m, 100m) / 100m;
            var baseConGlobal = Math.Round(BaseImponible * (1m - pct), 2);
            return Math.Round(baseConGlobal * (Tarifa / 100m), 2);
        }
    }

