@page "/e-contax/soporte"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Simetric.Services
@using Simetric.Services.EContax
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@rendermode InteractiveServer

<PageTitle>Soporte | Numerica E-Contax</PageTitle>

<div class="support-shell">
    @if (isLoading)
    {
        <section class="support-state">
            <div class="support-state-icon">
                <span class="spinner-border" role="status"></span>
            </div>
            <h3>Cargando soporte</h3>
            <p>Preparando las preguntas frecuentes de E-Contax.</p>
        </section>
    }
    else
    {
        <section class="support-hero">
            <div class="hero-copy">
                <span class="hero-eyebrow">Centro de ayuda</span>
                <h2>Soporte E-Contax</h2>
                <p>
                    Encuentra respuestas concretas sobre catalogos, retenciones,
                    auditoria SQL y configuracion del modulo contable.
                </p>
            </div>

            <div class="hero-summary">
                <article class="summary-card summary-card-primary">
                    <span class="summary-label">Horario</span>
                    <strong>09:00</strong>
                    <small>Lunes a viernes hasta las 18:00.</small>
                </article>

                <article class="summary-card">
                    <span class="summary-label">Canales</span>
                    <strong>2</strong>
                    <small>WhatsApp y correo electronico.</small>
                </article>

                <article class="summary-card">
                    <span class="summary-label">Guias</span>
                    <strong>@faqs.Count</strong>
                    <small>Preguntas frecuentes disponibles.</small>
                </article>
            </div>
        </section>

        <section class="toolbar-card">
            <div class="toolbar-copy">
                <span class="toolbar-kicker">Atencion</span>
                <h3>Canales de soporte</h3>
                <p>Ten a mano RUC, usuario, pantalla, emisor y captura del inconveniente.</p>
            </div>

            <div class="support-actions">
                <button type="button" class="primary-btn whatsapp-btn" @onclick="IrAWhatsApp">
                    <i class="bi bi-whatsapp"></i>
                    <span>WhatsApp</span>
                </button>
                <a href="mailto:soporte@numericasoftware.com" class="secondary-btn">
                    <i class="bi bi-envelope"></i>
                    <span>Correo electronico</span>
                </a>
            </div>
        </section>

        <section class="support-grid">
            <section class="table-card">
                <div class="table-card-head">
                    <div>
                        <span class="table-kicker">Preguntas frecuentes</span>
                        <h3>Respuestas rapidas</h3>
                    </div>
                    <span class="table-badge">@faqs.Count temas</span>
                </div>

                <div class="faq-list">
                    @foreach (var item in faqs)
                    {
                        var isActive = active == item.Id;
                        <article class="faq-item @(isActive ? "is-active" : string.Empty)">
                            <button type="button"
                                    class="faq-button"
                                    aria-expanded="@isActive"
                                    @onclick="() => Toggle(item.Id)">
                                <span class="faq-icon">
                                    <i class="@item.Icon"></i>
                                </span>
                                <span class="faq-question">@item.Pregunta</span>
                                <i class="bi @(isActive ? "bi-chevron-up" : "bi-chevron-down") faq-toggle"></i>
                            </button>

                            @if (isActive)
                            {
                                <div class="faq-answer">@item.Respuesta</div>
                            }
                        </article>
                    }
                </div>
            </section>

            <aside class="editor-card support-side-card">
                <div class="editor-head">
                    <div>
                        <span class="panel-kicker">Antes de escribir</span>
                        <h3>Datos utiles</h3>
                        <p>Con esta informacion soporte puede revisar tu caso con mayor rapidez.</p>
                    </div>
                </div>

                <div class="support-checklist">
                    <div class="support-check-item">
                        <i class="bi bi-building-check"></i>
                        <span>RUC, emisor, usuario y nombre de la empresa.</span>
                    </div>
                    <div class="support-check-item">
                        <i class="bi bi-window"></i>
                        <span>Pantalla de E-Contax donde aparece el problema.</span>
                    </div>
                    <div class="support-check-item">
                        <i class="bi bi-chat-left-text"></i>
                        <span>Mensaje exacto que muestra el sistema.</span>
                    </div>
                    <div class="support-check-item">
                        <i class="bi bi-clock-history"></i>
                        <span>Fecha, hora y accion que estabas realizando.</span>
                    </div>
                </div>
            </aside>
        </section>
    }
</div>

@code {
    private bool isLoading = true;
    private int active = 1;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (!await ValidarAccesoEContaxAsync(authState.User))
        {
            isLoading = false;
            return;
        }

        isLoading = false;
    }

    private void Toggle(int id)
    {
        active = active == id ? 0 : id;
    }

    private readonly List<FaqItem> faqs = new()
    {
        new()
        {
            Id = 1,
            Icon = "bi bi-sliders",
            Pregunta = "Donde configuro formas de pago, identificaciones, impuestos y retenciones?",
            Respuesta = "En E-Contax estos catalogos estan dentro de Administracion. Cada opcion trabaja con rutas /e-contax y mantiene su logica separada de E-Fact."
        },
        new()
        {
            Id = 2,
            Icon = "bi bi-percent",
            Pregunta = "Por que una retencion no aparece en mis procesos contables?",
            Respuesta = "Verifica que el codigo exista en Retenciones, que el tipo corresponda a IVA, ISD o Renta y que los datos se hayan guardado sin errores."
        },
        new()
        {
            Id = 3,
            Icon = "bi bi-database-check",
            Pregunta = "Para que sirve la auditoria SQL?",
            Respuesta = "Sirve para revisar cambios registrados en base de datos con fecha, usuario, accion, entidad, ruta y valores JSON cuando el evento los registra."
        },
        new()
        {
            Id = 4,
            Icon = "bi bi-person-lock",
            Pregunta = "Que hago si un usuario no puede entrar a E-Contax?",
            Respuesta = "Confirma que tenga acceso activo al servicio E-Contax, que su sesion sea valida y que este entrando desde rutas que empiezan con /e-contax."
        },
        new()
        {
            Id = 5,
            Icon = "bi bi-building",
            Pregunta = "Como confirmo que estoy trabajando en E-Contax y no en E-Fact?",
            Respuesta = "Las pantallas de E-Contax usan el menu verde, el encabezado del servicio activo y rutas que empiezan con /e-contax."
        },
        new()
        {
            Id = 6,
            Icon = "bi bi-person-gear",
            Pregunta = "Donde actualizo mi perfil de E-Contax?",
            Respuesta = "El perfil esta dentro del menu Configuracion de E-Contax. Desde ahi puedes revisar tus datos de cuenta y avatar."
        },
        new()
        {
            Id = 7,
            Icon = "bi bi-search",
            Pregunta = "Como encuentro rapido un registro en E-Contax?",
            Respuesta = "Usa las barras de busqueda y filtros de cada pantalla. En administracion puedes filtrar catalogos por codigo, descripcion o estado segun la vista."
        },
        new()
        {
            Id = 8,
            Icon = "bi bi-headset",
            Pregunta = "Que informacion debo enviar para recibir ayuda mas rapido?",
            Respuesta = "Envia RUC, usuario, emisor, pantalla, accion realizada, fecha aproximada, mensaje exacto y captura completa del problema."
        }
    };

    private async Task<bool> ValidarAccesoEContaxAsync(ClaimsPrincipal user)
    {
        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var userId = ObtenerIdUsuario(user);
        if (userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private void IrAWhatsApp()
    {
        var numero = "593995876753";
        var mensaje = Uri.EscapeDataString("Hola, necesito soporte en E-Contax.");
        NavManager.NavigateTo($"https://wa.me/{numero}?text={mensaje}", true);
    }

    private sealed class FaqItem
    {
        public int Id { get; set; }
        public string Icon { get; set; } = string.Empty;
        public string Pregunta { get; set; } = string.Empty;
        public string Respuesta { get; set; } = string.Empty;
    }
}
