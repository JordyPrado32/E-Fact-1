    private void CerrarModal()
    {
        if (isSaving)
        {
            return;
        }

        LimpiarModal();
    }

    private void LimpiarModal()
    {
        showModal = false;
        isReadOnly = false;
        isEdit = false;
        isSaving = false;
        errorMessage = null;
        tmpIva = new();
        tmpIsd = new();
        tmpRenta = new() { Estado = true };
    }

    private async Task Guardar()
    {
        if (isSaving || isReadOnly)
        {
            return;
        }

        errorMessage = null;
        NormalizarFormularioActual();

        var validacion = ValidarFormularioActual();
        if (!string.IsNullOrWhiteSpace(validacion))
        {
            errorMessage = validacion;
            return;
        }

        isSaving = true;
        try
        {
            if (tab == "iva")
            {
                await AdministracionService.GuardarRetencionIvaAsync(tmpIva, isEdit);
            }
            else if (tab == "isd")
            {
                await AdministracionService.GuardarRetencionIsdAsync(tmpIsd, isEdit);
            }
            else
            {
                await AdministracionService.GuardarRetencionRentaAsync(tmpRenta, isEdit);
            }

            LimpiarModal();
            await CargarDatos();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void NormalizarFormularioActual()
    {
        if (tab == "iva")
        {
            tmpIva.Descripcion = (tmpIva.Descripcion ?? string.Empty).Trim();
            return;
        }

        if (tab == "isd")
        {
            tmpIsd.Descripcion = (tmpIsd.Descripcion ?? string.Empty).Trim();
            return;
        }

        tmpRenta.Codigo = (tmpRenta.Codigo ?? string.Empty).Trim();
        tmpRenta.Descripcion = (tmpRenta.Descripcion ?? string.Empty).Trim();
        tmpRenta.CodigoFormulario103 = (tmpRenta.CodigoFormulario103 ?? string.Empty).Trim();
        tmpRenta.InformacionExtra = (tmpRenta.InformacionExtra ?? string.Empty).Trim();
        tmpRenta.Estado ??= true;
    }

    private string? ValidarFormularioActual() => tab switch
    {
        "iva" => ValidarIva(),
        "isd" => ValidarIsd(),
        _ => ValidarRenta()
    };

    private string? ValidarIva()
    {
        if (tmpIva.Codigo <= 0)
        {
            return "El codigo de IVA debe ser mayor a cero.";
        }

        if (string.IsNullOrWhiteSpace(tmpIva.Descripcion) || tmpIva.Descripcion.Length < 3)
        {
            return "La descripcion de IVA debe tener al menos 3 caracteres.";
        }

        if (tmpIva.Valor is null || tmpIva.Valor < 0m || tmpIva.Valor > 100m)
        {
            return "El valor de IVA debe estar entre 0 y 100.";
        }

        if (!isEdit && ivaList.Any(item => item.Codigo == tmpIva.Codigo))
        {
            return "Ya existe una retencion IVA con ese codigo.";
        }

        return null;
    }

    private string? ValidarIsd()
    {
        if (tmpIsd.Codigo <= 0)
        {
            return "El codigo de ISD debe ser mayor a cero.";
        }

        if (string.IsNullOrWhiteSpace(tmpIsd.Descripcion) || tmpIsd.Descripcion.Length < 3)
        {
            return "La descripcion de ISD debe tener al menos 3 caracteres.";
        }

        if (tmpIsd.Valor is null || tmpIsd.Valor < 0m || tmpIsd.Valor > 100m)
        {
            return "El valor de ISD debe estar entre 0 y 100.";
        }

        if (!isEdit && isdList.Any(item => item.Codigo == tmpIsd.Codigo))
        {
            return "Ya existe una retencion ISD con ese codigo.";
        }

        return null;
    }

    private string? ValidarRenta()
    {
        if (string.IsNullOrWhiteSpace(tmpRenta.Codigo))
        {
            return "El codigo de renta es obligatorio.";
        }

        if (!tmpRenta.Codigo.All(char.IsDigit))
        {
            return "El codigo de renta solo permite numeros.";
        }

        if (string.IsNullOrWhiteSpace(tmpRenta.Descripcion) || tmpRenta.Descripcion.Length < 3)
        {
            return "La descripcion de renta debe tener al menos 3 caracteres.";
        }

        if (tmpRenta.Valor is null || tmpRenta.Valor < 0m || tmpRenta.Valor > 100m)
        {
            return "El valor de renta debe estar entre 0 y 100.";
        }

        if (tmpRenta.ValorFinal is null || tmpRenta.ValorFinal < 0m || tmpRenta.ValorFinal > 100m)
        {
            return "El valor final debe estar entre 0 y 100.";
        }

        if (!string.IsNullOrWhiteSpace(tmpRenta.CodigoFormulario103) && !tmpRenta.CodigoFormulario103.All(char.IsLetterOrDigit))
        {
            return "El codigo F103 solo puede contener letras y numeros.";
        }

        if (!isEdit && rentaList.Any(item =>
                string.Equals((item.Codigo ?? string.Empty).Trim(), tmpRenta.Codigo, StringComparison.OrdinalIgnoreCase)))
        {
            return "Ya existe una retencion de renta con ese codigo.";
        }

        return null;
    }

