@page "/e-contax/administracion/retenciones"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Simetric.Components
@using Simetric.Models
@using Simetric.Services
@using Simetric.Services.EContax
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject EContaxAdministracionService AdministracionService
@rendermode InteractiveServer

<PageTitle>Retenciones | Numerica E-Contax</PageTitle>

<div class="ret-shell ret-shell-econtax" data-tour="econtax.retenciones.page">
    <section class="ret-hero" data-tour="retenciones.hero">
        <div>
            <span class="table-kicker">Panel fiscal</span>
            <h2>Retenciones</h2>
            <p>Filtra por codigo o descripcion y administra IVA, ISD y renta desde una sola vista.</p>
        </div>
    </section>

    <section class="tabs-shell" aria-label="Tipos de retencion" data-tour="retenciones.tabs">
        <button type="button"
                class="tab-pill @(tab == "iva" ? "is-active" : string.Empty)"
                @onclick='() => CambiarTab("iva")'>
            <i class="bi bi-percent"></i>
            <span>IVA</span>
        </button>

        <button type="button"
                class="tab-pill @(tab == "isd" ? "is-active" : string.Empty)"
                @onclick='() => CambiarTab("isd")'>
            <i class="bi bi-globe-americas"></i>
            <span>ISD</span>
        </button>

        <button type="button"
                class="tab-pill @(tab == "renta" ? "is-active" : string.Empty)"
                @onclick='() => CambiarTab("renta")'>
            <i class="bi bi-bank"></i>
            <span>Renta</span>
        </button>
    </section>

    <section class="table-card" data-tour="retenciones.table">
        <div class="table-card-head">
            <div>
                <span class="table-kicker">Busqueda y control</span>
                <h3>@CurrentTabHeader</h3>
                <p>@CurrentTabDescription</p>
            </div>

            <button class="primary-btn ret-primary-btn" @onclick="AbrirModalActual">
                <i class="bi bi-plus-circle"></i>
                <span>Nueva</span>
            </button>
        </div>

        <div class="ret-toolbar" data-tour="retenciones.toolbar">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>

                <input type="search"
                       class="search-input"
                       placeholder="Buscar por codigo o descripcion"
                       @bind="CurrentSearchTerm"
                       @bind:event="oninput" />
            </div>

            @if (tab == "renta")
            {
                <div class="filter-box">
                    <label class="field-label field-label-compact" for="retencionesFiltro">Filtro</label>
                    <select id="retencionesFiltro" class="filter-select" @bind="CurrentFilterValue">
                        <option value="all">Todos</option>
                        <option value="active">Activos</option>
                        <option value="inactive">Inactivos</option>
                    </select>
                </div>
            }

            <select class="filter-select filter-select-small" @bind="CurrentPageSize">
                <option value="5">5 registros</option>
                <option value="10">10 registros</option>
                <option value="20">20 registros</option>
            </select>
        </div>

        @if (isLoading)
        {
            <div class="state-card">
                <div class="state-icon">
                    <span class="spinner-border text-primary" role="status"></span>
                </div>
                <h3>Cargando retenciones</h3>
                <p>Estamos consultando los catalogos configurados para IVA, ISD y renta.</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(pageErrorMessage))
        {
            <div class="state-card state-card-error">
                <div class="state-icon">
                    <i class="bi bi-exclamation-octagon"></i>
                </div>
                <h3>No pudimos cargar la informacion</h3>
                <p>@pageErrorMessage</p>
            </div>
        }
        else if (CurrentTotalRecords == 0)
        {
            <div class="state-card state-card-empty">
                <div class="state-icon">
                    <i class="bi bi-search"></i>
                </div>
                <h3>Sin resultados</h3>
                <p>@CurrentEmptyMessage</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                @if (tab == "iva")
                {
                    <table class="table table-hover align-middle mb-0 ret-table">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 180px;">Codigo</th>
                                <th>Descripcion</th>
                                <th class="text-center" style="width: 160px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in IvaPaginados)
                            {
                                <tr @key="item.Codigo">
                                    <td class="ps-4">
                                        <span class="code-pill">@item.Codigo</span>
                                    </td>
                                    <td>
                                        <div class="cell-main">
                                            <strong>@item.Descripcion</strong>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="action-group">
                                            <button class="action-btn action-view" @onclick="() => AbrirIva(item, true)" title="Ver detalle">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="action-btn action-edit" @onclick="() => AbrirIva(item)" title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="action-btn action-delete" @onclick="() => EliminarIva(item)" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (tab == "isd")
                {
                    <table class="table table-hover align-middle mb-0 ret-table">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 180px;">Codigo</th>
                                <th>Descripcion</th>
                                <th class="text-center" style="width: 160px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in IsdPaginados)
                            {
                                <tr @key="item.Codigo">
                                    <td class="ps-4">
                                        <span class="code-pill">@item.Codigo</span>
                                    </td>
                                    <td>
                                        <div class="cell-main">
                                            <strong>@item.Descripcion</strong>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="action-group">
                                            <button class="action-btn action-view" @onclick="() => AbrirIsd(item, true)" title="Ver detalle">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="action-btn action-edit" @onclick="() => AbrirIsd(item)" title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="action-btn action-delete" @onclick="() => EliminarIsd(item)" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <table class="table table-hover align-middle mb-0 ret-table ret-table-renta">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 180px;">Codigo</th>
                                <th>Descripcion</th>
                                <th style="width: 140px;">Valor</th>
                                <th style="width: 140px;">Estado</th>
                                <th class="text-center" style="width: 160px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in RentaPaginados)
                            {
                                <tr @key="item.Codigo">
                                    <td class="ps-4">
                                        <span class="code-pill">@item.Codigo</span>
                                    </td>
                                    <td>
                                        <div class="cell-main">
                                            <strong>@item.Descripcion</strong>
                                            @if (!string.IsNullOrWhiteSpace(item.InformacionExtra))
                                            {
                                                <span>@item.InformacionExtra</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="value-pill">@FormatDecimal(item.Valor)</span>
                                    </td>
                                    <td>
                                        <span class="state-pill @(item.Estado == true ? "state-active" : "state-inactive")">
                                            @(item.Estado == true ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="action-group">
                                            <button class="action-btn action-view" @onclick="() => AbrirRenta(item, true)" title="Ver detalle">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="action-btn action-edit" @onclick="() => AbrirRenta(item)" title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="action-btn action-delete" @onclick="() => EliminarRenta(item)" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="ret-pagination">
                <span class="ret-pagination-meta">
                    Mostrando @CurrentPageStart - @CurrentPageEnd de @CurrentTotalRecords registros
                </span>

                <div class="ret-pagination-actions">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaAnterior" disabled="@(CurrentPage <= 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="ret-page-indicator">Pagina @CurrentPage de @CurrentTotalPages</span>
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaSiguiente" disabled="@(CurrentPage >= CurrentTotalPages)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </section>
</div>

@if (showModal)
{
    <div class="ret-modal-backdrop"></div>
    <div class="modal fade show d-block ret-modal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered @(tab == "renta" ? "modal-lg" : "")">
            <div class="modal-content ret-modal-content animate__animated animate__zoomIn animate__faster">
                <div class="modal-header ret-modal-header @(isReadOnly ? "is-readonly" : "is-editable")">
                    <div class="ret-modal-copy">
                        <span class="modal-kicker">Catalogo fiscal</span>
                        <h5 class="modal-title fw-bold">@CurrentModalTitle</h5>
                        <p class="ret-modal-description">@CurrentModalDescription</p>
                    </div>
                    <button type="button"
                            class="ret-modal-close"
                            @onclick="CerrarModal"
                            disabled="@isSaving"
                            aria-label="Cerrar modal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="modal-body ret-modal-body">
                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-3 border-0 animate__animated animate__shakeX">
                            <i class="bi bi-exclamation-octagon-fill me-2 fs-5"></i>
                            <div>@errorMessage</div>
                        </div>
                    }

                    <div class="ret-modal-intro">
                        <div class="ret-modal-intro-copy">
                            <span class="ret-modal-badge">
                                <i class="bi @CurrentModalIcon"></i>
                                <span>@CurrentModalFamilyLabel</span>
                            </span>
                            <span class="ret-modal-badge ret-modal-badge-muted">
                                @(isReadOnly ? "Solo lectura" : isEdit ? "Edicion" : "Nuevo registro")
                            </span>
                            <p>@CurrentModalHelperText</p>
                        </div>
                    </div>

                    @if (tab == "iva")
                    {
                        <div class="row g-3 ret-form-grid">
                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Codigo</label>
                                    <input type="number"
                                           class="form-control field-input"
                                           @bind="tmpIva.Codigo"
                                           readonly="@(isReadOnly || isEdit)" />
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="ret-field-card">
                                    <label class="field-label">Descripcion</label>
                                    <input type="text"
                                           class="form-control field-input"
                                           @bind="tmpIva.Descripcion"
                                           readonly="@isReadOnly"
                                           maxlength="120" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Valor</label>
                                    <input type="number"
                                           class="form-control field-input"
                                           step="0.01"
                                           @bind="tmpIva.Valor"
                                           readonly="@isReadOnly" />
                                </div>
                            </div>
                        </div>
                    }
                    else if (tab == "isd")
                    {
                        <div class="row g-3 ret-form-grid">
                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Codigo</label>
                                    <input type="number"
                                           class="form-control field-input"
                                           @bind="tmpIsd.Codigo"
                                           readonly="@(isReadOnly || isEdit)" />
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="ret-field-card">
                                    <label class="field-label">Descripcion</label>
                                    <input type="text"
                                           class="form-control field-input"
                                           @bind="tmpIsd.Descripcion"
                                           readonly="@isReadOnly"
                                           maxlength="120" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Valor</label>
                                    <input type="number"
                                           class="form-control field-input"
                                           step="0.01"
                                           @bind="tmpIsd.Valor"
                                           readonly="@isReadOnly" />
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3 ret-form-grid">
                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Codigo</label>
                                    <input type="text"
                                           class="form-control field-input"
                                           @bind="tmpRenta.Codigo"
                                           readonly="@(isReadOnly || isEdit)"
                                           maxlength="50" />
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="ret-field-card">
                                    <label class="field-label">Descripcion</label>
                                    <input type="text"
                                           class="form-control field-input"
                                           @bind="tmpRenta.Descripcion"
                                           readonly="@isReadOnly"
                                           maxlength="150" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Valor</label>
                                    <input type="number"
                                           class="form-control field-input"
                                           step="0.01"
                                           @bind="tmpRenta.Valor"
                                           readonly="@isReadOnly" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Valor final</label>
                                    <input type="number"
                                           class="form-control field-input"
                                           step="0.01"
                                           @bind="tmpRenta.ValorFinal"
                                           readonly="@isReadOnly" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="ret-field-card">
                                    <label class="field-label">Codigo F103</label>
                                    <input type="text"
                                           class="form-control field-input"
                                           @bind="tmpRenta.CodigoFormulario103"
                                           readonly="@isReadOnly"
                                           maxlength="50" />
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="ret-field-card">
                                    <label class="field-label">Informacion extra</label>
                                    <textarea class="form-control field-input field-textarea"
                                              rows="3"
                                              @bind="tmpRenta.InformacionExtra"
                                              readonly="@isReadOnly"></textarea>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="switch-card">
                                    <input class="form-check-input" type="checkbox" @bind="tmpRenta.Estado" disabled="@isReadOnly" />
                                    <div>
                                        <strong>Retencion activa</strong>
                                        <span>Disponible para uso en documentos y procesos contables.</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer ret-modal-footer">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal" disabled="@isSaving">Cerrar</button>
                    @if (!isReadOnly)
                    {
                        <button type="button" class="primary-btn" @onclick="Guardar" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Procesando...</span>
                            }
                            else
                            {
                                <i class="bi bi-save me-2"></i>
                                <span>@(isEdit ? "Guardar cambios" : "Crear registro")</span>
                            }
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string tab = "iva";
    private bool isLoading = true;
    private bool showModal;
    private bool isReadOnly;
    private bool isEdit;
    private bool isSaving;
    private string? pageErrorMessage;
    private string? errorMessage;

    private string ivaSearchTerm = string.Empty;
    private string isdSearchTerm = string.Empty;
    private string rentaSearchTerm = string.Empty;

    private string ivaFilterValue = "all";
    private string isdFilterValue = "all";
    private string rentaFilterValue = "all";

    private int ivaPageSize = 10;
    private int isdPageSize = 10;
    private int rentaPageSize = 10;

    private int ivaCurrentPage = 1;
    private int isdCurrentPage = 1;
    private int rentaCurrentPage = 1;

    private List<RetencionIva> ivaList = new();
    private List<RetencionIsd> isdList = new();
    private List<RetencionRenta> rentaList = new();

    private RetencionIva tmpIva = new();
    private RetencionIsd tmpIsd = new();
    private RetencionRenta tmpRenta = new() { Estado = true };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (!await ValidarAccesoEContaxAsync(authState.User))
        {
            isLoading = false;
            return;
        }

        await CargarDatos();
    }

    private string CurrentTabHeader => tab switch
    {
        "iva" => "Retenciones IVA registradas",
        "isd" => "Retenciones ISD registradas",
        _ => "Retenciones de renta registradas"
    };

    private string CurrentTabDescription => tab switch
    {
        "iva" => "Filtra por codigo o descripcion y administra las retenciones de IVA.",
        "isd" => "Filtra por codigo o descripcion y administra las retenciones de ISD.",
        _ => "Filtra por codigo o descripcion y administra las retenciones de renta."
    };

    private string CurrentModalDescription => isReadOnly
        ? "Consulta el detalle de la retencion seleccionada sin modificar sus valores."
        : isEdit
            ? "Actualiza la informacion fiscal y conserva el formato del catalogo."
            : "Crea un nuevo codigo de retencion y dejalo disponible para tus procesos.";

    private string CurrentModalHelperText => tab switch
    {
        "iva" => "Mantiene el codigo, la descripcion y el porcentaje de retencion IVA con una estructura clara y facil de revisar.",
        "isd" => "Configura los datos esenciales del catalogo ISD antes de usarlo en tus comprobantes y procesos de compra.",
        _ => "Completa el detalle tributario de renta, incluyendo valores, codigo F103 y el estado operativo del registro."
    };

    private string CurrentModalFamilyLabel => tab switch
    {
        "iva" => "Retencion IVA",
        "isd" => "Retencion ISD",
        _ => "Retencion Renta"
    };

    private string CurrentModalIcon => tab switch
    {
        "iva" => "bi-percent",
        "isd" => "bi-globe-americas",
        _ => "bi-bank"
    };

    private string CurrentModalTitle => isReadOnly
        ? "Vista de detalle"
        : tab switch
        {
            "iva" => isEdit ? "Editar retencion IVA" : "Nueva retencion IVA",
            "isd" => isEdit ? "Editar retencion ISD" : "Nueva retencion ISD",
            _ => isEdit ? "Editar retencion renta" : "Nueva retencion renta"
        };

    private string CurrentSearchTerm
    {
        get => GetSearchTerm(tab);
        set
        {
            var nuevoValor = value ?? string.Empty;
            if (string.Equals(GetSearchTerm(tab), nuevoValor, StringComparison.Ordinal))
            {
                return;
            }

            SetSearchTerm(tab, nuevoValor);
            SetCurrentPage(tab, 1);
        }
    }

    private int CurrentPageSize
    {
        get => GetPageSize(tab);
        set
        {
            if (GetPageSize(tab) == value)
            {
                return;
            }

            SetPageSize(tab, value);
            SetCurrentPage(tab, 1);
            AjustarPaginaActual(tab);
        }
    }

    private int CurrentPage => GetCurrentPage(tab);

    private string CurrentFilterValue
    {
        get => GetFilterValue(tab);
        set
        {
            var nuevoValor = string.IsNullOrWhiteSpace(value) ? "all" : value;
            if (string.Equals(GetFilterValue(tab), nuevoValor, StringComparison.Ordinal))
            {
                return;
            }

            SetFilterValue(tab, nuevoValor);
            SetCurrentPage(tab, 1);
            AjustarPaginaActual(tab);
        }
    }

    private IEnumerable<RetencionIva> IvaFiltrados =>
        ivaList
            .Where(item => CoincideBusqueda(ivaSearchTerm, item.Codigo.ToString(), item.Descripcion))
            .OrderBy(item => item.Codigo)
            .ThenBy(item => (item.Descripcion ?? string.Empty).Trim(), StringComparer.OrdinalIgnoreCase);

    private IEnumerable<RetencionIsd> IsdFiltrados =>
        isdList
            .Where(item => CoincideBusqueda(isdSearchTerm, item.Codigo.ToString(), item.Descripcion))
            .OrderBy(item => item.Codigo)
            .ThenBy(item => (item.Descripcion ?? string.Empty).Trim(), StringComparer.OrdinalIgnoreCase);

    private IEnumerable<RetencionRenta> RentaFiltrados =>
        rentaList
            .Where(item => CoincideBusqueda(rentaSearchTerm, item.Codigo, item.Descripcion, item.InformacionExtra, item.CodigoFormulario103))
            .Where(CoincideFiltroRenta)
            .OrderBy(item => ParseCodigoNumerico(item.Codigo))
            .ThenBy(item => (item.Codigo ?? string.Empty).Trim(), StringComparer.OrdinalIgnoreCase)
            .ThenBy(item => (item.Descripcion ?? string.Empty).Trim(), StringComparer.OrdinalIgnoreCase);

    private IEnumerable<RetencionIva> IvaPaginados =>
        IvaFiltrados
            .Skip((ivaCurrentPage - 1) * ivaPageSize)
            .Take(ivaPageSize);

    private IEnumerable<RetencionIsd> IsdPaginados =>
        IsdFiltrados
            .Skip((isdCurrentPage - 1) * isdPageSize)
            .Take(isdPageSize);

    private IEnumerable<RetencionRenta> RentaPaginados =>
        RentaFiltrados
            .Skip((rentaCurrentPage - 1) * rentaPageSize)
            .Take(rentaPageSize);

    private int CurrentTotalRecords => tab switch
    {
        "iva" => IvaFiltrados.Count(),
        "isd" => IsdFiltrados.Count(),
        _ => RentaFiltrados.Count()
    };

    private int CurrentTotalPages => Math.Max(1, (int)Math.Ceiling(CurrentTotalRecords / (double)CurrentPageSize));
    private int CurrentPageStart => CurrentTotalRecords == 0 ? 0 : ((CurrentPage - 1) * CurrentPageSize) + 1;
    private int CurrentPageEnd => CurrentTotalRecords == 0 ? 0 : Math.Min(CurrentTotalRecords, CurrentPage * CurrentPageSize);

    private string CurrentEmptyMessage
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(CurrentSearchTerm))
            {
                return "No encontramos retenciones con los filtros actuales.";
            }

            return tab switch
            {
                "iva" => "Aun no hay retenciones IVA registradas.",
                "isd" => "Aun no hay retenciones ISD registradas.",
                _ => "Aun no hay retenciones de renta registradas."
            };
        }
    }

    private async Task CargarDatos()
    {
        isLoading = true;
        pageErrorMessage = null;

        try
        {
            ivaList = await AdministracionService.GetRetencionesIvaAsync();
            isdList = await AdministracionService.GetRetencionesIsdAsync();
            rentaList = await AdministracionService.GetRetencionesRentaAsync();

            AjustarPaginaActual("iva");
            AjustarPaginaActual("isd");
            AjustarPaginaActual("renta");
        }
        catch (Exception ex)
        {
            ivaList = new();
            isdList = new();
            rentaList = new();
            pageErrorMessage = $"Error al cargar las retenciones: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CambiarTab(string nuevaTab)
    {
        if (tab == nuevaTab)
        {
            return;
        }

        tab = nuevaTab;
        AjustarPaginaActual(tab);
    }

    private void AbrirModalActual()
    {
        if (tab == "iva")
        {
            AbrirIva();
            return;
        }

        if (tab == "isd")
        {
            AbrirIsd();
            return;
        }

        AbrirRenta();
    }

