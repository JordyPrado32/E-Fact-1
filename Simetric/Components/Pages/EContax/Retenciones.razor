    private void PaginaAnterior()
    {
        if (CurrentPage > 1)
        {
            SetCurrentPage(tab, CurrentPage - 1);
        }
    }

    private void PaginaSiguiente()
    {
        if (CurrentPage < CurrentTotalPages)
        {
            SetCurrentPage(tab, CurrentPage + 1);
        }
    }

    private void AjustarPaginaActual(string targetTab)
    {
        var paginaActual = GetCurrentPage(targetTab);
        var totalPaginas = GetTotalPages(targetTab);
        SetCurrentPage(targetTab, Math.Min(Math.Max(1, paginaActual), totalPaginas));
    }

    private int GetTotalPages(string targetTab)
    {
        var totalRegistros = targetTab switch
        {
            "iva" => IvaFiltrados.Count(),
            "isd" => IsdFiltrados.Count(),
            _ => RentaFiltrados.Count()
        };

        var tamanoPagina = GetPageSize(targetTab);
        return Math.Max(1, (int)Math.Ceiling(totalRegistros / (double)tamanoPagina));
    }

