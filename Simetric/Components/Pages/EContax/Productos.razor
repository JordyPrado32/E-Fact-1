    private async Task Guardar()
    {
        if (isSaving)
            return;

        mensaje = null;
        mensajeEdicion = null;
        mensajeFormularioError = null;
        debugError = null;

        model.Nombre = model.Nombre?.Trim();
        model.CodigoPrincipal = model.CodigoPrincipal?.Trim();
        model.TipoCompravena = model.TipoCompravena?.Trim().ToUpperInvariant();
        model.Codigoimpuesto = model.Codigoimpuesto?.Trim();
        model.Porcentajeimpuesto = model.Porcentajeimpuesto?.Trim();
        model.Observacion = model.Observacion?.Trim();
        model.Idsucursal = contextoEContax?.EsJefeEmpresa == true
            ? model.Idsucursal
            : contextoEContax?.IdSucursal;

        if (model.Idsucursal is not > 0)
        {
            mensajeFormularioError = "Debe seleccionar la sucursal del producto.";
            return;
        }

        if (model.TipoProducto.HasValue && model.Idsubtipo.HasValue)
        {
            var subtipoOk = subtiposProducto.Any(s =>
                s.Idsubtipo == model.Idsubtipo.Value &&
                s.Idtipoproducto == model.TipoProducto.Value);

            if (!subtipoOk)
            {
                mensajeFormularioError = "La subcategoría no pertenece a la categoría elegida.";
                return;
            }
        }

        if (!string.IsNullOrWhiteSpace(model.CodigoPrincipal))
        {
            var existeCodigoPrincipal = productos.Any(p =>
                p.Codigo != model.Codigo &&
                p.Idsucursal == model.Idsucursal &&
                string.Equals(p.CodigoPrincipal?.Trim(), model.CodigoPrincipal, StringComparison.OrdinalIgnoreCase));

            if (existeCodigoPrincipal)
            {
                mensajeFormularioError = "Ya existe un producto con ese código.";
                return;
            }
        }

        var estabaEditando = editando;
        isSaving = true;

        try
        {
            var resp = editando
                ? await Http.PutAsJsonAsync($"api/e-contax/productos/{model.Codigo}?userId={usuarioLogueadoId}", model)
                : await Http.PostAsJsonAsync($"api/e-contax/productos?userId={usuarioLogueadoId}", model);

            if (resp.IsSuccessStatusCode)
            {
                await CargarTodo();
                Nuevo();
                mensaje = estabaEditando
                    ? "Producto actualizado correctamente."
                    : "Producto creado correctamente.";
            }
            else
            {
                debugError = await resp.Content.ReadAsStringAsync();
                mensaje = "No se pudo guardar el registro.";
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
            mensaje = "Error al guardar el registro.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ManejarFormularioInvalido(EditContext _)
    {
        mensaje = null;
        mensajeEdicion = null;
        debugError = null;
        mensajeFormularioError = "Revisa los campos obligatorios antes de confirmar el producto.";
    }

    private void OnIvaChanged(ChangeEventArgs e)
    {
        var marcado = false;

        if (e.Value is bool b)
        {
            marcado = b;
        }
        else if (e.Value is string s && bool.TryParse(s, out var parsed))
        {
            marcado = parsed;
        }

        if (marcado)
        {
            model.Codigoimpuesto = "2";
        }
        else
        {
            model.Codigoimpuesto = "";
            model.Porcentajeimpuesto = "";
        }
    }

    private void AgregarCampoPrecioAdicional()
    {
        if (camposPrecioVisibles < 3)
        {
            camposPrecioVisibles++;
        }
    }

    private void EliminarCampoPrecioAdicional(int numeroCampo)
    {
        if (numeroCampo == 2)
        {
            model.Precio2 = model.Precio3;
            model.Precio3 = null;
            camposPrecioVisibles = Math.Max(1, camposPrecioVisibles - 1);
            return;
        }

        if (numeroCampo == 3)
        {
            model.Precio3 = null;
            camposPrecioVisibles = Math.Max(1, camposPrecioVisibles - 1);
        }
    }

    private void SincronizarCamposPrecioVisibles()
    {
        camposPrecioVisibles = 1;

        if (model.Precio2.HasValue || model.Precio3.HasValue)
        {
            camposPrecioVisibles = 2;
        }

        if (model.Precio3.HasValue)
        {
            camposPrecioVisibles = 3;
        }
    }

    private async Task ConfirmarEliminar(ProductoDto p)
    {
        var nombreProducto = string.IsNullOrWhiteSpace(p.Nombre)
            ? $"el registro #{p.Codigo}"
            : p.Nombre;

        if (!await JS.ConfirmDeleteAsync("Dar de baja producto", $"Se dara de baja {nombreProducto}.", "Si, dar de baja"))
        {
            return;
        }

        try
        {
            var del = await Http.DeleteAsync($"api/e-contax/productos/{p.Codigo}?userId={usuarioLogueadoId}");

            if (del.IsSuccessStatusCode)
            {
                await CargarTodo();
                mensaje = "Registro desactivado con exito.";
                await JS.ShowToastAsync("Registro dado de baja");
            }
            else
            {
                debugError = await del.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private void VerProducto(ProductoDto producto)
    {
        productoEnVista = producto;
    }

    private void CerrarVistaProducto()
    {
        productoEnVista = null;
    }

    private void ConfirmarEliminarLegacy(ProductoDto p)
    {
        productoAEliminar = p;
        mostrarConfirmacion = true;
    }

    private void CancelarEliminar()
    {
        mostrarConfirmacion = false;
        productoAEliminar = null;
    }

    private async Task EliminarConfirmado()
    {
        if (productoAEliminar is null)
        {
            return;
        }

        try
        {
            var del = await Http.DeleteAsync($"api/e-contax/productos/{productoAEliminar.Codigo}?userId={usuarioLogueadoId}");

            if (del.IsSuccessStatusCode)
            {
                await CargarTodo();
                CancelarEliminar();
                mensaje = "Registro desactivado con éxito.";
            }
            else
            {
                debugError = await del.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private string GetCategoriaDescripcion(int? tipoId) =>
        tipoId.HasValue
            ? tiposProducto.FirstOrDefault(t => t.Idtipoproducto == tipoId.Value)?.Descripcion ?? "Sin categoría"
            : "Sin categoría";

    private string GetSubcategoriaDescripcion(int? subtipoId) =>
        subtipoId.HasValue
            ? subtiposProducto.FirstOrDefault(s => s.Idsubtipo == subtipoId.Value)?.Descripcion ?? "Sin subcategoría"
            : "Sin subcategoría";

    private string GetSucursalDescripcion(int? sucursalId) =>
        sucursalId.HasValue
            ? sucursales.FirstOrDefault(s => s.IdSucursal == sucursalId.Value)?.Nombre ?? "Sucursal no asignada"
            : "Sucursal no asignada";

    private string GetTarifaDescripcion(string? codigo) =>
        string.IsNullOrWhiteSpace(codigo)
            ? "Sin tarifa"
            : porcentajesIva.FirstOrDefault(i => i.Codigo == codigo)?.Descripcion ?? codigo;

    private string GetImpuestoDescripcion(string? codigo) =>
        string.IsNullOrWhiteSpace(codigo)
            ? "Sin impuesto"
            : codigosImpuesto.FirstOrDefault(i => i.Codigo == codigo)?.Descripcion ?? codigo;

    private static string GetEstadoProductoDescripcion(bool? estado) => estado == true ? "Activo" : "Inactivo";

    private void AjustarPaginaActual()
    {
        currentPage = Math.Min(Math.Max(1, currentPage), CurrentTotalPages);
    }

    private void PaginaAnterior()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void PaginaSiguiente()
    {
        if (currentPage < CurrentTotalPages)
        {
            currentPage++;
        }
    }

    private static string FormatCurrency(decimal? value) => value?.ToString("C2") ?? "-";
}
