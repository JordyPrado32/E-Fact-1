        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            Nombre = Nombre?.Trim();
            CodigoPrincipal = CodigoPrincipal?.Trim();
            TipoCompravena = TipoCompravena?.Trim().ToUpperInvariant();
            Codigoimpuesto = Codigoimpuesto?.Trim();
            Porcentajeimpuesto = Porcentajeimpuesto?.Trim();
            Observacion = Observacion?.Trim();

            if (string.IsNullOrWhiteSpace(TipoCompravena))
            {
                yield return new ValidationResult(
                    "Debe seleccionar si el registro es producto o servicio.",
                    new[] { nameof(TipoCompravena) });
            }

            if (string.IsNullOrWhiteSpace(Nombre))
            {
                yield return new ValidationResult(
                    "Debe ingresar el nombre del producto o servicio.",
                    new[] { nameof(Nombre) });
            }
            else if (Nombre.Length > 120)
            {
                yield return new ValidationResult(
                    "El nombre no puede exceder 120 caracteres.",
                    new[] { nameof(Nombre) });
            }

            if (!string.IsNullOrWhiteSpace(CodigoPrincipal) && CodigoPrincipal.Length > 50)
            {
                yield return new ValidationResult(
                    "El código no puede exceder 50 caracteres.",
                    new[] { nameof(CodigoPrincipal) });
            }

            if (!ValorUnitario.HasValue)
            {
                yield return new ValidationResult(
                    "Debe ingresar el precio base.",
                    new[] { nameof(ValorUnitario) });
            }

            if (Idsucursal is <= 0)
            {
                yield return new ValidationResult(
                    "Debe seleccionar la sucursal del producto.",
                    new[] { nameof(Idsucursal) });
            }

            if (ValorUnitario.HasValue && ValorUnitario < 0)
            {
                yield return new ValidationResult(
                    "El precio 1 no puede ser menor a 0.",
                    new[] { nameof(ValorUnitario) });
            }

            if (Precio2.HasValue && Precio2 < 0)
            {
                yield return new ValidationResult(
                    "El precio 2 no puede ser menor a 0.",
                    new[] { nameof(Precio2) });
            }

            if (Precio3.HasValue && Precio3 < 0)
            {
                yield return new ValidationResult(
                    "El precio 3 no puede ser menor a 0.",
                    new[] { nameof(Precio3) });
            }

            if (!string.IsNullOrWhiteSpace(TipoCompravena) &&
                TipoCompravena != "PRODUCTO" &&
                TipoCompravena != "SERVICIO")
            {
                yield return new ValidationResult(
                    "Debe elegir PRODUCTO o SERVICIO.",
                    new[] { nameof(TipoCompravena) });
            }

            if (Idsubtipo.HasValue && !TipoProducto.HasValue)
            {
                yield return new ValidationResult(
                    "Debe seleccionar una categoría antes de elegir la subcategoría.",
                    new[] { nameof(Idsubtipo), nameof(TipoProducto) });
            }

            if (Codigoimpuesto == "2" && string.IsNullOrWhiteSpace(Porcentajeimpuesto))
            {
                yield return new ValidationResult(
                    "Debe seleccionar la tarifa IVA.",
                    new[] { nameof(Porcentajeimpuesto) });
            }

            if (!string.IsNullOrWhiteSpace(Observacion) && Observacion.Length > 250)
            {
                yield return new ValidationResult(
                    "La observación no puede exceder 250 caracteres.",
                    new[] { nameof(Observacion) });
            }
        }
    }

