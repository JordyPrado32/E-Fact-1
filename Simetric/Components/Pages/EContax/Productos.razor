@page "/e-contax/productos"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Net.Http.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using Simetric.Models
@using Simetric.Services
@using Simetric.Services.EContax
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject ProductCategoryService CategoryService
@inject NavigationManager NavManager
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@rendermode InteractiveServer

@{
    var filteredProducts = ProductosPaginados.ToList();
    var totalFilteredProducts = CurrentTotalRecords;
    var totalActivos = productos.Count(p => p.Estado == true);
    var totalServicios = productos.Count(p => p.Estado == true && string.Equals(p.TipoCompravena, "SERVICIO", StringComparison.OrdinalIgnoreCase));
    var totalConIva = productos.Count(p => p.Estado == true && p.Codigoimpuesto == "2");
}

<PageTitle>Productos | @PageBrandTitle</PageTitle>

<div class="products-shell" data-tour="productos.page">
    <section class="products-hero" data-tour="productos.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Catálogo comercial</span>
            <h2>Gestión de productos y servicios</h2>
            <p>
                Administra tu catálogo, configura precios, IVA y organiza tus registros por categoría y subcategoría.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Activos</span>
                <strong>@totalActivos</strong>
                <small>Productos y servicios visibles.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Servicios</span>
                <strong>@totalServicios</strong>
                <small>Registros marcados como servicio.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Con IVA</span>
                <strong>@totalConIva</strong>
                <small>Registros configurados con impuesto.</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="productos.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Control</span>
            <h3>Catálogo</h3>
            <p>Busca, filtra y administra tus productos o servicios.</p>
        </div>

        <div class="toolbar-actions">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>
                <input class="search-input"
                       placeholder="Buscar por nombre o código"
                       @bind="FiltroBusqueda"
                       @bind:event="oninput" />
            </div>

            <div class="toolbar-secondary-actions">
                @if (contextoEContax?.EsJefeEmpresa == true)
                {
                    <div class="filter-box">
                        <label class="filter-label" for="sucursalFiltro">Sucursal</label>
                        <select id="sucursalFiltro" class="filter-select" @bind="FiltroSucursalSeleccionada">
                            <option value="">Todas</option>
                            @foreach (var sucursal in sucursales)
                            {
                                <option value="@sucursal.IdSucursal">@sucursal.Nombre</option>
                            }
                        </select>
                    </div>
                }

                <div class="filter-box">
                    <label class="filter-label" for="tipoFiltro">Categoría</label>
                    <select id="tipoFiltro" class="filter-select" @bind="FiltroCategoriaSeleccionada">
                        <option value="">Todas</option>
                        @foreach (var t in tiposProducto)
                        {
                            <option value="@t.Idtipoproducto">@t.Descripcion</option>
                        }
                    </select>
                </div>

                <div class="filter-box">
                    <label class="filter-label" for="subtipoFiltro">Subcategorí­a</label>
                    <select id="subtipoFiltro" class="filter-select" @bind="FiltroSubcategoriaSeleccionada">
                        <option value="">Todas</option>
                        @foreach (var s in SubcategoriasFiltroDisponibles)
                        {
                            <option value="@s.Idsubtipo">@s.Descripcion</option>
                        }
                    </select>
                </div>

                <div class="filter-box">
                    <label class="filter-label" for="compraventaFiltro">Tipo</label>
                    <select id="compraventaFiltro" class="filter-select" @bind="FiltroCompraventaSeleccionado">
                        <option value="">Todos</option>
                        <option value="PRODUCTO">Producto</option>
                        <option value="SERVICIO">Servicio</option>
                    </select>
                </div>

                <div class="filter-box">
                    <label class="filter-label" for="pageSizeFiltro">Registros</label>
                    <select id="pageSizeFiltro" class="filter-select" @bind="CurrentPageSize">
                        <option value="5">5 registros</option>
                        <option value="10">10 registros</option>
                        <option value="20">20 registros</option>
                    </select>
                </div>

                <button type="button" class="secondary-btn toolbar-secondary-btn" @onclick="CargarTodo">
                    <i class="bi bi-arrow-clockwise"></i>
                    <span>Refrescar</span>
                </button>

                <button type="button" class="secondary-btn toolbar-secondary-btn" @onclick="ExportarProductosCsvAsync">
                    <i class="bi bi-download"></i>
                    <span>Exportar todos</span>
                </button>
            </div>
        </div>
    </section>

    <section class="products-grid">
        <section class="table-card" data-tour="productos.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado activo</span>
                    <h3>Productos registrados</h3>
                </div>

                <span class="table-badge">@totalFilteredProducts registros</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(debugError))
            {
                <div class="status-banner status-banner-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@debugError</span>
                </div>
            }

            @if (cargando)
            {
                <div class="state-card">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando catálogo</h3>
                    <p>Estamos consultando productos, categorías y tarifas IVA.</p>
                </div>
            }
            else if (!filteredProducts.Any())
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <h3>No hay registros para mostrar</h3>
                    <p>No existen productos o servicios activos con los filtros aplicados.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table table-hover align-middle mb-0 products-table products-table-compact">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th>Clasificacion</th>
                                <th>Precio</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in filteredProducts)
                            {
                                <tr>
                                    <td>
                                        <span class="code-pill">@(string.IsNullOrWhiteSpace(p.CodigoPrincipal) ? $"#{p.Codigo}" : p.CodigoPrincipal)</span>
                                    </td>
                                    <td>
                                        <div class="cell-main cell-main-stacked">
                                            <strong>@(string.IsNullOrWhiteSpace(p.Nombre) ? "Sin nombre" : p.Nombre)</strong>
                                            <span>@(string.IsNullOrWhiteSpace(p.TipoCompravena) ? "Sin tipo" : p.TipoCompravena)</span>
                                            @if (!string.IsNullOrWhiteSpace(p.NombreSucursal))
                                            {
                                                <span>@p.NombreSucursal</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="classification-stack">
                                            <span class="category-pill">@GetCategoriaDescripcion(p.TipoProducto)</span>
                                            <span class="subcategory-line">
                                                <i class="bi bi-diagram-2"></i>
                                                @GetSubcategoriaDescripcion(p.Idsubtipo)
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="price-stack">
                                            <strong>@FormatCurrency(p.ValorUnitario)</strong>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view" @onclick="() => VerProducto(p)" title="Ver">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button type="button"
                                                    class="action-btn action-edit"
                                                    @onclick="() => Editar(p.Codigo)"
                                                    disabled="@(isSaving || (editando && model.Codigo == p.Codigo))"
                                                    title="@(editando && model.Codigo == p.Codigo ? "Editando" : "Editar")">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button type="button" class="action-btn action-delete" @onclick="() => ConfirmarEliminar(p)" disabled="@isSaving" title="Desactivar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (mostrarConfirmacion && productoAEliminar is not null)
            {
                <div class="confirm-card">
                    <div class="confirm-copy">
                        <span class="confirm-kicker">Confirmación</span>
                        <strong>Desactivar @productoAEliminar.Nombre?</strong>
                        <p>El registro se conserva en base de datos, pero dejará de mostrarse en el catálogo activo.</p>
                    </div>

                    <div class="confirm-actions">
                        <button type="button" class="danger-btn" @onclick="EliminarConfirmado">
                            <i class="bi bi-trash3"></i>
                            <span>Sí, desactivar</span>
                        </button>
                        <button type="button" class="secondary-btn" @onclick="CancelarEliminar">
                            <span>Cancelar</span>
                        </button>
                    </div>
                </div>
            }

            @if (productoEnVista is not null)
            {
                <div class="products-modal-backdrop" @onclick:stopPropagation="true"></div>
                <div class="products-modal" role="dialog" aria-modal="true" aria-labelledby="productoDetalleTitulo">
                    <div class="products-modal-content" @onclick:stopPropagation="true">
                        <div class="products-modal-header">
                            <div>
                                <h3 id="productoDetalleTitulo">@(string.IsNullOrWhiteSpace(productoEnVista.Nombre) ? $"Registro #{productoEnVista.Codigo}" : productoEnVista.Nombre)</h3>
                                <p>@(string.IsNullOrWhiteSpace(productoEnVista.TipoCompravena) ? "Sin tipo de registro" : productoEnVista.TipoCompravena) - @GetEstadoProductoDescripcion(productoEnVista.Estado)</p>
                            </div>

                            <button type="button" class="modal-close" @onclick="CerrarVistaProducto" aria-label="Cerrar detalle" title="Cerrar">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>

                        <div class="products-modal-body">
                            <div class="detail-sections">
                                <section class="detail-section">
                                    <h4 class="detail-section-title">Clasificación</h4>
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <span>Código principal</span>
                                            <strong>@(string.IsNullOrWhiteSpace(productoEnVista.CodigoPrincipal) ? $"#{productoEnVista.Codigo}" : productoEnVista.CodigoPrincipal)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Tipo</span>
                                            <strong>@(string.IsNullOrWhiteSpace(productoEnVista.TipoCompravena) ? "Sin tipo" : productoEnVista.TipoCompravena)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Categoría</span>
                                            <strong>@GetCategoriaDescripcion(productoEnVista.TipoProducto)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Subcategoría</span>
                                            <strong>@GetSubcategoriaDescripcion(productoEnVista.Idsubtipo)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Sucursal</span>
                                            <strong>@GetSucursalDescripcion(productoEnVista.Idsucursal)</strong>
                                        </div>
                                    </div>
                                </section>

                                <section class="detail-section">
                                    <h4 class="detail-section-title">Precios e impuestos</h4>
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <span>Precio base</span>
                                            <strong>@FormatCurrency(productoEnVista.ValorUnitario)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Precio 2</span>
                                            <strong>@FormatCurrency(productoEnVista.Precio2)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Precio 3</span>
                                            <strong>@FormatCurrency(productoEnVista.Precio3)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Impuesto</span>
                                            <strong>@GetImpuestoDescripcion(productoEnVista.Codigoimpuesto)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Tarifa IVA</span>
                                            <strong>@GetTarifaDescripcion(productoEnVista.Porcentajeimpuesto)</strong>
                                        </div>

                                        <div class="detail-item">
                                            <span>Estado</span>
                                            <strong>@GetEstadoProductoDescripcion(productoEnVista.Estado)</strong>
                                        </div>
                                    </div>
                                </section>

                                @if (!string.IsNullOrWhiteSpace(productoEnVista.Observacion))
                                {
                                    <div class="detail-note">
                                        <span>Observaciones</span>
                                        <strong>@productoEnVista.Observacion</strong>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="products-modal-footer">
                            <button type="button" class="secondary-btn" @onclick="CerrarVistaProducto">Cerrar</button>
                        </div>
                    </div>
                </div>
            }

            <div class="products-pagination">
                <span class="products-pagination-meta">
                    Mostrando @CurrentPageStart - @CurrentPageEnd de @CurrentTotalRecords registros
                </span>

                <div class="products-pagination-actions">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaAnterior" disabled="@(currentPage <= 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="products-page-indicator">Pagina @currentPage de @CurrentTotalPages</span>
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="PaginaSiguiente" disabled="@(currentPage >= CurrentTotalPages)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        </section>

        <section class="editor-card product-editor-shell" data-tour="productos.editor">
            <div class="card shadow-sm border-top border-success border-4 product-editor-card product-editor-card-accent">
                <div class="card-body product-card-body">
                    <div class="product-form-copy">
                        <h5 class="card-title fw-bold product-editor-title">@(editando ? "Editar registro" : "Registrar producto o servicio")</h5>
                        <p class="text-muted small mb-0">Completa los campos visibles y, si deseas, agrega información opcional.</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(mensajeEdicion))
                    {
                        <div class="status-banner status-banner-info product-edit-banner">
                            <i class="bi bi-info-circle"></i>
                            <span>@mensajeEdicion</span>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(mensajeFormularioError))
                    {
                        <div class="status-banner status-banner-error product-edit-banner">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@mensajeFormularioError</span>
                        </div>
                    }

                    <EditForm Model="model"
                              OnValidSubmit="Guardar"
                              OnInvalidSubmit="ManejarFormularioInvalido"
                              @key="formKey"
                              class="product-form-legacy">
                        <DataAnnotationsValidator />

                        @if (contextoEContax?.EsJefeEmpresa == true)
                        {
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Sucursal</label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="model.Idsucursal">
                                    <option value="">Seleccione una sucursal</option>
                                    @foreach (var sucursal in sucursales)
                                    {
                                        <option value="@sucursal.IdSucursal">@sucursal.Nombre</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => model.Idsucursal" class="text-danger small d-block mt-1" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label small fw-bold d-block">Tipo</label>
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="button"
                                        class="btn @(model.TipoCompravena == "PRODUCTO" ? "btn-primary" : "btn-outline-primary")"
                                        @onclick='() => model.TipoCompravena = "PRODUCTO"'>
                                    Producto
                                </button>

                                <button type="button"
                                        class="btn @(model.TipoCompravena == "SERVICIO" ? "btn-primary" : "btn-outline-primary")"
                                        @onclick='() => model.TipoCompravena = "SERVICIO"'>
                                    Servicio
                                </button>
                            </div>
                            <ValidationMessage For="() => model.TipoCompravena" class="text-danger small d-block mt-2" />
                        </div>

                        <div class="row mb-2">
                            <div class="col-md-8">
                                <label class="form-label small fw-bold">Nombre</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.Nombre" />
                                <ValidationMessage For="() => model.Nombre" class="text-danger small d-block mt-1" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Código</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.CodigoPrincipal" />
                                <ValidationMessage For="() => model.CodigoPrincipal" class="text-danger small d-block mt-1" />
                            </div>
                        </div>

                        <div class="product-price-panel mb-3">
                            <div class="product-price-main-row">
                                <div class="product-price-field product-price-field-primary">
                                    <div class="product-price-field-head">
                                        <label class="form-label small fw-bold">Precio base</label>
                                        <button type="button"
                                                class="product-price-add-btn"
                                                @onclick="AgregarCampoPrecioAdicional"
                                                disabled="@(!PuedeAgregarCampoPrecioAdicional)"
                                                title="Agregar precio adicional"
                                                aria-label="Agregar precio adicional">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="model.ValorUnitario" />
                                    <ValidationMessage For="() => model.ValorUnitario" class="text-danger small d-block mt-1" />
                                    <small class="text-muted">Este será el precio base del producto o servicio.</small>
                                </div>
                            </div>

                            @if (MostrarPrecio2)
                            {
                                <div class="product-price-field product-price-field-secondary">
                                    <div class="product-price-field-head">
                                        <label class="form-label small fw-bold">Precio 2 (opcional)</label>
                                        <button type="button"
                                                class="product-price-remove-btn"
                                                @onclick="() => EliminarCampoPrecioAdicional(2)"
                                                title="Eliminar precio 2"
                                                aria-label="Eliminar precio 2">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="model.Precio2" />
                                    <ValidationMessage For="() => model.Precio2" class="text-danger small d-block mt-1" />
                                </div>
                            }

                            @if (MostrarPrecio3)
                            {
                                <div class="product-price-field product-price-field-secondary">
                                    <div class="product-price-field-head">
                                        <label class="form-label small fw-bold">Precio 3 (opcional)</label>
                                        <button type="button"
                                                class="product-price-remove-btn"
                                                @onclick="() => EliminarCampoPrecioAdicional(3)"
                                                title="Eliminar precio 3"
                                                aria-label="Eliminar precio 3">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="model.Precio3" />
                                    <ValidationMessage For="() => model.Precio3" class="text-danger small d-block mt-1" />
                                </div>
                            }
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="form-check mt-4">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           checked="@(!string.IsNullOrWhiteSpace(model.Codigoimpuesto) && model.Codigoimpuesto == "2")"
                                           @onchange="OnIvaChanged" />
                                    <label class="form-check-label fw-semibold">IVA</label>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <label class="form-label small fw-bold">Tarifa</label>
                                <InputSelect class="form-select form-select-sm"
                                             @bind-Value="model.Porcentajeimpuesto"
                                             disabled="@(string.IsNullOrWhiteSpace(model.Codigoimpuesto) || model.Codigoimpuesto != "2")">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var iva in porcentajesIva)
                                    {
                                        <option value="@iva.Codigo">@iva.Descripcion (@iva.Valor%)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => model.Porcentajeimpuesto" class="text-danger small d-block mt-1" />
                            </div>
                        </div>

                        <details class="mb-3">
                            <summary class="fw-bold small">Detalles adicionales</summary>
                            <div class="mt-3">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Categoría (opcional)</label>
                                        <InputSelect class="form-select form-select-sm" @bind-Value="CategoriaSeleccionada">
                                            <option value="">-- Sin categoría --</option>
                                            @foreach (var t in tiposProducto)
                                            {
                                                <option value="@t.Idtipoproducto">@t.Descripcion</option>
                                            }
                                        </InputSelect>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">Subcategoría (opcional)</label>
                                        <InputSelect class="form-select form-select-sm" @bind-Value="model.Idsubtipo">
                                            <option value="">@(model.TipoProducto.HasValue ? "-- Seleccione --" : "-- Seleccione una categoría primero --")</option>
                                            @foreach (var s in SubtiposDisponibles)
                                            {
                                                <option value="@s.Idsubtipo">@s.Descripcion</option>
                                            }
                                        </InputSelect>
                                        <ValidationMessage For="() => model.Idsubtipo" class="text-danger small d-block mt-1" />
                                    </div>
                                </div>

                                <label class="form-label small">Observaciones</label>
                                <InputTextArea class="form-control form-control-sm product-textarea"
                                               rows="4"
                                               @bind-Value="model.Observacion"
                                               placeholder="Campos opcionales del producto o servicio" />
                                <ValidationMessage For="() => model.Observacion" class="text-danger small d-block mt-1" />
                            </div>
                        </details>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end pt-3 border-top mt-4">
                            <button class="secondary-btn" type="button" @onclick="Nuevo" disabled="@isSaving">Limpiar</button>
                            <button class="primary-btn" type="submit" disabled="@isSaving">
