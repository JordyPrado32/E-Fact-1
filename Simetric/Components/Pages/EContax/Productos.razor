    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!await ValidarAccesoEContaxAsync(user))
        {
            cargando = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        usuarioLogueadoId = ObtenerIdUsuario(user);

        if (usuarioLogueadoId <= 0)
        {
            mensaje = "Sesión no válida (no se pudo obtener IdUsuario). Vuelve a iniciar sesión.";
            cargando = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await CargarTodo();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<bool> ValidarAccesoEContaxAsync(ClaimsPrincipal user)
    {
        if (!IsEContaxPath(NavManager.Uri))
            return true;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var userId = ObtenerIdUsuario(user);
        if (userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private bool IsEContaxPath(string location) => EContaxRoutes.IsEContaxPath(NavManager, location);

    private async Task CargarTodo()
    {
        cargando = true;
        try
        {
            var respLook = await Http.GetFromJsonAsync<LookupResponse>($"api/e-contax/productos/lookups?userId={usuarioLogueadoId}");
            if (respLook != null)
            {
                tiposProducto = respLook.tipos
                    .OrderBy(x => x.Descripcion, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                codigosImpuesto = respLook.impuestos;
                porcentajesIva = respLook.ivas;
                subtiposProducto = respLook.subtipos
                    .OrderBy(x => x.Descripcion, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                sucursales = respLook.sucursales
                    .OrderBy(x => x.Nombre, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                contextoEContax = respLook.contexto;

                if (contextoEContax?.EsJefeEmpresa == true)
                {
                    if (filtroSucursal.HasValue && !sucursales.Any(x => x.IdSucursal == filtroSucursal.Value))
                    {
                        filtroSucursal = null;
                    }

                    if (!editando && !model.Idsucursal.HasValue)
                    {
                        model.Idsucursal = filtroSucursal ?? sucursales.FirstOrDefault()?.IdSucursal;
                    }
                }
                else
                {
                    filtroSucursal = contextoEContax?.IdSucursal;
                    model.Idsucursal = contextoEContax?.IdSucursal;
                }

                if (filtroTipo.HasValue && !tiposProducto.Any(x => x.Idtipoproducto == filtroTipo.Value))
                {
                    filtroTipo = null;
                }

                if (filtroSubtipo.HasValue && !subtiposProducto.Any(x => x.Idsubtipo == filtroSubtipo.Value))
                {
                    filtroSubtipo = null;
                }
            }

            productos = await Http.GetFromJsonAsync<List<ProductoDto>>($"api/e-contax/productos?userId={usuarioLogueadoId}") ?? new();
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
        finally
        {
            cargando = false;
            AjustarPaginaActual();
        }
    }

    private IEnumerable<ProductoDto> ProductosFiltrados
    {
        get
        {
            var activos = productos.Where(p => p.Estado == true);

            if (filtroTipo.HasValue)
            {
                activos = activos.Where(p => p.TipoProducto == filtroTipo.Value);
            }

            if (filtroSubtipo.HasValue)
            {
                activos = activos.Where(p => p.Idsubtipo == filtroSubtipo.Value);
            }

            if (contextoEContax?.EsJefeEmpresa == true && filtroSucursal.HasValue)
            {
                activos = activos.Where(p => p.Idsucursal == filtroSucursal.Value);
            }

            if (!string.IsNullOrWhiteSpace(filtroCompraventa))
            {
                activos = activos.Where(p =>
                    string.Equals(p.TipoCompravena, filtroCompraventa, StringComparison.OrdinalIgnoreCase));
            }

            if (string.IsNullOrWhiteSpace(filtro))
            {
                return OrdenarProductosClasificados(activos);
            }

            return OrdenarProductosClasificados(activos.Where(p =>
                (p.Nombre ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (p.CodigoPrincipal ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                GetCategoriaDescripcion(p.TipoProducto).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                GetSubcategoriaDescripcion(p.Idsubtipo).Contains(filtro, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private IOrderedEnumerable<ProductoDto> OrdenarProductosClasificados(IEnumerable<ProductoDto> query) =>
        query
            .OrderBy(p => GetCategoriaDescripcion(p.TipoProducto), StringComparer.OrdinalIgnoreCase)
            .ThenBy(p => GetSubcategoriaDescripcion(p.Idsubtipo), StringComparer.OrdinalIgnoreCase)
            .ThenBy(p => p.Nombre ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            .ThenByDescending(p => p.Codigo);

    private async Task ExportarProductosCsvAsync()
    {
        var productosExportar = await Http.GetFromJsonAsync<List<ProductoDto>>($"api/e-contax/productos?userId={usuarioLogueadoId}") ?? productos;

        if (productosExportar.Count == 0)
        {
            mensaje = "No se encontraron productos para exportar.";
            return;
        }

        var sb = new StringBuilder();
        sb.AppendLine("Codigo;Nombre;Tipo;PrecioBase;Precio2;Precio3;Categoria;Subcategoria;Sucursal;AplicaIVA;TarifaIVA;Observacion");

        foreach (var p in OrdenarProductosClasificados(productosExportar))
        {
            var codigo = EscapeCsvField(p.CodigoPrincipal ?? string.Empty, forceExcelText: true);
            var nombre = EscapeCsvField(p.Nombre ?? string.Empty);
            var tipo = p.TipoCompravena ?? string.Empty;
            var precioBase = p.ValorUnitario?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            var precio2 = p.Precio2?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            var precio3 = p.Precio3?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            var categoria = EscapeCsvField(GetCategoriaDescripcion(p.TipoProducto));
            var subcategoria = EscapeCsvField(GetSubcategoriaDescripcion(p.Idsubtipo));
            var sucursal = EscapeCsvField(!string.IsNullOrWhiteSpace(p.NombreSucursal) ? p.NombreSucursal : GetSucursalDescripcion(p.Idsucursal));
            var aplicaIva = p.Codigoimpuesto == "2" ? "SI" : "NO";
            var ivaObj = porcentajesIva.FirstOrDefault(i => i.Codigo == p.Porcentajeimpuesto);
            var tarifaIva = ivaObj != null ? ivaObj.Valor : (p.Porcentajeimpuesto ?? string.Empty);
            var observacion = EscapeCsvField(p.Observacion ?? string.Empty);

            sb.AppendLine($"{codigo};{nombre};{tipo};{precioBase};{precio2};{precio3};{categoria};{subcategoria};{sucursal};{aplicaIva};{tarifaIva};{observacion}");
        }

        await JS.InvokeVoidAsync(
            "numericaUi.downloadTextFile",
            $"Productos_{DateTime.Now:yyyyMMdd_HHmmss}.csv",
            "\uFEFF" + sb.ToString(),
            "text/csv;charset=utf-8");
    }

    private static string EscapeCsvField(string field, bool forceExcelText = false)
    {
        if (string.IsNullOrEmpty(field)) return forceExcelText ? "=\"\"" : string.Empty;

        if (forceExcelText)
        {
            var cleanField = field.Replace("\"", "\"\"");
            return $"=\"{cleanField}\"";
        }

        if (field.Contains(";") || field.Contains("\"") || field.Contains("\n") || field.Contains("\r"))
        {
            return "\"" + field.Replace("\"", "\"\"") + "\"";
        }

        return field;
    }

    private IEnumerable<ProductoDto> ProductosPaginados =>
        ProductosFiltrados
            .Skip((currentPage - 1) * CurrentPageSize)
            .Take(CurrentPageSize);

    private int CurrentTotalRecords => ProductosFiltrados.Count();
    private int CurrentTotalPages => Math.Max(1, (int)Math.Ceiling(CurrentTotalRecords / (double)CurrentPageSize));
    private int CurrentPageStart => CurrentTotalRecords == 0 ? 0 : ((currentPage - 1) * CurrentPageSize) + 1;
    private int CurrentPageEnd => CurrentTotalRecords == 0 ? 0 : Math.Min(CurrentTotalRecords, currentPage * CurrentPageSize);

