    private async Task ResetearPassword(Usuario u)
    {
        const string passDefault = "00000000";
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Resetear contrasena de {u.Nombres} a '{passDefault}'?");
        if (!confirm)
        {
            return;
        }

        var codigoAcceso = string.Empty;

        try
        {
            const int minutosExpira = RecoveryCodeHelper.MinutosExpiracionPorDefecto;
            codigoAcceso = RecoveryCodeHelper.GenerarCodigoNumerico();

            await using var context = await DbFactory.CreateDbContextAsync();
            var usuarioDb = await context.Usuarios.FindAsync(u.IdUsuario);

            if (usuarioDb == null)
            {
                await JS.ShowAlertAsync("No se pudo completar", "No se encontro el usuario para resetear la contrasena.", "warning");
                return;
            }

            usuarioDb.PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(passDefault);
            usuarioDb.ClaveTemporal = true;
            usuarioDb.CuentaBloqueada = false;
            usuarioDb.IntentosFallidos = 0;
            usuarioDb.FechaDesbloqueo = null;
            usuarioDb.FechaExpiracionToken = DateTime.Now.AddMinutes(minutosExpira);
            usuarioDb.TokenRecuperacion = Simetric.Components.Helpers.SecurityHelper.HashPassword(codigoAcceso);

            await context.SaveChangesAsync();
            await EmailService.EnviarClaveTemporal(usuarioDb.Email, codigoAcceso, minutosExpira, "Reseteo de contrasena por administrador");
            await JS.ShowAlertAsync(
                "Contrasena restablecida",
                "El usuario debe ingresar con '00000000' y usar el codigo enviado al correo para cambiarla.",
                "success");
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync(
                "Correo no enviado",
                $"La contrasena se cambio a '{passDefault}', pero no se pudo enviar el correo. Codigo manual: {codigoAcceso}. Error: {ex.Message}",
                "warning");
        }
        finally
        {
            await LoadData();
        }
    }

    private async Task Guardar()
    {
        errorFormularioUsuario = ValidarFormularioUsuario();
        if (!string.IsNullOrWhiteSpace(errorFormularioUsuario))
        {
            return;
        }

        if (tempUser.IdUsuario == 0)
        {
            tempUser.PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(nuevaClave.Trim());
            tempUser.IdTipoUsuario = tempUser.IdTipoUsuario is > 0
                ? tempUser.IdTipoUsuario
                : TipoUsuarioSistemaPredeterminado;
        }

        await UserService.SaveUsuarioAsync(tempUser);

        if (rolSeleccionadoId > 0)
        {
            var rolGuardado = await AdministracionService.AsignarEContaxRolAUsuarioAsync(tempUser.IdUsuario, rolSeleccionadoId);
            if (!rolGuardado)
            {
                errorFormularioUsuario = "El usuario se guardo, pero no se pudo asignar el rol E-Contax.";
                return;
            }
        }

        try
        {
            await OrganizacionService.AsignarUsuarioAsync(
                currentUserId,
                tempUser.IdUsuario,
                empresaSeleccionadaId,
                sucursalSeleccionadaId > 0 ? sucursalSeleccionadaId : null);
        }
        catch (Exception ex)
        {
            errorFormularioUsuario = $"El usuario se guardo, pero no se pudo asignar empresa/sucursal. {ex.Message}";
            return;
        }

        if (tempUser.IdUsuario > 0 && cajaUsuarioEditando != null)
        {
            try
            {
                await UserService.GuardarSerieCajaUsuarioAsync(tempUser.IdUsuario, serieCajaUsuarioInput);
            }
            catch (Exception ex)
            {
                errorFormularioUsuario = ex.Message;
                return;
            }
        }

        var idUsuarioGuardado = tempUser.IdUsuario;
        await RefrescarSesionActualSiCorrespondeAsync(idUsuarioGuardado);
        showModal = false;
        errorFormularioUsuario = null;
        await LoadData();
        mensajeEstado = "Usuario guardado correctamente.";
        MenuStateService.NotifyMenuChanged();
        StateHasChanged();
    }

    private async Task RefrescarSesionActualSiCorrespondeAsync(int idUsuario)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claimIdUsuario = authState.User.FindFirst("IdUsuario")?.Value;

        if (!int.TryParse(claimIdUsuario, out var idUsuarioActual) || idUsuarioActual != idUsuario)
        {
            return;
        }

        var usuarioActualizado = await UserService.GetUsuarioByIdAsync(idUsuario);
        if (usuarioActualizado is null)
        {
            return;
        }

        if (AuthStateProvider is CustomAuthStateProvider authProvider)
        {
            await authProvider.UpdateAuthenticationState(usuarioActualizado);
        }
    }

