    private bool EsRolJefeEmpresa(int idRol)
    {
        var nombre = rolesEContax.FirstOrDefault(item => item.IdRol == idRol)?.NombreRol;
        return EContaxTenantService.EsRolJefeEmpresa(nombre);
    }

    private async Task<bool> ValidarAccesoEContaxAsync(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        currentUserId = int.TryParse(user.FindFirst("IdUsuario")?.Value, out var userId) ? userId : 0;
        if (currentUserId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(currentUserId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

