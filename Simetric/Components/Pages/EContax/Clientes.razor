    private async Task CargarTodo(bool esRefresco = false)
    {
        cargando = true;
        mensaje = null;
        debugError = null;

        try
        {
            await CargarLookupsClientes();
            await CargarPaises();
            await CargarUbicacionEcuador();

            if (!model.Pais.HasValue && ecuadorPaisId.HasValue)
                model.Pais = ecuadorPaisId;

            var resp = await Http.GetAsync($"api/e-contax/clientes?userId={usuarioLogueadoId}");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
                throw new Exception($"CLIENTES -> HTTP {(int)resp.StatusCode}: {body}");

            var data = System.Text.Json.JsonSerializer.Deserialize<List<ClienteDto>>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            clientes = data ?? new();

            await PrepararLookupsUbicacionParaListado();

            if (esRefresco) mensaje = "Datos actualizados correctamente.";
            dbName = $"API ({Http.BaseAddress})";
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
            mensaje = "Falló la carga de datos.";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task PrepararLookupsUbicacionParaListado()
    {
        var paisIds = clientes.Where(x => x.Pais.HasValue).Select(x => x.Pais!.Value).Distinct().ToList();
        foreach (var pid in paisIds)
        {
            if (!provincias.Any(p => p.IdPais == pid))
                await CargarProvincias(pid);
        }

        var provIds = clientes.Where(x => x.Provincia.HasValue).Select(x => x.Provincia!.Value).Distinct().ToList();
        foreach (var prId in provIds)
        {
            if (!ciudades.Any(c => c.IdProvincia == prId))
                await CargarCiudades(prId);
        }
    }

