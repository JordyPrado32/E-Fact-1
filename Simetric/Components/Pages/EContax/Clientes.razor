        paginaActual = 1;
    }

    private int TotalRegistrosFiltrados => ClientesFiltrados.Count();

    private int TotalPaginasClientes => Math.Max(1, (int)Math.Ceiling(TotalRegistrosFiltrados / (double)registrosPorPagina));

    private int PaginaActualNormalizada
    {
        get
        {
            if (paginaActual < 1)
                paginaActual = 1;

            var totalPaginas = TotalPaginasClientes;
            if (paginaActual > totalPaginas)
                paginaActual = totalPaginas;

            return paginaActual;
        }
    }

    private IEnumerable<ClienteDto> ClientesPaginados =>
        ClientesFiltrados
            .Skip((PaginaActualNormalizada - 1) * registrosPorPagina)
            .Take(registrosPorPagina);

    private void CambiarPagina(int nuevaPagina)
    {
        paginaActual = Math.Clamp(nuevaPagina, 1, TotalPaginasClientes);
    }

    private IEnumerable<ClienteDto> ClientesFiltrados
    {
        get
        {
            var query = clientes.AsEnumerable();

            if (filtroTipoCliente != 0)
                query = query.Where(c => c.TipoCliente == filtroTipoCliente);

            if (!string.IsNullOrWhiteSpace(filtro))
            {
                query = query.Where(c =>
                    ($"{c.Apellidos} {c.Nombres}".Trim()).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    (c.Numeroidentificacion ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    (c.Correo ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    (c.Nombrecomercial ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                    (c.Nombrerazonsocial ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase));
            }

            return query;
        }
    }

    private static string ObtenerNombreComercialCliente(ClienteDto cliente)
    {
        if (!string.IsNullOrWhiteSpace(cliente.Nombrecomercial))
            return cliente.Nombrecomercial;

        return string.Empty;
    }

    private string GetNombreCompletoCliente(ClienteDto cliente)
    {
        var nombreCompleto = $"{cliente.Apellidos} {cliente.Nombres}".Trim();
        var razonSocial = (cliente.Nombrerazonsocial ?? string.Empty).Trim();
        var nombreComercial = (cliente.Nombrecomercial ?? string.Empty).Trim();

        if (EsTipoClienteEmpresa(cliente.TipoCliente))
        {
            if (!string.IsNullOrWhiteSpace(razonSocial))
                return razonSocial;

            if (!string.IsNullOrWhiteSpace(nombreComercial))
                return nombreComercial;
        }
        else if (!string.IsNullOrWhiteSpace(nombreCompleto))
        {
            return nombreCompleto;
        }

        return !string.IsNullOrWhiteSpace(nombreCompleto)
            ? nombreCompleto
            : !string.IsNullOrWhiteSpace(razonSocial)
                ? razonSocial
                : $"Cliente #{cliente.Codcliente}";
    }

    private string ObtenerNombreSecundarioCliente(ClienteDto cliente)
    {
        if (!EsTipoClienteEmpresa(cliente.TipoCliente))
            return string.Empty;

        var nombreComercial = (cliente.Nombrecomercial ?? string.Empty).Trim();
        var razonSocial = (cliente.Nombrerazonsocial ?? string.Empty).Trim();

        if (!string.IsNullOrWhiteSpace(nombreComercial) &&
            !string.Equals(nombreComercial, razonSocial, StringComparison.OrdinalIgnoreCase))
        {
            return nombreComercial;
        }

        return string.Empty;
    }

    private string GetTipoClienteDescripcion(int tipoCliente)
    {
        if (tipoCliente <= 0) return "Sin tipo de cliente";
        var descripcion = tiposCliente.FirstOrDefault(t => t.TclCodigo == tipoCliente)?.Descripcion;
        return string.IsNullOrWhiteSpace(descripcion)
