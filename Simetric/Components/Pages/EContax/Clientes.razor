    private async Task OnNumeroIdentificacionChangedAsync(ChangeEventArgs args)
    {
        model.Numeroidentificacion = NormalizarNumeroIdentificacionEntrada(args.Value?.ToString());

        consultaCedulaCts?.Cancel();
        consultaCedulaCts?.Dispose();
        consultaCedulaCts = null;

        if (EsTipoIdentificacionConsultaExternaSeleccionado &&
            model.Numeroidentificacion.Length is 10 or 13)
        {
            var cts = new CancellationTokenSource();
            consultaCedulaCts = cts;

            try
            {
                await Task.Delay(250, cts.Token);
                await ConsultarCedulaSiAplicaAsync(cts.Token);
            }
            catch (OperationCanceledException)
            {
            }
            finally
            {
                if (ReferenceEquals(consultaCedulaCts, cts))
                {
                    consultaCedulaCts.Dispose();
                    consultaCedulaCts = null;
                }
            }
        }
    }

    private async Task OnNumeroIdentificacionBlurAsync(FocusEventArgs _)
    {
        model.Numeroidentificacion = NormalizarNumeroIdentificacionEntrada(model.Numeroidentificacion);
        consultaCedulaCts?.Cancel();
        await ConsultarCedulaSiAplicaAsync();
    }

    private async Task ConsultarCedulaSiAplicaAsync(CancellationToken cancellationToken = default)
    {
        if (consultandoCedula)
            return;

        if (!EsTipoIdentificacionConsultaExternaSeleccionado)
        {
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            return;
        }

        var identificacion = new string((model.Numeroidentificacion ?? string.Empty).Where(char.IsDigit).ToArray());
        model.Numeroidentificacion = identificacion;

        if (identificacion.Length is not (10 or 13))
        {
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            return;
        }

        if (string.Equals(ultimaCedulaConsultada, identificacion, StringComparison.Ordinal))
            return;

        consultandoCedula = true;
        mensajeConsultaCedula = null;
        consultaCedulaEsError = false;

        try
        {
            using var response = await Http.GetAsync(
                $"api/e-contax/clientes/consulta-identificacion?identificacion={identificacion}",
                cancellationToken);
            response.EnsureSuccessStatusCode();

            var resultado = await response.Content.ReadFromJsonAsync<ConsultaCedulaDto>(cancellationToken: cancellationToken);
            ultimaCedulaConsultada = identificacion;

            if (resultado?.Found == true)
            {
                AplicarDatosCedula(resultado);
                mensajeConsultaCedula = "Datos encontrados. Revisa la información, completa lo faltante y guarda.";
                consultaCedulaEsError = false;
                return;
            }

            mensajeConsultaCedula = resultado?.Mensaje ?? "No se encontraron datos automáticos para esta cédula.";
            consultaCedulaEsError = false;
        }
        catch (Exception ex)
        {
            debugError = (debugError is null) ? ex.Message : $"{debugError} || {ex.Message}";
            mensajeConsultaCedula = "No se pudo consultar la cédula ahora. Puedes completar los datos manualmente.";
            consultaCedulaEsError = true;
        }
        finally
        {
            consultandoCedula = false;
        }
    }

    private void AplicarDatosCedula(ConsultaCedulaDto resultado)
    {
        if (string.Equals(resultado.Tipo, "ruc", StringComparison.OrdinalIgnoreCase))
        {
            var esNatural = (resultado.TipoContribuyente ?? string.Empty).Contains("NATURAL", StringComparison.OrdinalIgnoreCase);

            if (model.TipoCliente <= 0)
            {
                var tipo = tiposCliente.FirstOrDefault(x => esNatural
                    ? TipoClienteClasificacion.EsNatural(x.Descripcion)
                    : TipoClienteClasificacion.EsJuridica(x.Descripcion));

                if (tipo is not null)
                    model.TipoCliente = tipo.TclCodigo;
            }

            ActualizarTipoClienteForm();
            model.Oblgconta = NormalizarObligadoContabilidad(resultado.ObligadoLlevarContabilidad);

            if (esNatural && !EsEmpresaSeleccionada)
            {
                var (apellidosNatural, nombresNatural) = SepararNombreCompleto(resultado.NombreCompleto);
                model.Apellidos = apellidosNatural;
                model.Nombres = nombresNatural;
                model.Nombrecomercial = null;
                model.Nombrerazonsocial = null;
                return;
            }

            model.Nombrerazonsocial = resultado.RazonSocial?.Trim();
            model.Nombrecomercial = resultado.RazonSocial?.Trim();
            model.Apellidos = null;
            model.Nombres = null;
            return;
        }

        if (model.TipoCliente <= 0)
        {
            var tipoPersona = tiposCliente.FirstOrDefault(x => TipoClienteClasificacion.EsNatural(x.Descripcion));
            if (tipoPersona is not null)
                model.TipoCliente = tipoPersona.TclCodigo;
        }

        ActualizarTipoClienteForm();

        if (EsEmpresaSeleccionada)
            return;

        var (apellidos, nombres) = SepararNombreCompleto(resultado.NombreCompleto);
        model.Apellidos = apellidos;
        model.Nombres = nombres;
        model.Oblgconta = "NO";
        if (string.IsNullOrWhiteSpace(model.Direccion))
            model.Direccion = NormalizarLugarNacimiento(resultado.LugarNacimiento);
        model.Nombrecomercial = null;
        model.Nombrerazonsocial = null;
    }

    private static (string? Apellidos, string? Nombres) SepararNombreCompleto(string? nombreCompleto)
    {
        var partes = (nombreCompleto ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (partes.Length == 2)
            return (partes[0], partes[1]);

        if (partes.Length == 3)
            return (string.Join(" ", partes.Take(2)), partes[2]);

        if (partes.Length >= 4)
            return (string.Join(" ", partes.Take(2)), string.Join(" ", partes.Skip(2)));

        if (partes.Length == 1)
            return (partes[0], null);

        return (null, null);
    }

    private async Task PrepararLookupsUbicacionFormularioAsync()
    {
        if (model.Pais is not null && model.Pais > 0 && model.Pais != ecuadorPaisId)
            await CargarProvincias(model.Pais.Value);

        if (model.Provincia is not null && model.Provincia > 0)
            await CargarCiudades(model.Provincia.Value);
    }

    private static string NormalizarObligadoContabilidad(string? valor)
    {
        var normalizado = (valor ?? string.Empty).Trim().ToUpperInvariant();
        return normalizado is "SI" or "NO" ? normalizado : string.Empty;
    }

    private void AsegurarTipoIdentificacionCompatible()
    {
        if (model.Tipoidentificacion.HasValue &&
            !IdentificacionesDisponibles.Any(x => x.Id == model.Tipoidentificacion.Value))
        {
            model.Tipoidentificacion = null;
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            ultimaCedulaConsultada = null;
        }
    }

    private bool EsIdentificacionPermitidaPorTipoCliente(IdentificacionDto identificacion)
    {
        if (!TieneTipoClienteSeleccionado)
            return true;

        if (EsEmpresaSeleccionada)
            return EsIdentificacionRuc(identificacion);

        return EsIdentificacionCedula(identificacion) ||
               EsIdentificacionRuc(identificacion) ||
               EsIdentificacionPasaporte(identificacion);
    }

    private static bool EsIdentificacionCedula(IdentificacionDto? identificacion)
    {
        if (identificacion is null)
            return false;

        return string.Equals(identificacion.Codigo, "05", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("cédula", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("cedula", StringComparison.OrdinalIgnoreCase);
    }

    private static bool EsIdentificacionRuc(IdentificacionDto? identificacion)
    {
        if (identificacion is null)
            return false;

        return string.Equals(identificacion.Codigo, "04", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("RUC", StringComparison.OrdinalIgnoreCase);
    }

    private static bool EsIdentificacionPasaporte(IdentificacionDto? identificacion)
    {
        if (identificacion is null)
            return false;

        return string.Equals(identificacion.Codigo, "06", StringComparison.OrdinalIgnoreCase) ||
               identificacion.Descripcion.Contains("pasaporte", StringComparison.OrdinalIgnoreCase);
    }

    private string NormalizarNumeroIdentificacionEntrada(string? valor)
    {
        var limpio = (valor ?? string.Empty).Trim();

        if (EsIdentificacionPasaporteSeleccionada)
            return new string(limpio.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();

        return new string(limpio.Where(char.IsDigit).ToArray());
    }

    private static string? NormalizarLugarNacimiento(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return null;

        return valor
            .Replace("/", ", ", StringComparison.Ordinal)
            .Trim();
    }

    private void VerCliente(ClienteDto cliente)
    {
        clienteEnVista = cliente;
    }

    private void CerrarVistaCliente()
    {
        clienteEnVista = null;
    }

    private void ConfirmarEliminar(ClienteDto c)
    {
        clienteAEliminar = c;
        mostrarConfirmacion = true;
    }

    private void CancelarEliminar()
    {
        mostrarConfirmacion = false;
        clienteAEliminar = null;
    }

    private async Task EliminarConfirmado()
    {
        if (clienteAEliminar is null) return;

        try
        {
            var resp = await Http.PutAsync($"api/e-contax/clientes/{clienteAEliminar.Codcliente}/desactivar?userId={usuarioLogueadoId}", null);

            if (!resp.IsSuccessStatusCode)
            {
                var detalle = await resp.Content.ReadAsStringAsync();
                mensaje = $"No se pudo desactivar: {(int)resp.StatusCode}";
                debugError = detalle;
                return;
            }

            mensaje = "Cliente desactivado (eliminación lógica).";
            await CargarTodo();
            CancelarEliminar();
        }
        catch (Exception ex)
        {
            debugError = $"{ex.Message} | INNER: {ex.InnerException?.Message}";
            mensaje = "No se pudo desactivar (API).";
        }
    }
