        await CargarTodo();
    }

    private async Task CargarLookupsClientes()
    {
        try
        {
            var respLook = await Http.GetAsync("api/e-contax/clientes/lookups");
            var bodyLook = await respLook.Content.ReadAsStringAsync();

            if (!respLook.IsSuccessStatusCode)
                throw new Exception($"LOOKUPS -> HTTP {(int)respLook.StatusCode}: {bodyLook}");

            using var doc = System.Text.Json.JsonDocument.Parse(bodyLook);

            tiposCliente = new();
            if (doc.RootElement.TryGetProperty("tipos", out var tiposElem) &&
                tiposElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var t in tiposElem.EnumerateArray())
                {
                    var codigo = t.TryGetProperty("tclCodigo", out var c) ? c.GetInt32() : 0;
                    var desc = t.TryGetProperty("descripcion", out var d) ? d.GetString() ?? "" : "";
                    tiposCliente.Add(new TipoClienteDto { TclCodigo = codigo, Descripcion = desc });
                }
            }

            paises = new();
            if (doc.RootElement.TryGetProperty("paises", out var paisesElem) &&
                paisesElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var p in paisesElem.EnumerateArray())
                {
                    var idPais = p.TryGetProperty("idPais", out var pid) ? pid.GetInt32() : 0;
                    var desc = p.TryGetProperty("descripcion", out var pd) ? pd.GetString() ?? "" : "";
                    paises.Add(new PaisLookupDto { IdPais = idPais, Descripcion = desc });
                }
            }

            ActualizarPaisEcuadorId();

            identificaciones = new();
            if (doc.RootElement.TryGetProperty("identificaciones", out var idElem) &&
                idElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var i in idElem.EnumerateArray())
                {
                    var ideSec = i.TryGetProperty("ideSec", out var sid) ? sid.GetInt32() : 0;
                    var ideCodigo = i.TryGetProperty("ideCodigo", out var scod) ? scod.GetString() ?? "" : "";
                    var ideDescripcion = i.TryGetProperty("ideDescripcion", out var sdesc) ? sdesc.GetString() ?? "" : "";
                    identificaciones.Add(new IdentificacionDto
                    {
                        Id = ideSec,
                        Codigo = ideCodigo,
                        Descripcion = ideDescripcion
                    });
                }
            }
        }
        catch (Exception exLook)
        {
            debugError = (debugError is null) ? exLook.Message : debugError + " || " + exLook.Message;
        }
    }

    private async Task<bool> ValidarAccesoEContaxAsync(ClaimsPrincipal user)
    {
        if (!IsEContaxPath(NavManager.Uri))
            return true;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var userId = ObtenerIdUsuario(user);
        if (userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private bool IsEContaxPath(string location) => EContaxRoutes.IsEContaxPath(NavManager, location);

    private async Task CargarPaises()
    {
        try
        {
            if (paises.Any())
            {
                ActualizarPaisEcuadorId();
                return;
            }

            var resp = await Http.GetAsync("api/e-contax/clientes/lookups");
            var body = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
                throw new Exception($"PAISES -> HTTP {(int)resp.StatusCode}: {body}");

            using var doc = System.Text.Json.JsonDocument.Parse(body);
            paises = new();

            if (doc.RootElement.TryGetProperty("paises", out var paisesElem) &&
                paisesElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var p in paisesElem.EnumerateArray())
                {
                    var idPais = p.TryGetProperty("idPais", out var pid) ? pid.GetInt32() : 0;
                    var desc = p.TryGetProperty("descripcion", out var pd) ? pd.GetString() ?? "" : "";
                    paises.Add(new PaisLookupDto { IdPais = idPais, Descripcion = desc });
                }
            }

            ecuadorPaisId = paises
                .FirstOrDefault(p => string.Equals(p.Descripcion?.Trim(), "ECUADOR", StringComparison.OrdinalIgnoreCase))
                ?.IdPais;
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private void ActualizarPaisEcuadorId()
    {
        ecuadorPaisId = paises
            .FirstOrDefault(p => string.Equals(p.Descripcion?.Trim(), "ECUADOR", StringComparison.OrdinalIgnoreCase))
            ?.IdPais;
    }

    private async Task CargarUbicacionEcuador()
    {
        try
        {
            if (ecuadorPaisId is null || ecuadorPaisId <= 0)
                return;

            var resp = await Http.GetAsync("api/e-contax/clientes/ubicacion-ecuador");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
                throw new Exception($"UBICACION ECUADOR -> HTTP {(int)resp.StatusCode}: {body}");

            using var doc = System.Text.Json.JsonDocument.Parse(body);

            if (doc.RootElement.TryGetProperty("provincias", out var provinciasElem) &&
                provinciasElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in provinciasElem.EnumerateArray())
                {
                    var idProvincia = item.TryGetProperty("idProvincia", out var idProp) ? idProp.GetInt32() : 0;
                    if (idProvincia <= 0 || provincias.Any(p => p.IdProvincia == idProvincia))
                        continue;

                    provincias.Add(new ProvinciaLookupDto
                    {
                        IdProvincia = idProvincia,
                        Descripcion = item.TryGetProperty("descripcion", out var descProp) ? descProp.GetString() ?? "" : "",
                        IdPais = item.TryGetProperty("idPais", out var paisProp) ? paisProp.GetInt32() : ecuadorPaisId
                    });
                }
            }

            OrdenarProvinciasEcuador();

            if (doc.RootElement.TryGetProperty("ciudades", out var ciudadesElem) &&
                ciudadesElem.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in ciudadesElem.EnumerateArray())
                {
                    var idCiudad = item.TryGetProperty("idCiudad", out var idProp) ? idProp.GetInt32() : 0;
                    if (idCiudad <= 0 || ciudades.Any(c => c.IdCiudad == idCiudad))
                        continue;

                    ciudades.Add(new CiudadLookupDto
                    {
                        IdCiudad = idCiudad,
                        Descripcion = item.TryGetProperty("descripcion", out var descProp) ? descProp.GetString() ?? "" : "",
                        IdProvincia = item.TryGetProperty("idProvincia", out var provProp) ? provProp.GetInt32() : null
                    });
                }
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private void OrdenarProvinciasEcuador()
    {
        if (ecuadorPaisId is null || ecuadorPaisId <= 0)
            return;

        var ordenCatalogo = CatalogoUbicacionEcuador.Provincias
            .Select((provincia, index) => new { provincia.Nombre, index })
            .ToDictionary(x => NormalizarClaveUbicacion(x.Nombre), x => x.index);

        provincias = provincias
            .OrderBy(p =>
            {
                if (p.IdPais != ecuadorPaisId)
                    return int.MaxValue - 1;

                var clave = NormalizarClaveUbicacion(p.Descripcion);
                return ordenCatalogo.TryGetValue(clave, out var orden) ? orden : int.MaxValue;
            })
            .ThenBy(p => p.Descripcion)
            .ToList();
    }

    private int GetOrdenProvincia(ProvinciaLookupDto provincia)
    {
        if (provincia.IdPais != ecuadorPaisId)
            return int.MaxValue;

        var clave = NormalizarClaveUbicacion(provincia.Descripcion);
        var indice = 0;
        foreach (var item in CatalogoUbicacionEcuador.Provincias)
        {
            if (NormalizarClaveUbicacion(item.Nombre) == clave)
                return indice;

            indice++;
        }

        return int.MaxValue;
    }

    private static string NormalizarClaveUbicacion(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return string.Empty;

        var normalizado = valor.Trim().Normalize(System.Text.NormalizationForm.FormD);
        var builder = new System.Text.StringBuilder(normalizado.Length);

        foreach (var caracter in normalizado)
        {
            if (System.Globalization.CharUnicodeInfo.GetUnicodeCategory(caracter) != System.Globalization.UnicodeCategory.NonSpacingMark)
                builder.Append(char.ToUpperInvariant(caracter));
        }

        return builder.ToString();
    }

    private async Task CargarProvincias(int paisId)
    {
        try
        {
            if (provincias.Any(p => p.IdPais == paisId))
                return;

            var resp = await Http.GetAsync($"api/e-contax/clientes/provincias?paisId={paisId}");
            var body = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
                throw new Exception($"PROVINCIAS -> HTTP {(int)resp.StatusCode}: {body}");

            var data = System.Text.Json.JsonSerializer.Deserialize<List<ProvinciaLookupDto>>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            var nuevas = data ?? new();
            foreach (var x in nuevas)
            {
                x.IdPais = paisId;
                if (!provincias.Any(p => p.IdProvincia == x.IdProvincia))
                    provincias.Add(x);
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private async Task CargarCiudades(int provinciaId)
    {
        try
        {
            if (ciudades.Any(c => c.IdProvincia == provinciaId))
                return;

            var resp = await Http.GetAsync($"api/e-contax/clientes/ciudades?provinciaId={provinciaId}");
            var body = await resp.Content.ReadAsStringAsync();
            if (!resp.IsSuccessStatusCode)
                throw new Exception($"CIUDADES -> HTTP {(int)resp.StatusCode}: {body}");

            var data = System.Text.Json.JsonSerializer.Deserialize<List<CiudadLookupDto>>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            var nuevas = data ?? new();
            foreach (var x in nuevas)
            {
                x.IdProvincia = provinciaId;
                if (!ciudades.Any(c => c.IdCiudad == x.IdCiudad))
                    ciudades.Add(x);
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
    }

    private async Task OnPaisChangedAsync()
    {
        model.Provincia = null;
        model.Ciudad = null;

        if (!model.Pais.HasValue || model.Pais <= 0)
        {
            model.Pais = null;
            return;
        }

        if (model.Pais != ecuadorPaisId)
            await CargarProvincias(model.Pais.Value);
    }

    private async Task OnProvinciaChangedAsync()
    {
        model.Ciudad = null;

        if (!model.Provincia.HasValue || model.Provincia <= 0)
        {
            model.Provincia = null;
            return;
        }

        if (model.Pais != ecuadorPaisId)
            await CargarCiudades(model.Provincia.Value);
