    private async Task Editar(int id)
    {
        mensaje = "Cargando cliente...";
        debugError = null;
        clienteEnVista = null;

        try
        {
            if (paises.Count == 0) await CargarPaises();
            if (tiposCliente.Count == 0 || identificaciones.Count == 0) await CargarLookupsClientes();
            await CargarUbicacionEcuador();

            var resp = await Http.GetAsync($"api/e-contax/clientes/{id}?userId={usuarioLogueadoId}");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                mensaje = $"No se pudo cargar el cliente (HTTP {(int)resp.StatusCode}).";
                debugError = body;
                return;
            }

            var item = System.Text.Json.JsonSerializer.Deserialize<ClienteDto>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (item is null)
            {
                mensaje = "Respuesta vacía al cargar cliente.";
                debugError = body;
                return;
            }

            // Mapeo al modelo de edición
            model = new ClienteUpsertDto
            {
                Codcliente = item.Codcliente,
                Apellidos = item.Apellidos,
                Nombres = item.Nombres,
                Nombrecomercial = item.Nombrecomercial,
                Nombrerazonsocial = item.Nombrerazonsocial,
                Tipoidentificacion = item.Tipoidentificacion,
                Numeroidentificacion = item.Numeroidentificacion,
                Direccion = item.Direccion,
                Telefonoconvencional = item.Telefonoconvencional,
                Celular = item.Celular,
                Correo = item.Correo, // Principal

                CorreosAdicionales = item.CorreosAdicionales != null
                    ? item.CorreosAdicionales.Where(correo => !string.IsNullOrWhiteSpace(correo)).ToList()
                    : new List<string>(),

                Oblgconta = NormalizarObligadoContabilidad(item.Oblgconta),
                TipoCliente = item.TipoCliente,
                Estado = item.Estado,
                Observaciones = item.Observaciones,
                Pais = item.Pais is > 0 ? item.Pais : ecuadorPaisId,
                Provincia = item.Provincia is > 0 ? item.Provincia : null,
                Ciudad = item.Ciudad is > 0 ? item.Ciudad : null,
                EsTipoEmpresa = EsTipoClienteEmpresa(item.TipoCliente)
            };

            await PrepararLookupsUbicacionFormularioAsync();
            ActualizarTipoClienteForm();

            estadoAux = model.Estado ?? true;
            mensajeConsultaCedula = null;
            consultaCedulaEsError = false;
            ultimaCedulaConsultada = null;
            editando = true;
            formKey = Guid.NewGuid();
            mensaje = "Cliente cargado para edición.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            debugError = $"{ex.Message} | INNER: {ex.InnerException?.Message}";
            mensaje = "Error al cargar cliente.";
        }
    }

    private async Task Guardar()
    {
        mensaje = "Guardando...";
        debugError = null;
        model.Estado = estadoAux;
        ActualizarTipoClienteForm();

        model.Apellidos = model.Apellidos?.Trim();
        model.Nombres = model.Nombres?.Trim();
        model.Nombrecomercial = model.Nombrecomercial?.Trim();
        model.Nombrerazonsocial = model.Nombrerazonsocial?.Trim();
        model.Numeroidentificacion = model.Numeroidentificacion?.Trim();
        model.Direccion = model.Direccion?.Trim();
        model.Telefonoconvencional = model.Telefonoconvencional?.Trim();
        model.Celular = model.Celular?.Trim();
        model.Correo = model.Correo?.Trim();
        model.CorreosAdicionales = model.CorreosAdicionales
            .Select(correo => correo?.Trim() ?? string.Empty)
            .Where(correo => !string.IsNullOrWhiteSpace(correo))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        model.Oblgconta = model.Oblgconta?.Trim().ToUpperInvariant();
        model.Observaciones = model.Observaciones?.Trim();

        if (EsEmpresaSeleccionada)
        {
            model.Apellidos = null;
            model.Nombres = null;
        }
        else
        {
            model.Nombrecomercial = null;
            model.Nombrerazonsocial = null;
        }

        try
        {
            HttpResponseMessage resp = !editando
                ? await Http.PostAsJsonAsync($"api/e-contax/clientes?userId={usuarioLogueadoId}", model)
                : await Http.PutAsJsonAsync($"api/e-contax/clientes/{model.Codcliente}?userId={usuarioLogueadoId}", model);

            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                mensaje = $"Error API: {(int)resp.StatusCode}";
                debugError = body;
                return;
            }

            mensaje = editando ? "Cliente actualizado correctamente." : "Cliente creado correctamente.";
            debugError = null;

            await CargarTodo();
            Nuevo();
        }
        catch (Exception ex)
        {
            debugError = $"{ex.Message} | INNER: {ex.InnerException?.Message}";
            mensaje = "Error al guardar cliente.";
        }
    }

    private bool TieneTipoClienteSeleccionado => model.TipoCliente > 0;

    private bool EsPersonaSeleccionada => TieneTipoClienteSeleccionado && !EsEmpresaSeleccionada;

    private bool EsEmpresaSeleccionada => TieneTipoClienteSeleccionado && EsTipoClienteEmpresa(model.TipoCliente);
    private bool UsaDiasCreditoPersonalizado =>
        model.DiasCredito.HasValue && !diasCreditoOpciones.Contains(model.DiasCredito.Value);

    private IEnumerable<IdentificacionDto> IdentificacionesDisponibles =>
        identificaciones.Where(EsIdentificacionPermitidaPorTipoCliente);

    private bool DebeMostrarObligadoContabilidad =>
        EsEmpresaSeleccionada || EsIdentificacionRucSeleccionada;

    private bool EsIdentificacionRucSeleccionada =>
        model.Tipoidentificacion.HasValue &&
        EsIdentificacionRuc(identificaciones.FirstOrDefault(x => x.Id == model.Tipoidentificacion.Value));

    private bool EsIdentificacionPasaporteSeleccionada =>
        model.Tipoidentificacion.HasValue &&
        EsIdentificacionPasaporte(identificaciones.FirstOrDefault(x => x.Id == model.Tipoidentificacion.Value));

    private bool EsTipoIdentificacionConsultaExternaSeleccionado
    {
        get
        {
            if (!model.Tipoidentificacion.HasValue)
                return false;

            var identificacion = identificaciones.FirstOrDefault(x => x.Id == model.Tipoidentificacion.Value);
            if (identificacion is null)
                return false;

            return string.Equals(identificacion.Codigo, "05", StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(identificacion.Codigo, "04", StringComparison.OrdinalIgnoreCase) ||
                   identificacion.Descripcion.Contains("cédula", StringComparison.OrdinalIgnoreCase) ||
                   identificacion.Descripcion.Contains("cedula", StringComparison.OrdinalIgnoreCase) ||
                   identificacion.Descripcion.Contains("RUC", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool EsTipoClienteEmpresa(int tipoCliente)
    {
        if (tipoCliente <= 0)
            return false;

        var desc = tiposCliente.FirstOrDefault(t => t.TclCodigo == tipoCliente)?.Descripcion;
        return TipoClienteClasificacion.EsJuridica(desc);
    }

