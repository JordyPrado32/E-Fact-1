    private void EditarMenuMaestro(EContaxMenu menu)
    {
        LimpiarEstadoOperacion();

        if (EsMenuProtegido(menu))
        {
            errorEstado = ObtenerMensajeProteccion(menu);
            return;
        }

        menuErrors.Clear();
        isSavingMenu = false;
        menuModel = ClonarMenu(menu);
        showModalMenu = true;
    }

    private void VerDetalleMenu(EContaxMenu menu)
    {
        menuDetalle = ClonarMenu(menu);
        showModalMenuDetail = true;
    }

    private async Task GuardarMenuMaestro()
    {
        if (isSavingMenu)
        {
            return;
        }

        LimpiarEstadoOperacion();
        menuErrors.Clear();

        if (menuModel.IdMenu != 0 && EsMenuProtegido(menuModel.IdMenu))
        {
            errorEstado = ObtenerMensajeProteccion(menuModel.IdMenu);
            return;
        }

        if (!ValidarReglasMenu())
        {
            return;
        }

        isSavingMenu = true;
        var idRolSeleccionado = rolSeleccionado?.IdRol;
        var esNuevo = menuModel.IdMenu == 0;

        try
        {
            var exito = await AdministracionService.GuardarEContaxMenuAsync(menuModel);
            if (!exito)
            {
                errorEstado = "No se pudo guardar el item de menu.";
                return;
            }

            CerrarModalMenuInterno();
            await CargarDatos();

            if (idRolSeleccionado.HasValue)
            {
                var rolActualizado = roles.FirstOrDefault(item => item.IdRol == idRolSeleccionado.Value);
                if (rolActualizado is not null)
                {
                    await SeleccionarRol(rolActualizado);
                }
            }

            mensajeEstado = esNuevo
                ? "Item de menu creado correctamente."
                : "Item de menu actualizado correctamente.";
            MenuStateService.NotifyMenuChanged();
        }
        catch (Exception ex)
        {
            errorEstado = $"No se pudo guardar el item de menu. {ex.Message}";
        }
        finally
        {
            isSavingMenu = false;
        }
    }

    private async Task EliminarMenuMaestro(int idMenu)
    {
        LimpiarEstadoOperacion();

        if (EsMenuProtegido(idMenu))
        {
            errorEstado = ObtenerMensajeProteccion(idMenu, true);
            return;
        }

        var menu = listaMaestraMenus.FirstOrDefault(item => item.IdMenu == idMenu);
        var nombreMenu = string.IsNullOrWhiteSpace(menu?.NombreMenu) ? "este item de menu" : $"el item de menu {menu.NombreMenu}";
        var confirmado = await ConfirmarAsync("Eliminar item de menu", $"Se desactivara {nombreMenu} y dejara de mostrarse.");

        if (!confirmado)
        {
            return;
        }

        var idRolSeleccionado = rolSeleccionado?.IdRol;
        if (await AdministracionService.EliminarLogicoEContaxMenuAsync(idMenu))
        {
            await CargarDatos();

            if (idRolSeleccionado.HasValue)
            {
                var rolActualizado = roles.FirstOrDefault(item => item.IdRol == idRolSeleccionado.Value);
                if (rolActualizado is not null)
                {
                    await SeleccionarRol(rolActualizado);
                }
            }

            mensajeEstado = "Item de menu eliminado correctamente.";
            MenuStateService.NotifyMenuChanged();
            await MostrarAlertaAsync("Registro eliminado", "El item de menu fue dado de baja correctamente.", "success");
        }
        else
        {
            errorEstado = "No se pudo eliminar el item de menu.";
            await MostrarAlertaAsync("No se pudo eliminar", errorEstado, "error");
        }
    }

    private void CerrarModalMenu()
    {
        if (isSavingMenu)
        {
            return;
        }

        CerrarModalMenuInterno();
    }

    private void CerrarModalMenuInterno()
    {
        showModalMenu = false;
        menuErrors.Clear();
    }

    private void CerrarDetalleMenu()
    {
        showModalMenuDetail = false;
        menuDetalle = null;
    }

    private bool ValidarReglasMenu()
    {
        menuErrors.Clear();
        menuModel.NombreMenu = (menuModel.NombreMenu ?? string.Empty).Trim();
        menuModel.UrlMenu = string.IsNullOrWhiteSpace(menuModel.UrlMenu) ? string.Empty : menuModel.UrlMenu.Trim();
        menuModel.DescripcionMenu = null;
        menuModel.IconoMenu = string.IsNullOrWhiteSpace(menuModel.IconoMenu) ? null : menuModel.IconoMenu.Trim();
        menuModel.PerteneceMenu = null;
        menuModel.EstadoMenu = menuModel.EstadoMenu == 0 ? 0 : 1;
        menuModel.IdPadre = menuModel.IdPadre is null or 0 ? null : menuModel.IdPadre;

        var idPadre = menuModel.IdPadre;

        if (menuModel.NombreMenu.Length is < 3 or > 200)
        {
            menuErrors[MenuNombreField] = "El nombre debe tener entre 3 y 200 caracteres.";
        }
        else if (listaMaestraMenus.Any(item =>
            item.IdMenu != menuModel.IdMenu &&
            NormalizarIdPadre(item.IdPadre) == idPadre &&
            string.Equals((item.NombreMenu ?? string.Empty).Trim(), menuModel.NombreMenu, StringComparison.OrdinalIgnoreCase)))
        {
            menuErrors[MenuNombreField] = "Ya existe un item con ese nombre en el mismo nivel.";
        }

        if (idPadre == menuModel.IdMenu && menuModel.IdMenu != 0)
        {
            menuErrors[MenuPadreField] = "Un item no puede ser padre de si mismo.";
        }

        if (!string.IsNullOrWhiteSpace(menuModel.IconoMenu))
        {
            if (menuModel.IconoMenu.Length > 50)
            {
                menuErrors[MenuIconoField] = "El icono no puede superar los 50 caracteres.";
            }
            else if (!menuModel.IconoMenu.All(ch => char.IsLetterOrDigit(ch) || ch == '-'))
            {
                menuErrors[MenuIconoField] = "El icono solo puede contener letras, numeros y guiones.";
            }
        }

        if (idPadre.HasValue && string.IsNullOrWhiteSpace(menuModel.UrlMenu))
        {
            menuErrors[MenuRutaField] = "La ruta es obligatoria para los items hijos.";
        }
        else if (!string.IsNullOrWhiteSpace(menuModel.UrlMenu))
        {
            if (!menuModel.UrlMenu.StartsWith("/", StringComparison.Ordinal))
            {
                menuErrors[MenuRutaField] = "La ruta debe iniciar con '/'.";
            }
            else if (menuModel.UrlMenu.Contains(' '))
            {
                menuErrors[MenuRutaField] = "La ruta no puede contener espacios.";
            }
            else if (menuModel.UrlMenu.Length > 200)
            {
                menuErrors[MenuRutaField] = "La ruta no puede superar los 200 caracteres.";
            }
            else if (listaMaestraMenus.Any(item =>
                item.IdMenu != menuModel.IdMenu &&
                !string.IsNullOrWhiteSpace(item.UrlMenu) &&
                string.Equals(item.UrlMenu.Trim(), menuModel.UrlMenu, StringComparison.OrdinalIgnoreCase)))
            {
                menuErrors[MenuRutaField] = "Ya existe otro item con esa ruta.";
            }
        }

        if (menuErrors.Any())
        {
            errorEstado = "Corrige los campos del menu antes de guardar.";
        }

        return !menuErrors.Any();
    }

    private async Task ConfirmarEliminar(EContaxRol item)
    {
        var confirmado = await ConfirmarAsync(
            "Eliminar perfil",
            $"Se desactivara el perfil {item.NombreRol} y dejara de mostrarse como activo.");

        if (!confirmado)
        {
            return;
        }

        var eliminado = await AdministracionService.DesactivarEContaxRolAsync(item.IdRol);
        if (!eliminado)
        {
            await MostrarAlertaAsync("No se pudo eliminar", "Intenta nuevamente en unos segundos.", "error");
            return;
        }

        await CargarDatos();
        mensajeEstado = "Perfil eliminado correctamente.";
        MenuStateService.NotifyMenuChanged();
        await MostrarAlertaAsync("Registro eliminado", "El perfil fue dado de baja correctamente.", "success");
    }

    private async Task ReactivarRol(EContaxRol item)
    {
        var exito = await AdministracionService.ReactivarEContaxRolAsync(item.IdRol);
        if (!exito)
        {
            await MostrarAlertaAsync("No se pudo reactivar", "Intenta nuevamente en unos segundos.", "error");
            return;
        }

        await CargarDatos();
        var rolReactivado = roles.FirstOrDefault(rol => rol.IdRol == item.IdRol);
        if (rolReactivado is not null)
        {
            await SeleccionarRol(rolReactivado);
        }

        mensajeEstado = "Perfil reactivado correctamente.";
        MenuStateService.NotifyMenuChanged();
        await MostrarAlertaAsync("Perfil reactivado", "El perfil vuelve a estar activo.", "success");
    }

    private async Task<bool> ConfirmarAsync(string titulo, string mensaje)
    {
        var resultado = await JS.InvokeAsync<JsonElement>("Swal.fire", new
        {
            icon = "warning",
            title = titulo,
            text = mensaje,
            showCancelButton = true,
            confirmButtonText = "Si, eliminar",
            cancelButtonText = "Cancelar",
            reverseButtons = true,
            focusCancel = true,
            confirmButtonColor = "#c23b4b",
            cancelButtonColor = "#7a8da2"
        });

        return resultado.TryGetProperty("isConfirmed", out var confirmacion) && confirmacion.GetBoolean();
    }

    private async Task MostrarAlertaAsync(string titulo, string mensaje, string icono)
    {
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = icono,
            title = titulo,
            text = mensaje,
            confirmButtonText = "Aceptar",
            timer = icono == "success" ? 1800 : (int?)null,
            showConfirmButton = icono != "success"
        });
    }

    private async Task<bool> ValidarAccesoEContaxAsync(ClaimsPrincipal user)
    {
        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var userId = ObtenerIdUsuario(user);
        if (userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        currentUserId = userId;

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

    private static EContaxRol ClonarRol(EContaxRol item) =>
        new()
        {
            IdRol = item.IdRol,
            NombreRol = item.NombreRol,
            PermisoRol = item.PermisoRol,
            EstadoRol = item.EstadoRol
        };

    private static EContaxMenu ClonarMenu(EContaxMenu item) =>
        new()
        {
            IdMenu = item.IdMenu,
            NombreMenu = item.NombreMenu,
            PerteneceMenu = item.PerteneceMenu,
            UrlMenu = item.UrlMenu,
            DescripcionMenu = item.DescripcionMenu,
            IconoMenu = item.IconoMenu,
            EstadoMenu = item.EstadoMenu,
            IdPadre = item.IdPadre,
