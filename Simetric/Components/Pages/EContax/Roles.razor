    private void CerrarModal()
    {
        if (isSaving)
        {
            return;
        }

        CerrarModalRolInterno();
    }

    private void CerrarModalRolInterno()
    {
        showModal = false;
        isReadOnly = false;
        errorMessage = null;
        errors.Clear();
    }

    private void OnNombreChanged(ChangeEventArgs e)
    {
        temp.NombreRol = LimitarTexto(e.Value?.ToString(), 200);
        ValidarNombre();
    }

    private string GetInputClass(string field) =>
        errors.ContainsKey(field) ? "roles-input input-error" : "roles-input";

    private string GetMenuInputClass(string field) =>
        menuErrors.ContainsKey(field) ? "roles-input input-error" : "roles-input";

    private bool ValidarFormulario()
    {
        errors.Clear();
        ValidarNombre();
        return errors.Count == 0;
    }

    private void ValidarNombre()
    {
        errors.Remove(nameof(temp.NombreRol));
        var nombre = (temp.NombreRol ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(nombre))
        {
            errors[nameof(temp.NombreRol)] = "El nombre del rol es obligatorio.";
        }
        else if (nombre.Length is < 3 or > 200)
        {
            errors[nameof(temp.NombreRol)] = "El nombre debe tener entre 3 y 200 caracteres.";
        }
        else if (roles.Any(item =>
            item.IdRol != temp.IdRol &&
            string.Equals((item.NombreRol ?? string.Empty).Trim(), nombre, StringComparison.OrdinalIgnoreCase)))
        {
            errors[nameof(temp.NombreRol)] = "Ya existe un rol con ese nombre.";
        }
    }

    private async Task Guardar()
    {
        if (isSaving)
        {
            return;
        }

        errorMessage = null;
        mensajeEstado = null;
        temp.NombreRol = (temp.NombreRol ?? string.Empty).Trim();
        temp.EstadoRol = temp.EstadoRol == 0 ? 0 : 1;

        if (!ValidarFormulario())
        {
            errorMessage = "Corrige los campos marcados antes de guardar.";
            return;
        }

        isSaving = true;
        var idGuardado = temp.IdRol;
        var nombreGuardado = temp.NombreRol;

        try
        {
            var exito = await AdministracionService.GuardarEContaxRolAsync(temp);
            if (!exito)
            {
                errorMessage = "No se pudo guardar. Verifica que el nombre no este duplicado.";
                return;
            }

            CerrarModalRolInterno();
            await CargarDatos();

            var rolGuardado = idGuardado == 0
                ? roles.FirstOrDefault(item => string.Equals(item.NombreRol, nombreGuardado, StringComparison.OrdinalIgnoreCase))
                : roles.FirstOrDefault(item => item.IdRol == idGuardado);

            if (rolGuardado is not null)
            {
                await SeleccionarRol(rolGuardado);
            }

            mensajeEstado = idGuardado == 0 ? "Perfil creado correctamente." : "Perfil actualizado correctamente.";
            MenuStateService.NotifyMenuChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AbrirModalMenu()
    {
        LimpiarEstadoOperacion();
        menuErrors.Clear();
        isSavingMenu = false;
        menuModel = new EContaxMenu
