    private void AbrirModal(EContaxRol? item = null)
    {
        isReadOnly = false;
        isSaving = false;
        errorMessage = null;
        errors.Clear();

        temp = item is null
            ? new EContaxRol { NombreRol = string.Empty, PermisoRol = null, EstadoRol = 1 }
            : ClonarRol(item);

        showModal = true;
    }

    private void VerDetalle(EContaxRol item)
    {
        AbrirModal(item);
        isReadOnly = true;
