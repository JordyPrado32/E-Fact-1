    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!await ValidarAccesoEContaxAsync(authState.User))
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await CargarDatos();
        await InvokeAsync(StateHasChanged);
    }

    private bool EsNuevoRegistro => temp.IdRol == 0;

    private int MenuPadreSeleccionado
    {
        get => menuModel.IdPadre ?? 0;
        set => menuModel.IdPadre = value <= 0 ? null : value;
    }

    private int SelectedParentIdForChildOrder
    {
        get => selectedParentIdForChildOrder;
        set
        {
            if (selectedParentIdForChildOrder != value)
            {
                ActualizarLocalDeHijos();
                selectedParentIdForChildOrder = value;
                CargarHijosParaOrden();
            }
        }
    }


    private IEnumerable<EContaxRol> RolesFiltrados
    {
        get
        {
            var query = roles.AsEnumerable();

            return query
                .OrderByDescending(item => item.EstadoRol == 1)
                .ThenBy(item => item.NombreRol ?? string.Empty)
                .ThenBy(item => item.IdRol);
        }
    }

    private async Task CargarDatos()
    {
        isLoading = true;
        pageErrorMessage = null;

        if (currentUserId <= 0)
        {
            roles = new List<EContaxRol>();
            listaMaestraMenus = new List<EContaxMenu>();
            rolSeleccionado = null;
            pageErrorMessage = "No se pudo identificar el usuario actual.";
            isLoading = false;
            return;
        }

        var idSeleccionado = rolSeleccionado?.IdRol;

        try
        {
            roles = await AdministracionService.GetEContaxRolesAsync(includeInactivos: true);
            listaMaestraMenus = await AdministracionService.GetEContaxMenusAsync();

            var rolActual = idSeleccionado.HasValue
                ? roles.FirstOrDefault(item => item.IdRol == idSeleccionado.Value)
                : null;

            rolActual ??= RolesFiltrados.FirstOrDefault();

            if (rolActual is not null)
            {
                await SeleccionarRol(rolActual);
            }
            else
            {
                rolSeleccionado = null;
                LimpiarSeleccionMenus();
            }
        }
        catch (Exception ex)
        {
            roles = new List<EContaxRol>();
            listaMaestraMenus = new List<EContaxMenu>();
            rolSeleccionado = null;
            pageErrorMessage = $"Error al cargar roles de E-Contax: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<EContaxMenu> GetMenusPadre() =>
        listaMaestraMenus
            .Where(item => !item.IdPadre.HasValue || item.IdPadre == 0)
            .OrderBy(item => item.OrdenMenu ?? 9999)
            .ThenBy(item => item.IdMenu)
            .ToList();

    private List<EContaxMenu> GetMenusHijo(int idPadre) =>
        listaMaestraMenus
            .Where(item => item.IdPadre == idPadre)
            .OrderBy(item => item.OrdenMenu ?? 9999)
            .ThenBy(item => item.IdMenu)
            .ToList();


    private static string ResolveIcono(string? icono) =>
        string.IsNullOrWhiteSpace(icono) ? "ri-checkbox-blank-circle-line" : icono.Trim();

    private static string GetRutaTexto(EContaxMenu menu) =>
        string.IsNullOrWhiteSpace(menu.UrlMenu) ? "Contenedor sin ruta" : menu.UrlMenu.Trim();

    private string GetTipoMenu(EContaxMenu menu) =>
        !menu.IdPadre.HasValue || menu.IdPadre == 0 ? "Modulo principal" : "Item hijo";

    private string GetPadreMenu(EContaxMenu menu)
    {
        if (!menu.IdPadre.HasValue || menu.IdPadre == 0)
        {
            return "Sin padre";
        }

        return listaMaestraMenus.FirstOrDefault(item => item.IdMenu == menu.IdPadre)?.NombreMenu ?? "No encontrado";
    }

    private async Task SeleccionarRol(EContaxRol rol)
    {
        LimpiarEstadoOperacion();
        rolSeleccionado = rol;
        LimpiarSeleccionMenus();

        if (rol.IdRol <= 0)
        {
            return;
        }

        try
        {
            var menusAsignados = await AdministracionService.GetEContaxMenusByRolIdAsync(rol.IdRol);
            var idsAsignados = menusAsignados.Select(item => item.IdMenu).ToHashSet();

            foreach (var item in listaMaestraMenus)
            {
                item.IsSelected = idsAsignados.Contains(item.IdMenu);
            }
        }
        catch (Exception ex)
        {
            errorEstado = $"No se pudo cargar la matriz de permisos. {ex.Message}";
        }
    }

    private void LimpiarSeleccionMenus()
    {
        foreach (var item in listaMaestraMenus)
        {
            item.IsSelected = false;
        }
    }

    private void ToggleGrupo(EContaxMenu padre, ChangeEventArgs e)
    {
        var valor = ParseCheckboxValue(e.Value);
        padre.IsSelected = valor;

        foreach (var hijo in listaMaestraMenus.Where(item => item.IdPadre == padre.IdMenu))
        {
            hijo.IsSelected = valor;
        }
    }

    private async Task GuardarAccesos()
    {
        if (rolSeleccionado is null)
        {
            return;
        }

        guardandoAccesos = true;
        LimpiarEstadoOperacion();

        var rolActual = rolSeleccionado;
        var idsSeleccionados = listaMaestraMenus
            .Where(item => item.IsSelected)
            .Select(item => item.IdMenu)
            .Distinct()
            .ToList();

        try
        {
            if (await AdministracionService.AsignarEContaxMenusARolAsync(rolActual.IdRol, idsSeleccionados))
            {
                await SeleccionarRol(rolActual);
                mensajeEstado = "Roles y permisos actualizados correctamente.";
                MenuStateService.NotifyMenuChanged();
            }
            else
            {
                errorEstado = "No se pudieron actualizar los permisos del rol seleccionado.";
            }
        }
        catch (Exception ex)
        {
            errorEstado = $"Ocurrio un error al guardar los permisos. {ex.Message}";
        }
        finally
        {
            guardandoAccesos = false;
        }
    }

    private void AbrirModalNuevo() => AbrirModal();

    private void ToggleRolMenu(int idRol)
