@page "/e-contax/administracion/roles"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@using System.Security.Claims
@using System.Text.Json
@using Simetric.Models.EContax
@using Simetric.Services
@using Simetric.Services.EContax
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject EContaxAdministracionService AdministracionService
@inject MenuStateService MenuStateService
@rendermode InteractiveServer

@{
    var rolesVisibles = RolesFiltrados.ToList();
    var modulosPadre = GetMenusPadre();
    var itemsMenu = listaMaestraMenus.Count;
    var permisosSeleccionados = listaMaestraMenus.Count(item => item.IsSelected);
}

<PageTitle>Roles y permisos | Numerica E-Contax</PageTitle>

<div class="security-shell">
    <section class="security-hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Control de accesos</span>
            <h2>Panel de seguridad</h2>
        </div>

        <div class="hero-actions">
            <button type="button" class="secondary-btn secondary-btn-accent" @onclick="CargarDatos">
                <i class="ri-refresh-line"></i>
                <span>Refrescar</span>
            </button>

            <button type="button" class="secondary-btn secondary-btn-accent" @onclick="AbrirModalMenu">
                <i class="ri-list-settings-line"></i>
                <span>Nuevo menu</span>
            </button>

            <button type="button" class="secondary-btn secondary-btn-accent" @onclick="AbrirModalOrdenar">
                <i class="ri-drag-drop-line"></i>
                <span>Ordenar menus</span>
            </button>

            <button type="button" class="primary-btn" @onclick="AbrirModalNuevo">
                <i class="ri-add-circle-line"></i>
                <span>Nuevo perfil</span>
            </button>

        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Perfiles registrados</span>
                <strong>@roles.Count</strong>
                <small>Roles disponibles para asignar matrices de acceso.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Modulos principales</span>
                <strong>@modulosPadre.Count</strong>
                <small>Estructura padre del arbol de navegacion.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Items de menu</span>
                <strong>@itemsMenu</strong>
                <small>Items configurados dentro del sistema.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Permisos seleccionados</span>
                <strong>@permisosSeleccionados</strong>
                <small>@(rolSeleccionado is null ? "Seleccione un perfil para comenzar." : $"Asignacion actual de {rolSeleccionado.NombreRol}.")</small>
            </article>
        </div>
    </section>

    <section class="security-grid">
        <aside class="roles-panel">
            <div class="panel-head">
                <div>
                    <span class="panel-kicker">Perfiles disponibles</span>
                    <h3>Roles de acceso</h3>
                </div>
                <span class="panel-badge">@rolesVisibles.Count</span>
            </div>

            @if (isLoading)
            {
                <div class="state-card state-card-compact">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando perfiles</h3>
                    <p>Recuperando los roles configurados en E-Contax.</p>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(pageErrorMessage))
            {
                <div class="state-card state-card-compact state-card-error">
                    <div class="state-icon">
                        <i class="ri-error-warning-line"></i>
                    </div>
                    <h3>No se pudo cargar</h3>
                    <p>@pageErrorMessage</p>
                </div>
            }
            else if (!rolesVisibles.Any())
            {
                <div class="state-card state-card-compact state-card-empty">
                    <div class="state-icon">
                        <i class="ri-shield-user-line"></i>
                    </div>
                    <h3>Sin perfiles visibles</h3>
                    <p>Cree el primer perfil de E-Contax para asignar permisos.</p>
                </div>
            }
            else
            {
                <div class="roles-list">
                    @foreach (var roleEntry in rolesVisibles.Select((role, index) => new { Role = role, Index = index }))
                    {
                        var r = roleEntry.Role;
                        <article class="role-card @(rolSeleccionado?.IdRol == r.IdRol ? "role-card-active" : string.Empty)"
                                 @key="r.IdRol"
                                 @onclick="() => SeleccionarRol(r)">
                            <div class="role-menu-wrap" @onclick:stopPropagation="true">
                                <button type="button"
                                        class="role-menu-trigger"
                                        title="Mas opciones"
                                        @onclick="() => ToggleRolMenu(r.IdRol)">
                                    <i class="ri-more-2-fill"></i>
                                </button>

                                @if (rolMenuAbiertoId == r.IdRol)
                                {
                                    <div class="role-menu-dropdown" @onclick:stopPropagation="true">
                                        @if (r.EstadoRol == 1)
                                        {
                                            <button type="button"
                                                    class="role-menu-item role-menu-item-danger"
                                                    @onclick="() => EliminarRolDesdeMenu(r)">
                                                <i class="ri-delete-bin-line"></i>
                                                <span>Eliminar</span>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="role-menu-item"
                                                    @onclick="() => ReactivarRolDesdeMenu(r)">
                                                <i class="ri-refresh-line"></i>
                                                <span>Reactivar</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="role-copy">
                                <strong>@r.NombreRol</strong>
                                <span>@(r.EstadoRol == 1 ? "Perfil activo" : "Perfil inactivo")</span>
                            </div>

                            <div class="role-actions" @onclick:stopPropagation="true">
                                <span class="role-status @(r.EstadoRol == 1 ? "role-status-active" : "role-status-muted")">
                                    @(r.EstadoRol == 1 ? "Activo" : "Inactivo")
                                </span>
                                <button type="button"
                                        class="secondary-btn secondary-btn-quiet role-select-btn"
                                        title="Seleccionar perfil"
                                        @onclick="() => SeleccionarRol(r)">
                                    <i class="ri-check-line"></i>
                                    <span>Seleccionar</span>
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </aside>

        <section class="permissions-panel">
            @if (rolSeleccionado is null)
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="ri-key-2-line"></i>
                    </div>
                    <h3>Seleccione un perfil</h3>
                    <p>Elija un rol desde la columna izquierda para administrar su matriz de accesos.</p>
                </div>
            }
            else
            {
                <div class="panel-head panel-head-spread">
                    <div>
                        <span class="panel-kicker">Matriz de permisos</span>
                        <h3>@rolSeleccionado.NombreRol</h3>
                        <p>Seleccione modulos completos o items individuales para este perfil.</p>
                    </div>
                    <div class="panel-actions">
                        <button type="button"
                                class="primary-btn"
                                @onclick="GuardarAccesos"
                                disabled="@(guardandoAccesos || rolSeleccionado.EstadoRol != 1)">
                            @if (guardandoAccesos)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <i class="ri-save-3-line"></i>
                                <span>Guardar cambios</span>
                            }
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensajeEstado))
                {
                    <div class="status-banner status-banner-success">
                        <i class="ri-checkbox-circle-line"></i>
                        <span>@mensajeEstado</span>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorEstado))
                {
                    <div class="status-banner status-banner-error">
                        <i class="ri-error-warning-line"></i>
                        <span>@errorEstado</span>
                    </div>
                }

                @if (!modulosPadre.Any())
                {
                    <div class="state-card state-card-empty">
                        <div class="state-icon">
                            <i class="ri-list-check-3"></i>
                        </div>
                        <h3>No hay modulos configurados</h3>
                        <p>Agregue un item maestro para construir la jerarquia de accesos.</p>
                    </div>
                }
                else
                {
                    <div class="modules-list">
                        @foreach (var moduloEntry in modulosPadre.OrderBy(m => m.OrdenMenu ?? 9999).ThenBy(m => m.IdMenu).Select((menu, index) => new { Menu = menu, Index = index }))
                        {
                            var padre = moduloEntry.Menu;
                            var hijos = GetMenusHijo(padre.IdMenu);
                            var esModuloProtegido = EsMenuProtegido(padre);
                            <article class="module-card">
                                <header class="module-head">
                                    <label class="module-selection">
                                        <input type="checkbox"
                                               class="permission-check"
                                               checked="@padre.IsSelected"
                                               disabled="@(rolSeleccionado.EstadoRol != 1)"
                                               @onchange="(e) => ToggleGrupo(padre, e)" />
                                        <span class="module-copy">
                                            <span class="module-kicker">Modulo principal</span>
                                            <span class="module-title">
                                                <i class="@ResolveIcono(padre.IconoMenu)"></i>
                                                @padre.NombreMenu
                                            </span>
                                            <span class="module-meta">
                                                <span class="module-badge">@hijos.Count items</span>
                                                @if (esModuloProtegido)
                                                {
                                                    <span class="route-chip route-chip-protected">
                                                        <i class="ri-lock-line"></i>
                                                        <span>Estatico</span>
                                                    </span>
                                                }
                                            </span>
                                        </span>
                                    </label>

                                    <div class="module-actions">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view" title="Ver detalle" @onclick="() => VerDetalleMenu(padre)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (!esModuloProtegido)
                                            {
                                                <button type="button" class="action-btn action-edit" title="Editar modulo" @onclick="() => EditarMenuMaestro(padre)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <button type="button" class="action-btn action-delete" title="Eliminar modulo" @onclick="() => EliminarMenuMaestro(padre.IdMenu)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="protected-flag" title="@ObtenerMensajeProteccion(padre)">
                                                    <i class="ri-shield-keyhole-line"></i>
                                                    <span>Protegido</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </header>

                                @if (hijos.Any())
                                {
                                    <div class="module-children">
                                        @foreach (var hijo in hijos)
                                        {
                                            var esItemProtegido = EsMenuProtegido(hijo);
                                            <div class="child-row">
                                                <label class="child-main">
                                                    <input type="checkbox"
                                                           class="permission-check"
                                                           disabled="@(rolSeleccionado.EstadoRol != 1)"
                                                           @bind="hijo.IsSelected" />
                                                    <span class="child-copy">
                                                        <strong>
                                                            <i class="@ResolveIcono(hijo.IconoMenu)"></i>
                                                            @hijo.NombreMenu
                                                        </strong>
                                                    </span>
                                                </label>
                                                <div class="child-actions">
                                                    <div class="action-group">
                                                        <button type="button" class="action-btn action-view" title="Ver detalle" @onclick="() => VerDetalleMenu(hijo)">
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                        @if (!esItemProtegido)
                                                        {
                                                            <button type="button" class="action-btn action-edit" title="Editar item" @onclick="() => EditarMenuMaestro(hijo)">
                                                                <i class="bi bi-pencil-square"></i>
                                                            </button>
                                                            <button type="button" class="action-btn action-delete" title="Eliminar item" @onclick="() => EliminarMenuMaestro(hijo.IdMenu)">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="protected-flag" title="@ObtenerMensajeProteccion(hijo)">
                                                                <i class="ri-shield-keyhole-line"></i>
                                                                <span>Protegido</span>
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="module-empty">
                                        <i class="ri-information-line"></i>
                                        <span>Este modulo aun no tiene items hijos.</span>
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }
            }
        </section>
    </section>
</div>

@if (showModal)
{
    <div class="roles-modal-backdrop"></div>
    <div class="roles-modal" role="dialog" aria-modal="true" aria-labelledby="rolModalTitle">
        <div class="roles-modal-content">
            <header class="roles-modal-header @(isReadOnly ? "is-readonly" : "is-editable")">
                <div>
                    <span class="modal-kicker">Perfil E-Contax</span>
                    <h3 id="rolModalTitle">@(isReadOnly ? "Vista de detalle" : (EsNuevoRegistro ? "Nuevo perfil" : "Perfil"))</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarModal" disabled="@isSaving" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="roles-modal-body">
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="roles-alert">
                        <i class="ri-error-warning-line"></i>
                        <span>@errorMessage</span>
                    </div>
                }

                <div class="roles-form-grid">
                    @if (!EsNuevoRegistro)
                    {
                        <label class="roles-field roles-field-short">
                            <span>ID rol</span>
                            <input class="roles-input" value="@temp.IdRol" readonly />
                        </label>
                    }

                    <label class="roles-field @(EsNuevoRegistro ? "roles-field-full" : string.Empty)">
                        <span>Nombre rol</span>
                        <input type="text"
                               value="@temp.NombreRol"
                               @oninput="OnNombreChanged"
                               class="@GetInputClass(nameof(temp.NombreRol))"
                               readonly="@isReadOnly"
                               maxlength="200" />
                        @if (errors.ContainsKey(nameof(temp.NombreRol)))
                        {
                            <small>@errors[nameof(temp.NombreRol)]</small>
                        }
                    </label>

                </div>
            </div>

            <footer class="roles-modal-footer">
                <button type="button" class="secondary-btn" @onclick="CerrarModal" disabled="@isSaving">Cerrar</button>
                @if (!isReadOnly)
                {
                    <button type="button" class="primary-btn" @onclick="Guardar" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span>Procesando...</span>
                        }
                        else
                        {
                            <i class="bi bi-save"></i>
                            <span>@(EsNuevoRegistro ? "Crear perfil" : "Guardar cambios")</span>
                        }
                    </button>
                }
            </footer>
        </div>
    </div>
}

@if (showModalMenu)
{
    <div class="roles-modal-backdrop"></div>
    <div class="roles-modal" role="dialog" aria-modal="true" aria-labelledby="menuModalTitle">
        <div class="roles-modal-content roles-modal-lg">
            <header class="roles-modal-header is-editable">
                <div>
                    <span class="modal-kicker">Configuracion de menu</span>
                    <h3 id="menuModalTitle">@(menuModel.IdMenu == 0 ? "Crear nuevo item" : "Editar item de menu")</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarModalMenu" disabled="@isSavingMenu" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="roles-modal-body">
                <div class="roles-form-grid menu-form-grid">
                    <label class="roles-field roles-field-full">
                        <span>Tipo de item o ubicacion</span>
                        <select class="@GetMenuInputClass(MenuPadreField)" @bind="MenuPadreSeleccionado" disabled="@isSavingMenu">
                            <option value="0">Es un modulo principal</option>
                            @foreach (var p in GetMenusPadre().Where(m => m.IdMenu != menuModel.IdMenu).OrderBy(m => m.NombreMenu))
                            {
                                <option value="@p.IdMenu">Hijo de: @p.NombreMenu</option>
                            }
                        </select>
                        @if (menuErrors.ContainsKey(MenuPadreField))
                        {
                            <small>@menuErrors[MenuPadreField]</small>
                        }
                    </label>

                    <label class="roles-field">
                        <span>Nombre visible</span>
                        <input type="text"
                               @bind="menuModel.NombreMenu"
                               @bind:event="oninput"
                               class="@GetMenuInputClass(MenuNombreField)"
                               maxlength="200"
                               disabled="@isSavingMenu"
                               placeholder="Ej: Facturacion" />
                        @if (menuErrors.ContainsKey(MenuNombreField))
                        {
                            <small>@menuErrors[MenuNombreField]</small>
                        }
                    </label>

                    <label class="roles-field">
                        <span>Icono</span>
                        <div class="icon-input-wrap">
                            <span class="icon-preview">
                                <i class="@ResolveIcono(menuModel.IconoMenu)"></i>
                            </span>
                            <input type="text"
                                   @bind="menuModel.IconoMenu"
                                   @bind:event="oninput"
                                   class="@GetMenuInputClass(MenuIconoField)"
                                   maxlength="50"
                                   disabled="@isSavingMenu"
                                   placeholder="ri-home-4-line" />
                        </div>
                        @if (menuErrors.ContainsKey(MenuIconoField))
                        {
                            <small>@menuErrors[MenuIconoField]</small>
                        }
                    </label>

                    <label class="roles-field roles-field-full">
                        <span>Ruta de navegacion</span>
                        <input type="text"
                               @bind="menuModel.UrlMenu"
                               @bind:event="oninput"
                               class="@GetMenuInputClass(MenuRutaField)"
                               maxlength="200"
                               disabled="@isSavingMenu"
                               placeholder="/e-contax/..." />
                        <span class="field-help">En items hijos la ruta es obligatoria; en modulos principales puede quedar vacia.</span>
                        @if (menuErrors.ContainsKey(MenuRutaField))
                        {
                            <small>@menuErrors[MenuRutaField]</small>
                        }
                    </label>

                    <div class="form-note">
                        <i class="ri-information-line"></i>
                        <span>Use clases de RemixIcon para mantener el mismo estilo del menu lateral.</span>
                    </div>

                    <div class="roles-field roles-field-full">
                        <a href="https://remixicon.com/" target="_blank" rel="noreferrer" class="catalog-link">
                            Ver catalogo de iconos Remixicon
                        </a>
                    </div>
                </div>
            </div>

            <footer class="roles-modal-footer">
                <button type="button" class="secondary-btn" @onclick="CerrarModalMenu" disabled="@isSavingMenu">Cerrar</button>
                <button type="button" class="primary-btn" @onclick="GuardarMenuMaestro" disabled="@isSavingMenu">
                    @if (isSavingMenu)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>Procesando...</span>
                    }
                    else
                    {
                        <i class="@(menuModel.IdMenu == 0 ? "ri-add-line" : "ri-save-3-line")"></i>
                        <span>@(menuModel.IdMenu == 0 ? "Crear item" : "Guardar cambios")</span>
                    }
                </button>
            </footer>
        </div>
    </div>
}

@if (showModalMenuDetail && menuDetalle is not null)
{
    <div class="roles-modal-backdrop"></div>
    <div class="roles-modal" role="dialog" aria-modal="true" aria-labelledby="menuDetailTitle">
        <div class="roles-modal-content roles-modal-sm">
            <header class="roles-modal-header is-readonly">
                <div>
                    <span class="modal-kicker">Vista de detalle</span>
                    <h3 id="menuDetailTitle">Detalle del item</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarDetalleMenu" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="roles-modal-body">
                <div class="detail-grid">
                    <div class="detail-block">
                        <span>Tipo de item</span>
                        <strong>@GetTipoMenu(menuDetalle)</strong>
                    </div>

                    <div class="detail-block detail-block-wide">
                        <span>Nombre visible</span>
                        <strong>@menuDetalle.NombreMenu</strong>
                    </div>

                    <div class="detail-block">
                        <span>Icono</span>
                        <strong><i class="@ResolveIcono(menuDetalle.IconoMenu)"></i> @ResolveIcono(menuDetalle.IconoMenu)</strong>
                    </div>

                    <div class="detail-block">
                        <span>Padre</span>
                        <strong>@GetPadreMenu(menuDetalle)</strong>
                    </div>

                    <div class="detail-block detail-block-wide">
                        <span>Ruta</span>
                        <strong>@GetRutaTexto(menuDetalle)</strong>
                    </div>

                </div>
            </div>

            <footer class="roles-modal-footer">
                <button type="button" class="secondary-btn" @onclick="CerrarDetalleMenu">Cerrar</button>
            </footer>
        </div>
    </div>
}

@if (showModalOrder)
{
    <div class="roles-modal-backdrop"></div>
    <div class="roles-modal" role="dialog" aria-modal="true" aria-labelledby="orderModalTitle">
        <div class="roles-modal-content roles-modal-lg animate__animated animate__fadeInDown">
            <header class="roles-modal-header is-editable">
                <div>
                    <span class="modal-kicker">Navegación del Portal</span>
                    <h3 id="orderModalTitle">Ordenar menú de servicios</h3>
                </div>
                <button type="button" class="modal-close" @onclick="CerrarModalOrder" disabled="@isSavingOrder" aria-label="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="roles-modal-body">
                <p class="order-desc">Arrastra los elementos o utiliza las flechas para ordenar los menús tal como quieres que aparezcan en el panel lateral.</p>

                <div class="order-grid">
                    <!-- Columna Módulos Principales -->
                    <div class="order-column">
                        <div class="column-header">
                            <h4>Módulos Principales</h4>
                            <span class="badge-count">@parentMenusParaOrden.Count</span>
                        </div>
                        
                        <div class="order-list">
                            @foreach (var parent in parentMenusParaOrden.Select((item, index) => new { Item = item, Index = index }))
                            {
                                var item = parent.Item;
                                var idx = parent.Index;
                                <div class="order-item @(dragItem == item ? "is-dragging" : "")"
                                     draggable="true"
                                     @ondragstart="() => HandleDragStart(item)"
                                     @ondragover:preventDefault
                                     @ondragover="() => HandleDragOver(item)"
                                     @ondrop="() => HandleDrop(item, true)"
                                     @key="@($"parent:{item.IdMenu}")">
                                    <div class="item-drag-handle">
                                        <i class="ri-drag-move-fill"></i>
                                    </div>
                                    <div class="item-icon">
                                        <i class="@ResolveIcono(item.IconoMenu)"></i>
                                    </div>
                                    <span class="item-name">@item.NombreMenu</span>
                                    <div class="item-actions">
                                        <button type="button" class="order-action-btn" title="Subir" 
                                                disabled="@(idx == 0)"
                                                @onclick="() => MoverItem(parentMenusParaOrden, item, -1)">
                                            <i class="ri-arrow-up-line"></i>
                                        </button>
                                        <button type="button" class="order-action-btn" title="Bajar" 
                                                disabled="@(idx == parentMenusParaOrden.Count - 1)"
                                                @onclick="() => MoverItem(parentMenusParaOrden, item, 1)">
                                            <i class="ri-arrow-down-line"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Columna Items Hijos -->
                    <div class="order-column">
                        <div class="column-header column-header-split">
                            <h4>Submenús de:</h4>
                            <select class="roles-input select-parent-order" @bind="SelectedParentIdForChildOrder">
                                @foreach (var parent in parentMenusParaOrden)
                                {
                                    <option value="@parent.IdMenu">@parent.NombreMenu</option>
                                }
                            </select>
                        </div>

                        <div class="order-list">
                            @if (!childMenusParaOrden.Any())
                            {
                                <div class="empty-order-state">
                                    <i class="ri-information-line"></i>
                                    <span>Este módulo no tiene submenús.</span>
                                </div>
                            }
                            else
                            {
                                @foreach (var child in childMenusParaOrden.Select((item, index) => new { Item = item, Index = index }))
                                {
                                    var item = child.Item;
                                    var idx = child.Index;
                                    <div class="order-item @(dragItem == item ? "is-dragging" : "")"
                                         draggable="true"
                                         @ondragstart="() => HandleDragStart(item)"
                                         @ondragover:preventDefault
                                         @ondragover="() => HandleDragOver(item)"
                                         @ondrop="() => HandleDrop(item, false)"
                                         @key="@($"child:{item.IdMenu}")">
                                        <div class="item-drag-handle">
                                            <i class="ri-drag-move-fill"></i>
                                        </div>
                                        <div class="item-icon">
                                            <i class="@ResolveIcono(item.IconoMenu)"></i>
                                        </div>
                                        <span class="item-name">@item.NombreMenu</span>
                                        <div class="item-actions">
                                            <button type="button" class="order-action-btn" title="Subir" 
                                                    disabled="@(idx == 0)"
                                                    @onclick="() => MoverItem(childMenusParaOrden, item, -1)">
                                                <i class="ri-arrow-up-line"></i>
                                            </button>
                                            <button type="button" class="order-action-btn" title="Bajar" 
                                                    disabled="@(idx == childMenusParaOrden.Count - 1)"
                                                    @onclick="() => MoverItem(childMenusParaOrden, item, 1)">
                                                <i class="ri-arrow-down-line"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <footer class="roles-modal-footer">
                <button type="button" class="secondary-btn" @onclick="CerrarModalOrder" disabled="@isSavingOrder">Cancelar</button>
                <button type="button" class="primary-btn" @onclick="GuardarOrdenMenus" disabled="@isSavingOrder">
                    @if (isSavingOrder)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>Guardando orden...</span>
                    }
                    else
                    {
                        <i class="ri-save-3-line"></i>
                        <span>Guardar orden</span>
                    }
                </button>
            </footer>
        </div>
    </div>
}


@code {
    private const string MenuPadreField = "IdPadre";
