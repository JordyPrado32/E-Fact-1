            NombreMenu = string.Empty,
            PerteneceMenu = null,
            UrlMenu = string.Empty,
            DescripcionMenu = null,
            IconoMenu = "ri-checkbox-blank-circle-line",
            EstadoMenu = 1,
            IdPadre = null
        };
        showModalMenu = true;
