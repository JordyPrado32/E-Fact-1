    private async Task EliminarConfirmado()
    {
        if (emisorAEliminar is null) return;

        try
        {
            var idUsuario = await ObtenerIdUsuarioLogueado();
            if (idUsuario == null || idUsuario <= 0)
            {
                mensaje = "No se pudo obtener la sesión del usuario.";
                return;
            }

            var resp = await Http.PutAsync(
                $"api/emisores/{emisorAEliminar.Codigo}/desactivar?idUsuario={idUsuario}",
                null);

            if (resp.IsSuccessStatusCode)
            {
                mensaje = "Emisor desactivado.";
                await CargarTodo();
                await EmisorOnboardingService.RefreshRequirementAsync(idUsuario);
                CancelarEliminar();
            }
            else
            {
                debugError = await LeerMensajeErrorHttpAsync(resp, "No se pudo desactivar el emisor.");
                mensaje = "No se pudo desactivar el emisor.";
            }
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = "Error al desactivar emisor.";
        }
    }

