    // Método para descargar el archivo P12
    private async Task DescargarCertificadoActual()
    {
        if (string.IsNullOrWhiteSpace(model.PathCertificado)) return;

        try
        {
            // Construimos la ruta física igual que cuando se guarda
            var physicalPath = Path.Combine(
                HostEnvironment.ContentRootPath,
                "App_Data",
                model.PathCertificado.Replace('/', Path.DirectorySeparatorChar));

            if (File.Exists(physicalPath))
            {
                var fileBytes = await File.ReadAllBytesAsync(physicalPath);
                var fileName = Path.GetFileName(model.PathCertificado);
            
                // Usamos JSInterop para disparar la descarga en el navegador
                using var streamRef = new DotNetStreamReference(new MemoryStream(fileBytes));
                await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
            }
            else
            {
                mensaje = "El archivo físico no se encuentra en el servidor.";
            }
        }
        catch (Exception ex)
        {
            debugError = "Error al descargar: " + ex.Message;
        }
    }
