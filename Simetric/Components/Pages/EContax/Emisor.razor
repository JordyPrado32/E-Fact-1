    private async Task SubirLogo(InputFileChangeEventArgs e)
    {
        try
        {
            if (e.FileCount > 1)
            {
                mensaje = "Solo puedes subir un archivo de logo.";
                debugError = null;
                return;
            }

            var file = e.File;

            if (file is null)
            {
                mensaje = "No se seleccionó ningún archivo.";
                return;
            }

            var extension = Path.GetExtension(file.Name)?.ToLowerInvariant();
            var extensionesPermitidas = new[] { ".jpg", ".jpeg", ".png" };

            if (string.IsNullOrWhiteSpace(extension) || !extensionesPermitidas.Contains(extension))
            {
                model.LogoImagen = null;
                mensaje = "Solo se permiten archivos JPG, JPEG o PNG.";
                return;
            }

            var contentType = (file.ContentType ?? "").ToLowerInvariant();
            var tiposPermitidos = new[] { "image/jpeg", "image/png" };

            if (!tiposPermitidos.Contains(contentType))
            {
                model.LogoImagen = null;
                mensaje = "El archivo seleccionado no es una imagen válida.";
                return;
            }

            const long maxSize = 2 * 1024 * 1024;
            if (file.Size > maxSize)
            {
                model.LogoImagen = null;
                mensaje = "El logo excede el tamaño máximo de 2 MB.";
                return;
            }

            using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var bytes = ms.ToArray();

            if (bytes.Length == 0)
            {
                model.LogoImagen = null;
                mensaje = "No se pudo leer la imagen seleccionada.";
                return;
            }

            model.LogoImagen = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
            mensaje = "Logo cargado correctamente.";
            debugError = null;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            model.LogoImagen = null;
            debugError = ex.Message;
            mensaje = "Error al procesar la imagen.";
        }
    }

    private Task SubirPathCertificado(InputFileChangeEventArgs e) =>
        SubirArchivoP12(e, "Archivo Firma", "path", relativePath =>
        {
            model.PathCertificado = relativePath;
            nombrePathCertificadoSeleccionado = e.File?.Name;
        });

    private async Task SubirArchivoP12(InputFileChangeEventArgs e, string etiqueta, string subcarpeta, Action<string> asignarRuta)
    {
        try
        {
            if (e.FileCount > 1)
            {
                mensaje = $"Solo puedes subir un archivo .p12 para {etiqueta}.";
                debugError = null;
                return;
            }

            var file = e.File;

            if (file is null)
            {
                mensaje = $"No se seleccionó ningún archivo para {etiqueta}.";
                return;
            }

            var extension = Path.GetExtension(file.Name)?.ToLowerInvariant();
            if (!string.Equals(extension, ".p12", StringComparison.OrdinalIgnoreCase))
            {
                mensaje = $"Solo se permiten archivos .p12 para {etiqueta}.";
                debugError = null;
                return;
            }

            var contentType = (file.ContentType ?? string.Empty).Trim().ToLowerInvariant();
            var tiposPermitidos = new[]
            {
                string.Empty,
                "application/x-pkcs12",
                "application/pkcs12",
                "application/x-pkcs-12",
                "application/octet-stream"
            };

            if (!tiposPermitidos.Contains(contentType))
            {
                mensaje = $"El archivo seleccionado para {etiqueta} no es un certificado .p12 válido.";
                debugError = null;
                return;
            }

            if (file.Size <= 0)
            {
                mensaje = $"El archivo seleccionado para {etiqueta} está vacío.";
                debugError = null;
                return;
            }

            if (file.Size > MaxCertificadoSize)
            {
                mensaje = $"El archivo de {etiqueta} excede el tamaño máximo de 5 MB.";
                debugError = null;
                return;
            }

            using var stream = file.OpenReadStream(MaxCertificadoSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var bytes = ms.ToArray();
            if (bytes.Length == 0)
            {
                mensaje = $"No se pudo leer el archivo seleccionado para {etiqueta}.";
                debugError = null;
                return;
            }

            var relativePath = await GuardarArchivoCertificadoAsync(bytes, subcarpeta);
            asignarRuta(relativePath);
            mensaje = $"{etiqueta} cargado correctamente.";
            debugError = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = $"Error al procesar el archivo de {etiqueta}.";
        }
    }

    private async Task<string> GuardarArchivoCertificadoAsync(byte[] bytes, string subcarpeta)
    {
        var relativePath = $"certs/{subcarpeta}/{Guid.NewGuid():N}.p12";
        var physicalPath = Path.Combine(
            HostEnvironment.ContentRootPath,
            "App_Data",
            relativePath.Replace('/', Path.DirectorySeparatorChar));

        var directory = Path.GetDirectoryName(physicalPath);
        if (!string.IsNullOrWhiteSpace(directory))
        {
            Directory.CreateDirectory(directory);
        }

        await File.WriteAllBytesAsync(physicalPath, bytes);
        return relativePath;
    }

    private static string? ObtenerNombreArchivo(string? rutaArchivo) =>
        string.IsNullOrWhiteSpace(rutaArchivo)
            ? null
            : Path.GetFileName(rutaArchivo.Replace('\\', '/'));

    private static string FormatearMensajeError(string? rawMessage)
    {
        if (string.IsNullOrWhiteSpace(rawMessage))
        {
            return "Se produjo un error inesperado.";
        }

        var limpio = rawMessage
            .Replace("\r", " ", StringComparison.Ordinal)
            .Replace("\n", " ", StringComparison.Ordinal)
            .Trim();

        if (PareceHtml(limpio))
        {
            return "El servidor devolvió un error interno no controlado.";
        }

        return limpio.Length > 320
            ? $"{limpio[..317].TrimEnd()}..."
            : limpio;
    }

    private async Task<string> LeerMensajeErrorHttpAsync(HttpResponseMessage response, string fallbackMessage)
    {
        var rawBody = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(rawBody))
        {
            return fallbackMessage;
        }

        var mediaType = response.Content.Headers.ContentType?.MediaType;
        var normalizedBody = rawBody.Trim();

        if (string.Equals(mediaType, "text/html", StringComparison.OrdinalIgnoreCase) || PareceHtml(normalizedBody))
        {
            return $"{fallbackMessage} El servidor devolvió un error interno.";
        }

        var messageFromJson = IntentarExtraerMensajeJson(normalizedBody);
        if (!string.IsNullOrWhiteSpace(messageFromJson))
        {
            return FormatearMensajeError(messageFromJson);
        }

        return FormatearMensajeError(normalizedBody);
    }

    private static string? IntentarExtraerMensajeJson(string rawBody)
    {
        try
        {
            using var doc = JsonDocument.Parse(rawBody);
            var root = doc.RootElement;

            if (root.ValueKind == JsonValueKind.String)
            {
                return root.GetString();
            }

            if (root.ValueKind != JsonValueKind.Object)
            {
                return null;
            }

            if (root.TryGetProperty("message", out var messageElement) && messageElement.ValueKind == JsonValueKind.String)
            {
                return messageElement.GetString();
            }

            if (root.TryGetProperty("title", out var titleElement) && titleElement.ValueKind == JsonValueKind.String)
            {
                return titleElement.GetString();
            }

            if (root.TryGetProperty("errors", out var errorsElement) && errorsElement.ValueKind == JsonValueKind.Object)
            {
                foreach (var property in errorsElement.EnumerateObject())
                {
                    if (property.Value.ValueKind != JsonValueKind.Array)
                    {
                        continue;
                    }

                    foreach (var item in property.Value.EnumerateArray())
                    {
                        if (item.ValueKind == JsonValueKind.String && !string.IsNullOrWhiteSpace(item.GetString()))
                        {
                            return item.GetString();
                        }
                    }
                }
            }
        }
        catch
        {
            return null;
        }

        return null;
    }

    private static bool PareceHtml(string value) =>
        value.StartsWith("<!DOCTYPE", StringComparison.OrdinalIgnoreCase) ||
        value.StartsWith("<html", StringComparison.OrdinalIgnoreCase);
}
