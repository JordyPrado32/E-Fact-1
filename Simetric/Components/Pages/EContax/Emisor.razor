@page "/e-contax/emisor"

@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using Simetric.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.Services
@using Simetric.Services.EContax
@using System.IO
@using System.Text.Json
@using System.Security.Claims

@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IWebHostEnvironment HostEnvironment
@inject NavigationManager NavManager
@inject EmisorOnboardingService EmisorOnboardingService
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState

@rendermode InteractiveServer

@{
    var filteredEmisores = EmisoresFiltrados.ToList();
    var totalActivos = emisores.Count(e => e.Estado == true);
    var totalConLogo = emisores.Count(e => !string.IsNullOrWhiteSpace(e.LogoImagen));
    var totalConRetenciones = emisores.Count(e => string.Equals(e.Retenciones, "SI", StringComparison.OrdinalIgnoreCase));
}

<PageTitle>Emisor | @PageBrandTitle</PageTitle>

<div class="entity-shell @(IsEContaxContext ? "entity-shell-econtax" : string.Empty)" data-tour="emisor.page">
    <section class="entity-hero" data-tour="emisor.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Catálogo fiscal</span>
            <h2>Gestión de emisor</h2>
            <p>
                Administra la información fiscal y operativa del emisor con un flujo visual
                alineado al resto de pantallas administrativas.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Emisores activos</span>
                <strong>@totalActivos</strong>
                <small>Registros listos para operación y emisión electrónica.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Con logo</span>
                <strong>@totalConLogo</strong>
                <small>Empresas con identidad visual cargada en el sistema.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Retenciones</span>
                <strong>@totalConRetenciones</strong>
                <small>Emisores configurados para procesos de retención.</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="emisor.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Búsqueda y control</span>
            <h3>Consulta y actualiza los datos del emisor</h3>
            <p>Busca por razón social o RUC y usa el formulario lateral para crear o editar registros.</p>
        </div>

        <div class="toolbar-actions">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>
                <input class="search-input"
                       placeholder="Buscar por razón social o RUC"
                       @bind="filtro"
                       @bind:event="oninput" />
            </div>

            <button type="button" class="secondary-btn" @onclick="CargarTodo">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refrescar</span>
            </button>
            
            @if (!esAsociado)
            {
                <button type="button"
                    class="primary-btn"
                    @onclick="Nuevo"
                    disabled="@(YaExisteEmisorActivo() && !editando)">
                    <i class="bi bi-plus-lg"></i>
                    <span>Nuevo emisor</span>
                </button>
            }
        </div>
    </section>

    <section class="entity-grid">
        <section class="table-card" data-tour="emisor.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado activo</span>
                    <h3>Emisores registrados</h3>
                </div>
                <span class="table-badge">@filteredEmisores.Count registros</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(debugError))
            {
                <div class="status-banner status-banner-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@debugError</span>
                </div>
            }

            @if (cargando)
            {
                <div class="state-card">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando emisores</h3>
                    <p>Preparando la configuración fiscal y visual de las empresas registradas.</p>
                </div>
            }
            else if (!filteredEmisores.Any())
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="bi bi-building-x"></i>
                    </div>
                    <h3>No hay emisores para mostrar</h3>
                    <p>Ajusta el criterio de búsqueda o registra un nuevo emisor.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table entity-table entity-table-emisores mb-0">
                        <thead>
                            <tr>
                                <th>Razón social</th>
                                <th>RUC</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in filteredEmisores)
                            {
                                <tr>
                                    <td>
                                        <div class="cell-main cell-main-stacked">
                                            <strong>@e.RazonSocial</strong>
                                            <span>@(string.IsNullOrWhiteSpace(e.NomComercial) ? "Sin nombre comercial" : e.NomComercial)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="code-pill">@(string.IsNullOrWhiteSpace(e.Ruc) ? "Sin RUC" : e.Ruc)</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-group">
                                            <button type="button" class="action-btn action-view"
                                                    title="Ver detalle"
                                                    @onclick="() => VerDetalle(e)">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (!esAsociado) // Solo se muestra si NO es asociado
                                            {
                                                <button type="button" class="action-btn action-edit"
                                                title="Editar"
                                                @onclick="() => Editar(e.Codigo)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <button type="button" class="action-btn action-delete"
                                                title="Eliminar"
                                                @onclick="() => ConfirmarEliminar(e)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (mostrarConfirmacion && emisorAEliminar is not null)
            {
                <div class="confirm-card">
                    <div class="confirm-copy">
                        <strong>Eliminar lógicamente el emisor</strong>
                        <p>@emisorAEliminar.RazonSocial</p>
                    </div>

                    <div class="confirm-actions">
                        <button type="button" class="secondary-btn" @onclick="CancelarEliminar">Cancelar</button>
                        <button type="button" class="danger-btn" @onclick="EliminarConfirmado">Sí, eliminar</button>
                    </div>
                </div>
            }
        </section>

        <section class="editor-card entity-editor-card" data-tour="emisor.editor">
            <div class="editor-head">
                <div>
                    <span class="panel-kicker">Formulario operativo</span>
                    <h3>@(editando ? "Editar emisor" : "Registrar emisor")</h3>
                    <p>Complete los datos fiscales, de contacto y configuración de la empresa.</p>
                </div>
                <span class="editor-badge @(editando ? "editor-badge-edit" : "editor-badge-new")">
                    @(editando ? "Edición" : "Nuevo")
                </span>
            </div>

            <div class="editor-body entity-form-legacy">

                <EditForm Model="@model" OnValidSubmit="Guardar" @key="formKey">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger small" />

                    @if (BloquearFormularioCreacion)
                    {
                        <div class="status-banner status-banner-info">
                            <i class="bi bi-lock"></i>
                            <span>@MensajeBloqueoFormulario</span>
                        </div>
                    }

                    <fieldset class="p-0 m-0 border-0" disabled="@BloquearFormularioCreacion">
                        <div class="row mb-2 mt-3">
                            <div class="col">
                                <label class="form-label small fw-bold">Razón Social *</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.RazonSocial" />
                                <ValidationMessage For="@(() => model.RazonSocial)" class="text-danger small" />
                            </div>
                            <div class="col">
                                <label class="form-label small fw-bold">RUC *</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.Ruc" />
                                <ValidationMessage For="@(() => model.Ruc)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Nombre Comercial *</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.NomComercial" />
                            <ValidationMessage For="@(() => model.NomComercial)" class="text-danger small" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Dirección Establecimiento *</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.DirEstablecimiento" />
                            <ValidationMessage For="@(() => model.DirEstablecimiento)" class="text-danger small" />
                        </div>

                        <div class="mb-2 d-none">
                            <label class="form-label small fw-bold">Lleva Contabilidad *</label>
                            <InputSelect class="form-select form-select-sm" @bind-Value="model.LlevaContabilidad">
                                <option value="">-- Seleccione --</option>
                                <option value="SI">Sí</option>
                                <option value="NO">No</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => model.LlevaContabilidad)" class="text-danger small" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small">Dirección Matriz *</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.DireccionMatriz" />
                            <ValidationMessage For="@(() => model.DireccionMatriz)" class="text-danger small" />
                        </div>

                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small fw-bold text-primary">
                                    <i class="bi bi-image me-1"></i>Logo Empresa
                                </label>

                                <InputFile class="form-control form-control-sm"
                                           accept=".jpg,.jpeg,.png,image/jpeg,image/png"
                                           OnChange="SubirLogo" />

                                <ValidationMessage For="@(() => model.LogoImagen)" class="text-danger small" />

                                <small class="text-muted d-block mt-1">
                                    Solo se permiten imágenes JPG, JPEG o PNG de hasta 2 MB.
                                </small>

                                @if (!string.IsNullOrWhiteSpace(model.LogoImagen))
                                {
                                    <div class="mt-2 text-center border rounded p-2 bg-light position-relative">
                                        <img src="@model.LogoImagen"
                                             style="max-height: 60px; max-width: 100%; object-fit: contain;"
                                             alt="Logo" />
                                        <button type="button"
                                                class="btn-close position-absolute top-0 end-0 m-1"
                                                style="font-size: 0.5rem;"
                                                title="Quitar logo"
                                                @onclick="QuitarLogo"></button>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-12 mt-2 d-none">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="RetencionesBool" />
                                <label class="form-check-label fw-semibold">
                                    ¿Es agente de Retención?
                                </label>
                            </div>
                        </div>

                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label small">Teléfono *</label>
                                <InputText class="form-control form-control-sm" @bind-Value="model.Telefono" />
                                <ValidationMessage For="@(() => model.Telefono)" class="text-danger small" />
                            </div>
                        <div class="col">
                            <label class="form-label small">Correo Electrónico</label>
                            <InputText class="form-control form-control-sm" @bind-Value="model.Email" />
                            <ValidationMessage For="@(() => model.Email)" class="text-danger small" />
                        </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label small">Archivo Firma</label>
                                <InputFile class="form-control form-control-sm"
                                           accept=".p12"
                                           OnChange="SubirPathCertificado" />
                                <small class="text-muted d-block mt-1">
                                    Solo se permiten archivos .p12 de hasta 5 MB.
                                </small>

                                @if (!string.IsNullOrWhiteSpace(NombrePathCertificadoActual))
                                {
                                    <div class="mt-2 border rounded p-2 bg-light position-relative">
                                        <div class="d-flex align-items-center gap-2 pe-4">
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                            <span class="small text-break">Archivo .p12 cargado</span>
                                        </div>
                                        <button type="button"
                                                class="btn-close position-absolute top-0 end-0 m-1"
                                                style="font-size: 0.5rem;"
                                                title="Quitar certificado"
                                                @onclick="QuitarPathCertificado"></button>
                                    </div>
                                }
                            </div>
                            <div class="col">
                                <label class="form-label small">Clave Certificado</label>
                                <div class="cert-password-shell">
                                    <input type="@tipoPassword"
                                           class="form-control form-control-sm cert-password-input"
                                           @bind="model.ClaveCertificado" />
                                    <button class="cert-password-eye" type="button" @onclick="TogglePasswordVisibility" title="Mostrar u ocultar clave">
                                        <i class="bi @(mostrarPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                                <small class="text-muted d-block mt-1">
                                    Ingresa la clave alfanumérica del archivo .p12.
                                </small>

                                @if (TieneClaveCertificadoActual)
                                {
                                    <div class="mt-2 border rounded p-2 bg-light position-relative">
                                        <div class="d-flex align-items-center gap-2 pe-4">
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                            <span class="small text-break">Clave configurada</span>
                                        </div>
                                        <button type="button"
                                                class="btn-close position-absolute top-0 end-0 m-1"
                                                style="font-size: 0.5rem;"
                                                title="Quitar clave"
                                                @onclick="QuitarClaveCertificado"></button>
                                    </div>
                                }
                            </div>
                        </div>
                    </fieldset>

                    <div class="form-actions entity-form-actions">
                        <button class="secondary-btn" type="button" @onclick="Nuevo" disabled="@BloquearFormularioCreacion">Limpiar</button>
                        <button class="primary-btn" type="submit" disabled="@BloquearFormularioCreacion">
                            <i class="bi bi-save me-1"></i> @(editando ? "Guardar cambios" : "Crear emisor")
                        </button>
                    </div>
                </EditForm>
            </div>
        </section>
    </section>
</div>

@if (mostrarDetalle && emisorDetalle is not null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" @onclick:stopPropagation="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 8px;">
                <div class="modal-header text-white" style="background-color: var(--n-blue); border-radius: 8px 8px 0 0;">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-building me-2"></i>Detalle del Emisor
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarDetalle"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6 border-end pe-md-4">
                            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3">Información General</h6>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Razón Social:</div>
                                <div class="col-7 fw-medium text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.RazonSocial) ? "N/A" : emisorDetalle.RazonSocial)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">RUC:</div>
                                <div class="col-7">
                                    <span class="badge bg-light text-dark border">
                                        @(string.IsNullOrWhiteSpace(emisorDetalle.Ruc) ? "N/A" : emisorDetalle.Ruc)
                                    </span>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Nombre Comercial:</div>
                                <div class="col-7 text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.NomComercial) ? "N/A" : emisorDetalle.NomComercial)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Lleva Contabilidad:</div>
                                <div class="col-7 text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.LlevaContabilidad) ? "N/A" : emisorDetalle.LlevaContabilidad)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Retenciones:</div>
                                <div class="col-7 text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.Retenciones) ? "NO" : emisorDetalle.Retenciones)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Estado:</div>
                                <div class="col-7">
                                    <span class="badge rounded-pill bg-success-subtle text-success">
                                        @(emisorDetalle.Estado == true ? "Activo" : "Inactivo")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 ps-md-4">
                            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3">Contacto y Configuración</h6>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Teléfono:</div>
                                <div class="col-7 text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.Telefono) ? "N/A" : emisorDetalle.Telefono)
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5 text-muted fw-bold small">Email:</div>
                                    <div class="col-7 text-dark">
                                        @(string.IsNullOrWhiteSpace(emisorDetalle.Email) ? "N/A" : emisorDetalle.Email)
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Dirección Establecimiento:</div>
                                <div class="col-7 text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.DirEstablecimiento) ? "N/A" : emisorDetalle.DirEstablecimiento)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Dirección Matriz:</div>
                                <div class="col-7 text-dark">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.DireccionMatriz) ? "N/A" : emisorDetalle.DireccionMatriz)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Archivo Firma:</div>
                                <div class="col-7 text-dark small">
                                    @(string.IsNullOrWhiteSpace(emisorDetalle.PathCertificado) ? "N/A" : ObtenerNombreArchivo(emisorDetalle.PathCertificado))
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Clave Certificado:</div>
                                <div class="col-7 text-dark">
                                    @(emisorDetalle.TieneClaveCertificadoConfigurada ? "Configurada" : "N/A")
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(emisorDetalle.LogoImagen))
                    {
                        <div class="row mt-4">
                            <div class="col-12 text-muted fw-bold small mb-2">Logo de la Empresa:</div>
                            <div class="col-12 text-center p-3 rounded" style="background-color: #f8fafc; border: 1px solid #dee2e6;">
                                <img src="@emisorDetalle.LogoImagen"
                                     alt="Logo Empresa"
                                     style="max-height: 120px; max-width: 100%; object-fit: contain;" />
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light" style="border-radius: 0 0 8px 8px; border-top: 1px solid #dee2e6;">
                    <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarDetalle">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {

    private bool IsEContaxContext => IsEContaxPath(NavManager.Uri);
    private string PageBrandTitle => IsEContaxContext ? "Numerica E-Contax" : "Numerica e-fact";

    private EmisorDto? emisorDetalle;
    private bool mostrarDetalle = false;
    bool esAsociado = false;
    private class EmisorDto
    {
        public int Codigo { get; set; }
        public string? RazonSocial { get; set; }
        public string? Ruc { get; set; }
        public string? NomComercial { get; set; }
        public string? DirEstablecimiento { get; set; }
        public string? Email { get; set; } // <--- Añadir
        [System.Text.Json.Serialization.JsonPropertyName("llevacontabilidad")]
        public string? LlevaContabilidad { get; set; }

        public string? LogoImagen { get; set; }
        public string? DireccionMatriz { get; set; }
        public string? ClaveInterna { get; set; }
        public string? Retenciones { get; set; }
        public string? PathCertificado { get; set; }
        public string? ClaveCertificado { get; set; }
        public bool TieneClaveCertificadoConfigurada { get; set; }
        public string? Telefono { get; set; }
        public bool? Estado { get; set; }
        public int? IdUsuario { get; set; }

        public string? CodEstablecimiento { get; set; }
        public string? CodPuntoEmision { get; set; }
    }



    private class EmisorUpsertDto
    {
        public int Codigo { get; set; }

        [Required(ErrorMessage = "La razón social es obligatoria")]
        [StringLength(70, ErrorMessage = "Máximo 70 caracteres")]
        public string? RazonSocial { get; set; }

        [Required(ErrorMessage = "El RUC es obligatorio")]
        [RegularExpression(@"^\d{13}$", ErrorMessage = "El RUC debe tener 13 dígitos")]
        public string? Ruc { get; set; }

        [Required(ErrorMessage = "El nombre comercial es obligatorio")]
        [StringLength(100, ErrorMessage = "Máximo 100 caracteres")]
        public string? NomComercial { get; set; }
        [EmailAddress(ErrorMessage = "Formato de correo inválido")]
        [StringLength(50, ErrorMessage = "Máximo 50 caracteres")]
        public string? Email { get; set; } // <--- Añadir
        [Required(ErrorMessage = "La dirección del establecimiento es obligatoria")]
        [StringLength(250, ErrorMessage = "Máximo 250 caracteres")]
        public string? DirEstablecimiento { get; set; }

        [Required(ErrorMessage = "Debe seleccionar si lleva contabilidad")]
        [RegularExpression(@"^(SI|NO)$", ErrorMessage = "Solo se permite SI o NO")]
        public string? LlevaContabilidad { get; set; }

        [Required(ErrorMessage = "El logo de la empresa es obligatorio")]
        public string? LogoImagen { get; set; }

        [Required(ErrorMessage = "La dirección matriz es obligatoria")]
        [StringLength(255, ErrorMessage = "Máximo 255 caracteres")]
        public string? DireccionMatriz { get; set; }

        [StringLength(25, ErrorMessage = "Máximo 25 caracteres")]
        public string? ClaveInterna { get; set; }

        public string? Retenciones { get; set; }
        [StringLength(150, ErrorMessage = "Máximo 150 caracteres")]
        public string? PathCertificado { get; set; }
        [RegularExpression(@"^[A-Za-z0-9]*$", ErrorMessage = "La clave del certificado debe ser alfanumérica")]
        public string? ClaveCertificado { get; set; }
        public bool EliminarClaveCertificado { get; set; }

        [Required(ErrorMessage = "El teléfono es obligatorio")]
        [RegularExpression(@"^\d{7,10}$", ErrorMessage = "El teléfono debe tener entre 7 y 10 dígitos")]
        public string? Telefono { get; set; }

        public bool? Estado { get; set; }
        public int? IdUsuario { get; set; }

        public string? CodEstablecimiento { get; set; }
        public string? CodPuntoEmision { get; set; }
    }
