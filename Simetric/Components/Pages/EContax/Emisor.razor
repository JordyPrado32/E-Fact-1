    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!await ValidarAccesoEContaxAsync(user))
        {
            return;
        }

        var jefeClaim = user.FindFirst("IdJefe")?.Value;
        var estadoAsociadoClaim = user.FindFirst("EstadoAsociado")?.Value;

        esAsociado =
            (bool.TryParse(estadoAsociadoClaim, out var estadoAsociado) && estadoAsociado) ||
            !string.IsNullOrWhiteSpace(jefeClaim);

        await CargarTodo();
        Nuevo();
    }

    private async Task CargarTodo()
    {
        cargando = true;
        mensaje = null;
        debugError = null;

        try
        {
            var idUsuario = await ObtenerIdUsuarioLogueado();

            if (idUsuario != null)
            {
                emisores = await Http.GetFromJsonAsync<List<EmisorDto>>($"api/emisores?idUsuario={idUsuario}") ?? new();
                await EmisorOnboardingService.RefreshRequirementAsync(idUsuario);
            }
            else
            {
                debugError = "No se pudo obtener la sesión del usuario.";
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private IEnumerable<EmisorDto> EmisoresFiltrados =>
        string.IsNullOrWhiteSpace(filtro)
            ? emisores
            : emisores.Where(e =>
                (e.RazonSocial ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (e.Ruc ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase));

