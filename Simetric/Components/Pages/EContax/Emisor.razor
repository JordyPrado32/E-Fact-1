    private async Task Editar(int id)
    {
        mensaje = "Cargando emisor...";
        debugError = null;

        try
        {
            var idUsuario = await ObtenerIdUsuarioLogueado();
            if (idUsuario == null || idUsuario <= 0)
            {
                mensaje = "No se pudo obtener la sesión del usuario.";
                return;
            }

            var item = await Http.GetFromJsonAsync<EmisorDto>($"api/emisores/{id}?idUsuario={idUsuario}");
            if (item is null)
            {
                mensaje = "No se encontró el emisor.";
                return;
            }

            model = new EmisorUpsertDto
            {
                Codigo = item.Codigo,
                RazonSocial = item.RazonSocial,
                Ruc = item.Ruc,
                NomComercial = item.NomComercial,
                DirEstablecimiento = item.DirEstablecimiento,
                LlevaContabilidad = "NO",
                LogoImagen = item.LogoImagen,
                ClaveInterna = item.ClaveInterna,
                DireccionMatriz = item.DireccionMatriz,
                Retenciones = string.IsNullOrWhiteSpace(item.Retenciones) ? "NO" : item.Retenciones,
                PathCertificado = item.PathCertificado,
                ClaveCertificado = null,
                Telefono = item.Telefono,
                Estado = item.Estado ?? true,
                CodEstablecimiento = item.CodEstablecimiento,
                CodPuntoEmision = item.CodPuntoEmision,
                Email = item.Email
            };
            nombrePathCertificadoSeleccionado = null;
            emisorDetalleEdicionTieneClaveCertificado = item.TieneClaveCertificadoConfigurada;

            editando = true;
            mensaje = "Emisor cargado para edición.";
            formKey = Guid.NewGuid();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
            mensaje = "Error al cargar emisor.";
        }
    }

    private async Task<int?> ObtenerIdUsuarioLogueado()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var idClaim = user.FindFirst("IdUsuario")?.Value;
        return int.TryParse(idClaim, out var id) ? id : null;
    }

    private async Task<bool> ValidarAccesoEContaxAsync(ClaimsPrincipal user)
    {
        if (!IsEContaxContext)
            return true;

        if (user.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var userId = ObtenerIdUsuario(user);
        if (userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return false;
        }

        var isSuperAdmin = string.Equals(
            user.FindFirst("IdTipoUsuario")?.Value,
            AppAccessService.AdminRoleId,
            StringComparison.OrdinalIgnoreCase);

        var access = await AppAccessService.CanAccessAsync(userId, EContaxRoutes.ServiceKey, isSuperAdmin);
        if (!access.HasAccess)
        {
            NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EContaxRoutes.ServiceKey)}", forceLoad: true);
            return false;
        }

        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EContaxRoutes.ServiceKey);
        return true;
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private bool IsEContaxPath(string location) => EContaxRoutes.IsEContaxPath(NavManager, location);

    private bool YaExisteEmisorActivo()
    {
        return emisores.Any(e => e.Estado == true);
    }

    private bool BloquearFormularioCreacion => !editando && (YaExisteEmisorActivo() || esAsociado);
    private string MensajeBloqueoFormulario => esAsociado
        ? "Los usuarios asociados pueden consultar el emisor de la cuenta, pero no crear ni modificar emisores."
        : "Esta cuenta ya tiene un emisor activo. Puedes editarlo desde el listado.";

    private async Task Guardar()
    {
        mensaje = "Guardando...";
        debugError = null;

        if (esAsociado)
        {
            mensaje = "Los usuarios asociados no pueden crear ni modificar emisores.";
            return;
        }

        var idActual = await ObtenerIdUsuarioLogueado();
        if (idActual == null)
        {
            mensaje = "Error: No se pudo identificar al usuario en sesión.";
            return;
        }

        // VALIDACIÓN: solo permitir un emisor al crear
        if (!editando && YaExisteEmisorActivo())
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "Emisor ya registrado",
                text = "Solo puedes registrar un emisor activo en el sistema.",
                confirmButtonText = "Entendido"
            });

            mensaje = "Ya existe un emisor activo registrado.";
            return;
        }

        model.IdUsuario = idActual;
        model.Estado ??= true;
        model.Retenciones = "NO";
        model.LlevaContabilidad = "NO";

        model.RazonSocial = model.RazonSocial?.Trim();
        model.Ruc = model.Ruc?.Trim();
        model.NomComercial = model.NomComercial?.Trim();
        model.DirEstablecimiento = model.DirEstablecimiento?.Trim();
        model.DireccionMatriz = model.DireccionMatriz?.Trim();
        model.ClaveInterna = model.ClaveInterna?.Trim();
        model.Telefono = model.Telefono?.Trim();
        model.Email = model.Email?.Trim();
        model.LlevaContabilidad = model.LlevaContabilidad?.Trim().ToUpperInvariant();
        model.PathCertificado = model.PathCertificado?.Trim();
        model.ClaveCertificado = model.ClaveCertificado?.Trim();
        if (!string.IsNullOrWhiteSpace(model.ClaveCertificado))
        {
            model.EliminarClaveCertificado = false;
        }

        model.CodEstablecimiento = null;
        model.CodPuntoEmision = null;

        try
        {
            var creandoPrimerEmisor = !editando;
            HttpResponseMessage resp = editando
     ? await Http.PutAsJsonAsync($"api/emisores/{model.Codigo}", model)
     : await Http.PostAsJsonAsync("api/emisores", model);

            if (!resp.IsSuccessStatusCode)
            {
                var detalle = await LeerMensajeErrorHttpAsync(resp, "No se pudo guardar el emisor.");

                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "No se pudo guardar el emisor",
                    text = detalle
                });

                debugError = detalle.Equals("No se pudo guardar el emisor.", StringComparison.Ordinal)
                    ? null
                    : detalle;
                mensaje = "No se pudo guardar el emisor.";
                return;
            }

            mensaje = "Operación realizada correctamente.";
            await CargarTodo();
            Nuevo();

            await EmisorOnboardingService.RefreshRequirementAsync(idActual);
            EmisorOnboardingService.NotifyChanged();

            if (creandoPrimerEmisor)
            {
                if (!IsEContaxContext)
                {
                    NavManager.NavigateTo(EmisorOnboardingService.RequiredRoute ?? "/dashboard", replace: true);
                }
            }
        }
        catch (Exception ex)
        {
            debugError = FormatearMensajeError(ex.Message);
            mensaje = "Error al guardar (API).";
        }
    }

