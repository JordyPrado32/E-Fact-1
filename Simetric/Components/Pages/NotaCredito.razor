@if (mostrarVistaPreviaPdfTemporal)
{
    <div class="n-product-modal-backdrop" style="position: fixed; inset: 0; background: rgba(15, 23, 42, 0.44); backdrop-filter: blur(4px); z-index: 2990;" @onclick="CerrarVistaPreviaPdfTemporalAsync"></div>
    <div class="n-product-modal-shell" style="position: fixed; inset: 0; width: 100vw; height: 100vh; z-index: 3000; display: flex; align-items: center; justify-content: center; padding: 2vh 2vw;" role="dialog" aria-modal="true" aria-labelledby="pdfPreviewNcTitulo" @onclick="CerrarVistaPreviaPdfTemporalAsync">
        <div class="n-modal n-product-modal-content n-pdf-preview-modal" style="width: min(96vw, 1280px); height: min(94vh, 920px); display: flex; flex-direction: column; background: #ffffff; border-radius: 18px; box-shadow: 0 20px 50px rgba(15, 23, 42, 0.15); overflow: hidden; border: 1px solid #dceaf5;" @onclick:stopPropagation>
            <div class="n-modal-header" style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; background: linear-gradient(180deg, #ffffff, #f7fbff); border-bottom: 1px solid rgba(15, 23, 42, 0.08); flex-shrink: 0;">
                <div style="display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap;">
                    <h5 id="pdfPreviewNcTitulo" style="margin: 0; font-size: 1.15rem; font-weight: 800; color: #0f172a;">@tituloPreviewPdfNotaCredito</h5>
                    <span style="font-size: 0.72rem; font-weight: 800; color: #006bb5; background: rgba(0, 107, 181, 0.12); padding: 0.25rem 0.75rem; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.04em;">@etiquetaPreviewPdfNotaCredito</span>
                    <span style="color: #64748b; font-size: 0.82rem; font-weight: 500;">Vista ampliada para revisar el PDF completo antes de emitir.</span>
                </div>
                <button type="button" @onclick="CerrarVistaPreviaPdfTemporalAsync" style="background: transparent; border: 0; color: #64748b; font-size: 1.34rem; cursor: pointer; transition: color 0.18s; padding: 0.2rem;" aria-label="Cerrar vista previa" onmouseover="this.style.color='#006bb5'" onmouseout="this.style.color='#64748b'">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="n-modal-body" style="flex: 1 1 auto; min-height: 0; padding: 0; background: #f4f8fc; position: relative;">
                @if (!string.IsNullOrWhiteSpace(urlPdfTemporal))
                {
                    <iframe src="@urlPdfTemporal" style="width: 100%; height: 100%; min-height: 0; border: 0; background: #ffffff;" title="Vista previa PDF temporal"></iframe>
                }
                else
                {
                    <div style="height: 100%; display: grid; place-items: center; gap: 0.75rem; padding: 2rem; color: #143451;">
                        <div class="spinner-border text-primary" role="status"></div>
                        <strong>Generando PDF...</strong>
                    </div>
                }
            </div>

            <div class="n-modal-footer" style="display: flex; align-items: center; justify-content: flex-end; padding: 0.8rem 1.5rem; background: #ffffff; border-top: 1px solid rgba(15, 23, 42, 0.08); flex-shrink: 0;">
                <button type="button" class="secondary-btn secondary-btn-quiet" @onclick="CerrarVistaPreviaPdfTemporalAsync">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (guardando)
