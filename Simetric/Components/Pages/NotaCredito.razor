    private string FormatearSerie(string raw)
    {
        raw = (raw ?? "").Replace("-", "").Trim();
        if (raw.Length >= 6) return $"{raw.Substring(0, 3)}-{raw.Substring(3, 3)}";
        return raw;
    }

    private static string NormalizarSerieRaw(string? valor)
    {
        var limpio = SoloDigitosNc(valor);
        return limpio.Length >= 6 ? limpio[..6] : limpio;
    }

    private static string NormalizarSecuencial(string? valor)
    {
        var limpio = SoloDigitosNc(valor);
        return string.IsNullOrWhiteSpace(limpio) ? (valor ?? string.Empty).Trim() : limpio.PadLeft(9, '0');
    }

    private static string ConstruirDocumentoModificadoCompleto(string? serie, string? secuencial)
    {
        var serieLimpia = NormalizarSerieRaw(serie);
        var secuencialLimpio = NormalizarSecuencial(secuencial);
        return serieLimpia.Length == 6 ? $"{serieLimpia}{secuencialLimpio}" : secuencialLimpio;
    }

    private static string SoloDigitosNc(string? valor)
        => new((valor ?? string.Empty).Where(char.IsDigit).ToArray());

    private static string FormatearDocumentoModificadoInput(string? valor)
    {
        var limpio = SoloDigitosNc(valor);
        if (limpio.Length > 15)
            limpio = limpio[..15];

        return limpio.Length switch
        {
            <= 3 => limpio,
            <= 6 => $"{limpio[..3]}-{limpio[3..]}",
            _ => $"{limpio[..3]}-{limpio.Substring(3, 3)}-{limpio[6..]}"
        };
    }

    private string FormatearNumeroCompletoNc(string? serie, string? secuencial)
    {
        var serieVisual = FormatearSerie(serie ?? string.Empty);
        var secuencialVisual = (secuencial ?? string.Empty).Trim().PadLeft(9, '0');

        return string.IsNullOrWhiteSpace(serieVisual)
            ? secuencialVisual
            : $"{serieVisual}-{secuencialVisual}";
    }

    private string FacturaReferenciaVisual
    {
        get
        {
            var serieVisual = !string.IsNullOrWhiteSpace(factura.Serie)
                ? FormatearSerie(factura.Serie)
                : serieFacturaVisual;

            return !string.IsNullOrWhiteSpace(serieVisual) &&
                   serieVisual != "—" &&
                   !string.IsNullOrWhiteSpace(factura.Numfactura)
                ? $"{serieVisual}-{factura.Numfactura}"
                : "—";
        }
    }

    private string NombreClienteVisual =>
        !string.IsNullOrWhiteSpace(cliente.Nombrerazonsocial)
            ? cliente.Nombrerazonsocial
            : ((cliente.Nombres ?? "") + " " + (cliente.Apellidos ?? "")).Trim();

    private static string ObtenerNombreClienteVisual(Cliente clienteActual)
    {
        if (!string.IsNullOrWhiteSpace(clienteActual.Nombrerazonsocial))
            return clienteActual.Nombrerazonsocial.Trim();

        var nombreCompleto = $"{clienteActual.Nombres ?? string.Empty} {clienteActual.Apellidos ?? string.Empty}".Trim();
        return string.IsNullOrWhiteSpace(nombreCompleto)
            ? "Cliente"
            : nombreCompleto;
    }

