    private async Task OcultarSugerenciasDetalleNotaCreditoAsync(DetalleNcDto item)
    {
        await Task.Delay(150);

        if (seleccionandoProductoNotaDesdeLista)
            return;

        if (ReferenceEquals(filaBusquedaProductoNotaActiva, item))
        {
            filaBusquedaProductoNotaActiva = null;
            sugerenciasProductosNota = null;
            indiceSugerenciaProductoNotaActiva = -1;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnKeyDownConceptoDetalleNotaCreditoAsync(DetalleNcDto item, KeyboardEventArgs e)
    {
        if (modoEmision != ModoEmisionNotaCredito.Manual)
            return;

        if (e.Key == "ArrowDown")
        {
            if (sugerenciasProductosNota == null || !sugerenciasProductosNota.Any())
                await MostrarSugerenciasDetalleNotaCreditoAsync(item);

            indiceSugerenciaProductoNotaActiva = MoverIndiceCircular(indiceSugerenciaProductoNotaActiva, 1, sugerenciasProductosNota?.Count ?? 0);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            indiceSugerenciaProductoNotaActiva = MoverIndiceCircular(indiceSugerenciaProductoNotaActiva, -1, sugerenciasProductosNota?.Count ?? 0);
            return;
        }

        if (e.Key == "Escape")
        {
            filaBusquedaProductoNotaActiva = null;
            sugerenciasProductosNota = null;
            indiceSugerenciaProductoNotaActiva = -1;
            return;
        }

        if ((e.Key == "Enter" || e.Key == "Tab") && sugerenciasProductosNota?.Any() == true)
        {
            var indice = indiceSugerenciaProductoNotaActiva >= 0 && indiceSugerenciaProductoNotaActiva < sugerenciasProductosNota.Count
                ? indiceSugerenciaProductoNotaActiva
                : 0;
            await SeleccionarProductoNotaEnFilaAsync(item, sugerenciasProductosNota[indice]);
        }
    }

    private Task SeleccionarProductoNotaEnFilaAsync(DetalleNcDto item, ProductoLookupDetalleDto producto)
    {
        CargarProductoEnDetalleNotaCredito(item, producto);
        return Task.CompletedTask;
    }

