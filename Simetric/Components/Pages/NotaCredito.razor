@page "/facturacion/nota-credito"
@using Simetric.DTOs
@implements IDisposable
@using Simetric.Components.Shared
@using Simetric.Models
@using Simetric.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using System.Text.Json
@using System.Globalization
@using System.IO
@using System.Xml.Linq
@using NcModel = Simetric.Models.NotaCredito
@using static Simetric.Services.NotaCreditoService
@using System.Text
@using Simetric.Models.Glogales
@inject Simetric.Services.NotaCreditoService NotaCreditoService
@inject IdentificacionService IdentificacionService
@inject AuthenticationStateProvider AuthStateProvider
@inject FacturacionService FacturacionService
@inject INotaCreditoPdfService NotaCreditoPdfService
@inject InitialSequencePromptService InitialSequencePromptService
@inject IJSRuntime JS
@inject HttpClient Http
@inject EmisionControlService EmisionControlService
@inject SweetAlertService AlertService
@inject NavigationManager NavigationManager

<PageTitle>Nota de Credito | Numerica e-fact</PageTitle>

<div class="container-fluid py-3 px-3 px-md-4 bg-light-modern docs-unified-page" data-tour="nc.page">
    <DocumentoEmisionToast Message="@mensajeRapidoEmision"
                           IsError="@mensajeRapidoEsError"
                           PdfUrl="@documentoGeneradoPdfUrl"
                           OnOpenPdf="AbrirDocumentoGeneradoAsync" />

    <InitialSequenceModal Visible="@mostrarModalSecuenciaInicial"
                          Title="Configuracion inicial de secuencia"
                          Description="Antes de emitir tu primera nota de credito en este sistema, indicanos si ya habias generado notas de credito anteriormente."
                          QuestionLabel="Ya habias generado notas de credito antes?"
                          SequenceLabel="Ingresa la el ultimo numero de nota de credito donde te quedaste"
                          SequencePlaceholder="Ej: 000000125"
                          SequenceHint="Si te quedaste en la 125, la siguiente sera la 126."
                          HadPreviousDocuments="usuarioYaEmitioAntes"
                          HadPreviousDocumentsChanged="OnCambioRespuestaSecuencia"
                          PreviousSequence="@secuenciaAnteriorManual"
                          PreviousSequenceChanged="OnSecuenciaAnteriorManualChanged"
                          ErrorMessage="@errorSecuenciaInicial"
                          OnDismiss="@(() => mostrarModalSecuenciaInicial = false)"
                          OnConfirm="ConfirmarSecuenciaInicialAsync" />

    <section class="docs-form-hero" data-tour="nc.hero">
        <div class="docs-form-hero-body">
            <div class="docs-form-hero-copy invoice-heading-card nc-heading-card">
                <div class="invoice-heading-head nc-heading-head">
                    <span class="invoice-heading-icon nc-heading-icon"><i class="bi bi-journal-minus"></i></span>
                    <span class="docs-form-kicker">Documento de ajuste</span>
                </div>
                <h2 class="docs-form-title">Nueva nota de credito</h2>
                <p class="docs-form-text">
                    Parte de la factura original, corrige el detalle y conserva una vista clara
                    para emitir o reenviar el documento sin salir de esta pantalla.
                </p>
                <div class="invoice-heading-meter nc-heading-meter"><span></span></div>
            </div>

            <div class="docs-form-toolbar">
                <div class="n-invoice-id-strip nc-id-strip" aria-label="Identificadores de la nota de credito">
                    <div class="n-invoice-id-pill nc-id-pill">
                        <span>Serie</span>
                        @if (seriesDocumento.Count > 1)
                        {
                            <select class="n-invoice-serie-select"
                                    value="@serieNcRawActual"
                                    @onchange="OnSerieDocumentoChangedAsync"
                                    aria-label="Seleccionar serie de nota de credito">
                                @foreach (var serie in seriesDocumento)
                                {
                                    <option value="@serie.SerieRaw">@serie.SerieVisual</option>
                                }
                            </select>
                        }
                        else
                        {
                            <strong>@serieNcVisual</strong>
                        }
                    </div>
                    <div class="n-invoice-id-pill nc-id-pill">
                        <span>Nota de credito</span>
                        <strong>@secuencialNcVisual</strong>
                    </div>
                </div>

                <button type="button" class="n-btn n-btn-secondary" @onclick="AbrirHistorialNotasCreditoAsync">
                    <i class="bi bi-clock-history me-2"></i> Historial
                </button>

                <button type="button" class="n-btn n-btn-secondary" @onclick="LimpiarFormularioNotaCreditoAsync">
                    <i class="bi bi-arrow-clockwise me-2"></i> Limpiar pantalla
                </button>
            </div>
        </div>
    </section>

    <section class="nc-issue-options" aria-label="Opciones para emitir nota de credito">
        <div class="nc-issue-options-copy">
            <span class="nc-section-kicker">Opciones de emision</span>
            <strong>Tambien puedes emitir la nota de credito de estas formas</strong>
        </div>

        <div class="nc-issue-options-grid">
            <button type="button"
                    class="nc-issue-option @(modoEmision == ModoEmisionNotaCredito.Manual ? "is-active" : string.Empty)"
                    @onclick="ActivarModoManualAsync">
                <span class="nc-issue-option-icon"><i class="bi bi-pencil-square"></i></span>
                <div>
                    <strong>Manual</strong>
                    <small>Ingresa cliente, motivo y detalle sin partir del buscador.</small>
                </div>
            </button>

            <div class="nc-issue-option nc-issue-option-file @(modoEmision == ModoEmisionNotaCredito.Xml ? "is-active" : string.Empty)"
                 @onclick="ActivarModoXmlAsync">
                <span class="nc-issue-option-icon"><i class="bi bi-filetype-xml"></i></span>
                <div>
                    <strong>Desde XML</strong>
                    <small>Carga el XML de la factura para precargar datos y ajustar el detalle.</small>
                    <label class="nc-xml-picker" @onclick:stopPropagation="true">
                        <span>Seleccionar archivo XML</span>
                        <InputFile OnChange="OnNotaCreditoXmlSelectedAsync" accept=".xml,text/xml,application/xml" />
                    </label>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(mensajeXmlNotaCredito))
        {
            <div class="nc-mode-message">@mensajeXmlNotaCredito</div>
        }
    </section>

    @if (modoEmision == ModoEmisionNotaCredito.Factura)
    {
        <section class="n-client-search-strip nc-search-strip" data-tour="nc.lookup">
            <div class="n-client-search-strip-copy nc-search-strip-copy">
                <span class="n-client-search-eyebrow nc-search-eyebrow">Buscador de factura</span>
                <strong>Encuentra la Factura Modificada para emitir la nota de crédito</strong>
            </div>

            <div class="n-client-search-input nc-search-panel position-relative">
                <div class="n-input-wrapper">
                    <i class="bi bi-search n-input-icon"></i>

                    <input class="n-input n-input-with-icon n-input-with-toggle nc-search-input"
                           value="@numFacturaBuscar"
                           @oninput="BuscarFacturasAutoAsync"
                           @onkeydown="OnKeyBuscarFactura"
                           @onblur="OcultarListaConDelay"
                           placeholder="Buscar por número de factura"
                           maxlength="9"
                           autocomplete="off" />
                    <button type="button"
                            class="n-input-toggle-btn"
                            @onmousedown="PrepararSeleccionFactura"
                            @onclick="ToggleListaFacturas"
                            aria-label="Mostrar facturas encontradas">
                        <i class="bi @(mostrarListaFacturas ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                </div>

                @if (mostrarListaFacturas && listaFacturas.Any())
                {
                    <ul class="n-suggestions">
                        @foreach (var f in listaFacturas)
                        {
                            <li @onmousedown="PrepararSeleccionFactura"
                                @onclick="() => SeleccionarFacturaDesdeListaAsync(f)">
                                <strong>@f.Numfactura</strong><br />
                                <small>
                                    Cliente: @f.ClienteNombre
                                    @if (!string.IsNullOrWhiteSpace(f.Serie))
                                    {
                                        <span> | Serie: @f.Serie</span>
                                    }
                                </small>
                            </li>
                        }
                    </ul>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(errorCarga))
            {
                <div class="alert alert-danger border-0 rounded-4 mt-3 mb-0">@errorCarga</div>
            }
        </section>
    }
    else
    {
        <section class="nc-manual-source-strip">
            <div>
                <span class="nc-section-kicker">@ModoEmisionTitulo</span>
                <strong>@ModoEmisionDescripcion</strong>
            </div>

            <div class="nc-source-fields">
                <label class="nc-source-document-field">
                    <span>Factura Modificada</span>
                    <input type="text"
                           class="n-input"
                           value="@DocumentoModificadoInputVisual"
                           @oninput="OnDocumentoModificadoInput"
                           maxlength="17"
                           inputmode="numeric"
                           placeholder="001-001-000000001" />
                </label>

                <label>
                    <span>Fecha Factura Modificada</span>
                    <input type="date"
                           class="n-input"
                           value="@FechaDocumentoModificadoInput"
                           @oninput="OnFechaDocumentoModificadoInput" />
                </label>

                <label>
                    <span>Número autorización</span>
                    <input type="text"
                           class="n-input"
                           @bind="notaCredito.NumAutorizacion"
                           @bind:event="oninput"
                           inputmode="numeric"
                           maxlength="49"
                           placeholder="Autorización del comprobante base" />
                </label>
            </div>
        </section>
    }

    @if (ClienteIngresadoSinRegistro)
    {
        <div class="n-client-create-notice n-client-create-notice-inline @(continuarConClienteSinRegistro ? "is-continued" : "")">
            <span class="n-client-create-icon">
                <i class="bi bi-person-plus"></i>
            </span>
            <div>
                <strong>Cliente no registrado</strong>
                <small>@(continuarConClienteSinRegistro
                    ? "Continuaras con los datos ingresados para esta nota de credito."
                    : "Puedes registrarlo ahora desde clientes o continuar con los datos de esta nota.")</small>
            </div>
            <div class="n-client-create-actions">
                <button type="button"
                        class="n-client-create-check"
                        @onclick="AbrirCrudClientesNotaAsync">
                    <i class="bi bi-person-plus"></i>
                    <span>Agregar ahora</span>
                </button>
                <button type="button"
                        class="n-client-continue-check @(continuarConClienteSinRegistro ? "is-active" : "")"
                        @onclick="ContinuarConClienteSinRegistroNota">
                    <i class="bi @(continuarConClienteSinRegistro ? "bi-x-circle" : "bi-arrow-right-circle")"></i>
                    <span>@(continuarConClienteSinRegistro ? "Desmarcar" : "Continuar")</span>
                </button>
            </div>
        </div>
    }

    <div class="n-card mb-4 nc-section-card" data-tour="nc.client">
        <div class="n-card-header">
            <h5><i class="bi bi-person-vcard me-2"></i> Información del Cliente</h5>
            <small class="d-none d-sm-flex"><i class="bi bi-lock me-1"></i> Cargado desde factura</small>
        </div>

        <div class="n-card-body n-client-card-body">
            <div class="row g-3 n-client-block n-client-main-grid">
                <div class="col-lg-3 col-md-6">
                    <label class="n-label">Tipo Identificación</label>
                    <div class="n-select-shell">
                        <select class="n-select" @bind="cliente.Tipoidentificacion" disabled="@(!CamposClienteEditables)">
                            <option value="">-- Seleccione --</option>
                            @foreach (var it in identificaciones)
                            {
                                <option value="@it.IdeCodigo">@it.IdeDescripcion</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="n-label">Número Identificación</label>
                    <div class="n-input-wrapper position-relative">
                        <i class="bi bi-person-badge n-input-icon"></i>
                        <input type="text" class="n-input n-input-with-icon bg-light"
                               value="@cliente.Numeroidentificacion"
                               @oninput="OnClienteIdentificacionNotaInputAsync"
                               @onfocus='() => MostrarSugerenciasClienteNotaAsync("identificacion")'
                               readonly="@(!CamposClienteEditables)" />
                        @if (CamposClienteEditables && campoClienteNotaActivo == "identificacion" && sugerenciasClientesNota.Any())
                        {
                            <ul class="n-suggestions n-client-field-suggestions">
                                @foreach (var sugerencia in sugerenciasClientesNota)
                                {
                                    <li @onmousedown="() => SeleccionarClienteNotaAsync(sugerencia)"
                                        @onmousedown:preventDefault>
                                        <strong>@ObtenerNombreClienteVisual(sugerencia)</strong>
                                        <small>@sugerencia.Numeroidentificacion</small>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="n-label">Tipo Cliente</label>
                    <div class="n-select-shell">
                        <select class="n-select" @bind="cliente.TipoCliente" disabled="@(!CamposClienteEditables)">
                            <option value="">-- Seleccione --</option>
                            @foreach (var tc in tiposCliente)
                            {
                                <option value="@tc.TclCodigo">@tc.TclDescripcion</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="n-label">Nombre / Razón Social</label>
                    <div class="n-input-wrapper position-relative">
                        <i class="bi bi-person-check n-input-icon"></i>
                        @if (CamposClienteEditables)
                        {
                            <input type="text" class="n-input n-input-with-icon bg-light"
                                   value="@NombreClienteVisual"
                                   @oninput="OnClienteNombreNotaInputAsync"
                                   @onfocus='() => MostrarSugerenciasClienteNotaAsync("nombre")' />
                            @if (campoClienteNotaActivo == "nombre" && sugerenciasClientesNota.Any())
                            {
                                <ul class="n-suggestions n-client-field-suggestions">
                                    @foreach (var sugerencia in sugerenciasClientesNota)
                                    {
                                        <li @onmousedown="() => SeleccionarClienteNotaAsync(sugerencia)"
                                            @onmousedown:preventDefault>
                                            <strong>@ObtenerNombreClienteVisual(sugerencia)</strong>
                                            <small>@sugerencia.Numeroidentificacion</small>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                        else
                        {
                            <input type="text" class="n-input n-input-with-icon bg-light"
                                   value="@NombreClienteVisual" readonly />
                        }
                    </div>
                </div>
            </div>

            <div class="n-client-block n-client-contact-modern">
                <div class="n-contact-field">
                    <label class="n-label">Dirección (Max 100)</label>
                    <div class="n-input-wrapper">
                        <i class="bi bi-geo-alt n-input-icon"></i>
                        <input type="text" class="n-input n-input-with-icon bg-light"
                               @bind="cliente.Direccion"
                               @bind:event="oninput"
                               readonly="@(!CamposClienteEditables)" />
                    </div>
                </div>

                <div class="n-contact-field n-contact-phone-field">
                    <label class="n-label">Telefono</label>
                    <div class="n-input-wrapper">
                        <i class="bi bi-phone n-input-icon"></i>
                        <input type="text" class="n-input n-input-with-icon bg-light"
                               @bind="cliente.Celular"
                               @bind:event="oninput"
                               readonly="@(!CamposClienteEditables)" />
                    </div>
                </div>

                <div class="n-contact-field n-email-main-field">
                    <div class="n-email-main-head">
                        <label class="n-label mb-0">Correo electrónico principal</label>
                    </div>

                    <div class="n-email-primary-row">
                        <div class="n-input-wrapper">
                            <i class="bi bi-envelope n-input-icon"></i>
                            <input type="text" class="n-input n-input-with-icon bg-light"
                                   @bind="cliente.Correo"
                                   @bind:event="oninput"
                                   readonly="@(!CamposClienteEditables)" />
                        </div>

                        <button type="button"
                                class="n-email-add-btn"
                                title="Agregar correo adicional"
                                @onclick="AgregarCorreoOpcionalNota"
                                disabled="@(correosOpcionalesNota.Count >= MaxCorreosOpcionalesNota)">
                            <i class="bi bi-envelope-plus"></i>
                            <span>Agregar correo</span>
                        </button>
                    </div>

                    @if (correosOpcionalesNota.Any())
                    {
                        <div class="n-additional-email-area">
                            <label class="n-label">Correos adicionales</label>
                            <div class="n-email-chip-grid">
                                @for (int i = 0; i < correosOpcionalesNota.Count; i++)
                                {
                                    var index = i;
                                    <div class="n-email-chip-field">
                                        <input type="email"
                                               class="n-email-chip-input"
                                               @bind="correosOpcionalesNota[index].Correo"
                                               @bind:event="oninput"
                                               placeholder="correo@ejemplo.com" />
                                        <button type="button"
                                                class="n-email-chip-remove"
                                                title="Quitar correo"
                                                @onclick="() => EliminarCorreoOpcionalNota(index)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                        @if (correosOpcionalesNota[index].EsPersistidoCliente)
                                        {
                                            <span class="n-email-chip-note">Guardado</span>
                                        }
                                        else
                                        {
                                            <label class="n-email-save-mini" for="@($"guardar-correo-nc-modern-{index}")">
                                                <input type="checkbox"
                                                       id="@($"guardar-correo-nc-modern-{index}")"
                                                       @bind="correosOpcionalesNota[index].GuardarEnCliente" />
                                                Guardar
                                            </label>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="row g-3 n-client-block">
                <div class="col-lg-4">
                    <label class="n-label">Motivo de la Nota de Crédito</label>
                    <div class="n-input-wrapper">
                        <i class="bi bi-card-list n-input-icon"></i>
                        <select class="n-select n-input-with-icon" @bind="motivoSeleccionado">
                            @foreach (var motivo in motivosPreestablecidos)
                            {
                                <option value="@motivo">@motivo</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="d-flex justify-content-between align-items-end mb-2">
                        <label class="n-label mb-0">Observación</label>
                        <span class="n-word-count">Máx. 250 caracteres</span>
                    </div>
                    <textarea class="n-textarea"
                              rows="3"
                              @bind="observacionCliente"
                              maxlength="250"
                              placeholder="Ingrese una observación adicional"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="n-card n-invoice-detail-card mb-4 nc-section-card" data-tour="nc.detail">
        <div class="n-card-header n-header-dark">
                <div class="invoice-detail-head">
                    <h5 class="mb-0"><i class="bi bi-cart4 me-2"></i> Detalle de Nota de Crédito</h5>
                </div>
            </div>

        <div class="n-card-body">
            <div class="table-responsive n-table-container">
                <table class="table table-hover align-middle mb-0">
                    <thead class="n-table-header bg-light">
                        <tr>
                            <th style="width: 88px; min-width: 88px;">Cód.</th>
                            <th style="min-width: 220px;">Concepto</th>
                            <th style="min-width: 250px;">Detalle</th>
                            <th class="text-center" style="width: 90px;">Cant.</th>
                            <th class="text-end" style="width: 110px;">Precio</th>
                            <th class="text-center" style="width: 170px;">Descuento</th>
                            <th class="text-end" style="width: 100px;">Desc. apl.</th>
                            <th class="text-end" style="width: 110px;">Base Imp.</th>
                            <th class="text-end" style="width: 120px;">IVA</th>
                            <th class="text-end" style="width: 120px;">Total</th>
                            <th class="text-center" style="width: 45px;"></th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (detallesNc.Any())
                        {
                            @for (int i = 0; i < detallesNc.Count; i++)
                            {
                                var index = i;
                                var d = detallesNc[i];
                                var descuentoFila = GetDescuentoEfectivoDetalle(d);
                                var baseImp = GetBaseImponibleDetalle(d);
                                var totalFila = GetTotalDetalle(d);

                                <tr @key="d" class="@(EsDetalleNotaCreditoVacio(d) ? "n-detail-empty-row" : null)">
                                    <td>
                                        <input type="text"
                                               class="n-input-sm text-center fw-bold nc-code-input"
                                               value="@d.Codprincipal"
                                               @oninput="(e) => OnCodigoDetalleNotaCreditoInput(d, e.Value?.ToString())"
                                               maxlength="70"
                                               placeholder="@GetCodigoVisualDetalle(d)" />
                                    </td>

                                    <td class="position-relative">
                                        <input type="text"
                                               class="n-input-sm n-detail-concept-input fw-semibold"
                                               value="@d.Descripcion"
                                               @oninput="async (e) => await OnConceptoDetalleNotaCreditoInputAsync(d, e.Value?.ToString())"
                                               @onfocus="async () => await MostrarSugerenciasDetalleNotaCreditoAsync(d)"
                                               @onblur="async () => await OcultarSugerenciasDetalleNotaCreditoAsync(d)"
                                               @onkeydown="async (KeyboardEventArgs e) => await OnKeyDownConceptoDetalleNotaCreditoAsync(d, e)"
                                               maxlength="1000"
                                               placeholder="Buscar producto o servicio" />
                                        @if (ReferenceEquals(filaBusquedaProductoNotaActiva, d) && sugerenciasProductosNota != null && sugerenciasProductosNota.Any())
                                        {
                                            <ul class="n-suggestions n-suggestions-inline n-detail-suggestions-floating">
                                                @for (var idx = 0; idx < sugerenciasProductosNota.Count; idx++)
                                                {
                                                    var producto = sugerenciasProductosNota[idx];
                                                    <li @onmousedown="PrepararSeleccionProductoNota"
                                                        class="@(indiceSugerenciaProductoNotaActiva == idx ? "is-active" : null)"
                                                        @onclick="async () => await SeleccionarProductoNotaEnFilaAsync(d, producto)">
                                                        <strong>@producto.Descripcion</strong><br />
                                                        <small>Cód: @producto.Codprincipal | @ObtenerResumenProductoBusqueda(producto) | PVP: $@producto.PrecioUnitario</small>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </td>

                                    <td>
                                        <textarea class="n-input-sm n-detail-extra-input"
                                                  rows="2"
                                                  @bind="d.Detalle"
                                                  @bind:event="oninput"
                                                  maxlength="300"
                                                  placeholder="Detalle adicional o concepto extendido"></textarea>
                                    </td>

                                    <td>
                                        <input type="number" class="n-input-sm text-center fw-bold"
                                               step="1" min="1"
                                               value="@GetCantidadVisual(d)"
                                               @oninput="@((ChangeEventArgs e) => OnCantidadInput(d, e.Value?.ToString()))" />
                                    </td>

                                    <td>
                                        <input type="number"
                                               class="n-input-sm text-end"
                                               step="0.01"
                                               min="0.01"
                                               value="@GetPrecioVisual(d)"
                                               @oninput="@((ChangeEventArgs e) => OnPrecioInput(d, e.Value?.ToString()))" />
                                    </td>

                                    <td>
                                        <div class="n-discount-editor nc-discount-editor">
                                            <div class="n-discount-mode" role="group" aria-label="Modo de descuento del item">
                                                <button type="button"
                                                        class="@(GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje ? "is-active" : string.Empty)"
                                                        title="Descuento por porcentaje"
                                                        @onclick="() => CambiarModoDescuentoDetalle(d, ModoDescuento.Porcentaje)">
                                                    %
                                                </button>
                                                <button type="button"
                                                        class="@(GetModoDescuentoDetalle(d) == ModoDescuento.Moneda ? "is-active" : string.Empty)"
                                                        title="Descuento por valor"
                                                        @onclick="() => CambiarModoDescuentoDetalle(d, ModoDescuento.Moneda)">
                                                    $
                                                </button>
                                            </div>
                                            <div class="n-discount-input-wrap">
                                                <input type="number"
                                                       class="n-input-sm text-end"
                                                       step="0.01"
                                                       min="0"
                                                       max="@(GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje ? "100" : null)"
                                                       value="@GetDescuentoDetalleVisual(d)"
                                                       @oninput="@((ChangeEventArgs e) => OnDescuentoDetalleInput(d, e.Value?.ToString()))" />
                                                <span>@(GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje ? "%" : "$")</span>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-end text-danger small fw-medium">@descuentoFila.ToString("N2")</td>
                                    <td class="text-end fw-medium text-dark">@baseImp.ToString("N2")</td>
                                    <td>
                                        <div class="d-flex justify-content-center">
                                            <select class="form-select form-select-sm text-center fw-semibold border-0 bg-white shadow-sm nc-detail-iva-select"
                                                    value="@d.Iva"
                                                    @onchange="@((ChangeEventArgs e) => OnIvaDetalleChanged(d, e.Value?.ToString()))">
                                                @foreach (var iva in TarifasIvaNotaCredito)
                                                {
                                                    <option value="@iva">@($"{iva}%")</option>
                                                }
                                            </select>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold nc-detail-total-cell">@totalFila.ToString("N2")</td>

                                    <td class="text-center">
                                        <button type="button"
                                                class="n-btn-primary p-0 d-flex justify-content-center align-items-center mx-auto nc-detail-delete-btn"
                                                @onclick="() => QuitarDetalle(index)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </td>
                                </tr>

                                @if (ReferenceEquals(filaBusquedaProductoNotaActiva, d) && sugerenciasProductosNota != null && sugerenciasProductosNota.Any())
                                {
                                    <tr class="n-detail-suggestions-row">
                                        <td class="n-detail-suggestions-spacer"></td>
                                        <td class="n-detail-suggestions-cell" colspan="10">
                                            <ul class="n-suggestions n-suggestions-inline">
                                                @for (var idx = 0; idx < sugerenciasProductosNota.Count; idx++)
                                                {
                                                    var producto = sugerenciasProductosNota[idx];
                                                    <li @onmousedown="PrepararSeleccionProductoNota"
                                                        class="@(indiceSugerenciaProductoNotaActiva == idx ? "is-active" : null)"
                                                        @onclick="async () => await SeleccionarProductoNotaEnFilaAsync(d, producto)">
                                                        <strong>@producto.Descripcion</strong><br />
                                                        <small>Cód: @producto.Codprincipal | @ObtenerResumenProductoBusqueda(producto) | PVP: $@producto.PrecioUnitario</small>
                                                    </li>
                                                }
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="text-center py-4 text-muted">
                                    No hay detalles cargados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (modoEmision == ModoEmisionNotaCredito.Manual)
            {
                <div class="nc-detail-product-actions">
                    <button type="button" class="n-table-add-product-btn" @onclick="AbrirCatalogoProductosNotaCredito">
                        <i class="bi bi-plus-circle"></i>
                        <span>Seleccionar servicio o producto</span>
                    </button>
                    <button type="button" class="n-detail-product-trigger" @onclick="AbrirModalProductoNotaCredito">
                        <i class="bi bi-plus-circle"></i>
                        <span>Registrar nuevo producto</span>
                    </button>
                </div>
            }

            <div class="row mt-4 justify-content-end">
                <div class="col-xl-6 col-lg-7 col-md-9">
                    <div class="n-summary-column nc-summary-column">
                        <div class="n-summary-top-grid nc-summary-top-grid">
                            <div class="docs-total-card nc-total-card" data-tour="nc.totals-section">
                                <div class="docs-total-card-header">
                                    <span>Resumen</span>
                                    <h6>Totales del comprobante</h6>
                                </div>

                                <div class="docs-total-fiscal-list nc-total-fiscal-list">
                                    <div class="docs-total-fiscal-row">
                                        <span>SUBTOTAL</span>
                                        <strong>$ @SubtotalBruto.ToString("N2")</strong>
                                    </div>
                                    <div class="docs-total-fiscal-row docs-total-fiscal-discount">
                                        <span>DESCUENTO</span>
                                        <strong>$ @DescuentoTotal.ToString("N2")</strong>
                                    </div>
                                    <div class="docs-total-fiscal-row">
                                        <span>SUBTOTAL + ICE</span>
                                        <strong>$ @SubtotalMasIce.ToString("N2")</strong>
                                    </div>
                                    <div class="docs-total-fiscal-row">
                                        <span>ICE</span>
                                        <strong>$ @IceTotal.ToString("N2")</strong>
                                    </div>
                                    <div class="docs-total-fiscal-row docs-total-fiscal-tax">
                                        <span>IVA</span>
                                        <strong>$ @IvaTotal.ToString("N2")</strong>
                                    </div>
                                    <div class="docs-total-fiscal-row">
                                        <span>IVA 0%</span>
                                        <strong>$ @SubtotalBaseCero.ToString("N2")</strong>
                                    </div>
                                    <div class="docs-total-fiscal-row docs-total-fiscal-total">
                                        <span>TOTAL</span>
                                        <strong>$ @TotalGeneral.ToString("N2")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="n-detail-actions-row nc-detail-actions-row">
                            <button type="button"
                                    class="n-btn n-btn-secondary"
                                    disabled="@(guardando || previsualizandoPdf)"
                                    @onclick="AbrirVistaPreviaPdfTemporalAsync"
                                    @onclick:preventDefault="true"
                                    @onclick:stopPropagation="true">
                                <i class="bi bi-file-earmark-pdf me-2"></i> @(previsualizandoPdf ? "Generando PDF..." : "Previsualizar PDF")
                            </button>

                            <button type="button" class="n-btn-link" @onclick="LimpiarFormularioNotaCreditoAsync">
                                Cancelar / Limpiar
                            </button>

                            <button type="button"
                                    class="n-btn-primary"
                                    data-tour="nc.save"
                                    disabled="@(guardando || BloqueadoPorSaldoDocumentos)"
                                    @onclick="GuardarNotaCreditoAsync">
                                <i class="bi bi-save me-2"></i> @(guardando ? "Guardando..." : "Generar Nota de Crédito")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

