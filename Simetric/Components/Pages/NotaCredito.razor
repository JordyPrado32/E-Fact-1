    private async Task OnNotaCreditoXmlSelectedAsync(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        modoEmision = ModoEmisionNotaCredito.Xml;
        mensajeXmlNotaCredito = null;
        errorCarga = null;
        estadoCarga = "Leyendo XML...";

        if (archivo is null)
            return;

        if (archivo.Size > MaxNotaCreditoXmlSize)
        {
            await MostrarAlertaAsync("warning", "XML demasiado grande", "Selecciona un archivo XML menor a 10 MB.");
            return;
        }

        try
        {
            await AsegurarEmisorActivoAsync();
            PrepararFormularioNuevoNotaCredito();

            await using var stream = archivo.OpenReadStream(MaxNotaCreditoXmlSize);
            using var reader = new StreamReader(stream, Encoding.UTF8, detectEncodingFromByteOrderMarks: true);
            var contenidoXml = await reader.ReadToEndAsync();

            CargarDatosFacturaDesdeXml(contenidoXml);
            await RecargarSecuencialNcAsync();

            mensajeXmlNotaCredito = $"XML cargado: {archivo.Name}. Revisa el detalle antes de guardar.";
            estadoCarga = "XML cargado";
        }
        catch (Exception ex)
        {
            estadoCarga = "Error";
            mensajeXmlNotaCredito = null;
            await MostrarAlertaAsync("error", "No se pudo leer el XML", ObtenerMensajeVisible(ex));
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CargarDatosFacturaDesdeXml(string contenidoXml)
    {
        var documento = ObtenerDocumentoComprobanteXml(contenidoXml);
        var infoTributaria = PrimerElemento(documento, "infoTributaria")
            ?? throw new InvalidOperationException("El XML no contiene infoTributaria.");
        var infoFactura = PrimerElemento(documento, "infoFactura")
            ?? throw new InvalidOperationException("El XML no contiene infoFactura.");

        var estab = ValorXml(infoTributaria, "estab");
        var ptoEmi = ValorXml(infoTributaria, "ptoEmi");
        var secuencial = ValorXml(infoTributaria, "secuencial");
        var autorizacion = ValorXml(infoTributaria, "claveAcceso")
            ?? ObtenerCampoAdicionalXml(documento, "NumeroAutorizacion")
            ?? ObtenerCampoAdicionalXml(documento, "numAutorizacion")
            ?? string.Empty;
        var fechaFactura = ParseFechaXml(ValorXml(infoFactura, "fechaEmision")) ?? DateTime.Today;

        factura = new Factura
        {
            Serie = ObtenerSerieFacturaManualRaw() is { Length: 6 } serieActiva ? serieActiva : $"{estab}{ptoEmi}",
            Numfactura = secuencial,
            Fchautorizacion = fechaFactura,
            Numautorizacion = autorizacion,
            Coddocumento = 1,
            Idusuario = currentUserId,
            Codemisor = emisor?.Codigo
        };
        notaCredito.NumAutorizacion = autorizacion;
        serieFacturaVisual = FormatearSerie(factura.Serie ?? string.Empty);

        cliente = new Cliente
        {
            Usuario = currentUserId,
            Estado = true,
            Tipoidentificacion = ValorXml(infoFactura, "tipoIdentificacionComprador") ?? "05",
            Numeroidentificacion = ValorXml(infoFactura, "identificacionComprador"),
            Nombrerazonsocial = ValorXml(infoFactura, "razonSocialComprador"),
            Direccion = ValorXml(infoFactura, "direccionComprador"),
            Correo = ObtenerCampoAdicionalXml(documento, "email")
                ?? ObtenerCampoAdicionalXml(documento, "correo"),
            Celular = ObtenerCampoAdicionalXml(documento, "telefono")
                ?? ObtenerCampoAdicionalXml(documento, "celular"),
            TipoCliente = tiposCliente.FirstOrDefault()?.TclCodigo
        };

        correosOpcionalesNota = new();
        correosPersistidosClienteNota = new();
        ResetearEstadoDetalles();

        detallesNc = documento
            .Descendants()
            .Where(x => x.Name.LocalName == "detalle" && x.Parent?.Name.LocalName == "detalles")
            .Select(ConstruirDetalleDesdeXml)
            .Where(x => !string.IsNullOrWhiteSpace(x.Descripcion))
            .ToList();

        if (!detallesNc.Any())
            throw new InvalidOperationException("El XML no contiene detalles para la nota de credito.");

        foreach (var detalle in detallesNc)
            modosDescuentoDetalle[detalle] = detalle.Descuento > 0m && detalle.PorcentajeDescuento <= 0m
                ? ModoDescuento.Moneda
                : ModoDescuento.Porcentaje;
    }

    private DetalleNcDto ConstruirDetalleDesdeXml(XElement detalleXml)
    {
        var cantidad = Math.Max(1m, ParseDecimalXml(ValorXml(detalleXml, "cantidad")));
        var precio = Math.Max(0.01m, ParseDecimalXml(ValorXml(detalleXml, "precioUnitario")));
        var descuento = Math.Max(0m, ParseDecimalXml(ValorXml(detalleXml, "descuento")));
        var bruto = Red2(cantidad * precio);
        var pctDescuento = bruto > 0m ? Math.Clamp(Red2((descuento / bruto) * 100m), 0m, 100m) : 0m;
        var impuesto = detalleXml.Descendants().FirstOrDefault(x => x.Name.LocalName == "impuesto");
        var iva = (int)Math.Round(ParseDecimalXml(ValorXml(impuesto, "tarifa")), MidpointRounding.AwayFromZero);
        var baseImp = Math.Max(0m, Red2(bruto - descuento));
        var detalleAdicional = detalleXml
            .Descendants()
            .FirstOrDefault(x => x.Name.LocalName == "detAdicional")
            ?.Attribute("valor")?.Value?.Trim();

        return new DetalleNcDto
        {
            Codproducto = 0,
            Codprincipal = ValorXml(detalleXml, "codigoPrincipal") ?? ValorXml(detalleXml, "codigoInterno") ?? string.Empty,
            Codauxiliar = ValorXml(detalleXml, "codigoAuxiliar"),
            Descripcion = ValorXml(detalleXml, "descripcion") ?? string.Empty,
            Detalle = detalleAdicional,
            Cantidad = cantidad,
            Preciounitario = precio,
            Descuento = Red2(descuento),
            PorcentajeDescuento = pctDescuento,
            Subtotal = baseImp,
            Iva = Math.Max(0, iva),
            Total = Red2(baseImp + (baseImp * Math.Max(0, iva) / 100m))
        };
    }

    private static XDocument ObtenerDocumentoComprobanteXml(string contenidoXml)
    {
        var documento = XDocument.Parse(contenidoXml, LoadOptions.PreserveWhitespace);
        var comprobante = documento
            .Descendants()
            .FirstOrDefault(x => x.Name.LocalName == "comprobante")
            ?.Value;

        if (!string.IsNullOrWhiteSpace(comprobante))
            return XDocument.Parse(comprobante, LoadOptions.PreserveWhitespace);

        return documento;
    }

    private static XElement? PrimerElemento(XContainer contenedor, string nombre)
        => contenedor.Descendants().FirstOrDefault(x => x.Name.LocalName == nombre);

    private static string? ValorXml(XContainer? contenedor, string nombre)
        => contenedor?
            .Descendants()
            .FirstOrDefault(x => x.Name.LocalName == nombre)
            ?.Value
            ?.Trim();

    private static string? ObtenerCampoAdicionalXml(XContainer documento, string nombre)
        => documento
            .Descendants()
            .Where(x => x.Name.LocalName == "campoAdicional")
            .FirstOrDefault(x => string.Equals(x.Attribute("nombre")?.Value?.Trim(), nombre, StringComparison.OrdinalIgnoreCase))
            ?.Value
            ?.Trim();

    private static decimal ParseDecimalXml(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return 0m;

        return decimal.TryParse(valor.Trim(), NumberStyles.Any, CultureInfo.InvariantCulture, out var numero)
            ? numero
            : decimal.TryParse(valor.Trim().Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out numero)
                ? numero
                : 0m;
    }

    private static DateTime? ParseFechaXml(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return null;

        var formatos = new[] { "dd/MM/yyyy", "yyyy-MM-dd", "dd-MM-yyyy" };
        return DateTime.TryParseExact(valor.Trim(), formatos, CultureInfo.InvariantCulture, DateTimeStyles.None, out var fecha)
            ? fecha
            : DateTime.TryParse(valor, CultureInfo.InvariantCulture, DateTimeStyles.None, out fecha)
                ? fecha
                : null;
    }

    private void OnCantidadInput(DetalleNcDto d, string? v)
    {
        valoresTemporalesCantidad[d] = v ?? "1";
        if (!TryParseDecimalFlexible(v, out var x)) return;

        var cantidadEntera = Math.Max(1m, decimal.Truncate(x));
        d.Cantidad = cantidadEntera;
        valoresTemporalesCantidad[d] = cantidadEntera.ToString("0", CultureInfo.InvariantCulture);

        if (d.PorcentajeDescuento > 0m)
        {
            d.Descuento = Red2(GetSubtotalBrutoDetalle(d) * (d.PorcentajeDescuento / 100m));
        }
        else if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda && d.Descuento > 0m)
        {
            d.Descuento = Math.Min(d.Descuento, GetSubtotalBrutoDetalle(d));
            valoresTemporalesDescuentoMoneda[d] = d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        StateHasChanged();
    }

    private void OnPrecioInput(DetalleNcDto d, string? v)
    {
        valoresTemporalesPrecio[d] = v ?? "0";
        if (!TryParseDecimalFlexible(v, out var x)) return;

        d.Preciounitario = Math.Max(0.01m, x);

        if (d.PorcentajeDescuento > 0m)
        {
            d.Descuento = Red2(GetSubtotalBrutoDetalle(d) * (d.PorcentajeDescuento / 100m));
        }
        else if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda && d.Descuento > 0m)
        {
            d.Descuento = Math.Min(d.Descuento, GetSubtotalBrutoDetalle(d));
            valoresTemporalesDescuentoMoneda[d] = d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        StateHasChanged();
    }

    private void OnDescuentoDetalleInput(DetalleNcDto d, string? v)
    {
        if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda)
        {
            valoresTemporalesDescuentoMoneda[d] = v ?? "0";

            if (TryParseDecimalFlexible(v, out var monto))
            {
                d.PorcentajeDescuento = 0m;
                d.Descuento = Math.Clamp(Red2(monto), 0m, GetSubtotalBrutoDetalle(d));
                valoresTemporalesDescuentoMoneda[d] = d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
            }
            else
            {
                d.Descuento = 0m;
            }

            StateHasChanged();
            return;
        }

        OnPctInput(d, v);
    }

    private void OnPctInput(DetalleNcDto d, string? v)
    {
        modosDescuentoDetalle[d] = ModoDescuento.Porcentaje;
        valoresTemporalesPct[d] = v ?? "0";
        valoresTemporalesDescuentoMoneda.Remove(d);

        if (!TryParseDecimalFlexible(v, out var pct))
        {
            d.PorcentajeDescuento = 0m;
            d.Descuento = 0m;
            StateHasChanged();
            return;
        }

        pct = Math.Clamp(pct, 0m, 100m);
        d.PorcentajeDescuento = pct;
        d.Descuento = Red2(GetSubtotalBrutoDetalle(d) * (pct / 100m));
        StateHasChanged();
    }

    private void LimpiarTodosLosDescuentos()
    {
        foreach (var d in detallesNc)
        {
            d.Descuento = 0m;
            d.PorcentajeDescuento = 0m;
        }

        valoresTemporalesPct.Clear();
        valoresTemporalesDescuentoMoneda.Clear();
        StateHasChanged();
    }

    private void QuitarDetalle(int index)
    {
        if (index < 0 || index >= detallesNc.Count) return;
        var detalle = detallesNc[index];
        valoresTemporalesCantidad.Remove(detalle);
        valoresTemporalesPrecio.Remove(detalle);
        valoresTemporalesPct.Remove(detalle);
        valoresTemporalesDescuentoMoneda.Remove(detalle);
        modosDescuentoDetalle.Remove(detalle);
        detallesNc.RemoveAt(index);
        if (!detallesNc.Any())
            detallesNc.Add(CrearDetalleNotaCreditoVacio());
        else
            AsegurarFilaNotaCreditoDisponible();
        StateHasChanged();
    }

    private async Task BuscarFacturasAutoAsync(ChangeEventArgs e)
    {
        numFacturaBuscar = e.Value?.ToString()?.Trim() ?? "";
        errorCarga = null;
        CancelarBusquedaFacturasPendiente();

        if (string.IsNullOrWhiteSpace(numFacturaBuscar))
        {
            listaFacturas.Clear();
            mostrarListaFacturas = false;
            estadoCarga = string.Empty;
            return;
        }

        var cts = new CancellationTokenSource();
        var token = cts.Token;
        busquedaFacturasCts = cts;

        try
        {
            estadoCarga = "Buscando coincidencias...";
            await Task.Delay(250, token);

            var facturasEncontradas = await NotaCreditoService.BuscarFacturasAutocompleteAsync(numFacturaBuscar, currentUserId);
            if (token.IsCancellationRequested || !ReferenceEquals(busquedaFacturasCts, cts))
                return;

            listaFacturas = facturasEncontradas;
            mostrarListaFacturas = listaFacturas.Any();

            estadoCarga = listaFacturas.Any()
                ? $"{listaFacturas.Count} coincidencia(s) encontrada(s)"
                : "No se encontraron coincidencias";
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            listaFacturas.Clear();
            mostrarListaFacturas = false;
            estadoCarga = "Error";
            errorCarga = ObtenerMensajeVisible(ex);
        }
        finally
        {
            if (ReferenceEquals(System.Threading.Interlocked.CompareExchange(ref busquedaFacturasCts, null, cts), cts))
            {
                cts.Dispose();
            }
        }
    }

    private void ToggleListaFacturas()
    {
        mostrarListaFacturas = !mostrarListaFacturas && listaFacturas.Any();
    }

    private void CancelarBusquedaFacturasPendiente()
    {
        var cts = System.Threading.Interlocked.Exchange(ref busquedaFacturasCts, null);

        if (cts is null)
            return;

        try
        {
            cts.Cancel();
        }
        catch (ObjectDisposedException)
        {
        }

        cts.Dispose();
    }

    private void PrepararSeleccionFactura()
    {
