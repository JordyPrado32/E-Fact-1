    private async Task BuscarFacturaAsync()
    {
        errorCarga = null;

        if (string.IsNullOrWhiteSpace(numFacturaBuscar) || numFacturaBuscar.Trim().Length < 3)
        {
            estadoCarga = "Escribe al menos 3 dígitos";
            return;
        }

        try
        {
            estadoCarga = "Buscando factura...";
            var dto = await FacturacionService.GetFacturaPorNumeroUsuarioAsync(numFacturaBuscar.Trim(), currentUserId);

            if (dto == null || dto.Factura == null)
            {
                estadoCarga = "No se encontró la factura.";
                return;
            }

            factura = dto.Factura;
            cliente = dto.Cliente ?? new Cliente();
            emisor = dto.Emisor;
            serieFacturaVisual = FormatearSerie(factura.Serie ?? "");

            var cargarCorreosTask = CargarCorreosOpcionalesClienteNotaAsync();
            var cargarDetallesTask = NotaCreditoService.ObtenerDetallesDisponiblesAsync(factura.Codfactura);
            var recargarSecuencialTask = RecargarSecuencialNcAsync();

            await Task.WhenAll(cargarCorreosTask, cargarDetallesTask, recargarSecuencialTask);
            var disponibles = await cargarDetallesTask;

            valoresTemporalesCantidad.Clear();
            valoresTemporalesPrecio.Clear();
            valoresTemporalesPct.Clear();
            valoresTemporalesDescuentoMoneda.Clear();
            modosDescuentoDetalle.Clear();

            detallesNc = disponibles
                .Select(d => new DetalleNcDto
                {
                    Codproducto = d.Codproducto,
                    Codprincipal = d.Codprincipal,
                    Codauxiliar = d.Codauxiliar,
                    Descripcion = d.Descripcion,
                    Detalle = d.Detalle,
                    Cantidad = d.Cantidad,
                    Preciounitario = d.Preciounitario,
                    Descuento = d.Descuento,
                    PorcentajeDescuento = d.PorcentajeDescuento,
                    Subtotal = d.Subtotal,
                    Iva = d.Iva,
                    Total = d.Total
                })
                .ToList();

            foreach (var detalle in detallesNc)
            {
                modosDescuentoDetalle[detalle] = detalle.Descuento > 0m && detalle.PorcentajeDescuento <= 0m
                    ? ModoDescuento.Moneda
                    : ModoDescuento.Porcentaje;
            }


            estadoCarga = detallesNc.Any()
                ? "Factura cargada "
                : "Todos los productos de esta factura ya fueron anulados.";

            if (!detallesNc.Any())
            {
                await MostrarAlertaAsync(
                    "warning",
                    "Factura sin productos disponibles",
                    "Todos los productos de esta factura ya fueron anulados."
                );
            }
        }
        catch (OperationCanceledException ex)
        {
            estadoCarga = "Tiempo agotado";
            errorCarga = ObtenerMensajeVisible(ex);
        }
        catch (Exception ex)
        {
            estadoCarga = "Error";
            errorCarga = ObtenerMensajeVisible(ex);
        }
    }



    private async Task GuardarNotaCreditoAsync()
    {
        mensajeRapidoEmision = null;
        mensajeRapidoEsError = false;
        documentoGeneradoPdfUrl = null;

        if (BloqueadoPorSaldoDocumentos)
        {
            await MostrarAlertaAsync("warning", "Documentos agotados", MensajeBloqueoDocumentos);
            return;
        }

        if (string.IsNullOrWhiteSpace(factura?.Numfactura))
        {
            await MostrarAlertaAsync("warning", "Factura requerida", "Ingresa o carga el número de la Factura Modificada.");
            return;
        }

        if (RequiereFacturaInterna && factura.Codfactura <= 0)
        {
            await MostrarAlertaAsync("warning", "Factura requerida", "Primero busca y carga una factura válida.");
            return;
        }

        if (!RequiereFacturaInterna)
        {
            var serieDocModificado = NormalizarSerieRaw(factura.Serie);
            var numeroDocModificado = SoloDigitosNc(factura.Numfactura);
            if (serieDocModificado.Length != 6 || string.IsNullOrWhiteSpace(numeroDocModificado))
            {
                await MostrarAlertaAsync("warning", "Factura Modificada requerida", "Ingresa la Factura Modificada con formato 001-001-000000001.");
                return;
            }

            if (!factura.Fchautorizacion.HasValue)
            {
                await MostrarAlertaAsync("warning", "Fecha requerida", "Ingresa la fecha de la Factura Modificada.");
                return;
            }

            if (string.IsNullOrWhiteSpace(cliente.Numeroidentificacion) || string.IsNullOrWhiteSpace(NombreClienteVisual))
            {
                await MostrarAlertaAsync("warning", "Cliente requerido", "Completa la identificación y nombre del cliente.");
                return;
            }

            if (ClienteSinRegistroPendienteDecision)
            {
                await MostrarAlertaAsync("warning", "Cliente no registrado", "Elige Agregar ahora o Continuar para usar estos datos en la nota de crédito.");
                return;
            }
        }

        var detalleIncompleto = detallesNc.FirstOrDefault(d =>
            string.IsNullOrWhiteSpace(d.Codprincipal) ||
            string.IsNullOrWhiteSpace(d.Descripcion) ||
            d.Preciounitario <= 0m);

        if (detalleIncompleto is not null)
        {
            await MostrarAlertaAsync("warning", "Detalle incompleto", "Cada línea debe tener código, concepto y precio mayor a cero.");
            return;
        }

        if (emisor is null)
        {
            await MostrarAlertaAsync("warning", "Emisor no disponible", "No hay emisor cargado.");
            return;
        }

        var serieNcRaw = (cajaUsuario?.SerieNotasCred ?? "").Replace("-", "").Trim();
        if (string.IsNullOrWhiteSpace(serieNcRaw))
        {
            await MostrarAlertaAsync("warning", "Serie no configurada", "Configura SerieNotasCred en tu Caja (serie de Nota de Crédito).");
            return;
        }

        var secNcRaw = (secuencialNcVisual ?? "").Replace("-", "").Trim();
        if (string.IsNullOrWhiteSpace(secNcRaw) || secNcRaw == "—")
        {
            await MostrarAlertaAsync("warning", "Numero no disponible", "No hay un numero disponible para la nota. Vuelve a seleccionar la Factura Modificada.");
            return;
        }

        secNcRaw = secNcRaw.PadLeft(9, '0');

        guardando = true;
        mensajeRapidoNotaCredito = null;
        mensajeRapidoNotaCreditoEsError = false;
        notaCreditoGeneradaPdfUrl = null;
        await InvokeAsync(StateHasChanged);

        var notaGuardada = false;

        try
        {
            if (!detallesNc.Any())
            {
                await MostrarAlertaAsync("warning", "Sin detalle", "Debes tener al menos un producto o servicio en la nota de crédito.");
                return;
            }

            if (string.IsNullOrWhiteSpace(motivoSeleccionado))
            {
                await MostrarAlertaAsync("warning", "Motivo requerido", "Debes seleccionar un motivo para la nota de crédito.");
                return;
            }

            var detalleCantidadInvalida = detallesNc.FirstOrDefault(d => d.Cantidad <= 0m || d.Cantidad != decimal.Truncate(d.Cantidad));
            if (detalleCantidadInvalida != null)
            {
                await MostrarAlertaAsync("warning", "Cantidad inválida", $"La cantidad del producto '{detalleCantidadInvalida.Descripcion}' debe ser un número entero mayor a cero.");
                return;
            }

            var validacionCorreos = ValidarCorreosNotaCredito();
            if (!string.IsNullOrWhiteSpace(validacionCorreos))
            {
                await MostrarAlertaAsync("warning", "Correos inválidos", validacionCorreos);
                return;
            }

            if (RequiereFacturaInterna)
            {
                var validacion = await NotaCreditoService.ValidarProductosDisponiblesAsync(factura.Codfactura, detallesNc);
                if (!validacion.Success)
                {
                    await MostrarAlertaAsync("warning", "Operación no permitida", validacion.Message);
                    return;
                }
            }
            else
            {
                factura.Serie = NormalizarSerieRaw(factura.Serie);
                factura.Numfactura = NormalizarSecuencial(factura.Numfactura);
                serieFacturaVisual = FormatearSerie(factura.Serie ?? string.Empty);
                cliente.Codcliente = await NotaCreditoService.ResolverClienteParaNotaCreditoAsync(currentUserId, cliente);
                factura.Codclientes = cliente.Codcliente;
            }

            var nc = new NcModel
            {
                Usuario = currentUserId,
                CodClientes = factura.Codclientes ?? (cliente.Codcliente > 0 ? cliente.Codcliente : (int?)null),
                CodEmisor = emisor.Codigo,
                CodDocumento = "04",
                Serie = serieNcRaw,
                NumNotaCredito = secNcRaw,
                IdDocModificado = factura.Codfactura > 0 ? factura.Codfactura : (int?)null,
                NumDocModificado = RequiereFacturaInterna
                    ? factura.Numfactura
                    : ConstruirDocumentoModificadoCompleto(factura.Serie, factura.Numfactura),
                CodDocModificado = factura.Coddocumento?.ToString() ?? "01",
                FechaEmiDocModificado = factura.Fchautorizacion ?? DateTime.Today,
                NumAutorizacion = string.IsNullOrWhiteSpace(notaCredito.NumAutorizacion)
                    ? factura.Numautorizacion
                    : notaCredito.NumAutorizacion.Trim(),
                Subtotal = BaseImponible,
                Descuentos = DescuentoTotal,
                Iva = IvaTotal,
                ValorTotal = TotalGeneral,
                Motivo = motivoSeleccionado,
                Observacion = string.IsNullOrWhiteSpace(observacionCliente) ? null : observacionCliente.Trim(),
                Estado = true,
                Autorizado = ""
            };

            foreach (var d in detallesNc)
            {
                d.Subtotal = GetBaseImponibleDetalle(d);
                d.Total = GetTotalDetalle(d);
                d.Descuento = GetDescuentoEfectivoDetalle(d);
                d.Codprincipal = string.IsNullOrWhiteSpace(d.Codprincipal) ? GetCodigoVisualDetalle(d) : d.Codprincipal.Trim();
                d.Codauxiliar = string.IsNullOrWhiteSpace(d.Codauxiliar) ? d.Codprincipal : d.Codauxiliar.Trim();
                d.Descripcion = (d.Descripcion ?? string.Empty).Trim();
                d.Detalle = (d.Detalle ?? string.Empty).Trim();
            }

            var correosNota = ObtenerCorreosOpcionalesNota();
            var id = await NotaCreditoService.CrearAsync(nc, detallesNc, correosNota);
            notaCredito.Sec = id;
            notaGuardada = id > 0;
            await InitialSequencePromptService.UpdateLastSequenceAsync(
                currentUserId,
                "nota-credito",
                secNcRaw,
                serieNcRawActual);
            var resultadoSri = await NotaCreditoService.EmitirNotaCreditoSriAsync(id, currentUserId);

            if (resultadoSri.Autorizada)
            {
                var pdfUrl = await NotaCreditoService.AsegurarPdfNotaCreditoUsuarioAsync(id, currentUserId);
                documentoGeneradoPdfUrl = AgregarVersionPdf(pdfUrl);
                mensajeRapidoEmision = resultadoSri.Message;
                mensajeRapidoEsError = false;
                await CargarEstadoEmisionAsync();
                EmisionControlService.NotifyChanged();
            }
            else
            {
                mensajeRapidoEmision = $"{resultadoSri.Message} Luego podrás reenviarla.";
                mensajeRapidoEsError = true;
            }

        }
        catch (Exception ex)
        {
            if (notaCredito.Sec > 0)
                await ActualizarAutorizacionNcSeguroAsync(notaCredito.Sec, "", DateTime.Now.ToString("O"), $"ERROR INTERNO: {ex.Message}", "ERROR INTERNO");
            if (notaGuardada)
            {
                MostrarAvisoRapidoNotaCredito($"La nota de crédito se guardó, pero el flujo de emisión terminó con una novedad. Detalle: {ObtenerMensajeVisible(ex)}", true);
                return;
            }
            await MostrarAlertaAsync("error", "Error al guardar", ObtenerMensajeVisible(ex));
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task ActualizarAutorizacionNcSeguroAsync(int sec, string? numeroAutorizacion, string? fechaAutorizacion, string? mensaje, string? autorizado)
    {
        if (sec <= 0)
            return;

        try
        {
            await NotaCreditoService.ActualizarAutorizacionNCAsync(
                sec,
                numeroAutorizacion ?? string.Empty,
                string.IsNullOrWhiteSpace(fechaAutorizacion) ? DateTime.Now.ToString("O") : fechaAutorizacion,
                mensaje ?? string.Empty,
                autorizado ?? string.Empty);
        }
        catch
        {
        }
    }

    private static string ObtenerMensajeVisible(Exception ex)
    {
        if (ex is OperationCanceledException || ex is TaskCanceledException)
            return "La operación tardó demasiado en completarse. Intenta nuevamente.";

        return string.IsNullOrWhiteSpace(ex.Message)
            ? "Ocurrió un error inesperado al procesar la nota de crédito."
            : ex.Message;
    }

