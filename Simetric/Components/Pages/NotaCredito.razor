    private async Task RecargarSecuencialNcAsync()
    {
        estadoSecuencialNc = "Calculando...";
        secuencialNcVisual = "—";
        try
        {
            if (currentUserId <= 0)
            {
                estadoSecuencialNc = "Usuario no válido.";
                return;
            }

            var serieNc = serieNcRawActual;
            if (string.IsNullOrWhiteSpace(serieNc))
                serieNc = await FacturacionService.GetSerieNotaCreditoRawAsync(currentUserId);
            if (string.IsNullOrWhiteSpace(serieNc))
            {
                estadoSecuencialNc = "Caja sin SerieNotasCred.";
                return;
            }

            serieNcRawActual = serieNc;
            serieNcVisual = FormatearSerie(serieNc);
            secuencialNcAutomatico = await FacturacionService.GetNextSecuencialNotaCreditoAsync(currentUserId, serieNc);
            estadoSecuencialNc = string.Empty;
            await AplicarConfiguracionSecuenciaInicialAsync();
        }
        catch (OperationCanceledException ex)
        {
            estadoSecuencialNc = ObtenerMensajeVisible(ex);
        }
        catch (Exception ex)
        {
            estadoSecuencialNc = ObtenerMensajeVisible(ex);
        }
    }

    private async Task OnSerieDocumentoChangedAsync(ChangeEventArgs e)
    {
        var serieRaw = e.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(serieRaw) ||
            string.Equals(serieNcRawActual, serieRaw, StringComparison.Ordinal))
            return;

        await FacturacionService.SavePreferredSeriesForAllDocumentsAsync(currentUserId, serieRaw);
        serieNcRawActual = serieRaw;
        serieNcVisual = FormatearSerie(serieRaw);

        if (cajaUsuario != null)
            cajaUsuario.SerieNotasCred = serieNcVisual;

        await RecargarSecuencialNcAsync();
        AplicarSerieFacturaManualDesdeEncabezado();
    }

    private string ObtenerSerieFacturaManualRaw()
    {
        var serie = NormalizarSerieRaw(serieNcRawActual);
        if (serie.Length == 6)
            return serie;

        return NormalizarSerieRaw(seriesDocumento.FirstOrDefault()?.SerieRaw);
    }

    private void AplicarSerieFacturaManualDesdeEncabezado()
    {
        if (modoEmision == ModoEmisionNotaCredito.Factura || factura.Codfactura > 0)
            return;

        var serie = ObtenerSerieFacturaManualRaw();
        if (serie.Length != 6)
            return;

        factura.Serie = serie;
        serieFacturaVisual = FormatearSerie(serie);
    }

    private async Task AplicarConfiguracionSecuenciaInicialAsync()
    {
        var estado = await InitialSequencePromptService.GetStateAsync(currentUserId, "nota-credito", serieNcRawActual);

        if (!estado.Initialized)
        {
            mostrarModalSecuenciaInicial = true;
            secuencialNcVisual = "—";
            return;
        }

        mostrarModalSecuenciaInicial = false;
        secuencialNcVisual = InitialSequencePromptService.ResolveNextSequence(secuencialNcAutomatico, estado);
    }

