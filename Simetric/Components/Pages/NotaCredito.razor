        if (int.TryParse(e.Value?.ToString(), out int nuevoCod))
        {
            var nuevoProd = listaProductosBase.FirstOrDefault(p => p.Codigo == nuevoCod);

            if (nuevoProd != null)
            {
                // VALIDACIÓN 1: El valor debe ser el mismo
                if (nuevoProd.ValorUnitario != itemParaCambiar.Preciounitario)
                {
                    await MostrarSwalCompatAsync("Error", "El valor del nuevo producto debe ser igual al original.", "error");
                    return;
                }

                // APLICAR CAMBIO
                itemParaCambiar.Codproducto = nuevoProd.Codigo;
                itemParaCambiar.Codprincipal = nuevoProd.CodigoPrincipal;
                itemParaCambiar.Codauxiliar = nuevoProd.CodigoPrincipal;
                itemParaCambiar.Descripcion = "(CAMBIO) " + nuevoProd.Nombre;

                mostrarModalCambio = false;
                CalcularTotales();
                await MostrarSwalCompatAsync("Éxito", "Producto intercambiado.", "success");
