    }

    private List<(int Tarifa, decimal Bruto, decimal DescUnit, decimal DescTotal, decimal Base, decimal Iva)> GruposPorTarifa =>
        detallesNc
            .GroupBy(x => GetTarifaEfectiva(x))
            .Select(g =>
            {
                var bruto = g.Sum(x => GetSubtotalBrutoDetalle(x));
                var descUnit = g.Sum(x => GetDescuentoUnitarioDetalle(x));
                var descTotal = descUnit;
                var baseImp = g.Sum(x => GetBaseImponibleDetalle(x));
                var iva = g.Sum(x => GetIvaDetalle(x));
                return (g.Key, bruto, descUnit, descTotal, baseImp, iva);
            })
            .ToList();

    private decimal SubtotalBruto => GruposPorTarifa.Sum(x => x.Bruto);
    private decimal DescuentosUnitarios => GruposPorTarifa.Sum(x => x.DescUnit);
    private decimal DescuentoTotal => GruposPorTarifa.Sum(x => x.DescTotal);
    private decimal BaseImponible => GruposPorTarifa.Sum(x => x.Base);
    private decimal IceTotal => 0m;
    private decimal SubtotalMasIce => BaseImponible + IceTotal;
    private decimal IvaTotal => GruposPorTarifa.Sum(x => x.Iva);
    private decimal IvaGravado => GruposPorTarifa.Where(x => x.Tarifa > 0).Sum(x => x.Iva);
    private decimal SubtotalBaseCero => GruposPorTarifa.Where(x => x.Tarifa == 0).Sum(x => x.Base);
    private List<(int Tarifa, decimal Valor)> IvasPorTarifa => GruposPorTarifa
        .Where(x => x.Tarifa > 0)
        .OrderBy(x => x.Tarifa)
        .Select(x => (x.Tarifa, x.Iva))
        .ToList();
    private decimal TotalGeneral => BaseImponible + IvaTotal;

