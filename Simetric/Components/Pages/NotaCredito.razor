    private string GetPctVisual(DetalleNcDto d)
    {
        if (valoresTemporalesPct.TryGetValue(d, out var v)) return v;
        return d.PorcentajeDescuento.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private ModoDescuento GetModoDescuentoDetalle(DetalleNcDto d)
    {
        if (modosDescuentoDetalle.TryGetValue(d, out var modo))
            return modo;

        return d.Descuento > 0m && d.PorcentajeDescuento <= 0m
            ? ModoDescuento.Moneda
            : ModoDescuento.Porcentaje;
    }

    private string GetDescuentoDetalleVisual(DetalleNcDto d)
    {
        if (GetModoDescuentoDetalle(d) == ModoDescuento.Moneda)
        {
            if (valoresTemporalesDescuentoMoneda.TryGetValue(d, out var moneda))
                return moneda;

            return d.Descuento.ToString("0.##", CultureInfo.InvariantCulture);
        }

        return GetPctVisual(d);
    }

    private void CambiarModoDescuentoDetalle(DetalleNcDto d, ModoDescuento modo)
    {
        var modoActual = GetModoDescuentoDetalle(d);
        if (modoActual == modo)
            return;

        modosDescuentoDetalle[d] = modo;
        valoresTemporalesPct.Remove(d);
        valoresTemporalesDescuentoMoneda.Remove(d);

        var bruto = GetSubtotalBrutoDetalle(d);

        if (modo == ModoDescuento.Porcentaje)
        {
            d.PorcentajeDescuento = bruto > 0m
                ? Math.Clamp(Red2((d.Descuento / bruto) * 100m), 0m, 100m)
                : 0m;
            d.Descuento = Red2(bruto * (d.PorcentajeDescuento / 100m));
        }
        else
        {
            d.Descuento = GetDescuentoUnitarioDetalle(d);
            d.PorcentajeDescuento = 0m;
        }

        StateHasChanged();
    }
    private void CalcularTotales()
    {
        // Usamos 'notaCredito' porque así se llama tu variable instanciada
        notaCredito.Subtotal = 0m;


        notaCredito.Iva = 0m;
        notaCredito.ValorTotal = 0m;

        decimal totalDescuento = 0m;

        if (detallesNc == null) return;

        foreach (var item in detallesNc)
        {
            // Cálculo por línea
            item.Subtotal = item.Cantidad * item.Preciounitario;
            totalDescuento += item.Descuento;

            // Clasificación por tarifa de IVA
            if (item.Iva == 0)
            {
                notaCredito.Subtotal += item.Subtotal;
            }
            else
            {
                decimal tarifaDecimal = (decimal)item.Iva / 100m;
                decimal ivaLinea = (item.Subtotal - item.Descuento) * tarifaDecimal;

                notaCredito.Subtotal += item.Subtotal;
                notaCredito.Iva += ivaLinea;
            }
        }

        // Suma final
        notaCredito.ValorTotal = (notaCredito.Subtotal + notaCredito.Iva) - totalDescuento;

        StateHasChanged();
    }

