    private void CargarProductoEnDetalleNotaCredito(DetalleNcDto detalle, ProductoLookupDetalleDto producto)
    {
        detalle.Codproducto = producto.Codproducto;
        detalle.Codprincipal = !string.IsNullOrWhiteSpace(producto.Codprincipal)
            ? producto.Codprincipal.Trim()
            : producto.Codproducto.ToString(CultureInfo.InvariantCulture);
        detalle.Codauxiliar = producto.Codauxiliar;
        detalle.Descripcion = producto.Descripcion ?? string.Empty;
        detalle.Detalle = producto.Subcategoria ?? producto.Categoria;
        detalle.Cantidad = detalle.Cantidad <= 0 ? 1m : detalle.Cantidad;
        detalle.Preciounitario = Math.Max(0.01m, producto.PrecioUnitario);
        detalle.Descuento = 0m;
        detalle.PorcentajeDescuento = 0m;
        detalle.Iva = producto.TarifaIva;

        valoresTemporalesCantidad.Remove(detalle);
        valoresTemporalesPrecio.Remove(detalle);
        valoresTemporalesPct.Remove(detalle);
        valoresTemporalesDescuentoMoneda.Remove(detalle);
        modosDescuentoDetalle[detalle] = ModoDescuento.Porcentaje;
        filaBusquedaProductoNotaActiva = null;
        seleccionandoProductoNotaDesdeLista = false;
        sugerenciasProductosNota = null;
        indiceSugerenciaProductoNotaActiva = -1;

        AsegurarFilaNotaCreditoDisponible();
        CalcularTotales();
    }

    private static bool EsDetalleNotaCreditoVacio(DetalleNcDto item)
    {
        return item.Codproducto <= 0 &&
               string.IsNullOrWhiteSpace(item.Codprincipal) &&
               string.IsNullOrWhiteSpace(item.Descripcion) &&
               item.Preciounitario <= 0.01m &&
               item.Descuento == 0m;
    }

    private void AsegurarFilaNotaCreditoDisponible()
    {
