    private decimal GetDescuentoUnitarioDetalle(DetalleNcDto d)
    {
        var bruto = GetSubtotalBrutoDetalle(d);

        if (GetModoDescuentoDetalle(d) == ModoDescuento.Porcentaje && d.PorcentajeDescuento > 0m)
            return Red2(bruto * (d.PorcentajeDescuento / 100m));

        return Red2(d.Descuento);
    }

