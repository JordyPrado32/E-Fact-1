            ? GetDescuentoUnitarioDetalle(d)
            : 0m;
    }

    private decimal GetBaseImponibleDetalle(DetalleNcDto d)
    {
        return Math.Max(0m, Red2(GetSubtotalBrutoDetalle(d) - GetDescuentoEfectivoDetalle(d)));
    }

    private decimal GetIvaDetalle(DetalleNcDto d)
    {
        return Red2(GetBaseImponibleDetalle(d) * (GetTarifaEfectiva(d) / 100m));
    }

