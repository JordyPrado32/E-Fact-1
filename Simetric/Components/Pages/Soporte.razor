    private async Task EnviarWhatsAppIntegradoAsync()
    {
        if (enviandoWhatsAppIntegrado)
            return;

        if (string.IsNullOrWhiteSpace(LimpiarPrefijoMotivo(whatsAppConsultaActual)))
        {
            whatsAppEstadoEsError = true;
            whatsAppEstadoMensaje = "Escribe el detalle de la consulta antes de continuar.";
            ScrollToBottom();
            return;
        }

        enviandoWhatsAppIntegrado = true;
        whatsAppEstadoMensaje = string.Empty;
        whatsAppEstadoEsError = false;

        try
        {
            AplicarClasificacionConsultaUsuario(whatsAppConsultaActual, actualizarFlujo: true);

            var request = new WhatsAppSupportRequest
            {
                Categoria = whatsAppCategoriaActual,
                Asesor = whatsAppAsesorActual,
                AdvisorPhoneNumber = whatsAppDestinoActual,
                Empresa = emisorRazonSocial ?? "XXXX",
                Usuario = ObtenerNombreUsuarioCorto(),
                Ruc = emisorRuc ?? "179XXXXXXXX",
                Consulta = BuildConsultaFinalWhatsApp()
            };

            var redirectUrl = WhatsAppSupportSvc.BuildExternalChatUrl(request);
            whatsAppEstadoEsError = false;
            whatsAppEstadoMensaje = $"Estamos abriendo tu chat de WhatsApp con {whatsAppAsesorActual}.";
            ScrollToBottom();

            await JS.InvokeVoidAsync("open", redirectUrl, "_blank");
        }
        catch (Exception ex)
        {
            whatsAppEstadoEsError = true;
            whatsAppEstadoMensaje = $"No se pudo preparar el chat de WhatsApp: {ex.Message}";
            ScrollToBottom();
        }
        finally
        {
            enviandoWhatsAppIntegrado = false;
        }
    }

