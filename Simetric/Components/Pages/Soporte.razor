@page "/soporte"
@inject NavigationManager Nav
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Services

<PageTitle>Soporte | Numerica e-fact</PageTitle>

<div class="support-center-shell">
    <section class="support-top-grid">
        <article class="support-search-panel">
            <div class="support-title">
                <span>Centro de ayuda</span>
                <h1>¿En que podemos ayudarte hoy?</h1>
                <p>Busca una respuesta, conversa con el asistente IA o contacta a un asesor.</p>
            </div>

            <div class="support-search-box">
                <i class="bi bi-search"></i>
                <input placeholder="Buscar una respuesta, ejemplo: factura rechazada, firmar PDF..."
                       @bind="supportSearch"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKeyDown" />
                @if (!string.IsNullOrWhiteSpace(supportSearch))
                {
                    <button type="button" class="support-search-clear-btn" @onclick="LimpiarBusqueda" aria-label="Limpiar búsqueda">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
                <button type="button" @onclick="AplicarBusqueda">Buscar</button>
            </div>
        </article>

        <article class="support-ai-panel">
            <div class="support-ai-copy">
                <div class="support-ai-heading">
                    <span>Asistente IA</span>
                    <small><i class="bi bi-circle-fill"></i> En linea</small>
                </div>
                <p>Habla o escribe tu consulta y te ayudare al instante.</p>
                <div class="support-ai-actions">
                    <button type="button" class="support-primary-btn support-bot-cta" @onclick='() => AbrirAsistenteIAGlobal("soporte_faqs")'>
                        <span class="support-bot-cta-icon"><i class="bi bi-robot"></i></span>
                        <span class="support-bot-cta-copy">
                            <strong>Hablar con el bot</strong>
                            <small>Respuestas inmediatas y guia paso a paso</small>
                        </span>
                        <i class="bi bi-arrow-right-short support-bot-cta-arrow"></i>
                    </button>
                </div>
            </div>

            <div class="support-bot-scene" aria-hidden="true">
                <div class="support-bot-bubble">
                    <strong>Hola!</strong>
                    <span>Soy tu asistente IA de e-Fact</span>
                </div>
                <div class="support-bot">
                    <!-- Antenna -->
                    <div class="support-bot-antenna"></div>
                    <!-- Ears -->
                    <span class="support-bot-ear is-left"></span>
                    <span class="support-bot-ear is-right"></span>
                    <!-- Head -->
                    <div class="support-bot-head">
                        <div class="support-bot-face">
                            <span class="support-bot-eye"></span>
                            <span class="support-bot-eye"></span>
                            <span class="support-bot-smile"></span>
                        </div>
                    </div>
                    <!-- Body -->
                    <div class="support-bot-body">
                        <span class="support-bot-arm is-left"></span>
                        <span class="support-bot-arm is-right"></span>
                        <div class="support-bot-chest">N</div>
                    </div>
                </div>
            </div>
        </article>
    </section>

    <section class="support-category-panel">
        <div class="support-section-head">
            <div>
                <span>Explora por categoria</span>
                <h2>Temas frecuentes</h2>
            </div>
        </div>

        <div class="support-category-grid">
            @foreach (var category in Categories)
            {
                <button type="button"
                        class="support-category @(activeCategory == category.Name ? "is-active" : string.Empty)"
                        @onclick="() => SetCategory(category.Name)">
                    <span><i class="@category.Icon"></i></span>
                    <strong>@category.Name</strong>
                </button>
            }
        </div>
    </section>

    <section class="support-main-grid">
        <article class="support-faq-panel">
            <div class="support-section-head">
                <div>
                    <span>Preguntas frecuentes</span>
                    <h2>Respuestas rapidas</h2>
                </div>
            </div>

            <div class="support-tabs">
                @foreach (var tab in Tabs)
                {
                    <button type="button"
                            class="@(activeCategory == tab ? "is-active" : string.Empty)"
                            @onclick="() => SetCategory(tab)">
                        @tab
                    </button>
                }
            </div>

            <div class="support-faq-list">
                @if (!string.IsNullOrWhiteSpace(supportSearch))
                {
                    <div class="support-search-helper-card">
                        <button type="button" class="support-helper-close-btn" @onclick="LimpiarBusqueda" aria-label="Cerrar">
                            <i class="bi bi-x-lg"></i>
                        </button>
                        <div class="support-helper-badge">
                            <span class="support-helper-badge-dot"></span>
                            SOPORTE DIRECTO
                        </div>
                        <h3>¿Tienes dudas sobre "@supportSearch"?</h3>
                        <p>Inicia un chat guiado o contáctanos de inmediato por nuestros canales prioritarios:</p>
                        <div class="support-helper-actions">
                            <button type="button" class="btn-helper-bot" @onclick="() => AbrirAsistenteIAGlobal(supportSearch)">
                                <i class="bi bi-chat-left-dots-fill"></i>
                                <span>Preguntar al Asistente</span>
                            </button>
                            <button type="button" class="btn-helper-wa" @onclick="AbrirWhatsAppDesdeBusqueda">
                                <i class="bi bi-whatsapp"></i>
                                <span>WhatsApp</span>
                            </button>
                            <button type="button" class="btn-helper-email" @onclick="EnviarBusquedaEmail">
                                <i class="bi bi-envelope-fill"></i>
                                <span>Enviar Correo</span>
                            </button>
                        </div>
                    </div>
                }

                @if (!FaqsFiltradas.Any())
                {
                    <div class="support-empty">
                        <i class="bi bi-search"></i>
                        <strong>Sin resultados</strong>
                        <span>Prueba con otro termino o revisa todas las preguntas.</span>
                    </div>
                }
                else
                {
                    @foreach (var item in FaqsFiltradas)
                    {
                        var isActive = activeFaq == item.Id;
                        <article class="support-faq-item @(isActive ? "is-open" : string.Empty)">
                            <button type="button" @onclick="() => Toggle(item.Id)">
                                <span class="support-faq-icon"><i class="@item.Icon"></i></span>
                                <strong>@item.Pregunta</strong>
                                <i class="bi @(isActive ? "bi-dash-lg" : "bi-plus-lg")"></i>
                            </button>
                            @if (isActive)
                            {
                                <p>@item.Respuesta</p>
                            }
                        </article>
                    }
                }
            </div>
        </article>

        <aside class="support-side-stack">
            <article class="support-card support-channel-card">
                <div class="support-section-head">
                    <div>
                        <span>Canales de soporte</span>
                        <h2>Contactanos</h2>
                    </div>
                </div>

                <button type="button" class="support-channel is-whatsapp @(string.IsNullOrWhiteSpace(supportSearch) ? "" : "pulse-highlight")" @onclick="AbrirWhatsAppPrincipal">
                    <span><i class="bi bi-whatsapp"></i></span>
                    <strong>WhatsApp</strong>
                    <small>Respuesta promedio: 3 min</small>
                    <i class="bi bi-arrow-right"></i>
                </button>

                <a class="support-channel @(string.IsNullOrWhiteSpace(supportSearch) ? "" : "border-highlight")" href="mailto:soporte@numericasoftware.com">
                    <span><i class="bi bi-envelope"></i></span>
                    <strong>Correo electronico</strong>
                    <small>Respuesta promedio: 2 horas</small>
                    <i class="bi bi-arrow-right"></i>
                </a>
            </article>

            <article class="support-card">
                <div class="support-section-head">
                    <div>
                        <span>Estado del servicio</span>
                        <h2>Operacion</h2>
                    </div>
                </div>
                <div class="support-status-box">
                    <i class="bi bi-circle-fill"></i>
                    <div>
                        <strong>Todos los servicios operativos</strong>
                        <small>Ultima actualizacion: hoy 09:45</small>
                    </div>
                </div>
                <div class="support-hours">
                    <span class="support-clock-icon" aria-hidden="true"></span>
                    <div>
                        <strong>Horarios de atencion</strong>
                        <span>Lunes a Viernes 09:00 - 18:00</span>
                    </div>
                </div>
            </article>

            <article class="support-card">
                <div class="support-section-head">
                    <div>
                        <span>Videos mas vistos</span>
                        <h2>Tutoriales</h2>
                    </div>
                </div>
                <div class="support-video-list">
                    @foreach (var video in Videos)
                    {
                        @if (video.Url.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                        {
                            <a href="@video.Url" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-play-fill"></i>
                                <span>@video.Title</span>
                            </a>
                        }
                        else
                        {
                            <a href="@video.Url">
                                <i class="bi bi-play-fill"></i>
                                <span>@video.Title</span>
                            </a>
                        }
                    }
                    <a href="https://www.youtube.com/@@NumericaSoftware" target="_blank" rel="noopener noreferrer" class="support-view-all-videos">
                        <span>Ver todos los videos</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </article>
        </aside>
    </section>


    <section class="support-metrics">
        <article>
            <span class="support-metric-icon is-green"><i class="bi bi-check-lg"></i></span>
            <div>
                <strong>98%</strong>
                <small>de consultas se resuelven en menos de 5 minutos</small>
            </div>
        </article>
        <article>
            <span class="support-metric-icon is-violet"><i class="bi bi-people-fill"></i></span>
            <div>
                <strong>+12.500</strong>
                <small>usuarios satisfechos confian en e-Fact</small>
            </div>
        </article>
        <article>
            <span class="support-metric-icon is-orange"><i class="bi bi-shield-check"></i></span>
            <div>
                <strong>Seguridad</strong>
                <small>Tu informacion esta protegida con altos estandares</small>
            </div>
        </article>
        <article>
            <span class="support-metric-icon is-blue"><i class="bi bi-award"></i></span>
            <div>
                <strong>Soporte experto</strong>
                <small>Nuestro equipo esta capacitado para ayudarte siempre</small>
            </div>
        </article>
    </section>

    @if (mostrarWhatsAppChatIntegrado)
    {
        <div class="support-chat-overlay" @onclick="CerrarWhatsAppIntegrado">
            <section class="support-chat-window @GetWhatsAppChatToneClass()" @onclick:stopPropagation="true">
                <header class="support-chat-header">
                    <div class="support-chat-avatar">
                        <div class="support-chat-bot-icon"><i class="bi bi-whatsapp"></i></div>
                        <span class="support-chat-status-dot"></span>
                    </div>
                    <div class="support-chat-header-text">
                        <h3>@whatsAppChatTitle</h3>
                        <span>@whatsAppChatSubtitle</span>
                    </div>
                    <button type="button" class="support-chat-close-btn" @onclick="CerrarWhatsAppIntegrado" aria-label="Cerrar">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>

                <div class="support-chat-messages">
                    <div class="support-chat-day-separator">
                        <span>Hoy</span>
                    </div>

                    <div class="support-chat-system-card">
                        <div class="support-chat-system-title">
                            <i class="bi bi-lock-fill"></i>
                            <span>Chat preparado para WhatsApp</span>
                        </div>
                        <small>Tu mensaje se abrirá en WhatsApp con el asesor correspondiente.</small>
                    </div>

                    <div class="support-chat-message-row is-bot">
                        <div class="support-chat-message-avatar">N</div>
                        <div class="support-chat-message-bubble">
                            @whatsAppBotPrompt
                        </div>
                    </div>
                    <div class="support-chat-form">
                        <div class="support-chat-meta-strip">
                            <span class="support-chat-meta-pill">
                                <i class="bi bi-building"></i>
                                @emisorRazonSocial
                            </span>
                            <span class="support-chat-meta-pill">
                                <i class="bi bi-person-badge"></i>
                                @ObtenerNombreUsuarioCorto()
                            </span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(whatsAppCategoriaActual) &&
                             !whatsAppCategoriaActual.Equals("Selecciona un area", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="support-chat-message-row is-user">
                                <div class="support-chat-message-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="support-chat-message-bubble">
                                    Necesito ayuda en <strong>@whatsAppCategoriaActual</strong>.
                                    <div class="support-chat-bubble-time">@whatsAppHoraActual</div>
                                </div>
                            </div>

                            <div class="support-chat-message-row is-bot">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-compact-bubble">
                                    <div class="support-chat-primary-copy">
                                        Te voy a conectar con <strong>@whatsAppAsesorActual</strong>.
                                    </div>
                                    <div class="support-chat-inline-meta">Primero afinemos tu consulta para que llegues mejor preparado.</div>
                                    <div class="support-chat-bubble-time">@whatsAppHoraActual</div>
                                </div>
                            </div>
                        }

                        @if (whatsAppMostrarCategorias)
                        {
                            <div class="support-chat-message-row is-bot">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-option-bubble">
                                    <div class="support-chat-quick-label">Elige el área que mejor describe tu caso</div>
                                    <div class="support-chat-options-container">
                                        @foreach (var opcion in whatsAppOpcionesCategoria)
                                        {
                                            <button type="button" class="support-chat-option-btn @GetWhatsAppAreaOptionClass(opcion)" @onclick="() => SeleccionarCategoriaWhatsApp(opcion)">
                                                <i class="@opcion.Icon"></i>
                                                <span>@opcion.Label</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (whatsAppMostrarMotivos)
                        {
                            <div class="support-chat-message-row is-bot">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-option-bubble">
                                    <div class="support-chat-quick-label">Selecciona el motivo principal</div>
                                    <button type="button" class="support-chat-option-btn is-back support-chat-back-inline" @onclick="VolverCategoriasWhatsApp">
                                        <i class="bi bi-arrow-left-short"></i>
                                        <span>Volver y cambiar area</span>
                                    </button>
                                    <div class="support-chat-options-container">
                                        @foreach (var opcion in whatsAppOpcionesMotivo)
                                        {
                                            <button type="button"
                                                    class="support-chat-option-btn @(whatsAppMotivoActual == opcion.Value ? "is-selected" : string.Empty)"
                                                    @onclick="() => SeleccionarMotivoWhatsApp(opcion)">
                                                <i class="@opcion.Icon"></i>
                                                <span>@opcion.Label</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (whatsAppMostrarSubmotivos)
                        {
                            <div class="support-chat-message-row is-bot">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-option-bubble">
                                    <div class="support-chat-quick-label">Selecciona el detalle de tu caso</div>
                                    <div class="support-chat-options-container">
                                        @foreach (var opcion in whatsAppOpcionesSubmotivo)
                                        {
                                            <button type="button"
                                                    class="support-chat-option-btn @(whatsAppSubmotivoActual == opcion.Value ? "is-selected" : string.Empty)"
                                                    @onclick="() => SeleccionarSubmotivoWhatsApp(opcion)">
                                                <i class="@opcion.Icon"></i>
                                                <span>@opcion.Label</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (whatsAppMostrarAcciones)
                        {
                            <div class="support-chat-message-row is-bot">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-option-bubble">
                                    <div class="support-chat-quick-label">¿Qué tipo de ayuda necesitas?</div>
                                    <div class="support-chat-options-container">
                                        @foreach (var opcion in whatsAppOpcionesAccion)
                                        {
                                            <button type="button"
                                                    class="support-chat-option-btn @(whatsAppAccionActual == opcion.Value ? "is-selected" : string.Empty)"
                                                    @onclick="() => SeleccionarAccionWhatsApp(opcion)">
                                                <i class="@opcion.Icon"></i>
                                                <span>@opcion.Label</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(whatsAppMotivoActual))
                        {
                            <div class="support-chat-message-row is-user">
                                <div class="support-chat-message-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="support-chat-message-bubble">
                                    Mi tema principal es <strong>@whatsAppMotivoActual</strong>.
                                    <div class="support-chat-bubble-time">@whatsAppHoraActual</div>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(whatsAppSubmotivoActual))
                        {
                            <div class="support-chat-message-row is-user">
                                <div class="support-chat-message-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="support-chat-message-bubble">
                                    El detalle es <strong>@whatsAppSubmotivoActual</strong>.
                                    <div class="support-chat-bubble-time">@whatsAppHoraActual</div>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(whatsAppAccionActual))
                        {
                            <div class="support-chat-message-row is-user">
                                <div class="support-chat-message-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="support-chat-message-bubble">
                                    Prefiero <strong>@whatsAppAccionActual</strong>.
                                    <div class="support-chat-bubble-time">@whatsAppHoraActual</div>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(whatsAppRespuestaAutomatica))
                        {
                            <div class="support-chat-message-row is-bot">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-guide-bubble">
                                    @((MarkupString)whatsAppRespuestaAutomatica)
                                    <div class="support-chat-bubble-time">@whatsAppHoraActual</div>
                                </div>
                            </div>
                        }

                        @if (MostrarBotonConsultaAsesor)
                        {
                            <div class="support-chat-message-row is-bot support-chat-cta-row">
                                <div class="support-chat-message-avatar">N</div>
                                <div class="support-chat-message-bubble support-chat-option-bubble">
                                    <div class="support-chat-quick-label">Si esto no resuelve tu caso, podemos pasarlo a un asesor.</div>
                                    <div class="support-chat-cta-actions">
                                        <button type="button"
                                                class="support-chat-cancel-btn support-chat-cta-restart"
                                                @onclick="VolverAEmpezarWhatsApp">
                                            <i class="bi bi-arrow-clockwise"></i>
                                            <span>Volver a empezar</span>
                                        </button>
                                    <button type="button"
                                            class="support-chat-submit-btn support-chat-submit-inline"
                                            @onclick="ActivarConsultaAsesorWhatsApp">
                                        <i class="bi bi-whatsapp"></i>
                                        <span>@TextoBotonConsultaWhatsApp</span>
                                    </button>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>

                <div class="support-chat-footer">
                    @if (MostrarSugerenciaIA)
                    {
                        <div class="support-chat-ai-hint">
                            <div class="support-chat-ai-pill">
                                <i class="bi bi-stars"></i>
                                <span>@whatsAppSugerenciaIA</span>
                            </div>
                        </div>
                    }

                    @if (MostrarEditorConsultaWhatsApp)
                    {
                        <div class="support-chat-composer">
                        <textarea class="support-chat-textarea"
                                  rows="2"
                                  placeholder="Escribe aquí tu consulta con más detalle..."
                                  @bind="whatsAppConsultaActual"
                                  @bind:event="oninput"
                                  @bind:after="AnalizarConsultaWhatsAppAsync"></textarea>

                        <div class="support-chat-composer-actions">
                            <div class="support-chat-inline-actions">
                                @if (PuedeCambiarArea)
                                {
                                    <button type="button" class="support-chat-cancel-btn" @onclick="VolverCategoriasWhatsApp">
                                        <i class="bi bi-arrow-left-short"></i>
                                        <span>Cambiar área</span>
                                    </button>
                                }
                                @if (PuedeCambiarMotivo)
                                {
                                    <button type="button" class="support-chat-cancel-btn" @onclick="VolverMotivosWhatsApp">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                        <span>Cambiar motivo</span>
                                    </button>
                                }
                                @if (PuedeCambiarDetalle)
                                {
                                    <button type="button" class="support-chat-cancel-btn" @onclick="VolverSubmotivosWhatsApp">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                        <span>Cambiar detalle</span>
                                    </button>
                                }
                            </div>
                            
                            <button type="button" class="support-chat-submit-btn" @onclick="EnviarWhatsAppIntegradoAsync" disabled="@(!PuedeEnviarWhatsApp)">
                                <i class="bi bi-whatsapp"></i>
                                <span>@(enviandoWhatsAppIntegrado ? "Abriendo mensaje..." : "Enviar mensaje")</span>
                            </button>
                        </div>
                    </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(whatsAppEstadoMensaje))
                    {
                        <div class="support-chat-status-card @(whatsAppEstadoEsError ? "is-error" : "is-success")">
                            <i class="bi @(whatsAppEstadoEsError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
                            <span>@whatsAppEstadoMensaje</span>
                        </div>
                    }

                    <div class="support-chat-footer-row">
                        <button type="button" class="support-chat-link-btn" @onclick="CerrarWhatsAppIntegrado">
                            Cerrar
                        </button>
                    </div>
                </div>
            </section>
        </div>
    }


</div>

<style>
    .support-center-shell {
        --support-text: #17324d;
        --support-muted: #6f8195;
        --support-blue: #0878d8;
        --support-border: #dfeaf5;
        display: grid;
        gap: 0.8rem;
        padding-bottom: 1rem;
        color: var(--support-text);
    }

    .support-top-grid,
    .support-main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(360px, 0.7fr);
        gap: 0.8rem;
    }


    .support-search-panel,
    .support-ai-panel,
    .support-category-panel,
    .support-faq-panel,
    .support-card,
    .support-metrics {
        border: 1px solid var(--support-border);
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
    }

    .support-search-panel {
        min-height: 174px;
        padding: 1.15rem;
        display: grid;
        align-content: center;
        gap: 1rem;
    }

    .support-title span,
    .support-section-head span,
    .support-ai-heading > span {
        color: var(--support-blue);
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.11em;
        text-transform: uppercase;
    }

    .support-title h1,
    .support-section-head h2 {
        margin: 0.2rem 0 0;
        color: var(--support-text);
        letter-spacing: 0;
        line-height: 1.12;
        font-weight: 900;
    }

    .support-title h1 {
        font-size: 1.65rem;
    }

    .support-title p,
    .support-ai-copy p {
        margin: 0.45rem 0 0;
        max-width: 42rem;
        color: var(--support-muted);
        font-size: 0.88rem;
        line-height: 1.45;
    }

    .support-search-box {
        min-height: 54px;
        border: 1px solid #d8e7f5;
        border-radius: 8px;
        background: #ffffff;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto auto;
        align-items: center;
        gap: 0.65rem;
        padding: 0.45rem 0.45rem 0.45rem 0.85rem;
        box-shadow: 0 10px 24px rgba(8, 120, 216, 0.08);
    }

    .support-search-box i {
        color: #8296aa;
        font-size: 1rem;
    }

    .support-search-box input {
        width: 100%;
        min-width: 0;
        border: 0;
        outline: none;
        color: var(--support-text);
        font-size: 0.88rem;
    }

    .support-search-box button,
    .support-primary-btn {
        min-height: 38px;
        border: 0;
        border-radius: 8px;
        background: var(--support-blue);
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        padding: 0 0.9rem;
        font-size: 0.82rem;
        font-weight: 900;
    }

    .support-ai-panel {
        min-height: 174px;
        padding: 1rem;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 290px;
        align-items: center;
        gap: 1rem;
        overflow: hidden;
        position: relative;
    }

    .support-ai-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .support-ai-heading small {
        color: #12815f;
        font-size: 0.72rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }

    .support-ai-heading small i {
        font-size: 0.46rem;
    }

    .support-ai-actions {
        margin-top: 0.85rem;
        display: flex;
    }

    .support-bot-cta {
        min-height: 64px;
        width: min(100%, 330px);
        justify-content: flex-start;
        gap: 0.75rem;
        padding: 0.65rem 0.7rem 0.65rem 0.75rem;
        border-radius: 18px;
        background:
            linear-gradient(135deg, rgba(35, 153, 224, 0.98), rgba(0, 107, 181, 1)),
            radial-gradient(circle at 16% 14%, rgba(125, 238, 255, 0.42), transparent 34%);
        box-shadow: 0 18px 34px rgba(0, 107, 181, 0.24);
        position: relative;
        overflow: hidden;
        text-align: left;
    }

    .support-bot-cta::after {
        content: "";
        position: absolute;
        inset: -55% auto -55% -34%;
        width: 42%;
        transform: rotate(18deg);
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.34), transparent);
        animation: support-bot-cta-shine 3.4s linear infinite;
    }

    @@keyframes support-bot-cta-shine {
        0% { left: -42%; }
        100% { left: 116%; }
    }

    .support-bot-cta > * {
        position: relative;
        z-index: 1;
    }

    .support-bot-cta-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 44px;
        background: rgba(255, 255, 255, 0.18);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.3);
        font-size: 1.25rem;
    }

    .support-bot-cta-copy {
        min-width: 0;
        display: grid;
        gap: 0.12rem;
        line-height: 1.12;
    }

    .support-bot-cta-copy strong,
    .support-bot-cta-copy small {
        display: block;
        color: #ffffff;
    }

    .support-bot-cta-copy strong {
        font-size: 0.94rem;
        font-weight: 950;
    }

    .support-bot-cta-copy small {
        font-size: 0.72rem;
        font-weight: 750;
        opacity: 0.86;
    }

    .support-bot-cta-arrow {
        margin-left: auto;
        font-size: 1.35rem;
        opacity: 0.95;
    }

    .support-bot-scene {
        min-height: 150px;
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
    }

    .support-bot {
        position: relative;
        width: 120px;
        height: 135px;
        margin-left: 10px;
        margin-bottom: 5px;
    }

    /* Antenna */
    .support-bot-antenna {
        position: absolute;
        left: 50%;
        top: -4px;
        width: 7px;
        height: 24px;
        border-radius: 99px;
        background: linear-gradient(180deg, #edfaff, #7fd8ff);
        transform: translateX(-50%);
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.34);
        z-index: 1;
    }

    .support-bot-antenna::before {
        content: "";
        position: absolute;
        left: 50%;
        top: -15px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 30%, #ffffff 0%, #7cf4ed 34%, #22b9ff 100%);
        box-shadow:
            0 0 0 8px rgba(124, 244, 237, 0.16),
            0 0 28px rgba(116, 238, 255, 0.55);
        transform: translateX(-50%);
        animation: support-bot-antenna-blink 1.6s ease-in-out infinite;
    }

    @@keyframes support-bot-antenna-blink {
        0%, 100% { opacity: .55; transform: translateX(-50%) scale(.8); }
        50% { opacity: 1; transform: translateX(-50%) scale(1.15); }
    }

    /* Ears */
    .support-bot-ear {
        position: absolute;
        top: 40px;
        width: 16px;
        height: 30px;
        border-radius: 999px;
        background: linear-gradient(180deg, #eaf7ff 0%, #69baf6 48%, #2a84db 100%);
        box-shadow:
            inset 0 0 0 2px rgba(255, 255, 255, 0.68),
            0 4px 10px rgba(0, 76, 130, 0.18);
        z-index: 4;
    }

    .support-bot-ear.is-left {
        left: 0px;
    }

    .support-bot-ear.is-right {
        right: 0px;
    }

    /* Arms / Waving Hands */
    .support-bot-arm {
        position: absolute;
        width: 26px;
        height: 9px;
        border-radius: 999px;
        background: linear-gradient(180deg, #fafdff 0%, #9bcbff 100%);
        box-shadow: inset 0 0 0 1px rgba(167, 204, 243, 0.72);
        z-index: 1;
    }

    .support-bot-arm::after {
        content: "";
        position: absolute;
        top: -2px;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        background: linear-gradient(180deg, #ffffff 0%, #b6dcff 100%);
        box-shadow: inset 0 0 0 1px rgba(167, 204, 243, 0.72);
    }

    .support-bot-arm.is-left {
        left: -18px;
        top: 14px;
        transform-origin: right center;
        transform: rotate(-20deg);
        animation: support-bot-wave-left 3s ease-in-out infinite alternate;
    }

    .support-bot-arm.is-left::after {
        left: -2px;
    }

    .support-bot-arm.is-right {
        right: -18px;
        top: 14px;
        transform-origin: left center;
        transform: rotate(20deg);
        animation: support-bot-wave-right 3s ease-in-out infinite alternate;
    }

    .support-bot-arm.is-right::after {
        right: -2px;
    }

    @@keyframes support-bot-wave-left {
        0% { transform: rotate(-10deg); }
        100% { transform: rotate(-40deg); }
    }

    @@keyframes support-bot-wave-right {
        0% { transform: rotate(10deg); }
        100% { transform: rotate(40deg); }
    }

    /* Head */
    .support-bot-head {
        position: absolute;
        top: 18px;
        left: 8px;
        width: 98px;
        height: 70px;
        border-radius: 40px 40px 36px 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(circle at 28% 18%, rgba(255, 255, 255, 0.96), transparent 18%),
            linear-gradient(180deg, #ffffff 0%, #e9f4ff 38%, #b7d9fb 72%, #7caee6 100%);
        border: 2px solid rgba(169, 209, 245, 0.92);
        box-shadow:
            0 9px 14px rgba(0, 76, 130, 0.16),
            inset 0 -8px 16px rgba(53, 133, 205, 0.16);
        z-index: 5;
    }

    .support-bot-head::before {
        content: "";
        position: absolute;
        inset: 6px 8px 24px;
        border-radius: 36px 36px 32px 32px;
        border: 2px solid rgba(255, 255, 255, 0.9);
        opacity: 0.9;
    }

    /* Face Screen */
    .support-bot-face {
        position: relative;
        width: 64px;
        height: 38px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        background:
            radial-gradient(circle at 50% 15%, rgba(124, 245, 255, 0.34), transparent 36%),
            linear-gradient(160deg, #163155 0%, #081c39 100%);
        box-shadow:
            inset 0 4px 12px rgba(125, 218, 255, 0.18),
            inset 0 -6px 10px rgba(0, 8, 27, 0.4);
    }

    .support-bot-eye {
        width: 10px;
        height: 14px;
        border-radius: 50%;
        background: linear-gradient(180deg, #d7ffff 0%, #6cecff 100%);
        box-shadow:
            0 0 16px rgba(173, 252, 255, 0.9),
            0 0 4px rgba(255, 255, 255, 0.9);
        animation: support-bot-blink 4.5s ease-in-out infinite;
    }

    @@keyframes support-bot-blink {
        0%, 42%, 46%, 100% { transform: scaleY(1); }
        44% { transform: scaleY(.12); }
    }

    .support-bot-smile {
        position: absolute;
        left: 50%;
        bottom: 4px;
        width: 20px;
        height: 8px;
        border-bottom: 4px solid #9df4ff;
        border-radius: 0 0 20px 20px;
        transform: translateX(-50%);
        box-shadow: 0 2px 10px rgba(129, 235, 255, 0.35);
    }

    /* Body */
    .support-bot-body {
        position: absolute;
        top: 82px;
        left: 28px;
        width: 58px;
        height: 42px;
        border-radius: 28px 28px 32px 32px;
        background:
            radial-gradient(circle at 30% 14%, rgba(255, 255, 255, 0.95), transparent 18%),
            linear-gradient(180deg, #fefeff 0%, #dcecff 48%, #9fcbfb 100%);
        border: 2px solid rgba(160, 200, 242, 0.96);
        box-shadow:
            0 8px 14px rgba(0, 76, 130, 0.14),
            inset 0 -8px 14px rgba(55, 134, 208, 0.14);
        z-index: 3;
    }

    .support-bot-chest {
        position: absolute;
        inset: 8px 14px 8px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.45rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #ffffff;
        background: linear-gradient(180deg, #38b7ff 0%, #0a7fd7 100%);
        box-shadow:
            0 0 0 4px rgba(255, 255, 255, 0.72),
            0 8px 16px rgba(0, 94, 162, 0.22);
    }

    .support-bot-bubble {
        position: absolute;
        left: 125px;
        top: 25px;
        max-width: 150px;
        padding: 0.65rem 0.8rem;
        border-radius: 16px 16px 16px 2px;
        background: #edf5ff;
        color: var(--support-text);
        font-size: 0.75rem;
        line-height: 1.35;
        z-index: 5;
        border: 1px solid #dbeafe;
        box-shadow: 0 4px 12px rgba(8, 120, 216, 0.05);
    }

    .support-bot-bubble strong,
    .support-bot-bubble span {
        display: block;
    }

    .support-category-panel,
    .support-faq-panel,
    .support-card {
        padding: 0.9rem;
    }

    .support-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        margin-bottom: 0.75rem;
    }

    .support-section-head h2 {
        font-size: 0.98rem;
    }

    .support-category-grid {
        display: grid;
        grid-template-columns: repeat(8, minmax(0, 1fr));
        gap: 0.65rem;
    }

    .support-category {
        min-width: 0;
        min-height: 86px;
        border: 1px solid #e0ebf6;
        border-radius: 8px;
        background: #f8fbff;
        color: var(--support-text);
        display: grid;
        place-items: center;
        gap: 0.38rem;
        padding: 0.65rem 0.35rem;
        font-size: 0.72rem;
        font-weight: 900;
        text-align: center;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .support-category span {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        background: #eef6ff;
        color: var(--support-blue);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: all 0.3s ease;
    }

    .support-category span i {
        display: inline-block;
        animation: subtleFloat 3.5s ease-in-out infinite;
    }

    .support-category:nth-child(2n) span i {
        animation-delay: 0.5s;
    }
    .support-category:nth-child(3n) span i {
        animation-delay: 1s;
    }
    .support-category:nth-child(4n) span i {
        animation-delay: 1.5s;
    }

    @@keyframes subtleFloat {
        0% { transform: translateY(0); }
        50% { transform: translateY(-4px); }
        100% { transform: translateY(0); }
    }

    .support-category:hover {
        transform: translateY(-3px);
        border-color: rgba(8, 120, 216, 0.28);
        background: #ffffff;
        box-shadow: 0 8px 20px rgba(8, 120, 216, 0.06);
    }

    .support-category:hover span {
        background: var(--support-blue);
        color: #ffffff;
        transform: scale(1.08);
    }

    .support-category:hover span i {
        animation-play-state: paused;
        transform: translateY(-2px);
    }

    .support-category.is-active {
        border-color: rgba(8, 120, 216, 0.45);
        background: linear-gradient(135deg, #eef7ff, #e0f2fe);
        color: var(--support-blue);
        box-shadow: 0 4px 12px rgba(8, 120, 216, 0.05);
    }

    .support-side-stack {
        display: grid;
        gap: 0.8rem;
        align-content: start;
    }

    .support-link-btn {
        border: 0;
        background: transparent;
        color: var(--support-blue);
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.78rem;
        font-weight: 900;
    }

    .support-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.7rem;
    }

    .support-tabs button {
        min-height: 28px;
        border: 0;
        border-radius: 999px;
        background: #f1f6fb;
        color: #5f7287;
        padding: 0 0.75rem;
        font-size: 0.72rem;
        font-weight: 800;
    }

    .support-tabs button.is-active {
        background: #e4f1ff;
        color: var(--support-blue);
    }

    .support-faq-list {
        display: grid;
        gap: 0.45rem;
    }

    .support-faq-item {
        border: 1px solid #e4edf5;
        border-radius: 8px;
        background: #ffffff;
        overflow: hidden;
    }

    .support-faq-item button {
        width: 100%;
        min-height: 46px;
        border: 0;
        background: transparent;
        color: var(--support-text);
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr) 26px;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 0.7rem;
        text-align: left;
    }

    .support-faq-item button > i {
        justify-self: end;
        color: var(--support-blue);
    }

    .support-faq-item strong {
        font-size: 0.86rem;
        line-height: 1.3;
    }

    .support-faq-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #edf6ff;
        color: var(--support-blue);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .support-faq-item p {
        margin: 0;
        padding: 0 0.85rem 0.75rem 3.9rem;
        color: var(--support-muted);
        font-size: 0.82rem;
        line-height: 1.45;
    }

    .support-empty {
        min-height: 160px;
        display: grid;
        place-items: center;
        align-content: center;
        gap: 0.35rem;
        color: var(--support-muted);
        text-align: center;
    }

    .support-empty i {
        color: var(--support-blue);
        font-size: 1.45rem;
    }

    .support-channel {
        width: 100%;
        min-height: 58px;
        border: 1px solid #dce9f5;
        border-radius: 8px;
        background: #ffffff;
        color: var(--support-text);
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr) auto;
        align-items: center;
        gap: 0.6rem;
        padding: 0.55rem 0.7rem;
        text-align: left;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .support-channel + .support-channel {
        margin-top: 0.55rem;
    }

    .support-channel > span {
        grid-row: span 2;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: #edf6ff;
        color: var(--support-blue);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    .support-channel strong,
    .support-channel small {
        display: block;
    }

    .support-channel small {
        color: var(--support-muted);
        font-size: 0.72rem;
    }

    .support-channel > i {
        grid-column: 3;
        grid-row: 1 / span 2;
        color: var(--support-blue);
        transition: transform 0.3s ease;
    }

    .support-channel:not(.is-whatsapp):hover {
        transform: translateY(-2px);
        border-color: var(--support-blue);
        background: linear-gradient(135deg, #ffffff, #f0f7ff);
        box-shadow: 0 8px 16px rgba(8, 120, 216, 0.08);
    }

    .support-channel:not(.is-whatsapp):hover > span {
        background: var(--support-blue);
        color: #ffffff;
        transform: scale(1.05);
    }

    .support-channel:not(.is-whatsapp):hover > i {
        transform: translateX(3px);
    }

    .support-channel.is-whatsapp {
        border-color: rgba(34, 197, 94, 0.32);
        background: linear-gradient(135deg, #22c55e, #15803d);
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(34, 197, 94, 0.15);
    }

    .support-channel.is-whatsapp > span {
        background: rgba(255, 255, 255, 0.18);
        color: #ffffff;
    }

    .support-channel.is-whatsapp small,
    .support-channel.is-whatsapp > i {
        color: rgba(255, 255, 255, 0.86);
    }

    .support-channel.is-whatsapp:hover {
        background: linear-gradient(135deg, #4ade80, #166534);
        box-shadow: 0 8px 16px rgba(34, 197, 94, 0.25);
        transform: translateY(-2px);
    }

    .support-channel.is-whatsapp:hover > span {
        transform: scale(1.05) rotate(10deg);
    }

    .support-channel.is-whatsapp:hover > i {
        transform: translateX(3px);
    }

    .support-status-box {
        min-height: 62px;
        border-radius: 8px;
        background: #eaf9ef;
        color: #138a49;
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.75rem;
        box-shadow: inset 0 2px 4px rgba(16, 185, 129, 0.05);
        border: 1px solid rgba(16, 185, 129, 0.12);
        transition: all 0.3s ease;
    }

    .support-status-box:hover {
        background: #d1fae5;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.08);
    }

    .support-status-box > i {
        font-size: 0.7rem;
        position: relative;
        display: inline-block;
        color: #10b981;
    }

    .support-status-box > i::after {
        content: '';
        position: absolute;
        top: -2px; left: -2px; right: -2px; bottom: -2px;
        border-radius: 50%;
        border: 2px solid #10b981;
        animation: statusRadar 2.5s infinite ease-out;
    }

    @@keyframes statusRadar {
        0% { transform: scale(1); opacity: 0.8; }
        100% { transform: scale(2.5); opacity: 0; }
    }

    .support-status-box strong,
    .support-status-box small,
    .support-hours strong,
    .support-hours span {
        display: block;
    }

    .support-status-box small,
    .support-hours span {
        color: #6f8195;
        font-size: 0.72rem;
    }

    .support-hours {
        margin-top: 0.7rem;
        display: flex;
        align-items: center;
        gap: 0.65rem;
        color: var(--support-text);
        font-size: 0.82rem;
        padding-left: 0.7rem;
    }

    /* Custom animated clock icon */
    .support-clock-icon {
        width: 16px;
        height: 16px;
        border: 2px solid #8aa1b5;
        border-radius: 50%;
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-sizing: border-box;
    }

    .support-clock-icon::before {
        content: '';
        position: absolute;
        width: 2px;
        height: 5px;
        background: #8aa1b5;
        top: 2px;
        left: 50%;
        transform: translateX(-50%);
        transform-origin: bottom center;
        border-radius: 1px;
        animation: clockHandsRotate 48s linear infinite;
    }

    .support-clock-icon::after {
        content: '';
        position: absolute;
        width: 2px;
        height: 6.5px;
        background: #8aa1b5;
        top: 0.5px;
        left: 50%;
        transform: translateX(-50%);
        transform-origin: bottom center;
        border-radius: 1px;
        animation: clockHandsRotate 4s linear infinite;
    }

    @@keyframes clockHandsRotate {
        from { transform: translateX(-50%) rotate(0deg); }
        to { transform: translateX(-50%) rotate(360deg); }
    }

    .support-video-list {
        display: grid;
        gap: 0.45rem;
    }

    .support-video-list a {
        color: var(--support-text);
        text-decoration: none;
    }

    .support-video-list a:not(.support-view-all-videos) {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 0.78rem;
        font-weight: 800;
        padding: 0.45rem 0.5rem;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .support-video-list a:not(.support-view-all-videos):hover {
        background: #f0f7ff;
        transform: translateX(4px);
    }

    .support-video-list a:not(.support-view-all-videos) i {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--support-blue);
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        transition: all 0.3s ease;
        box-shadow: 0 2px 6px rgba(8, 120, 216, 0.15);
    }

    .support-video-list a:not(.support-view-all-videos):hover i {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        transform: scale(1.15) rotate(15deg);
        box-shadow: 0 4px 10px rgba(37, 99, 235, 0.3);
    }

    .support-view-all-videos {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--support-blue) !important;
        font-size: 0.78rem;
        font-weight: 800;
        text-decoration: none;
        margin-top: 0.6rem;
        transition: gap 0.2s;
    }

    .support-view-all-videos:hover {
        gap: 0.5rem;
        text-decoration: underline !important;
    }

    .yt-icon {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        vertical-align: middle;
    }

    .yt-icon-sm {
        width: 15px;
        height: 15px;
        flex-shrink: 0;
        vertical-align: middle;
    }

    .support-yt-section-label {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #FF0000;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0.75rem;
        margin-bottom: 0.1rem;
        padding-top: 0.5rem;
        border-top: 1px solid #fee2e2;
    }

    .support-yt-video-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: #374151;
        text-decoration: none;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        transition: background 0.15s, color 0.15s;
    }

    .support-yt-video-link:hover {
        background: #fff1f2;
        color: #FF0000;
        text-decoration: none;
    }

    .support-yt-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: #FF0000 !important;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.15s;
    }

    .support-yt-link:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    .yt-icon-lg {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
    }

    .support-yt-card {
        border-top: 3px solid #FF0000;
        background: linear-gradient(135deg, #fff8f8 0%, #ffffff 100%);
    }

    .support-yt-card-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #fee2e2;
        margin-bottom: 0.5rem;
    }

    .support-yt-card-subtitle {
        display: block;
        font-size: 0.68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #FF0000;
        margin-bottom: 0.1rem;
    }

    .support-yt-card-title {
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .support-yt-channel-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        width: 100%;
        margin-top: 0.85rem;
        padding: 0.55rem 1rem;
        background: #FF0000;
        color: #ffffff !important;
        font-size: 0.82rem;
        font-weight: 700;
        text-decoration: none;
        border-radius: 8px;
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 2px 8px rgba(255, 0, 0, 0.25);
    }

    .support-yt-channel-btn:hover {
        background: #cc0000;
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(255, 0, 0, 0.35);
        text-decoration: none !important;
        color: #fff !important;
    }

    .support-yt-channel-btn .bi-arrow-right {
        margin-left: auto;
    }

    .support-metrics {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0;
        overflow: hidden;
        margin-top: 0.8rem;
    }



    .support-metrics article {
        min-height: 78px;
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        align-items: center;
        gap: 0.7rem;
        padding: 0.8rem 1rem;
        border-right: 1px solid #edf2f7;
        transition: background-color 0.25s ease;
    }

    .support-metrics article:hover {
        background-color: #fafbfc;
    }

    .support-metrics article:last-child {
        border-right: 0;
    }

    .support-metrics strong,
    .support-metrics small {
        display: block;
    }

    .support-metrics strong {
        font-size: 0.98rem;
        color: var(--support-blue);
        font-weight: 900;
    }

    .support-metrics small {
        color: var(--support-muted);
        font-size: 0.72rem;
        line-height: 1.35;
    }

    .support-metric-icon {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }

    .support-metrics article:hover .support-metric-icon {
        transform: scale(1.18);
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
    }

    .support-metric-icon.is-green {
        background: #dcfce7;
        color: #16a34a;
    }

    .support-metric-icon.is-violet {
        background: #f1e8ff;
        color: #7c3aed;
    }

    .support-metric-icon.is-orange {
        background: #fff0db;
        color: #f97316;
    }

    .support-metric-icon.is-blue {
        background: #e8f3ff;
        color: var(--support-blue);
    }

    @@media (max-width: 1180px) {
        .support-top-grid,
        .support-main-grid {
            grid-template-columns: 1fr;
        }

        .support-category-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @@media (max-width: 760px) {
        .support-ai-panel {
            grid-template-columns: 1fr;
        }

        .support-bot-scene {
            min-height: 120px;
        }

        .support-category-grid,
        .support-metrics {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .support-search-box {
            grid-template-columns: auto minmax(0, 1fr) auto;
        }

        .support-search-box button:not(.support-search-clear-btn) {
            grid-column: 1 / -1;
            width: 100%;
        }

        .support-metrics article {
            border-right: 0;
            border-bottom: 1px solid #edf2f7;
        }
    }

    @@media (max-width: 520px) {
        .support-category-grid,
        .support-metrics {
            grid-template-columns: 1fr;
        }

        .support-faq-item button {
            grid-template-columns: 30px minmax(0, 1fr) 24px;
        }

        .support-faq-item p {
            padding-left: 0.8rem;
        }
    }

    /* Support Chat Widget Styles */
    .support-chat-overlay {
        position: fixed;
        inset: 0;
        background:
            radial-gradient(circle at top right, rgba(37, 211, 102, 0.14), transparent 24%),
            rgba(15, 23, 42, 0.42);
        backdrop-filter: blur(7px);
        z-index: 5000;
        display: flex;
        align-items: flex-end;
        justify-content: flex-end;
        padding: 2rem;
        animation: chatFadeIn 0.3s ease-out;
    }

    .support-chat-window {
        width: 420px;
        max-width: calc(100vw - 4rem);
        height: min(660px, calc(100vh - 4rem));
        max-height: calc(100vh - 4rem);
        background: #efeae2;
        border: 1px solid rgba(13, 31, 43, 0.08);
        border-radius: 22px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: chatSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes chatFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes chatSlideUp {
        from { transform: translateY(30px) scale(0.95); }
        to { transform: translateY(0) scale(1); }
    }

    @@keyframes chatMessageIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .support-chat-header {
        background: linear-gradient(135deg, #0f6c5c, #0b8b74);
        color: #ffffff;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        position: relative;
    }

    .support-chat-avatar {
        position: relative;
    }

    .support-chat-bot-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.2rem;
        border: 2px solid rgba(255, 255, 255, 0.4);
    }

    .support-chat-status-dot {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 12px;
        height: 12px;
        background: #10b981;
        border: 2px solid #0f6c5c;
        border-radius: 50%;
    }

    .support-chat-header-text h3 {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 800;
    }

    .support-chat-header-text span {
        font-size: 0.75rem;
        opacity: 0.85;
    }

    .support-chat-close-btn {
        margin-left: auto;
        background: transparent;
        border: 0;
        color: #ffffff;
        opacity: 0.8;
        cursor: pointer;
        padding: 0.25rem;
        font-size: 1.1rem;
        transition: none;
    }

    .support-chat-close-btn:hover {
        opacity: 1;
    }

    .support-chat-messages {
        flex: 1;
        min-height: 0;
        padding: 0.95rem 1rem 0.75rem;
        overflow-y: auto;
        scroll-behavior: smooth;
        scroll-padding-bottom: 0.5rem;
        overscroll-behavior: contain;
        background:
            radial-gradient(circle at top left, rgba(255,255,255,0.35), transparent 28%),
            linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.06)),
            #e5ddd5;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .support-chat-day-separator {
        align-self: center;
    }

    .support-chat-day-separator span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 24px;
        padding: 0.2rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 248, 197, 0.9);
        color: #5b5540;
        font-size: 0.7rem;
        font-weight: 700;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
    }

    .support-chat-system-card {
        align-self: center;
        width: min(100%, 320px);
        padding: 0.55rem 0.75rem;
        border-radius: 14px;
        background: rgba(255, 248, 197, 0.92);
        color: #5b5540;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        font-size: 0.71rem;
        line-height: 1.45;
    }

    .support-chat-system-title {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .support-chat-message-row {
        display: flex;
        gap: 0.65rem;
        max-width: 85%;
        animation: none;
        scroll-margin-bottom: 0.4rem;
    }

    .support-chat-message-row.is-bot {
        align-self: flex-start;
    }

    .support-chat-message-row.is-user {
        align-self: flex-end;
        flex-direction: row-reverse;
        max-width: 75%;
    }

    .support-chat-message-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.7);
        color: #0f6c5c;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.85rem;
        flex-shrink: 0;
        border: 1px solid #dfeaf5;
    }

    .support-chat-message-bubble {
        padding: 0.72rem 0.86rem;
        border-radius: 12px;
        font-size: 0.79rem;
        line-height: 1.45;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
        word-break: break-word;
    }

    .support-chat-message-row.is-bot .support-chat-message-bubble {
        background: #ffffff;
        color: #1f2937;
        border: 1px solid rgba(15, 23, 42, 0.06);
        border-top-left-radius: 2px;
    }

    .support-chat-window.is-support-chat .support-chat-message-row.is-bot .support-chat-message-bubble {
        background: linear-gradient(135deg, #123d68, #0a6da8);
        color: #ffffff;
        border-color: rgba(18, 61, 104, 0.32);
        box-shadow: 0 8px 18px rgba(18, 61, 104, 0.2);
    }

    .support-chat-window.is-sales-chat .support-chat-message-row.is-bot .support-chat-message-bubble {
        background: linear-gradient(135deg, #dff8ff, #7ad6ff);
        color: #0b4f76;
        border-color: rgba(95, 197, 238, 0.56);
        box-shadow: 0 8px 18px rgba(90, 190, 232, 0.2);
    }

    .support-chat-message-row.is-user .support-chat-message-bubble {
        background: #d9fdd3;
        color: #183153;
        border: 1px solid rgba(16, 24, 40, 0.04);
        border-top-right-radius: 2px;
    }

    .support-chat-compact-bubble {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .support-chat-primary-copy {
        line-height: 1.45;
    }

    .support-chat-inline-meta {
        font-size: 0.71rem;
        color: #6b7280;
        margin-top: 0.05rem;
    }

    .support-chat-bubble-time {
        margin-top: 0.35rem;
        font-size: 0.68rem;
        line-height: 1;
        text-align: right;
        opacity: 0.72;
    }

    .support-chat-option-bubble {
        width: min(100%, 290px);
        padding: 0.42rem;
    }

    .support-chat-guide-bubble {
        width: min(100%, 340px);
    }

    .support-chat-cta-row {
        max-width: min(100%, 340px);
    }

    .support-chat-footer {
        background: linear-gradient(180deg, rgba(239, 234, 226, 0.92), #f7f5f1);
        border-top: 1px solid rgba(148, 163, 184, 0.18);
        padding: 0.7rem 0.75rem 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        box-shadow: 0 -8px 20px rgba(15, 23, 42, 0.06);
    }

    .support-chat-options-container {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        max-height: 132px;
        overflow-y: auto;
    }

    .support-chat-option-btn {
        width: 100%;
        min-height: 42px;
        padding: 0.62rem 0.8rem;
        border: 1px solid #d8dce1;
        border-radius: 10px;
        background: #fdfdfd;
        color: #1f2937;
        font-size: 0.77rem;
        font-weight: 700;
        text-align: left;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 0.5rem;
        cursor: pointer;
        transition: none;
        animation: none;
    }

    .support-chat-option-btn:hover {
        border-color: #7bd5bf;
        background: #f3fffb;
        color: #0f6c5c;
        transform: none;
        box-shadow: none;
    }

    .support-chat-option-btn.is-selected {
        border-color: #0f6c5c;
        background: #e8fff7;
        color: #0f6c5c;
    }

    .support-chat-option-btn.is-support-area {
        border-color: rgba(18, 61, 104, 0.34);
        background: linear-gradient(135deg, #123d68, #0a6da8);
        color: #ffffff;
        box-shadow: 0 8px 18px rgba(18, 61, 104, 0.2);
    }

    .support-chat-option-btn.is-support-area:hover {
        border-color: rgba(18, 61, 104, 0.48);
        background: linear-gradient(135deg, #0d3257, #075f95);
        color: #ffffff;
    }

    .support-chat-option-btn.is-sales-area {
        border-color: rgba(95, 197, 238, 0.56);
        background: linear-gradient(135deg, #dff8ff, #7ad6ff);
        color: #0b4f76;
        box-shadow: 0 8px 18px rgba(90, 190, 232, 0.2);
    }

    .support-chat-option-btn.is-sales-area:hover {
        border-color: rgba(34, 166, 223, 0.68);
        background: linear-gradient(135deg, #c8f2ff, #5fc5ee);
        color: #063f61;
    }

    .support-chat-option-btn.is-back {
        border-color: #cbd5e1;
        background: #f1f5f9;
        color: #475569;
    }

    .support-chat-option-btn.is-back:hover {
        border-color: #94a3b8;
        background: #e2e8f0;
        color: #334155;
    }

    .support-chat-back-inline {
        margin: 0.38rem 0 0.48rem;
    }

    .support-chat-input-row {
        display: flex;
        gap: 0.5rem;
    }

    .support-chat-input-row input {
        flex: 1;
        min-width: 0;
        padding: 0.65rem 0.85rem;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        font-size: 0.82rem;
        outline: none;
    }

    .support-chat-input-row input:focus {
        border-color: #0878d8;
    }

    .support-chat-input-row button {
        width: 40px;
        height: 40px;
        border: 0;
        border-radius: 10px;
        background: #0878d8;
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        cursor: pointer;
        transition: none;
    }

    .support-chat-input-row button:hover {
        background: #00539f;
    }

    /* Support Chat Form styles */
    .support-chat-form {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        width: 100%;
    }

    .support-chat-meta-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .support-chat-meta-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        min-height: 28px;
        padding: 0.28rem 0.58rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.76);
        color: #4b5563;
        font-size: 0.68rem;
        font-weight: 700;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
    }

    .support-chat-quick-label {
        font-size: 0.7rem;
        font-weight: 800;
        color: #6b7280;
        margin: 0 0 0.4rem 0.15rem;
    }

    .support-chat-composer {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 0.62rem;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.6);
    }

    .support-chat-textarea {
        width: 100%;
        min-height: 62px;
        max-height: 96px;
        padding: 0.72rem 0.82rem;
        border: 0;
        border-radius: 13px;
        font-size: 0.79rem;
        outline: none;
        resize: none;
        overflow-y: auto;
        font-family: inherit;
        background: #ffffff;
        color: #1f2937;
        box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.24);
    }

    .support-chat-textarea:focus {
        box-shadow: inset 0 0 0 2px rgba(15, 108, 92, 0.22);
    }

    .support-chat-composer-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
    }

    .support-chat-inline-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        flex: 1 1 auto;
    }

    .support-chat-ai-hint {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        justify-content: flex-start;
    }

    .support-chat-ai-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        min-width: 0;
        padding: 0.42rem 0.6rem;
        border-radius: 999px;
        background: rgba(15, 108, 92, 0.08);
        color: #0f6c5c;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .support-chat-ai-pill span {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .support-chat-cancel-btn {
        min-height: 40px;
        padding: 0.52rem 0.85rem;
        background: #ffffff;
        border: 1px solid #d8dce1;
        border-radius: 999px;
        color: #4b5563;
        font-size: 0.76rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        flex: 0 1 auto;
        transition: none;
    }

    .support-chat-cancel-btn:hover {
        background: #f8fafc;
        border-color: #b9c4d0;
        color: #334155;
        transform: none;
    }

    .support-chat-cancel-btn:disabled {
        opacity: 0.5;
        cursor: default;
