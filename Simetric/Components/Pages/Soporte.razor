    private IEnumerable<FaqItem> FaqsFiltradas =>
        Faqs.Where(MatchCategory).Where(MatchSearch);

    private void Toggle(int id)
    {
        activeFaq = activeFaq == id ? 0 : id;
    }

    private void SetCategory(string category)
    {
        activeCategory = category;
        activeFaq = FaqsFiltradas.FirstOrDefault()?.Id ?? 0;
    }

    private void AplicarBusqueda()
    {
        activeFaq = FaqsFiltradas.FirstOrDefault()?.Id ?? 0;
        
        // Scroll smoothly to the FAQ panel/results
        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            try
            {
                await JS.InvokeVoidAsync("eval", "const el = document.querySelector('.support-faq-panel'); if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });");
            }
            catch {}
        });
    }

    private void LimpiarBusqueda()
    {
        supportSearch = string.Empty;
        AplicarBusqueda();
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AplicarBusqueda();
        }
    }

    private bool MatchCategory(FaqItem item)
    {
        if (string.Equals(activeCategory, "Todos", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        if (string.Equals(activeCategory, "Correos", StringComparison.OrdinalIgnoreCase))
        {
            return item.Pregunta.Contains("correo", StringComparison.OrdinalIgnoreCase)
                || item.Respuesta.Contains("correo", StringComparison.OrdinalIgnoreCase);
        }

        if (string.Equals(activeCategory, "eRúbrica", StringComparison.OrdinalIgnoreCase))
        {
            return item.Pregunta.Contains("firma", StringComparison.OrdinalIgnoreCase)
                || item.Respuesta.Contains("firma", StringComparison.OrdinalIgnoreCase);
        }

        return string.Equals(item.Category, activeCategory, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchSearch(FaqItem item)
    {
        if (string.IsNullOrWhiteSpace(supportSearch))
        {
            return true;
        }

        var term = supportSearch.Trim();
        return item.Pregunta.Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.Respuesta.Contains(term, StringComparison.OrdinalIgnoreCase)
            || item.Category.Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private async Task AbrirAsistenteAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.querySelector('.ia-fact-fab')?.click();");
        }
        catch
        {
            IrAWhatsApp();
        }
    }

