    private string activeCategory = "Todos";
    private int activeFaq = 1;
    private bool shouldScroll = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldScroll)
        {
            shouldScroll = false;
            await InvokeScrollHelper();
        }
    }

    // Chatbot state
    private List<ChatMessage> chatMessages = new();
    private List<ChatOption> currentOptions = new();
    private string chatInputText = string.Empty;
    private string currentStep = "Inicio";
    private string technicalConsultationText = string.Empty;
    private string commercialConsultationText = string.Empty;
    private string? userNombre;
    private string? userApellidos;
    private string? emisorRazonSocial;
    private string? emisorRuc;
    private bool mostrarWhatsAppChatIntegrado;
    private bool enviandoWhatsAppIntegrado;
    private bool whatsAppEstadoEsError;
    private string whatsAppCategoriaActual = "Soporte tecnico";
    private string whatsAppAsesorActual = "Arleth";
    private string whatsAppMotivoActual = string.Empty;
    private string whatsAppConsultaActual = string.Empty;
    private string whatsAppDestinoActual = string.Empty;
    private string whatsAppRespuestaAutomatica = string.Empty;
    private string whatsAppEstadoMensaje = string.Empty;
    private string whatsAppSugerenciaIA = string.Empty;
    private string whatsAppChatTitle = "Chat de WhatsApp";
    private string whatsAppChatSubtitle = "Soporte e-Fact";
    private string whatsAppHoraActual => DateTime.Now.ToString("HH:mm");
    private string whatsAppBotPrompt = "Prepararemos un mensaje con los datos de tu cuenta y abriremos el chat de WhatsApp con el asesor correspondiente.";
    private bool whatsAppMostrarCategorias;
    private bool whatsAppMostrarMotivos;
    private bool whatsAppMostrarSubmotivos;
    private bool whatsAppMostrarAcciones;
    private List<WhatsAppQuickOption> whatsAppOpcionesCategoria = new();
    private List<WhatsAppQuickOption> whatsAppOpcionesMotivo = new();
    private List<WhatsAppQuickOption> whatsAppOpcionesSubmotivo = new();
    private List<WhatsAppQuickOption> whatsAppOpcionesAccion = new();
    private string whatsAppSubmotivoActual = string.Empty;
    private string whatsAppAccionActual = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                userNombre = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                userApellidos = user.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value;
                
                if (int.TryParse(user.FindFirst("IdUsuario")?.Value, out var userId) && userId > 0)
                {
                    var emisores = await Http.GetFromJsonAsync<List<EmisorDto>>($"api/emisores?idUsuario={userId}");
                    if (emisores != null && emisores.Any())
                    {
                        var firstEmisor = emisores.FirstOrDefault(e => e.Estado == true) ?? emisores.First();
                        emisorRazonSocial = firstEmisor.RazonSocial;
                        emisorRuc = firstEmisor.Ruc;
                    }
                }
            }
        }
        catch
        {
            // Fail silently
        }

        if (string.IsNullOrWhiteSpace(userNombre)) userNombre = "Mercedes Jeanneth";
        if (string.IsNullOrWhiteSpace(userApellidos)) userApellidos = "Jara";
        if (string.IsNullOrWhiteSpace(emisorRazonSocial)) emisorRazonSocial = "TERRAPRODUCTOS CIA. LTDA.";
        if (string.IsNullOrWhiteSpace(emisorRuc)) emisorRuc = "1793240003001";
    }

    private void AbrirChatSoporte()
    {
        InicializarChat();
    }

    private void AbrirWhatsAppPrincipal()
        => AbrirSelectorCategoriaWhatsApp();

    private void AbrirWhatsAppDesdeBusqueda()
        => AbrirWhatsAppIntegrado("Soporte tecnico", supportSearch);

    private void AbrirSelectorCategoriaWhatsApp()
    {
        whatsAppCategoriaActual = "Selecciona un area";
        whatsAppAsesorActual = "Numerica";
        whatsAppMotivoActual = string.Empty;
        whatsAppSubmotivoActual = string.Empty;
        whatsAppAccionActual = string.Empty;
        whatsAppConsultaActual = string.Empty;
        whatsAppDestinoActual = string.Empty;
        whatsAppRespuestaAutomatica = string.Empty;
        whatsAppEstadoMensaje = string.Empty;
        whatsAppSugerenciaIA = string.Empty;
        whatsAppEstadoEsError = false;
        whatsAppChatTitle = "WhatsApp | Soporte e-Fact";
        whatsAppChatSubtitle = "Conversacion guiada";
        whatsAppBotPrompt = "Antes de contactarte con un asesor, cuentame si tu tema es tecnico o comercial.";
        whatsAppMostrarCategorias = true;
        whatsAppMostrarMotivos = false;
        whatsAppMostrarSubmotivos = false;
        whatsAppMostrarAcciones = false;
        whatsAppOpcionesCategoria = BuildCategoryOptions();
        whatsAppOpcionesMotivo = new();
        whatsAppOpcionesSubmotivo = new();
        whatsAppOpcionesAccion = new();
        mostrarWhatsAppChatIntegrado = true;
        ScrollToBottom();
    }

    private void AbrirWhatsAppIntegrado(string categoria, string? consultaInicial = null, string? asesor = null)
    {
        whatsAppCategoriaActual = string.IsNullOrWhiteSpace(categoria) ? "Soporte tecnico" : categoria.Trim();
        whatsAppAsesorActual = string.IsNullOrWhiteSpace(asesor)
            ? WhatsAppSupportSvc.ResolveAdvisorName(whatsAppCategoriaActual)
            : asesor.Trim();
        whatsAppDestinoActual = WhatsAppSupportSvc.ResolveAdvisorPhoneNumber(whatsAppCategoriaActual, whatsAppAsesorActual);
        whatsAppMotivoActual = string.Empty;
        whatsAppSubmotivoActual = string.Empty;
        whatsAppAccionActual = string.Empty;
        whatsAppConsultaActual = string.IsNullOrWhiteSpace(consultaInicial)
            ? supportSearch.Trim()
            : consultaInicial.Trim();
        whatsAppRespuestaAutomatica = string.Empty;
        whatsAppEstadoMensaje = string.Empty;
        whatsAppSugerenciaIA = string.Empty;
        whatsAppEstadoEsError = false;
        whatsAppMostrarCategorias = false;
        whatsAppMostrarMotivos = true;
        whatsAppMostrarSubmotivos = false;
        whatsAppMostrarAcciones = false;
        whatsAppOpcionesCategoria = BuildCategoryOptions();
        whatsAppOpcionesMotivo = BuildTopicOptions(whatsAppCategoriaActual);
        whatsAppOpcionesSubmotivo = new();
        whatsAppOpcionesAccion = new();
        mostrarWhatsAppChatIntegrado = true;
        whatsAppChatTitle = $"WhatsApp | {whatsAppAsesorActual}";
        whatsAppChatSubtitle = whatsAppCategoriaActual;
        whatsAppBotPrompt = $"Perfecto. Vamos a abrir el chat con {whatsAppAsesorActual}. Primero selecciona el motivo principal de tu consulta.";
        AplicarClasificacionConsultaUsuario(whatsAppConsultaActual);
        ScrollToBottom();
    }

    private void CerrarWhatsAppIntegrado()
    {
        mostrarWhatsAppChatIntegrado = false;
        enviandoWhatsAppIntegrado = false;
    }

    private void SeleccionarCategoriaWhatsApp(WhatsAppQuickOption opcion)
    {
        AbrirWhatsAppIntegrado(opcion.Value, supportSearch, opcion.Advisor);
        whatsAppDestinoActual = opcion.PhoneNumber;
        whatsAppChatSubtitle = whatsAppCategoriaActual;
    }

    private void SeleccionarMotivoWhatsApp(WhatsAppQuickOption opcion, bool insertarEnConsulta = true)
    {
        whatsAppAsesorActual = opcion.Advisor;
        whatsAppDestinoActual = opcion.PhoneNumber;
        whatsAppChatTitle = $"WhatsApp | {whatsAppAsesorActual}";
        whatsAppChatSubtitle = whatsAppCategoriaActual;
        whatsAppMotivoActual = opcion.Label;
        whatsAppSubmotivoActual = string.Empty;
        whatsAppAccionActual = string.Empty;
        whatsAppOpcionesSubmotivo = BuildSubtopicOptions(whatsAppCategoriaActual, opcion.Label);
        whatsAppOpcionesAccion = BuildActionOptions(whatsAppCategoriaActual, opcion.Label, string.Empty);
        whatsAppMostrarMotivos = false;
        whatsAppMostrarSubmotivos = whatsAppOpcionesSubmotivo.Count > 0;
        whatsAppMostrarAcciones = !whatsAppMostrarSubmotivos && whatsAppOpcionesAccion.Count > 0;
        whatsAppBotPrompt = BuildBotPromptForCurrentStep();
        whatsAppRespuestaAutomatica = BuildAutomaticResponse(whatsAppCategoriaActual, whatsAppMotivoActual, whatsAppSubmotivoActual, whatsAppAccionActual);
        if (!insertarEnConsulta)
        {
            ScrollToBottom();
            return;
        }

        var consultaSinPrefijo = LimpiarPrefijoMotivo(whatsAppConsultaActual);

        if (string.IsNullOrWhiteSpace(consultaSinPrefijo))
        {
            whatsAppConsultaActual = opcion.Label;
            ScrollToBottom();
            return;
        }

        whatsAppConsultaActual = $"{opcion.Label}: {consultaSinPrefijo}".Trim();
        ScrollToBottom();
    }

    private void SeleccionarSubmotivoWhatsApp(WhatsAppQuickOption opcion)
    {
        whatsAppSubmotivoActual = opcion.Label;
        whatsAppOpcionesAccion = BuildActionOptions(whatsAppCategoriaActual, whatsAppMotivoActual, whatsAppSubmotivoActual);
        whatsAppMostrarSubmotivos = false;
        whatsAppMostrarAcciones = whatsAppOpcionesAccion.Count > 0;
        whatsAppBotPrompt = BuildBotPromptForCurrentStep();
        whatsAppRespuestaAutomatica = BuildAutomaticResponse(whatsAppCategoriaActual, whatsAppMotivoActual, whatsAppSubmotivoActual, whatsAppAccionActual);

        var consultaSinPrefijo = LimpiarPrefijoMotivo(whatsAppConsultaActual);
        var encabezado = BuildSelectionSummary();
        whatsAppConsultaActual = string.IsNullOrWhiteSpace(consultaSinPrefijo)
            ? encabezado
            : $"{encabezado}: {consultaSinPrefijo}".Trim();

        ScrollToBottom();
