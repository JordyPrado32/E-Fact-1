    private async Task InvokeScrollHelper()
    {
        await Task.Delay(70);
        try
        {
            await JS.InvokeVoidAsync("eval", "const el = document.querySelector('.support-chat-messages'); if (!el) return; requestAnimationFrame(() => { const rows = el.querySelectorAll('.support-chat-message-row'); const target = rows[rows.length - 1]; if (!target) return; const nextTop = target.offsetTop + target.offsetHeight - el.clientHeight + 16; el.scrollTo({ top: Math.max(0, nextTop), behavior: 'smooth' }); });");
        }
        catch
        {
            // Safe fallback
        }
    }

