    private static string BuildAutomaticResponse(string categoria, string motivo, string submotivo, string accion)
    {
        if (accion.Contains("asesor", StringComparison.OrdinalIgnoreCase))
            return "Te conectaremos con un asesor. Escribe el detalle de lo que ocurre y, si puedes, agrega el mensaje exacto del error.";

        if (categoria.Contains("Ventas", StringComparison.OrdinalIgnoreCase))
        {
            if (motivo.Contains("plan", StringComparison.OrdinalIgnoreCase) || motivo.Contains("modulo", StringComparison.OrdinalIgnoreCase))
                return "Para recomendarte el plan correcto, indicanos cuantas facturas emites al mes, si necesitas retenciones, guias o notas de credito, y si trabajas con uno o varios usuarios.";

            if (motivo.Contains("recarga", StringComparison.OrdinalIgnoreCase) || motivo.Contains("documentos", StringComparison.OrdinalIgnoreCase))
                return "Para comprar recargas, confirma que tipo de documentos necesitas: facturas, retenciones, notas de credito, notas de debito o guias. Tambien ayuda indicar la cantidad aproximada.";

            if (motivo.Contains("Renovar", StringComparison.OrdinalIgnoreCase) || motivo.Contains("suscripcion", StringComparison.OrdinalIgnoreCase))
                return "Para renovar tu suscripcion, ten listo el RUC, el plan actual y la fecha de vencimiento si la recuerdas. Tambien puedes indicar si deseas mantener el mismo plan o subir de capacidad.";

            if (motivo.Contains("Facturacion", StringComparison.OrdinalIgnoreCase) || motivo.Contains("pago", StringComparison.OrdinalIgnoreCase) || motivo.Contains("factura de compra", StringComparison.OrdinalIgnoreCase))
                return "Si tu consulta es sobre pago o factura de compra, indicanos si necesitas comprobante, validacion de transferencia, activacion pendiente o cambio de datos de facturacion.";

            if (motivo.Contains("Hablar con un asesor comercial", StringComparison.OrdinalIgnoreCase))
                return "Te conectaremos con el asesor comercial para continuar tu solicitud.";
        }

        if (motivo.Contains("Emision de documentos", StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(submotivo))
            return "Selecciona primero el documento que necesitas revisar para enviarte por el canal correcto.";

        if (motivo.Contains("eRúbrica", StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(accion))
            return "Podemos ayudarte con tutorial, guia o un asesor. Ten a mano tu archivo .p12 y la clave si el problema es al firmar.";

        if (motivo.Contains("Productos o clientes", StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(accion))
            return "Podemos ayudarte con creacion, edicion o importacion. Ahora elige si prefieres tutorial, guia o asesor.";

        if (motivo.Contains("Otro tema tecnico", StringComparison.OrdinalIgnoreCase))
            return "Este caso se enviara directo a un asesor tecnico. Cuentanos brevemente el contexto y, si existe, comparte el mensaje exacto del error.";

        var tema = !string.IsNullOrWhiteSpace(submotivo) ? submotivo : motivo;

        if (accion.Contains("Tutorial", StringComparison.OrdinalIgnoreCase))
        {
            var url = ObtenerUrlVideoTutorial(tema);
            return BuildVideoResourceHtml(tema, url);
        }

        if (accion.Contains("Guia", StringComparison.OrdinalIgnoreCase))
            return BuildGuideStepsHtml(tema);

        return "Cuentame un poco mas de detalle para que el asesor reciba tu caso mejor preparado.";
    }

    private static string ObtenerUrlVideoTutorial(string tema)
