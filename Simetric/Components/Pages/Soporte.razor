    private void EnviarMensajeTexto()
    {
        if (string.IsNullOrWhiteSpace(chatInputText)) return;
        var text = chatInputText.Trim();
        chatInputText = string.Empty;

        if (currentStep == "AsesorTecnico")
        {
            technicalConsultationText = text;
            AbrirAsesorTecnicoIntegrado();
            return;
        }
        
        if (currentStep == "AsesorComercial")
        {
            commercialConsultationText = text;
            AbrirAsesorComercialIntegrado();
            return;
        }

        if (currentStep == "Inicio")
        {
            if (text == "1") ProcesarSeleccion("1");
            else if (text == "2") ProcesarSeleccion("2");
            else ProcesarSeleccion(text);
        }
        else if (currentStep == "SoporteTecnico")
        {
            if (text == "1") ProcesarSeleccion("1.1");
            else if (text == "2") ProcesarSeleccion("1.2");
            else if (text == "3") ProcesarSeleccion("1.3");
            else if (text == "4") ProcesarSeleccion("1.4");
            else ProcesarSeleccion(text);
        }
        else if (currentStep == "VentasConsultas")
        {
            if (text == "1") ProcesarSeleccion("2.1");
            else if (text == "2") ProcesarSeleccion("2.2");
            else if (text == "3") ProcesarSeleccion("2.3");
            else if (text == "4") ProcesarSeleccion("2.4");
            else if (text == "5") ProcesarSeleccion("2.5");
            else ProcesarSeleccion(text);
        }
        else
        {
            chatMessages.Add(new ChatMessage { EsUsuario = true, Texto = text });
            chatMessages.Add(new ChatMessage { EsUsuario = false, Texto = "Por favor, seleccione una de las opciones del menú." });
            ScrollToBottom();
        }
    }

