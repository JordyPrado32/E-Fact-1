    private void VolverMotivosWhatsApp()
    {
        if (string.IsNullOrWhiteSpace(whatsAppCategoriaActual) || whatsAppCategoriaActual.Equals("Selecciona un area", StringComparison.OrdinalIgnoreCase))
        {
            AbrirSelectorCategoriaWhatsApp();
            return;
        }

        whatsAppMotivoActual = string.Empty;
        whatsAppSubmotivoActual = string.Empty;
        whatsAppAccionActual = string.Empty;
        whatsAppRespuestaAutomatica = string.Empty;
