    private void AplicarClasificacionConsultaUsuario(string? consulta, bool actualizarFlujo = false)
    {
        var inferencia = InferirConsultaWhatsApp(consulta);
        whatsAppSugerenciaIA = inferencia.Summary;

        if (!actualizarFlujo || !inferencia.HasSignal)
        {
            return;
        }

        var categoriaActualEsLibre = string.IsNullOrWhiteSpace(whatsAppCategoriaActual) ||
            whatsAppCategoriaActual.Equals("Selecciona un area", StringComparison.OrdinalIgnoreCase);
        var categoriaCambio = !string.Equals(whatsAppCategoriaActual, inferencia.Category, StringComparison.OrdinalIgnoreCase);

        if (categoriaActualEsLibre || whatsAppMostrarCategorias || categoriaCambio)
        {
            AbrirWhatsAppIntegrado(inferencia.Category, consulta, inferencia.Advisor);
        }

        if (!string.IsNullOrWhiteSpace(inferencia.Topic))
        {
            var motivoDetectado = whatsAppOpcionesMotivo.FirstOrDefault(op =>
                op.Label.Equals(inferencia.Topic, StringComparison.OrdinalIgnoreCase) ||
                op.Value.Equals(inferencia.Topic, StringComparison.OrdinalIgnoreCase));

            if (motivoDetectado is not null)
            {
                SeleccionarMotivoWhatsApp(motivoDetectado, insertarEnConsulta: false);
            }
        }

        if (!string.IsNullOrWhiteSpace(inferencia.Subtopic))
        {
            var submotivoDetectado = whatsAppOpcionesSubmotivo.FirstOrDefault(op =>
                op.Label.Equals(inferencia.Subtopic, StringComparison.OrdinalIgnoreCase) ||
                op.Value.Equals(inferencia.Subtopic, StringComparison.OrdinalIgnoreCase));

            if (submotivoDetectado is not null)
            {
                SeleccionarSubmotivoWhatsApp(submotivoDetectado);
            }
        }
    }

    private static WhatsAppInference InferirConsultaWhatsApp(string? consulta)
    {
        var text = (consulta ?? string.Empty).Trim();
        if (text.Length < 6)
        {
            return WhatsAppInference.Empty;
        }

        var normalized = text.ToLowerInvariant();
        var categoria = "Soporte tecnico";
        var advisor = "Arleth";
        var topic = "Otro tema tecnico";
        var subtopic = string.Empty;

        if (ContainsAny(normalized, "plan", "planes", "precio", "cost", "demo", "modulo", "módulo", "comprar", "recarga", "renovar", "suscripcion", "suscripción", "comercial", "ventas", "pago"))
        {
            categoria = "Ventas y consultas";
            advisor = "Brigitte";
            topic = "Hablar con un asesor comercial";

            if (ContainsAny(normalized, "plan", "planes", "precio", "cost", "demo", "modulo", "módulo", "compar", "informacion"))
                topic = "Informacion de planes";
            else if (ContainsAny(normalized, "recarga", "saldo", "documento", "documentos", "comprar"))
                topic = "Compras recargas";
            else if (ContainsAny(normalized, "renovar", "vence", "vencimiento", "suscripcion", "suscripción"))
                topic = "Renovar suscripcion";
            else if (ContainsAny(normalized, "facturacion", "facturación", "factura"))
                topic = "Facturacion";
        }
        else
        {
            if (ContainsAny(normalized, "firma", "p12", "certificado", "clave"))
                topic = "eRúbrica";
            else if (ContainsAny(normalized, "sri", "autoriz", "rechaz", "clave de acceso", "ambiente"))
                topic = "Emision de documentos";
            else if (ContainsAny(normalized, "cliente", "clientes", "producto", "productos", "catalogo", "catálogo", "import"))
                topic = "Productos o clientes";
            else if (ContainsAny(normalized, "factura", "xml", "emit", "secuencial", "comprobante"))
                topic = "Emision de documentos";

            if (topic == "Emision de documentos")
            {
                if (ContainsAny(normalized, "nota de credito", "nota credito", "credito"))
                    subtopic = "Notas de credito";
                else if (ContainsAny(normalized, "liquidacion", "liquidación", "compra"))
                    subtopic = "Liquidacion de compra";
                else if (ContainsAny(normalized, "retencion", "retención", "retenciones"))
                    subtopic = "Retenciones";
                else if (ContainsAny(normalized, "guia", "guía", "remision", "remisión"))
                    subtopic = "Guias de remision";
                else if (ContainsAny(normalized, "nota de debito", "nota debito", "debito"))
                    subtopic = "Notas de debito";
                else
                    subtopic = "Facturas";
            }
        }

        var summary = topic.StartsWith("Otro tema", StringComparison.OrdinalIgnoreCase)
            ? $"Asistente IA: detecté {categoria.ToLowerInvariant()}."
            : $"Asistente IA: detecté {categoria.ToLowerInvariant()} y sugerí \"{(string.IsNullOrWhiteSpace(subtopic) ? topic : $"{topic} > {subtopic}")}\".";
        return new WhatsAppInference(categoria, advisor, topic, subtopic, summary, true);
    }

    private static bool ContainsAny(string text, params string[] terms)
        => terms.Any(term => text.Contains(term, StringComparison.OrdinalIgnoreCase));

    private string BuildConsultaFinalWhatsApp()
    {
        var consultaBase = LimpiarPrefijoMotivo(whatsAppConsultaActual);
        var encabezado = BuildSelectionSummary();

        if (string.IsNullOrWhiteSpace(encabezado))
        {
            return consultaBase;
        }

        if (string.IsNullOrWhiteSpace(consultaBase))
        {
            return encabezado;
        }

        return $"{encabezado}: {consultaBase}".Trim();
    }

    private string LimpiarPrefijoMotivo(string? consulta)
    {
        var text = (consulta ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        var prefixes = new List<string>();

        foreach (var opcion in whatsAppOpcionesMotivo)
        {
            prefixes.Add($"{opcion.Label}:");
            prefixes.Add($"{opcion.Label} >");
        }

        foreach (var opcion in whatsAppOpcionesSubmotivo)
        {
            prefixes.Add($"{opcion.Label}:");
            prefixes.Add($"{opcion.Label} >");
        }

        foreach (var opcion in whatsAppOpcionesAccion)
        {
            prefixes.Add($"{opcion.Label}:");
        }

        prefixes.Add($"{BuildSelectionSummary()}:");

        foreach (var prefix in prefixes.Where(p => !string.IsNullOrWhiteSpace(p)).OrderByDescending(p => p.Length))
        {
            if (text.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            {
                return text[prefix.Length..].Trim();
            }
        }

        return text;
    }

    private string ObtenerNombreUsuarioCorto()
    {
        var primerNombre = ObtenerPrimerSegmento(userNombre);
        var primerApellido = ObtenerPrimerSegmento(userApellidos);
        var nombre = string.Join(" ", new[] { primerNombre, primerApellido }.Where(parte => !string.IsNullOrWhiteSpace(parte)));
        return string.IsNullOrWhiteSpace(nombre) ? "Mercedes Jara" : nombre;
    }

    private static string ObtenerPrimerSegmento(string? valor)
        => string.IsNullOrWhiteSpace(valor)
            ? string.Empty
            : valor.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? string.Empty;

