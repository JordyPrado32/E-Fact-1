        if (t.Contains("emision") || t.Contains("factura") || t.Contains("liquidacion") || t.Contains("retencion") || t.Contains("nota") || t.Contains("guia de remision") || t.Contains("remision"))
            return "https://youtu.be/NyfP6C7Ch_Q?si=Kihb12_mY3abUVCt";
        return "https://youtu.be/NyfP6C7Ch_Q?si=Kihb12_mY3abUVCt";
    }

