@page "/proveedores"
@using Simetric.Models
@using Simetric.Services
@inject IProveedorService ProveedorService

@{
    var filteredProveedores = ProveedoresFiltrados.ToList();
    var totalActivos = proveedores.Count(p => p.estado == true);
    var totalConRetencion = proveedores.Count(p => p.llevaRetencion == true);
    var totalConCorreo = proveedores.Count(p => !string.IsNullOrWhiteSpace(p.email));
}

<PageTitle>Proveedores | Numerica e-fact</PageTitle>

<div class="entity-shell" data-tour="proveedores.page">
    <section class="entity-hero" data-tour="proveedores.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Catalogo de abastecimiento</span>
            <h2>Gestion de proveedores</h2>
            <p>
                Centraliza la base de proveedores y mantenla alineada con el mismo
                patron visual y operativo del resto del panel administrativo.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Activos</span>
                <strong>@totalActivos</strong>
                <small>Proveedores habilitados para compras y procesos operativos.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Con retencion</span>
                <strong>@totalConRetencion</strong>
                <small>Registros marcados como agentes de retencion.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Con correo</span>
                <strong>@totalConCorreo</strong>
                <small>Proveedores listos para contacto y documentacion electronica.</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="proveedores.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Busqueda y control</span>
            <h3>Consulta y actualiza los datos del proveedor</h3>
            <p>Busca por razon social, nombre comercial o RUC y administra el formulario lateral.</p>
        </div>

        <div class="toolbar-actions">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>
                <input class="search-input"
                       placeholder="Buscar por nombre o RUC"
                       @bind="busqueda"
                       @bind:event="oninput" />
            </div>

            <div class="toolbar-secondary-actions">
                <div class="filter-box">
                    <label class="filter-label" for="proveedorTipoFiltro">Tipo</label>
                    <select id="proveedorTipoFiltro" class="filter-select" @bind="filtroTipoIdentificacion">
                        <option value="">Todos</option>
                        @foreach (var item in listaIdentificaciones)
                        {
                            <option value="@item.IdeCodigo">@item.IdeDescripcion</option>
                        }
                    </select>
                </div>

                <button type="button" class="secondary-btn toolbar-secondary-btn" @onclick="() => CargarTodo()">
                    <i class="bi bi-arrow-clockwise"></i>
                    <span>Refrescar</span>
                </button>
            </div>
        </div>
    </section>

    <section class="entity-grid">
        <section class="table-card" data-tour="proveedores.table">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado activo</span>
                    <h3>Proveedores registrados</h3>
                </div>
                <span class="table-badge">@filteredProveedores.Count registros</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(mensaje) && !Editando)
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="status-banner status-banner-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@error</span>
                </div>
            }

            @if (cargando)
            {
                <div class="state-card">
                    <div class="state-icon">
                        <span class="spinner-border text-primary" role="status"></span>
                    </div>
                    <h3>Cargando proveedores</h3>
                    <p>Preparando la informacion comercial, tributaria y de contacto.</p>
                </div>
            }
            else if (!filteredProveedores.Any())
            {
                <div class="state-card state-card-empty">
                    <div class="state-icon">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h3>No hay proveedores para mostrar</h3>
                    <p>Ajusta la busqueda o registra un nuevo proveedor desde el panel lateral.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table entity-table entity-table-proveedores mb-0">
                        <thead>
                            <tr>
                                <th>Proveedor</th>
                                <th>Identificacion</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var proveedor in filteredProveedores)
                            {
                                <tr>
                                    <td>
                                        <div class="cell-main cell-main-stacked">
                                            <strong>@ObtenerNombreProveedor(proveedor)</strong>

                                            @if (!string.IsNullOrWhiteSpace(proveedor.nombreComercial))
                                            {
                                                <span class="meta-line">
                                                    <i class="bi bi-shop"></i>
                                                    <span>@proveedor.nombreComercial</span>
                                                </span>
                                            }

                                            <span class="meta-line">
                                                <i class="bi bi-card-text"></i>
                                                <span>@ObtenerDescripcionIdentificacion(proveedor.tipoIdentificacion)</span>
                                            </span>

                                            @if (!string.IsNullOrWhiteSpace(proveedor.email))
                                            {
                                                <span class="meta-line">
                                                    <i class="bi bi-envelope"></i>
                                                    <span>@proveedor.email</span>
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="code-pill">@(string.IsNullOrWhiteSpace(proveedor.ruc) ? "Sin ID" : proveedor.ruc)</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-group">
                                            <button type="button"
                                                    class="action-btn action-view"
                                                    title="Ver detalle"
                                                    @onclick="() => VerDetalle(proveedor)">
                                                <i class="bi bi-eye"></i>
                                            </button>

                                            <button type="button"
                                                    class="action-btn action-edit"
                                                    title="Editar"
                                                    @onclick="() => EditarAsync(proveedor.idProveedor)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>

                                            <button type="button"
                                                    class="action-btn action-delete"
                                                    title="Eliminar"
                                                    @onclick="() => ConfirmarEliminar(proveedor)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (mostrarConfirmacion && proveedorAEliminar is not null)
            {
                <div class="confirm-card">
                    <div class="confirm-copy">
                        <span class="panel-kicker">Confirmacion</span>
                        <strong>Eliminar el proveedor seleccionado</strong>
                        <p>@ObtenerNombreProveedor(proveedorAEliminar)</p>
                    </div>

                    <div class="confirm-actions">
                        <button type="button" class="secondary-btn" @onclick="CancelarEliminar">Cancelar</button>
                        <button type="button" class="danger-btn" @onclick="EliminarConfirmado">Si, eliminar</button>
                    </div>
                </div>
            }
        </section>

        <section class="editor-card entity-editor-card" data-tour="proveedores.editor">
            <div class="editor-head">
                <div>
                    <span class="panel-kicker">Formulario operativo</span>
                    <h3>@(Editando ? "Editar proveedor" : "Registrar proveedor")</h3>
                    <p>Completa la informacion de identificacion, contacto y configuracion tributaria.</p>
                </div>
                <span class="editor-badge @(Editando ? "editor-badge-edit" : "editor-badge-new")">
                    @(Editando ? "Edicion" : "Nuevo")
                </span>
            </div>

            @if (Editando && !string.IsNullOrWhiteSpace(mensaje))
            {
                <div class="status-banner status-banner-info">
                    <i class="bi bi-info-circle"></i>
                    <span>@mensaje</span>
                </div>
            }

            <div class="editor-body entity-form-legacy">
                <EditForm Model="p_model" OnValidSubmit="Guardar" @key="formKey">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger small" />

                    <div class="row mb-2 mt-3">
                        <div class="col">
                            <label class="form-label small fw-bold">Tipo Identificacion *</label>
                            <InputSelect @bind-Value="p_model.tipoIdentificacion" class="form-select form-select-sm">
                                <option value="">-- Seleccione --</option>
                                @foreach (var item in listaIdentificaciones)
                                {
                                    <option value="@item.IdeCodigo">@item.IdeDescripcion</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col">
                            <label class="form-label small fw-bold">RUC o Identificacion *</label>
                            <InputText @bind-Value="p_model.ruc" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col">
                            <label class="form-label small fw-bold">Razon Social *</label>
                            <InputText @bind-Value="p_model.nombre" class="form-control form-control-sm" />
                        </div>
                        <div class="col">
                            <label class="form-label small">Nombre Comercial</label>
                            <InputText @bind-Value="p_model.nombreComercial" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small">Direccion</label>
                        <InputTextArea @bind-Value="p_model.direccion" class="form-control form-control-sm" rows="2" />
                    </div>

                    <div class="row mb-2">
                        <div class="col">
                            <label class="form-label small">Correo Electronico</label>
                            <InputText @bind-Value="p_model.email" class="form-control form-control-sm" />
                        </div>
                        <div class="col">
                            <label class="form-label small">Tipo Contribuyente</label>
                            <InputSelect @bind-Value="p_model.tipoContribuyente" class="form-select form-select-sm">
                                <option value="">-- Seleccione --</option>
                                <option value="PERSONA NATURAL">Persona natural</option>
                                <option value="SOCIEDAD">Sociedad</option>
                                <option value="MICROEMPRESA">Microempresa</option>
                                <option value="RIMPE">RIMPE</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col">
                            <label class="form-label small fw-bold">Tipo de servicio o producto que provee</label>
                            <InputSelect @bind-Value="p_model.tipoProvision" class="form-select form-select-sm">
                                <option value="">-- Seleccione --</option>
                                <option value="PRODUCTO">Producto</option>
                                <option value="SERVICIO">Servicio</option>
                                <option value="AMBOS">Ambos</option>
                            </InputSelect>
                        </div>
                    </div>


                    <div class="row mb-2">
                        <div class="col">
                            <label class="form-label small">Telefono Convencional</label>
                            <InputText @bind-Value="p_model.telefono" class="form-control form-control-sm" />
                        </div>
                        <div class="col">
                            <label class="form-label small">Telefono Movil</label>
                            <InputText @bind-Value="p_model.telefonoMovil" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col">
                            <label class="form-label small fw-bold">Obligado a llevar contabilidad *</label>
                            <InputSelect @bind-Value="p_model.obligado" class="form-select form-select-sm">
                                <option value="">-- Seleccione --</option>
                                <option value="@('1')">Si</option>
                                <option value="@('0')">No</option>
                            </InputSelect>
                        </div>
                        <div class="col">
                            <label class="form-label small">Detalle</label>
                            <InputTextArea @bind-Value="p_model.detalle" class="form-control form-control-sm" rows="2" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <div class="form-check form-switch mt-2">
                                <InputCheckbox class="form-check-input" @bind-Value="LlevaRetencionActual" />
                                <label class="form-check-label fw-semibold">Agente de retencion</label>
                            </div>
                            <small class="text-muted d-block mt-1">Marca el proveedor si aplica retenciones en tus procesos.</small>
                        </div>
                        <div class="col">
                            <div class="form-check form-switch mt-2">
                                <InputCheckbox class="form-check-input" @bind-Value="EstadoActual" />
                                <label class="form-check-label fw-semibold">Proveedor activo</label>
                            </div>
                            <small class="text-muted d-block mt-1">Controla si el registro permanece disponible para operacion.</small>
                        </div>
                    </div>

                    <div class="form-actions entity-form-actions">
                        <button class="secondary-btn" type="button" @onclick="Nuevo">Limpiar</button>
                        <button class="primary-btn" type="submit" disabled="@guardando">
                            @if (guardando)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <i class="bi bi-save me-1"></i>
                                <span>@(Editando ? "Guardar cambios" : "Crear proveedor")</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </section>
    </section>
</div>

@if (mostrarDetalle && proveedorSeleccionado != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 8px;">
                <div class="modal-header text-white" style="background-color: #006bb5; border-radius: 8px 8px 0 0;">
                    <h5 class="modal-title fw-bold"><i class="bi bi-truck me-2"></i>Detalle del Proveedor</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarDetalle"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6 border-end pe-md-4">
                            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3">Informacion General</h6>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Proveedor:</div>
                                <div class="col-7 fw-medium text-dark">@ObtenerNombreProveedor(proveedorSeleccionado)</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Tipo de provision:</div>
                                <div class="col-7 text-dark">@ObtenerTextoTipoProvision(proveedorSeleccionado.tipoProvision)</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Nombre Comercial:</div>
                                <div class="col-7 text-dark">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.nombreComercial) ? "N/A" : proveedorSeleccionado.nombreComercial)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Identificacion:</div>
                                <div class="col-7"><span class="badge bg-light text-dark border">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.ruc) ? "N/A" : proveedorSeleccionado.ruc)</span></div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Tipo ID:</div>
                                <div class="col-7 text-dark">@ObtenerDescripcionIdentificacion(proveedorSeleccionado.tipoIdentificacion)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Estado:</div>
                                <div class="col-7">
                                    <span class="badge rounded-pill @(proveedorSeleccionado.estado == true ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                        @(proveedorSeleccionado.estado == true ? "Activo" : "Inactivo")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 ps-md-4">
                            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3">Contacto y Tributacion</h6>

                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Correo:</div>
                                <div class="col-7 text-dark">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.email) ? "N/A" : proveedorSeleccionado.email)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Telefono:</div>
                                <div class="col-7 text-dark">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.telefono) ? "N/A" : proveedorSeleccionado.telefono)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Movil:</div>
                                <div class="col-7 text-dark">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.telefonoMovil) ? "N/A" : proveedorSeleccionado.telefonoMovil)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Direccion:</div>
                                <div class="col-7 text-dark">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.direccion) ? "N/A" : proveedorSeleccionado.direccion)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Contribuyente:</div>
                                <div class="col-7 text-dark">@(string.IsNullOrWhiteSpace(proveedorSeleccionado.tipoContribuyente) ? "N/A" : proveedorSeleccionado.tipoContribuyente)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Contabilidad:</div>
                                <div class="col-7 text-dark">@ObtenerTextoObligado(proveedorSeleccionado.obligado)</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-5 text-muted fw-bold small">Retencion:</div>
                                <div class="col-7 text-dark">@(proveedorSeleccionado.llevaRetencion == true ? "Si" : "No")</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="secondary-btn secondary-btn-quiet" @onclick="CerrarDetalle">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Proveedor> proveedores = new();
    private List<Identificacion> listaIdentificaciones = new();
    private Proveedor p_model = new();
    private Proveedor? proveedorAEliminar;
    private Proveedor? proveedorSeleccionado;
    private string busqueda = string.Empty;
    private string filtroTipoIdentificacion = string.Empty;
    private string? mensaje;
    private string? error;
    private bool cargando = true;
    private bool guardando;
    private bool mostrarConfirmacion;
    private bool mostrarDetalle;
    private Guid formKey = Guid.NewGuid();

    private bool Editando => p_model.idProveedor != 0;

    private bool LlevaRetencionActual
    {
        get => p_model.llevaRetencion ?? false;
        set => p_model.llevaRetencion = value;
    }

    private bool EstadoActual
    {
        get => p_model.estado ?? false;
        set => p_model.estado = value;
    }

    protected override async Task OnInitializedAsync()
    {
        ReiniciarFormulario(false);

        try
        {
            listaIdentificaciones = await ProveedorService.GetIdentificacionesAsync();
        }
        catch (Exception ex)
        {
            error = $"No se pudo cargar el catalogo de identificaciones. {ex.Message}";
        }

        await CargarTodo(true);
    }

    private static string ObtenerTextoTipoProvision(string? valor) =>
    valor switch
    {
        "PRODUCTO" => "Producto",
        "SERVICIO" => "Servicio",
        "AMBOS" => "Ambos",
        _ => "No definido"
    };

    private async Task CargarTodo(bool conservarMensajes = false)
    {
        cargando = true;

        if (!conservarMensajes)
        {
            LimpiarEstados();
        }

        try
        {
            proveedores = (await ProveedorService.GetAllAsync())
                .OrderBy(p => ObtenerNombreProveedor(p))
                .ToList();
        }
        catch (Exception ex)
        {
            error = $"No se pudo cargar la lista de proveedores. {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private void Nuevo() => ReiniciarFormulario();

    private void ReiniciarFormulario(bool limpiarEstados = true)
    {
        if (limpiarEstados)
        {
            LimpiarEstados();
        }

        p_model = new Proveedor
        {
            estado = true,
            obligado = '1',
            llevaRetencion = false,
            tipoProvision = ""
        };

        proveedorAEliminar = null;
        mostrarConfirmacion = false;
        formKey = Guid.NewGuid();
    }

    private async Task EditarAsync(int idProveedor)
    {
        LimpiarEstados();
        mostrarConfirmacion = false;
        mostrarDetalle = false;

        try
        {
            var proveedor = await ProveedorService.GetByIdAsync(idProveedor);

            if (proveedor is null)
            {
                error = "No se encontro el proveedor seleccionado.";
                return;
            }

            p_model = proveedor;
            formKey = Guid.NewGuid();
            mensaje = "Los datos del proveedor se cargaron correctamente en el formulario para su edicion.";
        }
        catch (Exception ex)
        {
            error = $"No se pudo cargar el proveedor para edicion. {ex.Message}";
        }
    }

    private IEnumerable<Proveedor> ProveedoresFiltrados => proveedores.Where(proveedor =>
        (string.IsNullOrWhiteSpace(busqueda) ||
         (!string.IsNullOrWhiteSpace(proveedor.nombre) &&
          proveedor.nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase)) ||
         (!string.IsNullOrWhiteSpace(proveedor.nombreComercial) &&
          proveedor.nombreComercial.Contains(busqueda, StringComparison.OrdinalIgnoreCase)) ||
         (!string.IsNullOrWhiteSpace(proveedor.ruc) &&
          proveedor.ruc.Contains(busqueda, StringComparison.OrdinalIgnoreCase))) &&
        (string.IsNullOrWhiteSpace(filtroTipoIdentificacion) ||
         string.Equals(proveedor.tipoIdentificacion, filtroTipoIdentificacion, StringComparison.OrdinalIgnoreCase)));

    private async Task Guardar()
    {
        guardando = true;
        LimpiarEstados();

        var estabaEditando = Editando;

        try
        {
            if (string.IsNullOrWhiteSpace(p_model.tipoProvision))
            {
                error = "Debes seleccionar si el proveedor provee productos, servicios o ambos.";
                return;
            }

            p_model.tipoProvision = p_model.tipoProvision.Trim().ToUpperInvariant();
            p_model.fechaActualizacion = DateTime.Now;

            if (await ProveedorService.UpsertAsync(p_model))
            {
                await CargarTodo(true);
                ReiniciarFormulario(false);
                mensaje = estabaEditando
                    ? "Proveedor actualizado correctamente."
                    : "Proveedor registrado correctamente.";
            }
            else
            {
                error = "No se pudo guardar el proveedor.";
            }
        }
        catch (Exception ex)
        {
            error = $"Ocurrio un error al guardar el proveedor. {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private void ConfirmarEliminar(Proveedor proveedor)
    {
        LimpiarEstados();
        proveedorAEliminar = proveedor;
        mostrarConfirmacion = true;
    }

    private void CancelarEliminar()
    {
        proveedorAEliminar = null;
        mostrarConfirmacion = false;
    }

    private async Task EliminarConfirmado()
    {
        if (proveedorAEliminar is null)
        {
            return;
        }

        var idProveedor = proveedorAEliminar.idProveedor;
        var nombreProveedor = ObtenerNombreProveedor(proveedorAEliminar);

        LimpiarEstados();

        try
        {
            if (await ProveedorService.DeleteAsync(idProveedor))
            {
                await CargarTodo(true);

                if (p_model.idProveedor == idProveedor)
                {
                    ReiniciarFormulario(false);
                }

                if (proveedorSeleccionado?.idProveedor == idProveedor)
                {
                    CerrarDetalle();
                }

                mensaje = $"Proveedor eliminado: {nombreProveedor}.";
            }
            else
            {
                error = "No se pudo eliminar el proveedor.";
            }
        }
        catch (Exception ex)
        {
            error = $"Ocurrio un error al eliminar el proveedor. {ex.Message}";
        }
        finally
        {
            CancelarEliminar();
        }
    }

    private string ObtenerDescripcionIdentificacion(string? codigo)
    {
        if (string.IsNullOrWhiteSpace(codigo))
        {
            return "Sin tipo de identificacion";
        }

        return listaIdentificaciones.FirstOrDefault(item => item.IdeCodigo == codigo)?.IdeDescripcion
            ?? $"Codigo {codigo}";
    }

    private static string ObtenerNombreProveedor(Proveedor proveedor)
    {
        if (!string.IsNullOrWhiteSpace(proveedor.nombre))
        {
            return proveedor.nombre;
        }

        var nombreNatural = string.Join(" ", new[]
        {
            proveedor.primerApellido,
            proveedor.segundoApellido,
            proveedor.primerNombre,
            proveedor.segundoNombre
        }.Where(valor => !string.IsNullOrWhiteSpace(valor)));

        return string.IsNullOrWhiteSpace(nombreNatural)
            ? "Sin nombre registrado"
            : nombreNatural;
    }

    private void VerDetalle(Proveedor proveedor)
    {
        proveedorSeleccionado = proveedor;
        mostrarDetalle = true;
        mostrarConfirmacion = false;
    }

    private void CerrarDetalle()
    {
        mostrarDetalle = false;
        proveedorSeleccionado = null;
    }

    private static string ObtenerTextoObligado(char? valor) =>
        valor switch
        {
            '1' => "Si",
            '0' => "No",
            _ => "No definido"
        };


    private void LimpiarEstados()
    {
        mensaje = null;
        error = null;
    }
}
