@page "/register"
@attribute [AllowAnonymous]
@layout Simetric.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.WebUtilities
@using Simetric.Components.Helpers
@using Simetric.Data
@using Simetric.Models
@using Simetric.Services
@using System.ComponentModel.DataAnnotations
@using System.IO
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDbContextFactory<AppDbContext> DbFactory
@inject Simetric.Services.ClienteService ClienteService
@inject IWebHostEnvironment Env
@inject AppAccessService AppAccessService
@inject VendedorBackOfficeService VendedorBackOfficeService
@inject IEmailService EmailService
@implements IAsyncDisposable

<PageTitle>Registro | Numérica software</PageTitle>

<style>
    @@font-face {
        font-family: "Conthrax SemiBold";
        src: url("/fonts/Conthrax-SemiBold.otf") format("opentype");
        font-style: normal;
        font-weight: 600;
        font-display: swap;
    }

    :root {
        --n-blue: #006bb5;
        --n-blue-dark: #004a7c;
        --n-blue-light: #e6f0f8;
        --n-dark: #2c3e50;
        --white: #ffffff;
        --bg-color: #f4f7f6;
    }

    body {
        font-family: "Montserrat", sans-serif;
        background-color: var(--bg-color);
        margin: 0;
        min-height: 100dvh;
        overflow-x: hidden;
        overflow-y: auto;
    }

    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        color: var(--n-blue);
    }

    .loading-shell {
        width: min(92vw, 28rem);
        padding: 2rem 1.75rem;
        border-radius: 28px;
        background: linear-gradient(155deg, rgba(255, 255, 255, 0.96), rgba(237, 246, 255, 0.92));
        box-shadow: 0 28px 70px rgba(0, 63, 114, 0.18);
        border: 1px solid rgba(0, 107, 181, 0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
    }

    .swal2-container {
        z-index: 20000 !important;
    }

    .loading-logo {
        width: 6rem;
        max-width: 100%;
        object-fit: contain;
        filter: drop-shadow(0 12px 20px rgba(0, 107, 181, 0.18));
    }

    .loading-progress {
        width: 100%;
        height: 0.55rem;
        border-radius: 999px;
        background: rgba(0, 107, 181, 0.1);
        overflow: hidden;
    }

    .loading-progress::after {
        content: "";
        display: block;
        width: 42%;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #1f8fe5, #0d6efd, #57b2ff);
        animation: registerLoadProgress 1.3s ease-in-out infinite;
    }

    @@keyframes registerLoadProgress {
        0% {
            transform: translateX(-110%);
        }

        100% {
            transform: translateX(260%);
        }
    }

    .main-viewport {
        display: flex;
        min-height: max(100vh, 100dvh);
        height: auto;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
        overflow-y: visible;
    }

    .brand-side {
        flex: 1 1 56%;
        background: linear-gradient(135deg, var(--n-blue) 0%, var(--n-blue-dark) 100%);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(2.5rem, 4vw, 5rem);
        position: relative;
        overflow: hidden;
        min-width: 0;
        min-height: 0;
    }

    .brand-side::before,
    .brand-side::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        z-index: 0;
    }

    .brand-side::before {
        width: 400px;
        height: 400px;
        top: -100px;
        left: -100px;
    }

    .brand-side::after {
        width: 600px;
        height: 600px;
        bottom: -200px;
        right: -150px;
    }

    .numeric-digits-layer {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
    }

    .numerica-digit {
        position: absolute;
        z-index: 1;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1;
        user-select: none;
        mix-blend-mode: screen;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.34), 0 0 42px rgba(255, 255, 255, 0.22), 0 0 64px rgba(184, 220, 255, 0.1);
        font-variant-numeric: tabular-nums;
        will-change: transform, opacity;
    }

    @@keyframes numericaDigitFloat {
        0% {
            opacity: 0;
            transform: translate3d(0, 18px, 0) scale(0.88) rotate(var(--rotate, 0deg));
        }

        18% {
            opacity: var(--peak-opacity, 0.42);
        }

        72% {
            opacity: calc(var(--peak-opacity, 0.42) * 0.7);
        }

        100% {
            opacity: 0;
            transform: translate3d(var(--drift-x, 0px), var(--drift-y, -38px), 0) scale(1.05) rotate(calc(var(--rotate, 0deg) + 6deg));
        }
    }

    .numeric-digits-layer::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        background: radial-gradient(circle at 18% 24%, rgba(255, 255, 255, 0.14), transparent 34%), radial-gradient(circle at 74% 72%, rgba(255, 255, 255, 0.11), transparent 30%);
        opacity: 0.78;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        padding: clamp(2.15rem, 3vw, 3.25rem);
        width: min(100%, 38rem);
        max-width: 38rem;
        min-height: clamp(23rem, 50vh, 27rem);
        position: relative;
        z-index: 2;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: clamp(1.35rem, 2vw, 1.9rem);
        text-align: center;
    }

    .brand-logo-shell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        max-width: 100%;
        padding: 0.8rem 1.1rem;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.08));
        border: 1px solid rgba(255, 255, 255, 0.26);
        box-shadow: 0 16px 30px rgba(2, 35, 66, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.18);
        backdrop-filter: blur(10px);
    }

    .brand-lockup {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(0.95rem, 1.4vw, 1.25rem);
        max-width: 100%;
    }

    .brand-logo {
        width: clamp(4.6rem, 8vw, 5.75rem);
        height: clamp(4.6rem, 8vw, 5.75rem);
        max-width: 100%;
        display: block;
        object-fit: contain;
        filter: drop-shadow(0 8px 18px rgba(1, 21, 40, 0.24)) saturate(1.04) contrast(1.04);
    }

    .login-brand-heading {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-weight: 600;
        font-size: clamp(2rem, 3.2vw, 2.85rem);
        letter-spacing: 0;
        line-height: 0.96;
        display: flex;
        flex-direction: column;
        margin: 0;
        text-align: left;
    }

    .brand-tagline {
        margin: 0;
        max-width: 28rem;
        color: rgba(255, 255, 255, 0.78);
        font-size: clamp(1.08rem, 1.55vw, 1.35rem);
        font-weight: 400;
        line-height: 1.55;
    }

    .brand-version-row {
        display: flex;
        justify-content: center;
        width: 100%;
    }

    .brand-mobile-lockup {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .brand-mobile-logo {
        width: 58px;
        height: 58px;
        display: inline-block;
        object-fit: contain;
        filter: drop-shadow(0 10px 18px rgba(37, 76, 205, 0.2));
    }

    .brand-mobile-name {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-size: 1.15rem;
        font-weight: 600;
        line-height: 0.98;
        color: var(--n-dark);
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    .form-side {
        flex: 1 1 52%;
        background: var(--white);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: clamp(1rem, 2vw, 2rem);
        min-width: 0;
        min-height: 0;
        overflow-x: hidden;
        overflow-y: auto;
    }

    .login-container-pro {
        width: 100%;
        max-width: 720px;
        animation: slideUp 0.6s ease-out forwards;
        background: white;
        padding: clamp(1.35rem, 2vw, 2rem);
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.02);
        overflow: visible;
    }

    .login-container-pro .mb-5 {
        margin-bottom: 1.4rem !important;
    }

    .login-container-pro .mb-4 {
        margin-bottom: 0.9rem !important;
    }

    .login-container-pro > .text-center.mb-5 h2 {
        font-size: clamp(1.45rem, 1.9vw, 1.68rem);
    }

    .login-container-pro > .text-center.mb-5 .text-muted.small {
        font-size: 0.76rem !important;
    }

    .register-section {
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 1rem;
        margin-bottom: 1rem;
        background: #ffffff;
    }

    .register-stepper {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
        margin-bottom: 1.5rem;
    }

    .register-step {
        border-radius: 16px;
        border: 1.5px solid #e8eef5;
        background: #f8fafc;
        padding: 0.95rem 1.15rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .register-step.is-active {
        border-color: var(--n-blue);
        background: linear-gradient(135deg, rgba(0, 107, 181, 0.05) 0%, rgba(0, 107, 181, 0.02) 100%);
        box-shadow: 0 10px 25px rgba(0, 107, 181, 0.08);
        transform: translateY(-1px);
    }

    .register-step.is-complete {
        border-color: rgba(25, 135, 84, 0.25);
        background: rgba(25, 135, 84, 0.03);
    }

    .register-step-index {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--n-blue);
        background: rgba(0, 107, 181, 0.08);
        transition: all 0.3s ease;
        flex: none;
    }

    .register-step.is-active .register-step-index {
        background: var(--n-blue);
        color: white;
        box-shadow: 0 0 12px rgba(0, 107, 181, 0.3);
    }

    .register-step.is-complete .register-step-index {
        color: #198754;
        background: rgba(25, 135, 84, 0.12);
    }

    .register-step-copy {
        display: flex;
        align-items: center;
    }

    .register-step-copy strong {
        color: var(--n-dark);
        font-size: 0.88rem;
    }

    .register-section-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--n-dark);
        font-size: 0.82rem;
        font-weight: 700;
        margin-bottom: 0.85rem;
    }

    .register-section-title i {
        color: var(--n-blue);
    }

    .register-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
    }

    .form-field {
        min-width: 0;
    }

    .form-field--full {
        grid-column: 1 / -1;
    }

    .avatar-picker-shell {
        display: grid;
        grid-template-columns: minmax(13rem, 0.78fr) minmax(13rem, 1fr);
        gap: 0.85rem;
        align-items: stretch;
    }

    .avatar-preview-card {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.9rem 1rem;
        margin-bottom: 0;
        border-radius: 18px;
        border: 1px solid #e6edf5;
        background: linear-gradient(135deg, #f8fbff 0%, #eef6ff 100%);
    }

    .avatar-preview-image {
        width: 3.6rem;
        height: 3.6rem;
        border-radius: 18px;
        object-fit: cover;
        border: 2px solid rgba(0, 107, 181, 0.18);
        box-shadow: 0 10px 18px rgba(0, 107, 181, 0.12);
    }

    .avatar-preview-image[src*="Bandera-"] {
        object-fit: contain !important;
        background-color: #ffffff;
    }

    .avatar-preview-copy {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .avatar-preview-copy strong {
        color: var(--n-dark);
        font-size: 0.88rem;
    }

    .avatar-preview-copy span {
        color: #6f7d8b;
        font-size: 0.75rem;
        line-height: 1.35;
    }

    .avatar-scroll {
        max-height: 8.9rem;
        overflow-y: auto;
        padding: 0.25rem 0.35rem 0.25rem 0.25rem;
        border: 1px solid #edf2f7;
        border-radius: 18px;
        background: #f8fafc;
    }

    .avatar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(54px, 1fr));
        gap: 0.55rem;
    }

    .avatar-option {
        border: 2px solid #e6edf5;
        background: #ffffff;
        border-radius: 16px;
        padding: 0.25rem;
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .avatar-option:hover {
        transform: translateY(-2px);
        border-color: rgba(0, 107, 181, 0.42);
        box-shadow: 0 10px 18px rgba(0, 107, 181, 0.12);
    }

    .avatar-option.is-selected {
        border-color: #006bb5;
        box-shadow: 0 0 0 4px rgba(0, 107, 181, 0.12);
    }

    .avatar-option img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 12px;
    }

    .avatar-option img[src*="Bandera-"] {
        object-fit: contain !important;
        background-color: #ffffff;
    }

    .input-wrapper .input-n-premium[type="date"] {
        appearance: none;
        color-scheme: light;
    }

    .form-label-n {
        font-weight: 600;
        font-size: 0.76rem;
        color: var(--n-dark);
        margin-bottom: 7px;
        display: block;
        letter-spacing: 0.5px;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-n-premium {
        width: 100%;
        padding: 14px 45px 14px 45px;
        border: 2px solid #edf2f7;
        border-radius: 12px;
        background: #f8fafc;
        font-size: 0.87rem;
        color: var(--n-dark);
        transition: all 0.3s ease;
    }

    .input-n-premium:focus {
        border-color: var(--n-blue);
        background: white;
        box-shadow: 0 0 0 4px rgba(0, 107, 181, 0.1);
        outline: none;
    }

    .input-icon-n {
        position: absolute;
        left: 16px;
        color: #a0aec0;
        font-size: 1.2rem;
        transition: color 0.3s ease;
    }

    .btn-eye-n {
        position: absolute;
        right: 16px;
        background: transparent;
        border: none;
        color: #a0aec0;
        font-size: 1.2rem;
        cursor: pointer;
        transition: color 0.3s ease;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-eye-n:hover {
        color: var(--n-blue);
    }

    .btn-n-login {
        background: linear-gradient(135deg, var(--n-blue) 0%, var(--n-blue-dark) 100%);
        color: white;
        padding: 16px;
        border-radius: 12px;
        width: 100%;
        border: none;
        font-weight: 600;
        font-size: 0.91rem;
        letter-spacing: 0.5px;
        box-shadow: 0 8px 20px rgba(0, 107, 181, 0.25);
        transition: all 0.3s ease;
        margin-top: 1rem;
    }

    .btn-n-login:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(0, 107, 181, 0.35);
    }

    .btn-n-login:disabled {
        opacity: 0.75;
        cursor: not-allowed;
    }

    .back-link-n {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        margin-top: 0.85rem;
        color: #7a8794;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        background: transparent;
        border: none;
        width: 100%;
        padding: 0.25rem 0;
    }

    .back-link-n:hover {
        color: var(--n-blue);
    }

    .auth-footer {
        margin-top: 1.25rem;
    }

    .service-selector-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .service-selector-card {
        border: 1px solid #e7eef6;
        border-radius: 20px;
        background: #fff;
        padding: 1rem;
        text-align: left;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .service-selector-card:hover {
        transform: translateY(-2px);
        border-color: rgba(0, 107, 181, 0.32);
        box-shadow: 0 14px 28px rgba(0, 107, 181, 0.1);
    }

    .service-selector-card.is-free {
        background: linear-gradient(135deg, #f3fbf6 0%, #ffffff 100%);
        border-color: rgba(25, 135, 84, 0.22);
    }

    .service-selector-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.8rem;
    }

    .service-selector-icon {
        width: 2.8rem;
        height: 2.8rem;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #fff;
        background: var(--service-color, var(--n-blue));
        box-shadow: 0 12px 24px color-mix(in srgb, var(--service-color, var(--n-blue)) 22%, transparent);
    }

    .service-selector-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 999px;
        padding: 0.32rem 0.62rem;
        font-size: 0.72rem;
        font-weight: 700;
        background: #eef3f8;
        color: #35516d;
    }

    .service-selector-title {
        margin: 0 0 0.35rem 0;
        color: var(--n-dark);
        font-size: 1rem;
        font-weight: 700;
    }

    .service-selector-copy {
        color: #6c7a89;
        font-size: 0.8rem;
        line-height: 1.5;
        margin-bottom: 0.9rem;
        min-height: 4.8rem;
    }

    .service-selector-action {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--service-color, var(--n-blue));
        font-size: 0.79rem;
        font-weight: 700;
    }

    .subscription-summary-card {
        border-radius: 20px;
        border: 1px solid #e8eef5;
        background: linear-gradient(135deg, #f8fbff 0%, #ffffff 100%);
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .subscription-summary-card h3 {
        margin: 0 0 0.35rem 0;
        color: var(--n-dark);
        font-size: 1rem;
    }

    .subscription-summary-card p {
        margin: 0;
        color: #6c7a89;
        font-size: 0.82rem;
        line-height: 1.5;
    }

    .subscription-plan-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
        margin-top: 1rem;
    }

    .subscription-plan-card {
        border-radius: 18px;
        border: 1px solid #e8eef5;
        background: #fff;
        padding: 0.95rem;
    }

    .subscription-plan-card strong {
        display: block;
        margin-bottom: 0.35rem;
        color: var(--n-dark);
        font-size: 0.85rem;
    }

    .subscription-plan-card span {
        color: #718096;
        font-size: 0.76rem;
        line-height: 1.45;
    }

    .service-hero-card {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 1.45rem;
        background:
            radial-gradient(circle at top right, rgba(110, 190, 255, 0.32), transparent 32%),
            linear-gradient(145deg, #0d6efd 0%, #005fa3 58%, #003d6b 100%);
        color: #fff;
        box-shadow: 0 26px 60px rgba(0, 83, 145, 0.18);
        margin-bottom: 1.15rem;
    }

    .service-hero-card::after {
        content: "";
        position: absolute;
        inset: auto -2rem -2rem auto;
        width: 10rem;
        height: 10rem;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
    }

    .service-hero-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 1;
    }

    .service-hero-logo {
        width: 4.2rem;
        height: 4.2rem;
        padding: 0.7rem;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
    }

    .service-hero-logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .service-hero-copy h3 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: 0.02em;
    }

    .service-hero-copy p {
        margin: 0.35rem 0 0;
        color: rgba(255, 255, 255, 0.82);
