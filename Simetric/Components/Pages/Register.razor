    private async Task MostrarAlertaAsync(string titulo, string mensaje, string icono, bool dismissProcessingOverlay = false)
    {
        if (_disposed)
            return;

        try
        {
            if (dismissProcessingOverlay && procesando)
            {
                procesando = false;
                await InvokeAsync(StateHasChanged);
                await Task.Yield();
            }

            await JS.InvokeVoidAsync("Swal.fire", titulo, mensaje, icono);
        }
        catch (TaskCanceledException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

