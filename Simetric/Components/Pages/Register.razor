    private static string SanitizarCelular(string? valor)
    {
        return (valor ?? string.Empty).Trim();
    }

    private string SanitizarIdentificacion(string? valor)
    {
        var raw = valor ?? string.Empty;
        if (string.Equals(model.TipoDocumento, "PASAPORTE", StringComparison.OrdinalIgnoreCase))
        {
            var alphaNumeric = new string(raw.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();
            return alphaNumeric.Length <= 20 ? alphaNumeric : alphaNumeric[..20];
        }

        var digitsOnly = new string(raw.Where(char.IsDigit).ToArray());
        return digitsOnly.Length <= 13 ? digitsOnly : digitsOnly[..13];
    }

    private async Task MostrarAlertaErroresAsync(EditContext editContext)
    {
        var identField = editContext.Field(nameof(RegistroForm.Identificacion));
        var identErrors = editContext.GetValidationMessages(identField).ToList();
        
        if (identErrors.Any())
        {
            await MostrarAlertaAsync("Identificación inválida", identErrors.First(), "error");
        }
        else
        {
            var allErrors = editContext.GetValidationMessages().ToList();
            if (allErrors.Any())
            {
                await MostrarAlertaAsync("Formulario Incompleto", allErrors.First(), "warning");
            }
        }
    }

    private async Task AvanzarASeleccionServicioAsync()
    {
        var existe = await EmailYaRegistradoAsync();
        if (existe)
        {
            await MostrarAlertaAsync("Error", "El correo ya esta registrado.", "error");
            return;
        }

        pasoActual = RegisterStep.Servicio;
    }

    private async Task CrearCuentaYRedirigirLoginAsync()
    {
        var existe = await EmailYaRegistradoAsync();
        if (existe)
        {
            await MostrarAlertaAsync("Error", "El correo ya esta registrado.", "error");
            return;
        }

        cuentaCreada = false;
        procesando = true;
        StateHasChanged();

        try
        {
            var usuarioId = await EnsureUsuarioRegistradoAsync();
            if (usuarioId <= 0)
                return;

            registeredUserId = usuarioId;
            cuentaCreada = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1800);
            Nav.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            await MostrarAlertaAsync("Error", ex.Message, "error", dismissProcessingOverlay: true);
        }
        finally
        {
            if (!cuentaCreada)
            {
                procesando = false;
            }

            if (!_disposed)
                await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SeleccionarServicioAsync(ServiceOption servicio)
    {
        if (!string.Equals(servicio.Clave, AppAccessService.FreeServiceKey, StringComparison.OrdinalIgnoreCase))
        {
            await MostrarAlertaAsync("Servicio no disponible", "Por el momento solo puedes registrarte en E-FACT.", "info");
            return;
        }

        procesando = true;
        selectedService = servicio;
        StateHasChanged();

        try
        {
            var usuarioId = await EnsureUsuarioRegistradoAsync();
            if (usuarioId <= 0)
            {
                return;
            }

            if (servicio.EsAccesoLibre)
            {
                procesando = false;
                pasoActual = RegisterStep.Suscripcion;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }
        catch (Exception ex)
        {
            await MostrarAlertaAsync("Error", ex.Message, "error", dismissProcessingOverlay: true);
        }
        finally
        {
            procesando = false;
            if (!_disposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task<int> EnsureUsuarioRegistradoAsync()
    {
        if (registeredUserId is > 0)
            return registeredUserId.Value;

        var email = model.Email.Trim().ToLowerInvariant();
        var usuarioId = 0;

        await using var strategyDb = await DbFactory.CreateDbContextAsync();
        var executionStrategy = strategyDb.Database.CreateExecutionStrategy();

        await executionStrategy.ExecuteAsync(async () =>
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await using var transaction = await db.Database.BeginTransactionAsync();

            var existente = await db.Usuarios.AsNoTracking().FirstOrDefaultAsync(u => u.Email == email);
            if (existente is not null)
            {
                throw new InvalidOperationException("El correo ya esta registrado. Intenta iniciar sesion o usa otro email.");
            }

            var finalAvatarUrl = model.AvatarUrl;
            if (string.IsNullOrWhiteSpace(finalAvatarUrl))
            {
                try
                {
                    var initials = GetInitials();
                    var bgColor = GetBackgroundColorForInitials(initials);
                    var svgContent = $"<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100' width='100' height='100'>" +
                                     $"<rect width='100' height='100' fill='{bgColor}'/>" +
                                     $"<text x='50%' y='55%' font-family='Arial, sans-serif' font-size='40' font-weight='bold' fill='#ffffff' text-anchor='middle' dominant-baseline='middle'>{initials}</text>" +
                                     $"</svg>";

                    var uploadsFolder = Path.Combine(Env.WebRootPath, "images", "Avatars", "uploads");
                    if (!Directory.Exists(uploadsFolder))
                    {
                        Directory.CreateDirectory(uploadsFolder);
                    }

                    var uniqueName = $"avatar_initials_{Guid.NewGuid()}.svg";
                    var filePath = Path.Combine(uploadsFolder, uniqueName);
                    
                    await File.WriteAllTextAsync(filePath, svgContent, System.Text.Encoding.UTF8);
                    finalAvatarUrl = $"images/Avatars/uploads/{uniqueName}";
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error al generar archivo de avatar con iniciales: {ex.Message}");
                    finalAvatarUrl = "/images/Avatars/Avatar-Boy.jpg";
                }
            }

            var usuario = new Usuario
            {
                Nombres = model.TipoCliente == 2 ? model.RazonSocial.Trim() : model.Nombres.Trim(),
                Apellidos = model.TipoCliente == 2 ? string.Empty : model.Apellidos.Trim(),
                NombreEmpresa = model.TipoCliente == 2 ? model.RazonSocial.Trim() : string.Empty,
                Email = email,
                DireccionEmpresa = model.Direccion?.Trim(),
                AvatarUrl = finalAvatarUrl,
                FechaNacimiento = model.FechaNacimiento,
                Celular = model.Celular,
                Identificacion = model.Identificacion.Trim(),
                IdTipoIdentificacion = model.TipoDocumento switch
                {
                    "RUC" => 2,
                    "PASAPORTE" => 3,
                    _ => 1
                },
                PasswordHash = Simetric.Components.Helpers.SecurityHelper.HashPassword(model.Password),
                IdTipoUsuario = 1,
                Estado = true,
                FechaCreacion = DateTime.Now,
                SaldoDocumentos = 5,
                TipoCliente = model.TipoCliente,
                IdVendedor = vendedorRegistroId
            };

            db.Usuarios.Add(usuario);
            await db.SaveChangesAsync();
            await ClienteService.EnsureConsumidorFinalAsync(db, usuario.IdUsuario);
            await transaction.CommitAsync();

            usuarioId = usuario.IdUsuario;
        });

        try
        {
            await EmailService.EnviarCuentaCreadaAsync(email, model.TipoCliente == 2 ? model.RazonSocial : model.Nombres);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"La cuenta se creo, pero no se pudo enviar el correo de confirmacion: {ex.Message}");
        }

        registeredUserId = usuarioId;
        return usuarioId;
    }

