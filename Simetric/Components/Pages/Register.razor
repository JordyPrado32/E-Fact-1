@code {
    private RegistroForm model = new();
    private bool procesando;
    private bool cuentaCreada;
    private bool showPassword;
    private bool _disposed;
    private int? vendedorRegistroId;
    private List<string> availableAvatars = new();
    private List<ServiceOption> serviceOptions = new();
    private RegisterStep pasoActual = RegisterStep.Formulario;
    private ServiceOption? selectedService;
    private int? registeredUserId;

    private string AvatarPreviewUrl => string.IsNullOrWhiteSpace(model.AvatarUrl) ? GenerarSvgIniciales() : ResolveAvatarUrl(model.AvatarUrl);

    private string CelularInput
    {
        get => model.Celular;
        set => model.Celular = SanitizarCelular(value);
    }

    private string IdentificacionInput
    {
        get => model.Identificacion;
        set => model.Identificacion = SanitizarIdentificacion(value);
    }

    private int IdentificacionMaxLength =>
        string.Equals(model.TipoDocumento, "PASAPORTE", StringComparison.OrdinalIgnoreCase) ? 20 : 13;

    private void TogglePasswordVisibility() => showPassword = !showPassword;

    protected override void OnInitialized()
    {
        availableAvatars = CargarAvataresDisponibles();
        model.AvatarUrl = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await AppAccessService.EnsureSchemaAsync();
        vendedorRegistroId = (await ResolverVendedorRegistroAsync()).IdVendedor;

        await using var db = await DbFactory.CreateDbContextAsync();
        serviceOptions = await db.AppServicios
            .AsNoTracking()
            .Where(x => x.Estado && x.Clave == AppAccessService.FreeServiceKey)
            .OrderBy(x => x.OrdenVisual)
            .ThenBy(x => x.Nombre)
            .Select(x => new ServiceOption
            {
                Clave = x.Clave,
                Nombre = x.Nombre,
                Descripcion = x.Descripcion ?? string.Empty,
                Icono = x.Icono,
                ColorHex = string.IsNullOrWhiteSpace(x.ColorHex) ? "#006bb5" : x.ColorHex,
                EsAccesoLibre = !x.RequiereSuscripcion || x.Clave == AppAccessService.FreeServiceKey,
                ServicioId = x.ServicioId
            })
            .ToListAsync();

        if (serviceOptions.Count == 0)
        {
            serviceOptions.Add(new ServiceOption
            {
                Clave = AppAccessService.FreeServiceKey,
                Nombre = "E-FACT",
                Descripcion = "Facturacion electronica con acceso libre para todos los usuarios registrados.",
                Icono = "ri-file-chart-line",
                ColorHex = "#0d6efd",
                EsAccesoLibre = true
            });
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("NumericaDigits.init", "numericaDigitsLayerRegister");
        }
    }

    private List<string> CargarAvataresDisponibles()
    {
        var avatarsPath = Path.Combine(Env.WebRootPath, "images", "Avatars");

        if (!Directory.Exists(avatarsPath))
            return new List<string> { "/images/Avatars/Avatar-Boy.jpg" };

        // Definimos el nombre del archivo que queremos ocultar
        string avatarAOcultar = "avatar_18e35752-9dbd-40a4-8c62-970a2dfc1dfb.png";

        return Directory.GetFiles(avatarsPath)
            .Select(Path.GetFileName)
            .Where(fileName => !string.IsNullOrWhiteSpace(fileName) &&
                               !fileName.Equals(avatarAOcultar, StringComparison.OrdinalIgnoreCase) &&
                               !fileName.Equals("Avatar-Boy.jpg", StringComparison.OrdinalIgnoreCase) &&
                               (fileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                                fileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                                fileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))) // Filtro aplicado
            .OrderByDescending(fileName => fileName.StartsWith("Bandera-", StringComparison.OrdinalIgnoreCase))
            .ThenBy(fileName => fileName, StringComparer.OrdinalIgnoreCase)
            .Select(fileName => $"/images/Avatars/{fileName}")
            .ToList();
    }

    private void SeleccionarAvatar(string avatarUrl)
    {
        model.AvatarUrl = avatarUrl;
        StateHasChanged();
    }

    private bool subiendoArchivo;

    private async Task UploadOwnPhotoAsync(InputFileChangeEventArgs e)
    {
        subiendoArchivo = true;
        StateHasChanged();
        try
        {
            var file = e.File;
            if (file != null)
            {
                // Limitar tamaño a 1MB
                if (file.Size > 1 * 1024 * 1024)
                {
                    await JS.InvokeVoidAsync("Swal.fire", "Error", "La imagen no debe superar 1MB.", "error");
                    return;
                }

                var extension = Path.GetExtension(file.Name).ToLower();
                if (extension != ".png" && extension != ".jpg" && extension != ".jpeg")
                {
                    await JS.InvokeVoidAsync("Swal.fire", "Error", "Formato de imagen no permitido. Use PNG, JPG o JPEG.", "error");
                    return;
                }

                var uploadsFolder = Path.Combine(Env.WebRootPath, "images", "Avatars", "uploads");
                if (!Directory.Exists(uploadsFolder))
                {
                    Directory.CreateDirectory(uploadsFolder);
                }

                // Eliminar avatar temporal anterior de la sesión de registro si existía para no acumular basura
                if (!string.IsNullOrWhiteSpace(model.AvatarUrl) && model.AvatarUrl.Contains("images/Avatars/uploads/"))
                {
                    try
                    {
                        var oldPath = Path.Combine(Env.WebRootPath, model.AvatarUrl.TrimStart('/'));
                        if (File.Exists(oldPath))
                        {
                            File.Delete(oldPath);
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error al eliminar avatar anterior: {ex.Message}");
                    }
                }

                var uniqueName = $"avatar_reg_{Guid.NewGuid()}{extension}";
                var filePath = Path.Combine(uploadsFolder, uniqueName);

                using (var stream = file.OpenReadStream(1 * 1024 * 1024))
                using (var fileStream = new FileStream(filePath, FileMode.Create))
                {
                    await stream.CopyToAsync(fileStream);
                }

                model.AvatarUrl = $"images/Avatars/uploads/{uniqueName}";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al subir imagen: {ex.Message}");
            await JS.InvokeVoidAsync("Swal.fire", "Error", "No se pudo procesar la imagen seleccionada.", "error");
        }
        finally
        {
            subiendoArchivo = false;
            StateHasChanged();
        }
    }

    private static string ResolveAvatarUrl(string? avatarUrl) =>
        string.IsNullOrWhiteSpace(avatarUrl)
            ? "/images/Avatars/Avatar-Boy.jpg"
            : avatarUrl;

    private string GetInitials()
    {
        var firstInit = string.Empty;
        var lastInit = string.Empty;

        if (model.TipoCliente == 2)
        {
            if (!string.IsNullOrWhiteSpace(model.RazonSocial))
            {
                var parts = model.RazonSocial.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0)
                {
                    firstInit = parts[0][0].ToString().ToUpper();
                    if (parts.Length > 1)
                    {
                        lastInit = parts[1][0].ToString().ToUpper();
                    }
                }
            }
        }
        else
        {
            if (!string.IsNullOrWhiteSpace(model.Nombres))
            {
                var parts = model.Nombres.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0)
                {
                    firstInit = parts[0][0].ToString().ToUpper();
                }
            }

            if (!string.IsNullOrWhiteSpace(model.Apellidos))
            {
                var parts = model.Apellidos.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0)
                {
                    lastInit = parts[0][0].ToString().ToUpper();
                }
            }
        }

        var initials = firstInit + lastInit;
        return string.IsNullOrWhiteSpace(initials) ? "?" : initials;
    }

    private string GetBackgroundColorForInitials(string initials)
    {
        string[] premiumColors = new[] {
            "#006bb5", // n-blue
            "#2c3e50", // n-dark
            "#e67e22", // orange
            "#27ae60", // green
            "#9b59b6", // purple
            "#e74c3c", // red
            "#1abc9c", // turquoise
            "#34495e", // wet asphalt
            "#2980b9", // belize hole
            "#8e44ad"  // wisteria
        };
        int hash = 0;
        foreach (char c in initials)
        {
            hash += c;
        }
        return premiumColors[Math.Abs(hash) % premiumColors.Length];
    }

    private string? _lastNombres;
    private string? _lastApellidos;
    private string? _lastRazonSocial;
    private string? _cachedSvg;
    private int _lastTipoCliente;

    private string GenerarSvgIniciales()
    {
        if (_cachedSvg != null &&
            _lastNombres == model.Nombres &&
            _lastApellidos == model.Apellidos &&
            _lastRazonSocial == model.RazonSocial &&
            _lastTipoCliente == model.TipoCliente)
        {
            return _cachedSvg;
        }

        _lastNombres = model.Nombres;
        _lastApellidos = model.Apellidos;
        _lastRazonSocial = model.RazonSocial;
        _lastTipoCliente = model.TipoCliente;

        var initials = GetInitials();
        var bgColor = GetBackgroundColorForInitials(initials);
        
        var svg = $"<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100' width='100' height='100'>" +
                  $"<rect width='100' height='100' fill='{bgColor}'/>" +
                  $"<text x='50%' y='55%' font-family='Arial, sans-serif' font-size='40' font-weight='bold' fill='#ffffff' text-anchor='middle' dominant-baseline='middle'>{initials}</text>" +
                  $"</svg>";
        
        _cachedSvg = $"data:image/svg+xml;base64,{Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(svg))}";
        return _cachedSvg;
    }

    private void OnTipoDocumentoChanged()
    {
        model.Identificacion = SanitizarIdentificacion(model.Identificacion);
    }

    private void OnTipoClienteChanged()
    {
        if (model.TipoCliente == 2)
        {
            model.Nombres = string.Empty;
            model.Apellidos = string.Empty;
            model.TipoDocumento = "RUC";
        }
        else
        {
            model.RazonSocial = string.Empty;
            model.TipoDocumento = "CEDULA";
        }
