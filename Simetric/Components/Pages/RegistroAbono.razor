    font-size: .84rem;
    outline: 0;
}
.cartera-filter-label {
    color: #6a8093;
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.cartera-filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: .55rem;
}
.cartera-filter-chip {
    min-height: 38px;
    padding: 0 .85rem;
    border: 1px solid #d6e4f0;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    background: #f8fbfe;
    color: #49637a;
    font-size: .74rem;
    font-weight: 800;
}
.cartera-filter-chip strong {
    color: #0c6dba;
    font-size: .71rem;
}
.cartera-filter-chip.is-active {
    border-color: #77bdf1;
    background: linear-gradient(180deg, #eff8ff, #dff0ff);
    color: #0c5d99;
    box-shadow: 0 10px 22px rgba(8, 117, 193, .12);
}
.cartera-toolbar-actions { display: flex; align-items: center; gap: .5rem; }
.confirm-btn-sm, .ghost-btn-sm { min-height: 42px; padding: 0 .95rem; }

.cartera-board {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: .7rem;
}
.cartera-insights {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, .9fr);
    gap: .9rem;
}
.cartera-board-main,
.cartera-board-side {
    border: 1px solid #dce8f2;
    border-radius: 9px;
    background: #fff;
    box-shadow: 0 7px 18px rgba(15, 23, 42, .045);
}
.cartera-board-main {
    min-width: 0;
    overflow: hidden;
}
.cartera-board-head {
    padding: .9rem 1rem;
    border-bottom: 1px solid #d8e8f4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    background: linear-gradient(180deg, #ffffff, #f4f9ff);
}
.cartera-board-head h3 {
    margin: .15rem 0 0;
    color: #17324a;
    font-size: .9rem;
}
.cartera-table-wrap { overflow-x: auto; }
.cartera-table {
    width: 100%;
    border-collapse: collapse;
}
.cartera-table th,
.cartera-table td {
    padding: .72rem .6rem;
    border-bottom: 1px solid #e6eef5;
    color: #29445b;
    font-size: .68rem;
    vertical-align: middle;
    white-space: nowrap;
}
.cartera-table tbody tr {
    cursor: pointer;
    transition: background-color .18s ease, box-shadow .18s ease;
}
.cartera-table tbody tr:hover {
    background: #edf7ff;
}
.cartera-table tbody tr.is-selected {
    background: linear-gradient(90deg, #e6f4ff, #f4faff);
    box-shadow: inset 4px 0 0 #0c7bd0;
}
.cartera-table th {
    background: linear-gradient(180deg, #eaf4ff, #deeeff);
    color: #4a6a87;
    font-size: .58rem;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.cartera-table td strong,
.cartera-table td small {
    display: block;
}
.cartera-table td small {
    margin-top: .12rem;
    color: #8495a5;
    font-size: .56rem;
}
.cartera-balance { color: #0875c1 !important; font-weight: 800; }
.cartera-status {
    min-height: 28px;
    padding: 0 .65rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    font-size: .58rem;
    font-weight: 800;
    border: 1px solid transparent;
}
.cartera-status.is-overdue { background: #ffe7ea; color: #bf2238; border-color: #ffc4cb; box-shadow: 0 8px 18px rgba(191,34,56,.12); }
.cartera-status.is-warning { background: #fff4dd; color: #a96805; border-color: #ffd38b; box-shadow: 0 8px 18px rgba(169,104,5,.12); }
.cartera-status.is-current { background: #e7fff3; color: #0d8a55; border-color: #b9efd2; box-shadow: 0 8px 18px rgba(13,138,85,.12); }
.cartera-empty { padding: 1.5rem; color: #708397; text-align: center; }
.cartera-board-side {
    padding: .8rem;
    display: grid;
    align-content: start;
    gap: .75rem;
    position: sticky;
    top: .9rem;
}
.cartera-cta-card {
    padding: 1rem;
    border-radius: 18px;
    border: 1px solid rgba(8, 117, 193, .16);
    background: linear-gradient(180deg, #ffffff, #eef7ff);
    box-shadow: 0 12px 24px rgba(8, 117, 193, .08);
    display: grid;
    gap: .75rem;
}
.cartera-cta-card p {
    margin: 0;
    color: #5e7488;
    font-size: .74rem;
    line-height: 1.5;
}
.cartera-cta-meta {
    padding: .85rem .9rem;
    border-radius: 14px;
    border: 1px solid rgba(8, 117, 193, .14);
    background: rgba(255, 255, 255, .82);
    display: grid;
    gap: .2rem;
}
.cartera-cta-meta span,
.cartera-cta-meta small {
    color: #6a8094;
    font-size: .72rem;
}
.cartera-cta-meta strong {
    color: #0b69b5;
    font-size: 1.05rem;
    font-weight: 900;
}
.cartera-primary-action {
    min-height: 46px;
    border: 0;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .55rem;
    background: linear-gradient(135deg, #0077c8, #0097e6);
    color: #fff;
    font-size: .82rem;
    font-weight: 900;
    box-shadow: 0 14px 24px rgba(0, 119, 200, .22);
}
.cartera-primary-action:disabled {
    opacity: .55;
    box-shadow: none;
}
.cartera-row-action {
    min-height: 34px;
    padding: 0 .8rem;
    border: 1px solid #b9e7cd;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .4rem;
    background: linear-gradient(180deg, #f6fff9, #e7fff0);
    color: #0d8a55;
    font-size: .64rem;
    font-weight: 900;
    box-shadow: 0 10px 18px rgba(13, 138, 85, .12);
}
.cartera-row-action:hover {
    border-color: #92dcaf;
    background: linear-gradient(180deg, #ffffff, #e0fbe9);
}
.cartera-chart-card {
    padding: .65rem;
    border-radius: 14px;
    border: 1px solid #e2edf5;
    background: linear-gradient(180deg, #ffffff, #f8fbff);
    box-shadow: 0 8px 18px rgba(15, 23, 42, .04);
    display: grid;
    gap: .5rem;
}
.cartera-chart-canvas-wrap {
    position: relative;
    min-height: 140px;
}
.cartera-chart-canvas-wrap-ring {
    min-height: 200px;
}
.cartera-chart-canvas-wrap-tall {
    min-height: 130px;
}
.cartera-chart-canvas-wrap canvas {
    width: 100% !important;
    height: 100% !important;
}
.cartera-chart-head h4 {
    margin: .1rem 0 0;
    color: #17324a;
    font-size: .92rem;
}
.cartera-insight-card {
    min-width: 0;
}
.cartera-legend {
    display: grid;
    gap: .45rem;
}
.cartera-legend span {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: .4rem;
    color: #61788e;
    font-size: .62rem;
}
.cartera-legend i {
    width: 8px;
    height: 8px;
    border-radius: 50%;
}
.cartera-legend i.is-danger { background: #ef5b62; }
.cartera-legend i.is-info { background: #f5a623; }
.cartera-legend i.is-current { background: #1eaa72; }
.cartera-legend strong { color: #29445b; }
.cartera-segment-bars {
    display: grid;
    gap: .55rem;
}
.cartera-segment {
    display: grid;
    gap: .25rem;
}
.cartera-segment div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .7rem;
    color: #61788e;
    font-size: .66rem;
    font-weight: 700;
}
.cartera-segment strong {
    color: #17324a;
}
.cartera-segment p {
    height: 8px;
    margin: 0;
    border-radius: 999px;
    overflow: hidden;
    background: #edf3f8;
}
.cartera-segment p span {
    display: block;
    min-width: 3px;
    height: 100%;
    border-radius: inherit;
}
.top-client-list {
    display: grid;
    gap: .7rem;
}
.top-client-list-large {
    gap: .85rem;
}
.top-client-list-compact {
    gap: .55rem;
}
.top-client-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: .65rem;
    align-items: center;
}
.top-client-rank {
    width: 26px;
    height: 26px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: #eef4fb;
    color: #5b738b;
    font-size: .7rem;
    font-weight: 900;
}
.top-client-meta {
    min-width: 0;
    display: grid;
    gap: .08rem;
}
.top-client-meta strong,
.top-client-value {
    color: #17324a;
    font-size: .72rem;
    font-weight: 800;
}
.top-client-meta small {
    color: #7a8ea1;
    font-size: .6rem;
}
.top-client-value {
    white-space: nowrap;
}
.aging-bars {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .9rem;
    align-items: end;
    min-height: 240px;
}
.aging-bar-card {
    display: grid;
    gap: .55rem;
    justify-items: center;
}
.aging-bar-track {
    width: 100%;
    height: 150px;
    padding: 0 .35rem;
    border-radius: 18px 18px 10px 10px;
    display: flex;
    align-items: end;
    background: linear-gradient(180deg, #f8fbff, #eef4f9);
}
.aging-bar-track span {
    display: block;
    width: 100%;
    min-height: 10px;
    border-radius: 14px 14px 8px 8px;
    box-shadow: 0 12px 24px rgba(15, 23, 42, .12);
}
.aging-bar-card strong {
    color: #17324a;
    font-size: .8rem;
    font-weight: 900;
}
.aging-bar-card small {
    color: #64748b;
    font-size: .72rem;
    font-weight: 700;
    text-align: center;
}
.cartera-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    padding: .7rem .85rem;
    border-top: 1px solid #edf2f6;
    color: #60788e;
    font-size: .72rem;
    flex-wrap: wrap;
}
.cartera-pagination-invoice {
    margin-top: .15rem;
    border-top: 0;
    padding-top: .1rem;
}
.distribution-summary-split {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: .75rem;
}
.dist-resumen-compact {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}
.distribution-summary-actions {
    display: flex;
    justify-content: flex-end;
}
.distribution-summary-actions .confirm-btn {
    min-width: 220px;
}

@@media (max-width: 1100px) {
.abono-hero {
        grid-template-columns: 1fr;
    }

    .cartera-toolbar {
        grid-template-columns: 1fr;
    }

    .cartera-toolbar-actions {
        justify-content: flex-start;
        flex-wrap: wrap;
    }

    .cartera-filter-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .cartera-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .cartera-board { grid-template-columns: 1fr; }
    .cartera-board-side { position: static; }
}

@@media (max-width: 640px) {
    .cartera-filter-grid { grid-template-columns: 1fr; }
    .cartera-metrics { grid-template-columns: 1fr; }
}

.hero-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    align-self: start;
}
.stat-card {
    display: flex; flex-direction: column; gap: 0.3rem;
    padding: 0.88rem 0.95rem;
    border-radius: 20px;
    border: 1px solid #e4edf5;
    background: linear-gradient(180deg, #fff, #f8fbff);
    box-shadow: 0 6px 16px rgba(15,23,42,0.04);
}
.stat-label { font-size: 0.74rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--n-text-muted, #64748b); }
.stat-card strong { font-size: 1.34rem; line-height: 1; letter-spacing: -0.03em; color: var(--n-text, #0f172a); }
.stat-card-primary { background: linear-gradient(135deg, rgba(0,107,181,0.1), #fff); border-color: rgba(0,107,181,0.18); }
.stat-card-primary strong { color: var(--n-blue, #006bb5); }
.stat-card-success { background: linear-gradient(135deg, rgba(23,101,63,0.08), #fff); border-color: rgba(23,101,63,0.15); }
.stat-card-success strong { color: #17653f; }
.stat-card-warn { background: linear-gradient(135deg, rgba(202,138,4,0.1), #fff); border-color: rgba(202,138,4,0.2); }
.stat-card-warn strong { color: #854d0e; }
.stat-card-danger { background: linear-gradient(135deg, rgba(220,53,69,0.1), #fff); border-color: rgba(220,53,69,0.18); }
.stat-card-danger strong { color: #b02a37; }
.stat-card-credito { background: linear-gradient(135deg, rgba(5,150,105,0.1), #fff); border-color: rgba(5,150,105,0.2); }
.stat-card-credito strong { color: #065f46; }

/* ── PROCESS ── */
.process-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    position: sticky;
    top: 0.75rem;
    z-index: 8;
}
.process-step {
    border: 0;
    display: flex;
    text-align: left;
    align-items: flex-start;
    gap: 0.75rem;
    min-width: 0;
    padding: 0.9rem 1rem;
    border: 1px solid var(--n-border, #d7e4f0);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,0.97), rgba(246,250,254,0.96));
    color: var(--n-text-muted, #64748b);
    box-shadow: 0 12px 26px rgba(15,23,42,0.06);
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
}
.process-step:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 16px 30px rgba(15,23,42,0.09);
}
.process-step:disabled {
    cursor: not-allowed;
    opacity: 0.72;
}
.process-index {
    width: 34px;
    height: 34px;
    flex: 0 0 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: #eef4f9;
    color: #58738c;
    font-size: 0.86rem;
    font-weight: 900;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.8);
}
.process-step strong,
.process-step small {
    display: block;
}
.process-step strong {
    color: var(--n-text, #16324a);
    font-size: 0.9rem;
}
.process-step small {
    margin-top: 0.08rem;
    color: var(--n-text-muted, #64748b);
    font-size: 0.78rem;
    line-height: 1.45;
}
.process-step.is-active {
    border-color: rgba(0,107,181,0.44);
    background: linear-gradient(135deg, rgba(0,107,181,0.16), rgba(255,255,255,0.98));
    box-shadow: 0 18px 34px rgba(0,107,181,0.16);
    transform: translateY(-2px);
}
.process-step.is-active .process-index,
.process-step.is-done .process-index {
    background: var(--n-blue-soft, #eaf4fb);
    color: var(--n-blue, #006bb5);
}
.process-step.is-active strong,
.process-step.is-active small {
    color: #0c3f69;
}
.process-step.is-active .process-index {
    background: linear-gradient(135deg, #0b7fda, #22a6f2);
    color: #ffffff;
    box-shadow: 0 12px 24px rgba(11,127,218,0.28);
}
.process-step.is-done {
    border-color: rgba(5,150,105,0.24);
    background: linear-gradient(135deg, rgba(5,150,105,0.08), #ffffff);
}
.process-step.is-done .process-index {
    background: rgba(5,150,105,0.1);
    color: #05825b;
}

/* ── NOTICES ── */
.notice-banner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 0.9rem 1rem;
    border-radius: 18px; border: 1px solid transparent;
    flex-wrap: wrap;
}
.notice-success { background: rgba(23,101,63,0.08); color: #17653f; border-color: rgba(23,101,63,0.14); }
.notice-error   { background: rgba(220,53,69,0.08); color: #b02a37; border-color: rgba(220,53,69,0.14); }
.notice-credito { background: rgba(5,150,105,0.08); color: #065f46; border-color: rgba(5,150,105,0.18); }
.notice-copy { display: inline-flex; align-items: center; gap: 0.55rem; font-weight: 600; font-size: 0.94rem; }
.notice-close {
    background: none; border: none; opacity: 0.7; font-size: 1.1rem; cursor: pointer; color: inherit;
    display: inline-flex; align-items: center; padding: 0.2rem;
}
.notice-close:hover { opacity: 1; }

/* ── CREDITO ACTIONS ── */
.credito-actions { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.toggle-label {
    display: inline-flex; align-items: center; gap: 0.55rem;
    cursor: pointer; font-size: 0.87rem; font-weight: 700; color: #065f46;
    user-select: none;
}
.toggle-checkbox { display: none; }
.toggle-track {
    width: 38px; height: 22px; border-radius: 999px;
    background: #d1d5db; transition: background 0.2s;
    position: relative; display: inline-block; flex-shrink: 0;
}
.toggle-checkbox:checked + .toggle-track { background: #059669; }
.toggle-thumb {
    position: absolute; top: 3px; left: 3px;
    width: 16px; height: 16px; border-radius: 50%;
    background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,0.2);
    transition: transform 0.2s;
}
.toggle-checkbox:checked + .toggle-track .toggle-thumb { transform: translateX(16px); }
.ghost-btn-sm { padding: 0 0.7rem; min-height: 34px; font-size: 0.82rem; }

/* ── SALDO DETALLE ── */
.saldo-detalle-card {
    border-radius: 18px; border: 1px solid rgba(5,150,105,0.2);
    background: rgba(5,150,105,0.04);
    padding: 1rem 1.2rem;
    overflow-x: auto;
}
.saldo-detalle-card h4 {
    display: flex; align-items: center; gap: 0.45rem;
    margin: 0 0 0.75rem; font-size: 0.88rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.1em; color: #065f46;
}
.saldo-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 0.87rem; }
.saldo-table th {
    padding: 0.5rem 0.75rem; text-align: left;
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
    color: #065f46; border-bottom: 1px solid rgba(5,150,105,0.2);
}
.saldo-table td { padding: 0.55rem 0.75rem; border-bottom: 1px solid rgba(5,150,105,0.1); }
.text-credito-cell { color: #065f46; font-weight: 700; }

/* ── CARDS ── */
.abono-form-card,
.abono-dist-card {
    width: 100%;
    max-width: none;
    border-radius: 24px;
    border: 1px solid var(--n-border, #e2e8f0);
    background: rgba(255,255,255,0.96);
    box-shadow: 0 10px 28px rgba(15,23,42,0.05);
    padding: 1.15rem 1.2rem;
}
.step-card {
    max-width: none;
}
.single-step-panel {
    max-width: 780px;
}
.step-workspace {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(320px, 0.7fr);
    gap: 1rem;
    align-items: start;
}
.step-main-panel {
    min-width: 0;
}
.step-side-panel {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
}
.step-side-card {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.05rem;
    border: 1px solid #dce9f3;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #f9fcff);
}
.step-side-card h4 {
    margin: 0;
    color: var(--n-text, #16324a);
    font-size: 1rem;
}
.step-side-card p {
    margin: 0;
    color: var(--n-text-muted, #64748b);
    font-size: 0.85rem;
    line-height: 1.6;
}
.step-side-stats {
    display: grid;
    gap: 0.7rem;
}
.mini-stat-card {
    display: grid;
    gap: 0.2rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid #e2edf5;
    border-radius: 16px;
    background: #ffffff;
}
.mini-stat-card span {
    color: #6b8095;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.mini-stat-card strong {
    color: var(--n-text, #16324a);
    font-size: 1rem;
    line-height: 1.35;
    font-variant-numeric: tabular-nums;
}
.step-tip-list {
    display: grid;
    gap: 0.65rem;
}
.step-tip-item {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 0.85rem 0.95rem;
    border: 1px dashed #d4e3ef;
    border-radius: 16px;
    background: #fbfdff;
    color: #5b738b;
    font-size: 0.84rem;
    line-height: 1.55;
}
.step-tip-item i {
    color: var(--n-blue, #006bb5);
    font-size: 1rem;
    margin-top: 0.05rem;
}
.payment-fields-inline {
    grid-template-columns: minmax(220px, 0.65fr) minmax(260px, 1fr);
}
.form-card-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 1.2rem; flex-wrap: wrap;
}
.form-card-head h3 { margin: 0.25rem 0 0; font-size: 1.15rem; letter-spacing: -0.02em; }
.head-hint { margin: 0.35rem 0 0; font-size: 0.85rem; color: var(--n-text-muted, #64748b); }
.section-kicker {
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--n-blue, #006bb5);
}
.cliente-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.85rem; border-radius: 999px;
    background: rgba(0,107,181,0.08); color: var(--n-blue, #006bb5);
    font-size: 0.85rem; font-weight: 700; white-space: nowrap;
}

/* ── FORM GRID ── */
.payment-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1rem;
}
.work-subcard {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
    height: 100%;
    padding: 1rem;
    border: 1px solid #dce9f3;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #f9fcff);
}
.subcard-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}
.subcard-icon {
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: var(--n-blue-soft, #eaf4fb);
    color: var(--n-blue, #006bb5);
    font-size: 1.05rem;
}
.subcard-head strong,
.subcard-head small {
    display: block;
}
.subcard-head strong {
    color: var(--n-text, #16324a);
    font-size: 0.98rem;
}
.subcard-head small {
    margin-top: 0.1rem;
    color: var(--n-text-muted, #64748b);
    font-size: 0.82rem;
    line-height: 1.45;
}
.payment-fields {
    display: grid;
    gap: 1rem;
}
.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}
.form-field-wide { grid-column: 1 / -1; }
.form-field { display: flex; flex-direction: column; gap: 0.45rem; }
.field-label { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.13em; text-transform: uppercase; color: #557089; }
.field-input {
    min-height: 46px; border-radius: 14px; border: 1px solid #d4e3ef;
    background: #fff; padding: 0 0.9rem; font-size: 0.95rem;
    transition: border-color 0.18s, box-shadow 0.18s;
}
.field-input:focus { outline: none; border-color: var(--n-blue, #006bb5); box-shadow: 0 0 0 4px rgba(0,107,181,0.12); }
.field-input:disabled { background: #f4f8fc; color: #94a3b8; cursor: not-allowed; }
.field-hint { font-size: 0.8rem; color: var(--n-text-muted, #64748b); }
.field-hint-credito { color: #065f46; font-weight: 600; display: flex; align-items: center; gap: 0.3rem; }
.amount-shortcuts {
    display: flex;
    gap: .45rem;
    flex-wrap: wrap;
}
.amount-chip {
    min-height: 32px;
    padding: 0 .8rem;
    border: 1px solid #cfe0ee;
    border-radius: 999px;
    background: #f8fbff;
    color: #31526d;
    font-size: .75rem;
    font-weight: 800;
}
.amount-chip-soft {
    background: #fff;
}
.step-toggle-card {
    padding: .9rem 1rem;
    border: 1px solid #dce9f3;
    border-radius: 16px;
    background: linear-gradient(180deg, #ffffff, #f9fcff);
    color: #17324a;
}

/* ── SEARCH ── */
.search-wrap { position: relative; }
.search-input-group {
    display: flex; align-items: center; gap: 0;
    position: relative;
}
.search-icon {
    position: absolute; left: 0.85rem; font-size: 1rem; color: #94a3b8; pointer-events: none; z-index: 1;
}

    .search-input {
        padding-left: 3.5rem !important; /* Respeta el espacio de la lupa a la izquierda */
        padding-right: 3.5rem !important; /* Respeta el espacio del ícono de cargar/cerrar a la derecha */
        width: 100%;
    }

.search-spin, .search-clear {
    position: absolute; right: 0.85rem;
    font-size: 1rem; color: #94a3b8;
}
.search-spin { animation: spin 0.8s linear infinite; pointer-events: none; }
.search-clear {
    background: none; border: none; cursor: pointer; padding: 0.15rem;
    display: inline-flex; align-items: center;
    transition: color 0.15s;
}
.search-clear:hover { color: #b02a37; }
@@keyframes spin { to { transform: rotate(360deg); } }

.suggestions-list {
    position: absolute; z-index: 200; width: 100%; top: calc(100% + 6px);
    background: #fff; border: 1px solid #d4e3ef; border-radius: 16px;
    box-shadow: 0 16px 40px rgba(15,23,42,0.12);
    list-style: none; margin: 0; padding: 0.4rem;
    max-height: 320px; overflow-y: auto;
}
.suggestion-item {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 0.75rem 0.9rem; border-radius: 12px;
    cursor: pointer; transition: background 0.15s;
}
.suggestion-item:hover { background: #f0f7ff; }
.suggestion-nombre { font-weight: 700; font-size: 0.9rem; color: var(--n-text, #0f172a); }
.suggestion-meta { font-size: 0.78rem; color: var(--n-text-muted, #64748b); line-height: 1.45; }

/* ── AMOUNT ── */
.amount-input-wrap { display: flex; align-items: center; position: relative; }
.amount-prefix {
    position: absolute; left: 0.9rem; font-weight: 800; color: #17653f; font-size: 1rem; pointer-events: none;
}
.amount-input { padding-left: 1.8rem; width: 100%; font-size: 1.1rem; font-weight: 700; color: #17653f; }

/* ── DISTRIBUTION OVERVIEW ── */
.distribution-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.1rem;
    margin-bottom: 1rem;
}
.overview-card {
    display: grid;
    gap: 0.42rem;
    min-width: 0;
    padding: 1.05rem 1.1rem;
    border-radius: 18px;
    border: 1px solid #dce9f3;
    background: linear-gradient(180deg, #ffffff, #f8fbff);
}
.overview-card span {
    color: #6b8095;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
}
.overview-card strong {
    color: var(--n-text, #16324a);
    font-size: 1.28rem;
    line-height: 1;
    font-variant-numeric: tabular-nums;
}
.overview-card small {
    color: var(--n-text-muted, #64748b);
    font-size: 0.78rem;
    line-height: 1.45;
}
.overview-card-primary {
    border-color: rgba(0,107,181,0.2);
    background: linear-gradient(135deg, rgba(0,107,181,0.1), #ffffff);
}
.overview-card-primary strong { color: var(--n-blue, #006bb5); }
.overview-card-success {
    border-color: rgba(5,150,105,0.22);
    background: linear-gradient(135deg, rgba(5,150,105,0.09), #ffffff);
}
.overview-card-success strong { color: #065f46; }
.overview-card-warn {
    border-color: rgba(202,138,4,0.22);
    background: linear-gradient(135deg, rgba(202,138,4,0.1), #ffffff);
}
.overview-card-warn strong { color: #9a6700; }
.overview-card-danger {
    border-color: rgba(220,53,69,0.24);
    background: linear-gradient(135deg, rgba(220,53,69,0.08), #ffffff);
}
.overview-card-danger strong { color: #b02a37; }
.overview-card-neutral {
    border-color: rgba(5,150,105,0.2);
    background: linear-gradient(135deg, rgba(5,150,105,0.05), #ffffff);
}
.overview-card-neutral strong { color: #05825b; }
.overview-card-soft {
    border-color: rgba(148,163,184,0.24);
    background: linear-gradient(180deg, #ffffff, #f6f9fc);
}

.distribution-workbench {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
    gap: 1.1rem;
    align-items: stretch;
    margin-top: 0.4rem;
    padding: 1.15rem 1.2rem;
    border-radius: 18px;
    border: 1px solid #dce9f3;
    background: linear-gradient(180deg, rgba(240,247,255,0.8), #ffffff);
}
.distribution-workbench h4 {
    margin: 0.2rem 0 0.35rem;
    color: var(--n-text, #16324a);
    font-size: 1.02rem;
}
.distribution-workbench p {
    margin: 0;
    color: var(--n-text-muted, #64748b);
    font-size: 0.88rem;
    line-height: 1.6;
}
.distribution-workbench-note {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    border: 1px solid rgba(0,107,181,0.16);
    background: rgba(0,107,181,0.05);
    color: #31526d;
    font-size: 0.85rem;
    line-height: 1.55;
}
.distribution-workbench-note i {
    font-size: 1rem;
    color: var(--n-blue, #006bb5);
    margin-top: 0.08rem;
}

.invoice-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.15rem;
    margin-bottom: 0.25rem;
}
.invoice-section-head h4 {
    margin: 0;
    color: var(--n-text, #16324a);
    font-size: 1rem;
}
.invoice-section-head p {
    margin: 0.2rem 0 0;
    color: var(--n-text-muted, #64748b);
    font-size: 0.84rem;
    line-height: 1.5;
}
/* ── DIST TABLE ── */
.invoice-list-shell {
    display: grid;
    gap: 0.9rem;
    margin-top: 0.35rem;
}
.invoice-list-head {
    display: grid;
    grid-template-columns: minmax(280px, 1.7fr) minmax(120px, 0.8fr) minmax(120px, 0.8fr) minmax(120px, 0.8fr) minmax(230px, 1fr);
    gap: 0.75rem;
    padding: 0 0.9rem;
    align-items: end;
}
.invoice-list-head span {
    color: #6b8095;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}
.invoice-list {
    display: grid;
    gap: 0.7rem;
    width: 100%;
}
.invoice-row {
    display: grid;
    grid-template-columns: minmax(280px, 1.7fr) minmax(120px, 0.8fr) minmax(120px, 0.8fr) minmax(120px, 0.8fr) minmax(230px, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 1rem 1.05rem;
    border: 1px solid #dce9f3;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #f9fcff);
    overflow: hidden;
}
.invoice-row.is-active {
    border-color: rgba(23,101,63,0.24);
    background: linear-gradient(180deg, rgba(23,101,63,0.05), #ffffff);
}
.invoice-row.has-error {
    border-color: rgba(220,53,69,0.38);
    background: linear-gradient(180deg, rgba(220,53,69,0.05), #ffffff);
}
.invoice-col {
    display: grid;
    min-width: 0;
}
.invoice-col-label {
    display: none;
    color: #6b8095;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.invoice-title {
    display: grid;
    gap: 0.35rem;
}
.invoice-title small {
    color: var(--n-text-muted, #64748b);
    font-size: 0.82rem;
    font-weight: 700;
}
.invoice-col-doc {
    gap: 0.8rem;
}
.invoice-doc-progress {
    display: grid;
    gap: 0.35rem;
    padding-top: 0.1rem;
}
.invoice-col-value {
    gap: 0.18rem;
    padding: 0.2rem 0.15rem;
}
.invoice-col-value strong {
    color: var(--n-text, #16324a);
    font-size: 0.98rem;
    font-variant-numeric: tabular-nums;
}
.invoice-col-balance strong {
    color: var(--n-blue, #006bb5);
}
.invoice-col-apply {
    min-width: 0;
}
.invoice-col-apply {
    display: grid;
    gap: 0.45rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid #e2edf5;
    border-radius: 14px;
    background: #ffffff;
    width: 100%;
}
.dist-table-wrap { overflow-x: auto; margin-top: 0.25rem; }
.dist-table {
    width: 100%; border-collapse: collapse; border-spacing: 0;
    font-size: 0.9rem;
}
.dist-table thead tr {
    background: linear-gradient(180deg, #f7fbff, #eef5fb);
}
.dist-table thead th {
    padding: 0.95rem 1rem; color: #31526d;
    font-size: 0.74rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;
    white-space: nowrap;
    border-bottom: 1px solid #dfeaf4;
}
.dist-table tbody tr { transition: background 0.15s; }
.dist-table tbody tr:hover { background: #f4f9ff; }
.dist-table tbody td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid #edf3f8;
    vertical-align: middle;
}
.row-activa { background: rgba(23,101,63,0.04) !important; }
.row-excede { background: rgba(220,53,69,0.05) !important; }
