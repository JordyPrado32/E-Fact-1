    private string CarteraRingStyle
    {
        get
        {
            if (SaldoCarteraTotal <= 0)
                return "background: conic-gradient(#dce8f1 0 100%);";

            var vencido = PorcentajeSegmento(SaldoVencido);
            var porVencer = vencido + PorcentajeSegmento(SaldoPorVencer);
            return string.Create(
                CultureInfo.InvariantCulture,
                $"background: conic-gradient(#ef5b62 0 {vencido:F2}%, #f5a623 {vencido:F2}% {porVencer:F2}%, #1eaa72 {porVencer:F2}% 100%);");
        }
    }

    private decimal PorcentajeSegmento(decimal valor) =>
        SaldoCarteraTotal <= 0 ? 0m : Math.Clamp(valor / SaldoCarteraTotal * 100m, 0m, 100m);

    private sealed class TopClienteSaldoVM
    {
        public int Rank { get; set; }
        public string NombreCliente { get; set; } = string.Empty;
        public string Identificacion { get; set; } = string.Empty;
        public decimal Saldo { get; set; }
        public decimal PercentCss { get; set; }
        public string Color { get; set; } = "#006bb5";
    }

    private sealed class SaldoBarraVM
    {
        public string Label { get; set; } = string.Empty;
        public decimal Valor { get; set; }
        public decimal PercentCss { get; set; }
        public string Color { get; set; } = "#006bb5";
    }

    private List<TopClienteSaldoVM> TopClientesSaldo
    {
        get
        {
            var grupos = carteraPendiente
                .GroupBy(f => new { f.IdCliente, Nombre = f.NombreCliente ?? "Cliente", Id = f.NumeroIdentificacion ?? "-" })
                .Select(g => new { g.Key.Nombre, g.Key.Id, Saldo = g.Sum(x => x.SaldoPendiente) })
                .OrderByDescending(x => x.Saldo)
                .Take(5)
                .ToList();

            var maxSaldo = grupos.FirstOrDefault()?.Saldo ?? 0m;
            var palette = new[] { "#006bb5", "#1d4ed8", "#10b981", "#f59e0b", "#ef4444" };

            return grupos.Select((g, index) => new TopClienteSaldoVM
            {
                Rank = index + 1,
                NombreCliente = g.Nombre,
                Identificacion = g.Id,
                Saldo = g.Saldo,
                PercentCss = maxSaldo <= 0 ? 0m : Math.Clamp(g.Saldo / maxSaldo * 100m, 0m, 100m),
                Color = palette[index % palette.Length]
            }).ToList();
        }
    }

    private List<SaldoBarraVM> AntiguedadSaldoBarras
    {
        get
        {
            var hoy = DateTime.Today;
            var barras = new List<SaldoBarraVM>
            {
                CrearBarraAntiguedad("0 - 30 dias", carteraPendiente.Where(f => ObtenerDiasAntiguedad(f, hoy) <= 30).Sum(f => f.SaldoPendiente), "#3b82f6"),
                CrearBarraAntiguedad("31 - 60 dias", carteraPendiente.Where(f => ObtenerDiasAntiguedad(f, hoy) is > 30 and <= 60).Sum(f => f.SaldoPendiente), "#f59e0b"),
                CrearBarraAntiguedad("61 - 90 dias", carteraPendiente.Where(f => ObtenerDiasAntiguedad(f, hoy) is > 60 and <= 90).Sum(f => f.SaldoPendiente), "#2563eb"),
                CrearBarraAntiguedad("Mas de 90 dias", carteraPendiente.Where(f => ObtenerDiasAntiguedad(f, hoy) > 90).Sum(f => f.SaldoPendiente), "#ef4444")
            };

            var maximo = barras.Max(x => x.Valor);
            foreach (var barra in barras)
                barra.PercentCss = maximo <= 0 ? 8m : Math.Max(8m, Math.Clamp(barra.Valor / maximo * 100m, 0m, 100m));

            return barras;
        }
    }

    private int FacturasTotalPaginas => Math.Max((int)Math.Ceiling(facturasPendientes.Count / (double)FacturasPageSize), 1);
    private int FacturasPaginaActual => Math.Clamp(facturasPage, 1, FacturasTotalPaginas);
    private int FacturasInicioRegistro => facturasPendientes.Count == 0 ? 0 : ((FacturasPaginaActual - 1) * FacturasPageSize) + 1;
    private int FacturasFinRegistro => Math.Min(FacturasPaginaActual * FacturasPageSize, facturasPendientes.Count);
    private IEnumerable<FacturaPendienteVM> FacturasPendientesOrdenadas =>
        ordenFacturasPendientesActual == OrdenFacturasPendientes.MasRecientes
