    background: rgba(245, 250, 255, .75);
}
.cartera-filter-panel-full {
    gap: .85rem;
}
.cartera-filter-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    flex-wrap: wrap;
}
.cartera-filter-head h4 {
    margin: .18rem 0 0;
    color: #17324a;
    font-size: .92rem;
}
.cartera-filter-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(3, minmax(180px, 1fr));
    gap: .75rem;
    align-items: start;
}
.cartera-filter-block,
.cartera-filter-field {
    display: grid;
    gap: .45rem;
}
.cartera-filter-field span {
    color: #587086;
    font-size: .72rem;
    font-weight: 800;
}
.cartera-filter-field select {
    min-height: 42px;
    padding: 0 .9rem;
    border: 1px solid #d6e4f0;
    border-radius: 14px;
    background: #fff;
