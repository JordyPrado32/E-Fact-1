    private CarteraSegmento CrearSegmentoCartera(string label, decimal valor, string color)
    {
        var porcentaje = PorcentajeSegmento(valor);
        return new CarteraSegmento
        {
            Label = label,
            Valor = valor,
            Color = color,
            PercentCss = porcentaje.ToString("0.##", CultureInfo.InvariantCulture),
            PercentLabel = $"{porcentaje:0.#}%"
        };
    }

    private bool PuedeIrADistribucion => clienteSeleccionado != null && MontoDisponibleTotal > 0;
    private bool PuedeProcesar =>
        clienteSeleccionado != null &&
        MontoDisponibleTotal > 0 &&
        TotalDistribuido > 0 &&
        TotalDistribuido <= MontoDisponibleTotal &&
        !abonosDistribucion.Any(kv => {
            var fac = facturasPendientes.FirstOrDefault(f => f.IdFactura == kv.Key);
            return fac != null && kv.Value > fac.SaldoPendiente;
        });
    private IEnumerable<(FacturaPendienteVM Factura, decimal Abono)> FacturasConAbono =>
        facturasPendientes
            .Select(f => (Factura: f, Abono: abonosDistribucion.TryGetValue(f.IdFactura, out var abono) ? abono : 0m))
            .Where(x => x.Abono > 0);
    private int FacturasConAbonoCount => abonosDistribucion.Count(kv => kv.Value > 0);
    private string FacturasPendientesConSaldoTexto =>
        FacturasConAbonoCount > 0
            ? $"{FacturasConAbonoCount} factura(s) ya tienen valor capturado."
            : "Aún no ha registrado abonos manuales.";

    private string GetPasoClase(int paso)
    {
        var clases = new List<string>();

        if (pasoActual == paso)
            clases.Add("is-active");

        if (paso < pasoActual && PasoCompletado(paso))
            clases.Add("is-done");

        return string.Join(" ", clases);
    }

    private bool PasoCompletado(int paso) => paso switch
    {
        1 => clienteSeleccionado != null,
        2 => PuedeIrADistribucion,
        3 => TotalDistribuido > 0,
        4 => PuedeProcesar,
        _ => false
    };

    private void IrAlPaso(int paso)
    {
        if (paso == 1)
        {
            pasoActual = 1;
            mostrarConfirmacionFinal = false;
            return;
        }

        if (paso == 2 && clienteSeleccionado != null)
        {
            pasoActual = 2;
            mostrarConfirmacionFinal = false;
            return;
        }

        if (paso == 3 && PuedeIrADistribucion)
        {
            pasoActual = 3;
            mostrarConfirmacionFinal = false;
            return;
        }

        if (paso == 4 && PuedeProcesar)
        {
            pasoActual = 4;
            mostrarConfirmacionFinal = false;
        }
    }

    private void ContinuarADistribucion()
    {
        if (!PuedeIrADistribucion)
        {
            mensajeError = "Seleccione un cliente e ingrese un monto mayor a cero.";
            return;
        }

        mensajeError = null;
        pasoActual = 3;
    }

    private void AbrirConfirmacionFinal()
    {
        if (!PuedeProcesar)
        {
            mensajeError = "Revise la distribucion antes de confirmar el abono.";
            return;
        }

        confirmacionFinalAceptada = false;
        mostrarConfirmacionFinal = true;
    }

    private void CerrarConfirmacionFinal()
    {
        if (cargando)
            return;

        mostrarConfirmacionFinal = false;
        confirmacionFinalAceptada = false;
    }

    private string GetSaldoRestanteDescripcion()
    {
        if (SaldoRestante < 0)
            return "La distribución supera lo disponible.";

        if (SaldoRestante == 0)
            return "El monto quedó distribuido por completo.";

        return "Este valor se guardará como saldo a favor.";
    }

    private async Task ProcesarPagoConfirmado()
    {
        if (!confirmacionFinalAceptada || !PuedeProcesar)
            return;

        await ProcesarPago();
    }

    /* ── Búsqueda predictiva ── */
    private System.Threading.CancellationTokenSource? _cts;

    [SupplyParameterFromQuery(Name = "tutorial")]
    public string? TutorialQuery { get; set; }

    [SupplyParameterFromQuery(Name = "forceTutorial")]
    public bool ForceTutorial { get; set; }

    [SupplyParameterFromQuery(Name = "clienteId")]
    public int? ClienteIdQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _tutorialAbonos = TutorialRegistry.GetById(TutorialAbonosId);
        isDemoMode = EsRutaDemoAbonos();

        if (isDemoMode)
        {
            CargarDemoAbonos();
            _tutorialAbonosEvaluado = true;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst("IdUsuario")?.Value;
        if (!int.TryParse(idClaim, out currentUserId) || currentUserId <= 0)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        carteraPendiente = await AbonoService.GetFacturasCreditoPendientes(currentUserId);
    }

    protected override void OnParametersSet()
    {
        var firmaActual = $"{TutorialQuery}|{ForceTutorial}";

        if (!string.Equals(_firmaTutorialActual, firmaActual, StringComparison.Ordinal))
        {
            _firmaTutorialActual = firmaActual;
            _tutorialAbonosEvaluado = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await RenderCarteraChartsAsync();

        if (isDemoMode)
            return;

        await IntentarSeleccionarClienteDesdeQueryAsync();

        if (_tutorialAbonosEvaluado || _tutorialAbonos is null || currentUserId <= 0)
            return;

        var lanzamientoForzado =
            ForceTutorial &&
            string.Equals(TutorialQuery, TutorialAbonosId, StringComparison.OrdinalIgnoreCase);

        var debeAutoIniciar = lanzamientoForzado ||
                              await TutorialStateService.ShouldAutoStartAsync(TutorialAbonosId);

        _tutorialAbonosEvaluado = true;

        if (!debeAutoIniciar)
            return;

        _tutorialLanzadoDesdeCatalogo = lanzamientoForzado;
        _mostrarTutorialAbonos = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task IntentarSeleccionarClienteDesdeQueryAsync()
    {
        if (!ClienteIdQuery.HasValue || currentUserId <= 0)
            return;

        if (clienteSeleccionado?.IdCliente == ClienteIdQuery.Value)
            return;

        var cliente = carteraPendiente.FirstOrDefault(x => x.IdCliente == ClienteIdQuery.Value);
        if (cliente is null)
            return;

        clienteFiltroCartera = ClienteIdQuery.Value.ToString(CultureInfo.InvariantCulture);
        OnCarteraFiltroChanged();
        await SeleccionarCliente(cliente);
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync(
            "eval",
            "requestAnimationFrame(() => { document.getElementById('registro-abono-paso-2')?.scrollIntoView({ behavior: 'smooth', block: 'start' }); });");
    }

    private async Task RenderCarteraChartsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("numericaCarteraCharts.render", new
            {
                resumen = new
                {
                    labels = ResumenChartLabels,
                    values = ResumenChartValues,
                    colors = ResumenChartColors
                },
                antiguedad = new
                {
                    labels = AntiguedadChartLabels,
                    values = AntiguedadChartValues,
                    colors = AntiguedadChartColors
                },
                topClientes = new
                {
                    labels = TopClientesChartLabels,
                    values = TopClientesChartValues,
                    colors = TopClientesChartColors
                }
            });
        }
        catch
        {
        }
    }

    private async Task OnFiltroInput(ChangeEventArgs e)
    {
        filtroBusqueda = e.Value?.ToString() ?? "";
        carteraPage = 1;
        ValidarFacturaSeleccionadaCartera();
        sugerencias.Clear();
        mensajeError = null;

        var filtroNormalizado = filtroBusqueda.Trim();
        var nombreClienteSeleccionado = clienteSeleccionado?.NombreCliente?.Trim() ?? string.Empty;

        if (clienteSeleccionado != null &&
            !string.Equals(filtroNormalizado, nombreClienteSeleccionado, StringComparison.OrdinalIgnoreCase))
        {
            ResetClienteSeleccionado();
        }

        _cts?.Cancel();
        _cts = null;

        if (filtroNormalizado.Length < 2)
        {
            buscando = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (isDemoMode)
        {
            sugerencias = ObtenerClientesDemoBusqueda()
                .Where(x =>
                    x.NombreCliente.Contains(filtroNormalizado, StringComparison.OrdinalIgnoreCase) ||
                    x.NumeroIdentificacion.Contains(filtroNormalizado, StringComparison.OrdinalIgnoreCase) ||
                    x.NumFactura.Contains(filtroNormalizado, StringComparison.OrdinalIgnoreCase))
                .Take(8)
                .ToList();
            buscando = false;
            return;
        }

        _cts = new System.Threading.CancellationTokenSource();
        var token = _cts.Token;
        var searchVersion = ++_searchVersion;

        buscando = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(180, token);
            var resultados = await AbonoService.GetFacturasCreditoPendientes(currentUserId, filtroNormalizado);
            token.ThrowIfCancellationRequested();

            if (searchVersion != _searchVersion)
                return;

            sugerencias = resultados
                .Take(8)
                .ToList();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            if (searchVersion != _searchVersion)
                return;

            mensajeError = $"No se pudo completar la búsqueda del cliente. {ex.Message}";
            sugerencias.Clear();
        }
        finally
        {
            if (searchVersion == _searchVersion)
            {
                buscando = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void CambiarFiltroCartera(FiltroCartera filtro)
    {
        filtroCarteraActual = filtro;
        OnCarteraFiltroChanged();
    }

    private string GetFiltroCarteraClase(FiltroCartera filtro) =>
        filtroCarteraActual == filtro ? "is-active" : string.Empty;

    private void OnCarteraFiltroChanged()
    {
        carteraPage = 1;
        ValidarFacturaSeleccionadaCartera();
    }

    private void LimpiarFiltrosCartera()
    {
        filtroCarteraActual = FiltroCartera.Todas;
        clienteFiltroCartera = "TODOS";
        vencimientoFiltroCartera = "TODOS";
        saldoFiltroCartera = "TODOS";
        OnCarteraFiltroChanged();
    }

    private void ValidarFacturaSeleccionadaCartera()
    {
        if (facturaCarteraSeleccionada is not null &&
            !CarteraPendienteVisibleLista.Any(x => x.IdFactura == facturaCarteraSeleccionada.IdFactura))
        {
            facturaCarteraSeleccionada = null;
        }
    }

    private bool CumpleBusquedaCartera(FacturaPendienteVM factura) =>
        string.IsNullOrWhiteSpace(filtroBusqueda) ||
        (factura.NombreCliente?.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (factura.NumeroIdentificacion?.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (factura.NumFactura?.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase) ?? false);

    private bool CumpleClienteFiltroCartera(FacturaPendienteVM factura) =>
        clienteFiltroCartera == "TODOS" ||
        (int.TryParse(clienteFiltroCartera, out var idCliente) && factura.IdCliente == idCliente);

    private bool CumpleVencimientoFiltroCartera(FacturaPendienteVM factura) =>
        vencimientoFiltroCartera switch
        {
            "CON_FECHA" => factura.FechaVencimiento.HasValue,
            "SIN_FECHA" => !factura.FechaVencimiento.HasValue,
            "ESTA_SEMANA" => factura.FechaVencimiento.HasValue &&
                             factura.FechaVencimiento.Value.Date >= DateTime.Today &&
                             factura.FechaVencimiento.Value.Date <= DateTime.Today.AddDays(7),
            _ => true
        };

    private bool CumpleSaldoFiltroCartera(FacturaPendienteVM factura) =>
        saldoFiltroCartera switch
        {
            "BAJO" => factura.SaldoPendiente <= 50m,
            "MEDIO" => factura.SaldoPendiente > 50m && factura.SaldoPendiente <= 200m,
            "ALTO" => factura.SaldoPendiente > 200m,
            _ => true
        };

    private void SeleccionarFacturaCartera(FacturaPendienteVM factura)
    {
        facturaCarteraSeleccionada = factura;
    }

    private async Task RegistrarAbonoDesdeFila(FacturaPendienteVM factura)
    {
        facturaCarteraSeleccionada = factura;
        await RegistrarAbonoDesdeCartera();
    }

    private async Task RegistrarAbonoDesdeCartera()
    {
        if (facturaCarteraSeleccionada is not null)
        {
            await SeleccionarCliente(facturaCarteraSeleccionada);
            await InvokeAsync(StateHasChanged);
            await JS.InvokeVoidAsync(
                "eval",
                "requestAnimationFrame(() => { document.querySelector('[data-tour=\"abonos.form\"]')?.scrollIntoView({ behavior: 'smooth', block: 'start' }); });");
        }
    }

    private async Task SeleccionarCliente(FacturaPendienteVM item)
    {
        facturaCarteraSeleccionada = item;

        if (isDemoMode)
        {
            AplicarClienteDemo(item.IdCliente);
            return;
        }

        _cts?.Cancel();
        _cts = null;
        buscando = false;
        clienteSeleccionado = item;
        filtroBusqueda = item.NombreCliente ?? "";
        sugerencias.Clear();
        mensajeError = null;
        usarSaldoAFavor = false;
        mostrarHistorial = false;
        mostrarDetalleSaldo = false;

        // EF Core no permite operaciones concurrentes en el mismo DbContext:
        // se deben ejecutar en secuencia, no con Task.WhenAll.
        facturasPendientes = await AbonoService.GetFacturasCreditoPendientes(currentUserId, item.IdCliente);
        facturasPage = 1;
        saldoAFavorCliente = await AbonoService.GetSaldoAFavor(currentUserId, item.IdCliente);
        detalleSaldoAFavor = await AbonoService.GetDetalleSaldoAFavor(currentUserId, item.IdCliente);
        abonosDistribucion.Clear();
        montoRecibido = 0;
        observacion = "";
        pasoActual = 2;
    }

    private static string FormatearFechaCartera(DateTime? fecha) =>
        fecha.HasValue ? fecha.Value.ToString("dd/MM/yyyy") : "-";

    private static string GetEstadoCartera(FacturaPendienteVM factura)
    {
        if (!factura.FechaVencimiento.HasValue)
            return "Vigente";

        var dias = (factura.FechaVencimiento.Value.Date - DateTime.Today).Days;
        return dias < 0 ? "Vencida" : dias <= 30 ? "Por vencer" : "Vigente";
    }

    private static string GetEstadoCarteraClase(FacturaPendienteVM factura) =>
        GetEstadoCartera(factura) switch
        {
            "Vencida" => "cartera-status is-overdue",
            "Por vencer" => "cartera-status is-warning",
            _ => "cartera-status is-current"
        };

    private static string GetResumenFacturaPendiente(FacturaPendienteVM factura)
    {
        var estado = GetEstadoCartera(factura);
        return factura.FechaVencimiento.HasValue
            ? $"{estado} · vence {factura.FechaVencimiento.Value:dd/MM/yyyy}"
            : $"Factura pendiente · emitida {FormatearFechaCartera(factura.FechaEmision)}";
    }

    private static int ObtenerDiasAntiguedad(FacturaPendienteVM factura, DateTime hoy)
    {
        var fechaBase = factura.FechaVencimiento ?? factura.FechaEmision ?? hoy;
        return Math.Max((hoy.Date - fechaBase.Date).Days, 0);
    }

    private static DateTime ObtenerFechaUrgenciaFactura(FacturaPendienteVM factura) =>
        factura.FechaVencimiento?.Date
        ?? factura.FechaEmision?.Date
        ?? DateTime.MaxValue.Date;

    private static SaldoBarraVM CrearBarraAntiguedad(string label, decimal valor, string color) =>
        new()
        {
            Label = label,
            Valor = valor,
            Color = color
        };

    private void CarteraPaginaAnterior()
    {
        if (carteraPage > 1)
            carteraPage--;
    }

    private void CarteraPaginaSiguiente()
    {
        if (carteraPage < CarteraTotalPaginas)
            carteraPage++;
    }

    private void FacturasPaginaAnterior()
    {
        if (facturasPage > 1)
            facturasPage--;
    }

    private void FacturasPaginaSiguiente()
    {
        if (facturasPage < FacturasTotalPaginas)
            facturasPage++;
    }

    private void AsignarMontoRapido(decimal monto)
    {
        montoRecibido = Math.Max(Math.Round(monto, 2), 0m);
        if (pasoActual <= 2)
            abonosDistribucion.Clear();
    }

    private decimal ObtenerDisponibleFactura(int idFactura)
    {
        var aplicadoActual = abonosDistribucion.TryGetValue(idFactura, out var actual) ? actual : 0m;
        return Math.Max(MontoDisponibleTotal - (TotalDistribuido - aplicadoActual), 0m);
    }

    private void AplicarDisponibleEnFactura(int idFactura)
    {
        var factura = facturasPendientes.FirstOrDefault(f => f.IdFactura == idFactura);
        if (factura == null)
            return;

        var aplicar = Math.Min(factura.SaldoPendiente, ObtenerDisponibleFactura(idFactura));
        if (aplicar > 0)
            abonosDistribucion[idFactura] = Math.Round(aplicar, 2);
        else
            abonosDistribucion.Remove(idFactura);
    }

    private void AplicarMaximoEnFactura(int idFactura)
    {
        var factura = facturasPendientes.FirstOrDefault(f => f.IdFactura == idFactura);
        if (factura == null)
            return;

        abonosDistribucion[idFactura] = Math.Round(factura.SaldoPendiente, 2);
    }

    private void LimpiarBusqueda()
    {
        _cts?.Cancel();
        _cts = null;
        buscando = false;
        _searchVersion++;
        filtroBusqueda = "";
        carteraPage = 1;
        sugerencias.Clear();
        ResetClienteSeleccionado();
    }

    private void ResetClienteSeleccionado()
    {
        facturaCarteraSeleccionada = null;
        clienteSeleccionado = null;
        facturasPendientes.Clear();
        facturasPage = 1;
        abonosDistribucion.Clear();
        montoRecibido = 0;
        observacion = "";
        saldoAFavorCliente = 0;
        detalleSaldoAFavor.Clear();
        historialSaldadas.Clear();
        mostrarHistorial = false;
        mostrarDetalleSaldo = false;
        usarSaldoAFavor = false;
        pasoActual = 1;
        mostrarConfirmacionFinal = false;
        confirmacionFinalAceptada = false;
    }

    /* ── Monto ── */
    private void OnMontoInput(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var val))
        {
            montoRecibido = val;
            if (pasoActual <= 2)
            {
                abonosDistribucion.Clear();
            }
        }
    }

    /* ── Distribución manual ── */
    private void OnAbonoChange(int idFactura, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var val) && val > 0)
            abonosDistribucion[idFactura] = val;
        else
            abonosDistribucion.Remove(idFactura);
    }

    private string GetMontoRecibidoInputValue() =>
        montoRecibido > 0
            ? montoRecibido.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
            : string.Empty;

    private string GetAbonoInputValue(int idFactura) =>
        abonosDistribucion.TryGetValue(idFactura, out var abono) && abono > 0
            ? abono.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
            : string.Empty;

    private void ClearAbono(int idFactura) => abonosDistribucion.Remove(idFactura);
    private void LimpiarDistribucion() => abonosDistribucion.Clear();

    private void DistribuirAutomatico()
    {
        abonosDistribucion.Clear();
        decimal saldo = MontoDisponibleTotal;
        foreach (var fac in facturasPendientes)
        {
            if (saldo <= 0) break;
            var aplicar = saldo >= fac.SaldoPendiente ? fac.SaldoPendiente : saldo;
            abonosDistribucion[fac.IdFactura] = aplicar;
            saldo -= aplicar;
        }
    }

    /* ── Historial ── */
    private async Task ToggleHistorial()
    {
        mostrarHistorial = !mostrarHistorial;

        if (isDemoMode)
            return;

        if (mostrarHistorial && !historialSaldadas.Any() && clienteSeleccionado != null)
        {
            cargandoHistorial = true;
            StateHasChanged();
            historialSaldadas = await AbonoService.GetHistorialFacturasSaldadas(currentUserId, clienteSeleccionado.IdCliente);
            cargandoHistorial = false;
        }
    }

    /* ── Procesar pago ── */
    private async Task ProcesarPago()
    {
        if (clienteSeleccionado == null || TotalDistribuido <= 0) return;

        if (isDemoMode)
        {
            mensajeExito = null;
            mensajeError = "Modo demo: el registro de abonos está bloqueado para no alterar información real.";
            mostrarConfirmacionFinal = false;
            confirmacionFinalAceptada = false;
            return;
        }

        cargando = true;
        mensajeExito = null;
        mensajeError = null;

        try
        {
            bool resultado = await AbonoService.RegistrarPagoManual(
                currentUserId,
                clienteSeleccionado.IdCliente,
                montoRecibido,
                abonosDistribucion,
                observacion,
                usarSaldoAFavor);

            if (resultado)
            {
                decimal saldoSobrante = SaldoRestante;
                string msgSaldo = saldoSobrante > 0
                    ? $" Se guardaron ${saldoSobrante:N2} como saldo a favor."
                    : "";

                mensajeExito = $"¡Abono registrado! Se distribuyeron ${TotalDistribuido:N2} entre {abonosDistribucion.Count} factura(s).{msgSaldo}";

                mostrarConfirmacionFinal = false;
                confirmacionFinalAceptada = false;
                abonosDistribucion.Clear();
                montoRecibido = 0;
                observacion = "";
                usarSaldoAFavor = false;
                mostrarHistorial = false;
                historialSaldadas.Clear();

                // Recargar datos del cliente (secuencial, no Task.WhenAll)
                
                clienteSeleccionado = null;
                filtroBusqueda = "";
                facturasPendientes.Clear();
                saldoAFavorCliente = 0;
                detalleSaldoAFavor.Clear();
                pasoActual = 1;
                LimpiarBusqueda();
                carteraPendiente = await AbonoService.GetFacturasCreditoPendientes(currentUserId);
            }
            else
            {
                mensajeError = "No se pudo procesar el abono. Intente de nuevo.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error interno: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task HandleTutorialAbonosClosedAsync(TutorialCloseResult result)
    {
        _mostrarTutorialAbonos = false;

        await TutorialStateService.SaveCloseProgressAsync(
            result.TutorialId,
            result.LastStepIndex,
            result.Completed,
            result.AutoShowDisabled);

        if (_tutorialLanzadoDesdeCatalogo)
        {
            _tutorialLanzadoDesdeCatalogo = false;
            Navigation.NavigateTo("/cuentas-por-cobrar", replace: true);
        }
    }

    private bool EsRutaDemoAbonos() =>
        Navigation.Uri.Contains("/demo/cuentas-por-cobrar", StringComparison.OrdinalIgnoreCase);

    private void CargarDemoAbonos()
    {
        currentUserId = 0;
        carteraPendiente =
        [
            .. ObtenerFacturasDemoCliente(1),
            .. ObtenerFacturasDemoCliente(2),
            .. ObtenerFacturasDemoCliente(3)
        ];

        for (var index = 0; index < carteraPendiente.Count; index++)
        {
            carteraPendiente[index].FechaEmision = DateTime.Today.AddDays(-(index + 4) * 3);
            carteraPendiente[index].FechaVencimiento = (index % 3) switch
            {
                0 => DateTime.Today.AddDays(-7 - index),
                1 => DateTime.Today.AddDays(8 + index),
                _ => DateTime.Today.AddDays(45 + index)
            };
        }

        AplicarClienteDemo(1);
        montoRecibido = 180m;
        observacion = "Transferencia recibida - demostración";
        usarSaldoAFavor = true;
        pasoActual = 3;
        abonosDistribucion = new Dictionary<int, decimal>
        {
            [101] = 120m,
            [102] = 75m
        };
        mostrarHistorial = true;
    }

    private void AplicarClienteDemo(int clienteId)
    {
        var cliente = ObtenerClientesDemoBusqueda().First(x => x.IdCliente == clienteId);
        clienteSeleccionado = cliente;
        filtroBusqueda = cliente.NombreCliente ?? string.Empty;
        sugerencias = ObtenerClientesDemoBusqueda();
        facturasPendientes = ObtenerFacturasDemoCliente(clienteId);
        saldoAFavorCliente = clienteId == 1 ? 35m : clienteId == 2 ? 18m : 0m;
        detalleSaldoAFavor = clienteId == 1
            ? new List<SaldoAFavorVM>
            {
                new() { IdAbonoMultiple = 1, FechaPago = DateTime.Today.AddDays(-12), ValorOriginal = 35m, SaldoDisponible = 35m, Observacion = "Saldo pendiente de abono anterior" }
            }
            : new List<SaldoAFavorVM>();
        historialSaldadas = ObtenerHistorialDemoCliente(clienteId);
        abonosDistribucion.Clear();
        mostrarHistorial = false;
        mostrarDetalleSaldo = false;
        usarSaldoAFavor = saldoAFavorCliente > 0;
        mensajeError = null;
        mensajeExito = null;
        confirmacionFinalAceptada = false;
        mostrarConfirmacionFinal = false;
        pasoActual = 2;
    }

