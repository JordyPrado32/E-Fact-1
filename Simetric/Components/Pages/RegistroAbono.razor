    private int DiasPromedioCobro =>
        carteraPendiente.Where(f => f.FechaEmision.HasValue).Any()
            ? (int)Math.Round(carteraPendiente.Where(f => f.FechaEmision.HasValue)
                .Average(f => (DateTime.Today - f.FechaEmision!.Value.Date).TotalDays))
            : 0;
    private IEnumerable<FacturaPendienteVM> FacturasVencidas =>
        carteraPendiente.Where(f => f.FechaVencimiento.HasValue && f.FechaVencimiento.Value.Date < DateTime.Today);
    private IEnumerable<FacturaPendienteVM> FacturasPorVencer =>
        carteraPendiente.Where(f => f.FechaVencimiento.HasValue &&
                                    f.FechaVencimiento.Value.Date >= DateTime.Today &&
                                    f.FechaVencimiento.Value.Date <= DateTime.Today.AddDays(30));
    private IEnumerable<FacturaPendienteVM> FacturasVigentes =>
        carteraPendiente.Where(f => !f.FechaVencimiento.HasValue || f.FechaVencimiento.Value.Date > DateTime.Today.AddDays(30));
    private decimal SaldoVencido => FacturasVencidas.Sum(f => f.SaldoPendiente);
    private decimal SaldoPorVencer => FacturasPorVencer.Sum(f => f.SaldoPendiente);
    private decimal SaldoVigente => Math.Max(SaldoCarteraTotal - SaldoVencido - SaldoPorVencer, 0m);
    private List<CarteraSegmento> CarteraSegmentos =>
    [
        CrearSegmentoCartera("Vencidas", SaldoVencido, "#ef5b62"),
        CrearSegmentoCartera("Por vencer", SaldoPorVencer, "#f5a623"),
        CrearSegmentoCartera("Vigentes", SaldoVigente, "#1eaa72")
    ];
    private IReadOnlyList<string> ResumenChartLabels => CarteraSegmentos.Select(x => x.Label).ToList();
    private IReadOnlyList<decimal> ResumenChartValues => CarteraSegmentos.Select(x => x.Valor).ToList();
    private IReadOnlyList<string> ResumenChartColors => CarteraSegmentos.Select(x => x.Color).ToList();
    private IReadOnlyList<string> AntiguedadChartLabels => AntiguedadSaldoBarras.Select(x => x.Label).ToList();
    private IReadOnlyList<decimal> AntiguedadChartValues => AntiguedadSaldoBarras.Select(x => x.Valor).ToList();
    private IReadOnlyList<string> AntiguedadChartColors => AntiguedadSaldoBarras.Select(x => x.Color).ToList();
