@page "/cuentas-por-cobrar"
@page "/demo/cuentas-por-cobrar"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Simetric.Services
@using Simetric.ViewModels
@using Simetric.Models
@using System.Globalization
@attribute [AllowAnonymous]
@inject AbonoService AbonoService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject TutorialRegistryService TutorialRegistry
@inject TutorialStateService TutorialStateService
@inject IJSRuntime JS

<PageTitle>Registro de Abonos | Numerica e-fact</PageTitle>

<div class="abono-shell" data-tour="abonos.page">
    <section class="abono-hero" data-tour="abonos.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Cuentas por cobrar</span>
            <h2>Registro de abonos</h2>
            <p>Avance paso a paso: seleccione el cliente, registre el pago, distribuya el valor y confirme el abono.</p>
        </div>
    </section>

    <section class="cartera-metrics" aria-label="Resumen de cuentas por cobrar">
        <article class="cartera-metric cartera-metric-primary">
            <div class="cartera-metric-head">
                <span>Saldo total por cobrar</span>
                <i class="ri-wallet-3-line"></i>
            </div>
            <strong>$@SaldoCarteraTotal.ToString("N2")</strong>
            <small>@TotalFacturasPendientes factura(s) pendientes</small>
            <div class="cartera-metric-line"></div>
        </article>
        <article class="cartera-metric cartera-metric-danger">
            <div class="cartera-metric-head">
                <span>Facturas vencidas</span>
                <i class="ri-alarm-warning-line"></i>
            </div>
            <strong>$@SaldoVencido.ToString("N2")</strong>
            <small>@FacturasVencidas.Count() requieren atención</small>
            <div class="cartera-metric-line"></div>
        </article>
        <article class="cartera-metric cartera-metric-info">
            <div class="cartera-metric-head">
                <span>Facturas por vencer</span>
                <i class="ri-timer-flash-line"></i>
            </div>
            <strong>$@SaldoPorVencer.ToString("N2")</strong>
            <small>@FacturasPorVencer.Count() dentro de 30 días</small>
            <div class="cartera-metric-line"></div>
        </article>
        <article class="cartera-metric cartera-metric-success">
            <div class="cartera-metric-head">
                <span>Clientes con saldo</span>
                <i class="ri-team-line"></i>
            </div>
            <strong>@ClientesConSaldo</strong>
            <small>Cartera activa visible</small>
            <div class="cartera-metric-line"></div>
        </article>
        <article class="cartera-metric cartera-metric-soft">
            <div class="cartera-metric-head">
            <span>Días promedio de cobro</span>
            <strong>@DiasPromedioCobro días</strong>
                <i class="ri-line-chart-line"></i>
            </div>
            <small>Promedio general</small>
            <div class="cartera-metric-line"></div>
        </article>
    </section>

    <section class="cartera-toolbar" aria-label="Filtros de cartera" data-tour="abonos.search">
        <div class="cartera-toolbar-heading">
            <div>
                <span class="section-kicker">Búsqueda y filtros</span>
                <h3>Encuentra tu cartera rápido</h3>
            </div>
            <small>Busca por cliente o factura y usa una sección completa de filtros para refinar tu vista.</small>
        </div>
        <div class="cartera-toolbar-main">
        <div class="cartera-search-box">
            <i class="ri-search-line"></i>
            <input placeholder="Buscar por cédula, RUC, nombre o factura..."
                   value="@filtroBusqueda"
                   @oninput="OnFiltroInput" />
        </div>
        <div class="cartera-toolbar-actions">
            <button type="button" class="ghost-btn ghost-btn-sm" @onclick="LimpiarBusqueda">
                <i class="ri-eraser-line"></i>
                <span>Limpiar</span>
            </button>
            <button type="button" class="confirm-btn confirm-btn-sm" @onclick="() => IrAlPaso(1)">
                <i class="ri-search-line"></i>
                <span>Buscar</span>
            </button>
        </div>
        </div>
        <div class="cartera-filter-panel cartera-filter-panel-full" data-tour="abonos.filters">
            <div class="cartera-filter-head">
                <div>
                    <span class="cartera-filter-label">Filtros</span>
                    <h4>Refina la cartera visible</h4>
                </div>
                <button type="button" class="ghost-btn ghost-btn-sm" @onclick="LimpiarFiltrosCartera">
                    <i class="ri-refresh-line"></i>
                    <span>Limpiar filtros</span>
                </button>
            </div>
            <div class="cartera-filter-grid">
                <div class="cartera-filter-block">
                    <span class="cartera-filter-label">Estado</span>
                    <div class="cartera-filter-row">
                        <button type="button" class="cartera-filter-chip @(GetFiltroCarteraClase(FiltroCartera.Todas))" @onclick="() => CambiarFiltroCartera(FiltroCartera.Todas)">
                            <span>Todas</span>
                            <strong>@carteraPendiente.Count</strong>
                        </button>
                        <button type="button" class="cartera-filter-chip @(GetFiltroCarteraClase(FiltroCartera.Vencidas))" @onclick="() => CambiarFiltroCartera(FiltroCartera.Vencidas)">
                            <span>Vencidas</span>
                            <strong>@FacturasVencidas.Count()</strong>
                        </button>
                        <button type="button" class="cartera-filter-chip @(GetFiltroCarteraClase(FiltroCartera.PorVencer))" @onclick="() => CambiarFiltroCartera(FiltroCartera.PorVencer)">
                            <span>Por vencer</span>
                            <strong>@FacturasPorVencer.Count()</strong>
                        </button>
                        <button type="button" class="cartera-filter-chip @(GetFiltroCarteraClase(FiltroCartera.Vigentes))" @onclick="() => CambiarFiltroCartera(FiltroCartera.Vigentes)">
                            <span>Vigentes</span>
                            <strong>@FacturasVigentes.Count()</strong>
                        </button>
                    </div>
                </div>

                <label class="cartera-filter-field">
                    <span>Cliente</span>
                    <select @bind="clienteFiltroCartera" @bind:after="OnCarteraFiltroChanged">
                        <option value="TODOS">Todos los clientes</option>
                        @foreach (var cliente in ClientesFiltroCartera)
                        {
                            <option value="@cliente.IdCliente.ToString()">@cliente.NombreCliente</option>
                        }
                    </select>
                </label>

                <label class="cartera-filter-field">
                    <span>Vencimiento</span>
                    <select @bind="vencimientoFiltroCartera" @bind:after="OnCarteraFiltroChanged">
                        <option value="TODOS">Todos</option>
                        <option value="CON_FECHA">Con fecha límite</option>
                        <option value="SIN_FECHA">Sin fecha límite</option>
                        <option value="ESTA_SEMANA">Vence esta semana</option>
                    </select>
                </label>

                <label class="cartera-filter-field">
                    <span>Saldo pendiente</span>
                    <select @bind="saldoFiltroCartera" @bind:after="OnCarteraFiltroChanged">
                        <option value="TODOS">Todos</option>
                        <option value="BAJO">Hasta $50</option>
                        <option value="MEDIO">$50 a $200</option>
                        <option value="ALTO">Más de $200</option>
                    </select>
                </label>
            </div>
        </div>
    </section>

    <section class="cartera-board" data-tour="abonos.table">
        <div class="cartera-board-main">
            <div class="cartera-board-head">
                <div>
                    <span class="section-kicker">Cartera pendiente</span>
                    <h3>Facturas por cobrar</h3>
                </div>
                <span class="cliente-badge">@CarteraPendienteVisibleLista.Count registros</span>
            </div>

            @if (!CarteraPendienteVisibleLista.Any())
            {
                <div class="cartera-empty">No hay facturas a crédito con saldo pendiente.</div>
            }
            else
            {
                <div class="cartera-table-wrap">
                    <table class="cartera-table">
                        <thead>
                            <tr>
                                <th>Factura</th>
                                <th>Cliente</th>
                                <th>Emisión</th>
                                <th>Vencimiento</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Saldo pendiente</th>
                                <th>Estado</th>
                                <th class="text-end">Abono</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var facturaPendiente in CarteraPendientePaginaActual)
                            {
                                <tr class="@(FacturaCarteraSeleccionada?.IdFactura == facturaPendiente.IdFactura ? "is-selected" : null)"
                                    @onclick="() => SeleccionarFacturaCartera(facturaPendiente)">
                                    <td><strong>@facturaPendiente.NumFactura</strong></td>
                                    <td>
                                        <strong>@facturaPendiente.NombreCliente</strong>
                                        <small>@facturaPendiente.NumeroIdentificacion</small>
                                    </td>
                                    <td>@FormatearFechaCartera(facturaPendiente.FechaEmision)</td>
                                    <td>@FormatearFechaCartera(facturaPendiente.FechaVencimiento)</td>
                                    <td class="text-end">$@facturaPendiente.TotalFactura.ToString("N2")</td>
                                    <td class="text-end cartera-balance">$@facturaPendiente.SaldoPendiente.ToString("N2")</td>
                                    <td><span class="@GetEstadoCarteraClase(facturaPendiente)">@GetEstadoCartera(facturaPendiente)</span></td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="cartera-row-action"
                                                data-tour="abonos.row-action"
                                                title="Registrar abono"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => RegistrarAbonoDesdeFila(facturaPendiente)">
                                            <i class="ri-hand-coin-line"></i>
                                            <span>Registrar</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="cartera-pagination">
                    <span>Mostrando @CarteraInicioRegistro-@CarteraFinRegistro de @CarteraPendienteVisibleLista.Count registros</span>
                    <div class="pagination-actions">
                        <button type="button" class="pagination-btn" disabled="@(CarteraPaginaActual <= 1)" @onclick="CarteraPaginaAnterior">Anterior</button>
                        <strong>@CarteraPaginaActual / @CarteraTotalPaginas</strong>
                        <button type="button" class="pagination-btn" disabled="@(CarteraPaginaActual >= CarteraTotalPaginas)" @onclick="CarteraPaginaSiguiente">Siguiente</button>
                    </div>
                </div>
            }
        </div>

        <aside class="cartera-board-side">
            <div class="cartera-cta-card">
                <div class="cartera-chart-head">
                    <span class="section-kicker">Factura seleccionada</span>
                    <h4>Resumen rápido</h4>
                </div>
                <p>
                    @(FacturaCarteraSeleccionada is null
                        ? "Usa el botón Registrar de cada fila en la tabla de cartera pendiente."
                        : $"Factura #{FacturaCarteraSeleccionada.NumFactura} · {FacturaCarteraSeleccionada.NombreCliente}")
                </p>
                @if (FacturaCarteraSeleccionada is not null)
                {
                    <div class="cartera-cta-meta">
                        <span>Saldo pendiente</span>
                        <strong>$@FacturaCarteraSeleccionada.SaldoPendiente.ToString("N2")</strong>
                        <small>@FormatearFechaCartera(FacturaCarteraSeleccionada.FechaEmision)</small>
                    </div>
                }
            </div>
            <div class="cartera-chart-card cartera-chart-ring">
                <div class="cartera-chart-head">
                    <span class="section-kicker">Resumen de cartera</span>
                    <h4>Distribución de saldos</h4>
                </div>
                <div class="cartera-chart-canvas-wrap cartera-chart-canvas-wrap-ring">
                    <canvas id="carteraResumenChart"></canvas>
                </div>
                <div class="cartera-legend">
                    <span><i class="is-danger"></i> Vencidas <strong>$@SaldoVencido.ToString("N2")</strong></span>
                    <span><i class="is-info"></i> Por vencer <strong>$@SaldoPorVencer.ToString("N2")</strong></span>
                    <span><i class="is-current"></i> Vigentes <strong>$@SaldoVigente.ToString("N2")</strong></span>
                </div>
            </div>
        </aside>
    </section>



    <section class="process-strip" aria-label="Flujo de registro de abono" data-tour="abonos.steps">
        <button type="button" class="process-step @GetPasoClase(1)" @onclick="() => IrAlPaso(1)">
            <span class="process-index">1</span>
            <div>
                <strong>Identificar cliente</strong>
                <small>Buscar por cedula, RUC o nombre</small>
            </div>
        </button>
        <button type="button" class="process-step @GetPasoClase(2)" @onclick="() => IrAlPaso(2)" disabled="@(clienteSeleccionado == null)">
            <span class="process-index">2</span>
            <div>
                <strong>Registrar pago</strong>
                <small>Monto recibido y observacion</small>
            </div>
        </button>
        <button type="button" class="process-step @GetPasoClase(3)" @onclick="() => IrAlPaso(3)" disabled="@(!PuedeIrADistribucion)">
            <span class="process-index">3</span>
            <div>
                <strong>Distribuir</strong>
                <small>Aplicar el abono por factura</small>
            </div>
        </button>
        <button type="button" class="process-step @GetPasoClase(4)" @onclick="() => IrAlPaso(4)" disabled="@(!PuedeProcesar)">
            <span class="process-index">4</span>
            <div>
                <strong>Confirmar</strong>
                <small>Registrar el abono final</small>
            </div>
        </button>
    </section>

    @if (isDemoMode)
    {
        <div class="notice-banner" style="background: rgba(0,107,181,0.08); color: #0f4c81; border-color: rgba(0,107,181,0.14);">
            <div class="notice-copy"><i class="ri-eye-line"></i><span>Modo demo: puedes recorrer el flujo y revisar la cartera, pero el registro final del abono está bloqueado.</span></div>
        </div>
    }

    @* ── ALERTAS ── *@
    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="notice-banner notice-success">
            <div class="notice-copy"><i class="ri-checkbox-circle-line"></i><span>@mensajeExito</span></div>
            <button type="button" class="notice-close" @onclick="() => mensajeExito = null"><i class="ri-close-line"></i></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="notice-banner notice-error">
            <div class="notice-copy"><i class="ri-error-warning-line"></i><span>@mensajeError</span></div>
            <button type="button" class="notice-close" @onclick="() => mensajeError = null"><i class="ri-close-line"></i></button>
        </div>
    }

    @* ── BANNER SALDO A FAVOR ── *@
    @if (saldoAFavorCliente > 0 && clienteSeleccionado != null && pasoActual >= 3)
    {
        <div class="notice-banner notice-credito">
            <div class="notice-copy">
                <i class="ri-wallet-3-line"></i>
                <span>
                    Este cliente tiene <strong>$@saldoAFavorCliente.ToString("N2") de saldo a favor</strong>
                    de pagos anteriores.
                </span>
            </div>
            <div class="credito-actions">
                @if (facturasPendientes.Any())
                {
                    <label class="toggle-label">
                        <input type="checkbox" @bind="usarSaldoAFavor" class="toggle-checkbox" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                        <span>Aplicar al pago</span>
                    </label>
                }
                <button type="button" class="ghost-btn ghost-btn-sm" @onclick="() => mostrarDetalleSaldo = !mostrarDetalleSaldo">
                    <i class="ri-information-line"></i>
                    <span>@(mostrarDetalleSaldo ? "Ocultar" : "Ver detalle")</span>
                </button>
            </div>
        </div>

        @if (mostrarDetalleSaldo && detalleSaldoAFavor.Any())
        {
            <div class="saldo-detalle-card">
                <h4><i class="ri-history-line"></i> Créditos disponibles</h4>
                <table class="saldo-table">
                    <thead>
                        <tr>
                            <th>Fecha pago</th>
                            <th>Valor original</th>
                            <th>Saldo disponible</th>
                            <th>Observación</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in detalleSaldoAFavor)
                        {
                            <tr>
                                <td data-label="Fecha pago">@s.FechaPago.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-mono" data-label="Valor original">$@s.ValorOriginal.ToString("N2")</td>
                                <td class="text-mono text-credito-cell" data-label="Saldo disponible">$@s.SaldoDisponible.ToString("N2")</td>
                                <td class="text-muted-cell" data-label="Observacion">@(s.Observacion ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    <div data-tour="abonos.form">
    @if (pasoActual == 1)
    {
        <section id="registro-abono-paso-2" class="abono-form-card step-card">
            <div class="form-card-head">
                <div>
                    <span class="section-kicker">Paso 1</span>
                    <h3>Buscar cliente</h3>
                    <p class="head-hint">Seleccione el cliente para cargar sus facturas pendientes.</p>
                </div>
                @if (clienteSeleccionado != null)
                {
                    <span class="cliente-badge">
                        <i class="ri-user-line"></i>
                        @clienteSeleccionado.NombreCliente
                    </span>
                }
            </div>

            <div class="step-workspace">
                <article class="work-subcard step-main-panel">
                    <div class="subcard-head">
                        <span class="subcard-icon"><i class="ri-user-search-line"></i></span>
                        <div>
                            <strong>Cliente</strong>
                            <small>Busque por cedula, RUC o razon social.</small>
                        </div>
                    </div>

                    <div class="form-field" data-tour="abonos.client-search">
                        <label class="field-label">Cédula / RUC / Nombre del cliente</label>
                        <div class="search-wrap">
                            <div class="search-input-group">
                                <i class="ri-search-2-line search-icon"></i>
                                 <input type="text"
                                        class="field-input search-input"
                                        value="@filtroBusqueda"
                                        @oninput="OnFiltroInput"
                                        placeholder="Escriba nombre, cédula o RUC..."
                                        autocomplete="off" />
                                @if (buscando)
                                {
                                    <i class="ri-loader-4-line search-spin"></i>
                                }
                                @if (!string.IsNullOrEmpty(filtroBusqueda))
                                {
                                    <button type="button" class="search-clear" @onclick="LimpiarBusqueda">
                                        <i class="ri-close-line"></i>
                                    </button>
                                }
                            </div>

                            @if (sugerencias.Any())
                            {
                                <ul class="suggestions-list">
                                    @foreach (var s in sugerencias)
                                    {
                                       <li class="suggestion-item" data-tour="abonos.client-option" @onclick="() => SeleccionarCliente(s)">
                                            <span class="suggestion-nombre">@s.NombreCliente</span>
                                            <span class="suggestion-meta">@s.NumeroIdentificacion · Factura @s.NumFactura · Saldo $@s.SaldoPendiente.ToString("N2")</span>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                        <small class="field-hint">Al seleccionar el cliente continuara al registro del monto.</small>
                    </div>

                    @if (clienteSeleccionado != null)
                    {
                        <div class="step-actions" data-tour="abonos.client-actions">
                            <button type="button" class="ghost-btn" @onclick="LimpiarBusqueda">
                                <i class="ri-refresh-line"></i>
                                <span>Cambiar cliente</span>
                            </button>
                            <button type="button" class="confirm-btn" @onclick="() => IrAlPaso(2)">
                                <i class="ri-arrow-right-line"></i>
                                <span>Continuar</span>
                            </button>
                        </div>
                    }
                </article>
                <aside class="step-side-panel">
                    <div class="step-side-card">
                        <span class="section-kicker">Resumen</span>
                        <h4>@(clienteSeleccionado != null ? "Cliente listo para continuar" : "Empiece por identificar al cliente")</h4>
                        <p>
                            @(clienteSeleccionado != null
                                ? "Ya puede pasar al registro del pago y luego distribuir el valor sobre sus facturas pendientes."
                                : "Use cedula, RUC o nombre comercial para encontrar rápidamente al cliente correcto.")
                        </p>
                    </div>

                    @if (clienteSeleccionado != null)
                    {
                        <div class="step-side-stats">
                            <article class="mini-stat-card">
                                <span>Cliente</span>
                                <strong>@clienteSeleccionado.NombreCliente</strong>
                            </article>
                            <article class="mini-stat-card">
                                <span>Facturas pendientes</span>
                                <strong>@facturasPendientes.Count</strong>
                            </article>
                            <article class="mini-stat-card">
                                <span>Saldo pendiente</span>
                                <strong>$@SaldoPendienteTotal.ToString("N2")</strong>
                            </article>
                        </div>
                    }
                    else
                    {
                        <div class="step-tip-list">
                            <div class="step-tip-item">
                                <i class="ri-search-eye-line"></i>
                                <span>Ingrese al menos 3 caracteres para activar la búsqueda.</span>
                            </div>
                            <div class="step-tip-item">
                                <i class="ri-user-follow-line"></i>
                                <span>Seleccione al cliente correcto desde la lista de coincidencias.</span>
                            </div>
                            <div class="step-tip-item">
                                <i class="ri-arrow-right-up-line"></i>
                                <span>Después podrá registrar el monto y distribuirlo por factura.</span>
                            </div>
                        </div>
                    }
                </aside>
            </div>
        </section>
    }

    @if (pasoActual == 2)
    {
        <section class="abono-form-card step-card">
        <div class="form-card-head">
            <div>
                <span class="section-kicker">Paso 2</span>
                <h3>Registrar monto recibido</h3>
                <p class="head-hint">Este valor sera el disponible para distribuir entre facturas.</p>
            </div>
            @if (clienteSeleccionado != null)
            {
                <span class="cliente-badge">
                    <i class="ri-user-line"></i>
                    @clienteSeleccionado.NombreCliente
                </span>
            }
        </div>

        <div class="step-workspace">
            <article class="work-subcard step-main-panel">
                <div class="subcard-head">
                    <span class="subcard-icon"><i class="ri-wallet-3-line"></i></span>
                    <div>
                        <strong>Pago recibido</strong>
                        <small>Luego ingresa el valor disponible para distribuir.</small>
                    </div>
                </div>

                <div class="payment-fields payment-fields-inline" data-tour="abonos.payment-fields">
                    <div class="form-field">
                        <label class="field-label">Monto total recibido</label>
                        <div class="amount-input-wrap">
                            <span class="amount-prefix">$</span>
                            <input type="number"
                                   step="0.01"
                                   min="0"
                                   class="field-input amount-input"
                                   value="@GetMontoRecibidoInputValue()"
                                   @onchange="OnMontoInput"
                                   placeholder="0.00"
                                   disabled="@(clienteSeleccionado == null)" />
                        </div>
                        @if (usarSaldoAFavor && saldoAFavorCliente > 0)
                        {
                            <small class="field-hint field-hint-credito">
                                <i class="ri-add-circle-line"></i>
                                Se añadirán hasta $@saldoAFavorCliente.ToString("N2") de saldo a favor
                            </small>
                        }
                        else
                        {
                            <small class="field-hint">Ingrese el valor exacto recibido del cliente.</small>
                        }
                        <div class="amount-shortcuts">
                            <button type="button" class="amount-chip" @onclick="() => AsignarMontoRapido(SaldoPendienteTotal * 0.5m)" disabled="@(clienteSeleccionado == null)">50%</button>
                            <button type="button" class="amount-chip" @onclick="() => AsignarMontoRapido(SaldoPendienteTotal)" disabled="@(clienteSeleccionado == null)">Saldo total</button>
                            <button type="button" class="amount-chip amount-chip-soft" @onclick="() => AsignarMontoRapido(0m)" disabled="@(clienteSeleccionado == null)">Limpiar</button>
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="field-label">Observación</label>
                        <input type="text"
                               class="field-input"
                               @bind="observacion"
                               placeholder="Ej. Pago efectivo, transferencia..."
                               disabled="@(clienteSeleccionado == null)" />
                    </div>
                </div>

                <div class="step-actions" data-tour="abonos.payment-actions">
                    <button type="button" class="ghost-btn" @onclick="() => IrAlPaso(1)">
                        <i class="ri-arrow-left-line"></i>
                        <span>Volver al cliente</span>
                    </button>
                    <button type="button" class="confirm-btn" @onclick="ContinuarADistribucion" disabled="@(!PuedeIrADistribucion)">
                        <i class="ri-arrow-right-line"></i>
                        <span>Continuar a facturas</span>
                    </button>
                </div>
            </article>
            <aside class="step-side-panel">
                <div class="step-side-card">
                    <span class="section-kicker">Preparación</span>
                    <h4>Monto listo para distribución</h4>
                    <p>Registre el valor recibido y una observación breve. Ese monto será la base del siguiente paso.</p>
                </div>

                <div class="step-side-stats">
                    <article class="mini-stat-card">
                        <span>Cliente</span>
                        <strong>@(clienteSeleccionado?.NombreCliente ?? "Sin seleccionar")</strong>
                    </article>
                    <article class="mini-stat-card">
                        <span>Saldo a favor</span>
                        <strong>$@saldoAFavorCliente.ToString("N2")</strong>
                    </article>
                    <article class="mini-stat-card">
                        <span>Monto disponible</span>
                        <strong>$@MontoDisponibleTotal.ToString("N2")</strong>
                    </article>
                </div>

                @if (saldoAFavorCliente > 0)
                {
                    <label class="toggle-label step-toggle-card">
                        <input type="checkbox" @bind="usarSaldoAFavor" class="toggle-checkbox" />
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                        <span>Usar saldo a favor en este abono</span>
                    </label>
                }
            </aside>
        </div>
    </section>
    }
    </div>

    @* ── PASO 3: DISTRIBUCIÓN POR FACTURA ── *@
    @if (pasoActual == 3 && facturasPendientes.Any())
    {
        <section class="abono-dist-card" data-tour="abonos.distribution">
            <div class="form-card-head">
                <div>
                    <span class="section-kicker">Paso 3</span>
                    <h3>Distribuir pago en facturas</h3>
                    <p class="head-hint">Ingrese cuánto desea abonar a cada factura. No es obligatorio cubrir el saldo completo.</p>
                </div>
                <div class="distribution-side-summary">
                    <span>Monto disponible</span>
                    <strong>$@MontoDisponibleTotal.ToString("N2")</strong>
                    <small>@facturasPendientes.Count factura(s) pendiente(s)</small>
                </div>
            </div>

            <div class="dist-toolbar" data-tour="abonos.distribution-actions">
                <button type="button" class="ghost-btn" @onclick="() => IrAlPaso(2)">
                    <i class="ri-arrow-left-line"></i>
                    <span>Editar monto</span>
                </button>
                <div class="dist-actions">
                    <button type="button" class="secondary-btn" @onclick="DistribuirAutomatico" disabled="@(MontoDisponibleTotal <= 0)">
                        <i class="ri-magic-line"></i>
                        <span>Distribuir automático</span>
                    </button>
                    <button type="button" class="ghost-btn" @onclick="LimpiarDistribucion">
                        <i class="ri-eraser-line"></i>
                        <span>Limpiar</span>
                    </button>
                </div>
            </div>

            <div class="distribution-overview">
                <article class="overview-card overview-card-primary">
                    <span>Monto disponible</span>
                    <strong>$@MontoDisponibleTotal.ToString("N2")</strong>
                    <small>Valor total listo para aplicar.</small>
                </article>
                <article class="overview-card overview-card-success">
                    <span>Total distribuido</span>
                    <strong>$@TotalDistribuido.ToString("N2")</strong>
                    <small>@FacturasConAbonoCount factura(s) con abono registrado.</small>
                </article>
                <article class="overview-card @(SaldoRestante < 0 ? "overview-card-danger" : SaldoRestante > 0 ? "overview-card-warn" : "overview-card-neutral")">
                    <span>Saldo sin asignar</span>
                    <strong>$@SaldoRestante.ToString("N2")</strong>
                    <small>@GetSaldoRestanteDescripcion()</small>
                </article>
                <article class="overview-card overview-card-soft">
                    <span>Facturas por revisar</span>
                    <strong>@facturasPendientes.Count</strong>
                    <small>@FacturasPendientesConSaldoTexto</small>
                </article>
            </div>

            <div class="distribution-workbench">
                <div>
                    <span class="section-kicker">Aplicación guiada</span>
                    <h4>Reparta el pago y confirme el resultado antes de registrar.</h4>
                    <p>Puede distribuirlo automáticamente y luego ajustar cada factura, o capturarlo manualmente desde cero.</p>
                </div>
                <div class="distribution-workbench-note">
                    <i class="ri-lightbulb-flash-line"></i>
                    <span>Si queda saldo libre, se guardará como crédito para el siguiente movimiento del cliente.</span>
                </div>
            </div>

            <div class="invoice-section-head">
                <div>
                    <h4>Facturas pendientes a aplicar</h4>
                    <p>Mostrando @FacturasPendientesPaginaActual.Count() de @facturasPendientes.Count factura(s).</p>
                </div>
                <label class="date-filter-box">
                    <span>Orden</span>
                    <select class="date-filter-input" @bind="OrdenFacturasPendientesActual">
                        <option value="@OrdenFacturasPendientes.MasUrgentes">Mas urgentes primero</option>
                        <option value="@OrdenFacturasPendientes.MasRecientes">Mas recientes primero</option>
                    </select>
                </label>
            </div>

            <div class="invoice-list-shell" data-tour="abonos.invoice-list">
                <div class="invoice-list-head" aria-hidden="true">
                    <span>Factura</span>
                    <span>Total</span>
                    <span>Abonado</span>
                    <span>Saldo</span>
                    <span>Abono a aplicar</span>
                </div>

            <div class="invoice-list">
                @foreach (var fac in FacturasPendientesPaginaActual)
                {
                    var abono = abonosDistribucion.ContainsKey(fac.IdFactura) ? abonosDistribucion[fac.IdFactura] : 0m;
                    var abonadoConEsteAbono = fac.TotalAbonado + abono;
                    var porcentaje = fac.TotalFactura > 0 ? (double)(abonadoConEsteAbono / fac.TotalFactura * 100) : 0;
                    porcentaje = Math.Min(porcentaje, 100);
                    var excede = abono > fac.SaldoPendiente;

                    <article class="invoice-row @(abono > 0 ? "is-active" : "") @(excede ? "has-error" : "")" data-tour="abonos.invoice-row">
                        <div class="invoice-col invoice-col-doc">
                            <div class="invoice-title">
                                <span class="num-pill">#@fac.NumFactura</span>
                                <small>@GetResumenFacturaPendiente(fac)</small>
                            </div>

                            <div class="invoice-doc-progress">
                                <div class="progress-labels">
                                    <span class="progress-amt">$@abonadoConEsteAbono.ToString("N2") / $@fac.TotalFactura.ToString("N2")</span>
                                    <span class="progress-pct @(porcentaje >= 100 ? "pct-full" : porcentaje > 60 ? "pct-mid" : "pct-low")">@porcentaje.ToString("0")%</span>
                                </div>
                                <div class="mini-progress">
                                    <div class="mini-bar @(porcentaje >= 100 ? "bar-full" : porcentaje > 60 ? "bar-mid" : "bar-low")"
                                         style="width: @porcentaje.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="invoice-col invoice-col-value" data-label="Total factura">
                            <span class="invoice-col-label">Total</span>
                            <strong>$@fac.TotalFactura.ToString("N2")</strong>
                        </div>

                        <div class="invoice-col invoice-col-value" data-label="Ya abonado">
                            <span class="invoice-col-label">Abonado</span>
                            <strong class="text-muted-cell">$@fac.TotalAbonado.ToString("N2")</strong>
                        </div>

                        <div class="invoice-col invoice-col-value invoice-col-balance" data-label="Saldo pendiente">
                            <span class="invoice-col-label">Saldo</span>
                            <strong>$@fac.SaldoPendiente.ToString("N2")</strong>
                        </div>

                        <div class="invoice-col invoice-col-apply">
                            <label class="field-label">Abono a aplicar</label>
                            <div class="abono-input-wrap @(excede ? "input-excede" : "")">
                                <span class="abono-prefix">$</span>
                                <input type="number"
                                       step="0.01"
                                       min="0"
                                       class="abono-input"
                                       @key="@($"abono-{fac.IdFactura}-{abono.ToString(System.Globalization.CultureInfo.InvariantCulture)}")"
                                       value="@GetAbonoInputValue(fac.IdFactura)"
                                       @oninput="e => OnAbonoChange(fac.IdFactura, e)"
                                       placeholder="0.00" />
                                @if (abono > 0)
                                {
                                    <button type="button" class="abono-clear" @onclick="() => ClearAbono(fac.IdFactura)" title="Quitar">
                                        <i class="ri-close-line"></i>
                                    </button>
                                }
                            </div>
                            @if (excede)
                            {
                                <small class="excede-hint">Supera el saldo ($@fac.SaldoPendiente.ToString("N2"))</small>
                            }
                            <div class="abono-quick-actions">
                                <button type="button" class="mini-action-btn" @onclick="() => AplicarDisponibleEnFactura(fac.IdFactura)">Disponible</button>
                                <button type="button" class="mini-action-btn mini-action-btn-primary" @onclick="() => AplicarMaximoEnFactura(fac.IdFactura)">Maximo</button>
                            </div>
                        </div>
                    </article>
                }
            </div>
            </div>

            <div class="cartera-pagination cartera-pagination-invoice">
                <span>Mostrando @FacturasInicioRegistro-@FacturasFinRegistro de @facturasPendientes.Count factura(s)</span>
                <div class="pagination-actions">
                    <button type="button" class="pagination-btn" disabled="@(FacturasPaginaActual <= 1)" @onclick="FacturasPaginaAnterior">Anterior</button>
                    <strong>@FacturasPaginaActual / @FacturasTotalPaginas</strong>
                    <button type="button" class="pagination-btn" disabled="@(FacturasPaginaActual >= FacturasTotalPaginas)" @onclick="FacturasPaginaSiguiente">Siguiente</button>
                </div>
            </div>

            <div class="confirm-panel distribution-summary distribution-summary-split">
                <div class="dist-resumen dist-resumen-compact">
                    <div class="resumen-item">
                        <span>Monto recibido</span>
                        <strong>$@montoRecibido.ToString("N2")</strong>
                    </div>
                    @if (usarSaldoAFavor && saldoAFavorCliente > 0)
                    {
                        <div class="resumen-sep">+</div>
                        <div class="resumen-item resumen-credito">
                            <span>Saldo a favor</span>
                            <strong>$@saldoAFavorCliente.ToString("N2")</strong>
                        </div>
                    }
                    <div class="resumen-sep">—</div>
                    <div class="resumen-item">
                        <span>Total distribuido</span>
                        <strong>$@TotalDistribuido.ToString("N2")</strong>
                    </div>
                    <div class="resumen-sep">=</div>
                    <div class="resumen-item @(SaldoRestante < 0 ? "resumen-danger" : SaldoRestante > 0 ? "resumen-warn" : "resumen-ok")">
                        <span>Saldo sin asignar</span>
                        <strong>$@SaldoRestante.ToString("N2")</strong>
                    </div>
                    @if (SaldoRestante > 0)
                    {
                        <div class="resumen-note">
                            <i class="ri-information-line"></i>
                            <span>Este saldo quedará disponible como crédito para el próximo pago.</span>
                        </div>
                    }
                </div>

                <div class="distribution-summary-actions" data-tour="abonos.review-action">
                    <button type="button"
                            class="confirm-btn"
                            @onclick="() => IrAlPaso(4)"
                            disabled="@(!PuedeProcesar || cargando)">
                        <i class="ri-arrow-right-line"></i>
                        <span>Revisar confirmación</span>
                    </button>
                </div>
            </div>
        </section>
    }
    else if (pasoActual == 3 && clienteSeleccionado != null && !buscando)
    {
        <section class="abono-dist-card state-empty">
            <div class="empty-icon"><i class="ri-inbox-line"></i></div>
            <h3>Sin facturas pendientes</h3>
            <p>El cliente seleccionado no tiene facturas a crédito con saldo pendiente.</p>
        </section>
    }

    @if (pasoActual == 4)
    {
        <section class="abono-dist-card" data-tour="abonos.review">
            <div class="form-card-head">
                <div>
                    <span class="section-kicker">Paso 4</span>
                    <h3>Confirmar registro de abono</h3>
                    <p class="head-hint">Revise el resumen antes de abrir la confirmación final.</p>
                </div>
                <span class="cliente-badge">
                    <i class="ri-user-line"></i>
                    @clienteSeleccionado?.NombreCliente
                </span>
            </div>

            <div class="confirm-review">
                <div class="step-workspace confirm-workspace">
                    <div class="step-main-panel confirm-main-panel">
                        <div class="dist-resumen">
                            <div class="resumen-item">
                                <span>Monto recibido</span>
                                <strong>$@montoRecibido.ToString("N2")</strong>
                            </div>
                            @if (usarSaldoAFavor && saldoAFavorCliente > 0)
                            {
                                <div class="resumen-item resumen-credito">
                                    <span>Saldo a favor</span>
                                    <strong>$@saldoAFavorCliente.ToString("N2")</strong>
                                </div>
                            }
                            <div class="resumen-item">
                                <span>Total distribuido</span>
                                <strong>$@TotalDistribuido.ToString("N2")</strong>
                            </div>
                            <div class="resumen-item @(SaldoRestante < 0 ? "resumen-danger" : SaldoRestante > 0 ? "resumen-warn" : "resumen-ok")">
                                <span>Saldo sin asignar</span>
                                <strong>$@SaldoRestante.ToString("N2")</strong>
                            </div>
                            <div class="resumen-item">
                                <span>Facturas afectadas</span>
                                <strong>@abonosDistribucion.Count</strong>
                            </div>
                        </div>
                    </div>

                    <aside class="step-side-panel confirm-side-panel">
                        <div class="step-side-card">
                            <span class="section-kicker">Detalle final</span>
                            <h4>Facturas incluidas en el abono</h4>
                            <p>Revise los valores por factura antes de confirmar el registro definitivo.</p>
                        </div>

                        <div class="selected-invoices selected-invoices-compact">
                            @foreach (var item in FacturasConAbono)
                            {
                                <article class="selected-invoice-item">
                                    <span class="num-pill">#@item.Factura.NumFactura</span>
                                    <strong>$@item.Abono.ToString("N2")</strong>
                                </article>
                            }
                        </div>
                    </aside>
                </div>

                <div class="step-actions">
                    <button type="button" class="ghost-btn" @onclick="() => IrAlPaso(3)">
                        <i class="ri-arrow-left-line"></i>
                        <span>Volver a distribución</span>
                    </button>
                    <button type="button"
                            class="confirm-btn"
                            data-tour="abonos.confirm"
                            @onclick="AbrirConfirmacionFinal"
                            disabled="@(!PuedeProcesar || cargando)">
                        <i class="ri-check-double-line"></i>
                        <span>Confirmar y registrar</span>
                    </button>
                </div>
            </div>
        </section>
    }


    <section class="cartera-insights" aria-label="Analitica de cartera">
        <article class="cartera-chart-card cartera-insight-card">
            <div class="cartera-chart-head">
                <span class="section-kicker">Antiguedad de saldos</span>
                <h4>Grafico estadistico</h4>
            </div>
            <div class="cartera-chart-canvas-wrap">
                <canvas id="carteraAntiguedadChart"></canvas>
            </div>
        </article>

        <article class="cartera-chart-card cartera-insight-card">
            <div class="cartera-chart-head">
                <span class="section-kicker">Top 5 clientes</span>
                <h4>Mayor saldo pendiente</h4>
            </div>
            <div class="cartera-chart-canvas-wrap cartera-chart-canvas-wrap-tall">
                <canvas id="carteraTopClientesChart"></canvas>
            </div>
            <div class="top-client-list top-client-list-large top-client-list-compact">
                @foreach (var cliente in TopClientesSaldo)
                {
                    <div class="top-client-item">
                        <div class="top-client-rank">@cliente.Rank</div>
                        <div class="top-client-meta">
                            <strong>@cliente.NombreCliente</strong>
                            <small>@cliente.Identificacion</small>
                        </div>
                        <strong class="top-client-value">$@cliente.Saldo.ToString("N2")</strong>
                    </div>
                }
            </div>
        </article>
    </section>

    @* ── HISTORIAL DE FACTURAS SALDADAS ── *@
    @if (clienteSeleccionado != null && pasoActual >= 3)
    {
        <section class="abono-dist-card historial-card">
            <div class="form-card-head">
                <div>
                    <span class="section-kicker">Historial del cliente</span>
                    <h3>Facturas completamente saldadas</h3>
                    <p class="head-hint">Facturas que ya han sido pagadas en su totalidad.</p>
                </div>
                <button type="button" class="ghost-btn" @onclick="ToggleHistorial">
                    <i class="@(mostrarHistorial ? "ri-eye-off-line" : "ri-eye-line")"></i>
                    <span>@(mostrarHistorial ? "Ocultar" : "Ver historial")</span>
                </button>
            </div>

            @if (mostrarHistorial)
            {
                @if (cargandoHistorial)
                {
                    <div class="historial-loading">
                        <i class="ri-loader-4-line spin"></i>
                        <span>Cargando historial...</span>
                    </div>
                }
                else if (!historialSaldadas.Any())
                {
                    <div class="historial-empty">
                        <i class="ri-file-list-3-line"></i>
                        <span>No hay facturas completamente saldadas aún.</span>
                    </div>
                }
                else
                {
                    <div class="historial-summary">
                        <span class="historial-badge">
                            <i class="ri-checkbox-circle-fill"></i>
                            @historialSaldadas.Count factura(s) saldada(s)
                        </span>
                        <span class="historial-total">
                            Total cobrado: <strong>$@historialSaldadas.Sum(x => x.TotalFactura).ToString("N2")</strong>
                        </span>
                    </div>

                    <div class="history-list">
                        @foreach (var h in historialSaldadas)
                        {
                            <article class="history-item">
                                <div class="history-main">
                                    <span class="num-pill num-pill-saldada">#@h.NumFactura</span>
                                    <span class="status-pill status-saldada">
                                        <i class="ri-checkbox-circle-fill"></i> Saldada
                                    </span>
                                </div>
                                <div class="invoice-values history-values">
                                    <div class="value-box">
                                        <span>Total factura</span>
                                        <strong>$@h.TotalFactura.ToString("N2")</strong>
                                    </div>
                                    <div class="value-box value-box-success">
                                        <span>Total cobrado</span>
                                        <strong>$@h.TotalAbonado.ToString("N2")</strong>
                                    </div>
                                    <div class="value-box value-box-muted">
                                        <span>Fecha saldada</span>
                                        <strong>@h.FechaSaldada.ToString("dd/MM/yyyy")</strong>
                                    </div>
                                </div>
                                <div class="progress-col history-progress">
                                    <div class="progress-labels">
                                        <span class="progress-amt">$@h.TotalAbonado.ToString("N2") / $@h.TotalFactura.ToString("N2")</span>
                                        <span class="progress-pct pct-full">100%</span>
                                    </div>
                                    <div class="mini-progress">
                                        <div class="mini-bar bar-full" style="width: 100%"></div>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            }
        </section>
    }

</div>

@if (_tutorialAbonos is not null)
{
    <AppTutorialOverlay Definition="_tutorialAbonos"
                        Visible="_mostrarTutorialAbonos"
                        OnClosed="HandleTutorialAbonosClosedAsync" />
}

@if (mostrarConfirmacionFinal)
{
    <div class="abono-modal-backdrop" @onclick="CerrarConfirmacionFinal"></div>
    <section class="abono-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="confirmarAbonoTitulo">
        <div class="confirm-modal-head">
            <span class="section-kicker">Confirmacion final</span>
            <h3 id="confirmarAbonoTitulo">¿Registrar este abono?</h3>
            <button type="button" class="notice-close" @onclick="CerrarConfirmacionFinal" disabled="@cargando">
                <i class="ri-close-line"></i>
            </button>
        </div>

        <div class="confirm-modal-body">
            <p>Se registrara un abono de <strong>$@TotalDistribuido.ToString("N2")</strong> para <strong>@clienteSeleccionado?.NombreCliente</strong>.</p>
            <div class="modal-summary-grid">
                <div>
                    <span>Monto disponible</span>
                    <strong>$@MontoDisponibleTotal.ToString("N2")</strong>
                </div>
                <div>
                    <span>Distribuido</span>
                    <strong>$@TotalDistribuido.ToString("N2")</strong>
                </div>
                <div>
                    <span>Saldo sin asignar</span>
                    <strong>$@SaldoRestante.ToString("N2")</strong>
                </div>
            </div>
            <label class="final-check">
                <input type="checkbox" @bind="confirmacionFinalAceptada" disabled="@cargando" />
                <span>Confirmo que revise el cliente, el monto y la distribucion por factura.</span>
            </label>
        </div>

        <div class="confirm-modal-actions">
            <button type="button" class="ghost-btn" @onclick="CerrarConfirmacionFinal" disabled="@cargando">Cancelar</button>
            <button type="button" class="confirm-btn" @onclick="ProcesarPagoConfirmado" disabled="@(!confirmacionFinalAceptada || cargando)">
                @if (cargando)
                {
                    <i class="ri-loader-4-line spin"></i>
                    <span>Procesando...</span>
                }
                else
                {
                    <i class="ri-check-line"></i>
                    <span>Si, registrar abono</span>
                }
            </button>
        </div>
    </section>
}

<style>
/* ── SHELL ── */
.abono-shell {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    padding-bottom: 5.5rem;
}
.abono-shell > .process-strip { order: 0; }
.abono-shell > [data-tour="abonos.form"] { order: 0; }
.abono-shell > .cartera-insights { order: 0; }

/* ── HERO ── */
.abono-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    padding: 1.15rem;
    border: 1px solid var(--n-border);
    border-radius: 24px;
    background:
        radial-gradient(circle at top left, rgba(0,107,181,0.14), transparent 34%),
        linear-gradient(145deg, rgba(255,255,255,0.98), rgba(246,250,254,0.96));
    box-shadow: var(--n-shell-shadow, 0 8px 32px rgba(15,23,42,0.07));
}
.hero-copy { display: flex; flex-direction: column; justify-content: center; }
.hero-snapshot { display: grid; gap: .7rem; align-content: start; }
.snapshot-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .7rem; }
.snapshot-card {
    padding: .82rem .9rem;
    border-radius: 18px;
    border: 1px solid #dce8f2;
    background: #fff;
    box-shadow: 0 8px 18px rgba(15, 23, 42, .04);
    display: grid;
    gap: .15rem;
    min-width: 0;
}
.snapshot-card span {
    color: #61788e;
    font-size: .62rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.snapshot-card strong { color: #17324a; font-size: 1.15rem; }
.snapshot-card small { color: #7b8fa1; font-size: .65rem; }
.snapshot-card-primary { border-top: 3px solid #1687d9; }
.snapshot-card-danger { border-top: 3px solid #ef5b62; }
.snapshot-card-info { border-top: 3px solid #f5a623; }
.snapshot-card-success { border-top: 3px solid #1eaa72; }
.snapshot-card-soft { border-top: 3px solid #8e7aff; }
.hero-eyebrow {
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--n-blue, #006bb5);
}
.abono-hero h2 {
    margin: 0.5rem 0 0.7rem;
    font-size: 1.72rem; line-height: 1.05;
    letter-spacing: -0.04em; color: var(--n-text, #0f172a);
}
.abono-hero p { margin: 0; color: var(--n-text-muted, #64748b); font-size: 0.93rem; line-height: 1.7; }

.cartera-metrics {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: .65rem;
}
.cartera-metric {
    min-width: 0;
    position: relative;
    overflow: hidden;
    padding: 1rem 1rem .95rem;
    border: 1px solid color-mix(in srgb, var(--stat-accent, #14b8a6) 24%, #e7edf4);
    border-radius: 16px;
    background:
        radial-gradient(circle at 92% 8%, color-mix(in srgb, var(--stat-accent, #14b8a6) 18%, transparent), transparent 38%),
        linear-gradient(145deg, #ffffff 0%, color-mix(in srgb, var(--stat-soft, #ecfeff) 45%, #ffffff) 100%);
    box-shadow:
        0 18px 34px rgba(15, 23, 42, .08),
        inset 0 1px 0 rgba(255, 255, 255, .78);
    isolation: isolate;
    display: grid;
    gap: .24rem;
    transition: transform .22s ease, box-shadow .22s ease;
}
.cartera-metric:hover { transform: translateY(-4px); box-shadow: 0 18px 32px rgba(15, 23, 42, .10); }
.cartera-metric::after {
    content: "";
    position: absolute;
    right: -18px;
    bottom: -28px;
    width: 86px;
    height: 86px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--stat-accent, #14b8a6) 10%, transparent);
    z-index: -1;
}
.cartera-metric-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .7rem;
}
.cartera-metric-head i {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--stat-accent, #14b8a6) 14%, #ffffff);
    color: var(--stat-accent, #14b8a6) !important;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--stat-accent, #14b8a6) 18%, #ffffff);
}
.cartera-metric-line {
    width: 72px;
    height: 4px;
    border-radius: 999px;
    background: currentColor;
    opacity: .18;
}
.cartera-metric span {
    color: #6b8095;
    font-size: .73rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
}
.cartera-metric strong {
    color: #17324a;
    font-size: 1.3rem;
    font-weight: 700;
    margin-top: .4rem;
}
.cartera-metric small {
    color: #7b8fa1;
    font-size: .64rem;
}
.cartera-metric-primary {
    --stat-accent: #006bb5;
    --stat-soft: #f4f9ff;
    border-top: 4px solid var(--stat-accent);
}
.cartera-metric-danger {
    --stat-accent: #ef4444;
    --stat-soft: #fef2f2;
    border-top: 4px solid var(--stat-accent);
}
.cartera-metric-info {
    --stat-accent: #f59e0b;
    --stat-soft: #fffbeb;
    border-top: 4px solid var(--stat-accent);
}
.cartera-metric-success {
    --stat-accent: #10b981;
    --stat-soft: #ecfdf5;
    border-top: 4px solid var(--stat-accent);
}
.cartera-metric-soft {
    --stat-accent: #8b5cf6;
    --stat-soft: #f5f3ff;
    border-top: 4px solid var(--stat-accent);
}

.cartera-toolbar {
    display: grid;
    gap: .75rem;
    padding: 1rem 1.05rem;
    border: 1px solid #dce8f2;
    border-radius: 22px;
