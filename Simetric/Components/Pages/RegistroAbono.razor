    font-size: 1rem;
}
.cartera-toolbar-heading small {
    color: #6f8498;
    font-size: .72rem;
}
.cartera-toolbar-main {
    display: flex;
    align-items: center;
    gap: .75rem;
}
.cartera-search-box {
    min-width: 0;
    flex: 1;
    display: flex;
    align-items: center;
    gap: .7rem;
    padding: .82rem .95rem;
    border: 1px solid #dce8f2;
    border-radius: 16px;
    background: #f9fbfe;
}
.cartera-search-box i { color: #7a8ea1; font-size: 1rem; }
.cartera-search-box input {
    border: 0;
