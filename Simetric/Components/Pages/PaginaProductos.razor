    private async Task ExportarProductosCsvAsync()
    {
        var productosExportar = await Http.GetFromJsonAsync<List<ProductoDto>>($"api/productos?userId={usuarioLogueadoId}") ?? productos;

        if (productosExportar.Count == 0)
        {
            mensaje = "No se encontraron productos para exportar.";
            return;
        }

        var sb = new StringBuilder();
        sb.AppendLine("Codigo;Nombre;Tipo;PrecioBase;Precio2;Precio3;Categoria;Subcategoria;AplicaIVA;TarifaIVA;Observacion");
        
        foreach (var p in OrdenarProductosClasificados(productosExportar))
        {
            var codigo = p.CodigoPrincipal ?? string.Empty;
            var nombre = p.Nombre ?? string.Empty;
            var tipo = p.TipoCompravena ?? string.Empty;
            var precioBase = p.ValorUnitario?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            var precio2 = p.Precio2?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            var precio3 = p.Precio3?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;
            
            var cat = p.TipoProducto.HasValue
                ? tiposProducto.FirstOrDefault(t => t.Idtipoproducto == p.TipoProducto.Value)?.Descripcion ?? string.Empty
                : string.Empty;
                
            var subcat = p.Idsubtipo.HasValue
                ? subtiposProducto.FirstOrDefault(s => s.Idsubtipo == p.Idsubtipo.Value)?.Descripcion ?? string.Empty
                : string.Empty;
                
            var aplicaIva = p.Codigoimpuesto == "2" ? "SI" : "NO";
            
            var ivaObj = porcentajesIva.FirstOrDefault(i => i.Codigo == p.Porcentajeimpuesto);
            var tarifaIva = ivaObj != null ? ivaObj.Valor : (p.Porcentajeimpuesto ?? string.Empty);
            
            var observacion = p.Observacion ?? string.Empty;

            codigo = EscapeCsvField(codigo, forceExcelText: true);
            nombre = EscapeCsvField(nombre);
            observacion = EscapeCsvField(observacion);
            cat = EscapeCsvField(cat);
            subcat = EscapeCsvField(subcat);
            
            sb.AppendLine($"{codigo};{nombre};{tipo};{precioBase};{precio2};{precio3};{cat};{subcat};{aplicaIva};{tarifaIva};{observacion}");
        }

        await JS.InvokeVoidAsync(
            "numericaUi.downloadTextFile",
            $"Productos_{DateTime.Now:yyyyMMdd_HHmmss}.csv",
            "\uFEFF" + sb.ToString(),
            "text/csv;charset=utf-8"
        );
    }

    private static string EscapeCsvField(string field, bool forceExcelText = false)
    {
        if (string.IsNullOrEmpty(field)) return forceExcelText ? "=\"\"" : string.Empty;
        if (forceExcelText)
        {
            var cleanField = field.Replace("\"", "\"\"");
            return $"=\"{cleanField}\"";
        }
        if (field.Contains(";") || field.Contains("\"") || field.Contains("\n") || field.Contains("\r"))
        {
            return "\"" + field.Replace("\"", "\"\"") + "\"";
        }
        return field;
    }


    private async Task ImportarProductosAsync(InputFileChangeEventArgs e)
    {
        if (isDemoMode)
        {
            mensajeImportacion = "La importación está bloqueada en modo demo.";
            erroresImportacion = 1;
            return;
        }

        var archivo = e.File;
        if (archivo is null)
            return;

        if (!string.Equals(Path.GetExtension(archivo.Name), ".csv", StringComparison.OrdinalIgnoreCase))
        {
            mensajeImportacion = "Selecciona el modelo guardado en formato CSV.";
            erroresImportacion = 1;
            return;
        }

        const long maxSize = 4 * 1024 * 1024;
        if (archivo.Size > maxSize)
        {
            mensajeImportacion = "El archivo supera el máximo permitido de 4 MB.";
            erroresImportacion = 1;
            return;
        }

        importandoProductos = true;
        erroresImportacion = 0;
        mensajeImportacion = "Procesando archivo...";
        StateHasChanged();

        try
        {
            using var stream = archivo.OpenReadStream(maxSize);
            using var reader = new StreamReader(stream, Encoding.UTF8, true);
            var contenido = await reader.ReadToEndAsync();
            var lineas = contenido.Replace("\r\n", "\n").Split('\n', StringSplitOptions.RemoveEmptyEntries);

            if (lineas.Length < 2)
            {
                mensajeImportacion = "El archivo no contiene productos para importar.";
                erroresImportacion = 1;
                importandoProductos = false;
                return;
            }

            categoriasFaltantes.Clear();
            subcategoriasFaltantes.Clear();
            filasImportacionPendientes = new List<List<string>>();

            for (var index = 1; index < lineas.Length; index++)
            {
                var campos = SepararCsv(lineas[index]);
                if (campos.All(string.IsNullOrWhiteSpace))
                    continue;

                filasImportacionPendientes.Add(campos);

                var categoria = Campo(campos, 6);
                var subcategoria = Campo(campos, 7);

                if (!string.IsNullOrWhiteSpace(categoria))
                {
                    var catExiste = tiposProducto.Any(x => string.Equals(x.Descripcion, categoria, StringComparison.OrdinalIgnoreCase));
                    if (!catExiste && !categoriasFaltantes.Contains(categoria))
                    {
                        categoriasFaltantes.Add(categoria);
                    }
                }

                if (!string.IsNullOrWhiteSpace(subcategoria))
                {
                    var catPadre = categoria;
                    var isMissing = true;
                    var catExistente = tiposProducto.FirstOrDefault(x => string.Equals(x.Descripcion, catPadre, StringComparison.OrdinalIgnoreCase));
                    
                    if (catExistente != null)
                    {
                        var subExistente = subtiposProducto.Any(x =>
                            x.Idtipoproducto == catExistente.Idtipoproducto &&
                            string.Equals(x.Descripcion, subcategoria, StringComparison.OrdinalIgnoreCase));
                        if (subExistente) isMissing = false;
                    }
                    
                    if (isMissing)
                    {
                        var combo = (Categoria: catPadre, Subcategoria: subcategoria);
                        if (!subcategoriasFaltantes.Any(c => string.Equals(c.Categoria, combo.Categoria, StringComparison.OrdinalIgnoreCase) && string.Equals(c.Subcategoria, combo.Subcategoria, StringComparison.OrdinalIgnoreCase)))
                        {
                            subcategoriasFaltantes.Add(combo);
                        }
                    }
                }
            }

            if (categoriasFaltantes.Any() || subcategoriasFaltantes.Any())
            {
                mostrarConfirmacionCategorias = true;
                importandoProductos = false;
                mensajeImportacion = "Se encontraron categorías o subcategorías nuevas en el archivo.";
            }
            else
            {
                await ProcesarImportacionFilasAsync();
            }
        }
        catch (Exception ex)
        {
            erroresImportacion = 1;
            mensajeImportacion = $"No se pudo importar el archivo: {ex.Message}";
            importandoProductos = false;
        }
    }

    private async Task ProcesarImportacionFilasAsync()
    {
        if (filasImportacionPendientes == null || !filasImportacionPendientes.Any())
        {
            importandoProductos = false;
            return;
        }

        try
        {
            var dtoList = new List<ProductoUpsertDto>();
            var errores = new List<string>();
            var filaOffset = 2; // Fila real en Excel

            for (int index = 0; index < filasImportacionPendientes.Count; index++)
            {
                var campos = filasImportacionPendientes[index];
                var fila = index + filaOffset;

                if (campos.Count < 4)
                {
                    errores.Add($"Fila {fila}: faltan columnas obligatorias.");
                    continue;
                }

                var codigo = Campo(campos, 0);
                var nombre = Campo(campos, 1);
                var tipo = Campo(campos, 2).ToUpperInvariant();

                if (string.IsNullOrWhiteSpace(codigo) || string.IsNullOrWhiteSpace(nombre) ||
                    (tipo != "PRODUCTO" && tipo != "SERVICIO") ||
                    !TryParseDecimal(campos[3], out var precioBase))
                {
                    errores.Add($"Fila {fila}: revisa Código, Nombre, Tipo y PrecioBase.");
                    continue;
                }

                var categoria = Campo(campos, 6);
                var subcategoria = Campo(campos, 7);
                
                var categoriaId = string.IsNullOrWhiteSpace(categoria)
                    ? (int?)null
                    : tiposProducto.FirstOrDefault(x => string.Equals(x.Descripcion, categoria, StringComparison.OrdinalIgnoreCase))?.Idtipoproducto;

                if (!string.IsNullOrWhiteSpace(categoria) && !categoriaId.HasValue)
                {
                    errores.Add($"Fila {fila}: la categoría '{categoria}' no existe.");
                    continue;
                }

                var subcategoriaId = string.IsNullOrWhiteSpace(subcategoria)
                    ? (int?)null
                    : subtiposProducto.FirstOrDefault(x =>
                        (!categoriaId.HasValue || x.Idtipoproducto == categoriaId.Value) &&
                        string.Equals(x.Descripcion, subcategoria, StringComparison.OrdinalIgnoreCase))?.Idsubtipo;

                if (!string.IsNullOrWhiteSpace(subcategoria) && !subcategoriaId.HasValue)
                {
                    errores.Add($"Fila {fila}: la subcategoría '{subcategoria}' no existe.");
                    continue;
                }

                var aplicaIva = Campo(campos, 8).Equals("SI", StringComparison.OrdinalIgnoreCase);
                var tarifaIvaTexto = Campo(campos, 9);
                string? codigoIva = null;
                
                if (aplicaIva)
                {
                    codigoIva = ResolverCodigoIva(tarifaIvaTexto);
                    if (string.IsNullOrWhiteSpace(codigoIva))
                    {
                        errores.Add($"Fila {fila}: la tarifa IVA '{tarifaIvaTexto}' no existe o no es válida.");
                        continue;
                    }
                }

                var dto = new ProductoUpsertDto
                {
                    CodigoPrincipal = codigo,
                    Nombre = nombre,
                    TipoCompravena = tipo,
                    ValorUnitario = precioBase,
                    Precio2 = ParseDecimalOpcional(Campo(campos, 4)),
                    Precio3 = ParseDecimalOpcional(Campo(campos, 5)),
                    TipoProducto = categoriaId,
                    Idsubtipo = subcategoriaId,
                    Codigoimpuesto = aplicaIva ? "2" : null,
                    Porcentajeimpuesto = codigoIva,
                    Observacion = Campo(campos, 10),
                    Estado = true
                };
                dtoList.Add(dto);
            }

            var creados = 0;
            if (dtoList.Any())
            {
                var respuesta = await Http.PostAsJsonAsync($"api/productos/bulk?userId={usuarioLogueadoId}", dtoList);
                if (respuesta.IsSuccessStatusCode)
                {
                    var result = await respuesta.Content.ReadFromJsonAsync<BulkImportResult>();
                    if (result != null)
                    {
                        creados = result.Creados;
                        errores.AddRange(result.Errores);
                    }
                }
                else
                {
                    errores.Add($"Error en la carga masiva: {await respuesta.Content.ReadAsStringAsync()}");
                }
            }

            erroresImportacion = errores.Count;
            mensajeImportacion = errores.Count == 0
                ? $"Importación completada: {creados} productos creados."
                : $"Se crearon {creados} productos. {errores.Count} filas presentaron errores. {string.Join(" ", errores.Take(3))}";

            if (errores.Count > 0)
            {
                if (creados == 0)
                {
                    await JS.ShowAlertAsync("No se importaron productos", "No se importaron productos por campos obligatorios incompletos o incorrectos en el archivo Excel.", "warning");
                }
                else
                {
                    await JS.ShowAlertAsync("Importación con observaciones", $"Se crearon {creados} productos, pero algunas filas no se importaron por campos obligatorios incompletos o incorrectos.", "warning");
                }
            }

            if (creados > 0)
            {
                await CargarTodo();
                EmisionControlService.NotifyChanged();
            }
        }
        catch (Exception ex)
        {
            erroresImportacion = 1;
            mensajeImportacion = $"Error al procesar la importación: {ex.Message}";
        }
        finally
        {
            importandoProductos = false;
            filasImportacionPendientes = null;
        }
    }

    private async Task ConfirmarCrearCategoriasFaltantesAsync()
    {
        mostrarConfirmacionCategorias = false;
        importandoProductos = true;
        mensajeImportacion = "Creando categorías y subcategorías nuevas...";
        StateHasChanged();

        try
        {
            // 1. Crear Categorías faltantes
            foreach (var catName in categoriasFaltantes)
            {
                var cat = new Productotipo
                {
                    Descripcion = catName,
                    Estado = true
                };
                await CategoryService.SaveTipoAsync(cat, usuarioLogueadoId);
            }

            // Recargar lookups
            await CargarTodo();

            // 2. Crear Subcategorías faltantes
            foreach (var subInfo in subcategoriasFaltantes)
            {
                var catPadre = tiposProducto.FirstOrDefault(x => string.Equals(x.Descripcion, subInfo.Categoria, StringComparison.OrdinalIgnoreCase));
                var catId = catPadre?.Idtipoproducto ?? 0;
                
                if (catId == 0)
                {
                    catId = tiposProducto.FirstOrDefault()?.Idtipoproducto ?? 0;
                }

                if (catId > 0)
                {
                    var sub = new Productosubtipo
                    {
                        Descripcion = subInfo.Subcategoria,
                        Idtipoproducto = catId,
                        Estado = "A"
                    };
                    await CategoryService.SaveSubtipoAsync(sub, usuarioLogueadoId);
                }
            }

            // Recargar lookups de nuevo
            await CargarTodo();

            // 3. Proceder con la importación final
            await ProcesarImportacionFilasAsync();
        }
        catch (Exception ex)
        {
            erroresImportacion = 1;
            mensajeImportacion = $"Error al crear categorías/subcategorías: {ex.Message}";
            importandoProductos = false;
        }
    }

    private void CancelarCrearCategoriasFaltantes()
    {
        mostrarConfirmacionCategorias = false;
        filasImportacionPendientes = null;
        erroresImportacion = 1;
        mensajeImportacion = "Carga masiva cancelada: El archivo contiene categorías o subcategorías no registradas.";
    }

    private string? ResolverCodigoIva(string? valorIva)
    {
        if (string.IsNullOrWhiteSpace(valorIva))
            return null;

        var input = valorIva.Trim().Replace("%", "").Replace(",", ".").ToLowerInvariant();

        // 1. Buscar por coincidencia exacta con el Código (ej: "4" o "2")
        var porCodigo = porcentajesIva.FirstOrDefault(i => string.Equals(i.Codigo, input, StringComparison.OrdinalIgnoreCase));
        if (porCodigo != null)
            return porCodigo.Codigo;

        // 2. Buscar por valor numérico (ej: "15" o "12")
        if (double.TryParse(input, NumberStyles.Any, CultureInfo.InvariantCulture, out var numero))
        {
            if (numero > 0 && numero < 1.0)
            {
                numero = Math.Round(numero * 100, 2);
            }
            var numStr = numero.ToString("0.##", CultureInfo.InvariantCulture);
            
            var porValor = porcentajesIva.FirstOrDefault(i => 
                string.Equals(i.Valor, numStr, StringComparison.OrdinalIgnoreCase) ||
                (double.TryParse(i.Valor, NumberStyles.Any, CultureInfo.InvariantCulture, out var ivaValNum) && Math.Abs(ivaValNum - numero) < 0.01));
            
            if (porValor != null)
                return porValor.Codigo;
        }

        // 3. Buscar dentro de la descripción (ej: "iva 15%" contiene "15")
        var porDescripcion = porcentajesIva.FirstOrDefault(i => i.Descripcion.Contains(input, StringComparison.OrdinalIgnoreCase));
        if (porDescripcion != null)
            return porDescripcion.Codigo;

        return null;
    }

    private static List<string> SepararCsv(string linea)
    {
        var resultado = new List<string>();
        var actual = new StringBuilder();
        var entreComillas = false;

        for (var i = 0; i < linea.Length; i++)
        {
            var caracter = linea[i];
            if (caracter == '"')
            {
                if (entreComillas && i + 1 < linea.Length && linea[i + 1] == '"')
                {
                    actual.Append('"');
                    i++;
                }
                else
                {
                    entreComillas = !entreComillas;
                }
            }
            else if (caracter == ';' && !entreComillas)
            {
                resultado.Add(actual.ToString());
                actual.Clear();
            }
            else
            {
                actual.Append(caracter);
            }
        }

        resultado.Add(actual.ToString());
        return resultado;
    }

    private static string CleanImportedField(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        var trimmed = value.Trim();
        if (trimmed.StartsWith("=\"") && trimmed.EndsWith("\""))
        {
            trimmed = trimmed.Substring(2, trimmed.Length - 3);
        }
        else if (trimmed.StartsWith("=") && !trimmed.Contains(";"))
        {
            trimmed = trimmed.Substring(1);
            if (trimmed.StartsWith("\"") && trimmed.EndsWith("\""))
            {
                trimmed = trimmed.Substring(1, trimmed.Length - 2);
            }
        }
        else if (trimmed.StartsWith("\"") && trimmed.EndsWith("\""))
        {
            trimmed = trimmed.Substring(1, trimmed.Length - 2);
        }
        return trimmed.Trim();
    }

    private static string Campo(IReadOnlyList<string> campos, int indice) =>
        indice < campos.Count ? CleanImportedField(campos[indice]) : string.Empty;

    private static bool TryParseDecimal(string valor, out decimal resultado) =>
        decimal.TryParse(valor.Trim().Replace(',', '.'), NumberStyles.Number, CultureInfo.InvariantCulture, out resultado);

    private static decimal? ParseDecimalOpcional(string valor) =>
        string.IsNullOrWhiteSpace(valor) ? null : TryParseDecimal(valor, out var resultado) ? resultado : null;

