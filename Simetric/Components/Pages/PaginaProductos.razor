    private async Task Guardar()
    {
        if (isSaving)
            return;

        if (isDemoMode)
        {
            mensaje = "Modo demo: guardar productos está bloqueado.";
            mensajeEdicion = null;
            mensajeFormularioError = null;
            debugError = null;
            return;
        }

        mensaje = null;
        mensajeEdicion = null;
        mensajeFormularioError = null;
        debugError = null;

        model.Nombre = model.Nombre?.Trim();
        model.CodigoPrincipal = model.CodigoPrincipal?.Trim();
        model.TipoCompravena = model.TipoCompravena?.Trim().ToUpperInvariant();
        model.Codigoimpuesto = model.Codigoimpuesto?.Trim();
        model.Porcentajeimpuesto = model.Porcentajeimpuesto?.Trim();
        model.Observacion = model.Observacion?.Trim();
        NormalizarPreciosFormulario();

        if (!productEditContext.Validate())
        {
            ManejarFormularioInvalido(productEditContext);
            return;
        }

        if (model.TipoProducto.HasValue && model.Idsubtipo.HasValue)
        {
            var subtipoOk = subtiposProducto.Any(s =>
                s.Idsubtipo == model.Idsubtipo.Value &&
                s.Idtipoproducto == model.TipoProducto.Value);

            var subtipoSinCambios = editando &&
                model.TipoProducto == tipoProductoOriginalEdicion &&
                model.Idsubtipo == subtipoOriginalEdicion;

            if (!subtipoOk && !subtipoSinCambios)
            {
                mensajeFormularioError = "La subcategoría no pertenece a la categoría elegida.";
                return;
            }
        }

        if (!string.IsNullOrWhiteSpace(model.CodigoPrincipal))
        {
            var existeCodigoPrincipal = productos.Any(p =>
                p.Codigo != model.Codigo &&
                string.Equals(p.CodigoPrincipal?.Trim(), model.CodigoPrincipal, StringComparison.OrdinalIgnoreCase));

            if (existeCodigoPrincipal)
            {
                mensajeFormularioError = "Ya existe un producto con ese código.";
                return;
            }
        }

        var estabaEditando = editando;
        isSaving = true;

        try
        {
            var resp = editando
                ? await Http.PutAsJsonAsync($"api/productos/{model.Codigo}?userId={usuarioLogueadoId}", model)
                : await Http.PostAsJsonAsync($"api/productos?userId={usuarioLogueadoId}", model);

            if (resp.IsSuccessStatusCode)
            {
                await CargarTodo();
                EmisionControlService.NotifyChanged();
                mostrarModalFormularioProducto = false;
                Nuevo();
                mensaje = estabaEditando
                    ? "Producto actualizado correctamente."
                    : "Producto creado correctamente.";
            }
            else
            {
                debugError = await resp.Content.ReadAsStringAsync();
                mensaje = "No se pudo guardar el registro.";
            }
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
            mensaje = "Error al guardar el registro.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ManejarFormularioInvalido(EditContext _)
    {
        mensaje = null;
        mensajeEdicion = null;
        debugError = null;
        mensajeFormularioError = "Revisa los campos obligatorios antes de confirmar el producto.";
    }

    private void OnIvaChanged(ChangeEventArgs e)
    {
        var marcado = false;

        if (e.Value is bool b)
        {
            marcado = b;
        }
        else if (e.Value is string s && bool.TryParse(s, out var parsed))
        {
            marcado = parsed;
        }

        if (marcado)
        {
            model.Codigoimpuesto = "2";
        }
        else
        {
            model.Codigoimpuesto = "";
            model.Porcentajeimpuesto = "";
        }
    }

    private void AgregarCampoPrecioAdicional()
    {
        if (camposPrecioVisibles < 3)
        {
            camposPrecioVisibles++;
        }
    }

    private void EliminarCampoPrecioAdicional(int numeroCampo)
    {
        if (numeroCampo == 2)
        {
            model.Precio2 = model.Precio3;
            model.Precio3 = null;
            SincronizarCamposPrecioVisibles();
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio2));
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio3));
            return;
        }

        if (numeroCampo == 3)
        {
            model.Precio3 = null;
            SincronizarCamposPrecioVisibles();
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio3));
        }
    }

    private void SincronizarCamposPrecioVisibles()
    {
        CompactarPreciosIntermedios();
        camposPrecioVisibles = 1;

        if (model.Precio2.HasValue || model.Precio3.HasValue)
        {
            camposPrecioVisibles = 2;
        }

        if (model.Precio3.HasValue)
        {
            camposPrecioVisibles = 3;
        }
    }

    private void NormalizarCampoPrecio(int numeroCampo)
    {
        if (numeroCampo == 1)
        {
            model.ValorUnitario = NormalizarMonto(model.ValorUnitario);
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.ValorUnitario));
        }
        else if (numeroCampo == 2)
        {
            model.Precio2 = NormalizarMonto(model.Precio2);
            CompactarPreciosIntermedios();
            SincronizarCamposPrecioVisibles();
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio2));
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio3));
        }
        else if (numeroCampo == 3)
        {
            model.Precio3 = NormalizarMonto(model.Precio3);
            CompactarPreciosIntermedios();
            SincronizarCamposPrecioVisibles();
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio2));
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Precio3));
        }
    }

    private void NormalizarPreciosFormulario()
    {
        model.ValorUnitario = NormalizarMonto(model.ValorUnitario);
        model.Precio2 = NormalizarMonto(model.Precio2);
        model.Precio3 = NormalizarMonto(model.Precio3);
        CompactarPreciosIntermedios();
        SincronizarCamposPrecioVisibles();
    }

    private void CompactarPreciosIntermedios()
    {
        if (!model.Precio2.HasValue && model.Precio3.HasValue)
        {
            model.Precio2 = model.Precio3;
            model.Precio3 = null;
        }
    }

    private static decimal? NormalizarMonto(decimal? valor)
    {
        if (!valor.HasValue)
        {
            return null;
        }

        var montoNormalizado = decimal.Round(valor.Value, 2, MidpointRounding.AwayFromZero);
        montoNormalizado = decimal.Clamp(montoNormalizado, 0m, PrecioMaximoPermitido);
        return montoNormalizado;
    }

