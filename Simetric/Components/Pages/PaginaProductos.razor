    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        isDemoMode = EsRutaDemoProductos();

        if (isDemoMode)
        {
            CargarDemoProductos();
            await InvokeAsync(StateHasChanged);
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        usuarioLogueadoId = ObtenerIdUsuario(user);

        if (usuarioLogueadoId <= 0)
        {
            mensaje = "Sesión no válida (no se pudo obtener IdUsuario). Vuelve a iniciar sesión.";
            cargando = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await CargarTodo();
        await InvokeAsync(StateHasChanged);
    }

    private static int ObtenerIdUsuario(ClaimsPrincipal user)
    {
        var id = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(id, out var userId) ? userId : 0;
    }

    private async Task CargarTodo()
    {
        if (isDemoMode)
        {
            CargarDemoProductos();
            return;
        }

        cargando = true;
        try
        {
            var respLook = await Http.GetFromJsonAsync<LookupResponse>($"api/productos/lookups?userId={usuarioLogueadoId}");
            if (respLook != null)
            {
                tiposProducto = respLook.tipos
                    .OrderBy(x => x.Descripcion, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                codigosImpuesto = respLook.impuestos;
                porcentajesIva = respLook.ivas;
                subtiposProducto = respLook.subtipos
                    .OrderBy(x => x.Descripcion, StringComparer.OrdinalIgnoreCase)
                    .ToList();

                if (filtroTipo.HasValue && !tiposProducto.Any(x => x.Idtipoproducto == filtroTipo.Value))
                {
                    filtroTipo = null;
                }

                if (filtroSubtipo.HasValue && !subtiposProducto.Any(x => x.Idsubtipo == filtroSubtipo.Value))
                {
                    filtroSubtipo = null;
                }
            }

            productos = await Http.GetFromJsonAsync<List<ProductoDto>>($"api/productos?userId={usuarioLogueadoId}") ?? new();
            await EmisorOnboardingService.RefreshRequirementAsync(usuarioLogueadoId);
            emisionEstado = await EmisionControlService.ObtenerEstadoAsync(usuarioLogueadoId);
        }
        catch (Exception ex)
        {
            debugError = ex.Message;
        }
        finally
        {
            cargando = false;
            AjustarPaginaActual();
        }
    }

