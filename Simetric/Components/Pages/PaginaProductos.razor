    private async Task GuardarCategoriaDesdeProductoAsync()
    {
        if (guardandoCategoriaProducto)
            return;

        tempDescripcionCategoriaProducto = (tempDescripcionCategoriaProducto ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(tempDescripcionCategoriaProducto) || tempDescripcionCategoriaProducto.Length < 3)
        {
            await JS.ShowAlertAsync("Revisa la informacion", "La descripcion es obligatoria y debe tener al menos 3 caracteres.", "warning");
            return;
        }

        if (modalCategoriaEsSubcategoria && tempCategoriaPadreProducto <= 0)
        {
            await JS.ShowAlertAsync("Categoria requerida", "Debes seleccionar una categoria para crear la subcategoria.", "warning");
            return;
        }

        if (isDemoMode)
        {
            await JS.ShowAlertAsync("Modo demo", modalCategoriaEsSubcategoria
                ? "La demo muestra el modal de subcategorias, pero el guardado real esta bloqueado."
                : "La demo muestra el modal de categorias, pero el guardado real esta bloqueado.", "info");
            return;
        }

        guardandoCategoriaProducto = true;

        try
        {
            if (modalCategoriaEsSubcategoria)
            {
                await CategoryService.SaveSubtipoAsync(new Simetric.Models.Productosubtipo
                {
                    Descripcion = tempDescripcionCategoriaProducto,
                    Idtipoproducto = tempCategoriaPadreProducto,
                    Estado = "A"
                }, usuarioLogueadoId);
            }
            else
            {
                await CategoryService.SaveTipoAsync(new Simetric.Models.Productotipo
                {
                    Descripcion = tempDescripcionCategoriaProducto,
                    Estado = true
                }, usuarioLogueadoId);
            }

            await CargarTodo();

            if (modalCategoriaEsSubcategoria)
            {
                model.TipoProducto = tempCategoriaPadreProducto;
                model.Idsubtipo = subtiposProducto
                    .Where(x => x.Idtipoproducto == tempCategoriaPadreProducto)
                    .OrderByDescending(x => x.Idsubtipo)
                    .FirstOrDefault(x => string.Equals(x.Descripcion, tempDescripcionCategoriaProducto, StringComparison.OrdinalIgnoreCase))
                    ?.Idsubtipo;
            }
            else
            {
                model.TipoProducto = tiposProducto
                    .OrderByDescending(x => x.Idtipoproducto)
                    .FirstOrDefault(x => string.Equals(x.Descripcion, tempDescripcionCategoriaProducto, StringComparison.OrdinalIgnoreCase))
                    ?.Idtipoproducto;
                model.Idsubtipo = null;
            }

            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.TipoProducto));
            productEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => model.Idsubtipo));
            await InvokeAsync(StateHasChanged);

            CerrarModalCategoriaProducto();
            await JS.ShowToastAsync(modalCategoriaEsSubcategoria ? "Subcategoria guardada" : "Categoria guardada");
        }
        catch (Exception ex)
        {
            mensajeModalCategoriaProducto = ex.Message;
        }
        finally
        {
            guardandoCategoriaProducto = false;
        }
    }

    private IEnumerable<ProductoDto> ProductosFiltrados
    {
        get
        {
            var activos = productos.Where(p => p.Estado == true);

            if (filtroTipo.HasValue)
            {
                activos = activos.Where(p => p.TipoProducto == filtroTipo.Value);
            }

            if (filtroSubtipo.HasValue)
            {
                activos = activos.Where(p => p.Idsubtipo == filtroSubtipo.Value);
            }

            if (!string.IsNullOrWhiteSpace(filtroCompraventa))
            {
                activos = activos.Where(p =>
                    string.Equals(p.TipoCompravena, filtroCompraventa, StringComparison.OrdinalIgnoreCase));
            }

            if (string.IsNullOrWhiteSpace(filtro))
            {
                return OrdenarProductosClasificados(activos);
            }

            return OrdenarProductosClasificados(activos.Where(p =>
                (p.Nombre ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                (p.CodigoPrincipal ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                GetCategoriaDescripcion(p.TipoProducto).Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
                GetSubcategoriaDescripcion(p.Idsubtipo).Contains(filtro, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private IOrderedEnumerable<ProductoDto> OrdenarProductosClasificados(IEnumerable<ProductoDto> query) =>
        query
            .OrderBy(p => GetCategoriaDescripcion(p.TipoProducto), StringComparer.OrdinalIgnoreCase)
            .ThenBy(p => GetSubcategoriaDescripcion(p.Idsubtipo), StringComparer.OrdinalIgnoreCase)
            .ThenBy(p => p.Nombre ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            .ThenByDescending(p => p.Codigo);

    private IEnumerable<ProductoDto> ProductosPaginados =>
        ProductosFiltrados
            .Skip((currentPage - 1) * CurrentPageSize)
            .Take(CurrentPageSize);

    private int CurrentTotalRecords => ProductosFiltrados.Count();
    private int CurrentTotalPages => Math.Max(1, (int)Math.Ceiling(CurrentTotalRecords / (double)CurrentPageSize));
    private int CurrentPageStart => CurrentTotalRecords == 0 ? 0 : ((currentPage - 1) * CurrentPageSize) + 1;
    private int CurrentPageEnd => CurrentTotalRecords == 0 ? 0 : Math.Min(CurrentTotalRecords, currentPage * CurrentPageSize);

