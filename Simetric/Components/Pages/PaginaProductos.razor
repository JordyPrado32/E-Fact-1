@code {

    private int usuarioLogueadoId = 0;
    private bool isDemoMode;
    private EmisionEstado? emisionEstado;
    private string PageBrandTitle => "Numerica e-fact";
    private bool MostrarVolverInicioOnboarding =>
        !isDemoMode &&
        (EmisorOnboardingService.RequiresInitialSetup || emisionEstado?.PuedeEmitir == false);
    private int? filtroTipo = null;
    private int? filtroSubtipo = null;
    private string filtroCompraventa = string.Empty;

    private class LookupResponse
    {
        public List<TipoDto> tipos { get; set; } = new();
        public List<ImpuestoDto> impuestos { get; set; } = new();
        public List<IvaDto> ivas { get; set; } = new();
        public List<SubtipoDto> subtipos { get; set; } = new();
    }

    private class TipoDto
    {
        public int Idtipoproducto { get; set; }
        public string Descripcion { get; set; } = "";
    }

    private class ImpuestoDto
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
    }

    private class IvaDto
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public string? Valor { get; set; }
    }

    private class SubtipoDto
    {
        public int Idsubtipo { get; set; }
        public string Descripcion { get; set; } = "";
        public int Idtipoproducto { get; set; }
    }

    private class ProductoDto
    {
        public int Codigo { get; set; }
        public string? Nombre { get; set; }
        public string? CodigoPrincipal { get; set; }

        public decimal? ValorUnitario { get; set; }
        public decimal? Precio2 { get; set; }
        public decimal? Precio3 { get; set; }

        public string? TipoCompravena { get; set; }

        public int? TipoProducto { get; set; }
        public int? Idsubtipo { get; set; }

        public string? Codigoimpuesto { get; set; }
        public string? Porcentajeimpuesto { get; set; }

        public bool? Estado { get; set; }
        public string? Observacion { get; set; }
        public int? Idusuario { get; set; }
    }

    private class ProductoUpsertDto : IValidatableObject
    {
        private const decimal PrecioMaximoPermitido = 99999999.99m;

        public int Codigo { get; set; }

        public string? Nombre { get; set; }
        public string? CodigoPrincipal { get; set; }

        public decimal? ValorUnitario { get; set; }
        public decimal? Precio2 { get; set; }
        public decimal? Precio3 { get; set; }

        public string? TipoCompravena { get; set; }

        public int? TipoProducto { get; set; }
        public int? Idsubtipo { get; set; }

        public string? Codigoimpuesto { get; set; }
        public string? Porcentajeimpuesto { get; set; }

        public bool? Estado { get; set; } = true;
        public string? Observacion { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            Nombre = Nombre?.Trim();
            CodigoPrincipal = CodigoPrincipal?.Trim();
            TipoCompravena = TipoCompravena?.Trim().ToUpperInvariant();
            Codigoimpuesto = Codigoimpuesto?.Trim();
            Porcentajeimpuesto = Porcentajeimpuesto?.Trim();
            Observacion = Observacion?.Trim();

            if (string.IsNullOrWhiteSpace(TipoCompravena))
            {
                yield return new ValidationResult(
                    "Debe seleccionar si el registro es producto o servicio.",
                    new[] { nameof(TipoCompravena) });
            }

            if (string.IsNullOrWhiteSpace(Nombre))
            {
                yield return new ValidationResult(
                    "Debe ingresar el nombre del producto o servicio.",
                    new[] { nameof(Nombre) });
            }
            else if (Nombre.Length > 120)
            {
                yield return new ValidationResult(
                    "El nombre no puede exceder 120 caracteres.",
                    new[] { nameof(Nombre) });
            }

            if (!string.IsNullOrWhiteSpace(CodigoPrincipal) && CodigoPrincipal.Length > 50)
            {
                yield return new ValidationResult(
                    "El código no puede exceder 50 caracteres.",
                    new[] { nameof(CodigoPrincipal) });
            }

            if (!ValorUnitario.HasValue)
            {
                yield return new ValidationResult(
                    "Debe ingresar el precio base.",
                    new[] { nameof(ValorUnitario) });
            }

            if (ValorUnitario.HasValue && ValorUnitario < 0)
            {
                yield return new ValidationResult(
                    "El precio 1 no puede ser menor a 0.",
                    new[] { nameof(ValorUnitario) });
            }

            if (ValorUnitario.HasValue && ValorUnitario > PrecioMaximoPermitido)
            {
                yield return new ValidationResult(
                    $"El precio base no puede superar {PrecioMaximoPermitido:N2}.",
                    new[] { nameof(ValorUnitario) });
            }

            if (ValorUnitario.HasValue && TieneMasDeDosDecimales(ValorUnitario.Value))
            {
                yield return new ValidationResult(
                    "El precio base solo admite hasta 2 decimales.",
                    new[] { nameof(ValorUnitario) });
            }

            if (Precio2.HasValue && Precio2 < 0)
            {
                yield return new ValidationResult(
                    "El precio 2 no puede ser menor a 0.",
                    new[] { nameof(Precio2) });
            }

            if (Precio2.HasValue && Precio2 > PrecioMaximoPermitido)
            {
                yield return new ValidationResult(
                    $"El precio 2 no puede superar {PrecioMaximoPermitido:N2}.",
                    new[] { nameof(Precio2) });
            }

            if (Precio2.HasValue && TieneMasDeDosDecimales(Precio2.Value))
            {
                yield return new ValidationResult(
                    "El precio 2 solo admite hasta 2 decimales.",
                    new[] { nameof(Precio2) });
            }

            if (Precio3.HasValue && Precio3 < 0)
            {
                yield return new ValidationResult(
                    "El precio 3 no puede ser menor a 0.",
                    new[] { nameof(Precio3) });
            }

            if (Precio3.HasValue && Precio3 > PrecioMaximoPermitido)
            {
                yield return new ValidationResult(
                    $"El precio 3 no puede superar {PrecioMaximoPermitido:N2}.",
                    new[] { nameof(Precio3) });
            }

            if (Precio3.HasValue && TieneMasDeDosDecimales(Precio3.Value))
            {
                yield return new ValidationResult(
                    "El precio 3 solo admite hasta 2 decimales.",
                    new[] { nameof(Precio3) });
            }

            if (!string.IsNullOrWhiteSpace(TipoCompravena) &&
                TipoCompravena != "PRODUCTO" &&
                TipoCompravena != "SERVICIO")
            {
                yield return new ValidationResult(
                    "Debe elegir PRODUCTO o SERVICIO.",
                    new[] { nameof(TipoCompravena) });
            }

            if (Idsubtipo.HasValue && !TipoProducto.HasValue)
            {
                yield return new ValidationResult(
                    "Debe seleccionar una categoría antes de elegir la subcategoría.",
                    new[] { nameof(Idsubtipo), nameof(TipoProducto) });
            }

            if (Codigoimpuesto == "2" && string.IsNullOrWhiteSpace(Porcentajeimpuesto))
            {
                yield return new ValidationResult(
                    "Debe seleccionar la tarifa IVA.",
                    new[] { nameof(Porcentajeimpuesto) });
            }

            if (!string.IsNullOrWhiteSpace(Observacion) && Observacion.Length > 250)
            {
                yield return new ValidationResult(
                    "La observación no puede exceder 250 caracteres.",
                    new[] { nameof(Observacion) });
            }
        }

        private static bool TieneMasDeDosDecimales(decimal valor) =>
            decimal.Round(valor, 2, MidpointRounding.AwayFromZero) != valor;
    }

