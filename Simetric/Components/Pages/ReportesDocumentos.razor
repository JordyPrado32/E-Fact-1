            var demoXmlUrl = ObtenerDemoXmlUrl(item);
            if (string.IsNullOrWhiteSpace(demoXmlUrl))
            {
                await AlertService.ShowInfoAsync("No hay un XML demo configurado para este documento.");
                return;
            }

            await AlertService.ShowInfoAsync("Abriendo XML demo de muestra.");
            await JS.InvokeVoidAsync("open", demoXmlUrl, "_blank");
            return;
        }

        var url = await ReporteComprobantesService.AsegurarXmlDocumentoUsuarioAsync(item.TipoDocumentoCodigo, item.DocumentoId, currentUserId);
        if (string.IsNullOrWhiteSpace(url))
        {
            await AlertService.ShowWarningAsync("No se pudo ubicar o generar el XML del documento seleccionado.");
            return;
