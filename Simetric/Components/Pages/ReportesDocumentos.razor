@page "/reportes/documentos"
@page "/demo/documentos"
@layout Simetric.Components.Layout.MainLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using System.Globalization
@using Simetric.DTOs
@using Simetric.Services

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SweetAlertService AlertService
@inject ReporteComprobantesService ReporteComprobantesService
@inject IReporteComprobantesPdfService ReporteComprobantesPdfService
@inject IReporteComprobantesExcelService ReporteComprobantesExcelService
@inject DemoCatalogService DemoCatalogService
@attribute [AllowAnonymous]
@implements IAsyncDisposable

<PageTitle>Reportes de documentos | Numerica e-fact</PageTitle>

@{
    var itemsFiltrados = ItemsFiltrados;
    var itemsPagina = ItemsPagina;
    var resumenTipos = ResumenTipos;
    var totalResumenTipos = resumenTipos.Sum(x => x.Count);
    var tipoPrincipal = resumenTipos
        .OrderByDescending(x => x.Count)
        .ThenByDescending(x => x.Total)
        .FirstOrDefault();
    var topTerceros = TopTerceros;
}

<div class="docs-report-shell">
    @if (cargando)
    {
        <section class="docs-report-state">
            <div class="state-icon">
                <span class="spinner-border" role="status"></span>
            </div>
            <h3>Cargando reporte consolidado</h3>
            <p>Estamos reuniendo facturas, notas, guias, retenciones y liquidaciones en una sola vista.</p>
        </section>
    }
    else
    {
        <section class="docs-report-hero">
            <div class="hero-copy">
                <span class="hero-kicker">Analitica documental</span>
                <h1>Reportes unificados de comprobantes emitidos</h1>
                <p>
                    Filtra los 6 tipos de documentos al mismo tiempo, revisa el resumen visual
                    y abre XML o PDF sin salir del reporte.
                </p>

                <div class="hero-actions">
                    <button type="button" class="hero-btn hero-btn-primary" @onclick="ExportarPdfAsync" disabled="@(exportandoPdf || itemsFiltrados.Count == 0)">
                        @(exportandoPdf ? "Descargando PDF..." : "Descargar PDF")
                    </button>

                    <button type="button" class="hero-btn hero-btn-success" @onclick="ExportarExcelAsync" disabled="@(exportandoExcel || itemsFiltrados.Count == 0)">
                        @if (exportandoExcel)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span>Descargando...</span>
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-spreadsheet"></i>
                            <span>Descargar Excel</span>
                        }
                    </button>

                    <button type="button" class="hero-btn hero-btn-secondary" @onclick="RecargarAsync" disabled="@cargando">
                        Actualizar datos
                    </button>
                </div>
            </div>

            <div class="hero-summary">
                <article class="summary-card summary-card-primary" style="--stat-accent:#14B8A6; --stat-soft:#CCFBF1;">
                    <div class="summary-card-head">
                        <span class="summary-icon"><i class="bi bi-files"></i></span>
                        <span class="summary-label">Total documentos</span>
                    </div>
                    <strong>@itemsFiltrados.Count</strong>
                    <small>@ResumenFechas</small>
                    <div class="summary-meter"><span style="width:100%;"></span></div>
                </article>

                <article class="summary-card" style="--stat-accent:#8B5CF6; --stat-soft:#F3E8FF;">
                    <div class="summary-card-head">
                        <span class="summary-icon"><i class="bi bi-receipt"></i></span>
                        <span class="summary-label">Total sin impuestos</span>
                    </div>
                    <strong>@FormatearMoneda(TotalBaseFiltrado)</strong>
                    <small>Base imponible visible</small>
                    <div class="summary-meter"><span style="@($"width:{ObtenerAnchoMonto(TotalBaseFiltrado, TotalGeneralFiltrado)}%;")"></span></div>
                </article>

                <article class="summary-card" style="--stat-accent:#F59E0B; --stat-soft:#FEF3C7;">
                    <div class="summary-card-head">
                        <span class="summary-icon"><i class="bi bi-percent"></i></span>
                        <span class="summary-label">Total IVA</span>
                    </div>
                    <strong>@FormatearMoneda(TotalIvaFiltrado)</strong>
                    <small>Impuesto generado</small>
                    <div class="summary-meter"><span style="@($"width:{ObtenerAnchoMonto(TotalIvaFiltrado, TotalGeneralFiltrado)}%;")"></span></div>
                </article>

                <article class="summary-card" style="--stat-accent:#EC4899; --stat-soft:#FCE7F3;">
                    <div class="summary-card-head">
                        <span class="summary-icon"><i class="bi bi-cash-stack"></i></span>
                        <span class="summary-label">Total con impuestos</span>
                    </div>
                    <strong>@FormatearMoneda(TotalGeneralFiltrado)</strong>
                    <small>Monto total facturado</small>
                    <div class="summary-meter"><span style="width:100%;"></span></div>
                </article>

                <article class="summary-card summary-card-success" style="--stat-accent:#10B981; --stat-soft:#D1FAE5;">
                    <div class="summary-card-head">
                        <span class="summary-icon"><i class="bi bi-check2-circle"></i></span>
                        <span class="summary-label">Documentos autorizados</span>
                    </div>
                    <strong>@TotalAutorizados</strong>
                    <small>@FormatearPorcentaje(TotalAutorizados, itemsFiltrados.Count) del total</small>
                    <div class="summary-meter"><span style="@($"width:{ObtenerAnchoPorcentaje(TotalAutorizados, itemsFiltrados.Count)}%;")"></span></div>
                </article>

                <article class="summary-card summary-card-warning" style="--stat-accent:#F97316; --stat-soft:#FFEDD5;">
                    <div class="summary-card-head">
                        <span class="summary-icon"><i class="bi bi-hourglass-split"></i></span>
                        <span class="summary-label">Documentos pendientes</span>
                    </div>
                    <strong>@TotalPendientes</strong>
                    <small>@FormatearPorcentaje(TotalPendientes, itemsFiltrados.Count) del total</small>
                    <div class="summary-meter"><span style="@($"width:{ObtenerAnchoPorcentaje(TotalPendientes, itemsFiltrados.Count)}%;")"></span></div>
                </article>
            </div>
        </section>

        <section class="filters-card">
            <div class="filters-head">
                <div>
                    <span class="section-kicker">Filtros combinados</span>
                    <h2>Refina el reporte por documento, fecha, cliente y detalle</h2>
                </div>

                <span class="filters-badge">@itemsFiltrados.Count resultado(s)</span>
            </div>

            <div class="filters-grid">
                <label class="field-card">
                    <span class="field-label">Tipo de documento</span>
                    <select class="field-input" @bind="tipoDocumentoFiltro" @bind:after="OnFiltersChanged">
                        <option value="@ReporteComprobantesCategoriaDetalle.Todos">Todos</option>
                        <option value="@ReporteComprobantesTipos.Factura">Facturas</option>
                        <option value="@ReporteComprobantesTipos.NotaCredito">Notas de crédito</option>
                        <option value="@ReporteComprobantesTipos.NotaDebito">Notas de débito</option>
                        <option value="@ReporteComprobantesTipos.GuiaRemision">Guías de remisión</option>
                        <option value="@ReporteComprobantesTipos.Retencion">Retenciones</option>
                        <option value="@ReporteComprobantesTipos.LiquidacionCompra">Liquidaciones de compra</option>
                    </select>
                </label>

                <label class="field-card">
                    <span class="field-label">Desde</span>
                    <InputDate TValue="DateTime?" class="field-input" @bind-Value="fechaDesde" @bind-Value:after="OnFiltersChanged" />
                </label>

                <label class="field-card">
                    <span class="field-label">Hasta</span>
                    <InputDate TValue="DateTime?" class="field-input" @bind-Value="fechaHasta" @bind-Value:after="OnFiltersChanged" />
                </label>

                <label class="field-card">
                    <span class="field-label">Estado</span>
                    <select class="field-input" @bind="estadoFiltro" @bind:after="OnFiltersChanged">
                        <option value="@ReporteComprobantesCategoriaDetalle.Todos">Todos</option>
                        @foreach (var estado in reporte.EstadosDisponibles)
                        {
                            <option value="@estado">@estado</option>
                        }
                    </select>
                </label>

                <label class="field-card">
                    <span class="field-label">Autorizacion</span>
                    <select class="field-input" @bind="autorizacionFiltro" @bind:after="OnFiltersChanged">
                        <option value="@DocumentoAutorizacionHelper.FiltroTodos">Todos</option>
                        <option value="@DocumentoAutorizacionHelper.FiltroAutorizados">Autorizados</option>
                        <option value="@DocumentoAutorizacionHelper.FiltroPendientes">Pendientes</option>
                        <option value="@DocumentoAutorizacionHelper.FiltroNoAutorizados">No autorizados</option>
                    </select>
                </label>

                <label class="field-card field-card-wide">
                    <span class="field-label">Cliente / tercero</span>
                    <input type="text"
                           class="field-input"
                           list="clientesReporteDatalist"
                           placeholder="Busca por nombre o identificacion"
                           @bind="clienteFiltro"
                           @bind:event="oninput"
                           @bind:after="OnFiltersChanged" />
                </label>

                <label class="field-card field-card-wide">
                    <span class="field-label">Producto / servicio</span>
                    <input type="text"
                           class="field-input"
                           list="productosReporteDatalist"
                           placeholder="Busca por descripcion del detalle"
                           @bind="productoFiltro"
                           @bind:event="oninput"
                           @bind:after="OnFiltersChanged" />
                </label>

                <label class="field-card">
                    <span class="field-label">Categoria del detalle</span>
                    <select class="field-input" @bind="categoriaDetalleFiltro" @bind:after="OnFiltersChanged">
                        <option value="@ReporteComprobantesCategoriaDetalle.Todos">Todos</option>
                        <option value="@ReporteComprobantesCategoriaDetalle.Producto">Solo producto</option>
                        <option value="@ReporteComprobantesCategoriaDetalle.Servicio">Solo servicio</option>
                    </select>
                </label>

                 <div class="field-card field-card-actions">
                     <span class="field-label">Acciones</span>
                     <div class="actions-stack">
                        <button type="button" class="hero-btn hero-btn-secondary" @onclick="LimpiarFiltros">
                            Limpiar
                        </button>
                     </div>
                 </div>
            </div>

            <datalist id="clientesReporteDatalist">
                @foreach (var cliente in reporte.ClientesDisponibles.Take(200))
                {
                    <option value="@cliente"></option>
                }
            </datalist>

            <datalist id="productosReporteDatalist">
                @foreach (var producto in reporte.ProductosDisponibles.Take(200))
                {
                    <option value="@producto"></option>
                }
            </datalist>
        </section>

        <section class="analytics-grid">
            <article class="analytics-card analytics-card-chart">
                <div class="section-head">
                    <div>
                        <span class="section-kicker">Distribucion</span>
                        <h2>Distribucion por tipo de documento</h2>
                    </div>
                    <span class="section-chip">@resumenTipos.Count tipo(s)</span>
                </div>

                @if (resumenTipos.Count == 0)
                {
                    <div class="empty-panel">
                        <i class="bi bi-pie-chart"></i>
                        <p>No hay datos con los filtros actuales para construir el grafico.</p>
                    </div>
                }
                else
                {
                    <div class="chart-shell">
                        <div class="chart-stage">
                            <div class="report-donut-frame">
                                <canvas id="reportDocumentTypeChart" aria-label="Distribucion por tipo de documento" role="img"></canvas>
                                <div class="pie-ring-inner">
                                    <span class="pie-kicker">Total visible</span>
                                    <strong>@itemsFiltrados.Count</strong>
                                    <span>documentos</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </article>

            <article class="analytics-card">
                <div class="section-head">
                    <div>
                        <span class="section-kicker">Tendencias</span>
                        <h2>Clientes o terceros con mas movimiento</h2>
                    </div>
                    <span class="section-chip">Top 5</span>
                </div>

                @if (topTerceros.Count == 0)
                {
                    <div class="empty-panel">
                        <i class="bi bi-bar-chart"></i>
                        <p>No hay terceros visibles con los filtros actuales.</p>
                    </div>
                }
                else
                {
                    <div class="report-bars-frame">
                        <canvas id="reportTopThirdPartiesChart" aria-label="Clientes o terceros con mas movimiento" role="img"></canvas>
                    </div>
                }
            </article>
        </section>

        <section class="table-card">
            <div class="table-head">
                <div>
                    <span class="section-kicker">Resultados</span>
                    <h2>Documentos emitidos</h2>
                </div>

                <div class="table-meta">
                    <span>Base: @FormatearMoneda(TotalBaseFiltrado)</span>
                    <span>IVA: @FormatearMoneda(TotalIvaFiltrado)</span>
                </div>
            </div>

            @if (itemsFiltrados.Count == 0)
            {
                <div class="docs-report-state docs-report-state-inline">
                    <div class="state-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h3>No encontramos documentos</h3>
                    <p>Ajusta los filtros para ampliar el rango o limpia la busqueda actual.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="docs-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Numero</th>
                                <th>Cliente / tercero</th>
                                <th>Producto / servicio</th>
                                <th>Estado</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itemsPagina)
                            {
                                <tr>
                                    <td data-label="Fecha">@(item.FechaEmision?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td data-label="Tipo">
                                        <span class="type-pill" style="@($"--type-accent:{ObtenerColorTipo(item.TipoDocumentoCodigo)}")">
                                            @item.TipoDocumento
                                        </span>
                                    </td>
                                    <td data-label="Numero">
                                        <div class="cell-stack">
                                            <strong>@item.NumeroDocumento</strong>
                                            <span>@(string.IsNullOrWhiteSpace(item.DocumentoRelacionado) ? item.TerceroRol : item.DocumentoRelacionado)</span>
                                        </div>
                                    </td>
                                    <td data-label="Cliente / tercero">
                                        <div class="cell-stack">
                                            <strong>@item.TerceroNombre</strong>
                                            <span>@item.TerceroIdentificacion</span>
                                        </div>
                                    </td>
                                    <td data-label="Producto / servicio">
                                        <div class="cell-stack">
                                            <strong>@item.ResumenProductos</strong>
                                            <span>@item.CategoriaDetalle</span>
                                        </div>
                                    </td>
                                    <td data-label="Estado">
                                        <div class="cell-stack">
                                            <span class="status-pill @ObtenerClaseEstado(item.EstadoDocumento)">
                                                @item.EstadoDocumento
                                            </span>
                                            <span class="authorization-number" title="@ObtenerNumeroAutorizacionTexto(item)">
                                                Autorizacion: @ObtenerNumeroAutorizacionTexto(item)
                                            </span>
                                        </div>
                                    </td>
                                    <td data-label="Total" class="text-end text-amount">@FormatearMoneda(item.Total)</td>
                                    <td data-label="Acciones" class="text-end">
                                        <div class="action-group">
                                            <button type="button" class="action-btn" title="Abrir XML" @onclick="() => AbrirXmlAsync(item)">XML</button>
                                            <button type="button" class="action-btn action-btn-primary" title="Abrir PDF" @onclick="() => AbrirPdfAsync(item)">PDF</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-footer">
                    <span>Mostrando @itemsPagina.Count de @itemsFiltrados.Count documento(s).</span>

                    <div class="pager-group">
                        <button type="button" class="pager-btn" @onclick="PaginaAnterior" disabled="@(paginaActual <= 1)">Anterior</button>
                        <span>Pagina @paginaActual de @TotalPaginas</span>
                        <button type="button" class="pager-btn" @onclick="PaginaSiguiente" disabled="@(paginaActual >= TotalPaginas)">Siguiente</button>
                    </div>
                </div>
            }
        </section>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "autorizacion")]
    public string? AutorizacionQuery { get; set; }

    private const int PageSize = 12;

    private ReporteComprobantesCargaDto reporte = new();
    private bool cargando = true;
    private bool exportandoPdf;
    private bool exportandoExcel;
    private bool isDemoMode;
    private int currentUserId;
    private int paginaActual = 1;
    private string reportChartsSignature = string.Empty;

    private string tipoDocumentoFiltro = ReporteComprobantesCategoriaDetalle.Todos;
    private string clienteFiltro = string.Empty;
    private string productoFiltro = string.Empty;
    private string categoriaDetalleFiltro = ReporteComprobantesCategoriaDetalle.Todos;
    private string estadoFiltro = ReporteComprobantesCategoriaDetalle.Todos;
    private string autorizacionFiltro = DocumentoAutorizacionHelper.FiltroTodos;
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;

    private List<ReporteComprobanteItemDto> ItemsFiltrados => AplicarFiltros(reporte.Items);

    private List<ReporteComprobanteItemDto> ItemsPagina =>
        ItemsFiltrados
            .Skip((paginaActual - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private int TotalPaginas =>
        Math.Max(1, (int)Math.Ceiling(ItemsFiltrados.Count / (double)PageSize));

    private decimal TotalBaseFiltrado => ItemsFiltrados.Sum(x => x.BaseImponible);
    private decimal TotalIvaFiltrado => ItemsFiltrados.Sum(x => x.Iva);
    private decimal TotalGeneralFiltrado => ItemsFiltrados.Sum(x => x.Total);
    private int TotalAutorizados => ItemsFiltrados.Count(x => x.EstaAutorizado);
    private int TotalPendientes => Math.Max(ItemsFiltrados.Count - TotalAutorizados, 0);
    private int TotalTercerosVisibles => ItemsFiltrados
        .Select(x => x.TerceroNombre)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
    private int TotalServiciosVisibles => ItemsFiltrados.Count(x => x.TieneServicio);

    private string ResumenFechas
    {
        get
        {
            if (fechaDesde.HasValue || fechaHasta.HasValue)
            {
                return $"{(fechaDesde?.ToString("dd/MM/yyyy") ?? "inicio")} a {(fechaHasta?.ToString("dd/MM/yyyy") ?? "hoy")}";
            }

            return "Todos los periodos visibles";
        }
    }

    private List<ResumenTipoVista> ResumenTipos
    {
        get
        {
            var items = ItemsFiltrados;
            if (items.Count == 0)
            {
                return new List<ResumenTipoVista>();
            }

            return DefinicionesTipo
                .Select(def =>
                {
                    var docs = items.Where(x => x.TipoDocumentoCodigo == def.Codigo).ToList();
                    return new ResumenTipoVista
                    {
                        Codigo = def.Codigo,
                        Label = def.Label,
                        Color = def.Color,
                        Count = docs.Count,
                        Total = docs.Sum(x => x.Total)
                    };
                })
                .Where(x => x.Count > 0)
                .ToList();
        }
    }

    private List<ResumenTerceroVista> TopTerceros
    {
        get
        {
            var items = ItemsFiltrados;
            if (items.Count == 0)
            {
                return new List<ResumenTerceroVista>();
            }

            var maximo = items
                .GroupBy(x => x.TerceroNombre, StringComparer.OrdinalIgnoreCase)
                .Select(x => x.Count())
                .DefaultIfEmpty(1)
                .Max();

            return items
                .Where(x => !string.IsNullOrWhiteSpace(x.TerceroNombre))
                .GroupBy(x => x.TerceroNombre.Trim(), StringComparer.OrdinalIgnoreCase)
                .Select((g, index) => new ResumenTerceroVista
                {
                    Label = g.Key,
                    Count = g.Count(),
                    Total = g.Sum(x => x.Total),
                    WidthPercent = maximo <= 0 ? 0 : g.Count() * 100d / maximo,
                    Color = Palette[index % Palette.Length]
                })
                .OrderByDescending(x => x.Count)
                .ThenByDescending(x => x.Total)
                .Take(5)
                .ToList();
        }
    }

    private string PieStyle => BuildPieStyle(ResumenTipos);

    private static readonly (string Codigo, string Label, string Color)[] DefinicionesTipo =
    [
        (ReporteComprobantesTipos.Factura, "Facturas", "#14B8A6"),
        (ReporteComprobantesTipos.NotaCredito, "Notas de crédito", "#10B981"),
        (ReporteComprobantesTipos.NotaDebito, "Notas de débito", "#F59E0B"),
        (ReporteComprobantesTipos.GuiaRemision, "Guías de remisión", "#8B5CF6"),
        (ReporteComprobantesTipos.Retencion, "Retenciones", "#F97316"),
        (ReporteComprobantesTipos.LiquidacionCompra, "Liquidaciones", "#EC4899")
    ];

    private static readonly string[] Palette = ["#F59E0B", "#10B981", "#8B5CF6", "#F97316", "#EC4899"];

    protected override async Task OnInitializedAsync()
    {
        if (string.Equals(AutorizacionQuery, DocumentoAutorizacionHelper.FiltroPendientes, StringComparison.OrdinalIgnoreCase))
            autorizacionFiltro = DocumentoAutorizacionHelper.FiltroPendientes;

        await RecargarAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!cargando)
        {
            await RenderReportDocumentChartsIfNeededAsync();
        }
    }

    private async Task RecargarAsync()
    {
        cargando = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            isDemoMode = EsRutaDemoDocumentos();
            if (isDemoMode)
            {
                reporte = DemoCatalogService.GetReporteComprobantesDemo();
            }
            else
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var idClaim = authState.User.FindFirst("IdUsuario")?.Value;
                currentUserId = int.TryParse(idClaim, out var id) ? id : 0;
                if (currentUserId <= 0)
                {
                    Navigation.NavigateTo("/", true);
                    return;
                }

                reporte = await ReporteComprobantesService.ObtenerReporteUsuarioAsync(currentUserId);
            }

            paginaActual = 1;
            reportChartsSignature = string.Empty;
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"No se pudo actualizar el reporte: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task RenderReportDocumentChartsIfNeededAsync()
    {
        var resumenTipos = ResumenTipos;
        var topTerceros = TopTerceros;
        var signature = BuildReportChartSignature(resumenTipos, topTerceros);

        if (string.Equals(signature, reportChartsSignature, StringComparison.Ordinal))
        {
            return;
        }

        reportChartsSignature = signature;

        var payload = new
        {
            documentTypes = new
            {
                labels = resumenTipos.Select(x => x.Label).ToArray(),
                values = resumenTipos.Select(x => x.Count).ToArray(),
                colors = resumenTipos.Select(x => x.Color).ToArray()
            },
            topThirdParties = new
            {
                labels = topTerceros.Select(x => x.Label).ToArray(),
                values = topTerceros.Select(x => x.Count).ToArray(),
                totals = topTerceros.Select(x => x.Total).ToArray(),
                colors = topTerceros.Select(x => x.Color).ToArray()
            }
        };

        await JS.InvokeVoidAsync("numericaDashboardCharts.renderReportDocuments", payload);
    }

    private static string BuildReportChartSignature(
        IEnumerable<ResumenTipoVista> resumenTipos,
        IEnumerable<ResumenTerceroVista> topTerceros)
    {
        var tipos = string.Join("|", resumenTipos.Select(x => $"{x.Codigo}:{x.Count}:{x.Total:0.##}"));
        var terceros = string.Join("|", topTerceros.Select(x => $"{x.Label}:{x.Count}:{x.Total:0.##}"));
        return $"{tipos}::{terceros}";
    }

    private Task OnFiltersChanged()
    {
        paginaActual = 1;
        return Task.CompletedTask;
    }

    private void LimpiarFiltros()
    {
        tipoDocumentoFiltro = ReporteComprobantesCategoriaDetalle.Todos;
        clienteFiltro = string.Empty;
        productoFiltro = string.Empty;
        categoriaDetalleFiltro = ReporteComprobantesCategoriaDetalle.Todos;
        estadoFiltro = ReporteComprobantesCategoriaDetalle.Todos;
        autorizacionFiltro = DocumentoAutorizacionHelper.FiltroTodos;
        fechaDesde = null;
        fechaHasta = null;
        paginaActual = 1;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
        {
            paginaActual--;
        }
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
        {
            paginaActual++;
        }
    }

    private async Task AbrirXmlAsync(ReporteComprobanteItemDto item)
    {
        if (isDemoMode)
