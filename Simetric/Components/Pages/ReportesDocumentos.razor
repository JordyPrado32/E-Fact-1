    private async Task ExportarPdfAsync()
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync("Abriendo un reporte PDF demo de ejemplo.");
            await JS.InvokeVoidAsync("open", "/reportes_documentos/reporte_documentos_20260508_164759.pdf", "_blank");
            return;
        }

        var items = ItemsFiltrados;
        if (items.Count == 0)
        {
            await AlertService.ShowInfoAsync("No hay datos visibles para exportar con los filtros actuales.");
            return;
        }

        exportandoPdf = true;

        try
        {
            var itemsExportacion = PrepararItemsExportacion(items);

            var request = new ReporteComprobantesPdfRequest
            {
                NombreEmisor = reporte.NombreEmisor,
                RucEmisor = reporte.RucEmisor,
                NombreUsuario = reporte.NombreUsuario,
                GeneradoEn = DateTime.Now,
                Filtros = new ReporteComprobantesFiltroDto
                {
                    TipoDocumento = tipoDocumentoFiltro,
                    FechaDesde = fechaDesde,
                    FechaHasta = fechaHasta,
                    Cliente = clienteFiltro,
                    Producto = productoFiltro,
                    CategoriaDetalle = categoriaDetalleFiltro,
                    EstadoDocumento = estadoFiltro,
                    Autorizacion = autorizacionFiltro
                },
                Items = itemsExportacion
            };

            var pdfUrl = await ReporteComprobantesPdfService.GenerarPdfAsync(request);
            await JS.InvokeVoidAsync("open", pdfUrl, "_blank");
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync(ex.Message, "No se pudo generar el reporte PDF");
        }
        finally
        {
            exportandoPdf = false;
        }
    }

