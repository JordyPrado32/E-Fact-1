    private List<ReporteComprobanteItemDto> PrepararItemsExportacion(IEnumerable<ReporteComprobanteItemDto> items)
    {
        var resultado = new List<ReporteComprobanteItemDto>();

        foreach (var item in items)
        {
            resultado.Add(new ReporteComprobanteItemDto
            {
                DocumentoId = item.DocumentoId,
                TipoDocumento = item.TipoDocumento,
                TipoDocumentoCodigo = item.TipoDocumentoCodigo,
                FechaEmision = item.FechaEmision,
                NumeroDocumento = item.NumeroDocumento,
                TerceroNombre = item.TerceroNombre,
                TerceroIdentificacion = item.TerceroIdentificacion,
                TerceroRol = item.TerceroRol,
                EstadoDocumento = item.EstadoDocumento,
                BaseImponible = item.BaseImponible,
                Iva = item.Iva,
                Total = item.Total,
                DocumentoRelacionado = item.DocumentoRelacionado,
                ClaveAcceso = item.ClaveAcceso,
                NumeroAutorizacion = item.NumeroAutorizacion,
                EstaAutorizado = item.EstaAutorizado,
                XmlUrl = BuildAbsoluteUrl(item.XmlUrl),
                PdfUrl = BuildAbsoluteUrl(item.PdfUrl),
                ProductosRelacionados = item.ProductosRelacionados.ToList(),
                TieneProducto = item.TieneProducto,
                TieneServicio = item.TieneServicio
            });
        }

        return resultado;
    }

    private bool EsRutaDemoDocumentos() =>
        Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("demo/documentos", StringComparison.OrdinalIgnoreCase);

    private List<ReporteComprobanteItemDto> AplicarFiltros(IEnumerable<ReporteComprobanteItemDto> origen)
    {
        var query = origen.AsEnumerable();

        if (!EsFiltroTodos(tipoDocumentoFiltro))
        {
            var tipoFiltroNormalizado = NormalizarFiltro(tipoDocumentoFiltro);
            query = query.Where(x => NormalizarFiltro(x.TipoDocumentoCodigo) == tipoFiltroNormalizado);
        }

        if (fechaDesde.HasValue)
        {
            query = query.Where(x => x.FechaEmision.HasValue && x.FechaEmision.Value.Date >= fechaDesde.Value.Date);
        }

        if (fechaHasta.HasValue)
        {
            query = query.Where(x => x.FechaEmision.HasValue && x.FechaEmision.Value.Date <= fechaHasta.Value.Date);
        }

        if (!EsFiltroTodos(estadoFiltro))
        {
            var estadoFiltroNormalizado = NormalizarFiltro(estadoFiltro);
            query = query.Where(x => NormalizarFiltro(x.EstadoDocumento) == estadoFiltroNormalizado);
        }

        if (string.Equals(autorizacionFiltro, DocumentoAutorizacionHelper.FiltroAutorizados, StringComparison.OrdinalIgnoreCase))
        {
            query = query.Where(x => x.EstaAutorizado);
        }
        else if (string.Equals(autorizacionFiltro, DocumentoAutorizacionHelper.FiltroPendientes, StringComparison.OrdinalIgnoreCase))
        {
            var estadoPendiente = NormalizarFiltro(DocumentoAutorizacionHelper.EstadoPendiente);
            query = query.Where(x => !x.EstaAutorizado && NormalizarFiltro(x.EstadoDocumento) == estadoPendiente);
        }
        else if (string.Equals(autorizacionFiltro, DocumentoAutorizacionHelper.FiltroNoAutorizados, StringComparison.OrdinalIgnoreCase))
        {
            var estadoNoAutorizado = NormalizarFiltro(DocumentoAutorizacionHelper.EstadoNoAutorizado);
            query = query.Where(x => !x.EstaAutorizado && NormalizarFiltro(x.EstadoDocumento) == estadoNoAutorizado);
        }

        if (!string.IsNullOrWhiteSpace(clienteFiltro))
        {
            var filtro = clienteFiltro.Trim();
            query = query.Where(x =>
                ContieneTexto(x.TerceroNombre, filtro) ||
                ContieneTexto(x.TerceroIdentificacion, filtro));
        }

        if (!string.IsNullOrWhiteSpace(productoFiltro))
        {
            var filtro = productoFiltro.Trim();
            query = query.Where(x =>
                x.ProductosRelacionados.Any(p => ContieneTexto(p, filtro)) ||
                ContieneTexto(x.ResumenProductos, filtro));
        }

        if (string.Equals(NormalizarFiltro(categoriaDetalleFiltro), NormalizarFiltro(ReporteComprobantesCategoriaDetalle.Producto), StringComparison.Ordinal))
        {
            query = query.Where(x => x.TieneProducto);
        }
        else if (string.Equals(NormalizarFiltro(categoriaDetalleFiltro), NormalizarFiltro(ReporteComprobantesCategoriaDetalle.Servicio), StringComparison.Ordinal))
        {
            query = query.Where(x => x.TieneServicio);
        }

        return query
            .OrderByDescending(x => x.FechaEmision ?? DateTime.MinValue)
            .ThenByDescending(x => x.DocumentoId)
            .ToList();
    }

    private static bool EsFiltroTodos(string? valor)
        => string.IsNullOrWhiteSpace(valor) ||
           string.Equals(NormalizarFiltro(valor), NormalizarFiltro(ReporteComprobantesCategoriaDetalle.Todos), StringComparison.Ordinal);

    private static bool ContieneTexto(string? origen, string? filtro)
    {
        var origenNormalizado = NormalizarFiltro(origen);
        var filtroNormalizado = NormalizarFiltro(filtro);

        return filtroNormalizado.Length == 0 || origenNormalizado.Contains(filtroNormalizado, StringComparison.Ordinal);
    }

    private static string NormalizarFiltro(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
        {
            return string.Empty;
        }

        var normalized = valor.Trim().Normalize(System.Text.NormalizationForm.FormD);
        var builder = new System.Text.StringBuilder(normalized.Length);

        foreach (var character in normalized)
        {
            if (CharUnicodeInfo.GetUnicodeCategory(character) != UnicodeCategory.NonSpacingMark)
            {
                builder.Append(char.ToUpperInvariant(character));
            }
        }

        return builder.ToString().Normalize(System.Text.NormalizationForm.FormC);
    }

    private string BuildAbsoluteUrl(string? relativeOrAbsolute)
    {
        if (string.IsNullOrWhiteSpace(relativeOrAbsolute))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(relativeOrAbsolute, UriKind.Absolute, out var absoluteUri))
        {
            return absoluteUri.ToString();
        }

        return new Uri(new Uri(Navigation.BaseUri), relativeOrAbsolute.TrimStart('/')).ToString();
    }

    private static string BuildPieStyle(IEnumerable<ResumenTipoVista> resumen)
    {
        var slices = resumen.Where(x => x.Count > 0).ToList();
        var total = slices.Sum(x => x.Count);
        if (total <= 0)
        {
            return "background: conic-gradient(#dbe7f1 0 100%);";
        }

        var partes = new List<string>();
        double inicio = 0;

        foreach (var item in slices)
        {
            var porcentaje = item.Count * 100d / total;
            var fin = inicio + porcentaje;
            partes.Add(string.Create(
                CultureInfo.InvariantCulture,
                $"{item.Color} {inicio:F2}% {fin:F2}%"));
            inicio = fin;
        }

        return $"background: conic-gradient({string.Join(", ", partes)});";
    }

    private static string FormatearMoneda(decimal valor) => $"$ {valor:N2}";
    private static string FormatearPorcentaje(int valor, int total)
        => total <= 0 ? "0%" : $"{valor * 100d / total:0.#}%";

    private static string ObtenerAnchoPorcentaje(int valor, int total)
        => total <= 0 ? "0" : (valor * 100d / total).ToString("0.##", CultureInfo.InvariantCulture);

    private static string ObtenerAnchoMonto(decimal valor, decimal total)
    {
        if (valor <= 0 || total <= 0)
        {
            return "0";
        }

        var porcentaje = Math.Clamp((double)(valor / total * 100m), 0d, 100d);
        return porcentaje.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private static string ObtenerColorTipo(string codigo) =>
        DefinicionesTipo.FirstOrDefault(x => x.Codigo == codigo).Color ?? "#14B8A6";

    private static string ObtenerClaseEstado(string estado)
    {
        if (DocumentoAutorizacionHelper.EsEstadoAutorizado(estado) || estado.Contains("ACTIVA", StringComparison.OrdinalIgnoreCase))
        {
            return "status-ok";
        }

        if (DocumentoAutorizacionHelper.EsNoAutorizado(estado) ||
            estado.Contains("INACTIVA", StringComparison.OrdinalIgnoreCase) ||
            estado.Contains("ERROR", StringComparison.OrdinalIgnoreCase) ||
            estado.Contains("RECHAZ", StringComparison.OrdinalIgnoreCase))
        {
            return "status-danger";
        }

        return "status-info";
    }

    private static string ObtenerNumeroAutorizacionTexto(ReporteComprobanteItemDto item) =>
        DocumentoAutorizacionHelper.ObtenerNumeroAutorizacionVisual(
            item.EstadoDocumento,
            item.EstaAutorizado,
            item.NumeroAutorizacion);

