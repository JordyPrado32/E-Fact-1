        DocumentoAutorizacionHelper.EstaAutorizado(retencion.Autorizado, retencion.Estado);

    private static string ObtenerEstadoSriTexto(RetencionGeneradaListDto retencion) =>
        ObtenerEstadoSriTexto(retencion.Autorizado, retencion.Estado);

    private static string ObtenerEstadoSriTexto(string? autorizado, string? estadoSri) =>
        DocumentoAutorizacionHelper.ObtenerEstadoVisual(
            estadoSri,
            DocumentoAutorizacionHelper.EstaAutorizado(autorizado, estadoSri));

    private static string ObtenerNumeroAutorizacionTexto(RetencionGeneradaListDto retencion) =>
        ObtenerNumeroAutorizacionTexto(retencion.Autorizado, retencion.Estado, retencion.NumeroAutorizacion);

    private static bool EsNoAutorizada(RetencionGeneradaListDto retencion) =>
        ObtenerEstadoSriTexto(retencion) == DocumentoAutorizacionHelper.EstadoNoAutorizado;

    private static bool PuedeReenviarSri(RetencionGeneradaListDto retencion) =>
        ObtenerEstadoSriTexto(retencion) == DocumentoAutorizacionHelper.EstadoPendiente;

    private static bool EsPendienteSri(RetencionGeneradaListDto retencion)
        => PuedeReenviarSri(retencion);

    private static string ObtenerErrorSriTexto(RetencionGeneradaListDto retencion)
    {
        var mensaje = (retencion.Mensaje ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(mensaje)
            ? "El SRI no devolvio un detalle de error para esta retencion."
            : mensaje;
    }

    private static string ObtenerNumeroAutorizacionTexto(
        string? autorizado,
        string? estadoSri,
        string? numeroAutorizacion) =>
        DocumentoAutorizacionHelper.ObtenerNumeroAutorizacionVisual(
            estadoSri,
            DocumentoAutorizacionHelper.EstaAutorizado(autorizado, estadoSri),
            numeroAutorizacion);

    private static (string Nombres, string Apellidos) ObtenerProveedorLineas(string? proveedor)
    {
        var texto = NormalizarEspacios(proveedor);
        if (string.IsNullOrWhiteSpace(texto))
            return ("Sin proveedor", string.Empty);

        var partes = texto.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (partes.Length <= 2)
            return (texto, string.Empty);

        var nombres = string.Join(' ', partes.Take(2));
        var apellidos = string.Join(' ', partes.Skip(2));
        return (nombres, apellidos);
    }

    private static (string Primera, string Segunda) PartirTextoEnDos(string? valor)
    {
        var texto = NormalizarEspacios(valor);
        if (string.IsNullOrWhiteSpace(texto))
            return ("No disponible", string.Empty);

        var mitad = (int)Math.Ceiling(texto.Length / 2m);
        var espacioCercano = texto.IndexOf(' ', mitad);
        if (espacioCercano > 0 && espacioCercano - mitad <= 8)
            mitad = espacioCercano + 1;

        return (
            texto[..Math.Min(mitad, texto.Length)].Trim(),
            mitad >= texto.Length ? string.Empty : texto[mitad..].Trim());
    }

    private static string NormalizarEspacios(string? valor) =>
        string.Join(' ', (valor ?? string.Empty).Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    private static string ObtenerEstadoSriClase(RetencionGeneradaListDto retencion)
    {
        var estado = ObtenerEstadoSriTexto(retencion);

        return estado == DocumentoAutorizacionHelper.EstadoAutorizado
            ? "status-pill-success"
            : estado == DocumentoAutorizacionHelper.EstadoNoAutorizado
                ? "status-pill-danger"
                : "status-pill-info";
    }

}
