@page "/facturacion/retenciones-generadas"
@page "/demo/retenciones-generadas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.DTOs
@using Simetric.Services
@using Simetric.Models
@attribute [AllowAnonymous]

@inject RetencionGeneradaService RetencionGeneradaService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject SweetAlertService AlertService
@inject IJSRuntime JS
@inject ISimpleExcelExportService SimpleExcelExportService

<PageTitle>Retenciones Generadas</PageTitle>

@{
    var retencionesFiltradas = RetencionesFiltradas;
    var retencionesPaginaActual = RetencionesPaginaActual;
    var totalBaseFiltrada = retencionesFiltradas.Sum(x => x.BaseTotal);
    var totalRetenidoVisible = retencionesPaginaActual.Sum(x => x.TotalRetenido);
    var autorizadas = retencionesFiltradas.Count(EstaAutorizada);
    var noAutorizadas = retencionesFiltradas.Count(x => ObtenerEstadoSriTexto(x) == DocumentoAutorizacionHelper.EstadoNoAutorizado);
    var pendientes = retencionesFiltradas.Count - autorizadas - noAutorizadas;
}

<div class="facturas-shell" data-tour="retgen.page">
    @if (procesandoAccion)
    {
        <div class="facturas-inline-overlay">
            <div class="facturas-inline-overlay-card">
                <span class="spinner-border spinner-border-sm" role="status"></span>
                <div>
                    <strong>@tituloAccionOverlay</strong>
                    <span>@detalleAccionOverlay</span>
                </div>
            </div>
        </div>
    }

    @if (mostrarResultadoOverlay)
    {
        <div class="facturas-inline-overlay" @onclick="CerrarResultadoOverlay">
            <div class="facturas-inline-overlay-card facturas-inline-overlay-card-result @(resultadoOverlayEsError ? "is-error" : "is-success")" @onclick:stopPropagation>
                <div class="overlay-result-icon">
                    <i class="bi @(resultadoOverlayEsError ? "bi-exclamation-triangle" : "bi-check-circle")"></i>
                </div>
                <div>
                    <strong>@tituloResultadoOverlay</strong>
                    <span>@detalleResultadoOverlay</span>
                </div>
                <button type="button" class="overlay-close-btn" @onclick="CerrarResultadoOverlay">Cerrar</button>
            </div>
        </div>
    }

    @if (idDocumentoMenuAbierto.HasValue)
    {
        <div class="row-menu-backdrop" @onclick="CerrarMenus"></div>
    }
    <section class="facturas-hero" data-tour="retgen.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Retenciones emitidas</span>
            <h2>Mis retenciones con filtros, reporte y acciones unificadas</h2>
            <p>
                Busca por proveedor, comprobante o documento sustento, revisa el estado y exporta la
                consulta visible con el mismo diseno del resto de documentos.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Retenciones filtradas</span>
                <strong>@retencionesFiltradas.Count</strong>
                <small>@ResumenRangoFechas</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Base filtrada</span>
                <strong>$ @totalBaseFiltrada.ToString("N2")</strong>
                <small>Base acumulada de los comprobantes visibles en la consulta.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Autorizadas</span>
                <strong>@autorizadas</strong>
                <small>Pendientes: @pendientes | No autorizadas: @noAutorizadas</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="retgen.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Busqueda y control</span>
            <h3>Retenciones generadas</h3>
            <p>Combina texto y rango de fechas para ubicar cualquier comprobante retenido.</p>
            @if (isDemoMode)
            {
                <p class="text-muted mb-0">Modo demo: puedes explorar filtros y detalles, pero XML, PDF y exportaciones están bloqueados.</p>
            }
        </div>

        <div class="toolbar-actions toolbar-actions-expanded">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>

                <input class="search-input"
                       placeholder="Buscar por numero, sustento, proveedor o identificacion"
                       @bind="Filtro"
                       @bind:event="oninput" />

                @if (!string.IsNullOrWhiteSpace(Filtro))
                {
                    <button class="search-clear" type="button" @onclick="LimpiarTexto" aria-label="Limpiar busqueda">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>

            <div class="date-filter-group">
                <label class="date-filter-box">
                    <span>Desde</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaDesde" />
                </label>

                <label class="date-filter-box">
                    <span>Hasta</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaHasta" />
                </label>
            </div>

            <button class="report-btn" type="button" @onclick="DescargarReporteAsync">
                <i class="bi bi-file-earmark-spreadsheet"></i>
                <span>Descargar Excel</span>
            </button>

            <button class="refresh-btn" type="button" @onclick="Recargar">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refrescar</span>
            </button>

            @if (HayFiltrosActivos)
            {
                <button class="filter-reset-btn" type="button" @onclick="LimpiarFiltros">
                    <i class="bi bi-eraser"></i>
                    <span>Limpiar filtros</span>
                </button>
            }
        </div>
    </section>

    @if (cargando)
    {
        <section class="state-card">
            <div class="state-icon">
                <span class="spinner-border"></span>
            </div>
            <h3>Cargando retenciones</h3>
            <p>Estamos organizando tu historial para mostrar el detalle mas reciente.</p>
        </section>
    }
    else if (retencionesFiltradas.Count == 0)
    {
        <section class="state-card state-card-empty">
            <div class="state-icon">
                <i class="bi bi-inbox"></i>
            </div>
            <h3>No hay resultados</h3>
            <p>
                @(HayFiltrosActivos
                    ? "No encontramos retenciones con los filtros aplicados. Ajusta el texto o las fechas."
                    : "Todavia no existen retenciones generadas para mostrar en este panel.")
            </p>
        </section>
    }
    else
    {
        <section class="table-card retenciones-table-card" data-tour="retgen.table">

            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado</span>
                    <h3>Retenciones</h3>
                    <p>Consulta documento sustento, proveedor, estado, base y valor retenido.</p>
                </div>

                <div class="table-head-actions">
                    <label class="page-size-box" for="ret-page-size">
                        <span>Ver</span>

                        <select id="ret-page-size" class="page-size-select" @bind="RegistrosPorPagina">
                            @foreach (var opcion in pageSizeOptions)
                            {
                                <option value="@opcion">@opcion</option>
                            }
                        </select>

                        <span>registros</span>
                    </label>
                </div>
            </div>

            <div class="table-wrap list-table-wrap retenciones-table-wrap">
                <table class="table table-hover align-middle mb-0 facturas-table responsive-list-table retenciones-generated-table">
                    <colgroup>
                        <col class="ret-col-number" />
                        <col class="ret-col-date" />
                        <col class="ret-col-support" />
                        <col class="ret-col-provider" />
                        <col class="ret-col-status" />
                        <col class="ret-col-base" />
                        <col class="ret-col-withheld" />
                        <col class="ret-col-actions" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Numero</th>
                            <th>Fecha</th>
                            <th>Documento sustento</th>
                            <th>Proveedor</th>
                            <th>Estado</th>
                            <th class="text-end">Base</th>
                            <th class="text-end">Retenido</th>
                            <th class="text-end actions-header-otros">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var retencionEntry in retencionesPaginaActual.Select((item, index) => new { Item = item, Index = index }))
                        {
                            var item = retencionEntry.Item;
                            var openUp = retencionEntry.Index >= retencionesPaginaActual.Count - 2 && retencionesPaginaActual.Count > 2;
                            var proveedorLineas = ObtenerProveedorLineas(item.Proveedor);
                            var autorizacionLineas = PartirTextoEnDos(ObtenerNumeroAutorizacionTexto(item));
                            <tr>
                                <td data-label="Numero">
                                    <span class="invoice-pill retention-number-wrap" title="@item.NumeroCompleto">
                                        @item.NumeroCompleto
                                    </span>
                                </td>

                                <td data-label="Fecha">
                                    <span class="invoice-id">
                                        @(item.Fecha?.ToString("dd/MM/yyyy") ?? "")
                                    </span>
                                </td>

                                <td data-label="Documento sustento">
                                    <span class="invoice-id retention-doc-wrap" title="@item.DocumentoSustento">
                                        @item.DocumentoSustento
                                    </span>
                                </td>

                                <td data-label="Proveedor">
                                    <div class="client-cell provider-cell">
                                        <strong title="@item.Proveedor">@proveedorLineas.Nombres</strong>
                                        @if (!string.IsNullOrWhiteSpace(proveedorLineas.Apellidos))
                                        {
                                            <span class="provider-lastnames" title="@item.Proveedor">@proveedorLineas.Apellidos</span>
                                        }
                                        <span class="provider-id">@item.IdentificacionProveedor</span>
                                    </div>
                                </td>
                                 <td data-label="Estado">
                                     <div class="client-cell">
                                          <span class="ret-status-line">
                                              <span class="status-pill @ObtenerEstadoSriClase(item)">
                                                  @ObtenerEstadoSriTexto(item)
                                              </span>
                                              @if (EsNoAutorizada(item))
                                              {
                                                  <button class="ret-status-info-btn"
                                                          type="button"
                                                          title="@ObtenerErrorSriTexto(item)"
                                                          @onclick="() => MostrarErrorSriRetencion(item)">
                                                      <i class="bi bi-info-circle-fill"></i>
                                                  </button>
                                              }
                                          </span>
                                          <span class="authorization-number authorization-number-wrap-half" title="@ObtenerNumeroAutorizacionTexto(item)">
                                              <span class="authorization-label">Autorizacion:</span>
                                              <span class="authorization-line">@autorizacionLineas.Primera</span>
                                              @if (!string.IsNullOrWhiteSpace(autorizacionLineas.Segunda))
                                              {
                                                  <span class="authorization-line">@autorizacionLineas.Segunda</span>
                                              }
                                          </span>
                                          @if (EsPendienteSri(item))
                                          {
                                              <button class="ret-sri-retry-btn"
                                                      type="button"
                                                      disabled="@procesandoAccion"
                                                      @onclick="() => ReintentarSriAsync(item.Sec)">
                                                  <i class="bi bi-send-fill"></i> Reenviar
                                              </button>
                                          }
                                      </div>
                                  </td>

                                <td class="text-end" data-label="Base">
                                    <span class="amount-pill">
                                        <span class="currency-symbol">$</span>
                                        <span class="currency-value">@item.BaseTotal.ToString("N2")</span>
                                    </span>
                                </td>

                                <td class="text-end" data-label="Retenido">
                                    <span class="amount-pill">
                                        <span class="currency-symbol">$</span>
                                        <span class="currency-value">@item.TotalRetenido.ToString("N2")</span>
                                    </span>
                                </td>
                                 <td class="text-end actions-cell" data-label="Acciones">
                                       <!-- Desktop: Inline summarized compact icon buttons -->
                                       <div class="actions-desktop-inline gap-1 justify-content-end row-actions-inline-desktop">
                                           <button class="row-action-btn row-action-view"
                                                   type="button"
                                                   title="Ver"
                                                   @onclick="() => VerRetencionAsync(item.Sec)">
                                               <i class="bi bi-eye"></i>
                                           </button>

                                           <button class="row-action-btn row-action-xml"
                                                   type="button"
                                                   title="Descargar XML"
                                                   @onclick="() => AbrirXmlAsync(item.Sec)">
                                               <i class="bi bi-filetype-xml"></i>
                                           </button>

                                            <button class="row-action-btn row-action-pdf"
                                                    type="button"
                                                    title="Descargar PDF"
                                                    @onclick="() => AbrirPdfAsync(item.Sec)">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </button>

                                            @if (PuedeReenviarSri(item))
                                            {
                                                <button class="row-action-btn row-action-sri"
                                                        type="button"
                                                        title="Enviar al SRI"
                                                        @onclick="() => ReintentarSriAsync(item.Sec)">
                                                    <i class="bi bi-send-check"></i>
                                                </button>
                                            }

                                            <button class="row-action-btn row-action-mail"
                                                    type="button"
                                                    title="Reenviar correo"
                                                    @onclick="() => ReenviarCorreoAsync(item.Sec)">
                                                <i class="bi bi-envelope-paper"></i>
                                            </button>
                                        </div>

                                       <!-- Mobile: Dropdown -->
                                       <div class="actions-mobile-dropdown row-actions-dropdown @(openUp ? "dropdown-open-up" : "")">
                                           <button class="row-actions-trigger" type="button" @onclick="() => ToggleMenu(item.Sec)" @onclick:stopPropagation>
                                               <i class="bi bi-three-dots"></i>
                                           </button>
                                           @if (idDocumentoMenuAbierto == item.Sec)
                                           {
                                               <div class="action-dropdown-menu">
                                                   <button class="action-dropdown-item item-view" type="button" @onclick="async () => { CerrarMenus(); await VerRetencionAsync(item.Sec); }">
                                                           <i class="bi bi-eye"></i>
                                                           <span>Ver</span>
                                                       </button>
                                                   <button class="action-dropdown-item item-xml" type="button" @onclick="async () => { CerrarMenus(); await AbrirXmlAsync(item.Sec); }">
                                                        <i class="bi bi-filetype-xml"></i>
                                                        <span>Descargar XML</span>
                                                    </button>
                                                     <button class="action-dropdown-item item-pdf" type="button" @onclick="async () => { CerrarMenus(); await AbrirPdfAsync(item.Sec); }">
                                                         <i class="bi bi-file-earmark-pdf"></i>
                                                         <span>Descargar PDF</span>
                                                     </button>
                                                    @if (PuedeReenviarSri(item))
                                                    {
                                                        <button class="action-dropdown-item item-sri" type="button" @onclick="async () => { CerrarMenus(); await ReintentarSriAsync(item.Sec); }">
                                                            <i class="bi bi-send-check"></i>
                                                            <span>Enviar al SRI</span>
                                                        </button>
                                                    }
                                                    <button class="action-dropdown-item item-mail" type="button" @onclick="async () => { CerrarMenus(); await ReenviarCorreoAsync(item.Sec); }">
                                                        <i class="bi bi-envelope-arrow-up"></i>
                                                        <span>Reenviar correo</span>
                                                    </button>
                                                </div>
                                            }
                                       </div>
                                  </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <div class="footer-metrics">
                    <div class="footer-metric">
                        <span class="footer-label">Resultados visibles</span>
                        <strong>@retencionesPaginaActual.Count</strong>
                    </div>

                    <div class="footer-metric">
                        <span class="footer-label">Resultados filtrados</span>
                        <strong>@retencionesFiltradas.Count</strong>
                    </div>

                    <div class="footer-metric footer-metric-highlight">
                        <span class="footer-label">Retenido visible</span>
                        <strong>$ @totalRetenidoVisible.ToString("N2")</strong>
                    </div>
                </div>

                @if (TotalPaginas > 1)
                {
                    <nav class="pagination-nav" aria-label="Paginacion de retenciones">
                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaAnterior"
                                disabled="@(PaginaActualSegura == 1)">
                            <i class="bi bi-chevron-left"></i>
                            <span>Anterior</span>
                        </button>

                        @foreach (var pagina in PaginasVisibles)
                        {
                            var paginaLocal = pagina;
                            <button class="pagination-btn @(paginaLocal == PaginaActualSegura ? "is-active" : null)"
                                    @onclick="() => IrAPagina(paginaLocal)">
                                @paginaLocal
                            </button>
                        }

                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaSiguiente"
                                disabled="@(PaginaActualSegura == TotalPaginas)">
                            <span>Siguiente</span>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </nav>
                }
            </div>

        </section>
    }

</div>

@if (mostrarModal && retencionSeleccionada != null)
{
    <div class="factura-modal-backdrop" @onclick="CerrarModal"></div>

    <div class="modal fade show d-block factura-modal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable factura-modal-dialog">
            <div class="modal-content factura-modal-content">

                <div class="modal-header factura-modal-header">
                    <div>
                        <span class="modal-kicker">Comprobante generado</span>
                        <h5 class="modal-title mb-0">
                            Retención @retencionSeleccionada.NumeroCompleto
                        </h5>
                    </div>

                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>

                <div class="modal-body factura-modal-body">

                    <div class="rt-preview-shell">

                        <div class="rt-preview-top">
                            <div class="rt-company-card">
                                <h4>@(retencionSeleccionada.Emisor?.RazonSocial ?? "EMISOR")</h4>
                                <div><strong>RUC:</strong> @(retencionSeleccionada.Emisor?.Ruc ?? "")</div>
                                <div><strong>Dirección:</strong> @(retencionSeleccionada.Emisor?.DireccionMatriz ?? retencionSeleccionada.Emisor?.Direccion ?? "")</div>
                                <div><strong>Obligado contabilidad:</strong> @(retencionSeleccionada.Emisor?.LlevaContabilidad ?? "NO")</div>
                            </div>

                            <div class="rt-doc-card">
                                <div class="rt-doc-title">COMPROBANTE DE RETENCIÓN</div>
                                <div><strong>No.:</strong> @retencionSeleccionada.NumeroCompleto</div>
                                <div><strong>Fecha emisión:</strong> @(retencionSeleccionada.RetencionInfo.Fecha?.ToString("dd/MM/yyyy") ?? "")</div>
                                <div><strong>Periodo fiscal:</strong> @(retencionSeleccionada.RetencionInfo.PeriodoFiscal ?? "")</div>
                                <div><strong>Estado SRI:</strong> @ObtenerEstadoSriTexto(retencionSeleccionada.RetencionInfo.Autorizado, retencionSeleccionada.RetencionInfo.Estado)</div>
                                <div><strong>Numero de autorizacion:</strong> @ObtenerNumeroAutorizacionTexto(retencionSeleccionada.RetencionInfo.Autorizado, retencionSeleccionada.RetencionInfo.Estado, retencionSeleccionada.RetencionInfo.NumAutorizacion)</div>
                                @if (!DocumentoAutorizacionHelper.EstaAutorizado(retencionSeleccionada.RetencionInfo.Autorizado, retencionSeleccionada.RetencionInfo.Estado) &&
                                    !string.IsNullOrWhiteSpace(retencionSeleccionada.RetencionInfo.Clave))
                                {
                                    <div><strong>Clave de acceso:</strong> @retencionSeleccionada.RetencionInfo.Clave</div>
                                }
                            </div>
                        </div>

                        <div class="rt-section-card">
                            <div class="rt-section-title">Datos del proveedor</div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <strong>Proveedor:</strong><br />
                                    @NombreProveedorDetalle
                                </div>

                                <div class="col-md-3">
                                    <strong>Identificación:</strong><br />
                                    @(retencionSeleccionada.Proveedor?.ruc ?? retencionSeleccionada.RetencionInfo.IdCliente ?? "")
                                </div>

                                <div class="col-md-3">
                                    <strong>Tipo identificación:</strong><br />
                                    @(@retencionSeleccionada.TipoIdentificacionProveedor ?? "")
                                </div>
                            </div>
                        </div>

                        <div class="rt-section-card">
                            <div class="rt-section-title">Documento sustento</div>

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <strong>Factura sustento:</strong><br />
                                    @retencionSeleccionada.DocumentoSustentoVisual
                                </div>

                                <div class="col-md-4">
                                    <strong>Total sin impuestos:</strong><br />
                                    $ @((retencionSeleccionada.Compra?.Subtotal ?? 0m).ToString("N2"))
                                </div>

                                <div class="col-md-4">
                                    <strong>Total factura:</strong><br />
                                    $ @((retencionSeleccionada.Compra?.ValorTotal ?? 0m).ToString("N2"))
                                </div>
                            </div>
                        </div>

                        <div class="rt-section-card">
                            <div class="rt-section-title">Detalle de retenciones</div>

                            <div class="table-wrap">
                                <table class="table table-hover align-middle mb-0 facturas-table">
                                    <thead>
                                        <tr>
                                            <th>Tipo</th>
                                            <th>Código</th>
                                            <th>Descripción</th>
                                            <th class="text-end">Base</th>
                                            <th class="text-end">% Ret.</th>
                                            <th class="text-end">Valor retenido</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (retencionSeleccionada.Retenciones.Any())
                                        {
                                            @foreach (var d in retencionSeleccionada.Retenciones)
                                            {
                                                <tr>
                                                    <td>@d.Tipo</td>
                                                    <td>@d.CodigoRetencion</td>
                                                    <td>@d.Descripcion</td>
                                                    <td class="text-end">@d.BaseImponible.ToString("N2")</td>
                                                    <td class="text-end">@d.PorcentajeRetener.ToString("N2")</td>
                                                    <td class="text-end">@d.ValorRetenido.ToString("N2")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="6" class="text-center py-4">
                                                    No se encontraron líneas de retención.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="rt-totals-row">
                            <div class="rt-total-card">
                                <span>Base total</span>
                                <strong>$ @retencionSeleccionada.BaseTotal.ToString("N2")</strong>
                            </div>

                            <div class="rt-total-card rt-total-card-main">
                                <span>Total retenido</span>
                                <strong>$ @retencionSeleccionada.TotalRetenido.ToString("N2")</strong>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="modal-footer factura-modal-footer">
                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirXmlAsync(retencionSeleccionada.RetencionInfo.Sec)">
                        Abrir XML
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(retencionSeleccionada.RetencionInfo.Sec)">
                        Abrir PDF A4
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(retencionSeleccionada.RetencionInfo.Sec, FormatoImpresionDocumento.Termica80mm)">
