    private int currentUserId;
    private bool cargando = true;
    private bool isDemoMode;
    private bool procesandoAccion;
    private bool mostrarResultadoOverlay;
    private bool resultadoOverlayEsError;
    private string tituloAccionOverlay = "Procesando retencion";
    private string detalleAccionOverlay = "Espera un momento.";
    private string tituloResultadoOverlay = string.Empty;
    private string detalleResultadoOverlay = string.Empty;

    private List<RetencionGeneradaListDto> retenciones = new();

    private readonly int[] pageSizeOptions = { 5, 10, 20, 50 };
    private int paginaActual = 1;
    private int registrosPorPagina = 10;

    private bool mostrarModal;
    private RetencionGeneradaDetalleViewDto? retencionSeleccionada;
    private string filtro = string.Empty;
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;

    private int RegistrosPorPagina
    {
        get => registrosPorPagina;
        set
        {
            registrosPorPagina = value;
            paginaActual = 1;
        }
    }

    private string Filtro
    {
        get => filtro;
        set
        {
            if (filtro == value)
                return;

            filtro = value;
            paginaActual = 1;
        }
    }

    private DateTime? FechaDesde
    {
        get => fechaDesde;
        set
        {
            if (fechaDesde == value)
                return;

            fechaDesde = value;
            paginaActual = 1;
        }
    }

    private DateTime? FechaHasta
    {
        get => fechaHasta;
        set
        {
            if (fechaHasta == value)
                return;

            fechaHasta = value;
            paginaActual = 1;
        }
    }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(Filtro) || FechaDesde.HasValue || FechaHasta.HasValue;

    private string ResumenRangoFechas
    {
        get
        {
            if (FechaDesde.HasValue && FechaHasta.HasValue)
                return $"{FechaDesde.Value:dd/MM/yyyy} al {FechaHasta.Value:dd/MM/yyyy}";

            if (FechaDesde.HasValue)
                return $"Desde {FechaDesde.Value:dd/MM/yyyy}";

            if (FechaHasta.HasValue)
                return $"Hasta {FechaHasta.Value:dd/MM/yyyy}";

            return "Todas las fechas";
        }
    }

    private string NombreProveedorDetalle =>
        retencionSeleccionada?.Proveedor != null
            ? (!string.IsNullOrWhiteSpace(retencionSeleccionada.Proveedor.nombre)
                ? retencionSeleccionada.Proveedor.nombre!
                : ((retencionSeleccionada.Proveedor.primerNombre ?? "") + " " +
                   (retencionSeleccionada.Proveedor.segundoNombre ?? "") + " " +
                   (retencionSeleccionada.Proveedor.primerApellido ?? "") + " " +
                   (retencionSeleccionada.Proveedor.segundoApellido ?? "")).Trim())
            : "";

    private List<RetencionGeneradaListDto> RetencionesFiltradas =>
        retenciones
            .Where(CumpleFiltroRetencion)
            .ToList();

    private List<RetencionGeneradaListDto> RetencionesPaginaActual =>
        RetencionesFiltradas
            .Skip((PaginaActualSegura - 1) * registrosPorPagina)
            .Take(registrosPorPagina)
            .ToList();

    private int TotalPaginas =>
        RetencionesFiltradas.Count == 0
            ? 0
            : (int)Math.Ceiling(RetencionesFiltradas.Count / (double)registrosPorPagina);

    private int PaginaActualSegura =>
        TotalPaginas == 0
            ? 1
            : Math.Min(paginaActual, TotalPaginas);

    private int RegistroInicialPagina =>
        RetencionesFiltradas.Count == 0 ? 0 : ((PaginaActualSegura - 1) * registrosPorPagina) + 1;

    private int RegistroFinalPagina =>
        RetencionesFiltradas.Count == 0 ? 0 : Math.Min(PaginaActualSegura * registrosPorPagina, RetencionesFiltradas.Count);

    private IEnumerable<int> PaginasVisibles
    {
        get
        {
            if (TotalPaginas == 0)
                return Array.Empty<int>();

            var inicio = Math.Max(1, PaginaActualSegura - 2);
            var fin = Math.Min(TotalPaginas, inicio + 4);

            if (fin - inicio < 4)
                inicio = Math.Max(1, fin - 4);

            return Enumerable.Range(inicio, fin - inicio + 1);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        isDemoMode = EsRutaDemoRetenciones();
        await Recargar();
    }

    private async Task Recargar()
    {
        cargando = true;

        if (isDemoMode)
        {
            retenciones = CrearDemoRetenciones();
            paginaActual = 1;
            cargando = false;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaim = authState.User.FindFirst("IdUsuario")?.Value;

        currentUserId = int.TryParse(userClaim, out var id) ? id : 0;

        if (currentUserId <= 0)
        {
            NavManager.NavigateTo("/", true);
            return;
        }

        retenciones = await RetencionGeneradaService.ListarRetencionesUsuarioAsync(currentUserId);
        paginaActual = 1;

        cargando = false;
    }

    private bool CumpleFiltroRetencion(RetencionGeneradaListDto item)
    {
        if (!string.IsNullOrWhiteSpace(Filtro))
        {
            var filtroActual = Filtro.Trim();
            var coincideTexto =
                (item.NumeroRetencion ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.NumeroCompleto ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.DocumentoSustento ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.Proveedor ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.IdentificacionProveedor ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.Estado ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.NumeroAutorizacion ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                ObtenerEstadoSriTexto(item).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (item.Clave ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase);

            if (!coincideTexto)
                return false;
        }

        var fechaReferencia = item.Fecha?.Date;

        if (FechaDesde.HasValue && (!fechaReferencia.HasValue || fechaReferencia.Value < FechaDesde.Value.Date))
            return false;

        if (FechaHasta.HasValue && (!fechaReferencia.HasValue || fechaReferencia.Value > FechaHasta.Value.Date))
            return false;

        return true;
    }

    private async Task VerRetencionAsync(int sec)
    {
        if (isDemoMode)
        {
            retencionSeleccionada = CrearDemoDetalleRetencion(sec);
        }
        else
        {
            retencionSeleccionada =
                await RetencionGeneradaService.GetRetencionDetalleUsuarioAsync(sec, currentUserId);
        }

        if (retencionSeleccionada != null)
            mostrarModal = true;
    }

    private async Task AbrirXmlAsync(int sec)
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync("Abriendo XML demo de retención.");
            await JS.InvokeVoidAsync("open", ObtenerDemoXmlRetencion(sec), "_blank");
            return;
        }

        var xmlUrl = await RetencionGeneradaService.AsegurarXmlRetencionUsuarioAsync(sec, currentUserId);
        if (string.IsNullOrWhiteSpace(xmlUrl))
        {
            await AlertService.ShowWarningAsync("No se pudo ubicar el XML de la retencion.");
            return;
        }

        await JS.InvokeVoidAsync("open", xmlUrl, "_blank");
    }

    private async Task AbrirPdfAsync(int sec, FormatoImpresionDocumento formato = FormatoImpresionDocumento.A4)
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync($"Abriendo PDF demo {formato.ObtenerEtiqueta()} de retención.");
            await JS.InvokeVoidAsync("open", ObtenerDemoPdfRetencion(formato), "_blank");
            return;
        }

        var pdfUrl = await RetencionGeneradaService.AsegurarPdfRetencionUsuarioAsync(sec, currentUserId, formato);
        if (string.IsNullOrWhiteSpace(pdfUrl))
        {
            await AlertService.ShowWarningAsync($"No se pudo generar o ubicar el PDF {formato.ObtenerEtiqueta()} de la retencion.");
            return;
        }

        await JS.InvokeVoidAsync("open", pdfUrl, "_blank");
    }

    private async Task ReintentarSriAsync(int sec)
    {
        if (isDemoMode)
        {
            MostrarResultadoOverlay("Modo demo", "La emision al SRI esta bloqueada en la demo.");
            return;
        }

        procesandoAccion = true;
        tituloAccionOverlay = "Enviando retencion al SRI";
        detalleAccionOverlay = "Estamos firmando el XML, consultando autorizacion y actualizando el estado.";

        try
        {
            var resultado = await RetencionGeneradaService.EmitirRetencionSriAsync(sec, currentUserId, intentarEnviarCorreo: true);
            await Recargar();

            if (mostrarModal)
                retencionSeleccionada = await RetencionGeneradaService.GetRetencionDetalleUsuarioAsync(sec, currentUserId);

            if (string.Equals(resultado.estado, DocumentoAutorizacionHelper.EstadoAutorizado, StringComparison.OrdinalIgnoreCase))
            {
                MostrarResultadoOverlay(
                    "Retencion autorizada",
                    string.IsNullOrWhiteSpace(resultado.mensaje) ? "La retencion se autorizo correctamente en el SRI." : resultado.mensaje);
            }
            else
            {
                MostrarResultadoOverlay(
                    "Retencion pendiente",
                    string.IsNullOrWhiteSpace(resultado.mensaje) ? "La retencion sigue pendiente o con observaciones del SRI." : resultado.mensaje,
                    string.Equals(resultado.estado, "ERROR", StringComparison.OrdinalIgnoreCase));
            }
        }
        finally
        {
            procesandoAccion = false;
        }
    }

    private async Task ReenviarCorreoAsync(int sec)
    {
        if (isDemoMode)
        {
            MostrarResultadoOverlay("Modo demo", "El reenvio de correo esta bloqueado en la demo.");
            return;
        }

        procesandoAccion = true;
        tituloAccionOverlay = "Reenviando retencion por correo";
        detalleAccionOverlay = "Estamos validando destinatarios y regenerando los adjuntos necesarios.";

        try
        {
            var resultado = await RetencionGeneradaService.IntentarEnviarRetencionPorCorreoAsync(sec);
            await Recargar();

            if (mostrarModal)
                retencionSeleccionada = await RetencionGeneradaService.GetRetencionDetalleUsuarioAsync(sec, currentUserId);

            var esError = !(resultado.Enviado || resultado.YaEnviado || resultado.PendienteAutorizacion || resultado.SinDestinatarios);
            MostrarResultadoOverlay(
                esError ? "No se pudo reenviar" : "Estado del correo actualizado",
                resultado.Mensaje,
                esError);
        }
        finally
        {
            procesandoAccion = false;
        }
    }

