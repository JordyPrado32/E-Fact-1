@* ============================================================
   E-Declara / Configuración — Parámetros
   Ruta: /e-declara/configuracion/parametros
   ============================================================ *@
@page "/e-declara/configuracion/parametros"
@rendermode InteractiveServer
@inject NavigationManager NavManager

<PageTitle>Parámetros | E-Declara</PageTitle>

<div class="edeclara-page">
    <section class="edeclara-overview">
        <article class="edeclara-spotlight">
            <div class="section-head section-head-tight">
                <div>
                    <span class="section-kicker">Configuración · E-Declara</span>
                    <h3>Parámetros</h3>
                </div>
                <button type="button" class="primary-btn">
                    <i class="bi bi-plus-lg"></i>
                    <span>Nuevo parámetro</span>
                </button>
            </div>
            <p class="summary-spotlight-copy">
                Administra los parámetros generales del módulo E-Declara.
            </p>
        </article>
    </section>

    <section class="edeclara-grid">
        <article class="edeclara-panel" style="grid-column: 1 / -1;">
            <div class="empty-panel">
                <i class="bi bi-sliders"></i>
                <p>La tabla de parámetros se implementará aquí.</p>
            </div>
        </article>
    </section>
</div>

@code { }
