@* ============================================================
   E-Declara / Configuración — Tipos de Declaración
   Ruta: /e-declara/configuracion/tipos-declaracion
   ============================================================ *@
@page "/e-declara/configuracion/tipos-declaracion"
@rendermode InteractiveServer
@inject NavigationManager NavManager

<PageTitle>Tipos de Declaración | E-Declara</PageTitle>

<div class="edeclara-page">
    <section class="edeclara-overview">
        <article class="edeclara-spotlight">
            <div class="section-head section-head-tight">
                <div>
                    <span class="section-kicker">Configuración · E-Declara</span>
                    <h3>Tipos de Declaración</h3>
                </div>
                <button type="button" class="primary-btn">
                    <i class="bi bi-plus-lg"></i>
                    <span>Nuevo tipo</span>
                </button>
            </div>
            <p class="summary-spotlight-copy">
                Configura los distintos tipos de declaración que maneja el sistema tributario.
            </p>
        </article>
    </section>

    <section class="edeclara-grid">
        <article class="edeclara-panel" style="grid-column: 1 / -1;">
            <div class="empty-panel">
                <i class="bi bi-file-earmark-ruled"></i>
                <p>La tabla de tipos de declaración se implementará aquí.</p>
            </div>
        </article>
    </section>
</div>

@code { }
