@page "/e-declara/soporte"
@inject NavigationManager Nav

<PageTitle>Soporte | E-Declara</PageTitle>

<div class="support-shell">
    <section class="support-hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Centro de ayuda</span>
            <h2>Soporte E-Declara</h2>
            <p>
                Encuentra respuestas concretas sobre el uso diario de E-Declara y contacta
                al equipo de atención cuando necesites acompañamiento.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Horario</span>
                <strong>09:00</strong>
                <small>Lunes a viernes hasta las 18:00.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Canales</span>
                <strong>2</strong>
                <small>WhatsApp y correo electrónico.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Guías</span>
                <strong>@faqs.Count</strong>
                <small>Preguntas frecuentes disponibles.</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Atención</span>
            <h3>Canales de soporte</h3>
            <p>Ten a mano el RUC, usuario, pantalla y captura del inconveniente.</p>
        </div>

        <div class="support-actions">
            <button type="button" class="primary-btn whatsapp-btn" @onclick="IrAWhatsApp">
                <i class="bi bi-whatsapp"></i>
                <span>WhatsApp</span>
            </button>
            <a href="mailto:soporte@numericasoftware.com" class="secondary-btn">
                <i class="bi bi-envelope"></i>
                <span>Correo electrónico</span>
            </a>
        </div>
    </section>

    <section class="support-grid">
        <section class="table-card">
            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Preguntas frecuentes</span>
                    <h3>Respuestas rápidas</h3>
                </div>
                <span class="table-badge">@faqs.Count temas</span>
            </div>

            <div class="faq-list">
                @foreach (var item in faqs)
                {
                    var isActive = active == item.Id;
                    <article class="faq-item @(isActive ? "is-active" : string.Empty)">
                        <button type="button"
                                class="faq-button"
                                aria-expanded="@isActive"
                                @onclick="() => Toggle(item.Id)">
                            <span class="faq-icon">
                                <i class="@item.Icon"></i>
                            </span>
                            <span class="faq-question">@item.Pregunta</span>
                            <i class="bi @(isActive ? "bi-chevron-up" : "bi-chevron-down") faq-toggle"></i>
                        </button>

                        @if (isActive)
                        {
                            <div class="faq-answer">@item.Respuesta</div>
                        }
                    </article>
                }
            </div>
        </section>

        <aside class="editor-card support-side-card">
            <div class="editor-head">
                <div>
                    <span class="panel-kicker">Antes de escribir</span>
                    <h3>Datos útiles</h3>
                    <p>Con esta información soporte puede revisar tu caso con mayor rapidez.</p>
                </div>
            </div>

            <div class="support-checklist">
                <div class="support-check-item">
                    <i class="bi bi-person-badge"></i>
                    <span>RUC, usuario y nombre del contribuyente.</span>
                </div>
                <div class="support-check-item">
                    <i class="bi bi-window"></i>
                    <span>Pantalla o módulo donde aparece el problema.</span>
                </div>
                <div class="support-check-item">
                    <i class="bi bi-chat-left-text"></i>
                    <span>Mensaje exacto que muestra el sistema.</span>
                </div>
                <div class="support-check-item">
                    <i class="bi bi-image"></i>
                    <span>Captura completa del error o comportamiento.</span>
                </div>
            </div>
        </aside>
    </section>
</div>

<style>
    .support-shell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-bottom: 1rem;
        font-family: 'Montserrat', sans-serif;
    }

    .support-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.22fr) minmax(300px, 0.88fr);
        gap: 0.85rem;
        padding: 1rem 1.15rem;
        border: 1px solid rgba(108, 99, 255, 0.15);
        border-radius: 28px;
        background:
            radial-gradient(circle at top left, rgba(108, 99, 255, 0.16), transparent 34%),
            linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(246, 250, 254, 0.96));
        box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05);
        align-items: center;
    }

    .hero-eyebrow,
    .toolbar-kicker,
    .table-kicker,
    .panel-kicker {
        display: inline-flex;
        align-items: center;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #6C63FF;
    }

    .hero-copy h2 {
        margin: 0.35rem 0 0.55rem;
        font-size: 1.7rem;
        line-height: 1.05;
        letter-spacing: -0.04em;
        color: #1e293b;
    }

    .hero-copy p,
    .toolbar-copy p,
    .editor-head p {
        margin: 0;
        color: #64748b;
        font-size: 0.88rem;
        line-height: 1.5;
    }

    .hero-summary {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.65rem;
    }

    .summary-card {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding: 0.85rem 0.9rem;
        border-radius: 20px;
        border: 1px solid rgba(108, 99, 255, 0.15);
        background: linear-gradient(180deg, #ffffff, #f8fbff);
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.04);
    }

    .summary-card-primary {
        background: linear-gradient(135deg, rgba(108, 99, 255, 0.12), rgba(255, 255, 255, 0.98));
        border-color: rgba(108, 99, 255, 0.15);
    }

    .summary-label {
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #64748b;
    }

    .summary-card strong {
        font-size: 1.35rem;
        line-height: 1;
        letter-spacing: -0.03em;
        color: #1e293b;
    }

    .summary-card small {
        color: #64748b;
        font-size: 0.8rem;
        line-height: 1.4;
    }

    .toolbar-card,
    .table-card,
    .editor-card {
        border-radius: 24px;
        border: 1px solid rgba(108, 99, 255, 0.15);
        background: rgba(255, 255, 255, 0.95);
        box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05);
    }

    .toolbar-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.1rem;
    }

    .toolbar-copy h3,
    .table-card-head h3,
    .editor-head h3 {
        margin: 0.45rem 0 0;
        font-size: 1.15rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #1e293b;
    }

    .support-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .primary-btn,
    .secondary-btn {
        min-height: 48px;
        padding: 0 1rem;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .primary-btn {
        border: 0;
        background: linear-gradient(135deg, #6C63FF, #8c85ff);
        color: #ffffff;
        box-shadow: 0 14px 24px rgba(108, 99, 255, 0.18);
    }

    .secondary-btn {
        border: 1px solid rgba(108, 99, 255, 0.15);
        background: #ffffff;
        color: #1e293b;
        box-shadow: 0 10px 18px rgba(15, 23, 42, 0.04);
    }

    .primary-btn:hover,
    .secondary-btn:hover {
        transform: translateY(-1px);
    }

    .support-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 1rem;
        align-items: start;
    }

    .table-card {
        padding-bottom: 1rem;
        overflow: hidden;
    }

    .table-card-head,
    .editor-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.1rem;
        border-bottom: 1px solid #edf3f8;
    }

    .table-badge {
        align-self: flex-start;
        min-height: 32px;
        padding: 0 0.8rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        background: rgba(108, 99, 255, 0.12);
        color: #6C63FF;
        font-weight: 800;
        font-size: 0.78rem;
    }

    .faq-list {
        display: grid;
        gap: 0.75rem;
        padding: 1rem 1.1rem 0;
    }

    .faq-item {
        border: 1px solid #e5edf5;
        border-radius: 18px;
        background: #ffffff;
        overflow: hidden;
    }

    .faq-item.is-active {
        border-color: rgba(108, 99, 255, 0.28);
        box-shadow: 0 14px 26px rgba(108, 99, 255, 0.08);
    }

    .faq-button {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr) 24px;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        padding: 0.85rem;
        border: 0;
        background: transparent;
        text-align: left;
    }

    .faq-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(108, 99, 255, 0.12);
        color: #6C63FF;
        flex-shrink: 0;
    }

    .faq-question {
        color: #1e293b;
        font-weight: 800;
        line-height: 1.35;
    }

    .faq-toggle {
        color: #6C63FF;
    }

    .faq-answer {
        margin-left: calc(42px + 1.6rem);
        padding: 0 0.95rem 0.95rem 0;
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .support-side-card {
        position: sticky;
        top: 1rem;
    }

    .support-checklist {
        display: grid;
        gap: 0.75rem;
        padding: 1rem 1.1rem;
    }

    .support-check-item {
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        gap: 0.7rem;
        align-items: center;
        padding: 0.8rem;
        border: 1px solid #e5edf5;
        border-radius: 16px;
        background: #fbfdff;
        color: #64748b;
        font-size: 0.88rem;
        line-height: 1.45;
    }

    .support-check-item i {
        width: 38px;
        height: 38px;
        border-radius: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(108, 99, 255, 0.12);
        color: #6C63FF;
    }

    @@media (max-width: 980px) {
        .support-hero,
        .support-grid {
            grid-template-columns: 1fr;
        }

        .hero-summary {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .support-side-card {
            position: static;
        }
    }

    @@media (max-width: 820px) {
        .toolbar-card,
        .table-card-head {
            flex-direction: column;
            align-items: stretch;
        }

        .primary-btn,
        .secondary-btn {
            width: 100%;
        }
    }

    @@media (max-width: 640px) {
        .support-hero,
        .toolbar-card,
        .table-card,
        .editor-card {
            border-radius: 20px;
        }

        .hero-summary {
            grid-template-columns: 1fr;
        }

        .faq-button {
            grid-template-columns: 36px minmax(0, 1fr) 22px;
            padding: 0.75rem;
        }

        .faq-icon {
            width: 36px;
            height: 36px;
        }

        .faq-answer {
            margin-left: 0;
            padding: 0 0.85rem 0.85rem;
        }
    }
</style>

@code {
    private int active = 1;

    private void Toggle(int id)
    {
        active = active == id ? 0 : id;
    }

    private readonly List<FaqItem> faqs = new()
    {
        new()
        {
            Id = 1,
            Icon = "bi bi-person-badge",
            Pregunta = "¿Cómo creo un nuevo contribuyente en el sistema?",
            Respuesta = "En el módulo 'Contribuyentes', haz clic en 'Registrar contribuyente'. Completa el tipo de contribuyente (Persona Natural o Sociedad), tipo y número de identificación, nombres/razón social, correo principal y secundario, celular, dirección y datos geográficos. Asegúrate de que no haya validaciones pendientes antes de guardar."
        },
        new()
        {
            Id = 2,
            Icon = "bi bi-calendar-event",
            Pregunta = "¿Cómo se calcula el día de declaración de un contribuyente?",
            Respuesta = "El sistema calcula automáticamente el día límite de declaración basado en el noveno dígito de la cédula o RUC del contribuyente. La fórmula oficial aplica día = (noveno_dígito == 0) ? 28 : (noveno_dígito * 2) + 8. El resultado se asigna automáticamente al campo de fecha de declaración."
        },
        new()
        {
            Id = 3,
            Icon = "bi bi-percent",
            Pregunta = "¿Cuál es la diferencia entre las opciones de Periodicidad de IVA?",
            Respuesta = "La periodicidad del IVA puede ser Mensual o Semestral. Los contribuyentes obligados a declarar mensualmente deben presentar el formulario del IVA cada mes, mientras que aquellos bajo régimen de microempresas o ciertas actividades específicas lo declaran semestralmente (en julio y enero)."
        },
        new()
        {
            Id = 4,
            Icon = "bi bi-bank",
            Pregunta = "¿Qué regímenes comerciales están disponibles para la Renta?",
            Respuesta = "E-Declara permite clasificar la periodicidad de Renta en: Régimen General (declaración anual estándar), Régimen Emprendedor (RIMPE Emprendedores), Régimen Negocio Popular (RIMPE Negocios Populares con cuota fija) y Régimen Mixto (cuando el contribuyente realiza actividades bajo múltiples regímenes)."
        },
        new()
        {
            Id = 5,
            Icon = "bi bi-patch-check",
            Pregunta = "¿Qué es un Contribuyente Especial y cómo influye en el sistema?",
            Respuesta = "Es aquel designado por el SRI mediante resolución debido a su volumen de transacciones. En el sistema, marcar la casilla 'Contribuyente especial' habilita configuraciones tributarias específicas para retenciones y plazos especiales de declaración de impuestos."
        },
        new()
        {
            Id = 6,
            Icon = "bi bi-toggle-on",
            Pregunta = "¿Cómo puedo activar o desactivar un contribuyente?",
            Respuesta = "En el listado de contribuyentes, localiza la columna 'Acciones'. Si el contribuyente está activo, verás un botón con el ícono del basurero para desactivarlo temporalmente. Si está inactivo, aparecerá un ícono de verificación azul para volver a activarlo sin perder sus registros históricos."
        },
        new()
        {
            Id = 7,
            Icon = "bi bi-envelope-plus",
            Pregunta = "¿Puedo agregar correos adicionales para recibir notificaciones tributarias?",
            Respuesta = "Sí. Además del correo principal obligatorio, puedes hacer clic en el botón '+' junto al correo principal para desplegar el gestor de correos adicionales. E-Declara permite ingresar múltiples direcciones para asegurar que los avisos de vencimientos lleguen a todos los interesados."
        },
        new()
        {
            Id = 8,
            Icon = "bi bi-shield-check",
            Pregunta = "¿Qué validaciones de seguridad se aplican a la cédula ecuatoriana y al RUC?",
            Respuesta = "El sistema implementa la validación oficial del dígito verificador ecuatoriano (módulo 10 para cédulas y personas naturales, módulo 11 para sociedades privadas y públicas). También verifica de forma estricta que no se dupliquen identificaciones ya registradas en la base de datos."
        },
        new()
        {
            Id = 9,
            Icon = "bi bi-geo-alt",
            Pregunta = "¿Cuándo se actualizan las provincias y ciudades al cambiar de país?",
            Respuesta = "Al seleccionar un país en el formulario, el sistema carga en cascada y de forma asíncrona sus provincias asociadas. Al elegir la provincia, se listan sus respectivas ciudades. Para el caso de Ecuador, el sistema carga automáticamente la distribución política oficial con su respectivo ordenamiento."
        },
        new()
        {
            Id = 10,
            Icon = "bi bi-headset",
            Pregunta = "¿Qué datos debo preparar antes de contactar a soporte por un error de declaración?",
            Respuesta = "Ten a mano el RUC del contribuyente afectado, el módulo (e.g. IVA, Renta, Anexos), el tipo de periodicidad configurada, el mensaje exacto de error arrojado por el SRI o el sistema y, de ser posible, una captura de pantalla completa para agilizar la revisión."
        }
    };

    private sealed class FaqItem
    {
        public int Id { get; set; }
        public string Icon { get; set; } = string.Empty;
        public string Pregunta { get; set; } = string.Empty;
        public string Respuesta { get; set; } = string.Empty;
    }

    private void IrAWhatsApp()
    {
        var numero = "593995876753";
        var mensaje = Uri.EscapeDataString("Hola, necesito soporte en E-Declara.");
        Nav.NavigateTo($"https://wa.me/{numero}?text={mensaje}", true);
    }
}
