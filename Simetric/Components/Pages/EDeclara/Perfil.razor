@page "/e-declara/configuracion/perfil"
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Models
@using Simetric.Auth
@using Simetric.Services
@using Simetric.Services.EDeclara
@using Simetric.ViewModels
@using System.IO
@using Simetric.Data
@using Microsoft.EntityFrameworkCore
@inject IUsuarioService UsuarioService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject IDbContextFactory<AppDbContext> DbFactory

@{
    var nombreCompleto = GetNombreCompleto();
}

<PageTitle>Mi Perfil | E-Declara</PageTitle>

<div class="profile-shell pd-shell">
    @if (perfil == null)
    {
        <section class="profile-state-card pd-state-card">
            <div class="profile-state-icon pd-state-icon">
                <span class="spinner-border" role="status" style="color:#6C63FF;"></span>
            </div>
            <h3>Cargando tu perfil</h3>
            <p>Preparando tu informacion.</p>
        </section>
    }
    else
    {
        <EditForm Model="@perfil" OnValidSubmit="GuardarCambios">
            <DataAnnotationsValidator />

            <div class="profile-grid">
                <!-- ── Aside: Avatar ─────────────────────────────────── -->
                <aside class="profile-aside-card pd-aside-card" data-tour="perfil.avatar">
                    <div class="profile-panel-head">
                        <div>
                            <span class="panel-kicker pd-kicker">Avatar</span>
                            <h3>Imagen</h3>
                        </div>
                        <span class="profile-pill pd-pill">@GetAvatarCountLabel()</span>
                    </div>

                    <div class="profile-avatar-stage pd-avatar-stage">
                        <div class="profile-avatar-frame pd-avatar-frame">
                            <img src="@GetAvatarPreviewSrc()" class="profile-avatar-preview" alt="Vista previa del avatar" />
                        </div>
                        <div class="profile-avatar-copy">
                            <strong>@nombreCompleto</strong>
                            <span>@GetAvatarCaption()</span>
                            <div class="mt-2 text-center">
                                <InputFile OnChange="UploadOwnPhotoAsync" accept="image/png, image/jpeg, image/jpg" class="d-none" id="fileOwnAvatar" />
                                <label for="fileOwnAvatar" class="btn btn-sm btn-outline-secondary cursor-pointer" style="border-radius: 8px; font-size: 0.8rem; padding: 0.25rem 0.5rem; font-weight: 600;">
                                    <i class="bi bi-cloud-arrow-up"></i> Subir Foto Propia
                                </label>
                                @if (subiendoArchivo)
                                {
                                    <div class="spinner-border spinner-border-sm text-primary mt-1" role="status" style="width: 1rem; height: 1rem; display: block; margin: 0.25rem auto;"></div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="profile-avatar-library">
                        <div class="profile-section-head">
                            <h4>Seleccion</h4>
                            <span class="profile-section-caption">Biblioteca</span>
                        </div>

                        @if (listaAvatares.Any())
                        {
                            <div class="profile-avatar-grid">
                                @{
                                    var esInitialsActual = !string.IsNullOrWhiteSpace(perfil.AvatarUrl) && perfil.AvatarUrl.Contains("avatar_initials_");
                                    var initialsPreview = GenerarSvgIniciales();
                                }
                                <button type="button"
                                        title="Iniciales del nombre"
                                        class="avatar-picker pd-avatar-picker @(esInitialsActual ? "pd-avatar-picker-active" : string.Empty)"
                                        @onclick="() => SeleccionarAvatarInitials()">
                                    <img src="@initialsPreview" alt="Iniciales" />
                                </button>
                                @foreach (var imgNombre in listaAvatares)
                                {
                                    var rutaRelativa = $"images/Avatars/{imgNombre}";
                                    var avatarSrc = $"/images/Avatars/{imgNombre}";
                                    var esActual = string.Equals(perfil.AvatarUrl, rutaRelativa, StringComparison.OrdinalIgnoreCase);

                                    <button type="button"
                                            title="@imgNombre"
                                            class="avatar-picker pd-avatar-picker @(esActual ? "pd-avatar-picker-active" : string.Empty)"
                                            @onclick="() => SeleccionarAvatar(imgNombre)">
                                        <img src="@avatarSrc" alt="Avatar @imgNombre" />
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="profile-avatar-empty pd-avatar-empty">
                                <i class="bi bi-images"></i>
                                <span>Sin avatares disponibles.</span>
                            </div>
                        }
                    </div>

                </aside>

                <!-- ── Main: Formulario ──────────────────────────────── -->
                <section class="profile-form-card pd-form-card" data-tour="perfil.form">
                    <div class="profile-panel-head profile-panel-head-form">
                        <div>
                            <span class="panel-kicker pd-kicker">Cuenta</span>
                            <h3>Informacion</h3>
                        </div>
                    </div>

                    <ValidationSummary class="profile-validation pd-validation" />

                    <div class="profile-form-grid">
                        <!-- Correo (readonly) -->
                        <div class="profile-field-card pd-field-card profile-field-wide pd-field-wide pd-field-readonly">
                            <div class="profile-field-top">
                                <label class="profile-field-label pd-field-label">Correo electronico</label>
                            </div>
                            <div class="profile-input-shell pd-input-shell pd-input-readonly">
                                <span class="profile-input-icon pd-input-icon"><i class="bi bi-envelope-paper-heart"></i></span>
                                <input type="text" class="profile-field-input pd-field-input" value="@perfil.Email" readonly />
                            </div>
                        </div>

                        <!-- Identificacion (readonly) -->
                        <div class="profile-field-card pd-field-card profile-field-wide pd-field-wide pd-field-readonly">
                            <div class="profile-field-top">
                                <label class="profile-field-label pd-field-label">Identificación (Cédula o RUC)</label>
                            </div>
                            <div class="profile-input-shell pd-input-shell pd-input-readonly">
                                <span class="profile-input-icon pd-input-icon"><i class="bi bi-card-text"></i></span>
                                <input type="text" class="profile-field-input pd-field-input" value="@perfil.Identificacion" readonly />
                            </div>
                        </div>

                        <!-- Nombres -->
                        <div class="profile-field-card pd-field-card">
                            <div class="profile-field-top">
                                <label class="profile-field-label pd-field-label">Nombres</label>
                            </div>
                            <div class="profile-input-shell pd-input-shell">
                                <span class="profile-input-icon pd-input-icon"><i class="bi bi-person-badge"></i></span>
                                <InputText @bind-Value="perfil.Nombres" class="profile-field-input pd-field-input" maxlength="60" />
                            </div>
                            <ValidationMessage For="@(() => perfil.Nombres)" class="profile-field-error pd-field-error" />
                        </div>

                        <!-- Apellidos -->
                        <div class="profile-field-card pd-field-card">
                            <div class="profile-field-top">
                                <label class="profile-field-label pd-field-label">Apellidos</label>
                            </div>
                            <div class="profile-input-shell pd-input-shell">
                                <span class="profile-input-icon pd-input-icon"><i class="bi bi-person-vcard"></i></span>
                                <InputText @bind-Value="perfil.Apellidos" class="profile-field-input pd-field-input" maxlength="60" />
                            </div>
                            <ValidationMessage For="@(() => perfil.Apellidos)" class="profile-field-error pd-field-error" />
                        </div>

                        <div class="profile-field-card pd-field-card profile-field-wide pd-field-wide">
                            <div class="profile-field-top">
                                <label class="profile-field-label pd-field-label">Fecha de nacimiento</label>
                            </div>
                            <div class="profile-input-shell pd-input-shell">
                                <span class="profile-input-icon pd-input-icon"><i class="bi bi-calendar3"></i></span>
                                <InputDate @bind-Value="perfil.FechaNacimiento"
                                           class="profile-field-input pd-field-input"
                                           min="@FechaNacimientoMinima"
                                           max="@FechaNacimientoMaxima" />
                            </div>
                            <ValidationMessage For="@(() => perfil.FechaNacimiento)" class="profile-field-error pd-field-error" />
                        </div>

                        <div class="profile-field-card pd-field-card profile-field-wide pd-field-wide">
                            <div class="profile-field-top">
                                <label class="profile-field-label pd-field-label">Tipo de Cliente</label>
                            </div>
                            <div class="profile-input-shell pd-input-shell">
                                <span class="profile-input-icon pd-input-icon"><i class="bi bi-person-workspace"></i></span>
                                <InputSelect @bind-Value="perfil.TipoCliente" class="profile-field-input pd-field-input">
                                    <option value="">Seleccione tipo de cliente...</option>
                                    @foreach (var tc in tipoClientesList)
                                    {
                                        <option value="@tc.TclCodigo">@tc.TclDescripcion</option>
                                    }
                                </InputSelect>
                            </div>
                            <ValidationMessage For="@(() => perfil.TipoCliente)" class="profile-field-error pd-field-error" />
                        </div>
                    </div>

                    <!-- Seguridad -->
                    <section class="profile-security-card pd-security-card" data-tour="perfil.security">
                        <div class="profile-security-head">
                            <div>
                                <span class="panel-kicker pd-kicker">Seguridad</span>
                                <h4>Clave de acceso</h4>
                            </div>
                            <div class="profile-security-controls">
                                <span class="profile-security-badge pd-security-badge @(cambiarPassword ? "pd-security-badge-active" : string.Empty)">
                                    @GetEstadoSeguridad()
                                </span>
                                <label class="profile-toggle pd-toggle">
                                    <input type="checkbox" @bind="cambiarPassword" />
                                    <span class="profile-toggle-track pd-toggle-track"></span>
                                    <span class="profile-toggle-label">Cambiar</span>
                                </label>
                            </div>
                        </div>

                        @if (cambiarPassword)
                        {
                            <div class="profile-password-grid">
                                <div class="profile-field-card pd-field-card">
                                    <div class="profile-field-top">
                                        <label class="profile-field-label pd-field-label">Nueva contraseña</label>
                                        <span class="profile-field-tag pd-field-tag">Privada</span>
                                    </div>
                                    <div class="profile-input-shell pd-input-shell">
                                        <span class="profile-input-icon pd-input-icon"><i class="bi bi-shield-lock"></i></span>
                                        <InputText @bind-Value="perfil.NuevaPassword" type="password" class="profile-field-input pd-field-input" />
                                    </div>
                                    <ValidationMessage For="@(() => perfil.NuevaPassword)" class="profile-field-error pd-field-error" />
                                </div>
                                <div class="profile-field-card pd-field-card">
                                    <div class="profile-field-top">
                                        <label class="profile-field-label pd-field-label">Confirmar contraseña</label>
                                        <span class="profile-field-tag pd-field-tag">Verificar</span>
                                    </div>
                                    <div class="profile-input-shell pd-input-shell">
                                        <span class="profile-input-icon pd-input-icon"><i class="bi bi-patch-check"></i></span>
                                        <InputText @bind-Value="perfil.ConfirmarPassword" type="password" class="profile-field-input pd-field-input" />
                                    </div>
                                    <ValidationMessage For="@(() => perfil.ConfirmarPassword)" class="profile-field-error pd-field-error" />
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="profile-security-placeholder pd-security-placeholder">
                                <div class="profile-security-placeholder-icon pd-placeholder-icon">
                                    <i class="bi bi-shield-check"></i>
                                </div>
                                <div class="profile-security-placeholder-copy">
                                    <strong>Sin cambios en contraseña</strong>
                                    <span></span>
                                </div>
                            </div>
                        }
                    </section>

                    <!-- Footer -->
                    <div class="profile-form-footer">
                        <button type="submit" class="primary-btn pd-save-btn profile-save-btn">
                            <i class="bi bi-save2-fill"></i>
                            <span>Guardar cambios</span>
                        </button>
                    </div>
                </section>
            </div>
        </EditForm>
    }
</div>
<style>

/* ── Variables moradas ───────────────────────────────────────────────── */
.pd-shell {
    --pd:          #6C63FF;
    --pd-dark:     #574fd6;
    --pd-subtle:   rgba(108, 99, 255, 0.10);
    --pd-border:   rgba(108, 99, 255, 0.25);
    --pd-bg:       rgba(108, 99, 255, 0.06);
    --pd-light-bg: #f3f2ff;
    --pd-mid-bg:   #ebe9ff;
    --pd-readonly: #e6e4ff;
    --pd-readonly-border: #b8b5ff;
    --pd-readonly-text: #4a3eaa;
}

/* ── Kicker / pill ───────────────────────────────────────────────────── */
.pd-shell .pd-kicker { color: var(--pd); }
.pd-shell .pd-pill   { background: var(--pd-subtle); color: var(--pd); }

/* ── Aside card ──────────────────────────────────────────────────────── */
.pd-shell .pd-aside-card {
    background:
        radial-gradient(circle at top, rgba(108,99,255,.08), transparent 32%),
        linear-gradient(180deg, #fdfcff, var(--pd-light-bg));
    border-color: var(--pd-border);
}

/* ── Avatar stage ─── fondo morado suave ────────────────────────────── */
.pd-shell .profile-avatar-stage {
    border-color: var(--pd-border);
    background:
        radial-gradient(circle at top, rgba(108,99,255,.12), transparent 34%),
        linear-gradient(180deg, #fdfcff, #eeeeff);
}

/* ── Avatar frame ─── sombra morada ─────────────────────────────────── */
.pd-shell .profile-avatar-frame {
    background: linear-gradient(145deg, rgba(108,99,255,.22), rgba(108,99,255,.06));
    box-shadow: 0 12px 22px rgba(108,99,255,.18);
}

/* ── Avatar picker ───────────────────────────────────────────────────── */
.pd-shell .avatar-picker {
    border-color: var(--pd-border) !important;
    box-shadow: inset 0 1px 3px rgba(108,99,255,.06) !important;
}
.pd-shell .avatar-picker:hover {
    border-color: var(--pd) !important;
    box-shadow: 0 0 0 3px var(--pd-subtle), inset 0 1px 3px rgba(108,99,255,.06) !important;
    background-color: #fdfcff !important;
}
.pd-shell .avatar-picker-active {
    border-color: var(--pd) !important;
    background: var(--pd-light-bg) !important;
    box-shadow: 0 0 0 3px var(--pd-subtle) !important;
}
.pd-shell .avatar-picker-active::after {
    background: var(--pd);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.96);
}

/* ── Avatar empty ────────────────────────────────────────────────────── */
.pd-shell .profile-avatar-empty { background: var(--pd-light-bg); }
.pd-shell .profile-avatar-empty i { color: var(--pd); }

/* ── Form card ───────────────────────────────────────────────────────── */
.pd-shell .pd-form-card {
    background:
        radial-gradient(circle at top right, rgba(108,99,255,.05), transparent 30%),
        #fff;
    border-color: var(--pd-border);
}

/* ── Field cards normales ────────────────────────────────────────────── */
.pd-shell .profile-field-card {
    border-color: var(--pd-border);
    background: linear-gradient(180deg, var(--pd-light-bg), var(--pd-mid-bg));
}

/* ── Fields readonly ─── fondito morado bajito ───────────────────────── */
.pd-shell .profile-field-card-readonly,
.pd-shell .profile-field-card.pd-field-readonly {
    border-color: var(--pd-readonly-border);
    background: linear-gradient(180deg, #eeeeff, var(--pd-readonly));
}

/* ── Input shell normal ──────────────────────────────────────────────── */
.pd-shell .profile-input-shell {
    border-color: var(--pd-border);
    box-shadow: inset 0 1px 3px rgba(108,99,255,.06);
}
.pd-shell .profile-field-card:focus-within .profile-input-shell {
    border-color: var(--pd);
    background-color: var(--pd-light-bg);
    box-shadow: 0 0 0 3px var(--pd-subtle), inset 0 1px 3px rgba(108,99,255,.06);
}

/* ── Input shell readonly ─── fondo morado bajito ────────────────────── */
.pd-shell .profile-input-shell-readonly,
.pd-shell .pd-input-readonly {
    background-color: #dddcff;
    border-color: var(--pd-readonly-border);
    box-shadow: none;
}

/* ── Icono del input ─────────────────────────────────────────────────── */
.pd-shell .profile-input-icon { color: var(--pd); }

/* ── Texto del input readonly ────────────────────────────────────────── */
.pd-shell .profile-field-input-readonly,
.pd-shell .profile-input-shell-readonly .profile-field-input,
.pd-shell .pd-input-readonly .profile-field-input {
    color: var(--pd-readonly-text) !important;
}

.pd-shell .profile-field-value {
    display: flex;
    align-items: center;
    height: auto;
    min-height: 34px;
    line-height: 1.35;
    white-space: nowrap;
}

.pd-shell .profile-input-shell-readonly,
.pd-shell .pd-input-readonly {
    min-height: 46px;
    padding-top: 0;
    padding-bottom: 0;
    align-items: center;
}

.pd-shell .profile-input-shell-readonly .profile-input-icon,
.pd-shell .pd-input-readonly .profile-input-icon {
    height: 100%;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.pd-shell .profile-input-shell-readonly .profile-field-value,
.pd-shell .pd-input-readonly .profile-field-value {
    height: 100%;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0;
    line-height: 1;
    align-self: stretch;
}

/* ── Placeholder ─────────────────────────────────────────────────────── */
.pd-shell .profile-date-readonly,
.pd-shell .pd-date-readonly {
    height: 46px;
    min-height: 46px;
    padding-top: 0;
    padding-bottom: 0;
    align-items: center;
}

.pd-shell .profile-date-readonly .profile-input-icon,
.pd-shell .pd-date-readonly .profile-input-icon {
    height: 44px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transform: translateY(1px);
}

.pd-shell .profile-date-value,
.pd-shell .pd-date-value {
    flex: 1 1 auto;
    min-width: 0;
    height: 44px;
    display: inline-flex;
    align-items: center;
    margin: 0;
    padding: 0;
    color: var(--pd-readonly-text);
    font-size: 0.89rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    transform: translateY(1px);
}

.pd-shell .profile-field-input::placeholder { color: #a5a0e8; }

/* ── Field label / tag ───────────────────────────────────────────────── */
.pd-shell .profile-field-label { color: #2e1f6e; }
.pd-shell .profile-field-tag   { background: var(--pd-subtle); color: var(--pd); }
.pd-shell .profile-field-error { color: #9333ea; }
.pd-shell .pd-field-wide       { grid-column: 1 / -1; }

/* ── Validation ──────────────────────────────────────────────────────── */
.pd-shell .profile-validation {
    border-color: rgba(108,99,255,.20);
    background: rgba(108,99,255,.06);
    color: var(--pd-dark);
}

/* ── Security card ───────────────────────────────────────────────────── */
.pd-shell .profile-security-card {
    border-color: var(--pd-border);
    background: linear-gradient(180deg, var(--pd-light-bg), var(--pd-mid-bg));
}

.pd-shell .profile-security-badge {
    background: var(--pd-subtle) !important;
    color: #574fd6 !important;
    box-shadow: none !important;
    background-image: none !important;
}
.pd-shell .profile-security-badge-active {
    background: rgba(108,99,255,.18) !important;
    color: var(--pd) !important;
}

/* ── Toggle morado ───────────────────────────────────────────────────── */
.pd-shell .profile-toggle-track { background: #c8c5f5; }
.pd-shell .profile-toggle input:checked + .profile-toggle-track {
    background: linear-gradient(135deg, var(--pd), var(--pd-dark));
    box-shadow: 0 10px 18px rgba(108,99,255,.25);
}

/* ── Security placeholder ────────────────────────────────────────────── */
.pd-shell .profile-security-placeholder {
    border-color: var(--pd-border);
    background: var(--pd-subtle);
}
.pd-shell .profile-security-placeholder-icon {
    background: rgba(108,99,255,.15);
    color: var(--pd);
}

/* ── Form footer border ──────────────────────────────────────────────── */
.pd-shell .profile-form-footer {
    border-top-color: rgba(108,99,255,.18);
}

/* ── Botón guardar morado ────────────────────────────────────────────── */
.pd-shell .profile-save-btn,
.pd-shell .pd-save-btn {
    background: linear-gradient(135deg, var(--pd), var(--pd-dark)) !important;
    background-image: linear-gradient(135deg, var(--pd), var(--pd-dark)) !important;
    border-color: var(--pd) !important;
    color: #fff !important;
    box-shadow: 0 14px 24px rgba(108,99,255,.28) !important;
}
.pd-shell .profile-save-btn:hover,
.pd-shell .pd-save-btn:hover {
    background: linear-gradient(135deg, var(--pd-dark), #4a3db5) !important;
    background-image: linear-gradient(135deg, var(--pd-dark), #4a3db5) !important;
    box-shadow: 0 18px 30px rgba(108,99,255,.34) !important;
}

/* ── State card ──────────────────────────────────────────────────────── */
.pd-shell .profile-state-card  { border-color: var(--pd-border); }
.pd-shell .profile-state-icon  { background: var(--pd-subtle); color: var(--pd); }

select.profile-field-input,
.profile-input-shell ::deep select.profile-field-input {
    display: inline-block !important;
    line-height: 34px !important;
    height: 34px !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    vertical-align: middle !important;
}
</style>

@code {
    private const string DefaultAvatarUrl = "/images/avatars/Avatar-Boy.jpg";

    private PerfilViewModel? perfil;
    private List<string> listaAvatares = new();
    private List<Tipocliente> tipoClientesList = new();
    private bool cambiarPassword;
    private int? usuarioIdActual;
    private bool esAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claimIdUsuario = authState.User.FindFirst("IdUsuario")?.Value;
        var claimTipo = authState.User.FindFirst("IdTipoUsuario")?.Value;

        esAdmin = claimTipo == "2";
        CargarListaAvatares();

        if (!int.TryParse(claimIdUsuario, out var idUsuario))
        {
            Nav.NavigateTo("/login");
            return;
        }

        usuarioIdActual = idUsuario;
        await SelectedAppServiceState.SetCurrentServiceKeyAsync(EDeclaraRoutes.ServiceKey);

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            tipoClientesList = await context.Tipoclientes.OrderBy(tc => tc.TclCodigo).ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar tipos de cliente: {ex.Message}");
        }

        try
        {
            var userDb = await UsuarioService.ObtenerUsuarioPorId(idUsuario);
            if (userDb is not null)
            {
                perfil = new PerfilViewModel
                {
                    Nombres = userDb.Nombres,
                    Apellidos = userDb.Apellidos,
                    Email = userDb.Email,
                    AvatarUrl = userDb.AvatarUrl,
                    FechaNacimiento = userDb.FechaNacimiento,
                    FotoByte = userDb.FirmaElectronica,
                    Identificacion = userDb.Identificacion,
                    TipoCliente = userDb.TipoCliente
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
    }

    private void CargarListaAvatares()
    {
        try
        {
            var folderPath = Path.Combine(Env.WebRootPath, "images", "Avatars");
            if (!Directory.Exists(folderPath)) return;

            const string avatarRestringido = "avatar_18e35752-9dbd-40a4-8c62-970a2dfc1dfb.png";

            var archivos = Directory.GetFiles(folderPath)
                .Select(Path.GetFileName)
                .Where(f => !string.IsNullOrEmpty(f) &&
                            !f.Equals("Avatar-Boy.jpg", StringComparison.OrdinalIgnoreCase) &&
                            (f.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                             f.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                             f.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)));

            if (!esAdmin)
                archivos = archivos.Where(f => !f.Equals(avatarRestringido, StringComparison.OrdinalIgnoreCase));

            listaAvatares = archivos
                .OrderByDescending(f => f != null && f.StartsWith("Bandera-", StringComparison.OrdinalIgnoreCase))
                .ThenBy(f => f, StringComparer.OrdinalIgnoreCase)
                .ToList()!;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar avatares: {ex.Message}");
        }
    }

