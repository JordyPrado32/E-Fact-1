    private string GetAvatarPreviewSrc()
    {
        if (!string.IsNullOrWhiteSpace(perfil?.AvatarUrl))
            return ResolveAvatarUrl(perfil.AvatarUrl);

        if (perfil?.FotoByte is { Length: > 0 })
            return $"data:image/png;base64,{Convert.ToBase64String(perfil.FotoByte)}";

        return DefaultAvatarUrl;
    }

    private string GetInitials()
    {
        var firstInit = string.Empty;
        var lastInit = string.Empty;

        if (perfil is not null)
        {
            if (!string.IsNullOrWhiteSpace(perfil.Nombres))
            {
                var parts = perfil.Nombres.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0)
                {
                    firstInit = parts[0][0].ToString().ToUpper();
                }
            }

            if (!string.IsNullOrWhiteSpace(perfil.Apellidos))
            {
                var parts = perfil.Apellidos.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0)
                {
                    lastInit = parts[0][0].ToString().ToUpper();
                }
            }
        }

        var initials = firstInit + lastInit;
        return string.IsNullOrWhiteSpace(initials) ? "?" : initials;
    }

    private string GetBackgroundColorForInitials(string initials)
    {
        string[] premiumColors = new[] {
            "#6C63FF", // purple theme for edeclara
            "#006bb5", // n-blue
            "#2c3e50", // n-dark
            "#e67e22", // orange
            "#27ae60", // green
            "#9b59b6", // purple
            "#e74c3c", // red
            "#1abc9c", // turquoise
            "#34495e", // wet asphalt
            "#2980b9"  // belize hole
        };
        int hash = 0;
        foreach (char c in initials)
        {
            hash += c;
        }
        return premiumColors[Math.Abs(hash) % premiumColors.Length];
    }

    private string GenerarSvgIniciales()
    {
        var initials = GetInitials();
        var bgColor = GetBackgroundColorForInitials(initials);
        
        var svg = $"<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100' width='100' height='100'>" +
                  $"<rect width='100' height='100' fill='{bgColor}'/>" +
                  $"<text x='50%' y='55%' font-family='Arial, sans-serif' font-size='40' font-weight='bold' fill='#ffffff' text-anchor='middle' dominant-baseline='middle'>{initials}</text>" +
                  $"</svg>";
        
        var base64Svg = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(svg));
        return $"data:image/svg+xml;base64,{base64Svg}";
    }

