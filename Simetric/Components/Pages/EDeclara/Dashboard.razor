@page "/e-declara"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@using System.Security.Claims
@using Simetric.Models.EDeclara
@using Simetric.Services
@using Simetric.Services.EDeclara
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject AppAccessService AppAccessService
@inject SelectedAppServiceStateService SelectedAppServiceState
@inject EDeclaraSharedDataService EDeclaraSharedData

<PageTitle>Inicio | E-Declara</PageTitle>

<div class="edeclara-page">
    @if (cargando)
    {
        <section class="edeclara-state">
            <span class="spinner-border" role="status"></span>
            <h3>Cargando E-Declara</h3>
            <p>Validando tu acceso y preparando contribuyentes y declaraciones.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(errorCarga))
    {
        <section class="edeclara-state edeclara-state-error">
            <i class="bi bi-exclamation-octagon"></i>
            <h3>No pudimos abrir E-Declara</h3>
            <p>@errorCarga</p>
            <button type="button" class="primary-btn" @onclick="VolverServicios">
                <i class="bi bi-grid"></i>
                <span>Volver a servicios</span>
            </button>
        </section>
    }
    else
    {
        <section class="edeclara-overview">
            <article class="edeclara-summary">
                <div class="summary-real-head">
                    <span class="summary-real-kicker">E-Declara</span>
                    <span class="summary-real-pill">@lastUpdatedLabel</span>
                </div>

                <div class="summary-real-grid">
                    <div class="summary-real-item">
                        <span class="summary-real-label">Contribuyentes registrados</span>
                        <strong>@(snapshot?.TotalContribuyentes ?? 0)</strong>
                        <small>Base de contribuyentes activos en el modulo tributario.</small>
                    </div>

                    <div class="summary-real-item">
                        <span class="summary-real-label">Contribuyentes activos</span>
                        <strong>@(snapshot?.ContribuyentesActivos ?? 0)</strong>
                        <small>Registros habilitados para declaraciones.</small>
                    </div>

                    <div class="summary-real-item">
                        <span class="summary-real-label">Personas naturales</span>
                        <strong>@(snapshot?.PersonasNaturales ?? 0)</strong>
                        <small>Contribuyentes persona natural.</small>
                    </div>

                    <div class="summary-real-item">
                        <span class="summary-real-label">Con correo</span>
                        <strong>@(snapshot?.ConCorreo ?? 0)</strong>
                        <small>Contribuyentes con correo electrónico.</small>
                    </div>

                    <div class="summary-real-item">
                        <span class="summary-real-label">Declaraciones registradas</span>
                        <strong>@(snapshot?.TotalDeclaraciones ?? 0)</strong>
                        <small>Declaraciones gestionadas en el periodo actual.</small>
                    </div>
                </div>
            </article>

            <article class="edeclara-spotlight">
                <div class="section-head section-head-tight">
                    <div>
                        <span class="section-kicker">Vista principal</span>
                        <h3>Tu modulo tributario empieza aqui</h3>
                    </div>
                    <span class="section-chip">@currentUserName</span>
                </div>

                <p class="summary-spotlight-copy">
                    Gestiona contribuyentes y declaraciones desde un solo lugar.
                    Consulta, crea y administra toda la informacion tributaria de tu organizacion.
                </p>

                <div class="spotlight-grid">
                    <button type="button" class="spotlight-card spotlight-action" @onclick="IrAContribuyentes">
                        <span class="spotlight-label">Contribuyentes</span>
                        <strong>@(snapshot?.TotalContribuyentes ?? 0)</strong>
                        <small>Consultar, crear, editar y desactivar contribuyentes.</small>
                    </button>

                    <button type="button" class="spotlight-card spotlight-action" @onclick="IrADeclaraciones">
                        <span class="spotlight-label">Declaraciones</span>
                        <strong>@(snapshot?.TotalDeclaraciones ?? 0)</strong>
                        <small>Administrar declaraciones y periodos tributarios.</small>
                    </button>
                </div>
            </article>
        </section>

        <section class="edeclara-grid">
            <article class="edeclara-panel">
                <div class="panel-head">
                    <div>
                        <span class="panel-kicker">Contribuyentes</span>
                        <h3>Ultimos contribuyentes</h3>
                    </div>
                    <button type="button" class="secondary-btn" @onclick="IrAContribuyentes">Abrir tabla</button>
                </div>

                @if (snapshot?.Contribuyentes.Count > 0)
                {
                    <div class="compact-list">
                        @foreach (var contribuyente in snapshot.Contribuyentes.Take(5))
                        {
                            <div class="compact-row">
                                <div>
                                    <strong>@contribuyente.Nombre</strong>
                                    <span>@DisplayOrFallback(contribuyente.Identificacion)</span>
                                </div>
                                <span class="@EstadoCss(contribuyente.Activo)">@EstadoTexto(contribuyente.Activo)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-panel">
                        <i class="bi bi-person-badge"></i>
                        <p>Aun no hay contribuyentes para mostrar.</p>
                    </div>
                }
            </article>

            <article class="edeclara-panel">
                <div class="panel-head">
                    <div>
                        <span class="panel-kicker">Declaraciones</span>
                        <h3>Ultimas declaraciones</h3>
                    </div>
                    <button type="button" class="secondary-btn" @onclick="IrADeclaraciones">Abrir tabla</button>
                </div>

                @if (snapshot?.Declaraciones.Count > 0)
                {
                    <div class="compact-list">
                        @foreach (var declaracion in snapshot.Declaraciones.Take(5))
                        {
                            <div class="compact-row">
                                <div>
                                    <strong>@declaracion.Titulo</strong>
                                    <span>@DisplayOrFallback(declaracion.Periodo)</span>
                                </div>
                                <span class="@EstadoCss(declaracion.Activo)">@EstadoTexto(declaracion.Activo)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-panel">
                        <i class="bi bi-file-earmark-text"></i>
                        <p>Aun no hay declaraciones para mostrar.</p>
                    </div>
                }
            </article>
        </section>
    }
</div>

@code {
    private static readonly CultureInfo Culture = CultureInfo.GetCultureInfo("es-EC");

    private bool cargando = true;
    private string? errorCarga;
    private string currentUserName = "Usuario";
    private DateTime loadedAt;
    private EDeclaraSharedDataSnapshot? snapshot;

    private string lastUpdatedLabel => loadedAt == default
        ? "Sin actualizar"
        : $"Actualizado {loadedAt:dd/MM/yyyy HH:mm}";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated != true)
            {
                NavManager.NavigateTo("/login", forceLoad: true);
                return;
            }

            if (!int.TryParse(user.FindFirst("IdUsuario")?.Value, out var userId) || userId <= 0)
            {
                NavManager.NavigateTo("/login", forceLoad: true);
                return;
            }

            var isSuperAdmin = string.Equals(
                user.FindFirst("IdTipoUsuario")?.Value,
                AppAccessService.AdminRoleId,
                StringComparison.OrdinalIgnoreCase);

            var access = await AppAccessService.CanAccessAsync(userId, EDeclaraRoutes.ServiceKey, isSuperAdmin);
            if (!access.HasAccess)
            {
                NavManager.NavigateTo($"/suscripciones?servicio={Uri.EscapeDataString(EDeclaraRoutes.ServiceKey)}", forceLoad: true);
                return;
            }

            await SelectedAppServiceState.SetCurrentServiceKeyAsync(EDeclaraRoutes.ServiceKey);

            var nombres = user.FindFirst(ClaimTypes.Name)?.Value ?? user.Identity?.Name ?? string.Empty;
            var apellidos = user.FindFirst(ClaimTypes.Surname)?.Value ?? string.Empty;
            currentUserName = string.Join(" ", new[] { nombres, apellidos }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
            if (string.IsNullOrWhiteSpace(currentUserName))
                currentUserName = "Usuario";

            snapshot = await EDeclaraSharedData.GetSnapshotAsync(userId, 10);
            loadedAt = DateTime.Now;
        }
        catch (Exception ex)
        {
            errorCarga = $"No fue posible cargar los datos de E-Declara: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private void IrAContribuyentes() => NavManager.NavigateTo(EDeclaraRoutes.Contribuyentes);
    private void IrADeclaraciones()  => NavManager.NavigateTo(EDeclaraRoutes.Declaraciones);
    private void VolverServicios()   => NavManager.NavigateTo("/portal-servicios", forceLoad: true);

    private static string DisplayOrFallback(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Sin dato" : value.Trim();

    private static string EstadoTexto(bool activo) => activo ? "Activo" : "Inactivo";

    private static string EstadoCss(bool activo) => activo ? "mini-status" : "mini-status mini-status-inactive";
}
