    private async Task Guardar()
    {
        modelo.PersonaNatural = modeloPersonaNatural;
        modelo.ContribuyenteEspecial = modeloEspecial;
        modelo.Oblgconta = (modelo.Oblgconta ?? "").Trim().ToUpperInvariant();

        var isValid = editContext?.Validate() ?? false;
        if (!isValid)
        {
            var errores = editContext?.GetValidationMessages().Select(x => x).ToList() ?? new();
            await JS.ShowAlertAsync("Revisa la información", string.Join("\n", errores), "warning");
            return;
        }

        try
        {
            HttpResponseMessage resp;
            if (editando)
                resp = await Http.PutAsJsonAsync($"api/contribuyentes-edeclara/{_editandoId}?userId={userId}", modelo);
            else
                resp = await Http.PostAsJsonAsync($"api/contribuyentes-edeclara?userId={userId}", modelo);

            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                await JS.ShowAlertAsync("Error al guardar", $"No se pudo completar la operación: {body}", "error");
                return;
            }

            var msjExito = editando ? "Contribuyente actualizado con éxito." : "Contribuyente creado con éxito.";
            await JS.ShowAlertAsync("Completado", msjExito, "success");
            Limpiar();
            await CargarTodo();
        }
        catch (Exception ex)
        {
            await JS.ShowAlertAsync("Error", $"Ocurrió un error inesperado: {ex.Message}", "error");
        }
    }

