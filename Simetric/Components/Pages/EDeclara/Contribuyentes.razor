@page "/e-declara/contribuyentes"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Controllers
@using Simetric.Components
@using Simetric.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Contribuyentes | E-Declara</PageTitle>

<div class="entity-shell edeclara-contribuyentes">
    <section class="toolbar-card">
        <div class="toolbar-copy">
            <span class="toolbar-kicker" style="color:#6C63FF">Búsqueda y control</span>
            <h3>Consulta y administra tus contribuyentes</h3>
        </div>
        <div class="toolbar-actions">
            <div class="search-box">
                <span class="search-icon"><i class="ri-search-line"></i></span>
                <input class="search-input"
                       placeholder="Buscar por nombre o identificación"
                       value="@filtro"
                       @oninput='e => { filtro = e.Value?.ToString() ?? ""; paginaActual = 1; }' />
            </div>
            <div class="toolbar-secondary-actions">
                <div class="filter-box">
                    <label class="filter-label" style="color:#6C63FF">Tipo</label>
                    <select class="filter-select" value="@filtroTipoContribuyente"
                            @onchange='e => { filtroTipoContribuyente = e.Value?.ToString() ?? "todos"; paginaActual = 1; }'>
                        <option value="todos">Todos</option>
                        <option value="natural">Persona Natural</option>
                        <option value="sociedad">Sociedad / Persona Jurídica</option>
                    </select>
                </div>
                <div class="filter-box">
                    <label class="filter-label" style="color:#6C63FF">Registros</label>
                    <select class="filter-select" value="@registrosPorPagina"
                            @onchange='e => { registrosPorPagina = int.Parse(e.Value?.ToString() ?? "10"); paginaActual = 1; }'>
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="20">20</option>
                    </select>
                </div>
                <button type="button" class="secondary-btn" @onclick="() => CargarTodo(true)">
                    <i class="ri-refresh-line"></i> Refrescar
                </button>
            </div>
        </div>
    </section>

    <section class="entity-grid">

        @* ── Tabla (Columna Izquierda) ── *@
        <div class="grid-left-col">
            <section class="table-card">
                <div class="table-card-head">
                    <div>
                        <span class="table-kicker" style="color:#6C63FF">Listado activo</span>
                        <h3>Contribuyentes registrados</h3>
                    </div>
                    <span class="table-badge" style="background:rgba(108,99,255,0.1);color:#6C63FF">
                        @ContribuFiltrados.Count() registros
                    </span>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensaje))
                {
                    <div class="status-banner status-banner-info"><i class="ri-information-line"></i> @mensaje</div>
                }
                @if (!string.IsNullOrWhiteSpace(errorMsg))
                {
                    <div class="status-banner status-banner-error"><i class="ri-error-warning-line"></i> @errorMsg</div>
                }

                @if (cargando)
                {
                    <div class="state-card">
                        <span class="spinner-border" role="status" style="color:#6C63FF"></span>
                        <h3 class="mt-2">Cargando contribuyentes</h3>
                    </div>
                }
                else if (!ContribuFiltrados.Any())
                {
                    <div class="state-card state-card-empty">
                        <div class="state-icon"><i class="ri-user-star-line"></i></div>
                        <h3>No hay contribuyentes para mostrar</h3>
                        <p>Ajusta la búsqueda o registra un nuevo contribuyente.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="table entity-table mb-0">
                            <thead>
                                <tr>
                                    <th style="width:70px">ID</th>
                                    <th>Contribuyente</th>
                                    <th>Identificación</th>
                                    <th>Estado</th>
                                    <th class="text-center col-acciones">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in ContribuPaginados)
                                {
                                    <tr>
                                        <td>
                                            <span class="code-pill code-pill-id">#@c.CodContribuyente</span>
                                        </td>
                                        <td>
                                            <div class="cell-main cell-main-stacked">
                                                <strong>@NombreCompleto(c)</strong>
                                                @if (!string.IsNullOrWhiteSpace(c.Nombrecomercial))
                                                {
                                                    <span class="meta-line">
                                                        <i class="ri-building-line"></i>
                                                        <span>@c.Nombrecomercial</span>
                                                    </span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(c.Correo))
                                                {
                                                    <span class="meta-line">
                                                        <i class="ri-mail-line"></i>
                                                        <span>@c.Correo</span>
                                                    </span>
                                                }
                                                @if (c.CorreosAdicionales.Any())
                                                {
                                                    @foreach (var extra in c.CorreosAdicionales)
                                                    {
                                                        <span class="meta-line">
                                                            <i class="ri-mail-add-line"></i>
                                                            <span>@extra</span>
                                                        </span>
                                                    }
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="code-pill">
                                                @(string.IsNullOrWhiteSpace(c.Numeroidentificacion) ? "Sin ID" : c.Numeroidentificacion)
                                            </span>
                                        </td>
                                        <td>
                                            <span class="@(c.Estado == true ? "mini-status" : "mini-status mini-status-inactive")">
                                                @(c.Estado == true ? "Activo" : "Inactivo")
                                            </span>
                                        </td>
                                        <td class="text-center col-acciones">
                                            <div class="action-group">
                                                <button type="button" class="action-btn action-view" title="Ver"
                                                        @onclick="() => { enVista = c; }">
                                                    <i class="ri-eye-line"></i>
                                                </button>
                                                <button type="button" class="action-btn action-edit" title="Editar"
                                                        @onclick="() => CargarEdicion(c)">
                                                    <i class="ri-pencil-line"></i>
                                                </button>
                                                @if (c.Estado == true)
                                                {
                                                    <button type="button" class="action-btn action-delete" title="Desactivar"
                                                            @onclick="() => ConfirmarDesactivar(c)">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="action-btn action-activate" title="Activar"
                                                            @onclick="() => ConfirmarActivar(c)">
                                                        <i class="ri-checkbox-circle-line"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="table-pagination">
                        <span>Mostrando @PrimerReg-@UltimoReg de @TotalFiltrados registros</span>
                        <div class="pagination-actions">
                            <button class="pagination-btn" disabled="@(paginaActual <= 1)"
                                    @onclick="() => paginaActual--">
                                <i class="ri-arrow-left-s-line"></i>
                            </button>
                            <strong>@paginaActual / @TotalPaginas</strong>
                            <button class="pagination-btn" disabled="@(paginaActual >= TotalPaginas)"
                                    @onclick="() => paginaActual++">
                                <i class="ri-arrow-right-s-line"></i>
                            </button>
                        </div>
                    </div>
                }
            </section>
        </div>

        @* ── Columna Derecha (Formulario O Vista de Detalle) ── *@
        <div class="grid-right-col">
            @if (enVista is not null)
            {
                @* Vista de Detalle (Reemplaza al formulario) *@
                <section class="editor-card entity-editor-card detail-card-interactive">
                    <div class="editor-head" style="border-bottom: 1px solid rgba(108, 99, 255, 0.15)">
                        <div>
                            <span class="panel-kicker" style="color:#6C63FF">Detalle contribuyente</span>
                            <h3>@NombreCompleto(enVista)</h3>
                            <p>Código contribuyente: #@enVista.CodContribuyente</p>
                        </div>
                        <button class="detail-close-btn" @onclick="() => enVista = null">&times;</button>
                    </div>

                    <div class="editor-body">
                        <div class="detail-sections">
                            <section class="detail-section">
                                <h4 class="detail-section-title">Datos principales</h4>
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <span>Identificación</span>
                                        <strong>@(enVista.Numeroidentificacion ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Estado</span>
                                        <strong>@(enVista.Estado == true ? "Activo" : "Inactivo")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Correo</span>
                                        <strong>@(enVista.Correo ?? "Sin correo")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Obligado contabilidad</span>
                                        <strong>@(enVista.Oblgconta ?? "No definido")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Persona natural</span>
                                        <strong>@(enVista.PersonaNatural == true ? "Sí" : "No")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Contribuyente especial</span>
                                        <strong>@(enVista.ContribuyenteEspecial == true ? "Sí" : "No")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>N° Contribuyente</span>
                                        <strong>@(enVista.NumContribuyente ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Periodicidad IVA</span>
                                        <strong>@(enVista.PeriodicidadIva ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Periodicidad Renta</span>
                                        <strong>@(enVista.PeriodicidadRenta ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item detail-item-full">
                                        <span>Fecha Declaración</span>
                                        <strong>@(enVista.FechaDeclaracion?.ToString("dd/MM/yyyy") ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item detail-item-full">
                                        <span>Actividad</span>
                                        <strong>@(enVista.ActividadContribuyente ?? "Sin datos")</strong>
                                    </div>
                                </div>
                            </section>
                            
                            @if (enVista.CorreosAdicionales.Any())
                            {
                                <section class="detail-section">
                                    <h4 class="detail-section-title">Correos Adicionales</h4>
                                    <div class="detail-note">
                                        @foreach (var extra in enVista.CorreosAdicionales)
                                        {
                                            <div style="margin-bottom: 0.25rem;">
                                                <strong><i class="ri-mail-line"></i> @extra</strong>
                                            </div>
                                        }
                                    </div>
                                </section>
                            }

                            <section class="detail-section">
                                <h4 class="detail-section-title">Contacto</h4>
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <span>Teléfono</span>
                                        <strong>@(enVista.Telefonoconvencional ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Celular</span>
                                        <strong>@(enVista.Celular ?? "Sin datos")</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>País</span>
                                        <strong>@(string.IsNullOrWhiteSpace(GetPaisNombre(enVista.Pais)) ? "Sin país" : GetPaisNombre(enVista.Pais))</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Provincia</span>
                                        <strong>@(string.IsNullOrWhiteSpace(GetProvinciaNombre(enVista.Provincia)) ? "Sin provincia" : GetProvinciaNombre(enVista.Provincia))</strong>
                                    </div>
                                    <div class="detail-item">
                                        <span>Ciudad</span>
                                        <strong>@(string.IsNullOrWhiteSpace(GetCiudadNombre(enVista.Ciudad)) ? "Sin ciudad" : GetCiudadNombre(enVista.Ciudad))</strong>
                                    </div>
                                    <div class="detail-item detail-item-full">
                                        <span>Dirección</span>
                                        <strong>@(enVista.Direccion ?? "Sin datos")</strong>
                                    </div>
                                </div>
                            </section>
                            
                            @if (!string.IsNullOrWhiteSpace(enVista.Observaciones))
                            {
                                <div class="detail-note">
                                    <span>Observaciones</span>
                                    <strong>@enVista.Observaciones</strong>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="detail-modal-footer" style="padding: 1rem 1.5rem; border-top: 1px solid rgba(108, 99, 255, 0.15); display: flex; justify-content: flex-end; gap: 0.75rem;">
                        <button class="secondary-btn" @onclick="() => CargarEdicion(enVista)">Editar Datos</button>
                        <button class="primary-btn" style="background:#6C63FF" @onclick="() => enVista = null">Cerrar</button>
                    </div>
                </section>
            }
            else
            {
                @* Formulario de Registro / Edición *@
                <section class="editor-card entity-editor-card">
                    <div class="editor-head">
                        <div>
                            <span class="panel-kicker" style="color:#6C63FF">Formulario</span>
                            <h3>@(editando ? "Editar contribuyente" : "Registrar contribuyente")</h3>
                            <p>Completa la información del contribuyente para el módulo tributario.</p>
                        </div>
                        <span class="editor-badge @(editando ? "editor-badge-edit" : "editor-badge-new")">
                            @(editando ? "Edición" : "Nuevo")
                        </span>
                    </div>

                    <div class="editor-body entity-form-legacy">
                        <EditForm EditContext="editContext" OnSubmit="Guardar">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger small mb-3 fw-semibold" />

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Tipo de Contribuyente *</label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="modeloPersonaNaturalString" style="border-color:#6C63FF">
                                    <option value="true">Persona Natural</option>
                                    <option value="false">Sociedad / Persona Jurídica</option>
                                </InputSelect>
                            </div>

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small fw-bold">Tipo identificación *</label>
                                    <InputSelect class="form-select form-select-sm"
                                                 Value="@modelo.Tipoidentificacion"
                                                 ValueExpression="() => modelo.Tipoidentificacion"
                                                 ValueChanged="(string val) => { modelo.Tipoidentificacion = val; CalcularFechaDeclaracion(); }">
                                        <option value="">-- Seleccione --</option>
                                        @foreach (var id in identificaciones)
                                        {
                                            <option value="@id.Codigo">@id.Descripcion</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => modelo.Tipoidentificacion)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label small fw-bold">N° Identificación *</label>
                                    <InputText class="form-control form-control-sm" 
                                               Value="@modelo.Numeroidentificacion" 
                                               ValueExpression="() => modelo.Numeroidentificacion" 
                                               ValueChanged="OnIdentificacionInput" />
                                    <ValidationMessage For="@(() => modelo.Numeroidentificacion)" class="text-danger small" />
                                </div>
                            </div>

                            @if (modeloPersonaNatural)
                            {
                                <div class="row mb-2">
                                    <div class="col">
                                        <label class="form-label small fw-bold">Apellidos * </label>
                                        <InputText class="form-control form-control-sm" 
                                                   Value="@modelo.Apellidos" 
                                                   ValueExpression="() => modelo.Apellidos" 
                                                   ValueChanged="OnApellidosInput" 
                                                   placeholder="Ej: Pérez Gómez" />
                                        <ValidationMessage For="@(() => modelo.Apellidos)" class="text-danger small" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label small fw-bold">Nombres *</label>
                                        <InputText class="form-control form-control-sm" 
                                                   Value="@modelo.Nombres" 
                                                   ValueExpression="() => modelo.Nombres" 
                                                   ValueChanged="OnNombresInput" 
                                                   placeholder="Ej: Juan Carlos" />
                                        <ValidationMessage For="@(() => modelo.Nombres)" class="text-danger small" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="row mb-2">
                                    <div class="col">
                                        <label class="form-label small fw-bold">Nombre comercial *</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="modelo.Nombrecomercial" />
                                        <ValidationMessage For="@(() => modelo.Nombrecomercial)" class="text-danger small" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label small fw-bold">Razón social *</label>
                                        <InputText class="form-control form-control-sm" @bind-Value="modelo.Nombrerazonsocial" />
                                        <ValidationMessage For="@(() => modelo.Nombrerazonsocial)" class="text-danger small" />
                                    </div>
                                </div>
                            }

                            @* Sección de correos múltiples *@
                            <div class="email-fields-shell mb-3">
                                <div class="form-group">
                                    <label class="form-label small fw-bold">Correo Principal *</label>
                                    <div class="email-primary-row">
                                        <InputText type="email" @bind-Value="modelo.Correo" class="form-control form-control-sm" placeholder="correo@empresa.com" />
                                        <button type="button" class="email-add-icon-btn" @onclick="AgregarCorreoCampo" title="Agregar correo adicional">
                                            <i class="ri-add-line"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => modelo.Correo)" class="text-danger small" />
                                </div>

                                @if (modelo.CorreosAdicionales.Any())
                                {
                                    <div class="email-extra-shell">
                                        <div class="email-extra-head">
                                            <label class="form-label small fw-bold mb-0">Correos adicionales</label>
                                            <button type="button" class="email-add-btn" @onclick="AgregarCorreoCampo">
                                                <i class="ri-add-line"></i>
                                                <span>Agregar otro correo</span>
                                            </button>
                                        </div>

                                        @for (var i = 0; i < modelo.CorreosAdicionales.Count; i++)
                                        {
                                            var index = i;
                                            <div class="email-extra-row">
                                                <InputText type="email" @bind-Value="modelo.CorreosAdicionales[index]" class="form-control form-control-sm" placeholder="adicional@empresa.com" />
                                                <button type="button" class="email-remove-btn" @onclick="() => EliminarCorreoAdicional(index)" title="Eliminar correo adicional">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small">Teléfono Convencional</label>
                                    <InputText class="form-control form-control-sm" 
                                               Value="@modelo.Telefonoconvencional" 
                                               ValueExpression="() => modelo.Telefonoconvencional" 
                                               ValueChanged="OnTelefonoInput" />
                                    <ValidationMessage For="@(() => modelo.Telefonoconvencional)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label small fw-bold">Celular *</label>
                                    <InputText class="form-control form-control-sm" 
                                               Value="@modelo.Celular" 
                                               ValueExpression="() => modelo.Celular" 
                                               ValueChanged="OnCelularInput" />
                                    <ValidationMessage For="@(() => modelo.Celular)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small fw-bold">Obligado contabilidad *</label>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="modelo.Oblgconta">
                                        <option value="">-- Seleccione --</option>
                                        <option value="SI">SI</option>
                                        <option value="NO">NO</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => modelo.Oblgconta)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label small">N° Contribuyente</label>
                                    <InputText class="form-control form-control-sm" 
                                               Value="@modelo.NumContribuyente" 
                                               ValueExpression="() => modelo.NumContribuyente" 
                                               ValueChanged="OnNumContribuyenteInput" />
                                    <ValidationMessage For="@(() => modelo.NumContribuyente)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small fw-bold">Periodicidad IVA *</label>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="modelo.PeriodicidadIva">
                                        <option value="">-- Seleccione --</option>
                                        <option value="Mensual">Mensual</option>
                                        <option value="Semestral">Semestral</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => modelo.PeriodicidadIva)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label small fw-bold">Periodicidad Renta *</label>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="modelo.PeriodicidadRenta">
                                        <option value="">-- Seleccione --</option>
                                        <option value="Régimen General">Régimen General</option>
                                        <option value="Régimen Emprendedor">Régimen Emprendedor</option>
                                        <option value="Régimen Negocio Popular">Régimen Negocio Popular</option>
                                        <option value="Régimen Mixto">Régimen Mixto</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => modelo.PeriodicidadRenta)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="mb-2">
                                <label class="form-label small fw-bold">Fecha Declaración *</label>
                                <InputDate class="form-control form-control-sm" @bind-Value="modelo.FechaDeclaracion" />
                                <ValidationMessage For="@(() => modelo.FechaDeclaracion)" class="text-danger small" />
                            </div>

                            <div class="row mb-2">
                                <div class="col">
                                    <label class="form-label small fw-bold">País *</label>
                                    <InputSelect class="form-select form-select-sm"
                                                 Value="@modelo.Pais"
                                                 ValueExpression="() => modelo.Pais"
                                                 ValueChanged="async (int? val) => { modelo.Pais = val; await OnPaisChangedAsync(); }">
                                        <option value="">-- Seleccione País --</option>
                                        @foreach (var p in paises)
                                        {
                                            <option value="@p.IdPais">@p.Descripcion</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => modelo.Pais)" class="text-danger small" />
                                </div>
                                <div class="col">
                                    <label class="form-label small fw-bold">Provincia *</label>
                                    <InputSelect class="form-select form-select-sm"
                                                 Value="@modelo.Provincia"
                                                 ValueExpression="() => modelo.Provincia"
                                                 ValueChanged="async (int? val) => { modelo.Provincia = val; await OnProvinciaChangedAsync(); }"
                                                 disabled="@(modelo.Pais is null)">
                                        <option value="">-- Seleccione Provincia --</option>
                                        @foreach (var pr in ProvinciasDisponibles)
                                        {
                                            <option value="@pr.IdProvincia">@pr.Descripcion</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => modelo.Provincia)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="mb-2">
                                <label class="form-label small fw-bold">Ciudad *</label>
                                <InputSelect class="form-select form-select-sm"
                                             @bind-Value="modelo.Ciudad"
                                             disabled="@(modelo.Provincia is null || !CiudadesDisponibles.Any())">
                                    <option value="">@(modelo.Provincia.HasValue ? "-- Seleccione Ciudad --" : "-- Seleccione una provincia --")</option>
                                    @foreach (var c in CiudadesDisponibles)
                                    {
                                        <option value="@c.IdCiudad">@c.Descripcion</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => modelo.Ciudad)" class="text-danger small" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label small fw-bold">Dirección *</label>
                                <InputText class="form-control form-control-sm" @bind-Value="modelo.Direccion" />
                                <ValidationMessage For="@(() => modelo.Direccion)" class="text-danger small" />
                            </div>

                            <div class="mb-2 d-flex align-items-center gap-3 pt-2">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="modeloEspecial" id="chkEspecial" />
                                    <label class="form-check-label small" for="chkEspecial">Contribuyente especial</label>
                                </div>
                            </div>

                            <div class="mb-2">
                                <label class="form-label small">Actividad del contribuyente</label>
                                <InputTextArea class="form-control form-control-sm" rows="2"
                                               @bind-Value="modelo.ActividadContribuyente" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label small">Observaciones</label>
                                <InputTextArea class="form-control form-control-sm" rows="2"
                                               @bind-Value="modelo.Observaciones" />
                            </div>

                            @if (!editando && limiteExcedido)
                            {
                                <div class="status-banner status-banner-error mb-3" style="border-radius:12px; margin-bottom: 1rem; padding: 0.75rem;">
                                    <i class="ri-error-warning-line"></i>
                                    <span>Has alcanzado el límite de <strong>@limiteContribuyentes</strong> contribuyente(s) activo(s) para tu plan actual. Para agregar más, debes actualizar tu plan en la sección de Suscripción.</span>
                                </div>
                            }

                            <div class="form-actions entity-form-actions">
                                <button type="button" class="secondary-btn" @onclick="Limpiar">Limpiar</button>
                                <button type="submit" class="primary-btn"
                                        disabled="@(!editando && limiteExcedido)"
                                        style="background:#6C63FF;background-image:linear-gradient(135deg,#6C63FF,#8c85ff)">
                                    <i class="ri-save-line"></i>
                                    @(editando ? "Guardar cambios" : "Crear contribuyente")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </section>
            }
        </div>
    </section>
</div>

