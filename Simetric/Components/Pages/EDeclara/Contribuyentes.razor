@code {
    private int userId;
    private bool cargando = true;
    private string? mensaje;
    private string? errorMsg;

    private int limiteContribuyentes = 0;
    private int actualContribuyentesActivos = 0;
    private bool limiteExcedido = false;

    private string filtro = "";
    private int registrosPorPagina = 10;
    private int paginaActual = 1;

    private ContribuyenteDto? enVista;
    private bool editando;

    private List<ContribuyenteDto> contribuyentes = new();

    // Modelo formulario
    private ContribuyenteUpsertDto modelo = new();
    private bool modeloPersonaNatural = true;
    private bool modeloEspecial;

    private EditContext? editContext;
    private ValidationMessageStore? messageStore;

    private List<PaisLookupDto> paises = new();
    private List<ProvinciaLookupDto> provincias = new();
    private List<CiudadLookupDto> ciudades = new();
    private int? ecuadorPaisId;

    private IEnumerable<ProvinciaLookupDto> ProvinciasDisponibles =>
        provincias
            .Where(x => x.IdPais == modelo.Pais)
            .OrderBy(GetOrdenProvincia)
            .ThenBy(x => x.Descripcion);

    private IEnumerable<CiudadLookupDto> CiudadesDisponibles =>
        ciudades
            .Where(x => x.IdProvincia == modelo.Provincia)
            .OrderBy(x => x.Descripcion);

    private class PaisLookupDto
    {
        public int IdPais { get; set; }
        public string Descripcion { get; set; } = "";
    }

    private class ProvinciaLookupDto
    {
        public int IdProvincia { get; set; }
        public string Descripcion { get; set; } = "";
        public int? IdPais { get; set; }
    }

    private class CiudadLookupDto
    {
        public int IdCiudad { get; set; }
        public string Descripcion { get; set; } = "";
        public int? IdProvincia { get; set; }
    }

    // Toggle string para bindeo del dropdown de tipo de contribuyente
    private string modeloPersonaNaturalString
    {
        get => modeloPersonaNatural.ToString().ToLowerInvariant();
        set
        {
            if (bool.TryParse(value, out var parsed))
            {
                modeloPersonaNatural = parsed;
                modelo.PersonaNatural = parsed;
                if (parsed)
                {
                    modelo.Nombrecomercial = null;
                    modelo.Nombrerazonsocial = null;
                }
                else
                {
                    modelo.Apellidos = null;
                    modelo.Nombres = null;
                }
                editContext?.Validate();
                StateHasChanged();
            }
        }
    }

    // Lookups de identificaciones
    private List<IdentificacionItem> identificaciones = new();
    private record IdentificacionItem(string Codigo, string Descripcion);

    // Paginación y Filtros
    private string filtroTipoContribuyente = "todos";

    private IEnumerable<ContribuyenteDto> ContribuFiltrados =>
        contribuyentes.Where(c =>
            (string.IsNullOrWhiteSpace(filtro) ||
             $"{c.Apellidos} {c.Nombres}".Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
             (c.Numeroidentificacion ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
             (c.Correo ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
             (c.Nombrerazonsocial ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase) ||
             (c.Nombrecomercial ?? "").Contains(filtro, StringComparison.OrdinalIgnoreCase)) &&
            (filtroTipoContribuyente == "todos" ||
             (filtroTipoContribuyente == "natural" && c.PersonaNatural == true) ||
             (filtroTipoContribuyente == "sociedad" && c.PersonaNatural != true))
        );

    private int TotalFiltrados => ContribuFiltrados.Count();
    private int TotalPaginas => Math.Max(1, (int)Math.Ceiling(TotalFiltrados / (double)registrosPorPagina));
    private int PrimerReg => TotalFiltrados == 0 ? 0 : ((paginaActual - 1) * registrosPorPagina) + 1;
    private int UltimoReg => Math.Min(paginaActual * registrosPorPagina, TotalFiltrados);

    private IEnumerable<ContribuyenteDto> ContribuPaginados =>
        ContribuFiltrados.Skip((paginaActual - 1) * registrosPorPagina).Take(registrosPorPagina);

    protected override void OnInitialized()
    {
        ReinitValidation();
    }

    private void ReinitValidation()
    {
        if (editContext != null)
        {
            editContext.OnValidationRequested -= HandleValidationRequested;
            editContext.OnFieldChanged -= HandleFieldChanged;
        }
        editContext = new EditContext(modelo);
        messageStore = new ValidationMessageStore(editContext);
        editContext.OnValidationRequested += HandleValidationRequested;
        editContext.OnFieldChanged += HandleFieldChanged;
    }

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        messageStore?.Clear(e.FieldIdentifier);
    }

    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs e)
    {
        messageStore?.Clear();

        // 1. Validación de Identificación Ecuatoriana (si el país es Ecuador)
        if (modelo.Pais == ecuadorPaisId && !string.IsNullOrWhiteSpace(modelo.Numeroidentificacion))
        {
            var ident = modelo.Numeroidentificacion.Trim();
            if (ident.All(char.IsDigit))
            {
                if (modelo.Tipoidentificacion == "05") // Cédula
                {
                    if (ident.Length != 10)
                    {
                        messageStore?.Add(() => modelo.Numeroidentificacion!, "La cédula debe tener exactamente 10 dígitos.");
                    }
                    else if (!ValidarCedulaEcuatoriana(ident))
                    {
                        messageStore?.Add(() => modelo.Numeroidentificacion!, "La cédula ecuatoriana ingresada no es válida.");
                    }
                }
                else if (modelo.Tipoidentificacion == "04") // RUC
                {
                    if (ident.Length != 13)
                    {
                        messageStore?.Add(() => modelo.Numeroidentificacion!, "El RUC debe tener exactamente 13 dígitos.");
                    }
                    else if (!ValidarRucEcuatoriano(ident))
                    {
                        messageStore?.Add(() => modelo.Numeroidentificacion!, "El RUC ecuatoriano ingresado no es válido.");
                    }
                }
            }
        }

        // 2. Validación de duplicados local en el listado
        if (!string.IsNullOrWhiteSpace(modelo.Numeroidentificacion))
        {
            var ident = modelo.Numeroidentificacion.Trim();
            var duplicado = contribuyentes.Any(c => 
                string.Equals(c.Numeroidentificacion?.Trim(), ident, StringComparison.OrdinalIgnoreCase) && 
                (!editando || c.CodContribuyente != _editandoId));
            if (duplicado)
            {
                messageStore?.Add(() => modelo.Numeroidentificacion!, "El número de identificación ya está registrado.");
            }
        }

        // 3. País, Provincia y Ciudad (no definidos en el DTO)
        if (!modelo.Pais.HasValue || modelo.Pais <= 0)
        {
            messageStore?.Add(() => modelo.Pais!, "Debe seleccionar un país.");
        }
        else
        {
            if (!modelo.Provincia.HasValue || modelo.Provincia <= 0)
            {
                messageStore?.Add(() => modelo.Provincia!, "Debe seleccionar una provincia.");
            }
            if (!modelo.Ciudad.HasValue || modelo.Ciudad <= 0)
            {
                messageStore?.Add(() => modelo.Ciudad!, "Debe seleccionar una ciudad.");
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var idStr = user.FindFirst("IdUsuario")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!int.TryParse(idStr, out userId) || userId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        await CargarIdentificaciones();
        await CargarTodo();
    }

    private async Task CargarIdentificaciones()
    {
        try
        {
            var resp = await Http.GetAsync("api/clientes/lookups");
            if (!resp.IsSuccessStatusCode) return;

            var body = await resp.Content.ReadAsStringAsync();
            using var doc = System.Text.Json.JsonDocument.Parse(body);

            if (doc.RootElement.TryGetProperty("identificaciones", out var idElem))
            {
                identificaciones = idElem.EnumerateArray().Select(i => new IdentificacionItem(
                    i.TryGetProperty("ideCodigo", out var cod) ? cod.GetString() ?? "" : "",
                    i.TryGetProperty("ideDescripcion", out var desc) ? desc.GetString() ?? "" : ""
                )).ToList();
            }
        }
        catch { /* silencioso */ }
    }

    private async Task CargarTodo(bool esRefresco = false)
    {
        cargando = true;
        mensaje = null;
        errorMsg = null;
        StateHasChanged();

        try
        {
            await CargarPaises();
            await CargarUbicacionEcuador();

            if (!modelo.Pais.HasValue && ecuadorPaisId.HasValue)
                modelo.Pais = ecuadorPaisId;

            // Cargar límite de contribuyentes
            try
            {
                var limiteResp = await Http.GetAsync($"api/contribuyentes-edeclara/limite-estado?userId={userId}");
                if (limiteResp.IsSuccessStatusCode)
                {
                    var limitBody = await limiteResp.Content.ReadAsStringAsync();
                    using var limitDoc = System.Text.Json.JsonDocument.Parse(limitBody);
                    var root = limitDoc.RootElement;
                    limiteContribuyentes = root.GetProperty("limite").GetInt32();
                    actualContribuyentesActivos = root.GetProperty("actual").GetInt32();
                    limiteExcedido = root.GetProperty("excedido").GetBoolean();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al cargar límite de contribuyentes: {ex.Message}");
            }

            var resp = await Http.GetAsync($"api/contribuyentes-edeclara?userId={userId}");
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
                throw new Exception($"HTTP {(int)resp.StatusCode}: {body}");

            contribuyentes = System.Text.Json.JsonSerializer.Deserialize<List<ContribuyenteDto>>(
                body,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();

            await PrepararLookupsUbicacionParaListado();

            if (esRefresco) mensaje = "Datos actualizados.";
        }
        catch (Exception ex)
        {
            errorMsg = ex.Message;
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

