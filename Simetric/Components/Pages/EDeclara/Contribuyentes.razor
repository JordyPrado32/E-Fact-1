    private void OnIdentificacionInput(string val)
    {
        int maxLength = 13;
        bool onlyDigits = true;

        if (modelo.Tipoidentificacion == "05") // Cédula
        {
            maxLength = 10;
        }
        else if (modelo.Tipoidentificacion == "04") // RUC
        {
            maxLength = 13;
        }
        else if (modelo.Tipoidentificacion == "06") // Pasaporte
        {
            onlyDigits = false;
            maxLength = 20;
        }

        string cleaned = val;
        if (onlyDigits)
        {
            cleaned = new string(val.Where(char.IsDigit).ToArray());
        }
        if (cleaned.Length > maxLength)
        {
            cleaned = cleaned[..maxLength];
        }

        modelo.Numeroidentificacion = cleaned;

        CalcularFechaDeclaracion();

        if (editContext != null)
        {
            editContext.NotifyFieldChanged(editContext.Field(nameof(modelo.Numeroidentificacion)));
        }
    }

    private void CalcularFechaDeclaracion()
    {
        if (string.IsNullOrWhiteSpace(modelo.Numeroidentificacion)) return;

        bool esEcuador = (modelo.Tipoidentificacion == "05" || modelo.Tipoidentificacion == "04") ||
                         (modelo.Pais == ecuadorPaisId || !modelo.Pais.HasValue || ecuadorPaisId == null);

        if (!esEcuador)
        {
            return;
        }

        var cleaned = new string(modelo.Numeroidentificacion.Where(char.IsDigit).ToArray());
        if (cleaned.Length >= 9)
        {
            if (char.IsDigit(cleaned[8]))
            {
                int novenoDigito = cleaned[8] - '0';
                int dia = (novenoDigito == 0) ? 28 : (novenoDigito * 2) + 8;
                
                var baseDate = modelo.FechaDeclaracion ?? DateOnly.FromDateTime(DateTime.Today);
                modelo.FechaDeclaracion = new DateOnly(baseDate.Year, baseDate.Month, dia);

                if (editContext != null)
                {
                    editContext.NotifyFieldChanged(editContext.Field(nameof(modelo.FechaDeclaracion)));
                }
            }
        }
    }

