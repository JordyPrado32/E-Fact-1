@* ============================================================
   E-Declara / Configuración — Períodos
   Ruta: /e-declara/configuracion/periodos
   ============================================================ *@
@page "/e-declara/configuracion/periodos"
@rendermode InteractiveServer
@using Simetric.Services
@inject NavigationManager NavManager

<PageTitle>Períodos | E-Declara</PageTitle>

<div class="edeclara-page">
    <section class="edeclara-overview">
        <article class="edeclara-spotlight">
            <div class="section-head section-head-tight">
                <div>
                    <span class="section-kicker">Configuración · E-Declara</span>
                    <h3>Períodos</h3>
                </div>
                <button type="button" class="primary-btn">
                    <i class="bi bi-plus-lg"></i>
                    <span>Nuevo período</span>
                </button>
            </div>
            <p class="summary-spotlight-copy">
                Define y administra los períodos fiscales disponibles para las declaraciones tributarias.
            </p>
        </article>
    </section>

    <section class="edeclara-grid">
        <article class="edeclara-panel" style="grid-column: 1 / -1;">
            <div class="empty-panel">
                <i class="bi bi-calendar3"></i>
                <p>La tabla de períodos se implementará aquí.</p>
            </div>
        </article>
    </section>
</div>

@code { }
