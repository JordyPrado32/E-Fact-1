@page "/demo/soporte"
@layout Simetric.Components.Layout.MainLayout
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Soporte demo | Numerica e-fact</PageTitle>

<div class="demo-support-shell">
    <section class="support-hero">
        <div>
            <span class="support-kicker">Centro de ayuda e-fact</span>
            <h1>¿En qué podemos ayudarte?</h1>
            <p>Busca respuestas sobre emisión, clientes, recargas y configuración general del sistema.</p>
            <label class="support-search">
                <i class="ri-search-line"></i>
                <input type="search" placeholder="Ejemplo: factura rechazada o recarga" @bind="busqueda" @bind:event="oninput" />
                @if (!string.IsNullOrWhiteSpace(busqueda))
                {
                    <button type="button" @onclick="() => busqueda = string.Empty" aria-label="Limpiar búsqueda"><i class="ri-close-line"></i></button>
                }
            </label>
        </div>
        <div class="support-illustration" aria-hidden="true">
            <span><i class="ri-customer-service-2-line"></i></span>
            <strong>Soporte experto</strong>
            <small>Estamos para ayudarte</small>
        </div>
    </section>

    <section class="support-categories">
        @foreach (var categoria in Categorias)
        {
            <button type="button" class="@(categoriaActiva == categoria.Nombre ? "active" : string.Empty)" @onclick="() => SeleccionarCategoria(categoria.Nombre)">
                <i class="@categoria.Icono"></i><span>@categoria.Nombre</span>
            </button>
        }
    </section>

    <div class="support-content-grid">
        <section class="faq-panel">
            <div class="section-head">
                <div><span>Preguntas frecuentes</span><h2>Respuestas rápidas</h2></div>
                <small>@PreguntasFiltradas.Count() resultado(s)</small>
            </div>

            <div class="faq-list">
                @if (!PreguntasFiltradas.Any())
                {
                    <div class="empty-support"><i class="ri-search-eye-line"></i><strong>No encontramos esa respuesta</strong><span>Prueba con factura, cliente, recarga, correo o firma.</span></div>
                }
                else
                {
                    @foreach (var pregunta in PreguntasFiltradas)
                    {
                        var abierta = preguntaAbierta == pregunta.Id;
                        <article class="faq-item @(abierta ? "open" : string.Empty)">
                            <button type="button" @onclick="() => AlternarPregunta(pregunta.Id)">
                                <span class="faq-icon"><i class="@pregunta.Icono"></i></span>
                                <strong>@pregunta.Pregunta</strong>
                                <i class="@(abierta ? "ri-subtract-line" : "ri-add-line")"></i>
                            </button>
                            @if (abierta)
                            {
                                <p>@pregunta.Respuesta</p>
                            }
                        </article>
                    }
                }
            </div>
        </section>

        <aside class="support-side">
            <article class="contact-card">
                <div class="section-head"><div><span>Canales oficiales</span><h2>Contáctanos</h2></div></div>
                <a href="https://wa.me/593995876753?text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20e-fact" target="_blank" rel="noopener noreferrer" class="channel whatsapp">
                    <span><i class="ri-whatsapp-line"></i></span><div><strong>WhatsApp</strong><small>Atención personalizada</small></div><i class="ri-arrow-right-line"></i>
                </a>
                <a href="mailto:soporte@numericasoftware.com?subject=Consulta%20sobre%20e-fact" class="channel email">
                    <span><i class="ri-mail-line"></i></span><div><strong>Correo electrónico</strong><small>soporte@numericasoftware.com</small></div><i class="ri-arrow-right-line"></i>
                </a>
            </article>

            <article class="service-card">
                <div class="service-status"><i class="ri-checkbox-circle-fill"></i><div><strong>Servicios operativos</strong><small>Plataforma disponible</small></div></div>
                <hr />
                <div class="service-hours"><i class="ri-time-line"></i><div><strong>Horario de atención</strong><small>Lunes a viernes, 09:00–18:00</small></div></div>
            </article>

            <a href="/demo/portal" class="portal-return"><i class="ri-arrow-left-line"></i> Volver al portal demo</a>
        </aside>
    </div>
</div>

@code {
    private string busqueda = string.Empty;
    private string categoriaActiva = "Todos";
    private int preguntaAbierta = 1;
    private static readonly IReadOnlyList<CategoriaSoporte> Categorias =
    [
        new("Todos", "ri-grid-line"), new("Facturación", "ri-file-list-3-line"),
        new("Clientes", "ri-group-line"), new("Recargas", "ri-coins-line"),
        new("Configuración", "ri-settings-3-line")
    ];
    private static readonly IReadOnlyList<PreguntaSoporte> Preguntas =
    [
        new(1, "Facturación", "ri-file-add-line", "¿Cómo emito una factura electrónica?", "Ingresa a Nueva factura, selecciona el cliente, agrega productos o servicios, revisa los totales y emite. El sistema prepara el XML, firma el comprobante y consulta su autorización en el SRI."),
        new(2, "Facturación", "ri-error-warning-line", "¿Qué hago si el SRI rechaza un comprobante?", "Revisa el mensaje recibido, corrige los datos tributarios, la fecha, la serie o la firma que correspondan y vuelve a procesarlo desde el historial."),
        new(3, "Clientes", "ri-user-add-line", "¿Cómo registro un cliente con RUC o cédula?", "Selecciona el tipo de identificación, registra el número y completa razón social o nombres, dirección y correo antes de guardar."),
        new(4, "Clientes", "ri-file-excel-2-line", "¿Puedo importar clientes y productos?", "Sí. Las pantallas de clientes y productos permiten importar archivos con la estructura solicitada y revisar los datos antes de guardarlos."),
        new(5, "Recargas", "ri-bank-card-line", "¿Cómo compro documentos para emitir?", "En Recargas y planes selecciona un paquete o ingresa una cantidad personalizada. El saldo se acredita cuando el pago queda aprobado."),
        new(6, "Recargas", "ri-wallet-3-line", "¿Dónde reviso el saldo disponible?", "El saldo se muestra en el panel principal y en la pantalla de recargas, junto con el historial de compras aprobadas."),
        new(7, "Configuración", "ri-quill-pen-line", "¿Qué debo configurar antes de emitir?", "Completa los datos del emisor, establecimiento, punto de emisión, secuencia y certificado de firma electrónica."),
        new(8, "Configuración", "ri-mail-settings-line", "¿Por qué no llegó el correo al cliente?", "Verifica que el comprobante esté autorizado, que el cliente tenga un correo válido y revisa el estado del envío en el historial.")
    ];
    private IEnumerable<PreguntaSoporte> PreguntasFiltradas => Preguntas.Where(p =>
        (categoriaActiva == "Todos" || p.Categoria == categoriaActiva) &&
        (string.IsNullOrWhiteSpace(busqueda) || p.Pregunta.Contains(busqueda.Trim(), StringComparison.OrdinalIgnoreCase) ||
         p.Respuesta.Contains(busqueda.Trim(), StringComparison.OrdinalIgnoreCase) || p.Categoria.Contains(busqueda.Trim(), StringComparison.OrdinalIgnoreCase)));
    private void SeleccionarCategoria(string categoria) { categoriaActiva = categoria; preguntaAbierta = PreguntasFiltradas.FirstOrDefault()?.Id ?? 0; }
    private void AlternarPregunta(int id) => preguntaAbierta = preguntaAbierta == id ? 0 : id;
    private sealed record CategoriaSoporte(string Nombre, string Icono);
    private sealed record PreguntaSoporte(int Id, string Categoria, string Icono, string Pregunta, string Respuesta);
}
