@page "/solicitud/pagos"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.DTOs
@using Simetric.Services
@using System.Security.Claims
@inject SolicitudService SolicitudService
@inject AuthenticationStateProvider AuthStateProvider
@inject SelectedAppServiceStateService SelectedAppServiceState

<PageTitle>Mis pagos | Numerica e-fact</PageTitle>

<div class="mis-pagos-shell" data-tour="pagos.page">
    <section class="mis-pagos-panel">
        <div class="mis-pagos-head" data-tour="pagos.header">
            <div>
                <span class="mis-pagos-kicker">Pagos</span>
                <h3>Mis pagos de solicitud</h3>
                <p>Revisa el estado de pago de tus solicitudes de firma electronica.</p>
            </div>

            <div class="mis-pagos-summary">
                <span class="mis-pagos-chip">
                    <i class="bi bi-list-ul"></i>
                    Total: @(solicitudes?.Count ?? 0)
                </span>
                <span class="mis-pagos-chip is-paid">
                    <i class="bi bi-check-circle"></i>
                    Pagados: @TotalPagados
                </span>
                <span class="mis-pagos-chip is-pending">
                    <i class="bi bi-clock"></i>
                    Pendientes: @TotalPendientes
                </span>
            </div>
        </div>

        @if (solicitudes is not null && solicitudes.Any())
        {
            <div class="mis-pagos-toolbar" data-tour="pagos.filters">
                <div class="mis-pagos-search">
                    <i class="bi bi-search"></i>
                    <input type="search"
                           placeholder="Buscar por solicitud, titular o referencia..."
                           @bind="Busqueda"
                           @bind:event="oninput" />
                </div>

                <div class="mis-pagos-filter-group">
                    <label>
                        <span>Pago</span>
                        <select @bind="FiltroPago">
                            <option value="todos">Todos</option>
                            <option value="pagado">Pagados</option>
                            <option value="pendiente">Pendientes</option>
                        </select>
                    </label>

                    <label>
                        <span>Solicitud</span>
                        <select @bind="FiltroEstadoSolicitud">
                            <option value="todos">Todos</option>
                            <option value="pendiente">Pendiente</option>
                            <option value="revision">Revision</option>
                            <option value="aprobada">Aprobada</option>
                            <option value="rechazada">Rechazada</option>
                        </select>
                    </label>
                </div>
            </div>

            <div class="mis-pagos-results-meta">
                <span>@TotalFiltrados resultado(s)</span>
                <span>Pagina @PaginaActual de @TotalPaginas</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorCarga))
        {
            <div class="mis-pagos-state mis-pagos-state-error">
                <div class="mis-pagos-state-icon">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h4>No se pudieron cargar tus pagos</h4>
                <p>@errorCarga</p>
            </div>
        }
        else if (solicitudes is null)
        {
            <div class="mis-pagos-state">
                <div class="mis-pagos-loader" aria-hidden="true"></div>
                <h4>Cargando tus pagos</h4>
                <p>Estamos consultando las solicitudes asociadas a tu usuario.</p>
            </div>
        }
        else if (!solicitudes.Any())
        {
            <div class="mis-pagos-state">
                <div class="mis-pagos-state-icon">
                    <i class="bi bi-receipt"></i>
                </div>
                <h4>Aun no tienes pagos registrados</h4>
                <p>Cuando generes una solicitud de firma, el pago aparecera aqui.</p>
                <a class="mis-pagos-primary" href="/solicitud/nueva">Nueva solicitud</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(mensajeRespuesta))
            {
                <div class="mis-pagos-response-message is-success">
                    <i class="bi bi-check-circle"></i>
                    <span>@mensajeRespuesta</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorRespuesta) && solicitudAvisoSeleccionadaId is null)
            {
                <div class="mis-pagos-response-message is-error">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@errorRespuesta</span>
                </div>
            }

            <div class="mis-pagos-table-wrap" data-tour="pagos.table">
                <table class="mis-pagos-table">
                    <thead>
                        <tr>
                            <th>Solicitud</th>
                            <th>Fecha</th>
                            <th>Firma</th>
                            <th>Total c/IVA</th>
                            <th>Pago</th>
                            <th>Estado solicitud</th>
                            <th>Soporte</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sol in SolicitudesPaginadas)
                        {
                            <tr>
                                <td data-label="Solicitud">
                                    <div class="mis-pagos-id">
                                        <strong>#@sol.SolId</strong>
                                        <span>@GetTitular(sol)</span>
                                    </div>
                                </td>
                                <td data-label="Fecha">
                                    <div class="mis-pagos-date">
                                        <strong>@sol.SolFechaSolicitud.ToString("dd/MM/yyyy")</strong>
                                        <span>@sol.SolFechaSolicitud.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td data-label="Firma">
                                    <div class="mis-pagos-firma">
                                        <strong>@GetFormatoFirma(sol.SolFormatoFirma)</strong>
                                        <span>@GetVigencia(sol.SolVigencia)</span>
                                    </div>
                                </td>
                                <td data-label="Total c/IVA">
                                    <strong class="mis-pagos-amount">@FormatearTotalConIva(sol.SolMontoPago)</strong>
                                </td>
                                <td data-label="Pago">
                                    <div class="mis-pagos-payment">
                                        <span class="mis-pagos-status @GetPagoClass(sol)">
                                            <i class="bi bi-circle-fill"></i>
                                            @GetEstadoPago(sol)
                                        </span>
                                        <small>@GetPagoDetalle(sol)</small>
                                    </div>
                                </td>
                                <td data-label="Estado solicitud">
                                    <span class="mis-pagos-status @GetSolicitudClass(sol.SolIdEstadoNumerica)">
                                        <i class="bi bi-circle-fill"></i>
                                        @GetEstadoSolicitud(sol)
                                    </span>
                                </td>
                                <td data-label="Soporte">
                                    @if (sol.ObservacionesPendientes > 0)
                                    {
                                        <div class="mis-pagos-support-alert">
                                            <button type="button"
                                                    class="mis-pagos-support-button"
                                                    @onclick="() => AbrirAvisosSoporte(sol.SolId)">
                                                <span class="mis-pagos-status is-support">
                                                    <i class="bi bi-bell-fill"></i>
                                                    @sol.ObservacionesPendientes aviso(s)
                                                </span>
                                                <i class="bi bi-chevron-right"></i>
                                            </button>
                                            <small>@GetUltimaNotificacion(sol)</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="mis-pagos-muted">Sin avisos</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPaginas > 1)
            {
                <div class="mis-pagos-pagination">
                    <button type="button" @onclick="PaginaAnterior" disabled="@(PaginaActual == 1)">
                        <i class="bi bi-chevron-left"></i>
                        <span>Anterior</span>
                    </button>

                    <div class="mis-pagos-pagination-pages">
                        @foreach (var pagina in PaginasVisibles)
                        {
                            <button type="button"
                                    class="@(pagina == PaginaActual ? "is-active" : string.Empty)"
                                    @onclick="() => IrAPagina(pagina)">
                                @pagina
                            </button>
                        }
                    </div>

                    <button type="button" @onclick="PaginaSiguiente" disabled="@(PaginaActual == TotalPaginas)">
                        <span>Siguiente</span>
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            }

            <div class="mis-pagos-actions" data-tour="pagos.action">
                <a class="mis-pagos-primary" href="/solicitud/nueva">Nueva solicitud</a>

            </div>
        }
    </section>

    @if (solicitudAvisoSeleccionadaId is not null)
    {
        var solicitudSeleccionada = SolicitudAvisoSeleccionada;
        var avisosSeleccionados = NotificacionesSolicitudSeleccionada.ToList();

        <div class="mis-pagos-modal-backdrop" @onclick="CerrarAvisosSoporte">
            <section class="mis-pagos-support-modal" role="dialog" aria-modal="true" aria-label="Avisos de soporte" @onclick:stopPropagation="true">
                <div class="mis-pagos-support-modal-head">
                    <div>
                        <span class="mis-pagos-kicker">Soporte</span>
                        <h4>Solicitud #@solicitudAvisoSeleccionadaId</h4>
                        <p>@GetTitularSolicitudGrupo(solicitudSeleccionada)</p>
                    </div>

                    <button type="button" class="mis-pagos-modal-close" @onclick="CerrarAvisosSoporte" aria-label="Cerrar avisos">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(mensajeRespuesta))
                {
                    <div class="mis-pagos-response-message is-success">
                        <i class="bi bi-check-circle"></i>
                        <span>@mensajeRespuesta</span>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorRespuesta))
                {
                    <div class="mis-pagos-response-message is-error">
                        <i class="bi bi-exclamation-triangle"></i>
                        <span>@errorRespuesta</span>
                    </div>
                }

                @if (!avisosSeleccionados.Any())
                {
                    <div class="mis-pagos-modal-empty">
                        <i class="bi bi-check2-circle"></i>
                        <strong>Sin avisos pendientes</strong>
                        <p>Esta solicitud no tiene requerimientos activos de soporte.</p>
                    </div>
                }
                else
                {
                    <div class="mis-pagos-notice-section-list">
                        @foreach (var grupo in avisosSeleccionados
                            .GroupBy(GetSeccionNotificacion)
                            .OrderBy(grupo => GetOrdenSeccionNotificacion(grupo.Key)))
                        {
                            <section class="mis-pagos-notice-section">
                                <div class="mis-pagos-notice-section-head">
                                    <h5>@grupo.Key</h5>
                                    <p>@GetAyudaSeccionNotificacion(grupo.Key)</p>
                                </div>

                                <div class="mis-pagos-notice-grid">
                                    @foreach (var notificacion in grupo)
                                    {
                                        <article class="mis-pagos-notice-card">
                                            <strong>@GetTipoNotificacion(notificacion)</strong>
                                            <p>@notificacion.ObsDetalle</p>
                                            <small>@notificacion.ObsFechaObservacion.ToString("dd/MM/yyyy HH:mm")</small>

                                            <div class="mis-pagos-response-form">
                                                @if (EsNotificacionCodigo(notificacion))
                                                {
                                                    <input value="@GetRespuesta(notificacion.ObsId)"
                                                           @oninput="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                           maxlength="6"
                                                           class="mis-pagos-code-response"
                                                           disabled="@(enviandoRespuestaId == notificacion.ObsId)"
                                                           placeholder="A1B2C3"
                                                           autocomplete="off"
                                                           spellcheck="false"
                                                           pattern="[A-Za-z0-9]{6}" />
                                                    <span class="mis-pagos-response-hint">Ingresa 6 caracteres alfanumericos.</span>
                                                }
                                                else if (EsCampoDocumentoAdjunto(notificacion))
                                                {
                                                    <InputFile OnChange="@(e => SeleccionarArchivoRespuesta(e, notificacion))"
                                                               accept="@GetAcceptDocumento(notificacion)"
                                                               disabled="@(enviandoRespuestaId == notificacion.ObsId)" />

                                                    @if (archivosSoporte.TryGetValue(notificacion.ObsId, out var archivoSeleccionado))
                                                    {
                                                        <span class="mis-pagos-response-hint">Archivo listo: @archivoSeleccionado.Name</span>
                                                    }

                                                    @if (erroresArchivosSoporte.TryGetValue(notificacion.ObsId, out var errorArchivo))
                                                    {
                                                        <span class="mis-pagos-response-error">@errorArchivo</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="mis-pagos-response-hint">@GetAyudaDocumento(notificacion)</span>
                                                    }
                                                }
                                                else if (EsCampoFecha(notificacion))
                                                {
                                                    <input type="date"
                                                           value="@GetRespuesta(notificacion.ObsId)"
                                                           @onchange="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                           disabled="@(enviandoRespuestaId == notificacion.ObsId)" />
                                                }
                                                else if (EsCampoBooleano(notificacion))
                                                {
                                                    <select value="@GetRespuesta(notificacion.ObsId)"
                                                            @onchange="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                            disabled="@(enviandoRespuestaId == notificacion.ObsId)">
                                                        <option value="">Seleccione...</option>
                                                        <option value="SI">Si</option>
                                                        <option value="NO">No</option>
                                                    </select>
                                                }
                                                else if (EsCampoSexo(notificacion))
                                                {
                                                    <select value="@GetRespuesta(notificacion.ObsId)"
                                                            @onchange="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                            disabled="@(enviandoRespuestaId == notificacion.ObsId)">
                                                        <option value="">Seleccione...</option>
                                                        <option value="M">Hombre</option>
                                                        <option value="F">Mujer</option>
                                                    </select>
                                                }
                                                else if (EsCampoTipoPersona(notificacion))
                                                {
                                                    <select value="@GetRespuesta(notificacion.ObsId)"
                                                            @onchange="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                            disabled="@(enviandoRespuestaId == notificacion.ObsId)">
                                                        <option value="">Seleccione...</option>
                                                        <option value="NATURAL">Persona natural</option>
                                                        <option value="JURIDICA">Persona juridica</option>
                                                    </select>
                                                }
                                                else if (EsCampoTipoIdentificacion(notificacion))
                                                {
                                                    <select value="@GetRespuesta(notificacion.ObsId)"
                                                            @onchange="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                            disabled="@(enviandoRespuestaId == notificacion.ObsId)">
                                                        <option value="">Seleccione...</option>
                                                        <option value="CEDULA">Cedula</option>
                                                        <option value="PASAPORTE">Pasaporte</option>
                                                    </select>
                                                }
                                                else if (EsCampoIdentificacion(notificacion))
                                                {
                                                    <input value="@GetRespuesta(notificacion.ObsId)"
                                                           @oninput="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                           maxlength="@GetMaxLengthCampo(notificacion)"
                                                           inputmode="@GetInputModeCampo(notificacion)"
                                                           class="mis-pagos-code-response"
                                                           disabled="@(enviandoRespuestaId == notificacion.ObsId)"
                                                           placeholder="@GetPlaceholderCampo(notificacion)"
                                                           autocomplete="off"
                                                           spellcheck="false" />
                                                    <span class="mis-pagos-response-hint">@GetAyudaIdentificacion(notificacion)</span>
                                                }
                                                else if (EsCampoDireccion(notificacion))
                                                {
                                                    <textarea value="@GetRespuesta(notificacion.ObsId)"
                                                              @oninput="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                              maxlength="300"
                                                              rows="2"
                                                              disabled="@(enviandoRespuestaId == notificacion.ObsId)"
                                                              placeholder="@GetPlaceholderCampo(notificacion)"></textarea>
                                                }
                                                else
                                                {
                                                    <input value="@GetRespuesta(notificacion.ObsId)"
                                                           @oninput="(e) => SetRespuesta(notificacion, e.Value?.ToString())"
                                                           maxlength="@GetMaxLengthCampo(notificacion)"
                                                           inputmode="@GetInputModeCampo(notificacion)"
                                                           disabled="@(enviandoRespuestaId == notificacion.ObsId)"
                                                           placeholder="@GetPlaceholderCampo(notificacion)"
                                                           autocomplete="off" />
                                                }

                                                <button type="button"
                                                        disabled="@(enviandoRespuestaId == notificacion.ObsId || !RespuestaLista(notificacion))"
                                                        @onclick="() => EnviarRespuestaAsync(notificacion.ObsId)">
                                                    @if (enviandoRespuestaId == notificacion.ObsId)
                                                    {
                                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                                        <span>Enviando</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-send"></i>
                                                        <span>Responder</span>
                                                    }
                                                </button>
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                }
            </section>
        </div>
    }
</div>

<style>
    .mis-pagos-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: end;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .mis-pagos-search {
        flex: 1 1 320px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.85rem 1rem;
        border: 1px solid #dbe5f0;
        border-radius: 16px;
        background: #fff;
    }

    .mis-pagos-search i {
        color: #6b7a90;
    }

    .mis-pagos-search input {
        width: 100%;
        border: none;
        background: transparent;
        outline: none;
        color: #16324f;
    }

    .mis-pagos-filter-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
    }

    .mis-pagos-filter-group label {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        min-width: 150px;
    }

    .mis-pagos-filter-group span,
    .mis-pagos-results-meta {
        color: #6b7a90;
        font-size: 0.9rem;
    }

    .mis-pagos-filter-group select {
        min-height: 44px;
        border: 1px solid #dbe5f0;
        border-radius: 12px;
        padding: 0.7rem 0.9rem;
        background: #fff;
        color: #16324f;
    }

    .mis-pagos-results-meta {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.9rem;
    }

    .mis-pagos-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .mis-pagos-pagination button {
        border: 1px solid #dbe5f0;
        background: #fff;
        color: #16324f;
        border-radius: 12px;
        min-height: 42px;
        padding: 0.65rem 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }

    .mis-pagos-pagination button:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .mis-pagos-pagination-pages {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .mis-pagos-pagination-pages button.is-active {
        background: #16324f;
        color: #fff;
        border-color: #16324f;
    }

    @@media (max-width: 768px) {
        .mis-pagos-results-meta,
        .mis-pagos-pagination {
            flex-direction: column;
            align-items: stretch;
        }

        .mis-pagos-filter-group {
            width: 100%;
        }

        .mis-pagos-filter-group label {
            flex: 1 1 100%;
        }
    }
</style>

@code {
    private const decimal Iva = 0.15m;
    private List<SolicitudPagoClienteDto>? solicitudes;
    private List<SolicitudNotificacionDto> notificacionesPendientes = new();
    private readonly Dictionary<int, string> respuestasSoporte = new();
    private readonly Dictionary<int, IBrowserFile> archivosSoporte = new();
    private readonly Dictionary<int, string> erroresArchivosSoporte = new();
    private string? errorCarga;
    private string? mensajeRespuesta;
    private string? errorRespuesta;
    private int usuarioIdActual;
    private int? enviandoRespuestaId;
    private int? solicitudAvisoSeleccionadaId;
    private string busqueda = string.Empty;
    private string filtroPago = "todos";
    private string filtroEstadoSolicitud = "todos";
    private const int TamanoPagina = 8;

    private int TotalPagados => solicitudes?.Count(sol => sol.SolPagoExitoso) ?? 0;
    private int TotalPendientes => solicitudes?.Count(sol => !sol.SolPagoExitoso) ?? 0;
    private IEnumerable<SolicitudPagoClienteDto> SolicitudesFiltradas =>
        (solicitudes ?? Enumerable.Empty<SolicitudPagoClienteDto>())
            .Where(CumpleBusqueda)
            .Where(CumpleFiltroPago)
            .Where(CumpleFiltroEstadoSolicitud)
            .OrderByDescending(sol => sol.SolFechaPago ?? sol.SolFechaSolicitud)
            .ThenByDescending(sol => sol.SolId);
    private int TotalFiltrados => SolicitudesFiltradas.Count();
    private int TotalPaginas => Math.Max(1, (int)Math.Ceiling(TotalFiltrados / (double)TamanoPagina));
    private int PaginaActual
    {
        get => Math.Min(Math.Max(1, paginaActual), TotalPaginas);
        set => paginaActual = Math.Min(Math.Max(1, value), TotalPaginas);
    }
    private IEnumerable<SolicitudPagoClienteDto> SolicitudesPaginadas =>
        SolicitudesFiltradas
            .Skip((PaginaActual - 1) * TamanoPagina)
            .Take(TamanoPagina);
    private IEnumerable<int> PaginasVisibles
    {
        get
        {
            var inicio = Math.Max(1, PaginaActual - 2);
            var fin = Math.Min(TotalPaginas, inicio + 4);
            inicio = Math.Max(1, fin - 4);
            return Enumerable.Range(inicio, fin - inicio + 1);
        }
    }
    private SolicitudPagoClienteDto? SolicitudAvisoSeleccionada =>
        solicitudAvisoSeleccionadaId is null || solicitudes is null
            ? null
            : solicitudes.FirstOrDefault(sol => sol.SolId == solicitudAvisoSeleccionadaId);
    private IEnumerable<SolicitudNotificacionDto> NotificacionesSolicitudSeleccionada =>
        solicitudAvisoSeleccionadaId is null
            ? Enumerable.Empty<SolicitudNotificacionDto>()
            : notificacionesPendientes
                .Where(notificacion => notificacion.SolId == solicitudAvisoSeleccionadaId)
                .OrderByDescending(notificacion => notificacion.ObsFechaObservacion);
    private int paginaActual = 1;
    private string Busqueda
    {
        get => busqueda;
        set
        {
            if (busqueda == value) return;
            busqueda = value;
            PaginaActual = 1;
        }
    }
    private string FiltroPago
    {
        get => filtroPago;
        set
        {
            if (filtroPago == value) return;
            filtroPago = value;
            PaginaActual = 1;
        }
    }
    private string FiltroEstadoSolicitud
    {
        get => filtroEstadoSolicitud;
        set
        {
            if (filtroEstadoSolicitud == value) return;
            filtroEstadoSolicitud = value;
            PaginaActual = 1;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var usuarioId = ObtenerUsuarioId(authState.User);
            usuarioIdActual = usuarioId;

            if (usuarioId <= 0)
            {
                solicitudes = new List<SolicitudPagoClienteDto>();
                errorCarga = "No se pudo identificar tu usuario. Cierra sesion e ingresa nuevamente.";
                return;
            }

            solicitudes = await SolicitudService.ObtenerSolicitudesClienteAsync(usuarioId);
            PaginaActual = 1;
            await CargarNotificacionesAsync();
        }
        catch (Exception ex)
        {
            errorCarga = "Ocurrio un problema al consultar tus pagos. Intenta nuevamente en unos minutos.";
            Console.WriteLine($"Error al cargar pagos del cliente: {ex.Message}");
        }
    }

