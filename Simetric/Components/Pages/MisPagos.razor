    private static string NormalizarCodigoAlfanumerico6(string? valor)
    {
        var caracteres = (valor ?? string.Empty)
            .Where(char.IsLetterOrDigit)
            .Take(6)
            .Select(char.ToUpperInvariant);

        return new string(caracteres.ToArray());
    }

    private static string NormalizarRespuestaCampo(SolicitudNotificacionDto notificacion, string? valor)
    {
        var texto = valor ?? string.Empty;
        var campo = (notificacion.ObsCampoObservado ?? string.Empty).Trim().ToUpperInvariant();

        return campo switch
        {
            "SOL_IDENTIFICACION" when EsSolicitudCedula(notificacion) => SoloDigitos(texto).Length > 10
                ? SoloDigitos(texto)[..10]
                : SoloDigitos(texto),
            "SOL_IDENTIFICACION" => new string(texto
                .ToUpperInvariant()
                .Where(c => char.IsLetterOrDigit(c) || c == '-')
                .Take(20)
                .ToArray()),
            "SOL_CODIGO_DACTILAR" => new string(texto
                .ToUpperInvariant()
                .Where(char.IsLetterOrDigit)
                .Take(10)
                .ToArray()),
            "SOL_NRO_RUC" => SoloDigitos(texto).Length > 13 ? SoloDigitos(texto)[..13] : SoloDigitos(texto),
            "SOL_TELEFONO_1" => SoloDigitos(texto).Length > 10 ? SoloDigitos(texto)[..10] : SoloDigitos(texto),
            "SOL_TELEFONO_2" => SoloDigitos(texto).Length > 15 ? SoloDigitos(texto)[..15] : SoloDigitos(texto),
            "SOL_CORREO_1" or "SOL_CORREO_2" => texto.Trim().ToLowerInvariant(),
            _ => texto
        };
    }

    private static string SoloDigitos(string valor) =>
        new(valor.Where(char.IsDigit).ToArray());

    private static string FormatearTamano(long bytes)
    {
        const long kilo = 1024;
        const long mega = kilo * 1024;

        return bytes >= mega
            ? $"{bytes / (double)mega:0.#} MB"
            : $"{bytes / (double)kilo:0.#} KB";
    }

    private bool CumpleBusqueda(SolicitudPagoClienteDto sol)
    {
        var criterio = busqueda.Trim();
        if (string.IsNullOrWhiteSpace(criterio))
        {
            return true;
        }

        return sol.SolId.ToString().Contains(criterio, StringComparison.OrdinalIgnoreCase)
            || GetTitular(sol).Contains(criterio, StringComparison.OrdinalIgnoreCase)
            || GetPagoDetalle(sol).Contains(criterio, StringComparison.OrdinalIgnoreCase)
            || GetEstadoSolicitud(sol).Contains(criterio, StringComparison.OrdinalIgnoreCase)
            || GetFormatoFirma(sol.SolFormatoFirma).Contains(criterio, StringComparison.OrdinalIgnoreCase);
    }

    private bool CumpleFiltroPago(SolicitudPagoClienteDto sol) => filtroPago switch
    {
        "pagado" => sol.SolPagoExitoso,
        "pendiente" => !sol.SolPagoExitoso,
        _ => true
    };

    private bool CumpleFiltroEstadoSolicitud(SolicitudPagoClienteDto sol) => filtroEstadoSolicitud switch
    {
        "pendiente" => sol.SolIdEstadoNumerica == 1,
        "revision" => sol.SolIdEstadoNumerica == 2,
        "aprobada" => sol.SolIdEstadoNumerica == 3,
        "rechazada" => sol.SolIdEstadoNumerica == 4,
        _ => true
    };

    private void PaginaAnterior() => PaginaActual--;

    private void PaginaSiguiente() => PaginaActual++;

    private void IrAPagina(int pagina) => PaginaActual = pagina;

    private sealed record DocumentoRespuestaConfig(
        string Accept,
        string FormatosTexto,
        long TamanoMaximoBytes,
        string[] ExtensionesPermitidas);
}
