    }

    private string GetRespuesta(int observacionId) =>
        respuestasSoporte.TryGetValue(observacionId, out var respuesta) ? respuesta : string.Empty;

    private void SetRespuesta(SolicitudNotificacionDto notificacion, string? respuesta)
    {
        respuestasSoporte[notificacion.ObsId] = EsNotificacionCodigo(notificacion)
            ? NormalizarCodigoAlfanumerico6(respuesta)
            : NormalizarRespuestaCampo(notificacion, respuesta);
    }

    private void SeleccionarArchivoRespuesta(InputFileChangeEventArgs e, SolicitudNotificacionDto notificacion)
    {
        archivosSoporte.Remove(notificacion.ObsId);
        erroresArchivosSoporte.Remove(notificacion.ObsId);
        errorRespuesta = null;

        if (!TryGetDocumentoConfig(notificacion, out var config) || e.FileCount == 0)
        {
            return;
        }

        var archivo = e.File;
        var extension = Path.GetExtension(archivo.Name);

        if (string.IsNullOrWhiteSpace(extension) ||
            !config.ExtensionesPermitidas.Contains(extension, StringComparer.OrdinalIgnoreCase))
        {
            erroresArchivosSoporte[notificacion.ObsId] = $"Formato no permitido. Use: {config.FormatosTexto}.";
            return;
        }

        if (archivo.Size > config.TamanoMaximoBytes)
        {
            erroresArchivosSoporte[notificacion.ObsId] = $"El archivo supera el maximo de {FormatearTamano(config.TamanoMaximoBytes)}.";
            return;
        }

        archivosSoporte[notificacion.ObsId] = archivo;
    }

    private bool RespuestaLista(SolicitudNotificacionDto notificacion)
    {
        if (EsCampoDocumentoAdjunto(notificacion))
        {
            return archivosSoporte.ContainsKey(notificacion.ObsId) &&
                   !erroresArchivosSoporte.ContainsKey(notificacion.ObsId);
        }

        return !string.IsNullOrWhiteSpace(GetRespuesta(notificacion.ObsId));
    }

    private async Task EnviarRespuestaAsync(int observacionId)
    {
        mensajeRespuesta = null;
        errorRespuesta = null;

        var notificacion = notificacionesPendientes.FirstOrDefault(item => item.ObsId == observacionId);
        if (notificacion is null)
        {
            errorRespuesta = "No se encontro la notificacion pendiente.";
            return;
        }

        if (EsCampoDocumentoAdjunto(notificacion))
        {
            await EnviarArchivoRespuestaAsync(notificacion);
            return;
        }

        var esCodigo = notificacion is not null && EsNotificacionCodigo(notificacion);
        var respuesta = esCodigo
            ? NormalizarCodigoAlfanumerico6(GetRespuesta(observacionId))
            : GetRespuesta(observacionId);

        if (string.IsNullOrWhiteSpace(respuesta))
        {
            errorRespuesta = "Escribe el codigo o dato corregido antes de responder.";
            return;
        }

        if (esCodigo && respuesta.Length != 6)
        {
            errorRespuesta = "El codigo debe tener exactamente 6 caracteres alfanumericos.";
            return;
        }

        enviandoRespuestaId = observacionId;

        try
        {
            var ok = await SolicitudService.ResponderObservacionAsync(observacionId, usuarioIdActual, respuesta);
            if (!ok)
            {
                errorRespuesta = "No se pudo enviar la respuesta. Revisa que la notificacion siga pendiente.";
                return;
            }

            respuestasSoporte.Remove(observacionId);
            solicitudes = await SolicitudService.ObtenerSolicitudesClienteAsync(usuarioIdActual);
            PaginaActual = Math.Min(PaginaActual, TotalPaginas);
            await CargarNotificacionesAsync();
            if (solicitudAvisoSeleccionadaId is int solIdSeleccionado &&
                !notificacionesPendientes.Any(notificacion => notificacion.SolId == solIdSeleccionado))
            {
                solicitudAvisoSeleccionadaId = null;
            }

            mensajeRespuesta = "Respuesta enviada correctamente a soporte. Si era una correccion, tu informacion ya fue actualizada.";
        }
        catch (Exception ex)
        {
            errorRespuesta = "Ocurrio un problema al enviar la respuesta.";
            Console.WriteLine($"Error al responder observacion {observacionId}: {ex.Message}");
        }
        finally
        {
            enviandoRespuestaId = null;
        }
    }

    private async Task EnviarArchivoRespuestaAsync(SolicitudNotificacionDto notificacion)
    {
        if (!archivosSoporte.TryGetValue(notificacion.ObsId, out var archivo))
        {
            errorRespuesta = "Adjunta el documento solicitado antes de responder.";
            return;
        }

        enviandoRespuestaId = notificacion.ObsId;

        try
        {
            var ok = await SolicitudService.ResponderObservacionDocumentoAsync(
                notificacion.ObsId,
                usuarioIdActual,
                archivo);

            if (!ok)
            {
                errorRespuesta = "No se pudo enviar el documento. Revisa que la notificacion siga pendiente y que el archivo sea valido.";
                return;
            }

            archivosSoporte.Remove(notificacion.ObsId);
            erroresArchivosSoporte.Remove(notificacion.ObsId);
            respuestasSoporte.Remove(notificacion.ObsId);
            solicitudes = await SolicitudService.ObtenerSolicitudesClienteAsync(usuarioIdActual);
            PaginaActual = Math.Min(PaginaActual, TotalPaginas);
            await CargarNotificacionesAsync();
            if (solicitudAvisoSeleccionadaId is int solIdSeleccionado &&
                !notificacionesPendientes.Any(item => item.SolId == solIdSeleccionado))
            {
                solicitudAvisoSeleccionadaId = null;
            }

            mensajeRespuesta = "Documento enviado correctamente a soporte.";
        }
        catch (Exception ex)
        {
            errorRespuesta = "Ocurrio un problema al enviar el documento.";
            Console.WriteLine($"Error al responder observacion de documento {notificacion.ObsId}: {ex.Message}");
        }
        finally
        {
            enviandoRespuestaId = null;
        }
    }

