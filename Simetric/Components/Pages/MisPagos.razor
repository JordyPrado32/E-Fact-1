    private static bool TryGetDocumentoConfig(SolicitudNotificacionDto notificacion, out DocumentoRespuestaConfig config)
    {
        var tipo = (notificacion.ObsCampoObservado ?? string.Empty).Trim().ToUpperInvariant();

        config = tipo switch
        {
            "DOC_CEDULA_FRONTAL" => new DocumentoRespuestaConfig("image/*,.pdf", "JPG, JPEG, PNG, PDF", 10 * 1024 * 1024, [".jpg", ".jpeg", ".png", ".pdf"]),
            "DOC_CEDULA_POSTERIOR" => new DocumentoRespuestaConfig("image/*,.pdf", "JPG, JPEG, PNG, PDF", 10 * 1024 * 1024, [".jpg", ".jpeg", ".png", ".pdf"]),
            "DOC_SELFIE_CEDULA" => new DocumentoRespuestaConfig("image/*", "JPG, JPEG, PNG", 10 * 1024 * 1024, [".jpg", ".jpeg", ".png"]),
            "DOC_VIDEO_ACEPTACION" => new DocumentoRespuestaConfig("video/*", "MP4, MOV, AVI, WEBM", 50 * 1024 * 1024, [".mp4", ".mov", ".avi", ".webm"]),
            _ => new DocumentoRespuestaConfig(string.Empty, string.Empty, 0, [])
        };

        return config.TamanoMaximoBytes > 0;
    }

