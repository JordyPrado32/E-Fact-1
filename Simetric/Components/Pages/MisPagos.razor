    private static string GetSeccionNotificacion(SolicitudNotificacionDto notificacion)
    {
        if (EsNotificacionCodigo(notificacion))
        {
            return "Codigos solicitados";
        }

        var campo = (notificacion.ObsCampoObservado ?? string.Empty).Trim().ToUpperInvariant();
        var documento = GetDocumentoIdentidadLabel(notificacion);

        if (EsCampoDocumentoAdjunto(notificacion))
        {
            return $"Documentos de {documento.ToLowerInvariant()}";
        }

        if (campo is "SOL_TIPO_IDENTIFICACION" or "SOL_IDENTIFICACION" or "SOL_CODIGO_DACTILAR")
        {
            return documento;
        }

        return campo switch
        {
            "SOL_TIPO_PERSONA" => "Titular",
            "SOL_NOMBRES" or "SOL_PRIMER_APELLIDO" or "SOL_SEGUNDO_APELLIDO" or "SOL_FECHA_NACIMIENTO" => "Datos personales",
            "SOL_SEXO" or "SOL_NACIONALIDAD" => "Perfil",
            "SOL_TIENE_RUC" or "SOL_NRO_RUC" => "RUC",
            "SOL_TELEFONO_1" or "SOL_TELEFONO_2" or "SOL_CORREO_1" or "SOL_CORREO_2" => "Contacto",
            "SOL_PROVINCIA" or "SOL_CANTON" or "SOL_DIRECCION" => "Domicilio",
            _ => "Otros datos"
        };
