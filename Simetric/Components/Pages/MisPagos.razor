    private async Task CargarNotificacionesAsync()
    {
        if (usuarioIdActual <= 0)
        {
            notificacionesPendientes = new List<SolicitudNotificacionDto>();
            return;
        }

        notificacionesPendientes = await SolicitudService.ObtenerNotificacionesPendientesClienteAsync(usuarioIdActual, 20);

        foreach (var notificacion in notificacionesPendientes)
        {
            respuestasSoporte.TryAdd(notificacion.ObsId, string.Empty);
        }
    }

    private void AbrirAvisosSoporte(int solId)
    {
        mensajeRespuesta = null;
        errorRespuesta = null;
        solicitudAvisoSeleccionadaId = solId;

        foreach (var notificacion in notificacionesPendientes.Where(item => item.SolId == solId))
        {
            respuestasSoporte.TryAdd(notificacion.ObsId, string.Empty);
        }
    }

