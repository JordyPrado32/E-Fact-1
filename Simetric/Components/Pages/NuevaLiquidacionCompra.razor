    private async Task PrepararSecuenciaInicialAsync()
    {
        if (preview == null)
            return;

        await ActualizarDatosAsync();

        if (preview == null)
            return;

        secuencialLiquidacionAutomatico = preview.Secuencial;

        var estado = await InitialSequencePromptService.GetStateAsync(
            usuarioActual ?? 0,
            "liquidacion-compra",
            ObtenerSerieDocumentoActual());
        if (!estado.Initialized)
        {
            mostrarModalSecuenciaInicial = true;
            preview.Secuencial = string.Empty;
            return;
        }

        mostrarModalSecuenciaInicial = false;
        preview.Secuencial = InitialSequencePromptService.ResolveNextSequence(secuencialLiquidacionAutomatico, estado);
    }

