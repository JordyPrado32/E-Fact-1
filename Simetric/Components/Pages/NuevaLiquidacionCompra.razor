    private void AplicarProveedorModal()
    {
        if (preview == null)
            return;

        AsegurarDatosProveedorModalPorDefecto();
        errorProveedorModal = ValidarProveedorModal();
        if (!string.IsNullOrWhiteSpace(errorProveedorModal))
            return;

        preview.TipoIdentificacionProveedor = proveedorModal.TipoIdentificacion?.Trim() ?? "05";
        preview.IdentificacionProveedor = proveedorModal.Identificacion?.Trim() ?? string.Empty;
        preview.RazonSocialProveedor = ConstruirNombreProveedorModal();
        preview.EmailProveedor = proveedorModal.Email?.Trim() ?? string.Empty;
        preview.TelefonoProveedor = proveedorModal.Telefono?.Trim() ?? string.Empty;
        preview.TelefonoFijoProveedor = proveedorModal.Telefono?.Trim() ?? string.Empty;
        preview.DireccionProveedor = proveedorModal.Direccion?.Trim() ?? string.Empty;
        preview.EsClienteProveedor = false;
        preview.EsProveedorProveedor = true;
        preview.CuentaContableProveedor = proveedorModal.CuentaContableProveedor?.Trim() ?? "21311 - Proveedores";
        preview.CodigoProveedorInterno = proveedorModal.CodigoProveedorInterno?.Trim() ?? string.Empty;
        preview.CreditoTributarioProveedor = proveedorModal.CreditoTributarioProveedor?.Trim() ?? "01";
        preview.EsSujetoRetencionProveedor = proveedorModal.EsSujetoRetencionProveedor;
        preview.RegistraInformacionBancariaProveedor = proveedorModal.RegistraInformacionBancariaProveedor;
        preview.BancoProveedor = proveedorModal.BancoProveedor?.Trim() ?? string.Empty;
        preview.TipoCuentaProveedor = proveedorModal.TipoCuentaProveedor?.Trim() ?? string.Empty;
        preview.NumeroCuentaProveedor = proveedorModal.NumeroCuentaProveedor?.Trim() ?? string.Empty;
        textoBusquedaProveedor = FormatearProveedorBusqueda(preview.IdentificacionProveedor, preview.RazonSocialProveedor);

        mostrarModalProveedor = false;
        campoProveedorActivo = string.Empty;
        sugerenciasProveedorBusqueda = new();
    }

    private string? ValidarProveedorModal()
    {
        if (string.IsNullOrWhiteSpace(proveedorModal.Identificacion))
            return "La identificacion del proveedor es obligatoria.";

        if (string.Equals(proveedorModal.TipoPersona, "Juridica", StringComparison.OrdinalIgnoreCase))
        {
            if (string.IsNullOrWhiteSpace(proveedorModal.RazonSocial))
                return "La razon social es obligatoria.";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(proveedorModal.Apellidos))
                return "Los apellidos son obligatorios.";
            if (string.IsNullOrWhiteSpace(proveedorModal.Nombres))
                return "Los nombres son obligatorios.";
        }

        if (string.IsNullOrWhiteSpace(proveedorModal.Email))
            return "El email del proveedor es obligatorio.";

        if (string.IsNullOrWhiteSpace(proveedorModal.Direccion))
            return "La direccion del proveedor es obligatoria.";

        if (proveedorModal.RegistraInformacionBancariaProveedor)
        {
            if (string.IsNullOrWhiteSpace(proveedorModal.BancoProveedor))
                return "El banco del proveedor es obligatorio.";

            if (string.IsNullOrWhiteSpace(proveedorModal.TipoCuentaProveedor))
                return "El tipo de cuenta del proveedor es obligatorio.";

            if (string.IsNullOrWhiteSpace(proveedorModal.NumeroCuentaProveedor))
                return "El numero de cuenta del proveedor es obligatorio.";
        }

        return null;
    }

    private void AsegurarDatosProveedorModalPorDefecto()
    {
        proveedorModal.CuentaContableProveedor = string.IsNullOrWhiteSpace(proveedorModal.CuentaContableProveedor)
            ? "21311 - Proveedores"
            : proveedorModal.CuentaContableProveedor.Trim();
        proveedorModal.CreditoTributarioProveedor = string.IsNullOrWhiteSpace(proveedorModal.CreditoTributarioProveedor)
            ? "01"
            : proveedorModal.CreditoTributarioProveedor.Trim();
    }

    private string ConstruirNombreProveedorModal()
    {
        if (string.Equals(proveedorModal.TipoPersona, "Juridica", StringComparison.OrdinalIgnoreCase))
        {
            return (proveedorModal.RazonSocial ?? string.Empty).Trim();
        }

        return string.Join(" ", new[]
        {
            proveedorModal.Apellidos,
            proveedorModal.Nombres
        }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
    }

    private static bool EsTipoJuridico(string? tipoIdentificacion) =>
        string.Equals(tipoIdentificacion?.Trim(), "04", StringComparison.OrdinalIgnoreCase);

    private static (string? Apellidos, string? Nombres) SepararNombreCompleto(string? nombreCompleto)
    {
        var partes = (nombreCompleto ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (partes.Length == 2)
            return (partes[0], partes[1]);

        if (partes.Length == 3)
            return (string.Join(" ", partes.Take(2)), partes[2]);

        if (partes.Length >= 4)
            return (string.Join(" ", partes.Take(2)), string.Join(" ", partes.Skip(2)));

        if (partes.Length == 1)
            return (partes[0], null);

        return (null, null);
    }

    private static string FormatearProveedorBusqueda(string? identificacion, string? razonSocial)
    {
        var id = (identificacion ?? string.Empty).Trim();
        var nombre = (razonSocial ?? string.Empty).Trim();

        if (!string.IsNullOrWhiteSpace(id) && !string.IsNullOrWhiteSpace(nombre))
            return $"{id} - {nombre}";

        return !string.IsNullOrWhiteSpace(nombre) ? nombre : id;
    }

