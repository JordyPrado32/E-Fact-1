    private async Task OnSerieDocumentoChangedAsync(ChangeEventArgs e)
    {
        if (preview == null)
            return;

        var serieRaw = e.Value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(serieRaw) ||
            string.Equals(preview.Serie, serieRaw, StringComparison.Ordinal))
            return;

        await FacturacionService.SavePreferredSeriesForAllDocumentsAsync(usuarioActual ?? 0, serieRaw);

        if (serieRaw.Length >= 3)
            preview.Estab = serieRaw[..3];

        if (serieRaw.Length >= 6)
            preview.PtoEmi = serieRaw.Substring(3, 3);

        usuarioYaEmitioAntes = null;
        secuenciaAnteriorManual = string.Empty;
        errorSecuenciaInicial = null;
        mostrarModalSecuenciaInicial = false;
        preview.Secuencial = string.Empty;
        await PrepararSecuenciaInicialAsync();
    }

    private void OnCambioRespuestaSecuencia(bool? value)
    {
        usuarioYaEmitioAntes = value;
