    private List<LiquidacionCatalogoOptionDto> tiposIdentificacion = new();
    private List<LiquidacionCatalogoOptionDto> formasPago = new();
    private string textoBusquedaProducto = "";
    private string textoBusquedaProveedor = "";
    private List<ProductoLookupDetalleDto>? sugerenciasCatalogo;
    private LiquidacionCompraDetalleDto? filaBusquedaProductoActiva;
    private int indiceSugerenciaProductoActiva = -1;
    private bool seleccionandoProductoDesdeLista;
    private bool mostrarCatalogoProductosLiquidacion;
    private bool mostrarModalProductoLiquidacion;
    private List<CompraXmlDetalleDto> sugerenciasProveedor = new();
    private List<LiquidacionProveedorLookupDto> sugerenciasProveedorBusqueda = new();
    private string campoProveedorActivo = "";
    private List<CajaSerieResolucion> seriesDocumento = new();
    private bool mostrarModalProveedor;
    private ProveedorModalModel proveedorModal = new();
    private string? errorProveedorModal;
    private const int MaxCorreosOpcionalesLiquidacion = 4;
    private List<CorreoOpcionalLiquidacionInput> correosOpcionalesLiquidacion = new();
    private Dictionary<LiquidacionCompraDetalleDto, ModoDescuento> modosDescuentoDetalle = new();

    private enum ModoDescuento
    {
        Porcentaje,
        Moneda
    }

    private sealed class CorreoOpcionalLiquidacionInput
    {
        public string Correo { get; set; } = string.Empty;
        public bool GuardarEnProveedor { get; set; }
    }

    private readonly List<(int Codigo, string Descripcion)> impuestosDetalle = new()
    {
        (0, "IVA 0%"),
        (5, "IVA 5%"),
        (8, "IVA 8%"),
        (4, "IVA 15%"),
        (6, "No objeto de IVA"),
        (7, "Exento de IVA")
    };

    private readonly List<string> bancosProveedorModal = new()
    {
        "Banco Pichincha",
        "Banco Internacional",
        "Banco Guayaquil",
        "Banco del Pacifico",
        "Banco Bolivariano",
        "Produbanco",
        "Banco del Austro",
        "Cooperativa JEP",
        "Cooperativa Policia Nacional",
        "Banco Solidario"
    };

    private readonly List<string> tiposCuentaProveedorModal = new()
    {
        "Ahorros",
        "Corriente"
    };

    private sealed class ProveedorModalModel
    {
        public string TipoPersona { get; set; } = "Natural";
        public string TipoIdentificacion { get; set; } = "05";
        public string Identificacion { get; set; } = string.Empty;
        public string Nombres { get; set; } = string.Empty;
        public string Apellidos { get; set; } = string.Empty;
        public string RazonSocial { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Telefono { get; set; } = string.Empty;
        public string Provincia { get; set; } = string.Empty;
        public string Direccion { get; set; } = string.Empty;
        public string Referencia { get; set; } = string.Empty;
        public string CuentaContableProveedor { get; set; } = string.Empty;
        public string CodigoProveedorInterno { get; set; } = string.Empty;
        public string CreditoTributarioProveedor { get; set; } = string.Empty;
        public bool EsSujetoRetencionProveedor { get; set; }
        public bool RegistraInformacionBancariaProveedor { get; set; }
        public string BancoProveedor { get; set; } = string.Empty;
        public string TipoCuentaProveedor { get; set; } = string.Empty;
        public string NumeroCuentaProveedor { get; set; } = string.Empty;
    }

    private bool PuedeGuardar =>
        preview != null &&
        string.IsNullOrWhiteSpace(ObtenerErrorValidacionLiquidacion());

    private bool PuedeIntentarGuardar =>
        preview != null &&
        !BloqueadoPorSaldoDocumentos;

    private bool BloqueadoPorSaldoDocumentos => emisionEstado?.RequiereCompraDocumentos == true;
    private string MensajeBloqueoDocumentos => emisionEstado?.Mensaje ?? EmisionControlService.MensajeSaldoAgotado;
    private bool EsLiquidacionSoloLectura => liquidacionRetencionId is > 0;

    protected override async Task OnInitializedAsync()
    {
        EmisionControlService.Changed += OnEmisionChanged;
        await CargarUsuarioActualAsync();
        await CargarEstadoEmisionAsync();
        await CargarCatalogosAsync();
        seriesDocumento = await FacturacionService.GetSeriesFacturaHabilitadasAsync(usuarioActual ?? 0);
        await ReiniciarFormularioAsync();

        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(NavManager.ToAbsoluteUri(NavManager.Uri).Query);
        if (query.TryGetValue("retencionLiquidacion", out var liquidacionIdRaw) &&
            int.TryParse(liquidacionIdRaw.ToString(), out var liquidacionId))
        {
            await HabilitarRetencionAsync(liquidacionId);
        }
    }

    public void Dispose()
    {
        EmisionControlService.Changed -= OnEmisionChanged;
    }

    private void OnEmisionChanged()
