        RecalcularTotales();
    }

    private ModoDescuento GetModoDescuentoDetalle(LiquidacionCompraDetalleDto item)
    {
        if (modosDescuentoDetalle.TryGetValue(item, out var modo))
            return modo;

        return item.Descuento > 0m && item.PorcentajeDescuento <= 0m
            ? ModoDescuento.Moneda
            : ModoDescuento.Porcentaje;
    }

    private string GetDescuentoDetalleVisual(LiquidacionCompraDetalleDto item)
    {
        return GetModoDescuentoDetalle(item) == ModoDescuento.Moneda
            ? item.Descuento.ToString("0.##", CultureInfo.InvariantCulture)
            : item.PorcentajeDescuento.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private void CambiarModoDescuentoDetalle(LiquidacionCompraDetalleDto item, ModoDescuento modo)
    {
        if (preview == null)
            return;

        if (GetModoDescuentoDetalle(item) == modo)
            return;

        modosDescuentoDetalle[item] = modo;
        var bruto = LiquidacionCompraService.ObtenerSubtotalBrutoDetalle(item);

        if (modo == ModoDescuento.Porcentaje)
        {
            item.PorcentajeDescuento = bruto > 0m
                ? Math.Clamp(Math.Round((item.Descuento / bruto) * 100m, 2), 0m, 100m)
                : 0m;
            item.Descuento = 0m;
        }
        else
        {
            item.Descuento = LiquidacionCompraService.ObtenerDescuentoUnitarioDetalle(item);
            item.PorcentajeDescuento = 0m;
        }

        AsegurarFilaVaciaDetalle();
        RecalcularTotales();
    }

    private void OnDescuentoDetalleInput(LiquidacionCompraDetalleDto item, string? valor)
    {
        if (preview == null)
            return;

        if (GetModoDescuentoDetalle(item) == ModoDescuento.Moneda)
        {
            var bruto = LiquidacionCompraService.ObtenerSubtotalBrutoDetalle(item);
            item.PorcentajeDescuento = 0m;
            item.Descuento = Math.Clamp(ParseDecimal(valor), 0m, bruto);
        }
        else
        {
            item.PorcentajeDescuento = Math.Clamp(ParseDecimal(valor), 0m, 100m);
            item.Descuento = 0m;
        }

        AsegurarFilaVaciaDetalle();
        RecalcularTotales();
    }

    private void OnImpuestoDetalleChanged(LiquidacionCompraDetalleDto item, string? valor)
    {
