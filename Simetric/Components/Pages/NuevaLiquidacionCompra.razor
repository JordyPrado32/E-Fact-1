@page "/compras/nueva-liquidacion"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Simetric.Components.Shared
@implements IDisposable
@using Simetric.DTOs
@using Simetric.Services
@using System.Globalization
@using System.Security.Claims
@using System.Text
@using Simetric.Models.Glogales
@inject AuthenticationStateProvider AuthStateProvider
@inject FacturacionService FacturacionService
@inject ComprasXmlService ComprasXmlService
@inject InitialSequencePromptService InitialSequencePromptService
@inject LiquidacionCompraService LiquidacionCompraService
@inject SweetAlertService AlertService
@inject EmisionControlService EmisionControlService
@inject ILiquidacionCompraPdfService LiquidacionCompraPdfService
@inject IWebHostEnvironment WebHostEnvironment
@inject NavigationManager NavManager

<PageTitle>Nueva Liquidacion | Numerica e-fact</PageTitle>

<div class="container-fluid py-3 px-3 px-md-4 bg-light-modern compact-liquidacion-page docs-unified-page @(liquidacionRetencionId is > 0 ? "liquidacion-integrada-activa" : null)" data-tour="liquidacion.page">
    @if (guardando)
    {
        <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
             style="background: rgba(15, 23, 42, 0.38); z-index: 2000; backdrop-filter: blur(2px);">
            <div class="bg-white rounded-4 shadow-lg px-4 py-4 text-center" style="width: min(92vw, 420px);">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <div class="fw-semibold fs-5">@TextoGuardandoLiquidacion</div>
                <div class="text-muted small mt-2">Espera un momento mientras procesamos la liquidacion y su envio al SRI.</div>
            </div>
        </div>
    }

    <DocumentoEmisionToast Message="@mensajeRapidoLiquidacion"
                           IsError="@mensajeRapidoEsError"
                           PdfUrl="@liquidacionGeneradaPdfUrl"
                           OnOpenPdf="AbrirDocumentoGeneradoAsync">
        <AdditionalActions>
            @if (!mensajeRapidoEsError && liquidacionGeneradaCodFactura is > 0)
            {
                <button type="button" class="documento-emision-accion" @onclick="IrARetencionLiquidacionGenerada">Ir a retencion</button>
                <button type="button" class="documento-emision-accion" @onclick="NuevaLiquidacionDesdeAvisoAsync">Nueva liquidacion</button>
            }
        </AdditionalActions>
    </DocumentoEmisionToast>

    <InitialSequenceModal Visible="@mostrarModalSecuenciaInicial"
                          Title="Configuracion inicial de secuencia"
                          Description="Antes de registrar tu primera liquidacion de compra en este sistema, indicanos si ya habias emitido liquidaciones anteriormente."
                          QuestionLabel="Ya habias generado liquidaciones antes?"
                          SequenceLabel="Ingresa la secuencia donde te quedaste"
                          SequencePlaceholder="Ej: 000000125"
                          SequenceHint="Si te quedaste en la 125, la siguiente sera la 126."
                          HadPreviousDocuments="usuarioYaEmitioAntes"
                          HadPreviousDocumentsChanged="OnCambioRespuestaSecuencia"
                          PreviousSequence="@secuenciaAnteriorManual"
                          PreviousSequenceChanged="OnSecuenciaAnteriorManualChanged"
                          ErrorMessage="@errorSecuenciaInicial"
                          OnDismiss="@(() => mostrarModalSecuenciaInicial = false)"
                          OnConfirm="ConfirmarSecuenciaInicialAsync" />

    <section class="docs-form-hero" data-tour="liquidacion.hero">
        <div class="docs-form-hero-body">
            <!-- Columna 1: Info (Izquierda) -->
            <div class="docs-form-hero-copy invoice-heading-card nc-heading-card">
                <div class="invoice-heading-head nc-heading-head">
                    <span class="invoice-heading-icon nc-heading-icon"><i class="bi bi-cart3"></i></span>
                    <span class="docs-form-kicker-blue">Documento de compra</span>
                </div>
                <h2 class="docs-form-title" style="font-size: 1.18rem !important; line-height: 1.18 !important;">Nueva liquidacion de compra</h2>
                <p class="docs-form-text">
                    Completa proveedor, detalle y forma de pago con una vista mas limpia y con <br />
                    acceso directo al historial sin salir de esta pantalla.
                </p>
                <div class="invoice-heading-meter nc-heading-meter"><span></span></div>
            </div>

            <!-- Columna 2: Toolbar (Derecha) conteniendo Pills a la izquierda y Botones apilados a la derecha -->
            <div class="docs-form-toolbar">
                @if (preview != null)
                {
                    <!-- Pills (Centro) -->
                    <div class="n-invoice-id-strip nc-id-strip" aria-label="Identificadores de la liquidacion de compra">
                        <div class="n-invoice-id-pill nc-id-pill">
                            <span>Serie</span>
                            @if (seriesDocumento.Count > 1)
                            {
                                <select class="n-input text-center fw-bold"
                                        value="@preview.Serie"
                                        @onchange="OnSerieDocumentoChangedAsync"
                                        disabled="@guardando"
                                        aria-label="Seleccionar serie de liquidacion">
                                    @foreach (var serie in seriesDocumento)
                                    {
                                        <option value="@serie.SerieRaw">@serie.SerieVisual</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <strong>@preview.SerieVisual</strong>
                            }
                        </div>
                        <div class="n-invoice-id-pill nc-id-pill">
                            <span>Liquidación</span>
                            <strong>@(string.IsNullOrWhiteSpace(preview.Secuencial) ? "-" : preview.Secuencial)</strong>
                        </div>
                    </div>
                }

                <!-- Botones apilados verticalmente -->
                <div class="nc-toolbar-actions">
                    <button type="button" class="n-btn n-btn-secondary" @onclick="AbrirHistorialLiquidacionesAsync" disabled="@guardando">
                        <i class="bi bi-clock-history me-2"></i> Historial
                    </button>

                    <button type="button" class="n-btn n-btn-secondary" @onclick="ReiniciarFormularioAsync" disabled="@guardando">
                        <i class="bi bi-arrow-clockwise me-2"></i> Limpiar pantalla
                    </button>
                </div>
            </div>
        </div>
    </section>

    @if (preview == null)
    {
        <div class="n-card">
            <div class="n-card-body compact-card-body">
                <div class="d-flex align-items-center gap-3">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span>Cargando configuracion de la liquidacion...</span>
                </div>
            </div>
        </div>
    }
    else
    {
        <div @key="formKey">
            @if (datosInicialesCargados && !preview.ExisteEmisor)
        {
            <div class="alert alert-danger rounded-3 border-0 shadow-sm">
                <strong>No se encontro un emisor activo.</strong>
                Revisa tu configuracion antes de guardar la liquidacion.
            </div>
        }

        @if (EsLiquidacionSoloLectura)
        {
            <div class="alert alert-info border-0 rounded-3 liquidacion-readonly-notice" role="status">
                <i class="bi bi-lock-fill me-2"></i>
                Datos de la liquidacion autorizada. Estos campos son solo de lectura mientras completas la retencion.
            </div>
        }

        <fieldset class="liquidacion-readonly-fieldset" disabled="@EsLiquidacionSoloLectura">
        <section class="n-client-search-strip liquidacion-provider-search-strip" data-tour="liquidacion.provider-search">
            <div class="n-client-search-strip-copy">
                <span class="n-client-search-eyebrow">Buscador de proveedor</span>
                <strong>Encuentra o completa el proveedor de la liquidacion</strong>
            </div>

            <div class="liquidacion-provider-search-actions">
                <div class="n-client-search-input position-relative">
                    <div class="n-input-wrapper">
                        <i class="bi bi-search n-input-icon"></i>
                        <input class="n-input n-input-with-icon n-input-with-toggle"
                               value="@textoBusquedaProveedor"
                               @oninput="OnBusquedaProveedorInput"
                               @onblur="OnBusquedaProveedorBlur"
                               placeholder="Buscar proveedor por identificacion o nombre" />
                    </div>

                    @if (campoProveedorActivo == "razon" && sugerenciasProveedorBusqueda.Any())
                    {
                        <ul class="liquidacion-suggestions liquidacion-provider-suggestions-popup">
                            @foreach (var proveedor in sugerenciasProveedorBusqueda)
                            {
                                <li @onmousedown="() => SeleccionarProveedorSugeridoAsync(proveedor)"
                                    @onmousedown:preventDefault>
                                    <strong>@proveedor.RazonSocial</strong><br />
                                    <small>@proveedor.Identificacion</small>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <button type="button" class="n-btn n-btn-secondary liquidacion-new-provider-btn" @onclick="AbrirModalNuevoProveedor">
                    <i class="bi bi-truck me-2"></i> Nuevo Proveedor
                </button>
            </div>
        </section>
        <div class="n-card mb-4 compact-card manual-entry-card" data-tour="liquidacion.document">
            <div class="n-card-header n-header-dark">
                <h5><i class="bi bi-building me-2"></i> Datos del Documento</h5>
                <small class="d-none d-sm-inline-flex">Datos de proveedor y forma de pago de la liquidacion.</small>
            </div>

            <div class="n-card-body compact-card-body">
                <div class="liquidacion-provider-order">
                    <div class="manual-entry-grid liquidacion-provider-data-grid">
                        <div class="manual-field manual-span-3">
                            <label class="n-label">Identificacion</label>
                            <div class="liquidacion-provider-field">
                                <input class="n-input"
                                       maxlength="20"
                                       value="@preview.IdentificacionProveedor"
                                       @oninput="OnIdentificacionProveedorInput"
                                       @onblur="OnProveedorBlurAsync"
                                       placeholder="Identificacion" />

                                @if (campoProveedorActivo == "identificacion" && sugerenciasProveedorBusqueda.Any())
                                {
                                    <ul class="liquidacion-suggestions liquidacion-provider-suggestions-popup">
                                        @foreach (var proveedor in sugerenciasProveedorBusqueda)
                                        {
                                            <li @onmousedown="() => SeleccionarProveedorSugeridoAsync(proveedor)"
                                                @onmousedown:preventDefault>
                                                <strong>@proveedor.Identificacion</strong><br />
                                                <small>@proveedor.RazonSocial</small>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>

                        <div class="manual-field manual-span-5">
                            <label class="n-label">Nombre proveedor</label>
                            <input class="n-input"
                                   maxlength="300"
                                   value="@preview.RazonSocialProveedor"
                                   @oninput="OnRazonSocialProveedorInput"
                                   placeholder="Nombre Proveedor" />
                        </div>

                        <div class="manual-field manual-span-4">
                            <label class="n-label">Telefono</label>
                            <input class="n-input" maxlength="20" @bind="preview.TelefonoProveedor" @bind:event="oninput" placeholder="Telefono" />
                        </div>

                        <div class="manual-field manual-span-6 n-email-main-field">
                            <label class="n-label">Correo electronico principal</label>
                            <div class="n-email-primary-row">
                                <div class="n-input-wrapper">
                                    <i class="bi bi-envelope n-input-icon"></i>
                                    <input class="n-input n-input-with-icon" maxlength="120" @bind="preview.EmailProveedor" @bind:event="oninput" placeholder="proveedor@ejemplo.com" />
                                </div>
                                <button type="button"
                                        class="n-email-add-btn"
                                        title="Agregar correo adicional"
                                        @onclick="AgregarCorreoOpcionalLiquidacion"
                                        disabled="@(correosOpcionalesLiquidacion.Count >= MaxCorreosOpcionalesLiquidacion)">
                                    <i class="bi bi-envelope-plus"></i>
                                    <span>Agregar correo</span>
                                </button>
                            </div>

                            @if (correosOpcionalesLiquidacion.Any())
                            {
                                <div class="n-additional-email-area">
                                    <label class="n-label">Correos adicionales</label>
                                    <div class="n-email-chip-grid">
                                        @for (int i = 0; i < correosOpcionalesLiquidacion.Count; i++)
                                        {
                                            var index = i;
                                            <div class="n-email-chip-field">
                                                <input type="email"
                                                       class="n-email-chip-input"
                                                       @bind="correosOpcionalesLiquidacion[index].Correo"
                                                       @bind:event="oninput"
                                                       placeholder="correo@ejemplo.com" />
                                                <button type="button"
                                                        class="n-email-chip-remove"
                                                        title="Quitar correo"
                                                        @onclick="() => EliminarCorreoOpcionalLiquidacion(index)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                                <label class="n-email-save-mini" for="@($"guardar-correo-liquidacion-{index}")">
                                                    <input type="checkbox"
                                                           id="@($"guardar-correo-liquidacion-{index}")"
                                                           @bind="correosOpcionalesLiquidacion[index].GuardarEnProveedor" />
                                                    Guardar
                                                </label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="manual-field manual-span-6">
                            <label class="n-label">Direccion</label>
                            <input class="n-input" maxlength="300" @bind="preview.DireccionProveedor" @bind:event="oninput" placeholder="Direccion" />
                        </div>
                    </div>
                </div>

                <div class="manual-entry-grid liquidacion-document-order-grid">
                    <div class="manual-field manual-span-8">
                        <label class="n-label">Forma de pago</label>
                        <select class="n-select" @bind="preview.FormaPago">
                            <option value="">Seleccionar...</option>
                            @foreach (var forma in formasPago)
                            {
                                <option value="@forma.Codigo">@forma.Descripcion</option>
                            }
                        </select>
                    </div>

                    <div class="manual-field manual-span-4">
                        <label class="n-label">Días de crédito</label>
                        <input class="n-input" type="number" min="0" step="1" placeholder="0" @bind="preview.Plazo" @bind:event="oninput" />
                    </div>

                </div>


            </div>
        </div>

        <div class="n-card mb-4 compact-card manual-entry-card d-none" data-tour="liquidacion.provider">
            <div class="n-card-header n-header-dark">
                <h5><i class="bi bi-person-vcard me-2"></i> Datos del Proveedor</h5>
                <small class="d-none d-sm-inline-flex">Identificacion, razon social y contacto.</small>
            </div>

            <div class="n-card-body compact-card-body">
                <div class="manual-entry-grid liquidacion-main-grid">
                    <div class="manual-field manual-span-3">
                        <label class="n-label">Tipo identificacion</label>
                        <select class="n-input" @bind="preview.TipoIdentificacionProveedor">
                            @foreach (var tipo in tiposIdentificacion)
                            {
                                <option value="@tipo.Codigo">@tipo.Descripcion</option>
                            }
                        </select>
                    </div>

                    <div class="manual-field manual-span-3">
                        <label class="n-label">Identificacion</label>
                        <div class="liquidacion-provider-field">
                            <input class="n-input"
                                   maxlength="20"
                                   value="@preview.IdentificacionProveedor"
                                   @oninput="OnIdentificacionProveedorInput"
                                   @onblur="OnProveedorBlurAsync" />

                            @if (campoProveedorActivo == "identificacion" && sugerenciasProveedorBusqueda.Any())
                            {
                                <ul class="liquidacion-suggestions liquidacion-provider-suggestions-popup">
                                    @foreach (var proveedor in sugerenciasProveedorBusqueda)
                                    {
                                        <li @onmousedown="() => SeleccionarProveedorSugeridoAsync(proveedor)"
                                            @onmousedown:preventDefault>
                                            <strong>@proveedor.Identificacion</strong><br />
                                            <small>@proveedor.RazonSocial</small>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>

                    <div class="manual-field manual-span-6">
                        <label class="n-label">Razon social / nombres</label>
                        <div class="liquidacion-provider-field">
                            <input class="n-input"
                                   maxlength="300"
                                   value="@preview.RazonSocialProveedor"
                                   @oninput="OnRazonSocialProveedorInput" />

                            @if (campoProveedorActivo == "razon" && sugerenciasProveedorBusqueda.Any())
                            {
                                <ul class="liquidacion-suggestions liquidacion-provider-suggestions-popup">
                                    @foreach (var proveedor in sugerenciasProveedorBusqueda)
                                    {
                                        <li @onmousedown="() => SeleccionarProveedorSugeridoAsync(proveedor)"
                                            @onmousedown:preventDefault>
                                            <strong>@proveedor.RazonSocial</strong><br />
                                            <small>@proveedor.Identificacion</small>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>

                    <div class="manual-field manual-span-12">
                        <label class="n-label">Direccion</label>
                        <input class="n-input" maxlength="300" @bind="preview.DireccionProveedor" @bind:event="oninput" />
                    </div>
                </div>

                <details class="liquidacion-collapsible mt-3">
                    <summary>Ver datos de contacto opcionales</summary>
                    <div class="manual-entry-grid liquidacion-collapsible-grid">
                        <div class="manual-field manual-span-3">
                            <label class="n-label">Telefono fijo</label>
                            <input class="n-input" maxlength="20" @bind="preview.TelefonoFijoProveedor" @bind:event="oninput" />
                        </div>

                        <div class="manual-field manual-span-3">
                            <label class="n-label">Telefono movil</label>
                            <input class="n-input" maxlength="20" @bind="preview.TelefonoProveedor" @bind:event="oninput" />
                        </div>

                        <div class="manual-field manual-span-6">
                            <label class="n-label">Correo</label>
                            <input class="n-input" maxlength="120" @bind="preview.EmailProveedor" @bind:event="oninput" />
                        </div>
                    </div>
                </details>
            </div>
        </div>

        <div class="n-card mb-4 compact-card" data-tour="liquidacion.detail">
            <div class="n-card-header n-header-dark">
                <h5><i class="bi bi-box-seam me-2"></i> Detalle de la Liquidacion</h5>
                <small class="d-none d-sm-inline-flex">Registra los productos o servicios adquiridos.</small>
            </div>

            <div class="n-card-body compact-card-body">
                <div class="table-responsive n-table-container liquidacion-detail-table-wrap">
                    <table class="table table-hover align-middle mb-0 liquidacion-detail-table">
                        <thead class="n-table-header bg-light">
                            <tr>
                                <th style="width: 80px;">Cod.</th>
                                <th style="min-width: 180px;">Concepto</th>
                                <th style="min-width: 260px;">Detalle</th>
                                <th class="text-center" style="width: 80px;">Cant.</th>
                                <th class="text-end" style="width: 100px;">Precio</th>
                                <th class="text-center" style="width: 168px;">Descuento</th>
                                <th class="text-end" style="width: 96px;" title="Descuento aplicado">Desc. apl.</th>
                                <th class="text-end" style="width: 100px;">Base Imp.</th>
                                <th class="text-end" style="width: 120px;">IVA</th>
                                <th class="text-end" style="width: 110px;">Total</th>
                                <th class="text-center" style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < preview.Detalles.Count; i++)
                            {
                                var item = preview.Detalles[i];
                                var indexActual = i;
                                var descuentoFila = LiquidacionCompraService.ObtenerDescuentoEfectivoDetalle(preview, item);
                                var baseImp = LiquidacionCompraService.ObtenerBaseImponibleDetalle(preview, item);

                                <tr class="@(EsDetalleVacio(item) ? "n-detail-empty-row" : null)">
                                    <td>
                                        <input class="n-input-sm text-center fw-bold"
                                               maxlength="25"
                                               @bind="item.CodPrincipal"
                                               placeholder="Codigo"
                                               @bind:event="oninput" />
                                    </td>

                                    <td class="position-relative">
                                        <input class="n-input-sm n-detail-concept-input"
                                               maxlength="300"
                                               @bind="item.Descripcion"
                                               @bind:after="@(() => OnConceptoDetalleEditadoAsync(item))"
                                               placeholder="Buscar producto o servicio"
                                               @bind:event="oninput"
                                               @onfocus="@(() => MostrarSugerenciasDetalleProductoAsync(item))"
                                               @onblur="@(() => OcultarSugerenciasDetalleProductoAsync(item))"
                                               @onkeydown="@((KeyboardEventArgs e) => OnKeyDownConceptoDetalleAsync(item, e))" />
                                        @if (ReferenceEquals(filaBusquedaProductoActiva, item) && sugerenciasCatalogo != null && sugerenciasCatalogo.Any())
                                        {
                                            <ul class="n-suggestions n-suggestions-inline n-detail-suggestions-floating">
                                                @for (var idx = 0; idx < sugerenciasCatalogo.Count; idx++)
                                                {
                                                    var producto = sugerenciasCatalogo[idx];
                                                    <li @onmousedown="() => PrepararSeleccionProducto()"
                                                        class="@(indiceSugerenciaProductoActiva == idx ? "is-active" : null)"
                                                        @onclick="async () => await SeleccionarProductoEnFilaDesdeListaAsync(item, producto)">
                                                        <strong>@producto.Descripcion</strong><br />
                                                        <small>Cod: @producto.Codprincipal | @ObtenerResumenProductoBusqueda(producto) | PVP: $@producto.PrecioUnitario.ToString("N2", CultureInfo.InvariantCulture)</small>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </td>

                                    <td>
                                        <textarea class="n-input-sm n-detail-extra-input"
                                                  maxlength="300"
                                                  rows="2"
                                                  @bind="item.CodAuxiliar"
                                                  @bind:after="AsegurarFilaVaciaDespuesDeEdicion"
                                                  @bind:event="oninput"
                                                  placeholder="Detalle adicional o concepto extendido"></textarea>
                                    </td>

                                    <td>
                                        <input class="n-input-sm text-center fw-bold border-primary"
                                               type="number"
                                               step="1"
                                               min="1"
                                               value="@item.Cantidad.ToString("0", CultureInfo.InvariantCulture)"
                                               @oninput="(e) => OnCantidadDetalleChanged(item, e.Value?.ToString())" />
                                    </td>

                                    <td>
                                        <input class="n-input-sm text-end bg-white border-0 fw-medium"
                                               type="number"
                                               step="0.01"
                                               min="0"
                                               value="@item.PrecioUnitario.ToString(CultureInfo.InvariantCulture)"
                                               @oninput="(e) => OnPrecioDetalleChanged(item, e.Value?.ToString())" />
                                    </td>

                                    <td>
                                        <div class="n-discount-editor">
                                            <div class="n-discount-mode" role="group" aria-label="Modo de descuento del item">
                                                <button type="button"
                                                        class="@(GetModoDescuentoDetalle(item) == ModoDescuento.Porcentaje ? "is-active" : string.Empty)"
                                                        title="Descuento por porcentaje"
                                                        @onclick="() => CambiarModoDescuentoDetalle(item, ModoDescuento.Porcentaje)">
                                                    %
                                                </button>
                                                <button type="button"
                                                        class="@(GetModoDescuentoDetalle(item) == ModoDescuento.Moneda ? "is-active" : string.Empty)"
                                                        title="Descuento por valor"
                                                        @onclick="() => CambiarModoDescuentoDetalle(item, ModoDescuento.Moneda)">
                                                    $
                                                </button>
                                            </div>
                                            <div class="n-discount-input-wrap">
                                                <input type="number"
                                                       class="n-input-sm text-end"
                                                       step="0.01"
                                                       min="0"
                                                       max="@(GetModoDescuentoDetalle(item) == ModoDescuento.Porcentaje ? "100" : null)"
                                                       value="@GetDescuentoDetalleVisual(item)"
                                                       @oninput="(e) => OnDescuentoDetalleInput(item, e.Value?.ToString())" />
                                                <span>@(GetModoDescuentoDetalle(item) == ModoDescuento.Porcentaje ? "%" : "$")</span>
                                            </div>
                                        </div>
                                     </td>

