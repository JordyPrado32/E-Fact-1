    private string? NormalizarUrlDocumentoGenerado(string? pdfUrl)
    {
        if (string.IsNullOrWhiteSpace(pdfUrl))
            return null;

        if (pdfUrl.StartsWith("/", StringComparison.Ordinal) || Uri.TryCreate(pdfUrl, UriKind.Absolute, out _))
            return $"{pdfUrl}?v={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}";

        if (Path.IsPathRooted(pdfUrl))
        {
            var webRoot = string.IsNullOrWhiteSpace(WebHostEnvironment.WebRootPath)
                ? Path.Combine(Directory.GetCurrentDirectory(), "wwwroot")
                : WebHostEnvironment.WebRootPath;

            var relativePath = Path.GetRelativePath(webRoot, pdfUrl).Replace(Path.DirectorySeparatorChar, '/');
            return "/" + relativePath + "?v=" + DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        }

        return "/" + pdfUrl.TrimStart('/', '\\').Replace('\\', '/') + "?v=" + DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
    }

