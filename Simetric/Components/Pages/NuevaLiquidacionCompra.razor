    private async Task GuardarLiquidacionAsync()
    {
        if (preview == null)
            return;

        guardando = true;
        textoGuardandoLiquidacion = "Generando liquidacion...";
        liquidacionGeneradaCodFactura = null;
        liquidacionGeneradaPdfUrl = null;

        try
        {
            preview.Usuario = usuarioActual;
            AplicarCorreosOpcionalesLiquidacion();
            await LiquidacionCompraService.ResolverDatosManualAsync(preview);

            var errorValidacion = ObtenerErrorValidacionLiquidacion();
            if (!string.IsNullOrWhiteSpace(errorValidacion))
            {
                MostrarAvisoRapidoLiquidacion(errorValidacion, esError: true);
                return;
            }

            preview.ClaveAcceso = LiquidacionCompraService.GenerarClaveAccesoTemporal(preview);

            var resultado = await LiquidacionCompraService.GuardarLiquidacionConArchivosAsync(preview);
            await InitialSequencePromptService.UpdateLastSequenceAsync(
                usuarioActual ?? 0,
                "liquidacion-compra",
                preview.Secuencial,
                preview.Serie);
            liquidacionGeneradaCodFactura = resultado.CodFactura;
            liquidacionGeneradaPdfUrl = NormalizarUrlDocumentoGenerado(resultado.PdfUrl);

            textoGuardandoLiquidacion = "Emitiendo en el SRI...";
            StateHasChanged();

            var respuestaSri = await LiquidacionCompraService.EmitirLiquidacionSriAsync(
                resultado.CodFactura,
                usuarioActual,
                intentarEnviarCorreo: true);

            if (usuarioActual is > 0)
            {
                var pdfActualizado = await LiquidacionCompraService.AsegurarPdfLiquidacionUsuarioAsync(resultado.CodFactura, usuarioActual.Value);
                liquidacionGeneradaPdfUrl = NormalizarUrlDocumentoGenerado(string.IsNullOrWhiteSpace(pdfActualizado) ? resultado.PdfUrl : pdfActualizado);
            }

            var observaciones = new List<string>();
            if (resultado.ProblemasArchivos.Any())
                observaciones.AddRange(resultado.ProblemasArchivos);

            var estadoSri = (respuestaSri?.estado ?? string.Empty).Trim();
            var mensajeSri = (respuestaSri?.mensaje ?? string.Empty).Trim();
            var autorizada = string.Equals(estadoSri, DocumentoAutorizacionHelper.EstadoAutorizado, StringComparison.OrdinalIgnoreCase)
                || !string.IsNullOrWhiteSpace(respuestaSri?.autorizacion);

            string mensajeResultado;
            bool esErrorResultado = false;

            if (autorizada)
            {
                liquidacionRetencionId = resultado.CodFactura;
                mensajeResultado = $"Liquidacion #{resultado.CodFactura} emitida correctamente al SRI.";
                if (observaciones.Any())
                    mensajeResultado += $" Observaciones: {string.Join(" | ", observaciones)}";
            }
            else if (string.Equals(estadoSri, "ERROR", StringComparison.OrdinalIgnoreCase))
            {
                mensajeResultado = $"Liquidacion #{resultado.CodFactura} guardada, pero no se pudo emitir al SRI. {mensajeSri}";
                if (observaciones.Any())
                    mensajeResultado += $" Observaciones: {string.Join(" | ", observaciones)}";
                esErrorResultado = true;
            }
            else
            {
                mensajeResultado = $"Liquidacion #{resultado.CodFactura} guardada y enviada al SRI con estado {estadoSri}.";
                if (!string.IsNullOrWhiteSpace(mensajeSri))
                    mensajeResultado += $" {mensajeSri}";
                if (observaciones.Any())
                    mensajeResultado += $" Observaciones: {string.Join(" | ", observaciones)}";
            }

            MostrarAvisoRapidoLiquidacion(mensajeResultado, esErrorResultado);
            EmisionControlService.NotifyChanged();
        }
        catch (Exception ex)
        {
            MostrarAvisoRapidoLiquidacion(ex.Message, esError: true);
        }
        finally
        {
            guardando = false;
            textoGuardandoLiquidacion = "Generando...";
        }
    }

