    private async Task BuscarProductoExactoAsync()
    {
        if (!usuarioActual.HasValue || string.IsNullOrWhiteSpace(textoBusquedaProducto))
            return;

        var filtro = textoBusquedaProducto.Trim();
        var producto = await FacturacionService.BuscarProductoParaDetalleAsync(usuarioActual.Value, filtro);

        if (producto != null)
        {
            AgregarProductoCatalogo(producto);
            return;
        }

        var sugerencias = sugerenciasCatalogo;
        if (sugerencias == null || !sugerencias.Any())
        {
            sugerencias = await FacturacionService.BuscarProductosFiltroAsync(usuarioActual.Value, filtro);
        }

        if (sugerencias != null && sugerencias.Any())
        {
            AgregarProductoCatalogo(sugerencias.First());
            return;
        }

        await AlertService.ShowInfoAsync("No se encontro un producto del catalogo con ese criterio.", "Producto no encontrado");
    }

