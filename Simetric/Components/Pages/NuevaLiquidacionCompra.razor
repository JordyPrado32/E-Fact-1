    private LiquidacionCompraDetalleDto ObtenerFilaDisponibleParaProducto()
    {
        preview ??= new LiquidacionCompraPreviewDto();
        preview.Detalles ??= new List<LiquidacionCompraDetalleDto>();

        var detalleDisponible = preview.Detalles.FirstOrDefault(EsDetalleVacio);
        if (detalleDisponible is not null)
            return detalleDisponible;

        var nuevoDetalle = LiquidacionCompraService.CrearDetalleVacio();
        preview.Detalles.Add(nuevoDetalle);
        modosDescuentoDetalle[nuevoDetalle] = ModoDescuento.Porcentaje;
        return nuevoDetalle;
    }

    private void EliminarDetalleManual(int index)
    {
        if (preview?.Detalles == null)
            return;

        if (index < 0 || index >= preview.Detalles.Count)
            return;

        preview.Detalles.RemoveAt(index);

        if (!preview.Detalles.Any())
            preview.Detalles.Add(LiquidacionCompraService.CrearDetalleVacio());

        RecalcularTotales();
    }

