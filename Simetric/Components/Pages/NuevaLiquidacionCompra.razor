    private static decimal ParseDecimal(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return 0m;

        valor = valor.Replace(",", ".");
        decimal.TryParse(valor, NumberStyles.Any, CultureInfo.InvariantCulture, out var resultado);
        return resultado;
    }

