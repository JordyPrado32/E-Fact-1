    private async Task HabilitarRetencionAsync(int codFactura)
    {
        if (usuarioActual is not > 0 || codFactura <= 0)
            return;

        var liquidacion = (await LiquidacionCompraService.ListarLiquidacionesUsuarioAsync(usuarioActual.Value))
            .FirstOrDefault(x => x.CodFactura == codFactura);

        if (liquidacion == null)
        {
            await AlertService.ShowWarningAsync("No se encontro la liquidacion seleccionada.");
            return;
        }

        if (!DocumentoAutorizacionHelper.EstaAutorizado(liquidacion.Autorizado, liquidacion.EstadoSri))
        {
            await AlertService.ShowWarningAsync("La liquidacion debe estar autorizada por el SRI antes de generar la retencion.");
            return;
        }

        if (liquidacion.TieneRetencion)
        {
            await AlertService.ShowWarningAsync("La liquidacion seleccionada ya tiene una retencion registrada.");
            return;
        }

        var detalle = await LiquidacionCompraService.GetLiquidacionDetalleUsuarioAsync(codFactura, usuarioActual.Value);
        if (detalle?.Preview == null)
        {
            await AlertService.ShowWarningAsync("No se pudieron cargar los datos de la liquidacion seleccionada.");
            return;
        }

        preview = detalle.Preview;
        preview.Usuario = usuarioActual;
        textoBusquedaProveedor = preview.RazonSocialProveedor ?? string.Empty;
        liquidacionGeneradaPdfUrl = NormalizarUrlDocumentoGenerado(detalle.PdfUrl);
        liquidacionGeneradaCodFactura = codFactura;
        liquidacionRetencionId = codFactura;
        datosInicialesCargados = true;
        formKey++;
        await InvokeAsync(StateHasChanged);
    }

