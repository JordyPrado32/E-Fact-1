    private void AsegurarFilaVaciaDetalle()
    {
        if (preview == null)
            return;

        preview.Detalles ??= new List<LiquidacionCompraDetalleDto>();

        if (preview.Detalles.Any(EsDetalleVacio))
            return;

        var detalleVacio = LiquidacionCompraService.CrearDetalleVacio();
        preview.Detalles.Add(detalleVacio);
        modosDescuentoDetalle[detalleVacio] = ModoDescuento.Porcentaje;
    }

