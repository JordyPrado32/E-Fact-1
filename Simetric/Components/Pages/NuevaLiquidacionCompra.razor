        if (seleccionandoProductoDesdeLista)
            return;

        if (ReferenceEquals(filaBusquedaProductoActiva, item))
        {
            filaBusquedaProductoActiva = null;
            sugerenciasCatalogo = null;
            indiceSugerenciaProductoActiva = -1;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnKeyDownConceptoDetalleAsync(LiquidacionCompraDetalleDto item, KeyboardEventArgs e)
    {
        if (!usuarioActual.HasValue)
            return;

        if (e.Key == "ArrowDown")
        {
            if (!ReferenceEquals(filaBusquedaProductoActiva, item) || sugerenciasCatalogo == null || !sugerenciasCatalogo.Any())
            {
                await MostrarSugerenciasDetalleProductoAsync(item);
                indiceSugerenciaProductoActiva = ObtenerIndiceInicial(sugerenciasCatalogo);
                return;
            }

            indiceSugerenciaProductoActiva = MoverIndiceCircular(indiceSugerenciaProductoActiva, 1, sugerenciasCatalogo.Count);
            return;
        }

        if (e.Key == "ArrowUp")
        {
            if (!ReferenceEquals(filaBusquedaProductoActiva, item) || sugerenciasCatalogo == null || !sugerenciasCatalogo.Any())
            {
                await MostrarSugerenciasDetalleProductoAsync(item);
                indiceSugerenciaProductoActiva = sugerenciasCatalogo?.Count > 0 ? sugerenciasCatalogo.Count - 1 : -1;
                return;
            }

            indiceSugerenciaProductoActiva = MoverIndiceCircular(indiceSugerenciaProductoActiva, -1, sugerenciasCatalogo.Count);
            return;
        }

        if (e.Key == "Escape")
        {
            filaBusquedaProductoActiva = null;
            sugerenciasCatalogo = null;
            indiceSugerenciaProductoActiva = -1;
            return;
        }

        if ((e.Key == "Enter" || e.Key == "Tab") &&
            ReferenceEquals(filaBusquedaProductoActiva, item) &&
            sugerenciasCatalogo != null &&
            sugerenciasCatalogo.Any())
        {
            var indice = indiceSugerenciaProductoActiva >= 0 &&
                         indiceSugerenciaProductoActiva < sugerenciasCatalogo.Count
                ? indiceSugerenciaProductoActiva
                : 0;

            await SeleccionarProductoEnFilaDesdeListaAsync(item, sugerenciasCatalogo[indice]);
        }
    }

