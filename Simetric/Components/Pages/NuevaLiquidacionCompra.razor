            return;

        correosOpcionalesLiquidacion.Add(new CorreoOpcionalLiquidacionInput());
    }

    private void EliminarCorreoOpcionalLiquidacion(int index)
    {
        if (index < 0 || index >= correosOpcionalesLiquidacion.Count)
            return;

        correosOpcionalesLiquidacion.RemoveAt(index);
    }

    private void NormalizarCorreosOpcionalesLiquidacion()
    {
        foreach (var correo in correosOpcionalesLiquidacion)
            correo.Correo = (correo.Correo ?? string.Empty).Trim();
    }

    private List<string> ObtenerCorreosOpcionalesLiquidacion()
    {
        NormalizarCorreosOpcionalesLiquidacion();

        return correosOpcionalesLiquidacion
            .Select(x => x.Correo)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(MaxCorreosOpcionalesLiquidacion)
            .ToList();
    }

    private void AplicarCorreosOpcionalesLiquidacion()
    {
        if (preview == null)
            return;

        var correos = correosOpcionalesLiquidacion
            .Select(x => new
            {
                Correo = (x.Correo ?? string.Empty).Trim(),
                x.GuardarEnProveedor
            })
            .Where(x => !string.IsNullOrWhiteSpace(x.Correo))
            .GroupBy(x => x.Correo, StringComparer.OrdinalIgnoreCase)
            .Select(x => x.First())
            .Take(MaxCorreosOpcionalesLiquidacion)
            .ToList();

        preview.CorreosAdicionalesProveedor = correos.Select(x => x.Correo).ToList();
        preview.CorreosAdicionalesProveedorGuardar = correos
            .Where(x => x.GuardarEnProveedor)
            .Select(x => x.Correo)
            .ToList();
    }

    private static bool EsDetalleVacio(LiquidacionCompraDetalleDto item)
    {
        return item != null &&
               string.IsNullOrWhiteSpace(item.CodPrincipal) &&
               string.IsNullOrWhiteSpace(item.CodAuxiliar) &&
               string.IsNullOrWhiteSpace(item.Descripcion) &&
               item.PrecioUnitario <= 0m &&
               item.PorcentajeDescuento <= 0m &&
               item.Descuento <= 0m;
    }

    private static int MapearCodigoPorcentajeDesdeTarifa(int tarifa)
    {
        return tarifa switch
        {
            5 => 5,
            8 => 8,
            15 => 4,
            _ => 0
        };
    }

    private static int NormalizarTarifaProducto(int tarifa)
    {
        return tarifa switch
        {
            5 => 5,
            8 => 8,
            15 => 15,
            _ => 0
        };
    }

    private static int NormalizarCodigoPorcentaje(int codigoPorcentaje, int tarifa)
    {
        if (codigoPorcentaje is 0 or 4 or 5 or 6 or 7 or 8)
            return codigoPorcentaje;

        return MapearCodigoPorcentajeDesdeTarifa(tarifa);
    }

    private string? ObtenerErrorValidacionLiquidacion()
    {
        if (preview == null)
            return "No hay una liquidación cargada.";

        if (!usuarioActual.HasValue || usuarioActual.Value <= 0)
            return "No se pudo identificar al usuario actual.";

        if (BloqueadoPorSaldoDocumentos)
            return MensajeBloqueoDocumentos;

        if (!preview.ExisteEmisor)
            return "No se encontró un emisor activo para la liquidación.";

        if (preview.FechaEmision == null)
            return "Debes seleccionar la fecha de emisión.";

        if (preview.FechaEmision.Value.Date > DateTime.Today)
            return "La fecha de emisión no puede ser futura.";

        if (string.IsNullOrWhiteSpace(preview.FormaPago) ||
            !formasPago.Any(x => string.Equals(x.Codigo, preview.FormaPago, StringComparison.OrdinalIgnoreCase)))
            return "Debes seleccionar una forma de pago válida.";

        preview.RucEmisor = SoloDigitos(preview.RucEmisor);
        if (preview.RucEmisor.Length != 13)
            return "El RUC del emisor debe tener 13 dígitos.";

        preview.DireccionEstablecimiento = (preview.DireccionEstablecimiento ?? string.Empty).Trim();
        preview.DireccionMatriz = preview.DireccionEstablecimiento;
        if (string.IsNullOrWhiteSpace(preview.DireccionEstablecimiento))
            return "Debes ingresar la dirección del emisor.";

        if (preview.ObligadoContabilidad is not ("SI" or "NO"))
            return "Debes indicar si el emisor está obligado a llevar contabilidad.";

        preview.TipoIdentificacionProveedor = (preview.TipoIdentificacionProveedor ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(preview.TipoIdentificacionProveedor))
            return "Debes seleccionar el tipo de identificación del proveedor.";

        preview.IdentificacionProveedor = (preview.IdentificacionProveedor ?? string.Empty).Trim();
        if (!EsIdentificacionValida(preview.TipoIdentificacionProveedor, preview.IdentificacionProveedor))
            return "La identificación del proveedor no tiene un formato válido para el tipo seleccionado.";

        preview.RazonSocialProveedor = (preview.RazonSocialProveedor ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(preview.RazonSocialProveedor))
            return "Debes ingresar la razón social del proveedor.";

        preview.DireccionProveedor = (preview.DireccionProveedor ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(preview.DireccionProveedor))
            return "Debes ingresar la dirección del proveedor.";

        preview.TelefonoFijoProveedor = (preview.TelefonoFijoProveedor ?? string.Empty).Trim();

        preview.TelefonoProveedor = (preview.TelefonoProveedor ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(preview.TelefonoProveedor) &&
            !EsTelefonoValido(preview.TelefonoProveedor))
            return "El teléfono móvil del proveedor debe tener entre 7 y 15 dígitos.";

        preview.EmailProveedor = (preview.EmailProveedor ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(preview.EmailProveedor) &&
            !EsCorreoValido(preview.EmailProveedor))
            return "El correo del proveedor no tiene un formato válido.";

        var correosUsados = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(preview.EmailProveedor))
            correosUsados.Add(preview.EmailProveedor);

        for (var i = 0; i < correosOpcionalesLiquidacion.Count; i++)
        {
            var correoExtra = (correosOpcionalesLiquidacion[i].Correo ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(correoExtra))
                continue;

            if (!EsCorreoValido(correoExtra))
                return $"El correo adicional #{i + 1} no tiene un formato válido.";

            if (!correosUsados.Add(correoExtra))
                return $"El correo {correoExtra} está repetido entre los destinatarios de la liquidación.";
        }

        var detallesActivos = (preview.Detalles ?? new List<LiquidacionCompraDetalleDto>())
            .Where(x => !EsDetalleVacio(x))
            .ToList();

        if (!detallesActivos.Any())
            return "Debes agregar al menos un detalle a la liquidación.";

        for (int i = 0; i < detallesActivos.Count; i++)
        {
            var item = detallesActivos[i];
            item.CodPrincipal = (item.CodPrincipal ?? string.Empty).Trim();
            item.Descripcion = (item.Descripcion ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(item.Descripcion))
                return $"En el detalle #{i + 1} la descripción es obligatoria.";

            if (item.Cantidad <= 0m)
                return $"En el detalle #{i + 1} la cantidad debe ser mayor a cero.";

            if (item.Cantidad != decimal.Truncate(item.Cantidad))
                return $"En el detalle #{i + 1} la cantidad debe ser un numero entero.";

            if (item.PrecioUnitario <= 0m)
                return $"En el detalle #{i + 1} el precio unitario debe ser mayor a cero.";

            if (item.PorcentajeDescuento < 0m || item.PorcentajeDescuento > 100m)
                return $"En el detalle #{i + 1} el descuento porcentual debe estar entre 0 y 100.";

            if (item.Descuento < 0m)
                return $"En el detalle #{i + 1} el descuento no puede ser negativo.";

            var subtotalBruto = item.Cantidad * item.PrecioUnitario;
            var descuentoEfectivo = LiquidacionCompraService.ObtenerDescuentoEfectivoDetalle(preview, item);
            if (descuentoEfectivo > subtotalBruto)
                return $"En el detalle #{i + 1} el descuento no puede ser mayor al subtotal bruto.";

            if (!impuestosDetalle.Any(x => x.Codigo == item.CodigoPorcentaje))
                return $"En el detalle #{i + 1} debes seleccionar un IVA válido.";
        }

        return null;
    }

    private static string SoloDigitos(string? valor) =>
        new string((valor ?? string.Empty).Where(char.IsDigit).ToArray());

    private static bool EsTelefonoValido(string telefono)
    {
        var digitos = SoloDigitos(telefono);
        return digitos.Length is >= 7 and <= 15;
    }

    private static bool EsCorreoValido(string correo)
    {
        try
        {
            _ = new System.Net.Mail.MailAddress(correo);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool EsIdentificacionValida(string tipo, string identificacion)
    {
        if (string.IsNullOrWhiteSpace(identificacion))
            return false;

        var valor = identificacion.Trim();
        return tipo switch
        {
            "04" => valor.Length == 13 && valor.All(char.IsDigit),
            "05" => valor.Length == 10 && valor.All(char.IsDigit),
            "06" => valor.Length is >= 3 and <= 20 &&
                    valor.All(ch => char.IsLetterOrDigit(ch) || ch == '-'),
            _ => valor.Length is >= 3 and <= 20
        };
    }

