@code {
    private bool cargando = true;
    private bool procesandoAccion = false;
    private int usuarioId;
    private string cicloSeleccionado = "mensual";
    private string? errorMensaje;
    private string? successMensaje;

    private Usuario? usuarioObj;
    private UsuarioServicioSuscripcion? subActiva;
    private List<EdeclareTarjeta> tarjetas = new();
    private int edeclaraServiceId;

    [SupplyParameterFromQuery(Name = "registro")]
    public string? Registro { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true ||
            !int.TryParse(user.FindFirst("IdUsuario")?.Value, out usuarioId) ||
            usuarioId <= 0)
        {
            NavManager.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadDataAsync();

        // Procesar retorno de registro de tarjeta
        if (string.Equals(Registro, "exito", StringComparison.OrdinalIgnoreCase))
        {
            successMensaje = "¡Tarjeta registrada exitosamente en Pagomedios!";
        }
        else if (string.Equals(Registro, "error", StringComparison.OrdinalIgnoreCase))
        {
            errorMensaje = "Hubo un problema al registrar la tarjeta. Por favor inténtalo de nuevo.";
        }
    }

    private async Task LoadDataAsync()
    {
        cargando = true;
        errorMensaje = null;

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();

            usuarioObj = await context.Usuarios.FirstOrDefaultAsync(u => u.IdUsuario == usuarioId);
            if (usuarioObj is null)
            {
                errorMensaje = "No se pudo cargar la información del usuario.";
                return;
            }

            // Cargar servicio E-Declara
            var servicio = await context.AppServicios.FirstOrDefaultAsync(x => x.Clave == "e-declara");
            if (servicio is not null)
            {
                edeclaraServiceId = servicio.ServicioId;

                // Cargar suscripción activa o existente
                subActiva = await context.UsuarioServicioSuscripciones
                    .FirstOrDefaultAsync(x => x.IdUsuario == usuarioId && x.ServicioId == edeclaraServiceId);
                
                // Si la suscripción actual tiene un plan específico, pre-seleccionar ciclo
                if (subActiva is not null && !string.IsNullOrWhiteSpace(subActiva.CicloActual))
                {
                    cicloSeleccionado = subActiva.CicloActual;
                }
            }
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error al cargar datos: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }

        // Sincronizar y cargar tarjetas en tiempo real
        await CargarYEstablecerTarjetasAsync();
    }

    private async Task EliminarTarjetaAsync(EdeclareTarjeta tarjeta)
    {
        procesandoAccion = true;
        errorMensaje = null;
        successMensaje = null;

        try
        {
            // 1. Eliminar de Pagomedios
            var result = await PagoService.EliminarTarjetaTokenizada(tarjeta.Token);
            if (result.IsSuccess)
            {
                // 2. Eliminar de base de datos
                await using var context = await DbFactory.CreateDbContextAsync();
                var dbTarjeta = await context.EdeclareTarjetas.FirstOrDefaultAsync(t => t.IdTarjeta == tarjeta.IdTarjeta);
                if (dbTarjeta is not null)
                {
                    context.EdeclareTarjetas.Remove(dbTarjeta);
                    await context.SaveChangesAsync();
                }

                successMensaje = "Tarjeta eliminada con éxito.";
                await LoadDataAsync();
            }
            else
            {
                errorMensaje = $"Error al eliminar la tarjeta en Pagomedios: {result.ErrorMessage ?? "Error desconocido."}";
            }
        }
        catch (Exception ex)
        {
            errorMensaje = $"Ocurrió un error inesperado: {ex.Message}";
        }
        finally
        {
            procesandoAccion = false;
        }
    }

    private async Task RegistrarNuevaTarjetaAsync()
    {
        if (usuarioObj is null || string.IsNullOrWhiteSpace(usuarioObj.Identificacion))
        {
            errorMensaje = "No se puede iniciar el registro sin la identificación del perfil.";
            return;
        }

        procesandoAccion = true;
        errorMensaje = null;
        successMensaje = null;

        try
        {
            var documentSanitized = new string((usuarioObj.Identificacion ?? "").Where(char.IsLetterOrDigit).ToArray());
            var notifyUrl = NavManager.ToAbsoluteUri("/api/pagomedios/notificacion-registro-tarjeta").ToString();

            var request = new
            {
                integration = true,
                third = new
                {
                    document = documentSanitized,
                    document_type = documentSanitized.Length == 13 ? "04" : "05",
                    name = usuarioObj.NombreCompleto,
                    email = usuarioObj.Email,
                    phones = string.IsNullOrWhiteSpace(usuarioObj.Celular) ? "0999999999" : usuarioObj.Celular,
                    address = string.IsNullOrWhiteSpace(usuarioObj.DireccionEmpresa) ? "Quito" : usuarioObj.DireccionEmpresa,
                    type = "Individual"
                },
                generate_invoice = 0,
                description = "Registro de Tarjeta - Configuración E-DECLARA",
                amount = 1.15m,
                amount_with_tax = 1.00m,
                amount_without_tax = 0.00m,
                tax_value = 0.15m,
                notify_url = notifyUrl,
                custom_value = $"user-{usuarioId}-plan-gestion-ciclo-gestion"
            };

            var result = await PagoService.RegistrarTarjetaSuscripcion(request);
            if (result.IsSuccess && !string.IsNullOrWhiteSpace(result.PaymentUrl))
            {
                NavManager.NavigateTo(result.PaymentUrl, forceLoad: true);
            }
            else
            {
                errorMensaje = $"Error al iniciar el registro de tarjeta: {result.ErrorMessage ?? "Error en el servidor de pagos."}";
                procesandoAccion = false;
            }
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error: {ex.Message}";
            procesandoAccion = false;
        }
    }

    private async Task AgendarCambioPlanAsync(string plan, string ciclo)
    {
        // Si no hay suscripción en absoluto, o si está pendiente de pago, redirigir a checkout
        if (subActiva is null || string.Equals(subActiva.Estado, "PENDIENTE_PAGO", StringComparison.OrdinalIgnoreCase))
        {
            NavManager.NavigateTo($"/suscripciones?servicio=e-declara&plan={plan}&ciclo={ciclo}");
            return;
        }

        procesandoAccion = true;
        errorMensaje = null;
        successMensaje = null;

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            var dbSub = await context.UsuarioServicioSuscripciones.FirstOrDefaultAsync(s => s.SuscripcionId == subActiva.SuscripcionId);

            if (dbSub is not null)
            {
                dbSub.PlanAgendado = plan;
                dbSub.CicloAgendado = ciclo;
                dbSub.FechaActualizacion = DateTime.Now;

                await context.SaveChangesAsync();
                successMensaje = $"Tu cambio de plan a {GetPlanFriendlyName(plan)} ({GetCicloFriendlyName(ciclo)}) fue programado con éxito.";
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error al agendar el plan: {ex.Message}";
        }
        finally
        {
            procesandoAccion = false;
        }
    }

    private async Task CancelarCambioPlanAsync()
    {
        if (subActiva is null) return;

        procesandoAccion = true;
        errorMensaje = null;
        successMensaje = null;

        try
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            var dbSub = await context.UsuarioServicioSuscripciones.FirstOrDefaultAsync(s => s.SuscripcionId == subActiva.SuscripcionId);

            if (dbSub is not null)
            {
                dbSub.PlanAgendado = null;
                dbSub.CicloAgendado = null;
                dbSub.FechaActualizacion = DateTime.Now;

                await context.SaveChangesAsync();
                successMensaje = "El cambio agendado fue cancelado.";
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error al cancelar cambio de plan: {ex.Message}";
        }
        finally
        {
            procesandoAccion = false;
        }
    }

    private string GetPlanFriendlyName(string? plan)
    {
        if (string.Equals(plan, "individual", StringComparison.OrdinalIgnoreCase)) return "Plan Individual";
        if (string.Equals(plan, "asesor", StringComparison.OrdinalIgnoreCase)) return "Plan Asesor";
        if (string.Equals(plan, "empresarial", StringComparison.OrdinalIgnoreCase)) return "Plan Empresarial";
        return plan ?? "Ninguno";
    }

    private string GetCicloFriendlyName(string? ciclo)
    {
        if (string.Equals(ciclo, "anual", StringComparison.OrdinalIgnoreCase)) return "Anual";
        if (string.Equals(ciclo, "mensual", StringComparison.OrdinalIgnoreCase)) return "Mensual";
        return ciclo ?? "-";
    }

    private decimal GetPlanPrice(string? plan, string? ciclo)
    {
        if (string.Equals(plan, "individual", StringComparison.OrdinalIgnoreCase))
            return string.Equals(ciclo, "anual", StringComparison.OrdinalIgnoreCase) ? 80.00m : 10.00m;
        if (string.Equals(plan, "asesor", StringComparison.OrdinalIgnoreCase))
            return string.Equals(ciclo, "anual", StringComparison.OrdinalIgnoreCase) ? 200.00m : 25.00m;
        if (string.Equals(plan, "empresarial", StringComparison.OrdinalIgnoreCase))
            return string.Equals(ciclo, "anual", StringComparison.OrdinalIgnoreCase) ? 500.00m : 50.00m;
        return 0m;
    }

    private bool IsPlanActual(string plan) =>
        subActiva is not null && string.Equals(subActiva.PlanActual, plan, StringComparison.OrdinalIgnoreCase);

    private bool IsPlanAgendado(string plan) =>
        subActiva is not null && string.Equals(subActiva.PlanAgendado, plan, StringComparison.OrdinalIgnoreCase);

    private void SetCiclo(string ciclo)
    {
        cicloSeleccionado = ciclo;
    }

    private async Task CargarYEstablecerTarjetasAsync()
    {
        if (usuarioObj is null || string.IsNullOrWhiteSpace(usuarioObj.Identificacion)) return;

        try
        {
            var result = await PagoService.ObtenerTarjetasTokenizadas(usuarioObj.Identificacion);
            if (result.IsSuccess && !string.IsNullOrWhiteSpace(result.ResponseBody))
            {
                var cardsResponse = JsonSerializer.Deserialize<PagomediosCardListResponse>(result.ResponseBody);
                if (cardsResponse?.Success == true && cardsResponse.Data != null)
                {
                    var apiCards = cardsResponse.Data.SelectMany(x => x.Cards ?? new List<PagomediosTokenizedCard>()).ToList();
                    
                    if (apiCards.Any())
                    {
                        await using var context = await DbFactory.CreateDbContextAsync();
                        var existingTokens = await context.EdeclareTarjetas
                            .Where(x => x.IdUsuario == usuarioId)
                            .Select(x => x.Token)
                            .ToListAsync();

                        var newTarjetas = new List<EdeclareTarjeta>();
                        foreach (var card in apiCards)
                        {
                            if (!string.IsNullOrWhiteSpace(card.Token) && !existingTokens.Contains(card.Token))
                            {
                                newTarjetas.Add(new EdeclareTarjeta
                                {
                                    IdUsuario = usuarioId,
                                    Documento = usuarioObj.Identificacion,
                                    Token = card.Token,
                                    MarcaTarjeta = card.CardBrand ?? "Desconocida",
                                    NumeroMascara = card.Number ?? "****",
                                    FechaRegistro = DateTime.Now,
                                    Estado = true
                                });
                            }
                        }

                        if (newTarjetas.Any())
                        {
                            context.EdeclareTarjetas.AddRange(newTarjetas);
                            await context.SaveChangesAsync();
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error al sincronizar tarjetas: {ex.Message}");
        }
        
        // Cargar tarjetas de base de datos actualizadas
        try 
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            tarjetas = await context.EdeclareTarjetas
                .Where(x => x.IdUsuario == usuarioId && x.Estado)
                .OrderByDescending(x => x.FechaRegistro)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error al cargar tarjetas de BD: {ex.Message}");
        }
    }

    public class PagomediosCardListResponse
    {
        [JsonPropertyName("success")]
        public bool Success { get; set; }

        [JsonPropertyName("status")]
        public int Status { get; set; }

        [JsonPropertyName("data")]
        public List<PagomediosClientCards>? Data { get; set; }
    }

    public class PagomediosClientCards
    {
        [JsonPropertyName("document")]
        public string? Document { get; set; }

        [JsonPropertyName("name")]
        public string? Name { get; set; }

        [JsonPropertyName("tradename")]
        public string? Tradename { get; set; }

        [JsonPropertyName("cards")]
        public List<PagomediosTokenizedCard>? Cards { get; set; }
    }

    public class PagomediosTokenizedCard
    {
        [JsonPropertyName("card_brand")]
        public string? CardBrand { get; set; }

        [JsonPropertyName("number")]
        public string? Number { get; set; }

        [JsonPropertyName("token")]
        public string? Token { get; set; }
    }
}
