@page "/e-declara/configuracion/suscripcion"
@using Microsoft.AspNetCore.Components.Authorization
@using Simetric.Models
@using Simetric.Services
@using Simetric.Services.EDeclara
@using Microsoft.EntityFrameworkCore
@using Simetric.Data
@using System.Text.Json
@using System.Text.Json.Serialization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject AppAccessService AppAccessService
@inject IDbContextFactory<AppDbContext> DbFactory
@inject PagoService PagoService

<PageTitle>Mi Suscripción | E-Declara</PageTitle>

<div class="suscripcion-container">
    @if (cargando)
    {
        <section class="loading-state-card">
            <div class="loading-state-icon">
                <span class="spinner-border" role="status" style="color: #6e40c9;"></span>
            </div>
            <h3>Cargando tu suscripción</h3>
            <p>Preparando tu información de facturación de E-Declara.</p>
        </section>
    }
    else
    {
        <!-- Mensajes de Estado -->
        @if (!string.IsNullOrWhiteSpace(successMensaje))
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 16px; background-color: #f1ecfc; color: #4e2d91; padding: 1rem 1.5rem; margin-bottom: 1.5rem; border-left: 4px solid #6e40c9 !important;">
                <i class="ri-checkbox-circle-line me-2" style="font-size: 1.2rem; vertical-align: middle; color: #6e40c9;"></i> @successMensaje
                <button type="button" class="btn-close" @onclick="() => successMensaje = null" aria-label="Cerrar"></button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMensaje))
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 16px; background-color: #fdf3f2; color: #b02a37; padding: 1rem 1.5rem; margin-bottom: 1.5rem; border-left: 4px solid #dc3545 !important;">
                <i class="ri-error-warning-line me-2" style="font-size: 1.2rem; vertical-align: middle;"></i> @errorMensaje
                <button type="button" class="btn-close" @onclick="() => errorMensaje = null" aria-label="Cerrar"></button>
            </div>
        }

        <div class="suscripcion-layout-grid">
            
            <!-- PANEL IZQUIERDO: DETALLE DE PLAN & TARJETAS (Aside Glassmorphism) -->
            <aside class="suscripcion-aside-panel">
                
                <!-- PLAN ACTIVO -->
                <div class="aside-block-card">
                    <div class="block-header">
                        <div>
                            <span class="block-kicker-purple">Suscripción</span>
                            <h3>Plan Activo</h3>
                        </div>
                        @if (subActiva is not null && string.Equals(subActiva.Estado, "ACTIVA", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="status-badge-active">Activo</span>
                        }
                        else
                        {
                            <span class="status-badge-inactive">Inactivo</span>
                        }
                    </div>

                    <div style="margin-top: 1rem;">
                        @if (subActiva is not null && string.Equals(subActiva.Estado, "ACTIVA", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="plan-info-detail-box">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                    <strong style="font-size: 1.1rem; color: #2c3d50; font-weight: 800;">
                                        @GetPlanFriendlyName(subActiva.PlanActual)
                                    </strong>
                                    <span class="cycle-pill">
                                        @GetCicloFriendlyName(subActiva.CicloActual)
                                    </span>
                                </div>
                                <div style="display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.85rem; color: #6b7d8e;">
                                    <div>Costo: <strong style="color: #6e40c9;">$@GetPlanPrice(subActiva.PlanActual, subActiva.CicloActual).ToString("F2") + IVA</strong></div>
                                    <div>Fecha de Vencimiento: <strong style="color: #2c3d50;">@(subActiva.FechaFin?.ToString("dd/MM/yyyy") ?? "Sin fecha")</strong></div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="empty-plan-placeholder">
                                <div class="placeholder-icon-wrap">
                                    <i class="ri-error-warning-line"></i>
                                </div>
                                <div class="placeholder-copy">
                                    <strong>Sin plan activo</strong>
                                    <span>Suscríbete en el panel lateral para empezar.</span>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- CAMBIO AGENDADO -->
                    @if (subActiva is not null && !string.IsNullOrWhiteSpace(subActiva.PlanAgendado))
                    {
                        <div class="scheduled-banner">
                            <div style="display: flex; gap: 0.6rem; align-items: flex-start;">
                                <i class="ri-time-line" style="color: #b25e00; font-size: 1.15rem; margin-top: 0.1rem;"></i>
                                <div style="font-size: 0.8rem; color: #b25e00; line-height: 1.45; text-align: left;">
                                    <strong style="display: block; font-weight: 800; margin-bottom: 0.15rem;">Cambio de plan agendado</strong>
                                    Tu suscripción cambiará al <strong>@GetPlanFriendlyName(subActiva.PlanAgendado) (@GetCicloFriendlyName(subActiva.CicloAgendado))</strong> automáticamente el día <strong>@(subActiva.FechaFin?.ToString("dd/MM/yyyy") ?? "")</strong> una vez finalice tu ciclo actual.
                                </div>
                            </div>
                            <div style="display: flex; justify-content: flex-end; margin-top: 0.8rem;">
                                <button type="button" class="btn btn-sm btn-outline-danger cancel-agenda-btn" @onclick="CancelarCambioPlanAsync" disabled="@procesandoAccion">
                                    @if (procesandoAccion)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                    }
                                    else
                                    {
                                        <span>Cancelar Cambio</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <!-- TARJETAS -->
                <div class="aside-block-card" style="border-top: 1px solid rgba(110,64,201,0.12); padding-top: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <div>
                            <span class="block-kicker-purple">Método de Pago</span>
                            <h3 style="font-size: 1rem; font-weight: 800; color: #2c3d50; margin: 0.1rem 0 0;">Tarjetas Registradas</h3>
                        </div>
                        <button type="button" class="btn btn-sm add-card-purple-btn" @onclick="RegistrarNuevaTarjetaAsync" disabled="@procesandoAccion">
                            <i class="ri-add-line"></i> Agregar
                        </button>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.65rem;">
                        @if (tarjetas.Any())
                        {
                            @foreach (var tarjeta in tarjetas)
                            {
                                <div class="card-item-row">
                                    <div style="display: flex; align-items: center; gap: 0.65rem;">
                                        <div class="card-icon-frame">
                                            @if ((tarjeta.MarcaTarjeta ?? "").Contains("visa", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <i class="ri-visa-line visa-brand-icon"></i>
                                            }
                                            else
                                            {
                                                <i class="ri-mastercard-line mastercard-brand-icon"></i>
                                            }
                                        </div>
                                        <div style="display: flex; flex-direction: column; text-align: left;">
                                            <span style="font-size: 0.82rem; font-weight: 800; color: #2d3748;">
                                                •••• @(tarjeta.NumeroMascara?.Length >= 4 ? tarjeta.NumeroMascara.Substring(tarjeta.NumeroMascara.Length - 4) : "****")
                                            </span>
                                            <span style="font-size: 0.68rem; color: #a0aec0;">
                                                Registrada el @tarjeta.FechaRegistro.ToString("dd/MM/yyyy")
                                            </span>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm text-danger delete-btn-icon" @onclick="() => EliminarTarjetaAsync(tarjeta)" disabled="@procesandoAccion" title="Eliminar tarjeta">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-cards-box">
                                <div style="color: #cbd5e0; font-size: 1.6rem; margin-bottom: 0.25rem;">
                                    <i class="ri-bank-card-line"></i>
                                </div>
                                <p style="font-size: 0.76rem; color: #a0aec0; margin: 0; line-height: 1.35; max-width: 25ch; margin: 0 auto;">
                                    No tienes tarjetas de pago registradas. Agrega una tarjeta para cobros automáticos.
                                </p>
                            </div>
                        }
                    </div>
                </div>

            </aside>

            <!-- PANEL DERECHO: SELECTOR DE PLANES (Main Glassmorphism) -->
            <section class="suscripcion-main-panel">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.8rem; border-bottom: 1px solid rgba(110,64,201,0.12); padding-bottom: 1.2rem;">
                    <div style="text-align: left;">
                        <span class="block-kicker-purple">Planes E-Declara</span>
                        <h3 style="font-size: 1.2rem; font-weight: 800; color: #2c3d50; margin: 0.1rem 0 0;">Planes de Suscripción</h3>
                    </div>
                    
                    <!-- Frecuencia Toggle -->
                    <div class="billing-frequency-switcher">
                        <button type="button" class="billing-switch-btn @(cicloSeleccionado == "mensual" ? "active" : "")" @onclick='() => SetCiclo("mensual")'>
                            Mensual
                        </button>
                        <button type="button" class="billing-switch-btn @(cicloSeleccionado == "anual" ? "active" : "")" @onclick='() => SetCiclo("anual")'>
                            Anual <span class="ahorro-badge">Ahorra 20%</span>
                        </button>
                    </div>
                </div>

                <div class="planes-cards-stack">
                    <!-- PLAN INDIVIDUAL -->
                    <div class="plan-card-box @(IsPlanActual("individual") ? "active-plan" : "") @(IsPlanAgendado("individual") ? "scheduled-plan" : "")">
                        <div class="plan-box-body">
                            <div class="plan-box-info">
                                <div class="plan-box-title-row">
                                    <h4>Plan Individual</h4>
                                    @if (IsPlanActual("individual") && string.Equals(cicloSeleccionado, subActiva?.CicloActual, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="plan-status-pill current-pill"><i class="ri-checkbox-circle-fill"></i> Actual</span>
                                    }
                                    else if (IsPlanAgendado("individual") && string.Equals(cicloSeleccionado, subActiva?.CicloAgendado, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="plan-status-pill agenda-pill"><i class="ri-time-fill"></i> Agendado</span>
                                    }
                                </div>
                                <p class="plan-box-desc">Para personas naturales que desean manejar su control tributario de forma básica y rápida.</p>
                                
                                <ul class="plan-features-bullet-list">
                                    <li><i class="ri-check-line text-success"></i> 1 Contribuyente máximo</li>
                                    <li><i class="ri-check-line text-success"></i> Declaración de impuestos simplificada</li>
                                </ul>
                            </div>

                            <div class="plan-box-price-action">
                                <div class="plan-box-price">
                                    <span class="price-symbol">$</span>
                                    <span class="price-num">@(cicloSeleccionado == "anual" ? "80.00" : "10.00")</span>
                                    <span class="price-cycle">/@(cicloSeleccionado == "anual" ? "año" : "mes")</span>
                                    <small class="price-tax-label">+ IVA</small>
                                </div>

                                @if (!(IsPlanActual("individual") && string.Equals(cicloSeleccionado, subActiva?.CicloActual, StringComparison.OrdinalIgnoreCase)) &&
                                     !(IsPlanAgendado("individual") && string.Equals(cicloSeleccionado, subActiva?.CicloAgendado, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <button type="button" class="btn btn-purple-action" @onclick='() => AgendarCambioPlanAsync("individual", cicloSeleccionado)' disabled="@procesandoAccion">
                                        @if (subActiva is null || string.Equals(subActiva.Estado, "PENDIENTE_PAGO", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span>Suscribirse</span>
                                        }
                                        else
                                        {
                                            <span>Agendar Cambio</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- PLAN ASESOR -->
                    <div class="plan-card-box popular-plan @(IsPlanActual("asesor") ? "active-plan" : "") @(IsPlanAgendado("asesor") ? "scheduled-plan" : "")">
                        <div class="popular-ribbon-tag">Más Popular</div>
                        <div class="plan-box-body">
                            <div class="plan-box-info">
                                <div class="plan-box-title-row">
                                    <h4>Plan Asesor</h4>
                                    @if (IsPlanActual("asesor") && string.Equals(cicloSeleccionado, subActiva?.CicloActual, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="plan-status-pill current-pill"><i class="ri-checkbox-circle-fill"></i> Actual</span>
                                    }
                                    else if (IsPlanAgendado("asesor") && string.Equals(cicloSeleccionado, subActiva?.CicloAgendado, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="plan-status-pill agenda-pill"><i class="ri-time-fill"></i> Agendado</span>
                                    }
                                </div>
                                <p class="plan-box-desc">Para contadores y asesores tributarios independientes que manejan múltiples clientes.</p>
                                
                                <ul class="plan-features-bullet-list">
                                    <li><i class="ri-check-line text-success"></i> Hasta 100 Contribuyentes</li>
                                    <li><i class="ri-check-line text-success"></i> Soporte prioritario y descargas masivas</li>
                                </ul>
                            </div>

                            <div class="plan-box-price-action">
                                <div class="plan-box-price">
                                    <span class="price-symbol">$</span>
                                    <span class="price-num">@(cicloSeleccionado == "anual" ? "200.00" : "25.00")</span>
                                    <span class="price-cycle">/@(cicloSeleccionado == "anual" ? "año" : "mes")</span>
                                    <small class="price-tax-label">+ IVA</small>
                                </div>

                                @if (!(IsPlanActual("asesor") && string.Equals(cicloSeleccionado, subActiva?.CicloActual, StringComparison.OrdinalIgnoreCase)) &&
                                     !(IsPlanAgendado("asesor") && string.Equals(cicloSeleccionado, subActiva?.CicloAgendado, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <button type="button" class="btn btn-purple-action" @onclick='() => AgendarCambioPlanAsync("asesor", cicloSeleccionado)' disabled="@procesandoAccion">
                                        @if (subActiva is null || string.Equals(subActiva.Estado, "PENDIENTE_PAGO", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span>Suscribirse</span>
                                        }
                                        else
                                        {
                                            <span>Agendar Cambio</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- PLAN EMPRESARIAL -->
                    <div class="plan-card-box @(IsPlanActual("empresarial") ? "active-plan" : "") @(IsPlanAgendado("empresarial") ? "scheduled-plan" : "")">
                        <div class="plan-box-body">
                            <div class="plan-box-info">
                                <div class="plan-box-title-row">
                                    <h4>Plan Empresarial</h4>
                                    @if (IsPlanActual("empresarial") && string.Equals(cicloSeleccionado, subActiva?.CicloActual, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="plan-status-pill current-pill"><i class="ri-checkbox-circle-fill"></i> Actual</span>
                                    }
                                    else if (IsPlanAgendado("empresarial") && string.Equals(cicloSeleccionado, subActiva?.CicloAgendado, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="plan-status-pill agenda-pill"><i class="ri-time-fill"></i> Agendado</span>
                                    }
                                </div>
                                <p class="plan-box-desc">Para firmas contables y corporaciones que necesitan accesos multi-usuario y soporte 24/7.</p>
                                
                                <ul class="plan-features-bullet-list">
                                    <li><i class="ri-check-line text-success"></i> Hasta 500 Contribuyentes</li>
                                    <li><i class="ri-check-line text-success"></i> Soporte 24/7 y acceso a API</li>
                                </ul>
                            </div>

                            <div class="plan-box-price-action">
                                <div class="plan-box-price">
                                    <span class="price-symbol">$</span>
                                    <span class="price-num">@(cicloSeleccionado == "anual" ? "500.00" : "50.00")</span>
                                    <span class="price-cycle">/@(cicloSeleccionado == "anual" ? "año" : "mes")</span>
                                    <small class="price-tax-label">+ IVA</small>
                                </div>

                                @if (!(IsPlanActual("empresarial") && string.Equals(cicloSeleccionado, subActiva?.CicloActual, StringComparison.OrdinalIgnoreCase)) &&
                                     !(IsPlanAgendado("empresarial") && string.Equals(cicloSeleccionado, subActiva?.CicloAgendado, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <button type="button" class="btn btn-purple-action" @onclick='() => AgendarCambioPlanAsync("empresarial", cicloSeleccionado)' disabled="@procesandoAccion">
                                        @if (subActiva is null || string.Equals(subActiva.Estado, "PENDIENTE_PAGO", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span>Suscribirse</span>
                                        }
                                        else
                                        {
                                            <span>Agendar Cambio</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    }
</div>

<style>
    /* Estilos base compartidos y personalizaciones de E-Declara (Tema Lavanda / Purpura / Glassmorphism) */
    .suscripcion-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem 1rem;
        font-family: 'Inter', sans-serif;
    }

    .loading-state-card {
        border-radius: 24px;
        border: 1px solid rgba(110, 64, 201, 0.15);
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 14px 30px rgba(110, 64, 201, 0.05);
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        min-height: 320px;
    }

    .loading-state-icon {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        background: rgba(110, 64, 201, 0.08);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.2rem;
    }

    .loading-state-card h3 {
        margin: 0;
        font-size: 1.15rem;
        font-weight: 800;
        color: #2c3d50;
    }

    .loading-state-card p {
        color: #6b7d8e;
        margin: 0.35rem 0 0;
        font-size: 0.88rem;
    }

    .suscripcion-layout-grid {
        display: grid;
        grid-template-columns: minmax(290px, 340px) minmax(0, 1fr);
        gap: 1rem;
        align-items: start;
    }

    @@media (max-width: 1080px) {
        .suscripcion-layout-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Cards Estilo Aside y Form de E-Declara */
    .suscripcion-aside-panel,
    .suscripcion-main-panel {
        border-radius: 24px;
        border: 1px solid rgba(110, 64, 201, 0.15);
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 14px 30px rgba(110, 64, 201, 0.05);
        padding: 1rem;
    }

    .suscripcion-aside-panel {
        background:
            radial-gradient(circle at top, rgba(110, 64, 201, 0.06), transparent 35%),
            linear-gradient(180deg, rgba(255,255,255,0.98), rgba(252,250,255,0.98));
    }

    .aside-block-card {
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    .block-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .block-kicker-purple {
        display: inline-flex;
        align-items: center;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #6e40c9;
    }

    .suscripcion-aside-panel h3,
    .suscripcion-main-panel h3 {
        margin: 0.2rem 0 0;
        font-size: 1.05rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #2c3d50;
    }

    .status-badge-active {
        min-height: 28px;
        padding: 0 0.72rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(110, 64, 201, 0.12);
        color: #6e40c9;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.04em;
    }

    .status-badge-inactive {
        min-height: 28px;
        padding: 0 0.72rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.04em;
    }

    .plan-info-detail-box {
        display: flex;
        flex-direction: column;
        padding: 1rem;
        border-radius: 16px;
        border: 1px solid rgba(110,64,201,0.22);
        background: linear-gradient(180deg, #fbfaff, #f4f0fd);
        text-align: left;
    }

    .cycle-pill {
        min-height: 22px;
        padding: 0 0.5rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(110, 64, 201, 0.1);
        color: #6e40c9;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.04em;
    }

    .empty-plan-placeholder {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.8rem;
        border-radius: 16px;
        background: rgba(110, 64, 201, 0.04);
        border: 1px dashed rgba(110, 64, 201, 0.2);
        color: #6b7d8e;
        text-align: left;
    }

    .placeholder-icon-wrap {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(110, 64, 201, 0.08);
        color: #6e40c9;
        font-size: 1.15rem;
    }

    .placeholder-copy {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .placeholder-copy strong {
        font-size: 0.8rem;
        color: #2c3d50;
        font-weight: 800;
    }

    .placeholder-copy span {
        font-size: 0.72rem;
        color: #6b7d8e;
    }

    .scheduled-banner {
        margin-top: 0.8rem;
        background: #fffdf5;
        border: 1px solid #ffeeba;
        border-radius: 16px;
        padding: 1rem;
    }

    .cancel-agenda-btn {
        background: transparent;
        border: 1px solid #dc3545;
        color: #dc3545;
        transition: all 0.2s ease;
    }

