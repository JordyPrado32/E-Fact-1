    private async Task ReenviarAlSriAsync(NotaCreditoListDto nc)
    {
        if (procesandoReenvio)
            return;

        try
        {
            string pathCertificado = "";
            string pass = "";
            string rutaXml = string.Empty;
            var correosNC = new List<FacturaCorreoDestinoDto>();
            mensajeSRI m = new mensajeSRI();
            var mensajeResultado = string.Empty;
            procesandoReenvio = true;
            var resultadoSri = await NotaCreditoService.EmitirNotaCreditoSriAsync(nc.Sec, currentUserId);
            if (resultadoSri.Autorizada)
            {
                if (resultadoSri.ResultadoCorreo?.Error == true)
                    await AlertService.ShowWarningAsync(resultadoSri.Message, "Nota de crédito autorizada con observaciones");
                else
                    await AlertService.ShowSuccessAsync(resultadoSri.Message, "Nota de crédito autorizada");
            }
            else
            {
                await AlertService.ShowWarningAsync(resultadoSri.Message, "Nota de crédito con observaciones");
            }

            await Recargar();
            return;
        if (string.IsNullOrWhiteSpace(rutaXml) || !File.Exists(rutaXml))
        {
            await AlertService.ShowWarningAsync("No se pudo generar o ubicar el XML físico de la nota de crédito.");
            return;
        }

        if (!emisores.Any())
        {
            await AlertService.ShowWarningAsync("No existe un emisor activo con certificado configurado para reenviar esta nota.");
            return;
        }

        if (emisores.Any())
        {
            pathCertificado = $"App_Data/{emisores.First().PathCertificado}";
            pass = emisores.First().ClaveCertificado;
            //EnviarXmlAApiFrameworkAsync(rutaXml, pathCertificado, pass).Wait();
            m = await NotaCreditoService.EnviarXmlAApiFrameworkConReintentosAsync(rutaXml, pathCertificado, pass);
        }

        if (m.autorizacion != "")
        {

            await NotaCreditoService.ActualizarAutorizacionNCAsync(nc.Sec, m.autorizacion, m.fecha, "", "AUTORIZADO");
            var resultadoCorreo = await NotaCreditoService.IntentarEnviarNotaCreditoPorCorreoAsync(nc.Sec, rutaXml);
            mensajeResultado = correosNC.Any() || !string.IsNullOrWhiteSpace(cliente.Correo)
            ? "Factura guardada correctamente. El procesamiento de archivos y el envío por correo continuarán en segundo plano."
            : "Factura guardada correctamente."; if (resultadoCorreo.Error)
                await AlertService.ShowWarningAsync(mensajeResultado, "Factura guardada con observaciones");
            else
                await AlertService.ShowSuccessAsync(mensajeResultado, "Factura guardada");
        }
        else
        {
            await NotaCreditoService.ActualizarAutorizacionNCAsync(nc.Sec, m.autorizacion, m.fecha, m.xml, "ERROR SRI" + m.mensaje);
            await AlertService.ShowWarningAsync("La nota de credito no fue autorizada por el SRI: " + m.mensaje, "Nota de credito con observaciones");
        }
        }
        catch (Exception ex)
        {
            var mensaje = ex is OperationCanceledException or TaskCanceledException
                ? "El reenvío tardó demasiado en completarse. Intenta nuevamente."
                : ex.Message;
            await AlertService.ShowErrorAsync(mensaje, "Error al reenviar");
        }
        finally
        {
            procesandoReenvio = false;
        }
    }
    public async Task<mensajeSRI> EnviarXmlAApiFrameworkAsync(string rutaArchivoxml, string rutaFirma, string password)
    {
        try
        {
            string apiUrl = "http://localhost:8090/api/xml/process"; //produccion
            //string apiUrl = "https://localhost:44372/api/xml/process"; //pruebas

            if (!File.Exists(rutaArchivoxml))
            {
                throw new FileNotFoundException($"No se encontró el archivo XML en la ruta: {rutaArchivoxml}");
            }
            if (!File.Exists(rutaFirma))
            {
                throw new FileNotFoundException($"No se encontró el archivo de firma (.p12) en la ruta: {rutaFirma}");
            }

            rutaFirma = Path.Combine(Directory.GetCurrentDirectory(), "App_Data\\certs", "path\\" + Path.GetFileName(rutaFirma));
            var solicitudData = new
            {
                RutaXml = rutaArchivoxml,
                RutaFirma = rutaFirma,
                PasswordFirma = password
            };

            string jsonPayload = System.Text.Json.JsonSerializer.Serialize(solicitudData);
            var jsonContent = new StringContent(jsonPayload, Encoding.UTF8, "application/json");

            var request = new HttpRequestMessage(HttpMethod.Post, apiUrl)
            {
                Content = jsonContent
            };

            request.Headers.Add("X-Api-Key", "E-factSimetricNumericaKey2026*#");
            request.Headers.UserAgent.ParseAdd("NumericaSoftwareClient/1.0");

            var handler = new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true
            };

            using (var client = new HttpClient(handler))
            {
                client.Timeout = TimeSpan.FromSeconds(80);
                HttpResponseMessage response = await client.SendAsync(request).ConfigureAwait(false);
                string xmlRespuesta = await response.Content.ReadAsStringAsync().ConfigureAwait(false);

                if (response.IsSuccessStatusCode)
                {
                    // 2. DESERIALIZAR la respuesta XML recibida al objeto mensajeSRI
                    var serializer = new System.Xml.Serialization.XmlSerializer(typeof(mensajeSRI));
                    using (var reader = new System.IO.StringReader(xmlRespuesta))
                    {
                        return (mensajeSRI)serializer.Deserialize(reader);
                    }
                }
                else
                {
                    // Si la API responde un error controlado (400, 404, 500)
                    throw new Exception($"Respuesta de error de la API: {xmlRespuesta}");
                }
            }
        }
        catch (Exception ex)
        {
            // 3. En caso de error, mapeamos la excepción a un objeto mensajeSRI de error
            // Reemplaza "xml" o las propiedades según cómo se llamen en tu clase real
            return new mensajeSRI
            {
                xml = $"<error><tipo>ExcepcionBlazor</tipo><mensaje>{ex.Message}</mensaje></error>"
                // Si tienes propiedades como 'estado' o 'mensaje', inicialízalas aquí
            };
        }
    }
}
