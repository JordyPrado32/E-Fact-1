    private async Task ReenviarCorreoNotaAsync(int sec)
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync("Modo demo: el reenvío de correo está bloqueado.");
            return;
        }

        if (procesandoReenvio)
            return;

        try
        {
            procesandoReenvio = true;
            var resultado = await NotaCreditoService.IntentarEnviarNotaCreditoPorCorreoAsync(sec);

            if (mostrarModal)
                notaSeleccionada = await NotaCreditoService.GetNotaCreditoDetalleUsuarioAsync(sec, currentUserId);

            if (resultado.Enviado || resultado.YaEnviado)
                await AlertService.ShowSuccessAsync(resultado.Mensaje, "Correo");
            else if (resultado.PendienteAutorizacion || resultado.SinDestinatarios)
                await AlertService.ShowWarningAsync(resultado.Mensaje, "Correo");
            else
                await AlertService.ShowErrorAsync(resultado.Mensaje, "Correo");
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync(ex.Message, "Correo");
        }
        finally
        {
            procesandoReenvio = false;
        }
    }

    private async Task DescargarReporteAsync()
    {
        if (isDemoMode)
        {
            await AlertService.ShowInfoAsync("Modo demo: la exportación Excel está bloqueada.");
            return;
        }

        var notasFiltradas = NotasFiltradas;
        if (notasFiltradas.Count == 0)
        {
            await AlertService.ShowInfoAsync("No hay datos para exportar con los filtros actuales.");
            return;
        }

        var archivo = SimpleExcelExportService.Create(
            $"notas_credito_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx",
            new ExcelSheetData(
                "NotasCredito",
                new[]
                {
                    "Fecha sustento",
                    "Numero nota",
                    "Factura modificada",
                    "Cliente",
                    "Identificacion",
                    "Estado",
                    "Numero autorizacion",
                    "Subtotal",
                    "IVA",
                    "Total"
                },
                notasFiltradas
                    .Select(item => (IReadOnlyList<string>)new[]
                    {
                        item.FechaDocumentoModificado?.ToString("yyyy-MM-dd") ?? string.Empty,
                        item.NumeroCompleto ?? string.Empty,
                        item.NumeroDocModificado ?? string.Empty,
                        item.Cliente ?? string.Empty,
                        item.IdentificacionCliente ?? string.Empty,
                        ObtenerEstadoNotaTexto(item),
                        ObtenerNumeroAutorizacionTexto(item),
                        item.Subtotal.ToString("N2"),
                        item.Iva.ToString("N2"),
                        item.Total.ToString("N2")
                    })
                    .ToList()));

        await using var stream = new MemoryStream(archivo.Content);
        using var streamRef = new DotNetStreamReference(stream);
        await JS.InvokeVoidAsync("downloadFileFromStream", archivo.FileName, streamRef, archivo.ContentType);
    }

