    private bool procesandoAnulacion = false;

    private async Task ConfirmarAnularNotaAsync(NotaCreditoListDto item)
    {
        if (procesandoAnulacion) return;

        // Cuadro de diálogo de confirmación nativo e infalible vía JS Interop
        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"¿Está seguro de anular la Nota de Crédito N° {item.NumeroCompleto}?\n\nEsta acción cambiará el estado a ANULADA en el sistema interno.");

        if (confirmado)
        {
            try
            {
                procesandoAnulacion = true;

                // Consumimos el método directo de tu servicio
                var exito = await NotaCreditoService.AnularNotaCreditoDirectoAsync(item.Sec);

                if (exito)
                {
                    item.Estado = false; // Forzamos actualización en memoria de la UI

                    await AlertService.ShowSuccessAsync("Nota de crédito anulada internamente de forma correcta.");

                    await Recargar(); // Refrescamos el listado completo
                }
                else
                {
                    await AlertService.ShowErrorAsync("No se pudo completar la anulación en la base de datos.");
                }
            }
            catch (Exception ex)
            {
                await AlertService.ShowErrorAsync($"Error al intentar anular: {ex.Message}");
            }
            finally
            {
                procesandoAnulacion = false;
            }
        }
    }
