@page "/facturacion/notas-credito-generadas"
@page "/demo/notas-credito-generadas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Simetric.DTOs
@using Simetric.Services
@using System.Text
@using Simetric.Models.Glogales
@attribute [AllowAnonymous]
@inject FacturacionService FacturacionService
@inject NotaCreditoService NotaCreditoService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject SweetAlertService AlertService
@inject IJSRuntime JS
@inject ISimpleExcelExportService SimpleExcelExportService

<PageTitle>Notas de Crédito Generadas</PageTitle>

@{
    var notasFiltradas = NotasFiltradas;
    var notasPaginaActual = NotasPaginaActual;
    var totalFiltrado = notasFiltradas.Sum(x => x.Total);
    var totalVisible = notasPaginaActual.Sum(x => x.Total);
    var notasAutorizadas = notasFiltradas.Count(x => EstaAutorizada(x));
    var notasNoAutorizadas = notasFiltradas.Count(x => ObtenerEstadoNotaTexto(x) == DocumentoAutorizacionHelper.EstadoNoAutorizado);
    var notasPendientes = notasFiltradas.Count - notasAutorizadas - notasNoAutorizadas;
}

<div class="facturas-shell" data-tour="ncgen.page">
    @if (mostrarResultadoOverlay)
    {
        <div class="facturas-inline-overlay" @onclick="CerrarResultadoOverlay">
            <div class="facturas-inline-overlay-card facturas-inline-overlay-card-result is-error" @onclick:stopPropagation>
                <div class="overlay-result-icon">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div>
                    <strong>@tituloResultadoOverlay</strong>
                    <span>@detalleResultadoOverlay</span>
                </div>
                <button type="button" class="overlay-close-btn" @onclick="CerrarResultadoOverlay">Cerrar</button>
            </div>
        </div>
    }

    <section class="facturas-hero" data-tour="ncgen.hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">Ajustes emitidos</span>
            <h2>Mis notas de crédito con filtros, reporte y acciones unificadas</h2>
            <p>
                Busca por cliente, documento modificado o motivo, exporta el resultado visible y abre el
                XML o PDF desde la misma vista.
            </p>
        </div>

        <div class="hero-summary">
            <article class="summary-card summary-card-primary">
                <span class="summary-label">Notas filtradas</span>
                <strong>@notasFiltradas.Count</strong>
                <small>@ResumenRangoFechas</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Total filtrado</span>
                <strong>$ @totalFiltrado.ToString("N2")</strong>
                <small>Importe acumulado de las notas visibles en la consulta.</small>
            </article>

            <article class="summary-card">
                <span class="summary-label">Autorizadas</span>
                <strong>@notasAutorizadas</strong>
                <small>Pendientes: @notasPendientes | No autorizadas: @notasNoAutorizadas</small>
            </article>
        </div>
    </section>

    <section class="toolbar-card" data-tour="ncgen.toolbar">
        <div class="toolbar-copy">
            <span class="toolbar-kicker">Busqueda y control</span>
            <h3>Notas de crédito generadas</h3>
            <p>Combina texto y rango de fechas para ubicar cualquier ajuste sin salir del panel.</p>
            @if (isDemoMode)
            {
                <p class="text-muted mb-0">Modo demo: puedes revisar los comprobantes, pero XML, PDF y exportaciones están bloqueados.</p>
            }
        </div>

        <div class="toolbar-actions toolbar-actions-expanded">
            <div class="search-box">
                <span class="search-icon">
                    <i class="bi bi-search"></i>
                </span>

                <input class="search-input"
                       placeholder="Buscar por numero, factura, cliente o identificacion"
                       @bind="Filtro"
                       @bind:event="oninput" />

                @if (!string.IsNullOrWhiteSpace(Filtro))
                {
                    <button class="search-clear" type="button" @onclick="LimpiarTexto" aria-label="Limpiar busqueda">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>

            <div class="date-filter-group">
                <label class="date-filter-box">
                    <span>Desde</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaDesde" />
                </label>

                <label class="date-filter-box">
                    <span>Hasta</span>
                    <InputDate class="date-filter-input" @bind-Value="FechaHasta" />
                </label>
            </div>

            <button class="report-btn" type="button" @onclick="DescargarReporteAsync">
                <i class="bi bi-file-earmark-spreadsheet"></i>
                <span>Descargar Excel</span>
            </button>

            <button class="refresh-btn" type="button" @onclick="Recargar">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Refrescar</span>
            </button>

            @if (HayFiltrosActivos)
            {
                <button class="filter-reset-btn" type="button" @onclick="LimpiarFiltros">
                    <i class="bi bi-eraser"></i>
                    <span>Limpiar filtros</span>
                </button>
            }
        </div>
    </section>

    @if (cargando)
    {
        <section class="state-card">
            <div class="state-icon">
                <span class="spinner-border"></span>
            </div>
            <h3>Cargando notas de crédito</h3>
            <p>Estamos organizando tu historial para dejar visibles los ajustes mas recientes.</p>
        </section>
    }
    else if (notasFiltradas.Count == 0)
    {
        <section class="state-card state-card-empty">
            <div class="state-icon">
                <i class="bi bi-inbox"></i>
            </div>
            <h3>No hay resultados</h3>
            <p>
                @(HayFiltrosActivos
                    ? "No encontramos notas de credito con los filtros aplicados. Ajusta el texto o las fechas."
                    : "Todavia no existen notas de credito para mostrar en este panel.")
            </p>
        </section>
    }
    else
    {
        <section class="table-card" data-tour="ncgen.table">

            <div class="table-card-head">
                <div>
                    <span class="table-kicker">Listado</span>
                    <h3>Notas de crédito</h3>
                    <p>Consulta documento modificado, cliente, estado y total en una sola tabla.</p>
                </div>

                <div class="table-head-actions">
                    <label class="page-size-box" for="nc-page-size">
                        <span>Ver</span>
                        <select id="nc-page-size" class="page-size-select" @bind="RegistrosPorPagina">
                            @foreach (var opcion in pageSizeOptions)
                            {
                                <option value="@opcion">@opcion</option>
                            }
                        </select>
                        <span>registros</span>
                    </label>
                </div>
            </div>

            <div class="table-wrap list-table-wrap">

                <table class="table table-hover align-middle mb-0 facturas-table responsive-list-table">
                    <thead>
                        <tr>
                            <th style="width: 128px;">Fecha sustento</th>
                            <th style="width: 188px;">Numero de nota</th>
                            <th style="width: 176px;">Factura modificada</th>
                            <th>Cliente</th>
                            <th style="width: 180px;">Estado</th>
                            <th class="text-end" style="width: 132px;">Total</th>
                            <th class="text-end actions-header-facturas">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var notaEntry in notasPaginaActual.Select((item, index) => new { Item = item, Index = index }))
                        {
                            var item = notaEntry.Item;
                            var openUp = notaEntry.Index >= Math.Max(0, notasPaginaActual.Count - (notasPaginaActual.Count <= 2 ? 1 : 2));

                            // Evaluamos si el campo Estado es false (Anulada)
                            var esAnulada = (item.Estado == false);

                            var estaAutorizado = EstaAutorizada(item);

                            <tr class="@(esAnulada ? "table-light text-muted" : "")">

                                <td data-label="Fecha sustento">
                                    <span class="invoice-date">
                                        @(item.FechaDocumentoModificado?.ToString("dd/MM/yyyy") ?? "-")
                                    </span>
                                </td>

                                <td data-label="Numero de nota">
                                    <span class="invoice-pill">
                                        @item.NumeroCompleto
                                    </span>
                                </td>

                                <td data-label="Factura modificada">
                                    <span class="invoice-id">
                                        @item.NumeroDocModificado
                                    </span>
                                </td>

                                <td data-label="Cliente">
                                    <div class="client-cell">
                                        <strong>@item.Cliente</strong>
                                        <span>@item.IdentificacionCliente</span>
                                    </div>
                                </td>

                                <td data-label="Estado">
                                    <div class="d-flex flex-column gap-1 align-items-start">
                                        @if (esAnulada)
                                        {
                                            <span class="status-pill status-pill-danger fw-bold" style="background-color: #f8d7da; color: #842029; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">
                                                ANULADA
                                            </span>

                                            @* Si previamente el string contenía "AUTORIZADO", mostramos la advertencia del SRI *@
                                            @if (estaAutorizado)
                                            {
                                                <small class="text-danger d-block mt-1" style="font-size: 0.72rem; line-height: 1.2;">
                                                    <i class="bi bi-exclamation-triangle-fill"></i> Recuerde anular este comprobante en el portal del SRI.
                                                </small>
                                            }
                                        }
                                        else if (estaAutorizado)
                                        {
                                            <span class="status-pill @ObtenerEstadoNotaClase(item)">
                                                @ObtenerEstadoNotaTexto(item)
                                            </span>
                                            @if (EstaNotaVencida(item))
                                            {
                                                <span class="status-pill status-pill-warning text-dark">
                                                    Vencido
                                                </span>
                                            }
                                            <span class="authorization-number" title="@ObtenerNumeroAutorizacionTexto(item)">
                                                Autorizacion: @ObtenerNumeroAutorizacionTexto(item)
                                            </span>
                                        }
                                        else if (EsNoAutorizada(item))
                                        {
                                            <span class="status-with-info">
                                                <span class="status-pill @ObtenerEstadoNotaClase(item)">
                                                    @ObtenerEstadoNotaTexto(item)
                                                </span>
                                                <button class="status-info-btn"
                                                        type="button"
                                                        title="@ObtenerErrorSriTexto(item)"
                                                        @onclick="() => MostrarErrorSriNotaCredito(item)">
                                                    <i class="bi bi-info-circle-fill"></i>
                                                </button>
                                            </span>
                                            @if (EstaNotaVencida(item))
                                            {
                                                <span class="status-pill status-pill-danger">
                                                    Vencido
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="status-pill status-pill-warning text-dark">
                                                PENDIENTE
                                            </span>
                                            @if (EstaNotaVencida(item))
                                            {
                                                <span class="status-pill status-pill-danger">
                                                    Vencido
                                                </span>
                                            }
                                        }
                                    </div>
                                </td>

                                <td class="text-end" data-label="Total">
                                    <span class="amount-pill">
                                        <span class="currency-symbol">$</span>
                                        <span class="currency-value">@item.Total.ToString("N2")</span>
                                    </span>
                                </td>

                                <td class="text-end" data-label="Acciones">
                                     <!-- Desktop: Inline summarized compact icon buttons -->
                                     <div class="actions-desktop-inline gap-1 justify-content-end row-actions-inline-desktop">
                                         <button class="row-action-btn row-action-view"
                                                 type="button"
                                                 title="Ver"
                                                 @onclick="async () => await VerNotaAsync(item.Sec)">
                                             <i class="bi bi-eye"></i>
                                         </button>

                                         <button class="row-action-btn row-action-xml"
                                                 type="button"
                                                 title="Descargar XML"
                                                 disabled="@(!EstaAutorizada(item))"
                                                 @onclick="async () => await AbrirXmlAsync(item.Sec)">
                                             <i class="bi bi-filetype-xml"></i>
                                         </button>

                                         <button class="row-action-btn row-action-pdf"
                                                 type="button"
                                                 title="Descargar PDF"
                                                 disabled="@(!EstaAutorizada(item))"
                                                 @onclick="async () => await AbrirPdfAsync(item.Sec)">
                                             <i class="bi bi-file-earmark-pdf"></i>
                                         </button>

                                         @if (PuedeReenviarSri(item))
                                         {
                                             <button class="row-action-btn row-action-sri"
                                                     type="button"
                                                     title="Reenviar al SRI"
                                                     disabled="@(procesandoReenvio || procesandoAnulacion)"
                                                     @onclick="() => ReenviarAlSriAsync(item)">
                                                 <i class="bi bi-send-check"></i>
                                             </button>
                                         }

                                         <button class="row-action-btn row-action-mail"
                                                 type="button"
                                                 title="Reenviar correo"
                                                 disabled="@(procesandoReenvio || procesandoAnulacion)"
                                                 @onclick="async () => await ReenviarCorreoNotaAsync(item.Sec)">
                                             <i class="bi bi-envelope"></i>
                                         </button>

                                         @if (!esAnulada)
                                         {
                                             <button class="row-action-btn row-action-danger"
                                                     type="button"
                                                     title="Anular"
                                                     disabled="@(procesandoAnulacion || procesandoReenvio)"
                                                     @onclick="() => ConfirmarAnularNotaAsync(item)">
                                                 <i class="bi bi-trash3"></i>
                                             </button>
                                         }
                                     </div>

                                     <!-- Mobile: Dropdown -->
                                     <div class="actions-mobile-dropdown actions-dropdown @(openUp ? "dropdown-open-up" : "")">
                                         <button class="actions-dropdown-btn" type="button">
                                             <i class="bi bi-three-dots"></i>
                                         </button>
                                         <div class="actions-dropdown-content">
                                             <button class="actions-dropdown-item item-view" type="button"
                                                     @onclick="async () => await VerNotaAsync(item.Sec)">
                                                 <i class="bi bi-eye"></i>
                                                 <span>Ver</span>
                                             </button>

                                             <button class="actions-dropdown-item item-xml" type="button"
                                                     @onclick="async () => await AbrirXmlAsync(item.Sec)">
                                                 <i class="bi bi-filetype-xml"></i>
                                                 <span>Descargar XML</span>
                                             </button>

                                             <button class="actions-dropdown-item item-pdf" type="button"
                                                     @onclick="async () => await AbrirPdfAsync(item.Sec)">
                                                 <i class="bi bi-file-earmark-pdf"></i>
                                                 <span>Descargar PDF</span>
                                             </button>

                                             @if (PuedeReenviarSri(item))
                                             {
                                                 <button class="actions-dropdown-item" type="button"
                                                         disabled="@(procesandoReenvio || procesandoAnulacion)"
                                                         @onclick="() => ReenviarAlSriAsync(item)">
                                                     <i class="bi bi-send-check"></i>
                                                     <span>Reenviar al SRI</span>
                                                 </button>
                                             }

                                             <button class="actions-dropdown-item" type="button"
                                                     disabled="@(procesandoReenvio || procesandoAnulacion)"
                                                     @onclick="async () => await ReenviarCorreoNotaAsync(item.Sec)">
                                                 <i class="bi bi-envelope"></i>
                                                 <span>Reenviar correo</span>
                                             </button>

                                             @if (!esAnulada)
                                             {
                                                 <button class="actions-dropdown-item item-cancel" type="button"
                                                         disabled="@(procesandoAnulacion || procesandoReenvio)"
                                                         @onclick="() => ConfirmarAnularNotaAsync(item)">
                                                     <i class="bi bi-trash3"></i>
                                                     <span>Anular</span>
                                                 </button>
                                             }
                                         </div>
                                     </div>
                                 </td>

                            </tr>
                        }
                    </tbody>
                </table>

            </div>

            <div class="table-footer">
                <div class="footer-metrics">
                    <div class="footer-metric">
                        <span class="footer-label">Resultados visibles</span>
                        <strong>@notasPaginaActual.Count</strong>
                    </div>

                    <div class="footer-metric">
                        <span class="footer-label">Resultados filtrados</span>
                        <strong>@notasFiltradas.Count</strong>
                    </div>

                    <div class="footer-metric footer-metric-highlight">
                        <span class="footer-label">Total visible</span>
                        <strong>$ @totalVisible.ToString("N2")</strong>
                    </div>
                </div>

                @if (TotalPaginas > 1)
                {
                    <nav class="pagination-nav" aria-label="Paginacion de notas de credito">
                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaAnterior"
                                disabled="@(PaginaActualSegura == 1)">
                            <i class="bi bi-chevron-left"></i>
                            <span>Anterior</span>
                        </button>

                        @foreach (var pagina in PaginasVisibles)
                        {
                            var paginaLocal = pagina;

                            <button class="pagination-btn @(paginaLocal == PaginaActualSegura ? "is-active" : null)"
                                    @onclick="() => IrAPagina(paginaLocal)">
                                @paginaLocal
                            </button>
                        }

                        <button class="pagination-btn pagination-btn-direction"
                                @onclick="PaginaSiguiente"
                                disabled="@(PaginaActualSegura == TotalPaginas)">
                            <span>Siguiente</span>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </nav>
                }
            </div>

        </section>
    }

</div>


@if (mostrarModal && notaSeleccionada != null)
{
    <div class="factura-modal-backdrop" @onclick="CerrarModal"></div>

    <div class="modal fade show d-block factura-modal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable factura-modal-dialog">
            <div class="modal-content factura-modal-content">

                <div class="modal-header factura-modal-header">
                    <div>
                        <span class="modal-kicker">Comprobante generado</span>
                        <h5 class="modal-title mb-0">
                            Nota de Crédito @notaSeleccionada.NotaCredito.NumNotaCredito
                        </h5>
                    </div>

                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>

                <div class="modal-body factura-modal-body">
                    <NotaCreditoPreview Model="notaSeleccionada" />
                </div>

                <div class="modal-footer factura-modal-footer">
                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirXmlAsync(notaSeleccionada.NotaCredito.Sec)">
                        Abrir XML
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(notaSeleccionada.NotaCredito.Sec)">
                        Abrir PDF A4
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(notaSeleccionada.NotaCredito.Sec, FormatoImpresionDocumento.Termica80mm)">
                        Termica 80mm
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            @onclick="() => AbrirPdfAsync(notaSeleccionada.NotaCredito.Sec, FormatoImpresionDocumento.Termica50mm)">
                        Termica 50mm
                    </button>

                    <button class="secondary-btn secondary-btn-accent modal-link-btn"
                            disabled="@(procesandoReenvio || procesandoAnulacion)"
                            @onclick="() => ReenviarCorreoNotaAsync(notaSeleccionada.NotaCredito.Sec)">
                        Reenviar correo
                    </button>

                    <button class="secondary-btn secondary-btn-quiet" @onclick="CerrarModal">
                        Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private int currentUserId;
    private bool cargando = true;
    private bool isDemoMode;
    private List<NotaCreditoListDto> notas = new();
    private readonly int[] pageSizeOptions = { 5, 10, 20, 50 };
    private int paginaActual = 1;
    private int registrosPorPagina = 10;
    private bool mostrarModal;
    private NotaCreditoDetalleViewDto? notaSeleccionada;
    private string filtro = string.Empty;
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;
    private bool procesandoReenvio = false;
    private bool mostrarResultadoOverlay;
    private string tituloResultadoOverlay = string.Empty;
    private string detalleResultadoOverlay = string.Empty;
    private List<Simetric.Models.Emisor> emisores = new();
    private int RegistrosPorPagina
    {
        get => registrosPorPagina;
        set
        {
            registrosPorPagina = value;
            paginaActual = 1;
        }
    }

    private string Filtro
    {
        get => filtro;
        set
        {
            if (filtro == value)
                return;

            filtro = value;
            paginaActual = 1;
        }
    }

    private DateTime? FechaDesde
    {
        get => fechaDesde;
        set
        {
            if (fechaDesde == value)
                return;

            fechaDesde = value;
            paginaActual = 1;
        }
    }

    private DateTime? FechaHasta
    {
        get => fechaHasta;
        set
        {
            if (fechaHasta == value)
                return;

            fechaHasta = value;
            paginaActual = 1;
        }
    }

    private bool HayFiltrosActivos =>
        !string.IsNullOrWhiteSpace(Filtro) || FechaDesde.HasValue || FechaHasta.HasValue;

    private string ResumenRangoFechas
    {
        get
        {
            if (FechaDesde.HasValue && FechaHasta.HasValue)
                return $"{FechaDesde.Value:dd/MM/yyyy} al {FechaHasta.Value:dd/MM/yyyy}";

            if (FechaDesde.HasValue)
                return $"Desde {FechaDesde.Value:dd/MM/yyyy}";

            if (FechaHasta.HasValue)
                return $"Hasta {FechaHasta.Value:dd/MM/yyyy}";

            return "Todas las fechas";
        }
    }

    private string NombreClienteDetalle =>
        notaSeleccionada?.Cliente != null
            ? (!string.IsNullOrWhiteSpace(notaSeleccionada.Cliente.Nombrerazonsocial)
                ? notaSeleccionada.Cliente.Nombrerazonsocial
                : ((notaSeleccionada.Cliente.Nombres ?? "") + " " + (notaSeleccionada.Cliente.Apellidos ?? "")).Trim())
            : "";

    private List<NotaCreditoListDto> NotasFiltradas =>
        notas
            .Where(CumpleFiltroNota)
            .ToList();

    private List<NotaCreditoListDto> NotasPaginaActual =>
        NotasFiltradas
            .Skip((PaginaActualSegura - 1) * registrosPorPagina)
            .Take(registrosPorPagina)
            .ToList();

    private int TotalPaginas =>
        NotasFiltradas.Count == 0
            ? 0
            : (int)Math.Ceiling(NotasFiltradas.Count / (double)registrosPorPagina);

    private int PaginaActualSegura =>
        TotalPaginas == 0
            ? 1
            : Math.Min(paginaActual, TotalPaginas);

    private int RegistroInicialPagina =>
        NotasFiltradas.Count == 0
            ? 0
            : ((PaginaActualSegura - 1) * registrosPorPagina) + 1;

    private int RegistroFinalPagina =>
        NotasFiltradas.Count == 0
            ? 0
            : Math.Min(PaginaActualSegura * registrosPorPagina, NotasFiltradas.Count);

    private IEnumerable<int> PaginasVisibles
    {
        get
        {
            if (TotalPaginas == 0)
                return Array.Empty<int>();

            var inicio = Math.Max(1, PaginaActualSegura - 2);
            var fin = Math.Min(TotalPaginas, inicio + 4);

            if (fin - inicio < 4)
                inicio = Math.Max(1, fin - 4);

            return Enumerable.Range(inicio, fin - inicio + 1);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        isDemoMode = EsRutaDemoNotasCredito();
        await Recargar();
    }

    private async Task Recargar()
    {
        cargando = true;

        if (isDemoMode)
        {
            notas = CrearDemoNotasCredito();
            paginaActual = 1;
            cargando = false;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        var userClaim = authState.User.FindFirst("IdUsuario")?.Value;

        currentUserId = int.TryParse(userClaim, out var id) ? id : 0;

        if (currentUserId <= 0)
        {
            NavManager.NavigateTo("/", true);
            return;
        }

        notas = await NotaCreditoService.ListarNotasCreditoUsuarioAsync(currentUserId);
        paginaActual = 1;

        cargando = false;
    }

    private bool CumpleFiltroNota(NotaCreditoListDto nota)
    {
        if (!string.IsNullOrWhiteSpace(Filtro))
        {
            var filtroActual = Filtro.Trim();
            var coincideTexto =
                (nota.NumeroNotaCredito ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (nota.NumeroCompleto ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (nota.NumeroDocModificado ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (nota.Cliente ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (nota.IdentificacionCliente ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (nota.Motivo ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (nota.NumeroAutorizacion ?? string.Empty).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                ObtenerEstadoNotaTexto(nota).Contains(filtroActual, StringComparison.OrdinalIgnoreCase) ||
                (EstaNotaVencida(nota) && "vencido".Contains(filtroActual, StringComparison.OrdinalIgnoreCase));

            if (!coincideTexto)
                return false;
        }

        var fechaReferencia = nota.FechaDocumentoModificado?.Date;

        if (FechaDesde.HasValue && (!fechaReferencia.HasValue || fechaReferencia.Value < FechaDesde.Value.Date))
            return false;

        if (FechaHasta.HasValue && (!fechaReferencia.HasValue || fechaReferencia.Value > FechaHasta.Value.Date))
            return false;

        return true;
    }

