@using Microsoft.JSInterop
@using Simetric.Services
@using Simetric.Extensions
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject LoginDestinationService LoginDestination

@code {
    private bool _navigationTriggered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _navigationTriggered)
        {
            return;
        }

        _navigationTriggered = true;

        try
        {
            var authCheck = await JS.InvokeAsync<AuthCheckResponse>("authInterop.check");
            if (authCheck.Authenticated && authCheck.IdUsuario > 0)
            {
                var destination = await LoginDestination.PrepareDestinationAsync(authCheck.IdUsuario);
                Navigation.NavigateToIfNeeded(destination, forceLoad: true, replace: true);
                return;
            }
        }
        catch (JSDisconnectedException)
        {
            return;
        }
        catch
        {
            // Si no se puede validar la cookie, continuamos al login.
        }

        var currentUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrlParam = string.IsNullOrWhiteSpace(currentUrl) ? "" : $"?ReturnUrl={Uri.EscapeDataString("/" + currentUrl)}";
        try
        {
            Navigation.NavigateToIfNeeded($"/login{returnUrlParam}", replace: true);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private sealed class AuthCheckResponse
    {
        public bool Authenticated { get; set; }
        public int IdUsuario { get; set; }
    }
}
