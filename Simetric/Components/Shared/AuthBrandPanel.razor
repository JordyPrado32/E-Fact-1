<style>
    .auth-brand-panel {
        flex: 0 0 58%;
        display: none;
        grid-template-rows: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: clamp(1rem, 2vh, 2rem);
        padding: clamp(1rem, 2.4vh, 2.4rem) clamp(2rem, 4.4vw, 5.25rem);
        background:
            radial-gradient(circle at 9% 20%, rgba(17, 183, 255, 0.24), transparent 19rem),
            radial-gradient(circle at 54% 70%, rgba(43, 173, 255, 0.34), transparent 19rem),
            radial-gradient(circle at 100% 47%, rgba(13, 121, 215, 0.44), transparent 24rem),
            linear-gradient(138deg, #05256f 0%, var(--n-blue) 54%, #03215d 100%);
        color: #fff;
        position: relative;
        overflow: hidden;
        min-width: 0;
        min-height: 0;
    }

    .auth-brand-panel::before,
    .auth-brand-panel::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        z-index: 0;
    }

    .auth-brand-panel::before {
        width: clamp(30rem, 48vw, 56rem);
        height: clamp(30rem, 48vw, 56rem);
        left: -20rem;
        bottom: -27rem;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: radial-gradient(circle, rgba(42, 177, 255, 0.42) 0%, rgba(8, 111, 194, 0.24) 44%, transparent 70%);
    }

    .auth-brand-panel::after {
        width: clamp(24rem, 36vw, 44rem);
        height: clamp(24rem, 36vw, 44rem);
        right: -19rem;
        top: 6rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: radial-gradient(circle, rgba(255, 255, 255, 0.09), transparent 67%);
    }

    .auth-brand-panel .numeric-digits-layer {
        opacity: 0.08;
        mix-blend-mode: screen;
    }

    .auth-hero {
        position: relative;
        z-index: 2;
        display: grid;
        gap: clamp(1rem, 1.8vw, 1.75rem);
        width: min(100%, 50rem);
        padding-left: clamp(0.25rem, 0.8vw, 0.85rem);
    }

    .auth-hero-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        width: fit-content;
        color: #fff;
        text-decoration: none;
    }

    .auth-hero-brand img {
        width: clamp(3.5rem, 4.8vw, 4.75rem);
        height: clamp(3.5rem, 4.8vw, 4.75rem);
        object-fit: contain;
        filter: drop-shadow(0 14px 22px rgba(0, 0, 0, 0.18));
    }

    .auth-hero-brand span {
        font-family: "Conthrax SemiBold", "Conthrax", sans-serif;
        font-size: clamp(1.45rem, 2.25vw, 2.1rem);
        line-height: 0.98;
        display: flex;
        flex-direction: column;
    }

    .auth-hero-copy {
        max-width: 52rem;
    }

    .auth-hero-title {
        margin: 0;
        color: #fff;
        font-size: clamp(2.45rem, 3.65vw, 3.7rem);
        font-weight: 800;
        line-height: 1;
        letter-spacing: 0;
        text-shadow: 0 16px 28px rgba(0, 18, 65, 0.22);
        white-space: nowrap;
    }

    .auth-hero-title span {
        color: #20c7ff;
        display: inline;
    }

    .auth-hero-subtitle {
        margin: 0.75rem 0 0;
        color: #fff;
        font-size: clamp(1.25rem, 1.7vw, 1.65rem);
        font-weight: 800;
    }

    .auth-hero-text {
        margin: 0.65rem 0 0;
        max-width: 37rem;
        color: rgba(255, 255, 255, 0.9);
        font-size: clamp(1rem, 1.25vw, 1.15rem);
        line-height: 1.45;
        font-weight: 500;
    }

    .auth-ecosystem-stage {
        position: relative;
        width: min(100%, 52rem);
        height: min(100%, clamp(22rem, 42vh, 29rem));
        min-height: 0;
        margin-top: 0.25rem;
        align-self: center;
        transform: translateY(clamp(1.35rem, 3vh, 2.6rem));
    }

    .auth-ecosystem-stage::before {
        content: "";
        position: absolute;
        z-index: 1;
        left: 5%;
        right: 5%;
        top: 7%;
        height: 82%;
        border: 1px dashed rgba(255, 255, 255, 0.58);
        border-radius: 50%;
        box-shadow:
            inset 0 0 0 5.5rem rgba(255, 255, 255, 0.018),
            inset 0 0 0 10rem rgba(255, 255, 255, 0.028);
    }

    .auth-ecosystem-stage::after {
        content: "";
        position: absolute;
        z-index: 1;
        left: 23%;
        right: 17%;
        bottom: 0.85rem;
        height: 7.5rem;
        border-radius: 50%;
        background: radial-gradient(ellipse, rgba(30, 190, 255, 0.42), rgba(29, 128, 218, 0.22) 44%, transparent 72%);
        filter: blur(2px);
    }

    .auth-login-laptop {
        position: absolute;
        left: 50%;
        bottom: -0.7rem;
        width: min(46%, 23rem);
        transform: translateX(-50%);
        filter: drop-shadow(0 28px 34px rgba(0, 15, 55, 0.38));
        z-index: 2;
    }

    .auth-orbit-card {
        position: absolute;
        z-index: 4;
        left: var(--orbit-x);
        top: var(--orbit-y);
        transform: translate(-50%, -50%);
        width: 8.45rem;
        height: 5.75rem;
        padding: 0.46rem 0.55rem 0.42rem;
        border-radius: 15px;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.28);
        box-shadow: 0 22px 40px rgba(0, 20, 73, 0.26);
        text-align: center;
        color: inherit;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.12rem;
        overflow: hidden;
    }

    a.auth-orbit-card {
        cursor: pointer;
        transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

    a.auth-orbit-card:hover {
        transform: translate(-50%, calc(-50% - 0.25rem));
        box-shadow: 0 26px 44px rgba(0, 20, 73, 0.32);
    }

    .auth-orbit-service-icon {
        display: block;
        width: 6.65rem;
        height: 1.72rem;
        flex: 0 0 1.72rem;
        margin: 0 auto 0.28rem;
        border-radius: 10px;
        object-fit: contain;
        object-position: center;
        background: #fff;
        padding: 0.1rem 0.25rem;
        box-shadow: 0 8px 18px rgba(0, 34, 91, 0.12);
    }

    .auth-orbit-card span {
        display: block;
        color: #2c4665;
        font-size: 0.58rem;
        line-height: 1.15;
        margin-top: 0;
        font-weight: 600;
        min-height: 1.25rem;
    }

    .auth-orbit-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        max-width: 100%;
        margin-top: 0;
        padding: 0.14rem 0.48rem;
        min-height: 0.84rem;
        border-radius: 999px;
        background: rgba(0, 107, 181, 0.12);
        color: #006bb5;
        font-size: 0.46rem;
        line-height: 1.1;
        font-weight: 800;
        font-style: normal;
        text-transform: uppercase;
    }

    .auth-orbit-coming .auth-orbit-badge {
        background: rgba(244, 63, 94, 0.14);
        color: #d61f46;
    }

    .auth-orbit-efact { --orbit-x: 40%; --orbit-y: 9%; }
    .auth-orbit-esign { --orbit-x: 64%; --orbit-y: 9%; }
    .auth-orbit-edeclara { --orbit-x: 16%; --orbit-y: 37%; }
    .auth-orbit-econtax { --orbit-x: 88%; --orbit-y: 37%; }
    .auth-orbit-epeople { --orbit-x: 18%; --orbit-y: 77%; }
    .auth-orbit-econnect { --orbit-x: 82%; --orbit-y: 77%; }

    .auth-benefit-strip {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        width: min(100%, 45rem);
        align-self: center;
        justify-self: center;
        margin-left: auto;
        margin-right: auto;
        margin-top: auto;
        padding: 0.65rem;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 20px 46px rgba(0, 18, 65, 0.22);
        backdrop-filter: blur(12px);
    }

    .auth-benefit-item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.65rem;
        align-items: center;
        min-width: 0;
        padding: 0.45rem;
    }

    .auth-benefit-item i {
        color: #fff;
        font-size: 1.7rem;
    }

    .auth-benefit-item strong {
        display: block;
        color: #fff;
        font-size: 0.85rem;
        line-height: 1.1;
    }

    .auth-benefit-item span {
        display: block;
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.72rem;
        line-height: 1.25;
        margin-top: 0.15rem;
    }

    @@media (min-width: 993px) {
        html,
        body {
            height: 100%;
            overflow: hidden !important;
        }

        .main-viewport {
            min-height: 0 !important;
            height: 100vh !important;
            height: 100dvh !important;
            overflow: hidden !important;
        }

        .auth-brand-panel,
        .form-side {
            height: 100% !important;
            max-height: 100dvh !important;
            overflow: hidden !important;
        }

        .auth-brand-panel {
            display: grid !important;
            flex: 0 0 58% !important;
            width: 58% !important;
        }

        .form-side {
            flex: 0 0 42% !important;
            width: 42% !important;
        }
    }

    @@media (min-width: 993px) and (max-height: 820px) {
        .auth-brand-panel {
            gap: 0.55rem;
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }

        .auth-hero {
            gap: 0.6rem;
        }

        .auth-hero-brand img {
            width: 3.45rem;
            height: 3.45rem;
        }

        .auth-hero-brand span {
            font-size: 1.5rem;
        }

        .auth-hero-title {
            font-size: clamp(2.15rem, 3.2vw, 3.05rem);
        }

        .auth-hero-subtitle {
            margin-top: 0.55rem;
            font-size: clamp(1.05rem, 1.45vw, 1.35rem);
        }

        .auth-hero-text {
            margin-top: 0.45rem;
            font-size: 0.98rem;
            line-height: 1.35;
        }

        .auth-ecosystem-stage {
            height: clamp(20rem, 39vh, 24rem);
            transform: translateY(0);
        }

        .auth-login-laptop {
            bottom: -0.45rem;
            width: min(45%, 21rem);
        }

        .auth-orbit-card {
            width: 8rem;
            height: 5.35rem;
            padding: 0.36rem 0.42rem;
            border-radius: 14px;
        }

        .auth-orbit-service-icon {
            width: 6.75rem;
            height: 1.75rem;
            flex-basis: 1.75rem;
            margin-bottom: 0.3rem;
        }

        .auth-orbit-card span {
            font-size: 0.56rem;
            line-height: 1.12;
            min-height: 1.18rem;
        }

        .auth-orbit-badge {
            font-size: 0.42rem;
            padding: 0.12rem 0.34rem;
            min-height: 0.78rem;
        }

        .auth-benefit-strip {
            width: min(100%, 42rem);
            padding: 0.35rem;
            border-radius: 14px;
        }

        .auth-benefit-item {
            gap: 0.45rem;
            padding: 0.3rem;
        }

        .auth-benefit-item i {
            font-size: 1.42rem;
        }

        .auth-benefit-item strong {
            font-size: 0.74rem;
        }

        .auth-benefit-item span {
            font-size: 0.58rem;
            line-height: 1.12;
        }
    }

    @@media (min-width: 1400px) {
        .auth-brand-panel {
            flex-basis: 58% !important;
            padding: clamp(1.8rem, 3vh, 3rem) clamp(3.4rem, 5vw, 6rem);
        }

        .auth-hero {
            gap: clamp(1rem, 1.9vh, 1.65rem);
            width: min(100%, 58rem);
        }

        .auth-hero-brand img {
            width: clamp(3.9rem, 3.2vw, 4.6rem);
            height: clamp(3.9rem, 3.2vw, 4.6rem);
        }

        .auth-hero-brand span {
            font-size: clamp(1.75rem, 1.7vw, 2.2rem);
        }

        .auth-hero-title {
            font-size: clamp(3rem, 3.55vw, 4.15rem);
        }

        .auth-hero-subtitle {
            font-size: clamp(1.28rem, 1.55vw, 1.75rem);
        }

        .auth-hero-text {
            max-width: 46rem;
            font-size: clamp(1.05rem, 1vw, 1.18rem);
        }

        .auth-ecosystem-stage {
            width: min(100%, 53rem);
            height: clamp(27rem, 48vh, 34rem);
            transform: translateY(0);
        }

        .auth-login-laptop {
            width: min(49%, 28rem);
            bottom: -0.5rem;
        }

        .auth-orbit-card {
            width: 9.25rem;
            height: 6.2rem;
            padding: 0.5rem 0.58rem 0.46rem;
            border-radius: 16px;
        }

        .auth-orbit-service-icon {
            width: 7.35rem;
            height: 2rem;
            flex-basis: 2rem;
            margin-bottom: 0.3rem;
        }

        .auth-orbit-card span {
            font-size: 0.61rem;
        }

        .auth-orbit-badge {
            font-size: 0.47rem;
        }

        .auth-benefit-strip {
            width: min(100%, 47rem);
            padding: 0.55rem;
        }
    }

    @@media (min-width: 1400px) and (max-height: 820px) {
        .auth-brand-panel {
            gap: 0.55rem;
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }

        .auth-hero-title {
            font-size: clamp(2.6rem, 3.2vw, 3.45rem);
        }

        .auth-ecosystem-stage {
            height: clamp(20.5rem, 39vh, 24rem);
            transform: translateY(0);
        }

        .auth-login-laptop {
            width: min(45%, 22rem);
            bottom: -0.35rem;
        }

        .auth-orbit-card {
            width: 8.15rem;
            height: 5.4rem;
            padding: 0.4rem 0.46rem;
        }

        .auth-orbit-service-icon {
            width: 6.95rem;
            height: 1.82rem;
            flex-basis: 1.82rem;
        }

        .auth-benefit-strip {
            width: min(100%, 42rem);
            padding: 0.34rem;
        }

        .auth-benefit-item {
            padding: 0.28rem;
        }

        .auth-benefit-item i {
            font-size: 1.55rem;
        }
    }

    @@media (min-width: 993px) and (max-height: 700px) {
        .auth-benefit-item span {
            display: none;
        }
    }

    @@media (max-width: 992px) {
        html,
        body {
            height: auto;
            overflow-y: auto !important;
        }

        .main-viewport {
            height: auto !important;
            min-height: max(100vh, 100dvh) !important;
            overflow: visible !important;
        }
    }
</style>

<div class="auth-brand-panel">
    <div id="@DigitLayerId" class="numeric-digits-layer" aria-hidden="true"></div>

    <div class="auth-hero">
        <a class="auth-hero-brand" href="https://numericasoftware.com/" target="_blank" rel="noopener noreferrer">
            <img src="/images/company-logo.png" alt="Numérica software" onerror="this.style.display='none'" />
            <span>
                <span>Numérica</span>
                <span>software</span>
            </span>
        </a>

        <div class="auth-hero-copy">
            <h1 class="auth-hero-title">
                Bienvenido a
                <span>Numérica</span>
            </h1>
            <p class="auth-hero-subtitle">Tu ecosistema empresarial completo</p>
            <p class="auth-hero-text">Una sola cuenta para acceder a todas las soluciones que impulsan y hacen crecer tu negocio.</p>
        </div>
    </div>

    <div class="auth-ecosystem-stage">
        <img src="/images/login-laptop.png" class="auth-login-laptop" alt="" />

        <a class="auth-orbit-card auth-orbit-efact" href="https://numericasoftware.com/efact" target="_blank" rel="noopener noreferrer" aria-label="Ir a E-FACT">
            <img class="auth-orbit-service-icon" src="/images/services/efact.png" alt="" />
            <span>Facturación electrónica</span>
            <em class="auth-orbit-badge">Ir ahora</em>
        </a>

        <a class="auth-orbit-card auth-orbit-esign" href="https://numericasoftware.com/esign" target="_blank" rel="noopener noreferrer" aria-label="Ir a E-Rúbrica">
            <img class="auth-orbit-service-icon" src="/images/services/erubrica.png" alt="" />
            <span>Firma electrónica</span>
            <em class="auth-orbit-badge">Ir ahora</em>
        </a>

        <div class="auth-orbit-card auth-orbit-econtax auth-orbit-coming">
            <img class="auth-orbit-service-icon" src="/images/services/econtax.png" alt="" />
            <span>Contabilidad inteligente</span>
            <em class="auth-orbit-badge">Próximamente 2027</em>
        </div>

        <div class="auth-orbit-card auth-orbit-edeclara auth-orbit-coming">
            <img class="auth-orbit-service-icon" src="/images/services/edeclara.png" alt="" />
            <span>Declaraciones tributarias</span>
            <em class="auth-orbit-badge">Próximamente 2027</em>
        </div>

        <div class="auth-orbit-card auth-orbit-epeople auth-orbit-coming">
            <img class="auth-orbit-service-icon" src="/images/services/epeople.png" alt="" />
            <span>Gestión de talento humano</span>
            <em class="auth-orbit-badge">Próximamente 2027</em>
        </div>

        <div class="auth-orbit-card auth-orbit-econnect auth-orbit-coming">
            <img class="auth-orbit-service-icon" src="/images/services/econnect.png" alt="" />
            <span>CRM y gestión de ventas</span>
            <em class="auth-orbit-badge">Próximamente 2027</em>
        </div>
    </div>

    <div class="auth-benefit-strip">
        <div class="auth-benefit-item">
            <i class="ri-shield-check-line"></i>
            <div>
                <strong>Confiable</strong>
                <span>Alineado a normativas del SRI</span>
            </div>
        </div>
        <div class="auth-benefit-item">
            <i class="ri-cloud-line"></i>
            <div>
                <strong>Disponible 24/7</strong>
                <span>Plataforma estable, rápida y segura</span>
            </div>
        </div>
        <div class="auth-benefit-item">
            <i class="ri-customer-service-2-line"></i>
            <div>
                <strong>Soporte experto</strong>
                <span>Te acompañamos en cada paso</span>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string DigitLayerId { get; set; } = "numericaDigitsLayer";
}
