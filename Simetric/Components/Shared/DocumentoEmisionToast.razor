@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="documento-emision-toast @(IsError ? "is-error" : "is-ok")" role="status" aria-live="polite">
        <i class="bi @(IsError ? "bi-exclamation-triangle" : "bi-check-circle")"></i>
        <span class="documento-emision-mensaje">@Message</span>
        @if (!IsError && !string.IsNullOrWhiteSpace(PdfUrl))
        {
            <button type="button" class="documento-emision-accion is-primary" @onclick="OnOpenPdf">
                Ver PDF
            </button>
        }
        @AdditionalActions
    </div>
}

@code {
    [Parameter] public string? Message { get; set; }
    [Parameter] public bool IsError { get; set; }
    [Parameter] public string? PdfUrl { get; set; }
    [Parameter] public EventCallback OnOpenPdf { get; set; }
    [Parameter] public RenderFragment? AdditionalActions { get; set; }
}
