@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Text.Json
@using Simetric.Modules.AsistenteIAFacturacion.DTOs
@using Simetric.Modules.AsistenteIAFacturacion.Services
@inject IAsistenteFacturacionService AsistenteFacturacionService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject NavigationManager NavManager
@implements IAsyncDisposable

<div class="ia-fact-launcher" @ref="launcherContainer">
    @if (ShowOnboardingBubble)
    {
        <section class="ia-fact-bot-bubble" role="status" aria-live="polite">
            <div class="ia-fact-bot-copy">
                <strong>@OnboardingBubbleTitle</strong>
                <span>@OnboardingBubbleMessage</span>
            </div>
            <div class="ia-fact-bot-actions">
                @if (!string.IsNullOrWhiteSpace(OnboardingBubbleActionRoute))
                {
                    <button type="button" class="ia-fact-bot-action" @onclick="() => NavManager.NavigateTo(OnboardingBubbleActionRoute!)">
                        @OnboardingBubbleActionLabel
                    </button>
                }
                <button type="button" class="ia-fact-bot-dismiss" @onclick="OnboardingBubbleDismiss">
                    Ocultar por ahora
                </button>
            </div>
        </section>
    }

    @if (panelAbierto)
    {
        <section class="ia-fact-panel" data-tour="dashboard.ai-panel">
            <header class="ia-fact-header">
                <div class="ia-fact-brand-wrap">
                    <div class="ia-fact-brand">
                        <img src="/images/LogoPrincipal.svg" alt="e-fact" />
                        <div>
                            <strong>Asistente IA</strong>
                            <span>Facturas y notas de crédito</span>
                        </div>
                    </div>
                </div>
                <div class="ia-fact-header-actions">
                    <button type="button" class="ia-fact-audio-toggle" @onclick="ToggleVoiceOutputAsync" title="Activar o silenciar voz">
                        <i class="bi @(vozSalidaActiva ? "bi-volume-up-fill" : "bi-volume-mute-fill")"></i>
                    </button>
                    <button type="button" class="ia-fact-close" @onclick="TogglePanelAsync" aria-label="Cerrar asistente">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </header>

            <div class="ia-fact-messages" @ref="mensajesContainer">
                @foreach (var message in mensajes)
                {
                    <article class="ia-fact-message @(message.EsUsuario ? "is-user" : "is-bot")">
                        <div class="ia-fact-bubble">@message.Texto</div>
                    </article>
                }

                @if (opcionesSeleccion.Any())
                {
                    <section class="ia-fact-selection-box">
                        <strong>Selecciona una opción</strong>
                        @foreach (var opcion in opcionesSeleccion)
                        {
                            <button type="button" class="ia-fact-selection-option" @onclick="() => SeleccionarOpcionAsync(opcion)">
                                <span>@(opcion.Indice > 0 ? $"{opcion.Indice}. " : string.Empty)@opcion.Etiqueta</span>
                                @if (!string.IsNullOrWhiteSpace(opcion.Descripcion))
                                {
                                    <small>@opcion.Descripcion</small>
                                }
                            </button>
                        }
                    </section>
                }

                @if (respuestaActual?.FacturaDraft is { } draft && (draft.Cliente is not null || draft.Items.Count > 0))
                {
                    <section class="ia-fact-draft">
                        <h4>Borrador actual</h4>
                        @if (draft.Cliente is not null)
                        {
                            <div class="ia-fact-meta"><strong>Cliente:</strong> <span>@draft.Cliente.Nombre</span></div>
                        }
                        @foreach (var item in draft.Items)
                        {
                            <div class="ia-fact-item">@item.Cantidad x @item.Descripcion <span>$@item.Total.ToString("0.00")</span></div>
                        }
                        @if (draft.IvaDetalles.Count > 0)
                        {
                            @foreach (var iva in draft.IvaDetalles)
                            {
                                <div class="ia-fact-meta">
                                    <span>IVA @(iva.TarifaPorcentaje.ToString("0"))%</span>
                                    <span>Base $@iva.BaseImponible.ToString("0.00") / $@iva.ValorIva.ToString("0.00")</span>
                                </div>
                            }
                        }
                        <div class="ia-fact-meta"><strong>Subtotal:</strong> <span>$@draft.Subtotal.ToString("0.00")</span></div>
                        <div class="ia-fact-meta"><strong>Descuento:</strong> <span>$@draft.Descuento.ToString("0.00")</span></div>
                        <div class="ia-fact-meta"><strong>Impuestos:</strong> <span>$@draft.Impuesto.ToString("0.00")</span></div>
                        <div class="ia-fact-meta"><strong>Forma de pago:</strong> <span>@(string.IsNullOrWhiteSpace(draft.FormaPago) ? "Pendiente" : draft.FormaPago)</span></div>
                        @if (draft.DiasCredito.GetValueOrDefault() > 0 && draft.FechaVencimiento.HasValue)
                        {
                            <div class="ia-fact-meta"><strong>Crédito:</strong> <span>@draft.DiasCredito días | @draft.FechaVencimiento.Value.ToString("dd/MM/yyyy")</span></div>
                        }
                        <div class="ia-fact-totals">
                            <span>Total</span>
                            <strong>$@draft.Total.ToString("0.00")</strong>
                        </div>
                        <div class="ia-fact-quick-actions">
                            <button type="button" class="ia-fact-chip" @onclick='() => EnviarComandoRapidoAsync("forma de pago efectivo")' disabled="@enviando">Efectivo</button>
                            <button type="button" class="ia-fact-chip" @onclick='() => EnviarComandoRapidoAsync("forma de pago crédito")' disabled="@enviando">Crédito</button>
                            <button type="button" class="ia-fact-chip ia-fact-chip-primary" @onclick="EmitirFacturaRapidoAsync" disabled="@(!PuedeEmitirBorrador() || enviando)">Emitir</button>
                        </div>
                    </section>
                }
            </div>

            <footer class="ia-fact-footer">
                @if (!string.IsNullOrWhiteSpace(alertaMicrofono))
                {
                    <div class="ia-fact-mic-alert" role="alert">
                        <i class="bi bi-mic-fill"></i>
                        <span>@alertaMicrofono</span>
                    </div>
                }
                <div class="ia-fact-input-row">
                    <input @bind="mensajeActual" @bind:event="oninput" placeholder="Escribe o habla tu factura o nota de crédito..." @onkeydown="HandleKeyDown" />
                    <button type="button" class="ia-fact-send" @onclick="EnviarAsync" disabled="@enviando">Enviar</button>
                </div>
                <small>@estadoVoz</small>
            </footer>
        </section>
    }

    <button type="button"
            class="ia-fact-fab @(panelAbierto ? "is-open" : string.Empty)"
            @onclick="TogglePanelAsync"
            title="Asistente de facturación"
            aria-label="Abrir asistente de facturación">
        <span class="ia-fact-orbit ia-fact-orbit-one" aria-hidden="true"></span>
        <span class="ia-fact-orbit ia-fact-orbit-two" aria-hidden="true"></span>
        <span class="ia-fact-robot" aria-hidden="true">
            <span class="ia-fact-robot-antenna"></span>
            <span class="ia-fact-robot-head">
                <span class="ia-fact-robot-ear ia-fact-robot-ear-left"></span>
                <span class="ia-fact-robot-ear ia-fact-robot-ear-right"></span>
                <span class="ia-fact-robot-face">
                    <span class="ia-fact-robot-eye"></span>
                    <span class="ia-fact-robot-eye"></span>
                    <span class="ia-fact-robot-smile"></span>
                </span>
            </span>
            <span class="ia-fact-robot-body">
                <span class="ia-fact-robot-arm ia-fact-robot-arm-left"></span>
                <span class="ia-fact-robot-arm ia-fact-robot-arm-right"></span>
                <span class="ia-fact-robot-core">N</span>
            </span>
        </span>
        <span class="ia-fact-mic-badge" aria-hidden="true"><i class="bi bi-mic-fill"></i></span>
    </button>
</div>

@code {
    [Parameter] public bool ShowOnboardingBubble { get; set; }
    [Parameter] public string? OnboardingBubbleTitle { get; set; }
    [Parameter] public string? OnboardingBubbleMessage { get; set; }
    [Parameter] public string? OnboardingBubbleActionLabel { get; set; }
    [Parameter] public string? OnboardingBubbleActionRoute { get; set; }
    [Parameter] public EventCallback OnboardingBubbleDismiss { get; set; }

    private readonly List<UiChatMessage> mensajes = new();
    private const int MaxMensajesVisibles = 18;
    private string sessionId = Guid.NewGuid().ToString("N");
    private string mensajeActual = string.Empty;
    private bool panelAbierto;
    private bool enviando;
    private bool escuchando;
    private bool vozSalidaActiva = true;
    private bool manosLibresActivas;
    private bool vozInteractivaActiva;
    private string estadoVoz = "Pulsa el botón azul para hablar con el asistente.";
    private string? alertaMicrofono;
    private ChatFacturaResponse? respuestaActual;
    private DotNetObjectReference<AsistenteFacturacionLauncher>? dotNetRef;
    private ElementReference mensajesContainer;
    private ElementReference launcherContainer;
    private bool debeDesplazarAlFinal;
    private List<SelectionOptionDto> opcionesSeleccion = new();
    private DateTime ultimoEnvioUtc = DateTime.MinValue;
    private readonly HashSet<string> vocabularioVoz = new(StringComparer.OrdinalIgnoreCase);
    private static readonly string[] FrasesBaseVoz =
    [
        "factura",
        "nota de crédito",
        "nota de credito",
        "notas de crédito",
        "notas de credito",
        "cliente",
        "producto",
        "servicio",
        "subtotal",
        "descuento",
        "IVA",
        "RUC",
        "cédula",
        "forma de pago",
        "emitir factura",
        "crear nota de crédito",
        "crear nota de credito",
        "historial notas de crédito",
        "historial notas de credito",
        "crear factura",
        "agregar producto",
        "buscar cliente",
        "cuentas por cobrar",
        "cartera",
        "saldo a favor",
        "registrar abono",
        "clientes que deben"
    ];

    protected override void OnParametersSet()
    {
        if (ShowOnboardingBubble && panelAbierto)
        {
            panelAbierto = false;
            manosLibresActivas = false;
            vozInteractivaActiva = false;
            escuchando = false;
            estadoVoz = "Completa los pasos pendientes para activar el asistente de facturacion.";
        }
    }

    private void AgregarMensaje(bool esUsuario, string texto)
    {
        mensajes.Add(new UiChatMessage(esUsuario, texto));

        if (mensajes.Count > MaxMensajesVisibles)
        {
            mensajes.RemoveRange(0, mensajes.Count - MaxMensajesVisibles);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var existing = await JS.InvokeAsync<string?>("localStorage.getItem", "numerica:ia-fact-session");
                if (!string.IsNullOrWhiteSpace(existing))
                {
                    sessionId = existing;
                }
                else
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "numerica:ia-fact-session", sessionId);
                }

                await JS.InvokeVoidAsync(
                    "numericaUi.makeDraggable",
                    launcherContainer,
                    "numerica:ia-fact-position",
                    ".ia-fact-fab");
            }
            catch
            {
            }

            try
            {
                var vocabularioGuardado = await JS.InvokeAsync<string?>("localStorage.getItem", "numerica:ia-fact-vocabulario-voz");
                if (!string.IsNullOrWhiteSpace(vocabularioGuardado))
                {
                    foreach (var termino in JsonSerializer.Deserialize<List<string>>(vocabularioGuardado) ?? new List<string>())
                    {
                        RegistrarFraseVoz(termino);
                    }
                }
            }
            catch
            {
            }

            dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("numericaUi.registerAsistenteDotNetRef", dotNetRef);
            }
            catch
            {
            }
            var bienvenida = "Puedo ayudarte con facturas y también llevarte al flujo de notas de crédito. Escribe lo que necesitas y te guío.";
            AgregarMensaje(false, bienvenida);
            debeDesplazarAlFinal = true;
            StateHasChanged();
        }

        if (debeDesplazarAlFinal)
        {
            debeDesplazarAlFinal = false;
            try
            {
                await JS.InvokeVoidAsync("numericaUi.scrollElementToBottom", mensajesContainer);
            }
            catch
            {
            }
        }
    }

    private async Task TogglePanelAsync()
    {
        if (ShowOnboardingBubble)
        {
            panelAbierto = false;
            manosLibresActivas = false;
            vozInteractivaActiva = false;
            escuchando = false;
            estadoVoz = "Completa los pasos pendientes para activar el asistente de facturacion.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("numericaUi.stopSpeaking");
        }
        catch
        {
        }

        panelAbierto = !panelAbierto;

        if (!panelAbierto)
        {
            manosLibresActivas = false;
            vozInteractivaActiva = false;
            await JS.InvokeVoidAsync("numericaUi.stopSpeechRecognition");
            escuchando = false;
            estadoVoz = "Asistente en pausa.";
            return;
        }

        await StartVoiceInputAsync(autoOpen: true);
    }

    private async Task EnviarAsync()
    {
        if (enviando || string.IsNullOrWhiteSpace(mensajeActual))
            return;

        var texto = mensajeActual.Trim();
        mensajeActual = string.Empty;
        ultimoEnvioUtc = DateTime.UtcNow;
        AgregarMensaje(true, texto);
        enviando = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (!int.TryParse(user.FindFirst("IdUsuario")?.Value, out var userId) || userId <= 0)
            {
                AgregarMensaje(false, "No pude resolver tu sesión actual para usar el asistente.");
                return;
            }

            respuestaActual = await AsistenteFacturacionService.ProcesarAsync(userId, new ChatFacturaRequest
            {
                SessionId = sessionId,
                Mensaje = texto,
                Modo = "texto"
            });

            if (respuestaActual is not null)
            {
                opcionesSeleccion = respuestaActual.OpcionesSeleccion ?? new List<SelectionOptionDto>();
                await AprenderVocabularioAsync(respuestaActual);
                AgregarMensaje(false, respuestaActual.Respuesta);
                if (!string.IsNullOrWhiteSpace(respuestaActual.RutaSugerida))
                {
                    panelAbierto = false;
                    NavManager.NavigateTo(respuestaActual.RutaSugerida);
                }
                debeDesplazarAlFinal = true;
                await InvokeAsync(StateHasChanged);
                _ = SpeakThenResumeListeningAsync(respuestaActual.Respuesta);
            }
        }
        catch (Exception ex)
        {
            AgregarMensaje(false, $"El asistente no está disponible ahora mismo. {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            enviando = false;
            if (!vozSalidaActiva || !vozInteractivaActiva)
                await EnsureHandsFreeListeningAsync(450);
        }
    }

    private async Task ToggleVoiceInputAsync()
    {
        if (escuchando)
        {
            manosLibresActivas = false;
            vozInteractivaActiva = false;
            await JS.InvokeVoidAsync("numericaUi.stopSpeechRecognition");
            escuchando = false;
            alertaMicrofono = null;
            estadoVoz = "Micrófono detenido.";
            return;
        }

        await StartVoiceInputAsync();
    }

    private async Task StartVoiceInputAsync(bool autoOpen = false)
    {
        try
        {
            var disponible = await JS.InvokeAsync<bool>("numericaUi.isSpeechRecognitionAvailable");
            if (!disponible)
            {
                if (!autoOpen)
                    AgregarMensaje(false, "Tu navegador no soporta reconocimiento de voz. Puedes seguir usando texto.");

                manosLibresActivas = false;
                vozInteractivaActiva = false;
                alertaMicrofono = null;
                estadoVoz = "Voz no disponible en este navegador. Puedes escribir tu mensaje.";
                return;
            }

            var estadoPermiso = await JS.InvokeAsync<string>("numericaUi.getMicrophonePermissionState");
            if (string.Equals(estadoPermiso, "prompt", StringComparison.OrdinalIgnoreCase))
            {
                alertaMicrofono = "Debes permitir el acceso al micrófono en el navegador para hablar con el asistente.";
                estadoVoz = "El navegador está solicitando permiso para usar el micrófono.";
                await InvokeAsync(StateHasChanged);
            }
            else if (string.Equals(estadoPermiso, "denied", StringComparison.OrdinalIgnoreCase))
            {
                manosLibresActivas = false;
                vozInteractivaActiva = false;
                alertaMicrofono = "El micrófono está bloqueado para este sitio. Habilítalo en el navegador y vuelve a intentar.";
                estadoVoz = "El permiso del micrófono está denegado.";
                return;
            }
            else
            {
                alertaMicrofono = null;
            }

            if (dotNetRef is null)
                dotNetRef = DotNetObjectReference.Create(this);

            manosLibresActivas = true;
            vozInteractivaActiva = true;
            await JS.InvokeVoidAsync("numericaUi.startSpeechRecognition", dotNetRef, "es-EC", BuildSpeechPhraseHints());
            escuchando = true;
            alertaMicrofono = null;
            estadoVoz = "Escuchando en manos libres... habla cuando quieras.";
        }
        catch
        {
            manosLibresActivas = false;
            vozInteractivaActiva = false;
            escuchando = false;
            alertaMicrofono = "No pude activar el micrófono. Revisa los permisos del navegador.";
            estadoVoz = autoOpen
                ? "No pude activar el micrófono al abrir el asistente. Puedes intentar de nuevo o escribir."
                : "No pude activar el micrófono.";
        }
    }

    private async Task ToggleVoiceOutputAsync()
    {
        vozSalidaActiva = !vozSalidaActiva;
        if (!vozSalidaActiva)
        {
            await JS.InvokeVoidAsync("numericaUi.stopSpeaking");
            estadoVoz = "Respuesta hablada desactivada.";
        }
        else
        {
            estadoVoz = "Respuesta hablada activada.";
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await EnviarAsync();
    }

    [JSInvokable]
    public Task HandleSpeechPartial(string transcript)
    {
        if (!string.IsNullOrWhiteSpace(transcript))
        {
            mensajeActual = NormalizarTranscriptVoz(transcript);
            estadoVoz = "Escuchando... transcribiendo en vivo.";
            debeDesplazarAlFinal = true;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task HandleSpeechFinal(string transcript)
    {
        escuchando = false;
        alertaMicrofono = null;

        if (string.IsNullOrWhiteSpace(transcript))
        {
            estadoVoz = "No detecté una frase clara. Intenta nuevamente.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        mensajeActual = NormalizarTranscriptVoz(transcript);
        estadoVoz = $"Texto detectado: \"{mensajeActual}\"";
        debeDesplazarAlFinal = true;
        await InvokeAsync(StateHasChanged);
        await EnviarAsync();
    }

    [JSInvokable]
    public Task HandleSpeechError(string message)
    {
        escuchando = false;
        var normalized = message?.ToLowerInvariant() ?? string.Empty;
        var esErrorPermiso = EsErrorPermisoMicrofono(normalized);
        var esSinVoz = normalized.Contains("no detecté voz", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains("no detecte voz", StringComparison.OrdinalIgnoreCase)
            || normalized.Contains("no-speech", StringComparison.OrdinalIgnoreCase);

        estadoVoz = esSinVoz
            ? "No detecté voz clara. Sigo escuchando..."
            : string.IsNullOrWhiteSpace(message)
                ? "No pude procesar el audio."
                : $"Audio: {message}";

        alertaMicrofono = esErrorPermiso
            ? "Debes permitir el uso del micrófono en el navegador para continuar con la voz."
            : null;

        StateHasChanged();

        if (!esErrorPermiso)
            _ = EnsureHandsFreeListeningAsync(esSinVoz ? 650 : 1200);

        return Task.CompletedTask;
    }

    [JSInvokable]
    public void ActivarPreguntasSoporte()
    {
        opcionesSeleccion = new List<SelectionOptionDto>
        {
            new() { Indice = -999, Etiqueta = "¿Cómo configuro mi firma electrónica .p12?", Descripcion = "Carga y configura tu firma .p12" },
            new() { Indice = -999, Etiqueta = "¿Cómo puedo realizar una recarga de documentos?", Descripcion = "Comprar documentos y recargar plan" },
            new() { Indice = -999, Etiqueta = "¿Cómo crear una factura electrónica?", Descripcion = "Paso a paso para emitir comprobantes" }
        };
        StateHasChanged();
    }

    [JSInvokable]
    public void LimpiarPreguntasSoporte()
    {
        if (opcionesSeleccion.Any(o => o.Indice == -999))
        {
            opcionesSeleccion.Clear();
            StateHasChanged();
        }
    }

    private async Task SeleccionarOpcionAsync(SelectionOptionDto opcion)
    {
        if (opcion.Indice == -999)
        {
            mensajeActual = opcion.Etiqueta;
        }
        else
        {
            mensajeActual = opcion.Indice.ToString();
        }
        await EnviarAsync();
    }

    private async Task EnviarComandoRapidoAsync(string comando)
    {
        if (enviando || string.IsNullOrWhiteSpace(comando))
            return;

        mensajeActual = comando;
        await EnviarAsync();
    }

    private Task EmitirFacturaRapidoAsync()
        => EnviarComandoRapidoAsync(respuestaActual?.RequiereConfirmacion == true
            ? "confirmo emitir factura"
            : "emitir factura");

    private bool PuedeEmitirBorrador()
        => respuestaActual?.FacturaDraft is { } draft
            && draft.Cliente is not null
            && draft.Items.Count > 0;

    private string[] BuildSpeechPhraseHints()
    {
        var frases = new HashSet<string>(FrasesBaseVoz, StringComparer.OrdinalIgnoreCase);

        foreach (var termino in vocabularioVoz)
            frases.Add(termino);

        if (respuestaActual?.FacturaDraft?.Cliente is { } cliente)
        {
            RegistrarFraseTemporal(frases, cliente.Nombre);
            RegistrarFraseTemporal(frases, cliente.Identificacion);
            RegistrarFraseTemporal(frases, cliente.NumeroNotificacion);
        }

        if (respuestaActual?.FacturaDraft?.Items is not null)
        {
            foreach (var item in respuestaActual.FacturaDraft.Items)
            {
                RegistrarFraseTemporal(frases, item.Descripcion);
                RegistrarFraseTemporal(frases, item.CodigoPrincipal);
            }
        }

        foreach (var opcion in opcionesSeleccion)
        {
            RegistrarFraseTemporal(frases, opcion.Etiqueta);
        }

        return frases
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Take(80)
            .ToArray();
    }

    private async Task AprenderVocabularioAsync(ChatFacturaResponse response)
    {
        var cambios = false;

        if (response.FacturaDraft.Cliente is { } cliente)
        {
            cambios |= RegistrarFraseVoz(cliente.Nombre);
            cambios |= RegistrarFraseVoz(cliente.Identificacion);
            cambios |= RegistrarFraseVoz(cliente.NumeroNotificacion);
        }

        foreach (var item in response.FacturaDraft.Items)
        {
            cambios |= RegistrarFraseVoz(item.Descripcion);
            cambios |= RegistrarFraseVoz(item.CodigoPrincipal);
        }

        foreach (var opcion in response.OpcionesSeleccion)
        {
            cambios |= RegistrarFraseVoz(opcion.Etiqueta);
            cambios |= RegistrarFraseVoz(opcion.Descripcion);
            cambios |= RegistrarFraseVoz(opcion.Cliente?.Nombre);
            cambios |= RegistrarFraseVoz(opcion.Producto?.Nombre);
            cambios |= RegistrarFraseVoz(opcion.Producto?.CodigoPrincipal);
            cambios |= RegistrarFraseVoz(opcion.Producto?.Categoria);
            cambios |= RegistrarFraseVoz(opcion.Producto?.Subcategoria);
        }

        if (!cambios)
            return;

        try
        {
            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "numerica:ia-fact-vocabulario-voz",
                JsonSerializer.Serialize(vocabularioVoz.OrderBy(x => x).Take(200).ToList()));
        }
        catch
        {
        }
    }

    private bool RegistrarFraseVoz(string? valor)
    {
        var frase = (valor ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(frase) || frase.Length < 2)
            return false;

        if (frase.Length > 80)
            frase = frase[..80];

        return vocabularioVoz.Add(frase);
    }

    private static void RegistrarFraseTemporal(HashSet<string> frases, string? valor)
    {
        var frase = (valor ?? string.Empty).Trim();
        if (!string.IsNullOrWhiteSpace(frase))
            frases.Add(frase);
    }

    private string NormalizarTranscriptVoz(string transcript)
    {
        var texto = transcript.Trim();
        if (string.IsNullOrWhiteSpace(texto))
            return string.Empty;

        var reemplazos = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            [" iva "] = " IVA ",
            [" iba "] = " IVA ",
            [" ruc "] = " RUC ",
            [" rook "] = " RUC ",
            [" cédula "] = " cédula ",
            [" cedula "] = " cédula ",
            [" factura "] = " factura ",
            [" fractura "] = " factura ",
            [" producto "] = " producto ",
            [" productos "] = " productos ",
            [" cliente "] = " cliente ",
            [" clientes "] = " clientes ",
            [" código "] = " código ",
            [" codigo "] = " código ",
            [" categoría "] = " categoría ",
            [" categoria "] = " categoría "
        };

        texto = $" {texto} ";
        foreach (var reemplazo in reemplazos)
        {
            texto = texto.Replace(reemplazo.Key, reemplazo.Value, StringComparison.OrdinalIgnoreCase);
        }

        texto = string.Join(" ", texto.Split(' ', StringSplitOptions.RemoveEmptyEntries));
        return texto.Trim();
    }

    [JSInvokable]
    public Task HandleSpeechEnd()
    {
        escuchando = false;
        alertaMicrofono = null;
        if (DateTime.UtcNow - ultimoEnvioUtc < TimeSpan.FromMilliseconds(1500))
            return Task.CompletedTask;

        if (string.IsNullOrWhiteSpace(mensajeActual))
            estadoVoz = manosLibresActivas
                ? "Micrófono listo. Sigo atento por si quieres hablar."
                : "Micrófono listo. Puedes volver a intentar.";
        StateHasChanged();
        _ = EnsureHandsFreeListeningAsync(1100);
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("numericaUi.stopSpeechRecognition");
            await JS.InvokeVoidAsync("numericaUi.stopSpeaking");
            await JS.InvokeVoidAsync("numericaUi.releaseDraggable", launcherContainer);
        }
        catch
        {
        }

        dotNetRef?.Dispose();
    }

    private async Task SpeakIfEnabledAsync(string? text)
    {
        if (!vozSalidaActiva || !vozInteractivaActiva || string.IsNullOrWhiteSpace(text))
            return;

        try
        {
            var disponible = await JS.InvokeAsync<bool>("numericaUi.isSpeechSynthesisAvailable");
            if (!disponible)
                return;

            await JS.InvokeAsync<object?>("numericaUi.speakText", text, "es-EC");
        }
        catch
        {
        }
    }

    private async Task SpeakThenResumeListeningAsync(string? text)
    {
        try
        {
            await SpeakIfEnabledAsync(text);
        }
        finally
        {
            if (vozInteractivaActiva)
                await EnsureHandsFreeListeningAsync(900);
        }
    }

    private async Task EnsureHandsFreeListeningAsync(int delayMs = 0)
    {
        if (!panelAbierto || !manosLibresActivas || escuchando || enviando)
            return;

        try
        {
            if (delayMs > 0)
                await Task.Delay(delayMs);

            if (!panelAbierto || !manosLibresActivas || escuchando || enviando)
                return;

            var disponible = await JS.InvokeAsync<bool>("numericaUi.isSpeechRecognitionAvailable");
            if (!disponible)
                return;

            var estadoPermiso = await JS.InvokeAsync<string>("numericaUi.getMicrophonePermissionState");
            if (string.Equals(estadoPermiso, "denied", StringComparison.OrdinalIgnoreCase))
            {
                escuchando = false;
                manosLibresActivas = false;
                vozInteractivaActiva = false;
                alertaMicrofono = "El micrófono está bloqueado para este sitio. Habilítalo en el navegador y vuelve a intentar.";
                estadoVoz = "El permiso del micrófono está denegado.";
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (dotNetRef is null)
                dotNetRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("numericaUi.startSpeechRecognition", dotNetRef, "es-EC", BuildSpeechPhraseHints());
            escuchando = true;
            estadoVoz = "Escuchando en manos libres...";
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private static bool EsErrorPermisoMicrofono(string? normalizedMessage)
    {
        if (string.IsNullOrWhiteSpace(normalizedMessage))
            return false;

        return normalizedMessage.Contains("permiso", StringComparison.OrdinalIgnoreCase)
            || normalizedMessage.Contains("not-allowed", StringComparison.OrdinalIgnoreCase)
            || normalizedMessage.Contains("micrófono", StringComparison.OrdinalIgnoreCase)
            || normalizedMessage.Contains("microfono", StringComparison.OrdinalIgnoreCase)
            || normalizedMessage.Contains("micrófono", StringComparison.OrdinalIgnoreCase);
    }

    private sealed record UiChatMessage(bool EsUsuario, string Texto);
}

