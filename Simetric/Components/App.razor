        window.downloadFileFromStream = async function (fileName, contentStreamReference, contentType) {
            if (!contentStreamReference) {
                return;
            }

            const arrayBuffer = await contentStreamReference.arrayBuffer();
            const blob = new Blob([arrayBuffer], {
                type: contentType || "application/octet-stream"
            });

            const url = URL.createObjectURL(blob);
            const anchor = document.createElement("a");
            anchor.href = url;
            anchor.download = fileName || "archivo";
            document.body.appendChild(anchor);
            anchor.click();
            anchor.remove();

            setTimeout(() => URL.revokeObjectURL(url), 0);
        };

        window.numericaUi = window.numericaUi || {};
        window.numericaUi.downloadVendorQrCard = async function (templateUrl, qrDataUrl, vendorName, fileName) {
            if (!templateUrl || !qrDataUrl) {
                return;
            }

            const loadImage = function (src) {
                return new Promise((resolve, reject) => {
                    const image = new Image();
                    image.crossOrigin = "anonymous";
                    image.onload = () => resolve(image);
                    image.onerror = reject;
                    image.src = src;
                });
            };

            const wrapText = function (ctx, text, maxWidth, maxLines) {
                const words = String(text || "").trim().split(/\s+/).filter(Boolean);
                if (!words.length) {
                    return [""];
                }

                const lines = [];
                let current = words[0];

                for (let i = 1; i < words.length; i++) {
                    const test = current + " " + words[i];
                    if (ctx.measureText(test).width <= maxWidth) {
                        current = test;
                    } else {
                        lines.push(current);
                        current = words[i];
                    }
                }

                lines.push(current);

                if (lines.length <= maxLines) {
                    return lines;
                }

                const visible = lines.slice(0, maxLines);
                let last = visible[maxLines - 1];
                while (last.length > 0 && ctx.measureText(last + "...").width > maxWidth) {
                    last = last.slice(0, -1);
                }

                visible[maxLines - 1] = (last || visible[maxLines - 1]) + "...";
                return visible;
            };

            const template = await loadImage(templateUrl);
            const qrImage = await loadImage(qrDataUrl);

            const canvas = document.createElement("canvas");
            canvas.width = template.width;
            canvas.height = template.height;

            const ctx = canvas.getContext("2d");
            ctx.drawImage(template, 0, 0);

            const qrBox = { x: 177, y: 298, width: 726, height: 619 };
            const qrSize = Math.min(qrBox.width, qrBox.height) - 86;
            const qrX = qrBox.x + ((qrBox.width - qrSize) / 2);
            const qrY = qrBox.y + ((qrBox.height - qrSize) / 2);

            ctx.imageSmoothingEnabled = false;
            ctx.drawImage(qrImage, qrX, qrY, qrSize, qrSize);

            const nameBox = { x: 146, y: 1098, width: 757, height: 273 };
            ctx.fillStyle = "#0c4071";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.font = "700 58px 'Segoe UI', Arial, sans-serif";

            const lines = wrapText(ctx, vendorName, nameBox.width - 80, 2);
            const lineHeight = 68;
            const startY = nameBox.y + (nameBox.height / 2) - (((lines.length - 1) * lineHeight) / 2);

            lines.forEach((line, index) => {
                ctx.fillText(line, nameBox.x + (nameBox.width / 2), startY + (index * lineHeight));
            });

            const dataUrl = canvas.toDataURL("image/png");
            const anchor = document.createElement("a");
            anchor.href = dataUrl;
            anchor.download = fileName || "qr-vendedor.png";
            document.body.appendChild(anchor);
            anchor.click();
            anchor.remove();
        };

        window.numericaUi.scrollTutorialTargetIntoView = function (selector) {
            if (!selector) {
                return false;
            }

            const target = resolveTutorialTarget(selector);

            if (!target) {
                return false;
            }

            target.scrollIntoView({
                behavior: "auto",
                block: "center",
                inline: "nearest"
            });

            return true;
        };

        const buildTutorialTargetMetrics = function (rect, padding, shape) {
            if (!rect || !rect.width || !rect.height) {
                return null;
            }

            const safePadding = Number.isFinite(padding) ? padding : 16;
            const safeShape = typeof shape === "string" && shape.trim().length > 0 ? shape.trim().toLowerCase() : "rounded";
            const viewportPadding = 8;
            const viewportWidth = window.innerWidth;
            const viewportHeight = window.innerHeight;

            if (safeShape === "circle") {
                const availableWidth = Math.max(0, viewportWidth - (viewportPadding * 2));
                const availableHeight = Math.max(0, viewportHeight - (viewportPadding * 2));
                let size = Math.max(rect.width + (safePadding * 2), rect.height + (safePadding * 2));
                size = Math.min(size, availableWidth, availableHeight);

                const centerX = rect.left + (rect.width / 2);
                const centerY = rect.top + (rect.height / 2);
                const maxLeft = Math.max(viewportPadding, viewportWidth - size - viewportPadding);
                const maxTop = Math.max(viewportPadding, viewportHeight - size - viewportPadding);

                return {
                    top: Math.min(Math.max(viewportPadding, centerY - (size / 2)), maxTop),
                    left: Math.min(Math.max(viewportPadding, centerX - (size / 2)), maxLeft),
                    width: size,
                    height: size,
                    viewportWidth: viewportWidth,
                    viewportHeight: viewportHeight,
                    shape: safeShape
                };
            }

            const left = Math.max(viewportPadding, rect.left - safePadding);
            const top = Math.max(viewportPadding, rect.top - safePadding);
            const right = Math.min(viewportWidth - viewportPadding, rect.right + safePadding);
            const bottom = Math.min(viewportHeight - viewportPadding, rect.bottom + safePadding);

            return {
                top: top,
                left: left,
                width: Math.max(0, right - left),
                height: Math.max(0, bottom - top),
                viewportWidth: viewportWidth,
                viewportHeight: viewportHeight,
                shape: safeShape
            };
        };

        const readTutorialRect = function (target) {
            const rect = target.getBoundingClientRect();

            return {
                top: rect.top,
                left: rect.left,
                width: rect.width,
                height: rect.height,
                right: rect.right,
                bottom: rect.bottom
            };
        };

        const isTutorialTargetCandidate = function (target) {
            if (!target || typeof target.getBoundingClientRect !== "function") {
                return false;
            }

            if (target.closest(".workspace-header")) {
                return false;
            }

            const rect = readTutorialRect(target);

            if (!rect.width || !rect.height || target.getClientRects().length === 0) {
                return false;
            }

            const styles = window.getComputedStyle(target);

            return styles.display !== "none" &&
                styles.visibility !== "hidden" &&
                styles.visibility !== "collapse" &&
                Number(styles.opacity || "1") > 0;
        };

        const getTutorialTargetVisibleArea = function (rect) {
            if (!rect) {
                return 0;
            }

            const visibleWidth = Math.max(0, Math.min(rect.right, window.innerWidth) - Math.max(rect.left, 0));
            const visibleHeight = Math.max(0, Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0));
            return visibleWidth * visibleHeight;
        };

        const getTutorialTargetDistanceFromViewportCenter = function (rect) {
            if (!rect) {
                return Number.MAX_SAFE_INTEGER;
            }

            const rectCenterX = rect.left + (rect.width / 2);
            const rectCenterY = rect.top + (rect.height / 2);
            const viewportCenterX = window.innerWidth / 2;
            const viewportCenterY = window.innerHeight / 2;

            return Math.abs(rectCenterX - viewportCenterX) + Math.abs(rectCenterY - viewportCenterY);
        };

        const resolveTutorialTarget = function (selector) {
            if (!selector) {
                return null;
            }

            const matches = Array.from(document.querySelectorAll(selector));

            if (!matches.length) {
                return null;
            }

            const candidates = matches
                .filter(isTutorialTargetCandidate)
                .map(target => ({
                    target: target,
                    rect: readTutorialRect(target)
                }));

            if (!candidates.length) {
                return null;
            }

            candidates.sort((a, b) => {
                const visibleAreaDiff = getTutorialTargetVisibleArea(b.rect) - getTutorialTargetVisibleArea(a.rect);
                if (Math.abs(visibleAreaDiff) > 0.5) {
                    return visibleAreaDiff;
                }

                const distanceDiff = getTutorialTargetDistanceFromViewportCenter(a.rect) - getTutorialTargetDistanceFromViewportCenter(b.rect);
                if (Math.abs(distanceDiff) > 0.5) {
                    return distanceDiff;
                }

                return (b.rect.width * b.rect.height) - (a.rect.width * a.rect.height);
            });

            return candidates[0].target;
        };

        const isTutorialRectStable = function (currentRect, previousRect) {
            if (!currentRect || !previousRect) {
                return false;
            }

            return Math.abs(currentRect.top - previousRect.top) < 0.5 &&
                Math.abs(currentRect.left - previousRect.left) < 0.5 &&
                Math.abs(currentRect.width - previousRect.width) < 0.5 &&
                Math.abs(currentRect.height - previousRect.height) < 0.5;
        };

        const shouldTutorialTargetScroll = function (rect) {
            if (!rect) {
                return false;
            }

            const verticalMargin = 96;
            const horizontalMargin = 32;

            return rect.top < verticalMargin ||
                rect.bottom > window.innerHeight - verticalMargin ||
                rect.left < horizontalMargin ||
                rect.right > window.innerWidth - horizontalMargin;
        };

        const getTutorialScrollableAncestors = function (target) {
            const ancestors = [];
            let current = target.parentElement;

            while (current) {
                if (current !== document.body && current !== document.documentElement) {
                    const styles = window.getComputedStyle(current);
                    const canScrollY = /(auto|scroll|overlay)/.test(styles.overflowY) && current.scrollHeight > current.clientHeight + 1;
                    const canScrollX = /(auto|scroll|overlay)/.test(styles.overflowX) && current.scrollWidth > current.clientWidth + 1;

                    if (canScrollY || canScrollX) {
                        ancestors.push(current);
                    }
                }

                current = current.parentElement;
            }

            return ancestors;
        };

        const scrollTutorialAncestorIntoView = function (target, ancestor) {
            const targetRect = target.getBoundingClientRect();
            const ancestorRect = ancestor.getBoundingClientRect();
            const padding = 24;
            let nextScrollTop = ancestor.scrollTop;
            let nextScrollLeft = ancestor.scrollLeft;

            if (targetRect.top < ancestorRect.top + padding) {
                nextScrollTop -= (ancestorRect.top + padding) - targetRect.top;
            }
            else if (targetRect.bottom > ancestorRect.bottom - padding) {
                nextScrollTop += targetRect.bottom - (ancestorRect.bottom - padding);
            }

            if (targetRect.left < ancestorRect.left + padding) {
                nextScrollLeft -= (ancestorRect.left + padding) - targetRect.left;
            }
            else if (targetRect.right > ancestorRect.right - padding) {
                nextScrollLeft += targetRect.right - (ancestorRect.right - padding);
            }

            if (Math.abs(nextScrollTop - ancestor.scrollTop) > 0.5 || Math.abs(nextScrollLeft - ancestor.scrollLeft) > 0.5) {
                ancestor.scrollTo({
                    top: nextScrollTop,
                    left: nextScrollLeft,
                    behavior: "auto"
                });
            }
        };

        const scrollTutorialViewportIntoView = function (rect) {
            if (!shouldTutorialTargetScroll(rect)) {
                return;
            }

            const verticalMargin = 96;
            const horizontalMargin = 32;
            let nextScrollY = window.scrollY;
            let nextScrollX = window.scrollX;

            if (rect.top < verticalMargin) {
                nextScrollY += rect.top - verticalMargin;
            }
            else if (rect.bottom > window.innerHeight - verticalMargin) {
                nextScrollY += rect.bottom - (window.innerHeight - verticalMargin);
            }

            if (rect.left < horizontalMargin) {
                nextScrollX += rect.left - horizontalMargin;
            }
            else if (rect.right > window.innerWidth - horizontalMargin) {
                nextScrollX += rect.right - (window.innerWidth - horizontalMargin);
            }

            if (Math.abs(nextScrollY - window.scrollY) > 0.5 || Math.abs(nextScrollX - window.scrollX) > 0.5) {
                window.scrollTo({
                    top: nextScrollY,
                    left: nextScrollX,
                    behavior: "auto"
                });
            }
        };

        const ensureTutorialTargetVisible = function (target) {
            const ancestors = getTutorialScrollableAncestors(target);

            for (const ancestor of ancestors) {
                scrollTutorialAncestorIntoView(target, ancestor);
            }

            scrollTutorialViewportIntoView(readTutorialRect(target));
        };

        const waitForTutorialFrame = function () {
            return new Promise(resolve => window.requestAnimationFrame(() => resolve()));
        };

        window.numericaUi.getTutorialTargetMetrics = function (selector, padding, shape) {
            if (!selector) {
                return null;
            }

            const target = resolveTutorialTarget(selector);

            if (!target) {
                return null;
            }

            return buildTutorialTargetMetrics(target.getBoundingClientRect(), padding, shape);
        };

        window.numericaUi.measureTutorialTarget = async function (selector, padding, shape) {
            if (!selector) {
                return null;
            }

            let target = resolveTutorialTarget(selector);

            if (!target) {
                return null;
            }

            let rect = readTutorialRect(target);

            if (!rect.width || !rect.height) {
                return null;
            }

            ensureTutorialTargetVisible(target);

            let previousRect = null;
            let stableFrames = 0;

            for (let attempt = 0; attempt < 12; attempt++) {
                await waitForTutorialFrame();
                target = resolveTutorialTarget(selector) || target;
                rect = readTutorialRect(target);

                if (!rect.width || !rect.height) {
                    return null;
                }

                if (!shouldTutorialTargetScroll(rect) && isTutorialRectStable(rect, previousRect)) {
                    stableFrames += 1;

                    if (stableFrames >= 2) {
                        break;
                    }
                }
                else {
                    stableFrames = 0;
                }

                ensureTutorialTargetVisible(target);
                previousRect = rect;
            }

            return buildTutorialTargetMetrics(rect, padding, shape);
        };

        window.numericaUi.waitForTutorialTarget = async function (selector, timeoutMs) {
            if (!selector) {
                return true;
            }

            const timeout = Number.isFinite(timeoutMs) && timeoutMs > 0 ? timeoutMs : 3000;
            const startedAt = Date.now();
            const hasVisibleTarget = function () {
                const target = resolveTutorialTarget(selector);

                if (!target) {
                    return false;
                }

                const rect = target.getBoundingClientRect();
                return rect.width > 0 && rect.height > 0;
            };

            if (hasVisibleTarget()) {
                return true;
            }

            return await new Promise(resolve => {
                let observer = null;
                let settled = false;

                const complete = function (result) {
                    if (settled) {
                        return;
                    }

                    settled = true;

                    if (observer) {
                        observer.disconnect();
                    }

                    resolve(result);
                };

                const tick = function () {
                    if (settled) {
                        return;
                    }

                    if (hasVisibleTarget()) {
                        complete(true);
                        return;
                    }

                    if ((Date.now() - startedAt) > timeout) {
                        complete(false);
                        return;
                    }

                    window.requestAnimationFrame(tick);
                };

                if (typeof MutationObserver !== "undefined" && document.body) {
                    observer = new MutationObserver(() => {
                        if (hasVisibleTarget()) {
                            complete(true);
                        }
                    });

                    observer.observe(document.body, {
                        childList: true,
                        subtree: true,
                        attributes: true,
                        attributeFilter: ["class", "style", "hidden", "aria-hidden"]
                    });
                }

                window.requestAnimationFrame(tick);
            });
        };

        window.downloadPdfReport = function (elementId, filename) {
            const element = document.getElementById(elementId);
            if (!element) return;
            
            element.classList.add('is-pdf-exporting');
            
            const opt = {
                margin:       [6, 6, 6, 6],
                filename:     filename,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true, logging: false },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'landscape' },
                pagebreak:    { mode: ['css', 'legacy'], avoid: ['.user-report-card-wrapper', '.chart-card', '.kpi-card'] }
            };
            
            html2pdf().set(opt).from(element).save().then(function() {
                element.classList.remove('is-pdf-exporting');
            }).catch(function(err) {
                element.classList.remove('is-pdf-exporting');
                console.error(err);
            });
        };
