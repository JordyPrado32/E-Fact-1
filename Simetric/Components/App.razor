    <script>
        window.authInterop = window.authInterop || {};

        window.authInterop.clearClientSession = window.authInterop.clearClientSession || function () {
            try {
                localStorage.removeItem("userSession");
                localStorage.removeItem("numerica:last-activity");
                localStorage.removeItem("numerica:current-service");
                localStorage.removeItem("selectedAppService");
                sessionStorage.removeItem("numerica:session-expired");
            } catch {
            }
        };

        window.authInterop.postJson = window.authInterop.postJson || async function (url, payload) {
            const response = await fetch(url, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                credentials: "include",
                body: JSON.stringify(payload)
            });

            const text = await response.text();

            if (!text) {
                return {
                    ok: response.ok,
                    status: response.status,
                    statusText: response.statusText,
                    message: response.ok ? "" : `HTTP ${response.status} ${response.statusText}`
                };
            }

            try {
                const data = JSON.parse(text);
                return {
                    ok: response.ok,
                    status: response.status,
                    statusText: response.statusText,
                    ...data
                };
            } catch {
                return {
                    ok: response.ok,
                    status: response.status,
                    statusText: response.statusText,
                    message: text
                };
            }
        };

        window.authInterop.login = window.authInterop.login || function (payload) {
            return window.authInterop.postJson("/api/auth/login", payload);
        };

        window.authInterop.check = window.authInterop.check || async function () {
            let timeoutId;

            try {
                const controller = new AbortController();
                timeoutId = window.setTimeout(function () {
                    controller.abort();
                }, 4000);

                const response = await fetch("/api/auth/check", {
                    method: "GET",
                    credentials: "include",
                    cache: "no-store",
                    signal: controller.signal
                });

                window.clearTimeout(timeoutId);
                return await response.json();
            } catch {
                return { authenticated: false, idUsuario: 0 };
            } finally {
                if (timeoutId) {
                    window.clearTimeout(timeoutId);
                }
            }
        };

        window.authInterop.logout = window.authInterop.logout || async function () {
            try {
                return await window.authInterop.postJson("/api/auth/logout", {});
            } finally {
                window.authInterop.clearClientSession();
            }
        };
    </script>
    <script src="/js/auth.js?v=20260716-auth-shim"></script>
    <script>
        window.numericaLogoutAndRedirect = async function (url) {
            try {
                if (window.authInterop && typeof window.authInterop.logout === "function") {
                    await window.authInterop.logout();
                } else {
                    localStorage.removeItem("userSession");
                    localStorage.removeItem("numerica:last-activity");
                    localStorage.removeItem("numerica:current-service");
                    localStorage.removeItem("selectedAppService");
                    sessionStorage.removeItem("numerica:session-expired");
                }
            } finally {
                window.location.replace(url || "/login");
            }
        };

        window.backOfficeLogoutAndRedirect = async function () {
            try {
                await fetch("/api/auth/logout", {
                    method: "POST",
                    credentials: "include",
                    headers: { "Content-Type": "application/json" },
                    body: "{}"
                });
            } catch {
            } finally {
                try {
                    localStorage.removeItem("userSession");
                    localStorage.removeItem("numerica:last-activity");
                    localStorage.removeItem("numerica:current-service");
                    localStorage.removeItem("selectedAppService");
                    sessionStorage.removeItem("numerica:session-expired");
                } catch {
                }

                window.location.replace("/login");
            }
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.numericaUi = window.numericaUi || {};

        window.numericaUi.getLocalStorageItems = function (keys) {
            const result = {};

            if (!Array.isArray(keys)) {
                return result;
            }

            keys.forEach(function (key) {
                if (typeof key === "string" && key.length > 0) {
                    result[key] = localStorage.getItem(key);
                }
            });

            return result;
        };

        window.numericaUi.setLocalStorageItems = function (items) {
            if (!items || typeof items !== "object") {
                return;
            }

            Object.keys(items).forEach(function (key) {
                if (typeof key !== "string" || key.length === 0) {
                    return;
                }

                const value = items[key];
                if (value === null || value === undefined) {
                    localStorage.removeItem(key);
                    return;
                }

                localStorage.setItem(key, value);
            });
        };

        window.numericaUi.removeStorageItems = function (storageKind, keys) {
            const storage = storageKind === "session" ? sessionStorage : localStorage;

            if (!Array.isArray(keys)) {
                return;
            }

            keys.forEach(function (key) {
                if (typeof key === "string" && key.length > 0) {
                    storage.removeItem(key);
                }
            });
        };

        window.numericaUi.mergeClassNames = function () {
            return Array.from(arguments)
                .flatMap(value => (value || "").toString().split(" "))
                .map(value => value.trim())
                .filter(Boolean)
                .filter((value, index, list) => list.indexOf(value) === index)
                .join(" ");
        };

        window.numericaUi.getSwalThemeOptions = function (options) {
            const settings = options && typeof options === "object" ? { ...options } : {};
            const icon = (settings.icon || "").toString().toLowerCase();
            const confirmLabel = (settings.confirmButtonText || "").toString().toLowerCase();
            const denyLabel = (settings.denyButtonText || "").toString().toLowerCase();
            const isDanger = icon === "warning"
                || icon === "error"
                || confirmLabel.includes("eliminar")
                || confirmLabel.includes("borrar")
                || confirmLabel.includes("anular")
                || denyLabel.includes("eliminar");

            const existingClasses = settings.customClass || {};

            settings.buttonsStyling = false;
            settings.confirmButtonColor = undefined;
            settings.cancelButtonColor = undefined;
            settings.customClass = {
                ...existingClasses,
                popup: window.numericaUi.mergeClassNames("numerica-swal-popup", existingClasses.popup),
                title: window.numericaUi.mergeClassNames("numerica-swal-title", existingClasses.title),
                htmlContainer: window.numericaUi.mergeClassNames("numerica-swal-body", existingClasses.htmlContainer),
                actions: window.numericaUi.mergeClassNames("numerica-swal-actions", existingClasses.actions),
                confirmButton: window.numericaUi.mergeClassNames(
                    "numerica-swal-confirm",
                    isDanger ? "numerica-swal-confirm-danger" : "numerica-swal-confirm-primary",
                    existingClasses.confirmButton),
                cancelButton: window.numericaUi.mergeClassNames("numerica-swal-cancel", existingClasses.cancelButton),
                closeButton: window.numericaUi.mergeClassNames("numerica-swal-close", existingClasses.closeButton),
                icon: window.numericaUi.mergeClassNames("numerica-swal-icon", existingClasses.icon)
            };

            return settings;
        };

        window.numericaUi.patchSweetAlert = function () {
            if (!window.Swal || typeof window.Swal.fire !== "function" || window.numericaUi.__swalPatched) {
                return;
            }

            const originalFire = window.Swal.fire.bind(window.Swal);
            window.numericaUi.__originalSwalFire = originalFire;

            window.Swal.fire = function () {
                if (arguments.length === 1 && arguments[0] && typeof arguments[0] === "object" && !Array.isArray(arguments[0])) {
                    return originalFire(window.numericaUi.getSwalThemeOptions(arguments[0]));
                }

                if (arguments.length >= 1) {
                    const title = arguments[0];
                    const html = arguments.length >= 2 ? arguments[1] : undefined;
                    const icon = arguments.length >= 3 ? arguments[2] : undefined;

                    return originalFire(window.numericaUi.getSwalThemeOptions({
                        title,
                        html,
                        icon
                    }));
                }

                return originalFire();
            };

            window.numericaUi.__swalPatched = true;
        };

        window.numericaUi.toggleBodyScrollLock = function (locked) {
            const body = document.body;
            const html = document.documentElement;

            if (!body || !html) {
                return;
            }

            const currentLocks = Number(body.dataset.modalScrollLocks || "0");

            if (locked) {
                if (currentLocks === 0) {
                    html.classList.add("n-body-scroll-locked");
                    body.classList.add("n-body-scroll-locked");
                }

                body.dataset.modalScrollLocks = String(currentLocks + 1);
                return;
            }

            const nextLocks = Math.max(0, currentLocks - 1);

            if (nextLocks > 0) {
                body.dataset.modalScrollLocks = String(nextLocks);
                return;
            }

            html.classList.remove("n-body-scroll-locked");
            body.classList.remove("n-body-scroll-locked");
            body.removeAttribute("data-modal-scroll-locks");
        };

        window.numericaUi.outsideClickHandlers = window.numericaUi.outsideClickHandlers || {};

        window.numericaUi.registerOutsideClick = function (key, element, dotNetRef, methodName) {
            window.numericaUi.unregisterOutsideClick(key);

            const handler = function (event) {
                if (!element || element.contains(event.target)) {
                    return;
                }

                dotNetRef.invokeMethodAsync(methodName).catch(() => {});
            };

            document.addEventListener("pointerdown", handler, true);
            window.numericaUi.outsideClickHandlers[key] = handler;
        };

        window.numericaUi.unregisterOutsideClick = function (key) {
            const handler = window.numericaUi.outsideClickHandlers[key];
            if (!handler) {
                return;
            }

            document.removeEventListener("pointerdown", handler, true);
            delete window.numericaUi.outsideClickHandlers[key];
        };

        window.numericaUi.enableBackdropDismiss = function () {
            if (window.numericaUi.__backdropDismissEnabled) {
                return;
            }

            const closeSelectors = [
                "[data-modal-dismiss]",
                "button[aria-label*='cerrar' i]",
                "button[title*='cerrar' i]",
                ".modal-close",
                ".btn-close",
                ".welcome-close",
                ".solicitud-notification-close"
            ].join(",");

            document.addEventListener("click", function (event) {
                const clickedElement = event.target;
                if (!(clickedElement instanceof HTMLElement)) {
                    return;
                }

                if (clickedElement.closest("[data-no-backdrop-dismiss]")) {
                    return;
                }

                const classNames = Array.from(clickedElement.classList);
                const isBackdrop = classNames.some(className => className.toLowerCase().includes("backdrop"));
                const ignoredBackdrop = classNames.some(className =>
                    className === "n-loader-backdrop" ||
                    className === "tutorial-overlay-backdrop" ||
                    className === "tutorial-overlay-backdrop-segment");

                const style = window.getComputedStyle(clickedElement);
                const rect = clickedElement.getBoundingClientRect();
                const coversViewport = rect.width >= window.innerWidth * 0.85 &&
                    rect.height >= window.innerHeight * 0.85;
                const isModalSurface = !isBackdrop &&
                    (style.position === "fixed" || coversViewport) &&
                    classNames.some(className =>
                        className.toLowerCase() === "modal" ||
                        className.toLowerCase().endsWith("-modal")) &&
                    clickedElement.querySelector(closeSelectors);

                if ((!isBackdrop && !isModalSurface) || ignoredBackdrop) {
                    return;
                }

                const isVisible = element => {
                    const elementStyle = window.getComputedStyle(element);
                    const elementRect = element.getBoundingClientRect();
                    return elementStyle.display !== "none" &&
                        elementStyle.visibility !== "hidden" &&
                        elementRect.width > 0 &&
                        elementRect.height > 0;
                };

                let modalScope = isModalSurface ? clickedElement : null;
                let sibling = clickedElement.nextElementSibling;

                while (!modalScope && sibling) {
                    if (isVisible(sibling) && sibling.querySelector(closeSelectors)) {
                        modalScope = sibling;
                        break;
                    }

                    sibling = sibling.nextElementSibling;
                }

                modalScope ||= clickedElement.parentElement;

                const localCandidates = Array.from(modalScope?.querySelectorAll(closeSelectors) || []);
                const globalCandidates = Array.from(document.querySelectorAll(closeSelectors));
                const closeButton = localCandidates.find(isVisible) ||
                    Array.from(modalScope?.querySelectorAll("button") || [])
                        .find(button => isVisible(button) && /^(cerrar|cancelar|salir)$/i.test(button.textContent.trim())) ||
                    globalCandidates.reverse().find(isVisible);

                closeButton?.click();
            }, true);

            window.numericaUi.__backdropDismissEnabled = true;
        };

        window.numericaUi.showAlert = async function (options) {
            const settings = typeof options === "string"
                ? { text: options }
                : (options || {});

            const icon = settings.icon || "info";
            const title = settings.title || (
                icon === "success" ? "Proceso completado" :
                icon === "error" ? "Revisa la información" :
                icon === "warning" ? "Atención" :
                "Información");

            const text = settings.text || "";
            const html = settings.html || null;

            if (window.Swal && typeof window.Swal.fire === "function") {
                window.numericaUi.patchSweetAlert();

                return await window.Swal.fire({
                    title,
                    text: html ? undefined : text,
                    html,
                    icon,
                    confirmButtonText: settings.confirmButtonText || "Entendido",
                    allowOutsideClick: settings.allowOutsideClick ?? true,
                    allowEscapeKey: settings.allowEscapeKey ?? true
                });
            }

            window.alert(text || title || "Mensaje");
            return null;
        };

        window.numericaUi.patchSweetAlert();
        window.numericaUi.enableBackdropDismiss();

        window.numericaUi.enableButtonLoadingFeedback = function () {
            if (window.numericaUi.__buttonLoadingFeedbackEnabled) {
                return;
            }

            const selector = [
                "button.primary-btn",
                "button.config-primary-btn",
                "button.refresh-btn",
                "button.n-btn-primary",
                "input.n-btn-primary[type='button']",
                "input.n-btn-primary[type='submit']",
                "button.btn.btn-primary",
                "button.btn.btn-success",
                "button.danger-btn",
                "button.ghost-danger-btn",
                "button.btn.btn-danger"
            ].join(", ");

            const blockedContainers = [
                ".actions-dropdown-content",
                ".action-dropdown-menu",
                ".session-profile-dropdown",
                ".role-menu-dropdown"
            ].join(", ");

            const markBusy = function (button, options) {
                const settings = options || {};

                if (!button || button.classList.contains("n-auto-loading") || button.dataset.noAutoLoading === "true") {
                    return;
                }

                if (blockedContainers && button.closest(blockedContainers)) {
                    return;
                }

                const parentForm = button.closest("form");
                const buttonType = (button.getAttribute("type") || "").toLowerCase();
                const isSubmitLike = buttonType === "submit" || (button.tagName === "BUTTON" && parentForm);

                if (button.disabled && settings.allowDisabledVisual !== true) {
                    return;
                }

                if (isSubmitLike && button.dataset.allowFormAutoLoading !== "true" && settings.allowDisabledVisual !== true) {
                    return;
                }

                button.classList.add("n-auto-loading");
                button.setAttribute("aria-busy", "true");

                if (button.tagName === "BUTTON" && !button.disabled && settings.disableButton !== false) {
                    button.dataset.autoLoadingDisabled = "true";
                    button.disabled = true;
                }

                window.setTimeout(function () {
                    if (!button || !button.isConnected) {
                        return;
                    }

                    button.classList.remove("n-auto-loading");
                    button.removeAttribute("aria-busy");

                    if (button.dataset.autoLoadingDisabled === "true") {
                        button.disabled = false;
                        delete button.dataset.autoLoadingDisabled;
                    }
                }, 2200);
            };

            document.addEventListener("click", function (event) {
                const button = event.target instanceof Element
                    ? event.target.closest(selector)
                    : null;

                if (!button) {
                    return;
                }

                const parentForm = button.closest("form");
                const buttonType = (button.getAttribute("type") || "").toLowerCase();
                const isSubmitLike = buttonType === "submit" || (button.tagName === "BUTTON" && parentForm);

                if (isSubmitLike && button.dataset.allowFormAutoLoading !== "true") {
                    window.setTimeout(function () {
                        if (!button || !button.isConnected || button.classList.contains("n-auto-loading")) {
                            return;
                        }

                        if (button.disabled || button.getAttribute("aria-busy") === "true") {
                            markBusy(button, { allowDisabledVisual: true, disableButton: false });
                        }
                    }, 120);
                    return;
                }

                if (button.dataset.allowAutoLoading === "true") {
                    window.setTimeout(function () {
                        markBusy(button);
                    }, 0);
                    return;
                }

                window.setTimeout(function () {
                    if (!button || !button.isConnected || button.classList.contains("n-auto-loading")) {
                        return;
                    }

                    if (button.disabled || button.getAttribute("aria-busy") === "true") {
                        markBusy(button, { allowDisabledVisual: true, disableButton: false });
                    }
                }, 120);
            });

            document.addEventListener("submit", function (event) {
                const submitter = event.submitter;

                if (!(submitter instanceof Element) || !submitter.matches(selector)) {
                    return;
                }

                window.setTimeout(function () {
                    if (submitter.disabled || submitter.getAttribute("aria-busy") === "true") {
                        markBusy(submitter, { allowDisabledVisual: true, disableButton: false });
                    }
                }, 120);
            });

            window.numericaUi.__buttonLoadingFeedbackEnabled = true;
        };

        window.numericaUi.enableButtonLoadingFeedback();

        window.numericaUi.downloadTextFile = function (fileName, content, mimeType) {
            const blob = new Blob([content ?? ""], {
                type: mimeType || "text/plain;charset=utf-8"
            });

            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.download = fileName || "reporte.txt";
            document.body.appendChild(link);
            link.click();
            link.remove();

            setTimeout(() => URL.revokeObjectURL(url), 0);
        };

        window.numericaUi.openPdfPreviewFromStream = async function (contentStreamReference) {
            if (!contentStreamReference) {
                return null;
            }

            const arrayBuffer = await contentStreamReference.arrayBuffer();
            const blob = new Blob([arrayBuffer], { type: "application/pdf" });
            const url = URL.createObjectURL(blob);
            return url;
        };

        window.numericaUi.revokeObjectUrl = function (url) {
            if (url) {
                URL.revokeObjectURL(url);
            }
        };

        window.numericaUi.readInputValue = function (selectorOrId) {
            if (!selectorOrId) {
                return "";
            }

            let element = null;
            if (selectorOrId.startsWith("#") || selectorOrId.startsWith(".") || selectorOrId.includes("[") || selectorOrId.includes(" ")) {
                element = document.querySelector(selectorOrId);
            } else {
                element = document.getElementById(selectorOrId);
            }

            if (!element || typeof element.value !== "string") {
                return "";
            }

            return element.value || "";
        };

        window.numericaUi.isSpeechRecognitionAvailable = function () {
            return !!(window.SpeechRecognition || window.webkitSpeechRecognition);
        };

        window.numericaUi.getMicrophonePermissionState = async function () {
            try {
                if (!navigator.permissions || typeof navigator.permissions.query !== "function") {
                    return "unknown";
                }

                const result = await navigator.permissions.query({ name: "microphone" });
                return result && result.state ? result.state : "unknown";
            } catch {
                return "unknown";
            }
        };

        window.numericaUi.startSpeechRecognition = function (dotNetRef, culture, phraseHints) {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

            if (!SpeechRecognition) {
                dotNetRef?.invokeMethodAsync("HandleSpeechError", "Tu navegador no soporta reconocimiento de voz.");
                return;
            }

            if (window.numericaUi.__speechRecognitionInstance) {
                try {
                    window.numericaUi.__speechRecognitionStoppedManually = true;
                    window.numericaUi.__speechRecognitionInstance.stop();
                } catch {
                }
            }

            const recognition = new SpeechRecognition();
            window.numericaUi.__speechRecognitionStoppedManually = false;
            window.numericaUi.__speechRecognitionLastError = null;
            recognition.lang = culture || "es-EC";
            recognition.interimResults = true;
            recognition.continuous = false;
            recognition.maxAlternatives = 1;

            if (Array.isArray(phraseHints) && phraseHints.length > 0) {
                if ("phrases" in recognition) {
                    try {
                        recognition.phrases = phraseHints
                            .filter(text => typeof text === "string" && text.trim().length > 1)
                            .slice(0, 100)
                            .map(text => ({ text: text.trim(), boost: 10.0 }));
                    } catch {
                    }
                }
            }

            let finalTranscript = "";

            recognition.onresult = function (event) {
                let interimTranscript = "";

                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const result = event.results[i];
                    const transcript = result[0]?.transcript || "";

                    if (result.isFinal) {
                        finalTranscript += transcript + " ";
                    } else {
                        interimTranscript += transcript;
                    }
                }

                const combined = (finalTranscript + interimTranscript).trim();
                if (combined) {
                    dotNetRef?.invokeMethodAsync("HandleSpeechPartial", combined);
                }
            };

            recognition.onerror = function (event) {
                window.numericaUi.__speechRecognitionLastError = event.error || null;
                const messages = {
                    "no-speech": "No detecté voz. Intenta otra vez.",
                    "audio-capture": "No pude acceder al micrófono.",
                    "not-allowed": "El navegador no tiene permiso para usar el micrófono.",
                    "network": "Hubo un problema de red con el reconocimiento de voz."
                };

                dotNetRef?.invokeMethodAsync("HandleSpeechError", messages[event.error] || "No pude transcribir el audio.");
            };

            recognition.onend = function () {
                const transcript = finalTranscript.trim();
                const manualStop = !!window.numericaUi.__speechRecognitionStoppedManually;
                const lastError = window.numericaUi.__speechRecognitionLastError;

                if (transcript) {
                    dotNetRef?.invokeMethodAsync("HandleSpeechFinal", transcript);
                } else if (!manualStop && lastError !== "no-speech") {
                    dotNetRef?.invokeMethodAsync("HandleSpeechEnd");
                }

                window.numericaUi.__speechRecognitionStoppedManually = false;
                window.numericaUi.__speechRecognitionLastError = null;
                window.numericaUi.__speechRecognitionInstance = null;
            };

            window.numericaUi.__speechRecognitionInstance = recognition;
            recognition.start();
        };

        window.numericaUi.stopSpeechRecognition = function () {
            const recognition = window.numericaUi.__speechRecognitionInstance;
            if (!recognition) {
                return;
            }

            try {
                window.numericaUi.__speechRecognitionStoppedManually = true;
                recognition.stop();
            } catch {
            }
        };

        window.numericaUi.scrollElementToBottom = function (element) {
            if (!element) {
                return;
            }

            element.scrollTop = element.scrollHeight;
        };

        window.numericaUi.openAsistenteFacturacion = function (query) {
            const panel = document.querySelector(".ia-fact-panel");
            if (!panel) {
                const launcher = document.querySelector(".ia-fact-fab");
                if (launcher) {
                    launcher.click();
                }
            }
            if (query === "soporte_faqs") {
                if (window.numericaUi.asistenteDotNetRef) {
                    window.numericaUi.asistenteDotNetRef.invokeMethodAsync("ActivarPreguntasSoporte");
                }
            } else if (query) {
                if (window.numericaUi.asistenteDotNetRef) {
                    window.numericaUi.asistenteDotNetRef.invokeMethodAsync("LimpiarPreguntasSoporte");
                }
                setTimeout(() => {
                    const input = document.querySelector(".ia-fact-footer input");
                    if (input) {
                        input.value = query;
                        input.dispatchEvent(new Event('input', { bubbles: true }));
                        input.focus();
                    }
                }, 150);
            } else {
                if (window.numericaUi.asistenteDotNetRef) {
                    window.numericaUi.asistenteDotNetRef.invokeMethodAsync("LimpiarPreguntasSoporte");
