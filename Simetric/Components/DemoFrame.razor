<style>
    .demo-shell {
        min-height: 100dvh;
        padding: 1.5rem;
        background:
            radial-gradient(circle at top left, rgba(0, 107, 181, 0.18), transparent 28rem),
            linear-gradient(180deg, #eef7fd 0%, #dbeaf5 100%);
        font-family: 'Montserrat', sans-serif;
        color: #22384b;
    }

    .demo-container {
        max-width: 1240px;
        margin: 0 auto;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.92);
        border-radius: 28px;
        box-shadow: 0 28px 60px rgba(16, 61, 98, 0.12);
        overflow: hidden;
        backdrop-filter: blur(14px);
    }

    .demo-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 1.35rem 1.5rem;
        background: linear-gradient(135deg, #006bb5, #004a7c);
        color: #fff;
    }

    .demo-brand {
        display: flex;
        gap: 0.9rem;
        align-items: center;
    }

    .demo-brand-badge {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: rgba(255,255,255,0.14);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,255,255,0.18);
    }

    .demo-brand-badge i {
        font-size: 1.4rem;
    }

    .demo-brand-copy h1 {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 800;
    }

    .demo-brand-copy p {
        margin: 0.2rem 0 0;
        color: rgba(255,255,255,0.82);
        font-size: 0.92rem;
    }

    .demo-mode-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.14);
        border: 1px solid rgba(255,255,255,0.2);
        font-weight: 700;
        white-space: nowrap;
    }

    .demo-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 1rem 1.5rem 0;
    }

    .demo-nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.65rem 0.9rem;
        border-radius: 999px;
        border: 1px solid #d9e7f1;
        color: #36546b;
        text-decoration: none;
        font-weight: 700;
        background: #fff;
    }

    .demo-nav-link.active {
        background: #e8f4fb;
        border-color: #9dcdea;
        color: #0c5d97;
    }

    .demo-banner {
        margin: 1rem 1.5rem 0;
        padding: 1rem 1.1rem;
        border-radius: 18px;
        background: #fff6e9;
        border: 1px solid #f5d7a1;
        display: flex;
        gap: 0.8rem;
        align-items: flex-start;
    }

    .demo-banner i {
        font-size: 1.15rem;
        color: #b97910;
        margin-top: 0.1rem;
    }

    .demo-banner strong,
    .demo-banner p {
        display: block;
        margin: 0;
    }

    .demo-banner p {
        color: #70583a;
        font-size: 0.93rem;
        margin-top: 0.18rem;
    }

    .demo-content {
        padding: 1.25rem 1.5rem 1.5rem;
    }

    .demo-footer {
        padding: 0 1.5rem 1.4rem;
        color: #6d7f90;
        font-size: 0.88rem;
    }

    @@media (max-width: 760px) {
        .demo-shell {
            padding: 0.75rem;
        }

        .demo-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="demo-shell">
    <div class="demo-container">
        <header class="demo-header">
            <div class="demo-brand">
                <span class="demo-brand-badge">
                    <i class="ri-eye-line"></i>
                </span>
                <div class="demo-brand-copy">
                    <h1>@Title</h1>
                    <p>@Subtitle</p>
                </div>
            </div>

            <span class="demo-mode-pill">
                <i class="ri-shield-star-line"></i>
                Modo invitado solo lectura
            </span>
        </header>

        <nav class="demo-nav">
            <NavLink href="/demo/portal" class="demo-nav-link" Match="NavLinkMatch.All">
                <i class="ri-apps-line"></i> Portal
            </NavLink>
            <NavLink href="/demo/dashboard" class="demo-nav-link" Match="NavLinkMatch.All">
                <i class="ri-dashboard-line"></i> Dashboard
            </NavLink>
            <NavLink href="/demo/facturas/nueva" class="demo-nav-link" Match="NavLinkMatch.All">
                <i class="ri-file-add-line"></i> Nueva factura
            </NavLink>
            <NavLink href="/demo/documentos" class="demo-nav-link" Match="NavLinkMatch.All">
                <i class="ri-file-list-3-line"></i> Documentos
            </NavLink>
            <NavLink href="/demo/recargas" class="demo-nav-link" Match="NavLinkMatch.All">
                <i class="ri-coins-line"></i> Recargas
            </NavLink>
            <NavLink href="/demo/soporte" class="demo-nav-link" Match="NavLinkMatch.All">
                <i class="ri-customer-service-2-line"></i> Soporte
            </NavLink>
            <a href="/login" class="demo-nav-link">
                <i class="ri-login-box-line"></i> Volver al login
            </a>
        </nav>

        <section class="demo-banner">
            <i class="ri-information-line"></i>
            <div>
                <strong>Esta experiencia no emite, no guarda y no modifica información real.</strong>
                <p>Todo lo que ves aquí es una maqueta funcional con datos de ejemplo para que el invitado entienda el flujo del sistema sin riesgo operativo.</p>
            </div>
        </section>

        <main class="demo-content">
            @ChildContent
        </main>

        <footer class="demo-footer">
            Acceso de invitado pensado para recorrido comercial, capacitación inicial y demostraciones sin impacto en producción.
        </footer>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
